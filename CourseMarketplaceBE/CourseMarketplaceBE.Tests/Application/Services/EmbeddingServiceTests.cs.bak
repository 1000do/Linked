        //Assert
        result.Should().Be("media");
    }

    [Fact]
    public void GetEmbeddingType_TypeNotSetAndDimIsText_ReturnsText()
    {
        //Arrange 1
        var method = typeof(EmbeddingService).GetMethod("GetEmbeddingType", BindingFlags.NonPublic | BindingFlags.Instance);
        var cachedResponse = new MaterialEmbeddingResponse 
        { 
            EmbeddingType = null,
            Embedding = new List<float> { 0.1f } // less than MediaEmbeddingDim
        };

        //Arrange 2

        //Act
        var result = (string)method.Invoke(_sut, new object[] { cachedResponse });

        //Assert
        result.Should().Be("text");
    }

    [Fact]
    public async Task SaveMediaEmbeddingAsync_ExistingFound_UpdatesEmbedding()
    {
        //Arrange 1
        var method = typeof(EmbeddingService).GetMethod("SaveMediaEmbeddingAsync", BindingFlags.NonPublic | BindingFlags.Instance);
        var existingEntity = new MediaEmbedding { MediaEmbeddingId = 1, Embedding = new List<float>() };
        var newEmbedding = new List<float> { 0.9f };

        //Arrange 2
        _mediaEmbeddingRepositoryMock.GetByMaterialIdAsync(1).Returns(new List<MediaEmbedding> { existingEntity });
        _mediaEmbeddingRepositoryMock.SaveChangesAsync().Returns(1);

        //Act
        var result = await (Task<int>)method.Invoke(_sut, new object[] { 1, newEmbedding });

        //Assert
        result.Should().Be(1);
        _mediaEmbeddingRepositoryMock.Received(1).Update(existingEntity);
        existingEntity.Embedding.Should().BeEquivalentTo(newEmbedding);
        await _mediaEmbeddingRepositoryMock.DidNotReceive().AddAsync(Arg.Any<MediaEmbedding>());
    }

    [Fact]
    public async Task SaveMediaEmbeddingAsync_ExistingNotFound_AddsNewEntity()
    {
        //Arrange 1
        var method = typeof(EmbeddingService).GetMethod("SaveMediaEmbeddingAsync", BindingFlags.NonPublic | BindingFlags.Instance);
        var newEmbedding = new List<float> { 0.9f };

        //Arrange 2
        _mediaEmbeddingRepositoryMock.GetByMaterialIdAsync(1).Returns(new List<MediaEmbedding>());
        _mediaEmbeddingRepositoryMock.SaveChangesAsync().Returns(1);

        //Act
        var result = await (Task<int>)method.Invoke(_sut, new object[] { 1, newEmbedding });

        //Assert
        result.Should().Be(1);
        await _mediaEmbeddingRepositoryMock.Received(1).AddAsync(Arg.Is<MediaEmbedding>(e => e.MaterialId == 1 && e.Embedding == newEmbedding));
        _mediaEmbeddingRepositoryMock.DidNotReceive().Update(Arg.Any<MediaEmbedding>());
    }

    [Fact]
    public async Task SaveMediaEmbeddingChangesAsync_Success_ReturnsRowsAffected()
    {
        //Arrange 1
        var method = typeof(EmbeddingService).GetMethod("SaveMediaEmbeddingChangesAsync", BindingFlags.NonPublic | BindingFlags.Instance);

        //Arrange 2
        _mediaEmbeddingRepositoryMock.SaveChangesAsync().Returns(5);

        //Act
        var result = await (Task<int>)method.Invoke(_sut, null);

        //Assert
        result.Should().Be(5);
    }

    [Fact]
    public async Task SaveMediaEmbeddingChangesAsync_RepositoryThrowsMediaEmbeddingException_ThrowsBadRequestException()
    {
        //Arrange 1
        var method = typeof(EmbeddingService).GetMethod("SaveMediaEmbeddingChangesAsync", BindingFlags.NonPublic | BindingFlags.Instance);

        //Arrange 2
        _mediaEmbeddingRepositoryMock.SaveChangesAsync().Throws(new MediaEmbeddingException("err"));

        //Act
        Func<Task> act = async () => await (Task<int>)method.Invoke(_sut, null);

        //Assert
        await act.Should().ThrowAsync<BadRequestException>().WithMessage("err");
    }

