                                <th class="p-4 text-xs font-bold text-slate-400 uppercase w-[25%]">Người nhận</th>
                                <th class="p-4 text-xs font-bold text-slate-400 uppercase w-[45%]">Nội dung</th>
                                <th class="p-4 text-xs font-bold text-slate-400 uppercase w-[20%]">Thời gian</th>
                                <th class="p-4 text-xs font-bold text-slate-400 uppercase w-[10%] text-center">Trạng thái</th>
