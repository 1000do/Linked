@using System.Net
@{
    ViewData["Title"] = "Notification Settings";
    ViewData["PageHeader"] = "System Notifications";
    Layout = "_AdminLayout";

    var token = Context.Request.Cookies["AccessToken"] ?? "";
}

@section HeaderActions {
    <button onclick="openModal()" class="flex items-center gap-2 px-3 py-1.5 bg-primary hover:bg-secondary text-white text-sm font-medium rounded-md transition-colors shadow-sm">
        <span class="material-symbols-outlined text-[18px]">add</span>
        Create Notification
    </button>
}

<div class="bg-white border border-slate-200 rounded-lg shadow-sm flex flex-col h-[calc(100vh-8rem)]">
    <!-- Tabs Bar -->
    <div class="flex border-b border-slate-200 overflow-x-auto gap-2 bg-slate-50/30 p-3 shrink-0">
        <button type="button" onclick="switchRoleTab('all')" id="tab-all" 
                class="tab-btn px-4 py-2 text-xs md:text-sm font-semibold rounded-xl transition-all whitespace-nowrap bg-slate-900 text-white shadow-sm" data-role="all">
            All Notifications
        </button>
        <button type="button" onclick="switchRoleTab('student')" id="tab-student" 
                class="tab-btn px-4 py-2 text-xs md:text-sm font-semibold rounded-xl transition-all whitespace-nowrap text-slate-600 hover:bg-slate-100 hover:text-slate-900" data-role="student">
            Students
        </button>
        <button type="button" onclick="switchRoleTab('instructor')" id="tab-instructor" 
                class="tab-btn px-4 py-2 text-xs md:text-sm font-semibold rounded-xl transition-all whitespace-nowrap text-slate-600 hover:bg-slate-100 hover:text-slate-900" data-role="instructor">
            Instructors
        </button>
        <button type="button" onclick="switchRoleTab('staff-admin')" id="tab-staff-admin" 
                class="tab-btn px-4 py-2 text-xs md:text-sm font-semibold rounded-xl transition-all whitespace-nowrap text-slate-600 hover:bg-slate-100 hover:text-slate-900" data-role="staff-admin">
            Staff & Admin
        </button>
    </div>

    <!-- Controls Bar -->
    <div class="p-4 border-b border-slate-200 bg-slate-50/50 flex flex-col md:flex-row items-center gap-4 shrink-0">
        <!-- Search Input -->
        <div class="relative w-full md:w-80 shrink-0">
            <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-[18px]">search</span>
            <input type="text" id="search-input" placeholder="Search by recipient, title, content..."
                   class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all shadow-sm bg-white" />
        </div>

        <div class="flex flex-wrap items-center gap-3 w-full md:w-auto md:ml-auto">

            <!-- Filter Status Select -->
            <div class="relative w-full sm:w-40">
                <select id="filter-status" class="w-full appearance-none pl-3.5 pr-10 py-2 border border-slate-200 rounded-xl text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-slate-700 cursor-pointer shadow-sm">
                    <option value="all">All Statuses</option>
                    <option value="unread">Unread</option>
                    <option value="read">Read</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[18px]">arrow_drop_down</span>
            </div>

            <!-- Sort Select -->
            <div class="relative w-full sm:w-48">
                <select id="sort-select" class="w-full appearance-none pl-3.5 pr-10 py-2 border border-slate-200 rounded-xl text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-slate-700 cursor-pointer shadow-sm">
                    <option value="newest">Newest First</option>
                    <option value="oldest">Oldest First</option>
                    <option value="title-asc">Title (A - Z)</option>
                    <option value="title-desc">Title (Z - A)</option>
                    <option value="recipient-asc">Recipient (A - Z)</option>
                    <option value="recipient-desc">Recipient (Z - A)</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[18px]">arrow_drop_down</span>
            </div>

            <!-- Reset Button -->
            <button type="button" id="btn-reset" class="w-full sm:w-auto px-4 py-2 border border-slate-200 text-sm font-semibold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl transition-all flex items-center justify-center gap-1.5 shrink-0 shadow-sm">
                <span class="material-symbols-outlined text-[18px]">filter_alt_off</span>
                Reset
            </button>
        </div>
    </div>

    <div class="flex-1 overflow-auto">
        <table class="w-full text-left border-collapse">
            <thead class="sticky top-0 bg-slate-50/90 backdrop-blur-sm z-10 border-b border-slate-200">
                <tr>
                    <th class="px-5 py-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider w-[25%]">Recipient</th>
                    <th class="px-5 py-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider w-[45%]">Message Content</th>
                    <th class="px-5 py-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider w-[20%]">Timestamp</th>
                    <th class="px-5 py-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider w-[10%] text-center">Status</th>
                </tr>
            </thead>
            <tbody id="admin-table-body" class="divide-y divide-slate-100 text-sm">
                <!-- Data populated by JS -->
            </tbody>
        </table>
    </div>

    <div class="px-5 py-3 border-t border-slate-200 bg-slate-50 flex items-center justify-between shrink-0">
        <div class="text-xs font-medium text-slate-500" id="pagination-info">Loading...</div>
        <div class="flex items-center gap-1" id="pagination-controls"></div>
    </div>
</div>

<!-- Modal Send Notification -->
<div id="modal-send" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/30 backdrop-blur-sm transition-opacity" onclick="closeModal()"></div>

    <div class="bg-white w-full max-w-lg rounded-xl shadow-xl relative z-10 flex flex-col overflow-hidden border border-slate-200">
        <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h3 class="font-semibold text-slate-900">Compose New Notification</h3>
            <button type="button" onclick="closeModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>

        <form id="form-advanced" class="p-5 space-y-5">
            <div class="space-y-1.5">
                <label class="text-xs font-medium text-slate-700">Recipient Group</label>
                <select id="targetType" onchange="toggleEmailInput()" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-shadow">
                    <option value="SINGLE">Specific User (Email)</option>
                    <option value="ALL">Broadcast (All Users)</option>
                </select>
            </div>

            <div id="email-section" class="relative space-y-1.5">
                <label class="text-xs font-medium text-slate-700">Recipient Email(s)</label>
                <div id="tag-box" class="flex flex-wrap gap-1.5 p-2 border border-slate-300 rounded-md min-h-[42px] bg-white focus-within:ring-2 focus-within:ring-primary/20 focus-within:border-primary transition-shadow cursor-text" onclick="document.getElementById('emailInput').focus()">
                    <input type="text" id="emailInput" class="flex-1 bg-transparent border-none text-sm outline-none px-1 min-w-[150px]" placeholder="Type email addresses...">
                </div>
                <div id="suggestions" class="hidden absolute left-0 right-0 top-full mt-1 bg-white border border-slate-200 shadow-lg rounded-md z-20 max-h-48 overflow-y-auto py-1"></div>
            </div>

            <div class="space-y-1.5">
                <label class="text-xs font-medium text-slate-700">Message Details</label>
                <input type="text" id="title" maxlength="255" required class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-shadow mb-3" placeholder="Message Title...">
                <textarea id="content" rows="4" required class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-shadow resize-none mb-3" placeholder="Write message details..."></textarea>
            </div>

            <div class="space-y-1.5">
                <label class="text-xs font-medium text-slate-700">Link Action (Optional)</label>
                <input type="text" id="linkAction" maxlength="500" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-shadow" placeholder="https://... or /Course/Details/123">
            </div>

            <div class="pt-2 flex justify-end gap-2 border-t border-slate-100">
                <button type="button" onclick="closeModal()" class="px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 rounded-md transition-colors">
                    Cancel
                </button>
                <button type="submit" id="btnSubmit" class="px-4 py-2 text-sm font-medium bg-primary hover:bg-secondary text-white rounded-md transition-colors shadow-sm">
                    Send Notification
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal View Notification Detail -->
<div id="modal-detail" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/30 backdrop-blur-sm transition-opacity" onclick="closeDetailModal()"></div>
    <div class="bg-white w-full max-w-lg rounded-xl shadow-xl relative z-10 flex flex-col overflow-hidden border border-slate-200">
        <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <div class="flex items-center gap-2 text-teal-700">
                <span class="material-symbols-outlined text-[20px]">info</span>
                <span class="font-bold uppercase text-[11px] tracking-widest text-teal-700">Notification Details</span>
            </div>
            <button type="button" onclick="closeDetailModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
        <div class="p-6 space-y-4 text-left">
            <div>
                <label class="text-[11px] uppercase tracking-wider font-semibold text-slate-400">Recipient</label>
                <div id="detail-recipient" class="text-sm font-medium text-slate-800 break-all"></div>
            </div>
            <div>
                <label class="text-[11px] uppercase tracking-wider font-semibold text-slate-400">Title</label>
                <h3 id="detail-title" class="text-base font-bold text-slate-900 leading-tight break-all"></h3>
            </div>
            <div>
                <label class="text-[11px] uppercase tracking-wider font-semibold text-slate-400">Content</label>
                <div class="bg-slate-50 p-4 rounded-lg border border-slate-100 mt-1">
                    <p id="detail-content" class="text-sm text-slate-600 leading-relaxed whitespace-pre-wrap break-words"></p>
                </div>
            </div>
            <div id="detail-link-container" class="hidden">
                <label class="text-[11px] uppercase tracking-wider font-semibold text-slate-400">Action Link</label>
                <div class="mt-1">
                    <a id="detail-link" href="#" target="_blank" class="text-sm font-medium text-emerald-600 hover:text-emerald-700 underline break-all"></a>
                </div>
            </div>
            <div class="flex justify-between items-center text-xs text-slate-400 pt-2 border-t border-slate-100">
                <span id="detail-time"></span>
                <span id="detail-status" class="font-semibold"></span>
            </div>
        </div>
        <div class="px-5 py-3 bg-slate-50 border-t border-slate-100 flex justify-end">
            <button type="button" onclick="closeDetailModal()" class="px-4 py-2 bg-white border border-slate-200 text-slate-600 font-semibold rounded-lg hover:bg-slate-100 transition-all text-xs">
                Close
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_URL = "/Notification";
        const TOKEN = `@Html.Raw(token)`;

        let currentPage = 1;
        const pageSize = 10;
        let allNotifications = [];
        let filteredNotifications = [];
        let selectedEmails = [];
        let activeRoleTab = 'all';

        function formatDateTime(dateString) {
            const date = new Date(dateString);
            return date.toLocaleString('en-US', {
                hour: '2-digit', minute: '2-digit',
                day: '2-digit', month: '2-digit', year: 'numeric',
                hour12: false
            });
        }



        async function loadHistory() {
            try {
                const res = await fetch(`${API_URL}/GetAllAdmin`);
                if (res.ok) {
                    const apiResp = await res.json();
                    allNotifications = apiResp.data?.items || [];
                    applyFilters();
                }
            } catch (err) { console.error(err); }
        }

        function switchRoleTab(role) {
            activeRoleTab = role;
            
            document.querySelectorAll('.tab-btn').forEach(btn => {
                if (btn.getAttribute('data-role') === role) {
                    btn.classList.add('bg-slate-900', 'text-white', 'shadow-sm');
                    btn.classList.remove('text-slate-600', 'hover:bg-slate-100', 'hover:text-slate-900');
                } else {
                    btn.classList.remove('bg-slate-900', 'text-white', 'shadow-sm');
                    btn.classList.add('text-slate-600', 'hover:bg-slate-100', 'hover:text-slate-900');
                }
            });

            applyFilters();
        }

        function applyFilters() {
            const searchVal = document.getElementById('search-input').value.toLowerCase().trim();
            const statusVal = document.getElementById('filter-status').value;
            const sortVal = document.getElementById('sort-select').value;

            filteredNotifications = [...allNotifications];

            // 1. Filter Role Tab
            if (activeRoleTab === 'broadcast') {
                filteredNotifications = filteredNotifications.filter(n => n.receiverRole === 'broadcast');
            } else if (activeRoleTab === 'student') {
                filteredNotifications = filteredNotifications.filter(n => n.receiverRole === 'student');
            } else if (activeRoleTab === 'instructor') {
                filteredNotifications = filteredNotifications.filter(n => n.receiverRole === 'instructor');
            } else if (activeRoleTab === 'staff-admin') {
                filteredNotifications = filteredNotifications.filter(n => n.receiverRole === 'staff' || n.receiverRole === 'admin');
            }

            // 2. Search
            if (searchVal) {
                filteredNotifications = filteredNotifications.filter(n =>
                    (n.receiverFullName && n.receiverFullName.toLowerCase().includes(searchVal)) ||
                    (n.receiverEmail && n.receiverEmail.toLowerCase().includes(searchVal)) ||
                    (n.title && n.title.toLowerCase().includes(searchVal)) ||
                    (n.content && n.content.toLowerCase().includes(searchVal))
                );
            }

            // 3. Filter Status
            if (statusVal === 'read') {
                filteredNotifications = filteredNotifications.filter(n => n.isRead);
            } else if (statusVal === 'unread') {
                filteredNotifications = filteredNotifications.filter(n => !n.isRead);
            }

            // 4. Sorting
            if (sortVal === 'newest') {
                filteredNotifications.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
            } else if (sortVal === 'oldest') {
                filteredNotifications.sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt));
            } else if (sortVal === 'title-asc') {
                filteredNotifications.sort((a, b) => (a.title || '').localeCompare(b.title || '', 'en'));
            } else if (sortVal === 'title-desc') {
                filteredNotifications.sort((a, b) => (b.title || '').localeCompare(a.title || '', 'en'));
            } else if (sortVal === 'recipient-asc') {
                filteredNotifications.sort((a, b) => {
                    const nameA = a.receiverFullName || 'System Broadcast';
                    const nameB = b.receiverFullName || 'System Broadcast';
                    return nameA.localeCompare(nameB, 'en');
                });
            } else if (sortVal === 'recipient-desc') {
                filteredNotifications.sort((a, b) => {
                    const nameA = a.receiverFullName || 'System Broadcast';
                    const nameB = b.receiverFullName || 'System Broadcast';
                    return nameB.localeCompare(nameA, 'en');
                });
            }

            currentPage = 1;
            renderTable();
        }

        function renderTable() {
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;
            const pagedData = filteredNotifications.slice(start, end);
            const tbody = document.getElementById('admin-table-body');

            if (pagedData.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" class="px-5 py-12 text-center">
                    <div class="flex flex-col items-center justify-center text-slate-400">
                        <span class="material-symbols-outlined text-4xl mb-2 text-slate-300">inbox</span>
                        <p class="text-sm">No notifications found matching your filters</p>
                    </div>
                </td></tr>`;
                updatePaginationInfo(0, 0, 0);
                renderPaginationControls();
                return;
            }

            tbody.innerHTML = pagedData.map(n => `
                <tr class="hover:bg-slate-50/50 cursor-pointer transition-colors" onclick="showDetail(${n.notificationId})">
                    <td class="px-5 py-3 align-top">
                        <div class="font-medium text-slate-900 truncate">${n.receiverFullName || 'System Broadcast'}</div>
                        <div class="text-xs text-slate-500 truncate mt-0.5">${n.receiverEmail || 'all-users@system.com'}</div>
                    </td>
                    <td class="px-5 py-3 align-top">
                        <div class="font-medium text-slate-900">${n.title && n.title.length > 100 ? n.title.substring(0, 100) + '...' : n.title}</div>
                        <div class="text-xs text-slate-600 mt-0.5">${n.content && n.content.length > 100 ? n.content.substring(0, 100) + '...' : n.content}</div>
                    </td>
                    <td class="px-5 py-3 align-top text-xs text-slate-500 whitespace-nowrap">
                        ${formatDateTime(n.createdAt)}
                    </td>
                    <td class="px-5 py-3 align-top text-center">
                        ${n.isRead
                            ? `<span class="inline-flex items-center gap-1 text-[11px] font-medium text-slate-500"><span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span> Read</span>`
                            : `<span class="inline-flex items-center gap-1 text-[11px] font-medium text-emerald-600"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Unread</span>`
                        }
                    </td>
                </tr>
            `).join('');

            updatePaginationInfo(start + 1, Math.min(end, filteredNotifications.length), filteredNotifications.length);
            renderPaginationControls();
        }

        function updatePaginationInfo(start, end, total) {
            document.getElementById('pagination-info').innerText = total > 0 ? `${start} - ${end} of ${total}` : 'No data available';
        }

        function renderPaginationControls() {
            const totalPages = Math.ceil(filteredNotifications.length / pageSize);
            const container = document.getElementById('pagination-controls');
            let html = `<button type="button" onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} class="p-1 text-slate-500 hover:text-slate-900 disabled:opacity-30 disabled:hover:text-slate-500 transition-colors"><span class="material-symbols-outlined text-[18px]">chevron_left</span></button>`;

            html += `<span class="text-xs font-medium text-slate-700 px-2">${currentPage} / ${totalPages || 1}</span>`;

            html += `<button type="button" onclick="changePage(${currentPage + 1})" ${currentPage === totalPages || totalPages === 0 ? 'disabled' : ''} class="p-1 text-slate-500 hover:text-slate-900 disabled:opacity-30 disabled:hover:text-slate-500 transition-colors"><span class="material-symbols-outlined text-[18px]">chevron_right</span></button>`;
            container.innerHTML = html;
        }

        function changePage(page) {
            currentPage = page;
            renderTable();
        }

        const emailInput = document.getElementById('emailInput');
        const suggestions = document.getElementById('suggestions');

        emailInput.addEventListener('input', async (e) => {
            const query = e.target.value.trim();
            if (query.length < 1) { suggestions.classList.add('hidden'); return; }
            try {
                const res = await fetch(`${API_URL}/SearchEmails?query=${query}`);
                const apiResp = await res.json();
                const data = apiResp.data || [];
                if (data.length > 0) {
                    suggestions.innerHTML = data.filter(m => !selectedEmails.includes(m))
                        .map(m => `<div class="px-3 py-2 text-sm text-slate-700 hover:bg-slate-50 cursor-pointer" onclick="addTag('${m}')">${m}</div>`).join('');
                    suggestions.classList.remove('hidden');
                } else { suggestions.classList.add('hidden'); }
            } catch (err) { console.error(err); }
        });

        function addTag(email) {
            if (!selectedEmails.includes(email)) { selectedEmails.push(email); renderTags(); }
            emailInput.value = '';
            suggestions.classList.add('hidden');
            emailInput.focus();
        }

        function renderTags() {
            const box = document.getElementById('tag-box');
            box.querySelectorAll('.email-pill').forEach(el => el.remove());
            selectedEmails.forEach((email, idx) => {
                const pill = document.createElement('span');
                pill.className = "email-pill bg-slate-100 border border-slate-200 text-slate-700 text-xs font-medium px-2 py-0.5 rounded flex items-center gap-1 select-none";
                pill.innerHTML = `${email} <button type="button" onclick="removeTag(${idx})" class="text-slate-400 hover:text-slate-600 transition-colors material-symbols-outlined text-[14px]">close</button>`;
                box.insertBefore(pill, emailInput);
            });
        }

        function removeTag(idx) { selectedEmails.splice(idx, 1); renderTags(); emailInput.focus(); }

        function toggleEmailInput() {
            const type = document.getElementById('targetType').value;
            const section = document.getElementById('email-section');
            if (type === 'ALL') section.classList.add('hidden');
            else section.classList.remove('hidden');
        }

        function openModal() {
            document.getElementById('form-advanced').reset();
            selectedEmails = [];
            renderTags();
            toggleEmailInput();


            const modal = document.getElementById('modal-send');
            modal.classList.remove('hidden');
            setTimeout(() => emailInput.focus(), 100);
        }

        function decodeToken(token) {
            try {
                const base64Url = token.split('.')[1];
                const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));
                console.log("Decoded token: " + jsonPayload);
                return JSON.parse(jsonPayload);
            } catch (e) {
                console.error("Failed to decode token", e);
                return null;
            }
        }

        function closeModal() { document.getElementById('modal-send').classList.add('hidden'); }

        async function showDetail(id) {
            const noti = allNotifications.find(n => n.notificationId === id);
            if (!noti) return;

            document.getElementById('detail-recipient').innerText = `${noti.receiverFullName || 'System Broadcast'} (${noti.receiverEmail || 'all-users@system.com'})`;
            document.getElementById('detail-title').innerText = noti.title;
            document.getElementById('detail-content').innerText = noti.content;
            
            const linkContainer = document.getElementById('detail-link-container');
            const linkAnchor = document.getElementById('detail-link');
            if (noti.linkAction) {
                linkAnchor.href = noti.linkAction;
                linkAnchor.innerText = noti.linkAction;
                linkContainer.classList.remove('hidden');
            } else {
                linkContainer.classList.add('hidden');
            }

            document.getElementById('detail-time').innerText = `Created at: ${formatDateTime(noti.createdAt)}`;
            document.getElementById('detail-status').innerHTML = noti.isRead 
                ? `<span class="inline-flex items-center gap-1 text-[11px] font-medium text-slate-500"><span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span> Read</span>` 
                : `<span class="inline-flex items-center gap-1 text-[11px] font-medium text-emerald-600"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Unread</span>`;

            document.getElementById('modal-detail').classList.remove('hidden');

            const decoded = decodeToken(TOKEN);
            const currentUserId = decoded ? parseInt(decoded["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"] || decoded["nameid"]) : null;
            const currentUserRole = decoded ? (decoded["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || decoded["role"]) : null;
            console.log("Current User ID: " + currentUserId);
            console.log("Current User Role: " + currentUserRole);
            console.log("Notification Receiver ID: " + noti.receiverId);
            console.log("Notification Receiver Role: " + noti.receiverRole);
            console.log("Notification Sender ID: " + noti.senderId);
            console.log("Notification Sender Role: " + noti.senderRole);
            console.log("Notification Is Read: " + noti.isRead);

            // Staff viewing a notification addressed to them → mark as read
            if (currentUserRole === 'staff' && 
                noti.receiverId === currentUserId && 
                !noti.isRead) {
                
                try {
                    const res = await fetch(`${API_URL}/MarkAsRead/${id}`, {
                        method: 'PUT'
                    });
                    if (res.ok) {
                        noti.isRead = true;
                        document.getElementById('detail-status').innerHTML = `<span class="inline-flex items-center gap-1 text-[11px] font-medium text-slate-500"><span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span> Read</span>`;
                        applyFilters();
                    }
                } catch (err) {
                    console.error("Failed to sync read state for staff", err);
                }
            }
        }

        function closeDetailModal() {
            document.getElementById('modal-detail').classList.add('hidden');
        }

        document.getElementById('form-advanced').onsubmit = async (e) => {
            e.preventDefault();
            const type = document.getElementById('targetType').value;
            if (type === 'SINGLE' && selectedEmails.length === 0) {
                Swal.fire({
                    title: 'Missing Field',
                    text: "Please select at least one recipient email.",
                    icon: 'warning',
                    confirmButtonColor: '#10b981',
                    background: '#ffffff',
                    customClass: { popup: 'rounded-2xl shadow-xl' }
                });
                return;
            }

            const decoded = decodeToken(TOKEN);
            const senderEmail = decoded ? (decoded["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress"] || decoded["email"]) : null;

            if (type === 'SINGLE' && senderEmail && selectedEmails.includes(senderEmail)) {
                Swal.fire({
                    title: 'Invalid Recipient',
                    text: "You cannot send a notification to yourself.",
                    icon: 'warning',
                    confirmButtonColor: '#10b981',
                    background: '#ffffff',
                    customClass: { popup: 'rounded-2xl shadow-xl' }
                });
                return;
            }

            const btn = document.getElementById('btnSubmit');
            const originalText = btn.innerText;
            btn.disabled = true; btn.innerText = "Sending...";

            try {
                const res = await fetch(`${API_URL}/SendAdvanced`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        targetType: type,
                        emails: selectedEmails,
                        title: document.getElementById('title').value,
                        content: document.getElementById('content').value,
                        linkAction: document.getElementById('linkAction').value || null
                    })
                });

                if (res.ok) {
                    Swal.fire({
                        title: 'Sent Successfully!',
                        text: 'The notification was broadcasted to recipients successfully.',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false,
                        background: '#ffffff',
                        customClass: { popup: 'rounded-2xl shadow-xl' }
                    });
                    closeModal();
                    loadHistory();
                } else {
                    let errMsg = "An error occurred while sending.";
                    try {
                        const errData = await res.json();
                        if (errData && errData.message) errMsg = errData.message;
                        else if (errData && typeof errData === 'string') errMsg = errData;
                    } catch (e) {
                        try {
                            const errText = await res.text();
                            if (errText) errMsg = errText;
                        } catch (e2) {}
                    }
                    Swal.fire({
                        title: 'Send Error',
                        text: errMsg,
                        icon: 'error',
                        confirmButtonColor: '#10b981',
                        background: '#ffffff',
                        customClass: { popup: 'rounded-2xl shadow-xl' }
                    });
                }
            } catch (err) {
                Swal.fire({
                    title: 'Connection Failure',
                    text: "Failed to establish connection to the notification server.",
                    icon: 'error',
                    confirmButtonColor: '#10b981',
                    background: '#ffffff',
                    customClass: { popup: 'rounded-2xl shadow-xl' }
                });
            }
            btn.disabled = false; btn.innerText = originalText;
        };

        document.addEventListener("ReceiveNotificationEvent", () => loadHistory());

        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('search-input').addEventListener('input', applyFilters);
            document.getElementById('filter-status').addEventListener('change', applyFilters);
            document.getElementById('sort-select').addEventListener('change', applyFilters);
            document.getElementById('btn-reset').addEventListener('click', () => {
                document.getElementById('search-input').value = '';
                document.getElementById('filter-status').value = 'all';
                document.getElementById('sort-select').value = 'newest';
                switchRoleTab('all');
            });

            loadHistory();
        });
    </script>
}