    <div id="modal-send" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-slate-900/20 backdrop-blur-sm" onclick="closeModal()"></div>
        <div class="bg-white w-full max-w-lg rounded-2xl border border-border relative z-10 flex flex-col overflow-hidden no-shadow">
            <div class="p-6 border-b border-border flex justify-between items-center bg-emerald-50/50">
                <h3 class="font-bold text-emerald-900">Soạn thông báo mới</h3>
                <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form id="form-advanced" class="p-6 space-y-4">
                <div>
                    <label class="text-[10px] font-bold text-slate-400 uppercase block mb-1">Cấu hình đối tượng</label>
                    <select id="targetType" onchange="toggleEmailInput()" class="w-full border border-border rounded-lg px-3 py-2.5 text-sm focus:border-primary outline-none bg-slate-50">
                        <option value="SINGLE">Gửi theo danh sách Email</option>
                        <option value="ALL">Gửi toàn bộ thành viên</option>
                    </select>
                </div>

                <div id="email-section" class="relative">
                    <label class="text-[10px] font-bold text-slate-400 uppercase block mb-1">Người nhận (Tag Email)</label>
                    <div id="tag-box" class="flex flex-wrap gap-2 p-2 border border-border rounded-lg min-h-[46px] bg-slate-50 focus-within:bg-white focus-within:border-primary transition-all">
                        <input type="text" id="emailInput" class="flex-1 bg-transparent border-none text-sm outline-none px-1" placeholder="Nhập email và chọn...">
                    </div>
                    <div id="suggestions" class="hidden absolute left-0 right-0 top-full mt-1 bg-white border border-border rounded-lg z-20 max-h-40 overflow-auto no-shadow"></div>
                </div>

                <div>
                    <label class="text-[10px] font-bold text-slate-400 uppercase block mb-1">Thông tin nội dung</label>
                    <input type="text" id="title" maxlength="100" required class="w-full border border-border rounded-lg px-3 py-2.5 text-sm mb-3 focus:border-primary outline-none" placeholder="Tiêu đề thông báo...">
                    <textarea id="content" rows="4" maxlength="100" required class="w-full border border-border rounded-lg px-3 py-2.5 text-sm focus:border-primary outline-none resize-none" placeholder="Nhập nội dung chi tiết..."></textarea>
                    <div class="flex justify-end mt-1">
                        <span class="text-[10px] text-slate-400 font-medium"><span id="char-count">0</span>/100 ký tự</span>
                    </div>
                </div>

                <button type="submit" id="btnSubmit" class="w-full bg-primary hover:bg-secondary text-white font-bold py-3.5 rounded-xl transition-all mt-2 no-shadow">
                    Phát hành thông báo
                </button>
            </form>
        </div>
    </div>

    <script>
        const API_URL = "http://localhost:5207/api/Notification";
        const TOKEN = `@Html.Raw(token)`;

        let currentPage = 1;
        const pageSize = 10;
        let allNotifications = [];
        let selectedEmails = [];

        // 0. HÀM ĐỊNH DẠNG THỜI GIAN (24H - VN)
        function formatDateTime(dateString) {
            const date = new Date(dateString);
            return date.toLocaleString('vi-VN', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour12: false // Ép buộc sử dụng định dạng 24 giờ
            });
        }

        // 0.1 BỘ ĐẾM KÝ TỰ
        document.getElementById('content').addEventListener('input', (e) => {
            document.getElementById('char-count').innerText = e.target.value.length;
        });

        // 1. LOAD DỮ LIỆU & PHÂN TRANG
        async function loadHistory() {
            try {
                const res = await fetch(`${API_URL}/all`, { headers: { 'Authorization': `Bearer ${TOKEN}` } });
                if (res.ok) {
                    allNotifications = await res.json();
                    renderTable();
                }
            } catch (err) { console.error(err); }
        }

        function renderTable() {
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;
            const pagedData = allNotifications.slice(start, end);
            const tbody = document.getElementById('admin-table-body');

            if (pagedData.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-slate-400 text-sm">Chưa có thông báo nào</td></tr>`;
                updatePaginationInfo(0, 0, 0);
                return;
            }

            tbody.innerHTML = pagedData.map(n => `
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="p-4 overflow-hidden">
                        <div class="text-sm font-bold text-slate-700 truncate">${n.receiverFullName || 'Hệ thống'}</div>
                        <div class="text-[11px] text-slate-400 truncate">${n.receiverEmail || 'all-users@system.com'}</div>
                    </td>
                    <td class="p-4">
                        <div class="text-sm font-bold text-slate-800 break-all line-clamp-1">${n.title}</div>
                        <div class="text-xs text-slate-400 line-clamp-2 break-all">${n.content}</div>
                    </td>
                    <td class="p-4 text-xs text-slate-500">
                        ${formatDateTime(n.createdAt)}
                    </td>
                    <td class="p-4 text-center">
                        <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold uppercase
                            ${n.isRead ? 'bg-slate-100 text-slate-400' : 'bg-emerald-100 text-emerald-600'}">
                            ${n.isRead ? 'Đã xem' : 'Chờ đọc'}
                        </span>
                    </td>
                </tr>
            `).join('');

            updatePaginationInfo(start + 1, Math.min(end, allNotifications.length), allNotifications.length);
            renderPaginationControls();
        }

        function updatePaginationInfo(start, end, total) {
            document.getElementById('pagination-info').innerText = `Hiển thị ${start}-${end} trong ${total} thông báo`;
        }

        function renderPaginationControls() {
            const totalPages = Math.ceil(allNotifications.length / pageSize);
            const container = document.getElementById('pagination-controls');
            let html = `<button onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} class="p-1 rounded hover:bg-slate-200 disabled:opacity-30"><span class="material-symbols-outlined text-sm">chevron_left</span></button>`;

            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                    html += `<button onclick="changePage(${i})" class="w-7 h-7 rounded text-xs font-bold ${currentPage === i ? 'bg-primary text-white' : 'text-slate-500 hover:bg-slate-200'}">${i}</button>`;
                } else if (i === currentPage - 2 || i === currentPage + 2) {
                    html += `<span class="text-slate-400 text-xs px-1">...</span>`;
                }
            }
            html += `<button onclick="changePage(${currentPage + 1})" ${currentPage === totalPages || totalPages === 0 ? 'disabled' : ''} class="p-1 rounded hover:bg-slate-200 disabled:opacity-30"><span class="material-symbols-outlined text-sm">chevron_right</span></button>`;
            container.innerHTML = html;
        }

        function changePage(page) {
            currentPage = page;
            renderTable();
        }

        // 2. TAG EMAIL & AUTOCOMPLETE
        const emailInput = document.getElementById('emailInput');
        const suggestions = document.getElementById('suggestions');

        emailInput.addEventListener('input', async (e) => {
            const query = e.target.value.trim();
            if (query.length < 1) { suggestions.classList.add('hidden'); return; }
            try {
                const res = await fetch(`${API_URL}/search-emails?query=${query}`, { headers: { 'Authorization': `Bearer ${TOKEN}` } });
                const data = await res.json();
                if (data.length > 0) {
                    suggestions.innerHTML = data.filter(m => !selectedEmails.includes(m))
                        .map(m => `<div class="p-2.5 text-sm hover:bg-emerald-50 cursor-pointer" onclick="addTag('${m}')">${m}</div>`).join('');
                    suggestions.classList.remove('hidden');
                } else { suggestions.classList.add('hidden'); }
            } catch (err) { console.error(err); }
        });

        function addTag(email) {
            if (!selectedEmails.includes(email)) { selectedEmails.push(email); renderTags(); }
            emailInput.value = '';
            suggestions.classList.add('hidden');
        }

        function renderTags() {
            const box = document.getElementById('tag-box');
            box.querySelectorAll('.email-pill').forEach(el => el.remove());
            selectedEmails.forEach((email, idx) => {
                const pill = document.createElement('span');
                pill.className = "email-pill bg-emerald-100 text-emerald-700 text-[11px] font-bold px-2.5 py-1 rounded flex items-center gap-1.5";
                pill.innerHTML = `${email} <button type="button" onclick="removeTag(${idx})" class="hover:text-red-500 text-lg leading-none">&times;</button>`;
                box.insertBefore(pill, emailInput);
            });
        }

        function removeTag(idx) { selectedEmails.splice(idx, 1); renderTags(); }

        // 3. UI HELPERS
        function toggleEmailInput() {
            const type = document.getElementById('targetType').value;
            const section = document.getElementById('email-section');
            if (type === 'ALL') section.classList.add('hidden');
            else section.classList.remove('hidden');
        }

        function openModal() {
            document.getElementById('form-advanced').reset();
            selectedEmails = [];
            renderTags();
            toggleEmailInput();
            document.getElementById('char-count').innerText = "0";
            document.getElementById('modal-send').classList.remove('hidden');
        }

        function closeModal() { document.getElementById('modal-send').classList.add('hidden'); }

        

        // 4. SUBMIT FORM
        document.getElementById('form-advanced').onsubmit = async (e) => {
            e.preventDefault();
            const type = document.getElementById('targetType').value;
            if (type === 'SINGLE' && selectedEmails.length === 0) { alert("Vui lòng nhập email."); return; }

            const btn = document.getElementById('btnSubmit');
            btn.disabled = true; btn.innerText = "Đang gửi...";

            try {
                const res = await fetch(`${API_URL}/send-advanced`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${TOKEN}`, 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        targetType: type,
                        emails: selectedEmails,
                        title: document.getElementById('title').value,
                        content: document.getElementById('content').value
                    })
                });

                if (res.ok) {
                    alert("Thành công!");
                    closeModal();
                    loadHistory();
                    document.getElementById('form-advanced').reset();
                    selectedEmails = [];
                    renderTags();
                    toggleEmailInput();
                } else { alert("Lỗi khi gửi."); }
            } catch (err) { alert("Lỗi kết nối."); }
            btn.disabled = false; btn.innerText = "Phát hành thông báo";
        };

        // 5. SIGNALR
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("http://localhost:5207/notificationHub", { accessTokenFactory: () => TOKEN })
            .withAutomaticReconnect().build();
        connection.on("ReceiveNotification", () => loadHistory());
        connection.start().catch(err => console.error(err));

        document.addEventListener('DOMContentLoaded', loadHistory);
    </script>
@* </body> *@
@* </html> *@