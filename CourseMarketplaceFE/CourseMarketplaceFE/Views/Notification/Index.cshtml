@model IEnumerable<CourseMarketplaceFE.Models.NotificationViewModel>
@{
    ViewData["Title"] = "My Notifications";
    var tokenFromServer = Context.Request.Cookies["AccessToken"]
                        ?? Context.Request.Cookies[".AspNetCore.Identity.Application"];
}

<div class="max-w-4xl mx-auto p-6 min-h-screen flex flex-col">
    <div class="flex justify-between items-center mb-8">
        <div>
            <h2 class="text-3xl font-headline font-extrabold text-slate-800">Notifications</h2>
            <p class="text-slate-500 text-sm mt-1">Stay updated with the latest alerts and announcements.</p>
        </div>
        <span class="text-xs text-slate-500 bg-white border border-slate-200 px-3 py-1.5 rounded-full flex items-center gap-2">
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
            </span>
            Online
        </span>
    </div>

    @* ── Notification Search, Sort, Filter Bar ───────────────────── *@
    <div class="bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex flex-col md:flex-row items-center gap-4 mb-6">
        <div class="relative w-full md:w-1/2">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
            <input type="text" id="notification-search" placeholder="Search by title or content..." 
                   class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-800 placeholder:text-slate-400 bg-slate-50 focus:bg-white" />
        </div>
        
        <div class="flex flex-wrap items-center gap-3 w-full md:w-auto md:ml-auto">
            <div class="relative w-full sm:w-auto">
                <select id="notification-filter-read" class="w-full sm:w-auto appearance-none border border-slate-200 rounded-xl pl-4 pr-10 py-2.5 text-sm font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-700 cursor-pointer">
                    <option value="all">All Statuses</option>
                    <option value="unread">Unread</option>
                    <option value="read">Read</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
            </div>

            <div class="relative w-full sm:w-auto">
                <select id="notification-sort" class="w-full sm:w-auto appearance-none border border-slate-200 rounded-xl pl-4 pr-10 py-2.5 text-sm font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-700 cursor-pointer">
                    <option value="newest">Newest First</option>
                    <option value="oldest">Oldest First</option>
                    <option value="title-asc">Title (A-Z)</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
            </div>

            <button type="button" id="notification-clear" class="w-full sm:w-auto px-4 py-2.5 text-sm font-bold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl transition-all flex items-center justify-center gap-1.5 shrink-0">
                <span class="material-symbols-outlined text-[18px]">filter_alt_off</span>
                Reset
            </button>
        </div>
    </div>

    <div id="notification-container" class="space-y-4 flex-1">
        <div class="bg-white p-10 rounded-2xl border border-dashed border-slate-200 text-center">
            <div class="animate-pulse flex flex-col items-center">
                <div class="h-4 bg-slate-200 rounded w-1/3 mb-4"></div>
                <div class="h-3 bg-slate-100 rounded w-1/2"></div>
            </div>
            <p class="text-slate-400 italic mt-4 text-sm">Loading notifications...</p>
        </div>
    </div>

    <div id="pagination-bar" class="mt-8 pt-6 border-t border-slate-100 flex items-center justify-between hidden">
        <div class="text-xs text-slate-500 font-medium" id="pagination-info">
            Showing 0-0 of 0 notifications
        </div>
        <div class="flex items-center gap-1" id="pagination-controls"></div>
    </div>
</div>

<div id="modal-detail" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" onclick="closeModal()"></div>
    <div class="bg-white w-full max-w-lg rounded-3xl relative z-10 flex flex-col overflow-hidden border border-slate-100 shadow-none">
        <div class="p-6 border-b border-slate-50 flex justify-between items-center bg-teal-50/50">
            <div class="flex items-center gap-2 text-teal-700">
                <span class="material-symbols-outlined text-xl">info</span>
                <span class="font-bold uppercase text-[11px] tracking-widest">Notification Details</span>
            </div>
            <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600 p-1 hover:bg-white rounded-full transition-all">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-8 max-h-[70vh] overflow-y-auto">
            <h3 id="modal-title" class="text-2xl font-bold text-slate-800 mb-4 leading-tight break-all"></h3>
            <div id="modal-time" class="flex items-center gap-2 mb-6 text-slate-400 text-xs uppercase tracking-tighter"></div>
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
                <p id="modal-content" class="text-slate-600 leading-relaxed whitespace-pre-wrap break-words"></p>
            </div>
            <div id="modal-link" class="hidden mt-4">
                <a id="modal-link-btn" href="#" 
                   class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-bold rounded-xl shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 text-sm">
                     <span class="material-symbols-outlined text-lg">open_in_new</span>
                     <span id="modal-link-text">View Details</span>
                </a>
            </div>
        </div>
        <div class="p-4 bg-slate-50 border-t border-slate-100 flex justify-end">
            <button onclick="closeModal()" class="px-6 py-2.5 bg-white border border-slate-200 text-slate-600 font-bold rounded-xl hover:bg-slate-100 transition-all text-sm">
                Close
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const TOKEN_USER = '@tokenFromServer';
        const API_URL = "http://localhost:5207/api/Notification";

        let allNotifications = [];
        let filteredNotifications = [];
        let currentPage = 1;
        const pageSize = 10;

        document.addEventListener("DOMContentLoaded", loadNotifications);

        async function loadNotifications() {
            if (!TOKEN_USER) {
                document.getElementById('notification-container').innerHTML =
                    `<div class="bg-amber-50 text-amber-700 p-8 rounded-xl border border-amber-100 text-center font-bold">Please log in to view your notifications.</div>`;
                return;
            }
            try {
                const response = await fetch(`${API_URL}`, {
                    headers: { 'Authorization': `Bearer ${TOKEN_USER}` }
                });
                if (response.ok) {
                    allNotifications = await response.json();
                    applyNotificationFilters();
                }
            } catch (error) {
                console.error("Lỗi:", error);
                document.getElementById('notification-container').innerHTML = `<div class="text-red-500 text-center p-8">Connection error, please try again.</div>`;
            }
        }

        function applyNotificationFilters() {
            const query = document.getElementById('notification-search').value.toLowerCase().trim();
            const filterRead = document.getElementById('notification-filter-read').value;
            const sortVal = document.getElementById('notification-sort').value;

            filteredNotifications = [...allNotifications];

            // 1. Search Filter
            if (query) {
                filteredNotifications = filteredNotifications.filter(n => 
                    (n.title && n.title.toLowerCase().includes(query)) || 
                    (n.content && n.content.toLowerCase().includes(query))
                );
            }

            // 2. Read state filter
            if (filterRead === 'unread') {
                filteredNotifications = filteredNotifications.filter(n => !n.isRead);
            } else if (filterRead === 'read') {
                filteredNotifications = filteredNotifications.filter(n => n.isRead);
            }

            // 3. Sorting
            if (sortVal === 'newest') {
                filteredNotifications.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
            } else if (sortVal === 'oldest') {
                filteredNotifications.sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt));
            } else if (sortVal === 'title-asc') {
                filteredNotifications.sort((a, b) => (a.title || '').localeCompare(b.title || '', 'en'));
            }

            currentPage = 1;
            renderPage();
        }

        function renderPage() {
            const container = document.getElementById('notification-container');
            const paginationBar = document.getElementById('pagination-bar');

            if (filteredNotifications.length === 0) {
                container.innerHTML = `<div class="bg-white p-16 rounded-3xl border border-dashed border-slate-200 text-center text-slate-400">No notifications found matching your search criteria.</div>`;
                paginationBar.classList.add('hidden');
                return;
            }

            paginationBar.classList.remove('hidden');
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;
            const pagedData = filteredNotifications.slice(start, end);

            container.innerHTML = pagedData.map(noti => {
                const isUnread = !noti.isRead;
                return `
                    <div class="group bg-white p-5 rounded-2xl border transition-all duration-200 hover:border-teal-200
                        ${isUnread ? 'border-teal-100 bg-gradient-to-r from-white to-teal-50/20' : 'border-slate-100 opacity-90'}"
                        id="noti-row-${noti.notificationId}">

                        <div class="flex justify-between items-start gap-4">
                            <div class="flex-1 min-w-0 cursor-pointer overflow-hidden" onclick="showDetail(${noti.notificationId})">
                                <div class="flex items-center gap-3 mb-2">
                                    <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-emerald-100 text-emerald-700 uppercase">System</span>
                                    ${isUnread ? `<span id="dot-${noti.notificationId}" class="flex h-2 w-2 rounded-full bg-teal-600"></span>` : ''}
                                </div>

                                <h4 class="font-bold text-lg break-words line-clamp-1 ${isUnread ? 'text-slate-900' : 'text-slate-500 font-semibold'}">
                                    ${noti.title}
                                </h4>
                                <p class="text-sm text-slate-600 mt-1 line-clamp-2 break-words">
                                    ${noti.content}
                                </p>
                                ${noti.linkAction ? `
                                    <a href="${noti.linkAction}" 
                                       class="inline-flex items-center gap-1.5 mt-2 px-4 py-1.5 bg-primary/10 text-primary text-xs font-bold rounded-lg hover:bg-primary/20 transition-colors"
                                       onclick="event.stopPropagation()">
                                        <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                                        View Details
                                    </a>` : ''}

                                <div class="flex items-center justify-between mt-4">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[14px] text-slate-400">schedule</span>
                                        <span class="text-[11px] text-slate-400 uppercase font-semibold">
                                            ${new Date(noti.createdAt).toLocaleString('en-US')}
                                        </span>
                                    </div>
                                    <span class="text-[10px] font-bold text-teal-600 opacity-0 group-hover:opacity-100 transition-all flex items-center gap-1">
                                        Details <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                                    </span>
                                </div>
                            </div>

                            <div class="flex flex-shrink-0 gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                ${isUnread ? `
                                    <button onclick="markAsRead(${noti.notificationId})" title="Mark as read"
                                            class="p-2 text-teal-600 hover:bg-teal-50 rounded-xl transition-all">
                                        <span class="material-symbols-outlined text-xl">check_circle</span>
                                    </button>` : ''}
                                <button onclick="deleteNotification(${noti.notificationId})" title="Delete"
                                        class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-xl transition-all">
                                    <span class="material-symbols-outlined text-xl">delete</span>
                                </button>
                            </div>
                        </div>
                    </div>`;
            }).join('');

            updatePaginationInfo(start + 1, Math.min(end, filteredNotifications.length), filteredNotifications.length);
            renderPaginationControls();
        }

        function updatePaginationInfo(start, end, total) {
            document.getElementById('pagination-info').innerText = `Showing ${start}-${end} of ${total} notifications`;
        }

        function renderPaginationControls() {
            const totalPages = Math.ceil(filteredNotifications.length / pageSize);
            const container = document.getElementById('pagination-controls');
            let html = '';

            html += `<button onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} class="p-1.5 rounded-lg hover:bg-slate-100 disabled:opacity-20 transition-all"><span class="material-symbols-outlined text-sm">chevron_left</span></button>`;

            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                    html += `<button onclick="changePage(${i})" class="w-8 h-8 rounded-lg text-xs font-bold transition-all ${currentPage === i ? 'bg-teal-600 text-white' : 'text-slate-500 hover:bg-slate-100'}">${i}</button>`;
                } else if (i === currentPage - 2 || i === currentPage + 2) {
                    html += `<span class="text-slate-300 text-xs px-1">...</span>`;
                }
            }

            html += `<button onclick="changePage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''} class="p-1.5 rounded-lg hover:bg-slate-100 disabled:opacity-20 transition-all"><span class="material-symbols-outlined text-sm">chevron_right</span></button>`;

            container.innerHTML = html;
        }

        function changePage(page) {
            currentPage = page;
            renderPage();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function showDetail(id) {
            const noti = allNotifications.find(n => n.notificationId === id);
            if (!noti) return;

            document.getElementById('modal-title').innerText = noti.title;
            document.getElementById('modal-content').innerText = noti.content;
            document.getElementById('modal-time').innerHTML = `
                <span class="material-symbols-outlined text-[14px]">schedule</span>
                ${new Date(noti.createdAt).toLocaleString('en-US')}
            `;

            document.getElementById('modal-detail').classList.remove('hidden');
            document.body.style.overflow = 'hidden';

            const linkContainer = document.getElementById('modal-link');
            const linkBtn = document.getElementById('modal-link-btn');
            if (noti.linkAction) {
                linkBtn.href = noti.linkAction;
                linkContainer.classList.remove('hidden');
            } else {
                linkContainer.classList.add('hidden');
            }

            if(!noti.isRead) markAsRead(id);
        }

        function closeModal() {
            document.getElementById('modal-detail').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        async function markAsRead(id) {
            try {
                const response = await fetch(`${API_URL}/mark-as-read/${id}`, {
                    method: 'PUT',
                    headers: { 'Authorization': `Bearer ${TOKEN_USER}` }
                });

                if (response.ok) {
                    const localNoti = allNotifications.find(n => n.notificationId === id);
                    if(localNoti) localNoti.isRead = true;
                    applyNotificationFilters();
                }
            } catch (err) { console.error(err); }
        }

        async function deleteNotification(id) {
            const confirmResult = await Swal.fire({
                title: 'Confirm Delete',
                text: "Are you sure you want to delete this notification?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Delete',
                cancelButtonText: 'Cancel',
                background: '#ffffff',
                customClass: { popup: 'rounded-2xl shadow-xl' }
            });

            if (!confirmResult.isConfirmed) return;

            try {
                const response = await fetch(`${API_URL}/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${TOKEN_USER}` }
                });
                if (response.ok) {
                    Swal.fire({
                        title: 'Deleted!',
                        text: 'The notification was successfully deleted.',
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false,
                        background: '#ffffff',
                        customClass: { popup: 'rounded-2xl shadow-xl' }
                    });
                    allNotifications = allNotifications.filter(n => n.notificationId !== id);
                    applyNotificationFilters();
                }
            } catch (err) { console.error(err); }
        }

        // Attach filter listeners
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('notification-search');
            const readSelect = document.getElementById('notification-filter-read');
            const sortSelect = document.getElementById('notification-sort');
            const clearBtn = document.getElementById('notification-clear');

            if (searchInput) {
                searchInput.addEventListener('input', applyNotificationFilters);
                readSelect.addEventListener('change', applyNotificationFilters);
                sortSelect.addEventListener('change', applyNotificationFilters);

                clearBtn.addEventListener('click', () => {
                    searchInput.value = '';
                    readSelect.value = 'all';
                    sortSelect.value = 'newest';
                    applyNotificationFilters();
                });
            }
        });
    </script>
}