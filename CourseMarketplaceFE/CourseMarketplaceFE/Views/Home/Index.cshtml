@model List<CourseMarketplaceFE.Models.PublicCourseViewModel>
@{
    ViewData["Title"] = "Home Page";
}

<section class="relative px-8 pt-20 pb-32 overflow-hidden">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16">
        <div class="flex-1 z-10">
            <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface tracking-tight leading-tight mb-6">
                Master New Skills,<br />
                <span class="text-primary">Anytime, Anywhere.</span>
            </h1>
            <p class="text-lg text-slate-600 max-w-xl mb-10 leading-relaxed">
                Curated learning paths designed by industry experts. Join 2M+ students unlocking their digital potential with LinkedLearn.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 mb-8">
                <div class="relative flex-1 max-w-md">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                    <input class="w-full bg-white border border-slate-200 rounded-full py-4 pl-12 pr-4 shadow-xl focus:ring-4 focus:ring-primary/10 outline-none" placeholder="What do you want to learn today?" type="text" />
                </div>
                <button class="bg-primary text-on-primary px-8 py-4 rounded-full font-bold shadow-lg hover:opacity-90 transition-all">
                    Explore Courses
                </button>
            </div>
        </div>

        <div class="flex-1 relative">
            <div class="relative z-10 bg-white p-4 rounded-xl shadow-2xl rotate-3">
                <div class="aspect-video bg-slate-200 rounded-lg flex items-center justify-center text-slate-400 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" class="w-full h-full object-cover" alt="Hero" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Course List Section -->
<section class="py-12 px-8">
    <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-10">
            <div>
                <h2 class="font-headline text-3xl font-extrabold text-on-surface">Top Courses</h2>
                <p class="text-slate-500 mt-1">Hand-picked selections to start your journey</p>
            </div>
            <a href="#" class="text-primary font-bold hover:underline flex items-center gap-1">
                View all <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </a>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="bg-white rounded-2xl p-12 text-center border border-dashed border-slate-200">
                <span class="material-symbols-outlined text-6xl text-slate-200 mb-4">school</span>
                <p class="text-slate-500 font-medium">No courses available at the moment.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach (var course in Model)
                {
                    <div class="group bg-white rounded-2xl overflow-hidden border border-slate-200 hover:shadow-2xl hover:shadow-primary/10 transition-all duration-300 flex flex-col cursor-pointer" onclick="location.href='/Course/Details/@course.CourseId'">
                        <div class="aspect-video relative overflow-hidden">
                            <img src="@(string.IsNullOrEmpty(course.CourseThumbnailUrl) ? "https://images.unsplash.com/photo-1498050108023-c5249f4df085?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" : course.CourseThumbnailUrl)" 
                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" 
                                 alt="@course.Title" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                        </div>
                        <div class="p-5 flex-1 flex flex-col">
                            <h3 class="font-bold text-slate-900 mb-2 line-clamp-2 group-hover:text-primary transition-colors">@course.Title</h3>
                            <p class="text-xs text-slate-500 mb-4">@course.InstructorName</p>
                            
                            <div class="flex items-center gap-1 mb-4">
                                <div class="flex text-amber-400">
                                    <span class="material-symbols-outlined text-[16px] fill-1">star</span>
                                    <span class="material-symbols-outlined text-[16px] fill-1">star</span>
                                    <span class="material-symbols-outlined text-[16px] fill-1">star</span>
                                    <span class="material-symbols-outlined text-[16px] fill-1">star</span>
                                    <span class="material-symbols-outlined text-[16px] fill-1">star_half</span>
                                </div>
                                <span class="text-[11px] font-bold text-slate-700">4.8</span>
                                <span class="text-[11px] text-slate-400">(2.5k)</span>
                            </div>

                            <div class="mt-auto flex items-center justify-between">
                                <div class="text-lg font-extrabold text-slate-900">
                                    @if (course.Price == 0)
                                    {
                                        <span class="text-primary">Free</span>
                                    }
                                    else
                                    {
                                        <span>$@course.Price.ToString("F2")</span>
                                    }
                                </div>
                                <div class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-primary group-hover:text-white transition-colors">
                                    <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<section class="py-24 px-8 bg-surface-container-low">
    <div class="max-w-7xl mx-auto">
        <h2 class="font-headline text-3xl font-extrabold text-on-surface mb-12">Explore Categories</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
            @{
                var categories = new[] {
                        new { Name = "Design", Icon = "brush", Color = "bg-orange-100 text-orange-600" },
                        new { Name = "Development", Icon = "code", Color = "bg-blue-100 text-blue-600" },
                        new { Name = "Marketing", Icon = "monitoring", Color = "bg-green-100 text-green-600" },
                        new { Name = "Business", Icon = "account_balance", Color = "bg-purple-100 text-purple-600" },
                        new { Name = "Photography", Icon = "photo_camera", Color = "bg-pink-100 text-pink-600" },
                        new { Name = "Music", Icon = "music_note", Color = "bg-yellow-100 text-yellow-600" }
                        };
            }

            @foreach (var cat in categories)
            {
                <div class="group bg-white p-6 rounded-xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all cursor-pointer">
                    <div class="w-12 h-12 rounded-xl @cat.Color flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">@cat.Icon</span>
                    </div>
                    <h3 class="font-bold text-on-surface">@cat.Name</h3>
                </div>
            }
        </div>
    </div>
</section>