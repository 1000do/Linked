@{
    ViewData["Title"] = "Home Page";
}

<section class="relative px-8 pt-20 pb-32 overflow-hidden">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16">
        <div class="flex-1 z-10">
            <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-surface tracking-tight leading-tight mb-6">
                Master New Skills,<br />
                <span class="text-primary">Anytime, Anywhere.</span>
            </h1>
            <p class="text-lg text-slate-600 max-w-xl mb-10 leading-relaxed">
                Curated learning paths designed by industry experts. Join 2M+ students unlocking their digital potential with LinkedLearn.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 mb-8">
                <div class="relative flex-1 max-w-md">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                    <input class="w-full bg-white border border-slate-200 rounded-full py-4 pl-12 pr-4 shadow-xl focus:ring-4 focus:ring-primary/10 outline-none" placeholder="What do you want to learn today?" type="text" />
                </div>
                <button class="bg-primary text-on-primary px-8 py-4 rounded-full font-bold shadow-lg hover:opacity-90 transition-all">
                    Explore Courses
                </button>
            </div>
        </div>

        <div class="flex-1 relative">
            <div class="relative z-10 bg-white p-4 rounded-xl shadow-2xl rotate-3">
                <div class="aspect-video bg-slate-200 rounded-lg flex items-center justify-center text-slate-400">
                    <span class="material-symbols-outlined text-6xl">image</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-24 px-8 bg-surface-container-low">
    <div class="max-w-7xl mx-auto">
        <h2 class="font-headline text-3xl font-extrabold text-on-surface mb-12">Explore Categories</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
            @{
                var categories = new[] {
                        new { Name = "Design", Icon = "brush", Color = "bg-orange-100 text-orange-600" },
                        new { Name = "Development", Icon = "code", Color = "bg-blue-100 text-blue-600" },
                        new { Name = "Marketing", Icon = "monitoring", Color = "bg-green-100 text-green-600" },
                        new { Name = "Business", Icon = "account_balance", Color = "bg-purple-100 text-purple-600" },
                        new { Name = "Photography", Icon = "photo_camera", Color = "bg-pink-100 text-pink-600" },
                        new { Name = "Music", Icon = "music_note", Color = "bg-yellow-100 text-yellow-600" }
                        };
            }

            @foreach (var cat in categories)
            {
                <div class="group bg-white p-6 rounded-xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all cursor-pointer">
                    <div class="w-12 h-12 rounded-xl @cat.Color flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">@cat.Icon</span>
                    </div>
                    <h3 class="font-bold text-on-surface">@cat.Name</h3>
                </div>
            }
        </div>
    </div>
  
</section>