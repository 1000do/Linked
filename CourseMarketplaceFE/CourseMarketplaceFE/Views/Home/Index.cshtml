@model List<CourseMarketplaceFE.Models.PublicCourseViewModel>
@{
    ViewData["Title"] = "Trang chủ - Nền tảng học tập trực tuyến";
}

@* 
  THIẾT KẾ BỞI IMPECCABLE SKILL - UI/UX SENIOR DESIGNER
  - Layout: 12-column grid system
  - Palette: Deep Slate (Trust) + Emerald/Primary Accent (Action)
  - Typography: Modern Sans-serif, High Contrast Hierarchy
  - Spacing: Generous padding to reduce cognitive load
*@

<style>
    /* Custom Ease cho micro-interactions mượt mà */
    .ease-out-expo { transition-timing-function: cubic-bezier(0.19, 1, 0.22, 1); }
</style>

@* ─── HERO SECTION ───────────────────────────────────────────────────────── *@
<section class="relative pt-24 pb-32 lg:pt-36 lg:pb-40 overflow-hidden bg-slate-50 border-b border-slate-200">
    <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] opacity-40"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row items-center gap-16">
        <div class="flex-1 max-w-3xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-bold mb-6">
                <span class="relative flex h-2.5 w-2.5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
                </span>
                Hơn 2 triệu học viên đã tham gia
            </div>

            <h1 class="text-5xl lg:text-7xl font-extrabold text-slate-900 tracking-tight leading-[1.1] mb-8">
                Làm chủ kỹ năng mới. <br />
                <span class="text-primary">Kiến tạo tương lai.</span>
            </h1>
            
            <p class="text-lg lg:text-xl text-slate-600 leading-relaxed mb-10 max-w-2xl">
                Nền tảng học tập trực tuyến hàng đầu với hàng ngàn khóa học chất lượng cao từ các chuyên gia thực chiến. Học mọi lúc, mọi nơi.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 max-w-xl">
                <div class="relative flex-1 group">
                    <span class="material-symbols-outlined absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">search</span>
                    <input type="text" 
                           class="w-full h-14 pl-14 pr-6 bg-white border-2 border-slate-200 rounded-2xl text-slate-700 placeholder:text-slate-400 focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all ease-out-expo text-base font-medium shadow-sm"
                           placeholder="Bạn muốn học gì hôm nay?" />
                </div>
                <button class="h-14 px-8 bg-primary text-white text-base font-bold rounded-2xl shadow-lg shadow-primary/30 hover:bg-primary/90 hover:-translate-y-0.5 active:translate-y-0 active:shadow-md transition-all ease-out-expo whitespace-nowrap">
                    Khám phá ngay
                </button>
            </div>
        </div>

        <div class="flex-1 w-full relative hidden lg:block">
            <div class="relative aspect-square max-w-md mx-auto">
                <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent rounded-full blur-3xl"></div>
                <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop" 
                     class="relative z-10 w-full h-full object-cover rounded-[2rem] shadow-2xl border-4 border-white/50" 
                     alt="Students collaborating" />
                
                @* Floating UI Element cho cảm giác dynamic *@
                <div class="absolute -bottom-6 -left-6 z-20 bg-white p-4 rounded-2xl shadow-xl border border-slate-100 flex items-center gap-4 animate-bounce" style="animation-duration: 3s;">
                    <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center text-amber-500">
                        <span class="material-symbols-outlined" style='font-variation-settings:"FILL" 1;'>star</span>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Đánh giá trung bình</p>
                        <p class="text-xl font-extrabold text-slate-900">4.8 / 5.0</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ─── COURSES SECTION ─────────────────────────────────────────────────── *@
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        @{
            var featuredCourses = Model?.OrderByDescending(c => c.RatingAverage).Take(4).ToList() ?? new List<CourseMarketplaceFE.Models.PublicCourseViewModel>();
            var recentCourses = Model?.OrderByDescending(c => c.CreatedAt).Take(4).ToList() ?? new List<CourseMarketplaceFE.Models.PublicCourseViewModel>();
        }
        
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
            <div class="max-w-2xl">
                <h2 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-3">Khóa học nổi bật</h2>
                <p class="text-lg text-slate-500 leading-relaxed">Tuyển tập những khóa học được đánh giá cao nhất, thiết kế riêng cho mục tiêu nghề nghiệp của bạn.</p>
            </div>
            <a href="/Course" class="inline-flex items-center gap-2 text-primary font-bold hover:text-primary/80 transition-colors group pb-1">
                Xem tất cả khóa học 
                <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform ease-out-expo">arrow_forward</span>
            </a>
        </div>

        @if (!featuredCourses.Any())
        {
            <div class="py-24 flex flex-col items-center justify-center text-center bg-slate-50 rounded-3xl border border-dashed border-slate-200">
                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-sm mb-6">
                    <span class="material-symbols-outlined text-4xl text-slate-300">school</span>
                </div>
                <h3 class="text-xl font-bold text-slate-700 mb-2">Chưa có khóa học nào</h3>
                <p class="text-slate-500">Hệ thống đang cập nhật các khóa học mới. Vui lòng quay lại sau.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 mb-24">
                @foreach (var course in featuredCourses)
                {
                    <div class="flex flex-col h-full bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-2xl hover:shadow-slate-200/50 hover:-translate-y-1 transition-all duration-300 ease-out-expo group cursor-pointer" 
                         onclick="location.href='/Course/Details/@course.CourseId'">
                        <div class="relative w-full aspect-[16/9] overflow-hidden bg-slate-100 shrink-0">
                            <img src="@(string.IsNullOrEmpty(course.CourseThumbnailUrl) ? "https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=800&auto=format&fit=crop" : course.CourseThumbnailUrl)" 
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out-expo" 
                                 alt="@course.Title" loading="lazy" />
                            <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors"></div>

                            @* Wishlist Toggle *@
                            <button type="button" 
                                    class="absolute top-3 right-3 z-30 w-9 h-9 rounded-full bg-white/90 @(course.IsInWishlist ? "text-red-500" : "text-slate-400") flex items-center justify-center hover:bg-white hover:text-red-500 hover:scale-110 shadow-sm transition-all duration-300"
                                    onclick="event.stopPropagation(); toggleWishlist(this, @course.CourseId);">
                                <span class="material-symbols-outlined text-[20px]" style='font-variation-settings: "FILL" @(course.IsInWishlist ? "1" : "0");'>favorite</span>
                            </button>
                        </div>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="text-lg font-bold text-slate-900 line-clamp-2 leading-snug mb-2 group-hover:text-primary transition-colors">
                                @course.Title
                            </h3>
                            <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
                                <span class="material-symbols-outlined text-[18px]">person</span>
                                <span class="truncate">@course.InstructorName</span>
                            </div>
                            <div class="flex items-center gap-1.5 mb-6">
                                <span class="text-sm font-bold text-slate-800">@course.RatingAverage.ToString("F1")</span>
                                <div class="flex text-amber-400">
                                    @for(int i=0; i<Math.Floor((double)course.RatingAverage); i++) { <span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star</span> }
                                    @if((double)course.RatingAverage - Math.Floor((double)course.RatingAverage) >= 0.5) { <span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star_half</span> }
                                </div>
                                <span class="text-xs text-slate-400 font-medium">(@course.TotalStudents)</span>
                            </div>
                            <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                                <div class="text-xl font-extrabold text-slate-900 tracking-tight">
                                    @if (course.Price == 0)
                                    {
                                        <span class="text-emerald-600 uppercase text-lg">Miễn phí</span>
                                    }
                                    else
                                    {
                                        <span>$@course.Price.ToString("N2")</span>
                                    }
                                </div>

                                <form asp-action="AddToCart" asp-controller="Cart" method="post" class="m-0 z-20">
                                    <input type="hidden" name="courseId" value="@course.CourseId" />
                                    <input type="hidden" name="returnUrl" value="/" />
                                    <button type="submit" 
                                            class="w-10 h-10 rounded-full bg-slate-50 text-slate-500 flex items-center justify-center hover:bg-primary hover:text-white hover:scale-110 active:scale-95 shadow-sm transition-all duration-300"
                                            onclick="event.stopPropagation();"
                                            title="Thêm vào giỏ hàng">
                                        <span class="material-symbols-outlined text-[18px]" style='font-variation-settings:"FILL" 1;'>add_shopping_cart</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Recently Updated -->
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
                <div class="max-w-2xl">
                    <h2 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-3">Mới cập nhật</h2>
                    <p class="text-lg text-slate-500 leading-relaxed">Những khóa học mới nhất với kiến thức cập nhật liên tục.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
                @foreach (var course in recentCourses)
                {
                    <div class="flex flex-col h-full bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-2xl hover:shadow-slate-200/50 hover:-translate-y-1 transition-all duration-300 ease-out-expo group cursor-pointer" 
                         onclick="location.href='/Course/Details/@course.CourseId'">
                        <div class="relative w-full aspect-[16/9] overflow-hidden bg-slate-100 shrink-0">
                            <img src="@(string.IsNullOrEmpty(course.CourseThumbnailUrl) ? "https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=800&auto=format&fit=crop" : course.CourseThumbnailUrl)" 
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out-expo" 
                                 alt="@course.Title" loading="lazy" />
                            <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors"></div>

                            @* Wishlist Toggle *@
                            <button type="button" 
                                    class="absolute top-3 right-3 z-30 w-9 h-9 rounded-full bg-white/90 @(course.IsInWishlist ? "text-red-500" : "text-slate-400") flex items-center justify-center hover:bg-white hover:text-red-500 hover:scale-110 shadow-sm transition-all duration-300"
                                    onclick="event.stopPropagation(); toggleWishlist(this, @course.CourseId);">
                                <span class="material-symbols-outlined text-[20px]" style='font-variation-settings: "FILL" @(course.IsInWishlist ? "1" : "0");'>favorite</span>
                            </button>
                        </div>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="text-lg font-bold text-slate-900 line-clamp-2 leading-snug mb-2 group-hover:text-primary transition-colors">
                                @course.Title
                            </h3>
                            <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
                                <span class="material-symbols-outlined text-[18px]">person</span>
                                <span class="truncate">@course.InstructorName</span>
                            </div>
                            <div class="flex items-center gap-1.5 mb-6">
                                <span class="text-sm font-bold text-slate-800">@course.RatingAverage.ToString("F1")</span>
                                <div class="flex text-amber-400">
                                    @for(int i=0; i<Math.Floor((double)course.RatingAverage); i++) { <span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star</span> }
                                    @if((double)course.RatingAverage - Math.Floor((double)course.RatingAverage) >= 0.5) { <span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star_half</span> }
                                </div>
                                <span class="text-xs text-slate-400 font-medium">(@course.TotalStudents)</span>
                            </div>
                            <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                                <div class="text-xl font-extrabold text-slate-900 tracking-tight">
                                    @if (course.Price == 0)
                                    {
                                        <span class="text-emerald-600 uppercase text-lg">Miễn phí</span>
                                    }
                                    else
                                    {
                                        <span>$@course.Price.ToString("N2")</span>
                                    }
                                </div>

                                <form asp-action="AddToCart" asp-controller="Cart" method="post" class="m-0 z-20">
                                    <input type="hidden" name="courseId" value="@course.CourseId" />
                                    <input type="hidden" name="returnUrl" value="/" />
                                    <button type="submit" 
                                            class="w-10 h-10 rounded-full bg-slate-50 text-slate-500 flex items-center justify-center hover:bg-primary hover:text-white hover:scale-110 active:scale-95 shadow-sm transition-all duration-300"
                                            onclick="event.stopPropagation();"
                                            title="Thêm vào giỏ hàng">
                                        <span class="material-symbols-outlined text-[18px]" style='font-variation-settings:"FILL" 1;'>add_shopping_cart</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@* ─── CATEGORIES SECTION ─────────────────────────────────────────────────── *@
<section class="py-24 bg-slate-50 border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-2xl mx-auto mb-16">
            <h2 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">Khám phá danh mục</h2>
            <p class="text-lg text-slate-500">Mở rộng kỹ năng của bạn với các chuyên ngành đa dạng được giảng dạy bởi chuyên gia.</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
            @{
                var displayCategories = ViewBag.Categories as List<CourseMarketplaceFE.Models.CategoryViewModel> ?? new List<CourseMarketplaceFE.Models.CategoryViewModel>();
                var iconMap = new Dictionary<string, (string Icon, string Color, string Bg)>
                {
                    { "Lập trình", ("code", "text-blue-600", "bg-blue-50") },
                    { "Thiết kế", ("brush", "text-orange-600", "bg-orange-50") },
                    { "Marketing", ("monitoring", "text-emerald-600", "bg-emerald-50") },
                    { "Kinh doanh", ("account_balance", "text-indigo-600", "bg-indigo-50") },
                    { "Nhiếp ảnh", ("photo_camera", "text-pink-600", "bg-pink-50") },
                    { "Âm nhạc", ("music_note", "text-purple-600", "bg-purple-50") },
                    { "Ngoại ngữ", ("language", "text-amber-600", "bg-amber-50") },
                    { "Sức khỏe & Đời sống", ("favorite", "text-rose-600", "bg-rose-50") },
                    { "Khoa học dữ liệu", ("database", "text-cyan-600", "bg-cyan-50") }
                };
            }

            @foreach (var cat in displayCategories)
            {
                var style = iconMap.ContainsKey(cat.CategoriesName) ? iconMap[cat.CategoriesName] : ("school", "text-slate-600", "bg-slate-50");
                <a href="/Course?category=@cat.CategoriesName" class="group flex flex-col items-center justify-center p-8 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-primary/20 hover:shadow-primary/10 hover:-translate-y-1 transition-all duration-300 ease-out-expo text-center">
                    <div class="w-16 h-16 @style.Item3 @style.Item2 rounded-full flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 ease-out-expo">
                        <span class="material-symbols-outlined text-3xl">@style.Item1</span>
                    </div>
                    <h3 class="font-bold text-slate-800 text-sm">@cat.CategoriesName</h3>
                </a>
            }
        </div>
        </div>
    </div>
</section>