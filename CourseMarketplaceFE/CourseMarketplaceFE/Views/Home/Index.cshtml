@model List<CourseMarketplaceFE.Models.PublicCourseViewModel>
@{
    ViewData["Title"] = "Home - Online Learning Platform";
}

@* 
  THIẾT KẾ BỞI IMPECCABLE SKILL - UI/UX SENIOR DESIGNER
*@

@{
    var stats = ViewBag.PlatformStats as CourseMarketplaceFE.Models.PlatformStatsViewModel ?? new CourseMarketplaceFE.Models.PlatformStatsViewModel();
}

<style>
    /* Custom Ease for smooth micro-interactions */
    .ease-out-expo { transition-timing-function: cubic-bezier(0.19, 1, 0.22, 1); }
    
    @@keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-marquee {
        display: flex;
        width: max-content;
        animation: marquee 40s linear infinite;
    }
    .animate-marquee:hover {
        animation-play-state: paused;
    }
</style>

@* ─── HERO SECTION ───────────────────────────────────────────────────────── *@
<section class="relative pt-24 pb-32 lg:pt-36 lg:pb-40 overflow-hidden bg-slate-50 border-b border-slate-200">
    <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] opacity-40"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row items-center gap-16">
        <div class="flex-1 max-w-3xl text-center lg:text-left">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-bold mb-6 mx-auto lg:mx-0">
                <span class="relative flex h-2.5 w-2.5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
                </span>
                Over @stats.TotalStudents.ToString("N0") learners joined
            </div>

            <h1 class="text-5xl lg:text-7xl font-extrabold text-slate-900 tracking-tight leading-[1.1] mb-8">
                Master new skills. <br />
                <span class="text-primary">Shape your future.</span>
            </h1>
            
            <p class="text-lg lg:text-xl text-slate-600 leading-relaxed mb-10 max-w-2xl mx-auto lg:mx-0">
                Leading online learning platform with thousands of high-quality courses taught by industry experts. Learn anytime, anywhere.
            </p>


        </div>

        <div class="flex-1 w-full relative hidden lg:block">
            <div class="relative w-full max-w-lg mx-auto aspect-square flex items-center justify-center">
                @* Abstract Blob Background *@
                <div class="absolute inset-0 bg-primary/10 rounded-[30%_70%_70%_30%_/_30%_30%_70%_70%] animate-[spin_15s_linear_infinite] blur-2xl"></div>
                <div class="absolute inset-10 bg-emerald-400/20 rounded-[70%_30%_30%_70%_/_70%_70%_30%_30%] animate-[spin_20s_linear_infinite_reverse] blur-2xl"></div>
                
                @* Image with Organic Mask (Blob Shape) *@
                <div class="relative z-10 w-[90%] h-[90%] overflow-hidden shadow-2xl transition-all duration-700 hover:scale-105" 
                     style="border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;">
                    <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop" 
                         class="w-full h-full object-cover scale-110" 
                         alt="Students collaborating" />
                    <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent"></div>
                </div>

                @* Floating Decorations *@
                <div class="absolute top-0 right-0 w-24 h-24 bg-amber-400/10 rounded-full blur-xl animate-pulse"></div>
                <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-primary/10 rounded-full blur-xl animate-pulse" style="animation-delay: 2s;"></div>
            </div>
        </div>
    </div>
</section>

@* ─── IMPACT COUNTERS ─────────────────────────────────────────────────── *@
<section class="py-8 bg-white -mt-12 relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-gradient-to-br from-emerald-900 via-emerald-800 to-emerald-950 rounded-[2rem] p-6 lg:p-8 shadow-xl shadow-emerald-900/30 flex flex-wrap items-center justify-around gap-8 text-center border border-emerald-400/20">

            <div class="flex flex-col items-center">
                <div class="text-3xl lg:text-4xl font-black text-white mb-1 tracking-tighter">@stats.TotalStudents.ToString("N0")+</div>
                <div class="text-[10px] lg:text-xs font-bold text-emerald-200/60 uppercase tracking-widest">Active Learners</div>
            </div>
            <div class="w-px h-10 bg-white/10 hidden lg:block"></div>
            <div class="flex flex-col items-center">
                <div class="text-3xl lg:text-4xl font-black text-white mb-1 tracking-tighter">@stats.TotalCourses.ToString("N0")+</div>
                <div class="text-[10px] lg:text-xs font-bold text-emerald-200/60 uppercase tracking-widest">Courses</div>
            </div>
            <div class="w-px h-10 bg-white/10 hidden lg:block"></div>
            <div class="flex flex-col items-center">
                <div class="text-3xl lg:text-4xl font-black text-white mb-1 tracking-tighter">@stats.TotalInstructors.ToString("N0")+</div>
                <div class="text-[10px] lg:text-xs font-bold text-emerald-200/60 uppercase tracking-widest">Expert Instructors</div>
            </div>
            <div class="w-px h-10 bg-white/10 hidden lg:block"></div>
            <div class="flex flex-col items-center">
                <div class="text-3xl lg:text-4xl font-black text-amber-300 mb-1 tracking-tighter">@stats.SatisfactionRate.ToString("F1")</div>
                <div class="flex gap-0.5 mb-0.5">
                    @for(int i=0; i<5; i++) { <span class="material-symbols-outlined text-[12px] text-amber-300 @(i < Math.Floor((double)stats.SatisfactionRate) ? "fill-current" : "")">star</span> }
                </div>
                <div class="text-[10px] lg:text-xs font-bold text-emerald-200/60 uppercase tracking-widest">Average Rating</div>
            </div>
        </div>
    </div>
</section>

@* ─── COURSES SECTION ─────────────────────────────────────────────────── *@
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        @{
            var featuredCourses = ViewBag.FeaturedCourses as List<CourseMarketplaceFE.Models.PublicCourseViewModel> ?? new List<CourseMarketplaceFE.Models.PublicCourseViewModel>();
        }
        
        <div class="mb-12">
            <h2 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-3">Featured Courses</h2>
            <p class="text-lg text-slate-500 leading-relaxed">Top courses highly rated by our community. The top 3 receive honor badges.</p>
        </div>

        @if (!featuredCourses.Any())
        {
            <div class="py-24 flex flex-col items-center justify-center text-center bg-slate-50 rounded-3xl border border-dashed border-slate-200 mb-24">
                <h3 class="text-xl font-bold text-slate-700 mb-2">Updating featured list...</h3>
            </div>
        }
        else
        {
            var isCarousel = featuredCourses.Count > 4;
            @* Marquee Carousel Section *@
            <div class="relative overflow-hidden mb-32 -mx-4 sm:-mx-6 lg:-mx-8">
                <div class="@(isCarousel ? "animate-marquee" : "flex flex-wrap justify-center") gap-8 px-4 sm:px-6 lg:px-8 py-4">
                    @* Render 2 times only for infinite loop effect if carousel is active *@
                    @for (int loop = 0; loop < (isCarousel ? 2 : 1); loop++)
                    {
                        @for (int i = 0; i < featuredCourses.Count; i++)
                        {
                            var course = featuredCourses[i];
                            var rank = i + 1;
                            <div class="w-[320px] flex flex-col h-full bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-2xl hover:shadow-slate-200/50 hover:-translate-y-2 transition-all duration-500 ease-out-expo group cursor-pointer" 
                                 onclick="location.href='/Course/Details/@course.CourseId'">
                                <div class="relative w-full aspect-[16/9] overflow-hidden bg-slate-100 shrink-0">
                                    <img src="@(string.IsNullOrEmpty(course.CourseThumbnailUrl) ? "/img/default-course.png" : course.CourseThumbnailUrl)" 
                                         onerror="this.onerror=null; this.src='/img/default-course.png';"
                                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out-expo" 
                                         alt="@course.Title" />
                                    
                                    @* Rank Badges for Top 3 *@
                                    @if (rank <= 3)
                                    {
                                        <div class="absolute top-0 left-0 p-3 z-20">
                                            @if (rank == 1)
                                            {
                                                <div class="bg-amber-400 text-white px-3 py-1 rounded-br-xl rounded-tl-lg font-black text-[10px] flex items-center gap-1 shadow-lg border border-amber-200/50">
                                                    <span class="material-symbols-outlined text-[12px] fill-current">workspace_premium</span> NO.1
                                                </div>
                                            }
                                            else if (rank == 2)
                                            {
                                                <div class="bg-slate-300 text-slate-800 px-3 py-1 rounded-br-xl rounded-tl-lg font-black text-[10px] flex items-center gap-1 shadow-lg border border-slate-200/50">
                                                    <span class="material-symbols-outlined text-[12px] fill-current">workspace_premium</span> NO.2
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="bg-orange-400 text-white px-3 py-1 rounded-br-xl rounded-tl-lg font-black text-[10px] flex items-center gap-1 shadow-lg border border-orange-200/50">
                                                    <span class="material-symbols-outlined text-[12px] fill-current">workspace_premium</span> NO.3
                                                </div>
                                            }
                                        </div>
                                    }

                                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent group-hover:opacity-0 transition-opacity"></div>
                                </div>
                                <div class="p-6 flex flex-col flex-grow">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-[9px] font-black text-primary uppercase tracking-widest px-2 py-0.5 bg-primary/5 rounded">Featured</span>
                                        <div class="flex items-center gap-0.5 text-amber-400">
                                            <span class="material-symbols-outlined text-[14px] fill-current">star</span>
                                            <span class="text-xs font-bold text-slate-700">@course.RatingAverage.ToString("F1")</span>
                                        </div>
                                    </div>
                                    <h3 class="text-sm font-bold text-slate-900 line-clamp-2 leading-snug mb-4 group-hover:text-primary transition-colors">
                                        @course.Title
                                    </h3>
                                    <div class="mt-auto flex items-center justify-between border-t border-slate-50 pt-4">
                                        <span class="text-xs text-slate-500 truncate max-w-[120px]">@course.InstructorName</span>
                                        <div class="text-base font-black text-slate-900">
                                            @if (course.Price == 0)
                                            {
                                                <span class="text-emerald-600 uppercase text-xs">Free</span>
                                            }
                                            else
                                            {
                                                <span>$@course.Price.ToString("N2")</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        }

        <!-- New Releases -->
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
            <div class="max-w-2xl">
                <h2 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-3">New Releases</h2>
                <p class="text-lg text-slate-500 leading-relaxed">Top 8 recently released courses with the latest skills this week.</p>
            </div>
            <a href="/Course?sort=newest" class="inline-flex items-center gap-2 text-primary font-bold hover:text-primary/80 transition-colors group">
                View All 
                <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform ease-out-expo">arrow_forward</span>
            </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 mb-24">
            @{
                var recentCourses = ViewBag.RecentCourses as List<CourseMarketplaceFE.Models.PublicCourseViewModel> ?? new List<CourseMarketplaceFE.Models.PublicCourseViewModel>();
            }
            @foreach (var course in recentCourses)
            {
                <div class="flex flex-col h-full bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-2xl hover:shadow-slate-200/50 hover:-translate-y-1 transition-all duration-300 ease-out-expo group cursor-pointer" 
                     onclick="location.href='/Course/Details/@course.CourseId'">
                    <div class="relative w-full aspect-[16/9] overflow-hidden bg-slate-100 shrink-0">
                        <img src="@(string.IsNullOrEmpty(course.CourseThumbnailUrl) ? "/img/default-course.png" : course.CourseThumbnailUrl)" 
                             onerror="this.onerror=null; this.src='/img/default-course.png';"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out-expo" 
                             alt="@course.Title" loading="lazy" />
                        <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors"></div>

                        @* Wishlist Toggle *@
                        @if (course.Price > 0)
                        {
                            <button type="button" 
                                    class="absolute top-3 right-3 z-30 w-9 h-9 rounded-full bg-white/90 @(course.IsInWishlist ? "text-red-500" : "text-slate-400") flex items-center justify-center hover:bg-white hover:text-red-500 hover:scale-110 shadow-sm transition-all duration-300"
                                    onclick="event.stopPropagation(); toggleWishlist(this, @course.CourseId);">
                                <span class="material-symbols-outlined text-[20px]" style='font-variation-settings: "FILL" @(course.IsInWishlist ? "1" : "0");'>favorite</span>
                            </button>
                        }
                    </div>
                    <div class="p-6 flex flex-col flex-grow">
                        <h3 class="text-lg font-bold text-slate-900 line-clamp-2 leading-snug mb-2 group-hover:text-primary transition-colors">
                            @course.Title
                        </h3>
                        <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
                            <span class="material-symbols-outlined text-[18px]">person</span>
                            <span class="truncate">@course.InstructorName</span>
                        </div>
                        <div class="flex items-center gap-1.5 mb-6">
                            <span class="text-sm font-bold text-slate-800">@course.RatingAverage.ToString("F1")</span>
                            <div class="flex text-amber-400">
                                @for(int i=0; i<Math.Floor((double)course.RatingAverage); i++) { <span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star</span> }
                                @if((double)course.RatingAverage - Math.Floor((double)course.RatingAverage) >= 0.5) { <span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star_half</span> }
                            </div>
                            <span class="text-xs text-slate-400 font-medium">(@course.TotalStudents)</span>
                        </div>
                        <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                            <div class="text-xl font-extrabold text-slate-900 tracking-tight">
                                @if (course.Price == 0)
                                {
                                    <span class="text-emerald-600 uppercase text-lg">Free</span>
                                }
                                else
                                {
                                    <span>$@course.Price.ToString("N2")</span>
                                }
                            </div>

                            @if (course.IsEnrolled)
                            {
                                <div class="w-10 h-10 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center shadow-sm" title="Enrolled">
                                    <span class="material-symbols-outlined text-[18px]">check_circle</span>
                                </div>
                            }
                            else if (course.Price == 0)
                            {
                                <button type="button" 
                                        class="px-4 py-2 rounded-xl bg-primary text-white text-xs font-bold hover:bg-emerald-700 hover:scale-105 active:scale-95 shadow-sm transition-all duration-300 z-20 flex items-center gap-1"
                                        onclick="event.stopPropagation(); enrollFree(@course.CourseId, this);">
                                    <span class="material-symbols-outlined text-sm">person_add</span>
                                    Enroll
                                </button>
                            }
                            else
                            {
                                <button type="button" 
                                        class="w-10 h-10 rounded-full bg-slate-50 text-slate-500 flex items-center justify-center hover:bg-primary hover:text-white hover:scale-110 active:scale-95 shadow-sm transition-all duration-300 z-20"
                                        onclick="event.stopPropagation(); addToCart(@course.CourseId, this);"
                                        title="Add to cart">
                                    <span class="material-symbols-outlined text-[18px]" style='font-variation-settings:"FILL" 1;'>add_shopping_cart</span>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@* ─── CATEGORIES SECTION ─────────────────────────────────────────────────── *@
<section class="py-24 bg-slate-50 border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-2xl mx-auto mb-16">
            <h2 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">Explore Categories</h2>
            <p class="text-lg text-slate-500">Expand your skills with diverse specializations taught by industry leaders.</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
            @{
                var displayCategories = ViewBag.Categories as List<CourseMarketplaceFE.Models.CategoryViewModel> ?? new List<CourseMarketplaceFE.Models.CategoryViewModel>();
                var iconMap = new Dictionary<string, (string Icon, string Color, string Bg)>
                {
                    { "Development", ("code", "text-blue-600", "bg-blue-50") },
                    { "Design", ("brush", "text-orange-600", "bg-orange-50") },
                    { "Marketing", ("monitoring", "text-emerald-600", "bg-emerald-50") },
                    { "Business", ("account_balance", "text-indigo-600", "bg-indigo-50") },
                    { "Photography & Video", ("photo_camera", "text-pink-600", "bg-pink-50") },
                    { "Music", ("music_note", "text-purple-600", "bg-purple-50") },
                    { "Languages", ("language", "text-amber-600", "bg-amber-50") },
                    { "Health & Fitness", ("favorite", "text-rose-600", "bg-rose-50") },
                    { "Data Science", ("database", "text-cyan-600", "bg-cyan-50") },
                    { "Personal Development", ("psychology", "text-teal-600", "bg-teal-50") },
                    { "Finance & Investing", ("finance", "text-violet-600", "bg-violet-50") },
                    { "Office Productivity", ("table_chart", "text-sky-600", "bg-sky-50") },
                    { "Lifestyle", ("home", "text-lime-600", "bg-lime-50") }
                };
            }

            @foreach (var cat in displayCategories)
            {
                var style = iconMap.ContainsKey(cat.CategoriesName) ? iconMap[cat.CategoriesName] : ("school", "text-slate-600", "bg-slate-50");
                <a href="/Course?category=@cat.CategoriesName" class="group flex flex-col items-center justify-center p-8 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-primary/20 hover:shadow-primary/10 hover:-translate-y-1 transition-all duration-300 ease-out-expo text-center">
                    <div class="w-16 h-16 @style.Item3 @style.Item2 rounded-full flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 ease-out-expo">
                        <span class="material-symbols-outlined text-3xl">@style.Item1</span>
                    </div>
                    <h3 class="font-bold text-slate-800 text-sm">@cat.CategoriesName</h3>
                </a>
            }
        </div>
    </div>
</section>