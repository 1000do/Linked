@model CourseMarketplaceFE.Models.InstructorStudioViewModel
@{
    ViewData["Title"] = "Instructor Studio";
    Layout = "_InstructorLayout";
    var courseList = Model.Courses;
    var totalStudents = Model.TotalStudents;
    var activeCourses = Model.ActiveCoursesCount;
    var avgRating = Model.AverageRating;

}

<div class="p-8 max-w-[1100px] mx-auto">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-headline font-extrabold text-slate-900">Dashboard</h1>
            <p class="text-slate-500 mt-2">Manage your curriculum and track performance across @courseList.Count active courses.</p>
        </div>
        <div class="flex items-center gap-3">
            <div id="view-toggle" class="bg-white border border-slate-200 rounded-lg p-1 flex items-center shadow-sm">
                <button data-view="list" class="view-btn px-3 py-1.5 bg-slate-100 rounded text-slate-800 text-sm font-semibold flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">format_list_bulleted</span> List
                </button>
                <button data-view="grid" class="view-btn px-3 py-1.5 text-slate-500 hover:text-slate-800 text-sm font-semibold flex items-center gap-2 transition-colors">
                    <span class="material-symbols-outlined text-[18px]">grid_view</span> Grid
                </button>
            </div>
        </div>
    </div>

    <!-- STATS CARDS -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Total Enrollment</h3>
            <p class="text-3xl font-headline font-extrabold text-slate-900">@totalStudents.ToString("N0")</p>
            <p class="text-xs font-semibold text-primary mt-2 flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">trending_up</span> +14% this month
            </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Average Rating</h3>
            <p class="text-3xl font-headline font-extrabold text-slate-900">@avgRating.ToString("F2")</p>
            <p class="text-xs font-semibold text-amber-600 mt-2 flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px] fill-amber-600" style='font-variation-settings: "FILL" 1;'>star</span> Top 5% Instructor
            </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
            <h3 class="text-sm font-semibold text-slate-500 mb-1">Active Courses</h3>
            <p class="text-3xl font-headline font-extrabold text-slate-900">@activeCourses</p>
            <p class="text-xs font-medium text-slate-500 mt-2">@(Model.PendingCoursesCount + Model.DraftCoursesCount) Pending / Draft</p>
        </div>
    </div>

    <!-- ACTION BAR -->
    <div class="flex flex-wrap items-center justify-between gap-4 mb-6 bg-slate-50/50 backdrop-blur-md p-4 border border-slate-200 rounded-2xl">
        <div class="flex flex-wrap items-center gap-3 flex-1 min-w-[300px]">
            <div class="relative w-72">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                <input type="text" id="course-search-input" value="@Model.SearchTerm" placeholder="Search courses by title..." class="w-full bg-white border border-slate-200 rounded-lg py-2 pl-10 pr-4 text-sm focus:ring-2 focus:ring-primary/20 outline-none placeholder:text-slate-400 shadow-sm" onkeydown="if(event.key === 'Enter') applyFilters()" />
            </div>
            
            <div class="relative">
                <select id="status-filter" onchange="applyFilters()" class="appearance-none border border-slate-200 rounded-lg pl-4 pr-10 py-2 text-sm font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-shadow text-slate-700 shadow-sm cursor-pointer">
                    <option value="All" selected="@(string.IsNullOrEmpty(Model.FilterStatus) || Model.FilterStatus == "All")">All Status</option>
                    <option value="Draft" selected="@(Model.FilterStatus == "Draft")">Draft</option>
                    <option value="Pending" selected="@(Model.FilterStatus == "Pending")">Pending Review</option>
                    <option value="Published" selected="@(Model.FilterStatus == "Published")">Published</option>
                    <option value="Rejected" selected="@(Model.FilterStatus == "Rejected")">Rejected</option>
                    <option value="Removed" selected="@(Model.FilterStatus == "Removed")">Removed</option>
                    <option value="Archived" selected="@(Model.FilterStatus == "Archived")">Archived</option>
                    <option value="permanently_locked" selected="@(Model.FilterStatus == "permanently_locked")">Permanently Locked</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
            </div>

            <div class="relative">
                <select id="course-sort" onchange="applySort()" class="appearance-none border border-slate-200 rounded-lg pl-4 pr-10 py-2 text-sm font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-shadow text-slate-700 shadow-sm cursor-pointer">
                    <option value="newest">Updated: Newest</option>
                    <option value="oldest">Updated: Oldest</option>
                    <option value="students-desc">Students: High to Low</option>
                    <option value="rating-desc">Rating: High to Low</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
            </div>

            <button type="button" onclick="clearFilters()" class="flex items-center gap-1.5 px-3 py-2 border border-slate-200 hover:bg-slate-50 text-slate-600 text-sm font-bold rounded-lg transition-all shadow-sm active:scale-95">
                <span class="material-symbols-outlined text-[20px]">filter_alt_off</span>
                Clear
            </button>
        </div>

        <div class="flex items-center gap-3">
            <a href="/InstructorCourse/Trash" class="px-5 py-2 bg-white text-slate-700 border border-slate-200 font-bold rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-2 shadow-sm">
                <span class="material-symbols-outlined text-[18px]">delete</span>
                Trash
            </a>
            <a href="/InstructorCourse/Create" class="px-5 py-2 bg-primary hover:bg-secondary text-white font-bold rounded-lg transition-colors shadow-md shadow-primary/20 flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Create New Course
            </a>
        </div>
    </div>

    <!-- COURSES TABLE (List View) -->
    <div id="list-view" class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-8">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-200 text-xs font-bold text-slate-500 uppercase tracking-wider">
                        <th class="px-6 py-4 w-2/5">Course Details</th>
                        <th class="px-6 py-4">Students</th>
                        <th class="px-6 py-4">Rating</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <!-- Rendered Reactively -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- COURSES GRID (Grid View - hidden by default) -->
    <div id="grid-view" class="hidden grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 mb-8">
        <!-- Rendered Reactively -->
    </div>

    <div id="pagination-container" class="px-6 py-4 border border-slate-200 flex items-center justify-between bg-white rounded-2xl shadow-sm mb-8">
        <!-- Rendered Reactively -->
    </div>

    <!-- BANNER -->
    <div class="bg-gradient-to-r from-surface-container-low to-primary-container/30 rounded-2xl p-8 border border-primary-container/50 flex items-center justify-between">
        <div>
            <span class="px-3 py-1 bg-primary text-white text-[10px] font-extrabold uppercase tracking-widest rounded-full">New Feature</span>
            <h2 class="text-2xl font-headline font-extrabold text-slate-900 mt-4 mb-2">Boost your course engagement with Quizzes</h2>
            <p class="text-slate-600 max-w-xl">Create comprehensive assessments to evaluate your students' understanding. Independent quizzes can be built once and assigned to any of your courses seamlessly.</p>
        </div>
        <a href="/Quiz" class="px-6 py-3 bg-primary text-white rounded-xl font-bold flex items-center gap-2 hover:bg-secondary transition-colors shadow-lg shadow-primary/20">
            Create a Quiz <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
        </a>
    </div>
</div>

<!-- Delete confirmation modal -->
<div id="delete-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-2xl p-8 max-w-md w-full mx-4 shadow-2xl">
        <div class="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="material-symbols-outlined text-red-600 text-[24px]">warning</span>
        </div>
        <h3 class="text-lg font-headline font-bold text-slate-900 text-center mb-2">Delete Course</h3>
        <p class="text-sm text-slate-500 text-center mb-6">Are you sure you want to delete "<span id="delete-course-name"></span>"? This action cannot be undone.</p>
        <div class="flex gap-3">
            <button onclick="closeDeleteModal()" class="flex-1 px-4 py-2.5 bg-slate-100 text-slate-700 font-bold rounded-lg hover:bg-slate-200 transition-colors">Cancel</button>
            <button id="confirm-delete-btn" class="flex-1 px-4 py-2.5 bg-red-600 text-white font-bold rounded-lg hover:bg-red-700 transition-colors">Delete</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // List / Grid toggle
        const viewBtns = document.querySelectorAll('.view-btn');
        const listView = document.getElementById('list-view');
        const gridView = document.getElementById('grid-view');

        viewBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const view = btn.dataset.view;
                viewBtns.forEach(b => {
                    b.classList.remove('bg-slate-100', 'text-slate-800');
                    b.classList.add('text-slate-500');
                });
                btn.classList.add('bg-slate-100', 'text-slate-800');
                btn.classList.remove('text-slate-500');

                if (view === 'list') {
                    listView.classList.remove('hidden');
                    gridView.classList.add('hidden');
                } else {
                    listView.classList.add('hidden');
                    gridView.classList.remove('hidden');
                }
            });
        });

        // Search and Filter Logic
        const allCourses = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(courseList.Select(c => new {
            Id = c.Id,
            Title = c.Title,
            ThumbnailUrl = c.ThumbnailUrl,
            Students = c.Students,
            Rating = c.Rating,
            Status = c.Status,
            UpdatedAt = c.UpdatedAt,
            IsRemoved = c.IsRemoved,
            FlagCount = c.FlagCount
        })));

        const ITEMS_PER_PAGE = 6;
        let currentPage = @Model.CurrentPage;
        let totalItems = @Model.TotalItems;
        let totalPages = @Model.TotalPages;
        
        // This is now purely the current page data from server
        let displayedCourses = [...allCourses];

        function renderListView(courses) {
            const tbody = document.querySelector("#list-view tbody");
            if (courses.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-24 text-center bg-slate-50/30">
                    <div class="flex flex-col items-center justify-center text-slate-400">
                        <span class="material-symbols-outlined text-4xl mb-2 text-slate-300">inventory_2</span>
                        <p class="text-sm font-bold text-slate-700">No courses match your criteria</p>
                    </div>
                </td></tr>`;
                return;
            }

            tbody.innerHTML = courses.map(course => {
                const date = new Date(course.UpdatedAt);
                const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' });
                
                let statusBadge = '';
                const isPermanentlyLocked = (course.Status.toLowerCase() === 'archived' && course.FlagCount >= 3);
                const status = isPermanentlyLocked ? 'permanently_locked' : course.Status.toLowerCase();
                
                if (course.IsRemoved) {
                    statusBadge = `<span class="px-3 py-1 bg-red-100 text-red-700 border border-red-300 rounded-full text-xs font-bold">Removed</span>`;
                } else if (status === 'published') {
                    statusBadge = `<span class="px-3 py-1 bg-primary-container/20 text-primary border border-primary-container rounded-full text-xs font-bold">Published</span>`;
                } else if (status === 'pending') {
                    statusBadge = `<span class="px-3 py-1 bg-amber-50 text-amber-600 border border-amber-200 rounded-full text-xs font-bold">Pending Review</span>`;
                } else if (status === 'rejected') {
                    statusBadge = `<span class="px-3 py-1 bg-red-50 text-red-600 border border-red-200 rounded-full text-xs font-bold">Rejected</span>`;
                } else if (status === 'draft') {
                    statusBadge = `<span class="px-3 py-1 bg-slate-100 text-slate-600 border border-slate-200 rounded-full text-xs font-bold">Draft</span>`;
                } else if (status === 'permanently_locked') {
                    statusBadge = `<span class="px-3 py-1 bg-red-800 text-white shadow-lg shadow-red-900/20 rounded-full text-xs font-bold">Permanently Locked</span>`;
                } else if (status === 'archived' || status === 'hidden') {
                    statusBadge = `<span class="px-3 py-1 bg-slate-200 text-slate-700 border border-slate-300 rounded-full text-xs font-bold">Archived</span>`;
                } else {
                    statusBadge = `<span class="px-3 py-1 bg-slate-100 text-slate-500 border border-slate-200 rounded-full text-xs font-bold">${course.Status}</span>`;
                }

                let ratingHtml = '';
                if (course.Rating > 0) {
                    ratingHtml = `<div class="flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-[16px] text-amber-400" style='font-variation-settings: "FILL" 1;'>star</span>
                        <span class="font-bold text-slate-900 text-sm">${course.Rating.toFixed(2)}</span>
                    </div>`;
                } else {
                    ratingHtml = `<div class="flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-[16px] text-slate-300" style='font-variation-settings: "FILL" 1;'>star</span>
                        <span class="font-medium text-slate-400 text-sm">--</span>
                    </div>`;
                }

                let hideBtn = '';
                if (status === 'archived' || status === 'hidden') {
                    hideBtn = `<button onclick="toggleHide(${course.Id}, 'published')" title="Unhide course" class="w-8 h-8 flex items-center justify-center text-emerald-500 hover:bg-emerald-50 rounded-full transition-colors">
                        <span class="material-symbols-outlined text-[18px]">unarchive</span>
                    </button>`;
                } else if (status === 'published') {
                    hideBtn = `<button onclick="toggleHide(${course.Id}, 'archived')" title="Hide course" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-amber-600 hover:bg-amber-50 rounded-full transition-colors">
                        <span class="material-symbols-outlined text-[18px]">archive</span>
                    </button>`;
                }

                const titleSafe = course.Title.replace(/'/g, "\\'");
                const isHidden = status === 'archived' || status === 'hidden';
                const isRemoved = course.IsRemoved;
                const rowClass = (isHidden || isRemoved) ? "hover:bg-slate-50/50 transition-colors group opacity-40 hover:opacity-100 grayscale-[0.5] hover:grayscale-0" : "hover:bg-slate-50/50 transition-colors group";

                let actionsHtml = '';
                if (isRemoved) {
                    actionsHtml = `
                        <a href="/InstructorCourse/Editor/${course.Id}" title="View course" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-primary hover:bg-primary-container/20 rounded-full transition-colors">
                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                        </a>
                    `;
                } else if (status === 'permanently_locked') {
                    actionsHtml = `
                        <a href="/Course/Details/${course.Id}" title="View details" target="_blank" class="w-8 h-8 flex items-center justify-center text-red-500 hover:text-red-700 hover:bg-red-50 rounded-full transition-colors">
                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                        </a>
                    `;
                } else {
                    const isReadOnly = status === 'pending';
                    actionsHtml = `
                        <a href="/InstructorCourse/Editor/${course.Id}" title="${isReadOnly ? 'View course' : 'Edit course'}" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-primary hover:bg-primary-container/20 rounded-full transition-colors">
                            <span class="material-symbols-outlined text-[18px]">${isReadOnly ? 'visibility' : 'edit'}</span>
                        </a>
                        ${hideBtn}
                        <button title="Delete course" onclick="confirmDelete(${course.Id}, '${titleSafe}', ${course.Students})" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-full transition-colors">
                            <span class="material-symbols-outlined text-[18px]">delete</span>
                        </button>
                    `;
                }

                return `<tr class="${rowClass}">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-4">
                            <div class="w-24 h-16 bg-slate-200 rounded-lg overflow-hidden flex-shrink-0 relative">
                                ${course.ThumbnailUrl 
                                    ? `<img src="${course.ThumbnailUrl}" alt="${course.Title}" class="w-full h-full object-cover" />`
                                    : `<div class="w-full h-full bg-gradient-to-br from-primary to-primary-container opacity-80"></div>`
                                }
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 text-sm">${course.Title}</h4>
                                <p class="text-xs text-slate-500 mt-1">Updated ${dateStr}</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <p class="font-bold text-slate-900 text-sm">${new Intl.NumberFormat('en-US').format(course.Students)}</p>
                        <p class="text-xs text-slate-500">Students</p>
                    </td>
                    <td class="px-6 py-4">
                        ${ratingHtml}
                    </td>
                    <td class="px-6 py-4">
                        ${statusBadge}
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            ${actionsHtml}
                        </div>
                    </td>
                </tr>`;
            }).join("");
        }

        function renderGridView(courses) {
            const grid = document.getElementById("grid-view");
            if (courses.length === 0) {
                grid.innerHTML = `<div class="col-span-full py-24 text-center bg-slate-50/30 rounded-2xl border border-slate-200">
                    <div class="flex flex-col items-center justify-center text-slate-400">
                        <span class="material-symbols-outlined text-4xl mb-2 text-slate-300">inventory_2</span>
                        <p class="text-sm font-bold text-slate-700">No courses match your criteria</p>
                    </div>
                </div>`;
                return;
            }

            grid.innerHTML = courses.map(course => {
                const date = new Date(course.UpdatedAt);
                const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' });
                
                let statusBadge = '';
                const isPermanentlyLocked = (course.Status.toLowerCase() === 'archived' && course.FlagCount >= 3);
                const status = isPermanentlyLocked ? 'permanently_locked' : course.Status.toLowerCase();

                if (course.IsRemoved) {
                    statusBadge = `<span class="px-2 py-1 bg-red-100 text-red-700 rounded text-[10px] font-bold">Removed</span>`;
                } else if (status === 'published') {
                    statusBadge = `<span class="px-2 py-1 bg-white/90 text-primary rounded text-[10px] font-bold">Published</span>`;
                } else if (status === 'pending') {
                    statusBadge = `<span class="px-2 py-1 bg-white/90 text-amber-600 rounded text-[10px] font-bold">Pending Review</span>`;
                } else if (status === 'rejected') {
                    statusBadge = `<span class="px-2 py-1 bg-white/90 text-red-600 rounded text-[10px] font-bold">Rejected</span>`;
                } else if (status === 'permanently_locked') {
                    statusBadge = `<span class="px-2 py-1 bg-red-800 text-white rounded text-[10px] font-bold">Permanently Locked</span>`;
                } else {
                    statusBadge = `<span class="px-2 py-1 bg-white/90 text-slate-600 rounded text-[10px] font-bold">${course.Status}</span>`;
                }

                let ratingHtml = '';
                if (course.Rating > 0) {
                    ratingHtml = `<span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[14px] text-amber-400" style='font-variation-settings: "FILL" 1;'>star</span>
                        ${course.Rating.toFixed(2)}
                    </span>`;
                }

                const isHidden = status === 'archived' || status === 'hidden';
                let cardClass = isHidden ? "bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow group block opacity-40 hover:opacity-100 grayscale-[0.5] hover:grayscale-0" : "bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow group block";
                if (course.IsRemoved || status === 'permanently_locked') cardClass += " opacity-50 grayscale hover:opacity-75";

                const courseLink = status === 'permanently_locked' ? `/Course/Details/${course.Id}` : `/InstructorCourse/Editor/${course.Id}`;

                return `<a href="${courseLink}" ${status === 'permanently_locked' ? 'target="_blank"' : ''} class="${cardClass}">
                    <div class="w-full h-40 bg-slate-200 relative overflow-hidden">
                        ${course.ThumbnailUrl
                            ? `<img src="${course.ThumbnailUrl}" alt="${course.Title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />`
                            : `<div class="w-full h-full bg-gradient-to-br from-primary to-primary-container opacity-80 group-hover:opacity-100 transition-opacity"></div>`
                        }
                        <div class="absolute top-3 right-3">
                            ${statusBadge}
                        </div>
                    </div>
                    <div class="p-5">
                        <h4 class="font-bold text-slate-900 text-sm mb-2">${course.Title}</h4>
                        <div class="flex items-center justify-between text-xs text-slate-500">
                            <span>${new Intl.NumberFormat('en-US').format(course.Students)} students</span>
                            ${ratingHtml}
                        </div>
                        <p class="text-[10px] text-slate-400 mt-2">Updated ${dateStr}</p>
                    </div>
                </a>`;
            }).join("");
        }

        function applySort() {
            const sort = document.getElementById('course-sort').value;
            // Sorting is only applied to the current page as backend API doesn't support sort parameter yet
            if (sort === 'newest') {
                displayedCourses.sort((a, b) => new Date(b.UpdatedAt) - new Date(a.UpdatedAt));
            } else if (sort === 'oldest') {
                displayedCourses.sort((a, b) => new Date(a.UpdatedAt) - new Date(b.UpdatedAt));
            } else if (sort === 'students-desc') {
                displayedCourses.sort((a, b) => b.Students - a.Students);
            } else if (sort === 'rating-desc') {
                displayedCourses.sort((a, b) => b.Rating - a.Rating);
            }
            renderListView(displayedCourses);
            renderGridView(displayedCourses);
        }

        function applyFilters() {
            const searchTerm = document.getElementById('course-search-input').value.trim();
            const status = document.getElementById('status-filter').value;
            
            // Redirect to server-side filter
            let url = '/InstructorCourse?page=1';
            if (searchTerm) url += '&searchTerm=' + encodeURIComponent(searchTerm);
            if (status && status !== 'All') url += '&status=' + encodeURIComponent(status);
            
            window.location.href = url;
        }

        function clearFilters() {
            window.location.href = '/InstructorCourse';
        }

        function renderAll() {
            applySort(); // Applies initial sort to current page data
            renderPagination();
        }

        function renderPagination() {
            const container = document.getElementById('pagination-container');
            if (totalPages <= 1) {
                container.innerHTML = '';
                container.classList.add('hidden');
                return;
            }
            container.classList.remove('hidden');

            const startIdx = (currentPage - 1) * ITEMS_PER_PAGE + 1;
            const endIdx = Math.min(currentPage * ITEMS_PER_PAGE, totalItems);

            let buttonsHtml = '';
            // Generate pagination logic (max 5 pages shown)
            let startPage = Math.max(1, currentPage - 2);
            let endPage = Math.min(totalPages, startPage + 4);
            if (endPage - startPage < 4) {
                startPage = Math.max(1, endPage - 4);
            }

            for (let i = startPage; i <= endPage; i++) {
                buttonsHtml += `<button onclick="changePage(${i})" class="w-10 h-10 rounded-lg border ${currentPage === i ? 'bg-primary text-white border-primary font-bold' : 'border-slate-200 hover:bg-white text-slate-600 font-semibold'} transition-all">${i}</button>`;
            }

            container.innerHTML = `
                <p class="text-sm text-slate-500">
                    Showing <span class="font-bold text-slate-700">${startIdx} - ${endIdx}</span> of <span class="font-bold text-slate-700">${totalItems}</span> courses
                </p>
                <div class="flex items-center gap-1">
                    <button onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} class="p-2 rounded-lg border border-slate-200 hover:bg-white disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                        <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                    </button>
                    ${buttonsHtml}
                    <button onclick="changePage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''} class="p-2 rounded-lg border border-slate-200 hover:bg-white disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                        <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                    </button>
                </div>
            `;
        }

        window.changePage = function(page) {
            if (page < 1 || page > totalPages) return;
            const searchTerm = document.getElementById('course-search-input').value.trim();
            const status = document.getElementById('status-filter').value;
            
            let url = '/InstructorCourse?page=' + page;
            if (searchTerm) url += '&searchTerm=' + encodeURIComponent(searchTerm);
            if (status && status !== 'All') url += '&status=' + encodeURIComponent(status);
            
            window.location.href = url;
        };

        // Delete modal
        let deleteTargetId = null;
        function confirmDelete(id, name, students) {
            if (students > 0) {
                Swal.fire({
                    title: 'Cannot Delete!',
                    text: `The course "${name}" currently has ${students} enrolled learners. You cannot delete this course to protect their learning access.`,
                    icon: 'warning',
                    confirmButtonColor: '#006a62'
                });
                return;
            }
            deleteTargetId = id;
            document.getElementById('delete-course-name').textContent = name;
            document.getElementById('delete-modal').classList.remove('hidden');
        }
        function closeDeleteModal() {
            document.getElementById('delete-modal').classList.add('hidden');
            deleteTargetId = null;
        }
        document.getElementById('confirm-delete-btn').addEventListener('click', async () => {
            if (deleteTargetId) {
                const btn = document.getElementById('confirm-delete-btn');
                btn.disabled = true; btn.textContent = 'Deleting...';
                try {
                    const resp = await fetch('/InstructorCourse/Delete?id=' + deleteTargetId, { method: 'POST' });
                    const result = await resp.json();
                    if (result.success) {
                        location.reload();
                    } else {
                        Swal.fire('Error', 'Delete failed: ' + (result.message || 'Unknown error'), 'error');
                    }
                } catch(e) { Swal.fire('Error', 'An error occurred: ' + e.message, 'error'); }
                btn.disabled = false; btn.textContent = 'Delete';
                closeDeleteModal();
            }
        });

        // Toggle Hide/Show
        async function toggleHide(id, newStatus) {
            const confirmText = (newStatus === 'archived' || newStatus === 'Hidden') 
                ? 'Are you sure you want to hide this course? New students will not be able to find it.' 
                : 'Do you want to make this course visible again?';
                
            const { isConfirmed } = await Swal.fire({
                title: 'Confirm Change',
                text: confirmText,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#006a62',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes',
                cancelButtonText: 'Cancel'
            });

            if (isConfirmed) {
                try {
                    const formData = new FormData();
                    formData.append('courseId', id);
                    formData.append('status', newStatus);

                    const resp = await fetch('/InstructorCourse/UpdateCourseStatus', {
                        method: 'POST',
                        body: formData
                    });
                    const result = await resp.json();
                    if (result.success) {
                        location.reload();
                    } else {
                        Swal.fire('Error', result.message || 'Could not update status', 'error');
                    }
                } catch(e) { Swal.fire('Error', 'An error occurred: ' + e.message, 'error'); }
            }
        }
        
        // Close modal on backdrop click
        document.getElementById('delete-modal').addEventListener('click', (e) => {
            if (e.target === e.currentTarget) closeDeleteModal();
        });

        // Initial render
        document.addEventListener("DOMContentLoaded", () => {
            renderAll();

            @if (TempData["Error"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Access Denied',
                    text: '@Html.Raw(TempData["Error"]?.ToString()?.Replace("'", "\\'"))',
                    confirmButtonColor: '#d33'
                });
                </text>
            }
        });
    </script>
}
