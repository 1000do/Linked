@{
    ViewData["Title"] = "Curriculum Editor";
    Layout = "_InstructorLayout";
    var courseId = ViewBag.CourseId ?? 1;
}

<div class="p-8 h-full flex flex-col">
    <div class="flex items-center justify-between mb-8 flex-shrink-0">
        <div class="flex items-center gap-4">
            <a href="/InstructorCourse" class="text-slate-400 hover:text-primary transition-colors"><span class="material-symbols-outlined text-[20px]">arrow_back</span></a>
            <h1 class="text-2xl font-headline font-extrabold text-slate-900">Course Structure</h1>
            <span class="px-2 py-1 bg-primary-container/20 text-primary border border-primary-container rounded text-[10px] font-bold uppercase tracking-wider">Draft</span>
        </div>
        <div class="flex items-center gap-3">
            <a href="/Course/Details/@courseId" target="_blank" class="px-4 py-2 bg-white text-slate-700 font-bold border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">visibility</span> Preview
            </a>
            <button class="px-5 py-2 bg-emerald-600 text-white font-bold rounded-lg hover:bg-emerald-700 transition-colors shadow-lg shadow-emerald-600/20 flex items-center gap-2" onclick="submitCourseForReview()">
                <span class="material-symbols-outlined text-[18px]">send</span> Submit for Review
            </button>
        </div>
    </div>

    <div class="flex gap-8 h-full overflow-hidden">
        <!-- LEFT: Course Structure -->
        <div class="w-80 flex-shrink-0 flex flex-col gap-4 overflow-hidden">
            <div class="flex border-b border-slate-200 mb-2">
                <button class="flex-1 py-3 text-sm font-bold border-b-2 border-primary text-primary" id="btn-tab-curriculum" onclick="switchMainTab('curriculum')">Curriculum</button>
                <button class="flex-1 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors" id="btn-tab-landing" onclick="switchMainTab('landing')">Course Landing Page</button>
            </div>
            
            <div id="course-structure-container" class="flex-1 flex flex-col gap-4 overflow-y-auto pb-8 pr-2 custom-scrollbar">
                <!-- Dynamic content injected by JS -->
            </div>
        </div>

        <!-- RIGHT: Lesson Editor / Landing Page Editor -->
        <div class="flex-1 flex flex-col bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden relative">
            
            <!-- Tab: Landing Page Editor (Hidden by default) -->
            <div id="landing-page-editor" class="hidden flex-1 flex-col h-full overflow-y-auto p-8 custom-scrollbar">
                <div class="max-w-4xl mx-auto space-y-12">
                    <div>
                        <h2 class="text-3xl font-headline font-extrabold text-slate-900 mb-2">Course Landing Page</h2>
                        <p class="text-slate-500">Your course landing page is crucial to your success. Make it stand out!</p>
                    </div>

                    <div class="grid grid-cols-1 gap-8">
                        <!-- Basic Info -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Course Title</label>
                            <input type="text" id="course-title-input" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary" value="@ViewBag.CourseTitle" />
                        </div>

                        <!-- Description -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Course Description</label>
                            <div class="bg-white rounded-xl">
                                <div id="course-description-editor">@Html.Raw(ViewBag.Description)</div>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-8">
                            <!-- Category -->
                            <div class="space-y-4">
                                <label class="text-sm font-bold text-slate-900 block">Category</label>
                                <select id="course-category-input" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary">
                                    <!option value="1" @(ViewBag.CategoryId == 1 ? "selected" : "")>Design & Creative</!option>
                                    <!option value="2" @(ViewBag.CategoryId == 2 ? "selected" : "")>Development</!option>
                                    <!option value="3" @(ViewBag.CategoryId == 3 ? "selected" : "")>Business</!option>
                                </select>
                            </div>
                            <!-- Price -->
                            <div class="space-y-4">
                                <div class="flex items-center justify-between">
                                    <label class="text-sm font-bold text-slate-900 block">Price (USD)</label>
                                    <span class="text-xs text-slate-500 font-medium bg-slate-100 px-2 py-1 rounded">Min: $0.00</span>
                                </div>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                        <span class="text-slate-500 font-bold material-symbols-outlined text-[18px]">attach_money</span>
                                    </div>
                                    <input type="number" id="course-price-input" min="0" step="0.01" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary font-semibold text-slate-800 transition-colors" value="@ViewBag.Price" placeholder="0.00" onblur="formatPrice(this)" />
                                </div>
                                
                                <!-- Quick Price Tiers -->
                                <div class="flex flex-wrap gap-2 mt-3">
                                    <button type="button" onclick="setPrice(0)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">Free</button>
                                    <button type="button" onclick="setPrice(9.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$9.99</button>
                                    <button type="button" onclick="setPrice(19.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$19.99</button>
                                    <button type="button" onclick="setPrice(49.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$49.99</button>
                                    <button type="button" onclick="setPrice(99.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$99.99</button>
                                </div>
                            </div>
                        </div>

                        <!-- What you will learn -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">What you will learn (one per line or list)</label>
                            <div class="bg-white rounded-xl">
                                <div id="course-learn-editor">@Html.Raw(ViewBag.WhatYouWillLearn)</div>
                            </div>
                        </div>

                        <!-- Requirements -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Requirements</label>
                            <div class="bg-white rounded-xl">
                                <div id="course-req-editor">@Html.Raw(ViewBag.Requirements)</div>
                            </div>
                        </div>

                        <!-- Thumbnail -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Course Thumbnail URL</label>
                            <div class="flex gap-4">
                                <input type="text" id="course-thumbnail-input" class="flex-1 px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary" value="@ViewBag.ThumbnailUrl" />
                                <div class="w-24 h-16 bg-slate-100 rounded-lg overflow-hidden border border-slate-200">
                                    <img id="course-thumbnail-preview" src="@(string.IsNullOrEmpty(ViewBag.ThumbnailUrl) ? "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=200" : ViewBag.ThumbnailUrl)" class="w-full h-full object-cover" />
                                </div>
                            </div>
                        </div>
                        
                        <div class="pt-6 border-t border-slate-100 flex justify-end">
                            <button class="px-8 py-3 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-all shadow-lg shadow-primary/20 flex items-center gap-2" onclick="saveCourseDetails()" id="save-course-details-btn">
                                <span class="material-symbols-outlined text-[20px]">save</span> Save Course Details
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Empty State -->
            <div id="lesson-editor-empty" class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center bg-white z-10">
                <div class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mb-6 border border-slate-100">
                    <span class="material-symbols-outlined text-[48px] text-slate-300">edit_document</span>
                </div>
                <h2 class="text-2xl font-headline font-extrabold text-slate-900 mb-2">No Lesson Selected</h2>
                <p class="text-slate-500 max-w-sm">Select a lesson from the curriculum on the left or create a new one to start editing.</p>
                <button onclick="addNewLesson()" class="mt-8 px-6 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors shadow-lg shadow-primary/20 flex items-center gap-2 mx-auto">
                    <span class="material-symbols-outlined text-[18px]">add</span> Create New Lesson
                </button>
            </div>

            <!-- Active Editor -->
            <div id="lesson-editor-active" class="hidden flex-1 flex-col h-full opacity-0 transition-opacity duration-300">
                <div class="p-6 border-b border-slate-200 flex items-center justify-between bg-slate-50/50">
                <div>
                    <div class="flex items-center gap-2 text-[10px] font-bold text-primary uppercase tracking-widest mb-2">
                        <span class="material-symbols-outlined text-[14px]">edit</span> Editing Lesson <span id="editing-lesson-id">--</span>
                    </div>
                    <h2 id="editing-lesson-title" class="text-3xl font-headline font-extrabold text-slate-900">Select a Lesson</h2>
                    <div class="flex items-center gap-4 mt-2 text-xs font-semibold text-slate-500">
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">schedule</span> <span id="editing-lesson-duration">0 mins</span></span>
                        <span id="editing-lesson-status-badge" class="flex items-center gap-1 text-slate-400">
                            <span class="material-symbols-outlined text-[16px]">pending_actions</span> 
                            <span id="editing-lesson-status-text">Draft</span>
                        </span>
                    </div>
                </div>
                <div class="flex gap-3">
                    <!-- Actions are now within tabs -->
                </div>
            </div>

            <div class="flex-1 overflow-y-auto p-8 custom-scrollbar">
                <!-- Tabs -->
                <div class="flex border-b border-slate-200 mb-8">
                    <button class="tab-btn px-6 py-3 border-b-2 border-primary text-primary font-bold text-sm" data-tab="tab-video">Video Content</button>
                    <button class="tab-btn px-6 py-3 border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-semibold text-sm transition-colors" data-tab="tab-resources">Resources & Files</button>
                </div>

                <!-- Tab: Video Content -->
                <div id="tab-video" class="tab-content">
                    <div class="grid grid-cols-3 gap-8">
                        <div class="col-span-2">
                            <div class="max-w-2xl mx-auto mb-12">
                                <input type="hidden" id="MaterialUrl" name="MaterialUrl" />
                                <div id="video-drop-area" class="border-2 border-dashed border-slate-200 rounded-2xl p-12 text-center hover:bg-slate-50 transition-colors cursor-pointer group">
                                    <div class="w-20 h-20 bg-primary-container/30 text-primary rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                                        <span class="material-symbols-outlined text-[40px]">movie</span>
                                    </div>
                                    <h3 class="text-lg font-bold text-slate-900 mb-2">Upload Lesson Video</h3>
                                    <p class="text-sm text-slate-500 mb-4">MP4, WebM or OGG up to 2GB</p>
                                    <span class="px-6 py-2 bg-white border border-slate-200 rounded-lg text-slate-700 font-bold text-sm hover:bg-slate-50 inline-block">Browse Files</span>
                                    <input type="file" id="video-input" accept="video/*" class="hidden" />
                                </div>
                                <div id="video-upload-progress" class="hidden text-center py-8">
                                    <div class="w-16 h-16 bg-primary-container/30 text-primary rounded-2xl flex items-center justify-center mx-auto mb-6">
                                        <span class="material-symbols-outlined text-[32px]">cloud_upload</span>
                                    </div>
                                    <h3 id="upload-filename-display" class="text-xl font-bold text-slate-900 mb-2"></h3>
                                    <p class="text-sm text-slate-500 mb-6">Processing <span id="progress-text">0</span>% • Do not close this tab during upload.</p>
                                    <div class="h-2 bg-slate-100 rounded-full w-full max-w-md mx-auto mb-8 overflow-hidden">
                                        <div id="progress-bar-fill" class="h-full bg-primary-container transition-all duration-300" style="width: 0%"></div>
                                    </div>
                                    <div class="flex justify-center gap-4">
                                        <button type="button" id="cancel-upload" class="px-6 py-2.5 bg-red-50 text-red-600 font-bold rounded-lg flex items-center gap-2 hover:bg-red-100 transition-colors">
                                            <span class="material-symbols-outlined text-[18px]">cancel</span> Cancel Upload
                                        </button>
                                    </div>
                                </div>
                                <div id="video-success" class="hidden border border-slate-200 rounded-2xl p-6 flex items-center justify-between bg-surface-container-low">
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 bg-primary text-white rounded-lg flex items-center justify-center">
                                            <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>play_circle</span>
                                        </div>
                                        <div>
                                            <h4 class="font-bold text-slate-900" id="uploaded-filename"></h4>
                                            <p class="text-xs text-slate-500">Video successfully processed</p>
                                        </div>
                                    </div>
                                    <button class="text-slate-400 hover:text-red-500 transition-colors" onclick="resetVideoUpload()"><span class="material-symbols-outlined">delete</span></button>
                                </div>
                            </div>
                            
                            <div class="mt-8">
                                <label class="text-sm font-bold text-slate-900 mb-2 block">Video Description</label>
                                <div class="bg-white rounded-xl">
                                    <div id="video-editor"></div>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-6">
                            <button class="w-full px-6 py-3 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors shadow-lg shadow-primary/20" onclick="saveVideoMaterial()" id="save-video-btn">Save Video Content</button>
                            
                            <div class="bg-white rounded-xl p-5 border border-slate-200">
                                <label class="block text-sm font-bold text-slate-900 mb-4">Visibility & Access</label>
                                <label id="downloadable-label" class="toggle-card flex items-start gap-4 p-4 rounded-xl border-2 border-primary bg-primary/5 cursor-pointer transition-all">
                                    <div class="mt-0.5 text-primary"><span class="material-symbols-outlined text-[20px]">download</span></div>
                                    <div class="flex-1">
                                        <p class="font-bold text-slate-900 text-sm">Downloadable</p>
                                        <p class="text-[10px] text-slate-500 mt-1">Allow students to save offline</p>
                                    </div>
                                    <div class="mt-1"><input type="checkbox" id="cb-downloadable" checked class="w-5 h-5 border-2 border-primary rounded text-primary focus:ring-primary" /></div>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tab: Resources -->
                <div id="tab-resources" class="tab-content hidden">
                    <div class="grid grid-cols-3 gap-8">
                        <div class="col-span-2">
                            <!-- Existing Resources -->
                            <div class="mb-8">
                                <h4 class="font-bold text-slate-900 mb-4">Uploaded Resources</h4>
                                <div id="resources-list" class="space-y-3">
                                    <div class="text-slate-500 text-sm italic py-4 text-center border-2 border-dashed border-slate-200 rounded-lg bg-slate-50">No resources uploaded yet.</div>
                                </div>
                            </div>
                            
                            <!-- Add New Resource Form -->
                            <div class="bg-slate-50 p-6 rounded-xl border border-slate-200">
                                <h4 class="font-bold text-slate-900 mb-4">Add New Resource</h4>
                                
                                <div class="mb-4">
                                    <label class="text-sm font-bold text-slate-700 block mb-2">Resource File</label>
                                    <div class="flex items-center gap-4">
                                        <input type="hidden" id="ResourceUrl" name="ResourceUrl" />
                                        <input type="file" id="resource-input" class="hidden" />
                                        <button id="upload-resource-btn" class="px-4 py-2 bg-white border border-slate-300 text-slate-700 font-bold rounded-lg hover:bg-slate-50 transition-colors shadow-sm">
                                            Choose File
                                        </button>
                                        <span id="resource-upload-progress" class="hidden text-primary font-bold text-sm">Uploading...</span>
                                        <span id="resource-file-name" class="text-sm text-slate-500">No file chosen</span>
                                    </div>
                                </div>
                                
                                <div class="mb-4">
                                    <label class="text-sm font-bold text-slate-700 block mb-2">Resource Title</label>
                                    <input type="text" id="resource-title-input" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:ring-primary focus:border-primary" placeholder="e.g. Presentation Slides" />
                                </div>
                                
                                <div>
                                    <label class="text-sm font-bold text-slate-700 block mb-2">Resource Description</label>
                                    <div class="bg-white rounded-xl">
                                        <div id="resource-editor"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-6">
                            <button class="w-full px-6 py-3 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors shadow-lg shadow-primary/20" onclick="saveResourceMaterial()" id="save-resource-btn">Save Resource</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>

<!-- Add Lesson Modal -->
<div id="add-lesson-modal" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 transform scale-95 transition-transform duration-300">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-headline font-extrabold text-slate-900">Add New Lesson</h3>
            <button onclick="closeLessonModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="mb-6">
            <label class="block text-sm font-bold text-slate-700 mb-2">Lesson Title</label>
            <input type="text" id="new-lesson-title" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-900 font-medium" placeholder="e.g. 1.1 Introduction to the Course" onkeydown="if(event.key==='Enter') submitNewLesson()" />
        </div>
        <div class="flex justify-end gap-3">
            <button onclick="closeLessonModal()" class="px-5 py-2.5 bg-slate-100 text-slate-600 font-bold rounded-lg hover:bg-slate-200 transition-colors">Cancel</button>
            <button onclick="submitNewLesson()" class="px-5 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors shadow-lg shadow-primary/20" id="submit-lesson-btn">Create Lesson</button>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
</style>

@section Scripts {
    <script>
        // ─── Quill ───
        const quillConfig = {
            theme: 'snow',
            modules: { toolbar: [['bold','italic'],[{'list':'ordered'},{'list':'bullet'}],['link','code-block']] }
        };
        window.videoQuill = new Quill('#video-editor', { ...quillConfig, placeholder: 'Describe the video content...' });
        window.resourceQuill = new Quill('#resource-editor', { ...quillConfig, placeholder: 'Describe this resource...' });
        
        // Course Landing Page Quills
        window.courseDescQuill = new Quill('#course-description-editor', { ...quillConfig, placeholder: 'Detailed course description...' });
        window.courseLearnQuill = new Quill('#course-learn-editor', { ...quillConfig, placeholder: 'What will students achieve?' });
        window.courseReqQuill = new Quill('#course-req-editor', { ...quillConfig, placeholder: 'What do students need before starting?' });

        // ─── Main Tabs Switching ───
        window.switchMainTab = function(tab) {
            const btnCurriculum = document.getElementById('btn-tab-curriculum');
            const btnLanding = document.getElementById('btn-tab-landing');
            const structureContainer = document.getElementById('course-structure-container');
            const lessonEditorEmpty = document.getElementById('lesson-editor-empty');
            const lessonEditorActive = document.getElementById('lesson-editor-active');
            const landingEditor = document.getElementById('landing-page-editor');

            if (tab === 'curriculum') {
                btnCurriculum.className = "flex-1 py-3 text-sm font-bold border-b-2 border-primary text-primary";
                btnLanding.className = "flex-1 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors";
                structureContainer.classList.remove('hidden');
                
                landingEditor.classList.add('hidden');
                landingEditor.style.display = 'none';

                // Determine which curriculum state to show
                if (lessonsData.length === 0) {
                    lessonEditorEmpty.classList.remove('hidden');
                    lessonEditorEmpty.style.display = 'flex';
                    lessonEditorActive.classList.add('hidden');
                    lessonEditorActive.style.display = 'none';
                } else {
                    const activeId = document.getElementById('editing-lesson-id').textContent;
                    if (activeId !== '--') {
                        lessonEditorActive.classList.remove('hidden');
                        lessonEditorActive.style.display = 'flex';
                        lessonEditorEmpty.classList.add('hidden');
                        lessonEditorEmpty.style.display = 'none';
                    } else {
                        lessonEditorEmpty.classList.remove('hidden');
                        lessonEditorEmpty.style.display = 'flex';
                        lessonEditorActive.classList.add('hidden');
                        lessonEditorActive.style.display = 'none';
                    }
                }
            } else {
                btnLanding.className = "flex-1 py-3 text-sm font-bold border-b-2 border-primary text-primary";
                btnCurriculum.className = "flex-1 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors";
                structureContainer.classList.add('hidden');
                
                landingEditor.classList.remove('hidden');
                landingEditor.style.display = 'flex';
                
                lessonEditorEmpty.classList.add('hidden');
                lessonEditorEmpty.style.display = 'none';
                lessonEditorActive.classList.add('hidden');
                lessonEditorActive.style.display = 'none';
            }
        };

        window.saveCourseDetails = async function() {
            const btn = document.getElementById('save-course-details-btn');
            const title = document.getElementById('course-title-input').value;
            const price = document.getElementById('course-price-input').value;
            const catId = document.getElementById('course-category-input').value;
            const thumb = document.getElementById('course-thumbnail-input').value;
            
            const desc = window.courseDescQuill.root.innerHTML;
            const learn = window.courseLearnQuill.root.innerHTML;
            const req = window.courseReqQuill.root.innerHTML;

            if (!title) { Swal.fire('Error', 'Title is required', 'error'); return; }

            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> Saving...';

            try {
                const fd = new FormData();
                fd.append('courseId', courseId);
                fd.append('title', title);
                fd.append('description', desc);
                fd.append('price', price);
                fd.append('categoryId', catId);
                fd.append('thumbnailUrl', thumb);
                fd.append('whatYouWillLearn', learn);
                fd.append('requirements', req);

                const res = await fetch('/InstructorCourse/UpdateDetails', { method: 'POST', body: fd });
                if (res.ok) {
                    const json = await res.json();
                    if (json.success) {
                        Swal.fire({ icon: 'success', title: 'Saved!', text: 'Course details updated successfully.', timer: 1500, showConfirmButton: false });
                        document.querySelector('h1').textContent = title;
                        document.getElementById('course-thumbnail-preview').src = thumb || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=200";
                    } else {
                        Swal.fire('Error', json.message || 'Failed to update details', 'error');
                    }
                } else {
                    Swal.fire('Error', 'Server error while updating details', 'error');
                }
            } catch (e) {
                Swal.fire('Error', 'An error occurred', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<span class="material-symbols-outlined text-[20px]">save</span> Save Course Details';
            }
        };

        // Thumbnail preview sync
        document.getElementById('course-thumbnail-input').addEventListener('input', function(e) {
            document.getElementById('course-thumbnail-preview').src = e.target.value || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=200";
        });

        // ─── Tabs ───
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('border-primary','text-primary','font-bold'); b.classList.add('border-transparent','text-slate-500','font-semibold'); });
                btn.classList.add('border-primary','text-primary','font-bold');
                btn.classList.remove('border-transparent','text-slate-500','font-semibold');
                document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
                document.getElementById(btn.dataset.tab).classList.remove('hidden');
            });
        });

        // ─── Render Lessons dynamically ───
        const courseId = @courseId;
        // Pass JSON directly as a JS object to avoid quote/newline issues
        let lessonsData = @Html.Raw(ViewBag.LessonsJson ?? "[]");
        
        // Show API error if any
        @if (ViewBag.ApiError != null) {
            <text>
            console.error("API Error:", "@Html.Raw(ViewBag.ApiError)");
            // Show a warning banner at the top
            const errBanner = document.createElement('div');
            errBanner.className = 'mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm font-semibold';
            errBanner.innerHTML = '<span class="material-symbols-outlined text-[16px] align-middle mr-1">error</span> @Html.Raw(ViewBag.ApiError) — Lesson data could not be loaded. Try logging in again.';
            document.querySelector('.p-8')?.prepend(errBanner);
            </text>
        }

        // Debugging — inspect what the server gave us
        console.log("Lessons Data loaded:", lessonsData);
        if (lessonsData.length > 0) {
            console.log("First lesson keys:", Object.keys(lessonsData[0]));
            if (lessonsData[0].learningMaterials || lessonsData[0].LearningMaterials) {
                console.log("First lesson has materials:", lessonsData[0].learningMaterials || lessonsData[0].LearningMaterials);
            } else {
                console.warn("First lesson has NO learningMaterials property. Available keys:", Object.keys(lessonsData[0]));
            }
        } else {
            console.warn("lessonsData is EMPTY. API may have returned 401 or no lessons exist.");
        }

        // ─── UI Element Declarations (moved up to avoid TDZ) ───
        const videoDropArea = document.getElementById('video-drop-area');
        const videoInput = document.getElementById('video-input');
        const uiProgress = document.getElementById('video-upload-progress');
        const uiSuccess = document.getElementById('video-success');
        const progressBarFill = document.getElementById('progress-bar-fill');
        const progressText = document.getElementById('progress-text');
        const uploadedFilename = document.getElementById('uploaded-filename');
        const materialUrlInput = document.getElementById('MaterialUrl');
        let currentXHR = null;

        // Remove unused resource references to avoid null errors
        function renderCourseStructure() {
            const container = document.getElementById('course-structure-container');
            container.innerHTML = '';
            
            // Render a default section wrapper (since we don't have sections API yet)
            let sectionHtml = `
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden border-l-4 border-l-primary mb-4">
                <div class="p-4 bg-slate-50/50 flex items-center justify-between">
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Course Curriculum</p>
                        <h3 class="font-bold text-slate-900 text-sm">Main Section</h3>
                    </div>
                </div>
                <div class="p-4 space-y-2">
            `;
            
            lessonsData.forEach((lesson, index) => {
                const num = index + 1;
                // Safely get lesson properties (handle both PascalCase and camelCase)
                const lId = lesson.lessonId || lesson.LessonId;
                const lTitle = lesson.title || lesson.Title;
                
                const currentEditingId = document.getElementById('editing-lesson-id').textContent;
                const isSelected = currentEditingId == num;
                const activeClasses = isSelected ? 'border-primary ring-1 ring-primary/20 shadow-sm' : 'border-slate-100 hover:border-slate-300';
                
                sectionHtml += `
                    <div class="lesson-item p-3 bg-white border rounded-lg flex items-start gap-3 cursor-pointer transition-colors ${activeClasses}" 
                         data-lesson-id="${lId}" data-num="${num}" data-title="${lTitle}" onclick="selectLesson(this)">
                        <span class="material-symbols-outlined text-${isSelected ? 'primary' : 'slate-400'} text-[20px] mt-0.5" ${isSelected ? "style='font-variation-settings: \"FILL\" 1;'" : ""}>play_circle</span>
                        <div class="flex-1">
                            <p class="font-bold text-slate-900 text-sm">${num}. ${lTitle}</p>
                            <p class="text-[10px] text-slate-500 mt-1">Video Lesson</p>
                        </div>
                    </div>
                `;
            });
            
            sectionHtml += `
                    <button class="w-full py-3 border-2 border-dashed border-slate-200 rounded-lg text-slate-500 hover:text-primary hover:border-primary hover:bg-primary/5 transition-colors flex items-center justify-center gap-2 text-xs font-bold mt-2" onclick="addNewLesson()">
                        <span class="material-symbols-outlined text-[16px]">add_circle</span> Add Lesson
                    </button>
                </div>
            </div>`;
            
            container.innerHTML = sectionHtml;
            
            // Auto-select first lesson if none selected and we have lessons
            if (lessonsData.length > 0) {
                const firstLessonEl = container.querySelector('.lesson-item');
                if (firstLessonEl && (document.getElementById('lesson-editor-empty').classList.contains('z-10') || !document.getElementById('lesson-editor-empty').classList.contains('hidden'))) {
                    selectLesson(firstLessonEl);
                }
            }
        }

        window.selectLesson = function(el) {
            // Show editor, hide empty state
            const emptyState = document.getElementById('lesson-editor-empty');
            const editor = document.getElementById('lesson-editor-active');
            const landingEditor = document.getElementById('landing-page-editor');
            
            // Ensure landing page editor is hidden when selecting a lesson
            landingEditor.classList.add('hidden');
            landingEditor.style.display = 'none';

            emptyState.style.display = 'none';
            emptyState.classList.add('hidden');
            emptyState.classList.remove('z-10');
            emptyState.style.pointerEvents = 'none';
            
            editor.style.display = 'flex';
            editor.classList.remove('hidden');
            editor.classList.add('z-20');
            editor.style.pointerEvents = 'auto';
            setTimeout(() => editor.classList.remove('opacity-0'), 10);
            
            document.querySelectorAll('.lesson-item').forEach(i => {
                i.classList.remove('border-primary','ring-1','ring-primary/20','shadow-sm'); 
                i.classList.add('border-slate-100');
                const icon = i.querySelector('.material-symbols-outlined');
                icon.classList.remove('text-primary'); icon.classList.add('text-slate-400');
                icon.style.fontVariationSettings = '';
            });
            el.classList.add('border-primary','ring-1','ring-primary/20','shadow-sm');
            el.classList.remove('border-slate-100');
            const icon = el.querySelector('.material-symbols-outlined');
            icon.classList.remove('text-slate-400'); icon.classList.add('text-primary');
            icon.style.fontVariationSettings = '"FILL" 1';

            document.getElementById('editing-lesson-id').textContent = el.dataset.num;
            document.getElementById('editing-lesson-title').textContent = el.dataset.title;

            // Extract duration from materialMetadata
            const lessonId = parseInt(el.dataset.lessonId);
            const lesson = lessonsData.find(l => (l.lessonId || l.LessonId) == lessonId);
            console.log("Selecting Lesson:", lessonId, lesson); // Debug log
            let durationDisplay = "0 mins";
            
            // Update Status Badge
            const statusBadge = document.getElementById('editing-lesson-status-badge');
            const statusText = document.getElementById('editing-lesson-status-text');
            const lStatus = (lesson?.lessonStatus || lesson?.LessonStatus || 'draft').toLowerCase();
            
            if (lStatus === 'published') {
                statusBadge.className = "flex items-center gap-1 text-primary";
                statusBadge.querySelector('.material-symbols-outlined').textContent = "check_circle";
                statusText.textContent = "Published";
            } else {
                statusBadge.className = "flex items-center gap-1 text-slate-400";
                statusBadge.querySelector('.material-symbols-outlined').textContent = "pending_actions";
                statusText.textContent = "Draft";
            }
            
            // Clear current form
            if (window.videoQuill) window.videoQuill.root.innerHTML = '';
            if (window.resourceQuill) window.resourceQuill.root.innerHTML = '';
            document.getElementById('MaterialUrl').value = '';
            document.getElementById('ResourceUrl').value = '';
            document.getElementById('resource-title-input').value = '';
            document.getElementById('resource-file-name').textContent = 'No file chosen';
            resetVideoUpload();
            
            const resourcesList = document.getElementById('resources-list');
            resourcesList.innerHTML = '';
            let hasResources = false;
            
            if (lesson) {
                // Handle various casing: learningMaterials, LearningMaterials, learning_materials
                const materials = lesson.learningMaterials || lesson.LearningMaterials || lesson.learning_materials || [];
                console.log("Materials found for lesson:", lessonId, materials);
                
                if (Array.isArray(materials) && materials.length > 0) {
                    materials.forEach(material => {
                        // Extract metadata safely - it might be an object or a JSON string
                        let metadata = material.materialMetadata || material.MaterialMetadata;
                        if (typeof metadata === 'string') {
                            try { metadata = JSON.parse(metadata); } catch(e) { metadata = {}; }
                        }
                        
                        const type = (metadata?.file_type || 'video').toLowerCase();
                        const mUrl = material.materialUrl || material.MaterialUrl;
                        const mDesc = material.description || material.Description;
                        const mTitle = material.title || material.Title;

                        if (type === 'video') {
                            // Populate video description
                            if (mDesc && window.videoQuill) {
                                window.videoQuill.root.innerHTML = mDesc;
                            }
                            // Populate video UI
                            if (mUrl) {
                                document.getElementById('MaterialUrl').value = mUrl;
                                document.getElementById('video-drop-area').classList.add('hidden');
                                document.getElementById('video-success').classList.remove('hidden');
                                document.getElementById('uploaded-filename').textContent = mTitle || "Lesson Video Content";
                                
                                const totalSeconds = metadata?.duration || 0;
                                const mins = Math.floor(totalSeconds / 60);
                                durationDisplay = (mins > 0 ? mins : 0) + " mins";
                            }
                        } else if (type === 'document' || type === 'file') {
                            // Populate resource UI list
                            if (mUrl) {
                                hasResources = true;
                                resourcesList.innerHTML += `
                                    <div class="flex items-center justify-between p-3 bg-white border border-slate-200 rounded-lg shadow-sm">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-[#006a62]/10 text-[#006a62] rounded flex items-center justify-center">
                                                <span class="material-symbols-outlined">description</span>
                                            </div>
                                            <div>
                                                <p class="font-bold text-slate-900 text-sm">${mTitle || "Resource File"}</p>
                                                <p class="text-xs text-slate-500 truncate max-w-xs">${mDesc ? mDesc.replace(/<[^>]*>?/gm, '').substring(0, 50) + "..." : "No description"}</p>
                                            </div>
                                        </div>
                                        <a href="${mUrl}" target="_blank" class="text-[#006a62] hover:bg-[#006a62]/10 p-2 rounded-full transition-colors"><span class="material-symbols-outlined text-[20px]">open_in_new</span></a>
                                    </div>
                                `;
                            }
                        }
                    });
                }
            }
            if (!hasResources) {
                resourcesList.innerHTML = '<div class="text-slate-500 text-sm italic py-4 text-center border-2 border-dashed border-slate-200 rounded-lg bg-slate-50">No resources uploaded yet.</div>';
            }
            const durationEl = document.getElementById('editing-lesson-duration');
            if(durationEl) durationEl.textContent = durationDisplay;
        };

        window.addNewLesson = function() {
            const modal = document.getElementById('add-lesson-modal');
            const input = document.getElementById('new-lesson-title');
            modal.classList.remove('hidden');
            // small delay to allow display block to apply before animating opacity
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.querySelector('div').classList.remove('scale-95');
                input.value = '';
                input.focus();
            }, 10);
        };

        window.closeLessonModal = function() {
            const modal = document.getElementById('add-lesson-modal');
            modal.classList.add('opacity-0');
            modal.querySelector('div').classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        };

        window.submitNewLesson = async function() {
            const input = document.getElementById('new-lesson-title');
            const title = input.value;
            const btn = document.getElementById('submit-lesson-btn');
            
            if (title && title.trim() !== '') {
                btn.disabled = true;
                btn.textContent = 'Creating...';
                
                try {
                    const fd = new FormData();
                    fd.append('courseId', courseId);
                    fd.append('title', title);
                    const res = await fetch('/InstructorCourse/AddLesson', { method: 'POST', body: fd });
                    if(res.ok) {
                        const json = await res.json();
                        if(json.success && json.data) {
                            lessonsData.push(json.data);
                            renderCourseStructure();
                            // Select the newly added lesson
                            setTimeout(() => {
                                const newLessonEl = document.querySelector(`.lesson-item[data-lesson-id="${json.data.lessonId}"]`);
                                if(newLessonEl) selectLesson(newLessonEl);
                            }, 50);
                            closeLessonModal();
                        } else {
                            alert('Failed to add lesson: ' + (json.message || 'Unknown error'));
                        }
                    } else {
                        alert('Failed to add lesson');
                    }
                } catch(e) {
                    alert('Error adding lesson');
                } finally {
                    btn.disabled = false;
                    btn.textContent = 'Create Lesson';
                }
            } else {
                input.focus();
                input.classList.add('ring-2', 'ring-red-500/50', 'border-red-500');
                setTimeout(() => input.classList.remove('ring-2', 'ring-red-500/50', 'border-red-500'), 2000);
            }
        };

        // Render on init
        renderCourseStructure();
        
        // Format initial price — deferred to after formatPrice definition (line ~966)

        // ─── Checkbox toggle styling ───
        function updateToggleCard(checkboxId, labelId) {
            const cb = document.getElementById(checkboxId);
            if (!cb) return;
            const label = document.getElementById(labelId);
            const icon = label.querySelector('.material-symbols-outlined');
            cb.addEventListener('change', () => {
                if (cb.checked) {
                    label.classList.remove('border','border-slate-200'); label.classList.add('border-2','border-primary','bg-primary/5');
                    if(icon) icon.classList.replace('text-slate-400','text-primary');
                } else {
                    label.classList.remove('border-2','border-primary','bg-primary/5'); label.classList.add('border','border-slate-200');
                    if(icon) icon.classList.replace('text-primary','text-slate-400');
                }
            });
        }
        updateToggleCard('cb-downloadable', 'downloadable-label');



        // ─── Video Upload (XHR with progress) ───
        videoDropArea.addEventListener('click', () => videoInput.click());
        videoInput.addEventListener('change', function() { handleVideoUpload(this.files); });
        ['dragenter','dragover','dragleave','drop'].forEach(ev => videoDropArea.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); }, false));
        ['dragenter','dragover'].forEach(ev => videoDropArea.addEventListener(ev, () => videoDropArea.classList.add('border-primary','bg-primary/5'), false));
        ['dragleave','drop'].forEach(ev => videoDropArea.addEventListener(ev, () => videoDropArea.classList.remove('border-primary','bg-primary/5'), false));
        videoDropArea.addEventListener('drop', e => handleVideoUpload(e.dataTransfer.files), false);

        function handleVideoUpload(files) {
            if (!files.length) return;
            const file = files[0];
            if (!file.type.startsWith('video/')) { alert('Please upload a video file.'); return; }
            videoDropArea.classList.add('hidden');
            uiProgress.classList.remove('hidden');
            document.getElementById('upload-filename-display').textContent = `Uploading "${file.name}"`;
            progressBarFill.style.width = '0%'; progressText.textContent = '0';

            const CLOUD_NAME = 'df8i0azc5';
            const UPLOAD_PRESET = 'course_marketplace_preset';
            const url = `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/video/upload`;
            const fd = new FormData(); fd.append('upload_preset', UPLOAD_PRESET); fd.append('file', file);
            const xhr = new XMLHttpRequest(); currentXHR = xhr;

            xhr.upload.addEventListener('progress', e => {
                if (e.lengthComputable) { const pct = Math.round(e.loaded/e.total*100); progressBarFill.style.width=pct+'%'; progressText.textContent=pct; }
            });
            xhr.addEventListener('load', () => {
                if (xhr.status >= 200 && xhr.status < 300) {
                    const data = JSON.parse(xhr.responseText);
                    setTimeout(() => { uiProgress.classList.add('hidden'); uiSuccess.classList.remove('hidden'); uploadedFilename.textContent=file.name; materialUrlInput.value=data.secure_url; }, 400);
                } else { handleUploadError('Upload failed: ' + xhr.statusText); }
            });
            xhr.addEventListener('error', () => handleUploadError('Network error during upload.'));
            xhr.addEventListener('abort', () => resetVideoUpload());
            xhr.open('POST', url, true); xhr.send(fd);
        }

        document.getElementById('cancel-upload').addEventListener('click', () => { if(currentXHR) currentXHR.abort(); });
        function handleUploadError(msg) { alert(msg); resetVideoUpload(); }
        function resetVideoUpload() { videoDropArea.classList.remove('hidden'); uiProgress.classList.add('hidden'); uiSuccess.classList.add('hidden'); videoInput.value=''; materialUrlInput.value=''; }
        window.resetVideoUpload = resetVideoUpload;

        // ─── Save Draft / Submit ───
        window.saveVideoMaterial = async function() {
            const lessonIdEl = document.querySelector('.lesson-item.border-primary');
            if (!lessonIdEl) { Swal.fire({ icon: 'warning', title: 'Oops...', text: 'Please select a lesson first.' }); return; }
            const lessonId = lessonIdEl.dataset.lessonId;
            const title = lessonIdEl.dataset.title;
            const description = window.videoQuill.root.innerHTML;
            const materialUrl = document.getElementById('MaterialUrl').value;
            
            if (!materialUrl) { Swal.fire({ icon: 'warning', title: 'Oops...', text: 'Please upload a video first.' }); return; }

            const btn = document.getElementById('save-video-btn');
            btn.disabled = true; btn.textContent = 'Saving...';
            
            try {
                const fd = new FormData();
                fd.append('lessonId', lessonId);
                fd.append('title', title + " Video");
                if(description && description !== '<p><br></p>') fd.append('description', description);
                fd.append('materialUrl', materialUrl);
                fd.append('type', 'video');
                
                const res = await fetch('/InstructorCourse/AddMaterial', { method: 'POST', body: fd });
                if(res.ok) {
                    const json = await res.json();
                    if(json.success) {
                        Swal.fire({ icon: 'success', title: 'Saved!', text: 'Video content saved successfully.', timer: 1500, showConfirmButton: false });
                        if (json.data) updateLocalMaterials(lessonId, json.data, 'video');
                    } else { Swal.fire({ icon: 'error', title: 'Error', text: "Failed to save: " + (json.message || "Unknown error") }); }
                } else { Swal.fire({ icon: 'error', title: 'Error', text: "Failed to save video content." }); }
            } catch(e) { Swal.fire({ icon: 'error', title: 'Error', text: "Error saving video." }); } 
            finally { btn.disabled = false; btn.textContent = 'Save Video Content'; }
        };

        window.saveResourceMaterial = async function() {
            const lessonIdEl = document.querySelector('.lesson-item.border-primary');
            if (!lessonIdEl) { Swal.fire({ icon: 'warning', title: 'Oops...', text: 'Please select a lesson first.' }); return; }
            const lessonId = lessonIdEl.dataset.lessonId;
            const description = window.resourceQuill.root.innerHTML;
            const resourceUrl = document.getElementById('ResourceUrl').value;
            const resourceName = document.getElementById('resource-title-input').value || "Resource File";
            
            if (!resourceUrl) { Swal.fire({ icon: 'warning', title: 'Oops...', text: 'Please upload a resource file first.' }); return; }

            const btn = document.getElementById('save-resource-btn');
            btn.disabled = true; btn.textContent = 'Adding...';
            
            try {
                const fd = new FormData();
                fd.append('lessonId', lessonId);
                fd.append('title', resourceName);
                if(description && description !== '<p><br></p>') fd.append('description', description);
                fd.append('materialUrl', resourceUrl);
                fd.append('type', 'document');
                
                const res = await fetch('/InstructorCourse/AddMaterial', { method: 'POST', body: fd });
                if(res.ok) {
                    const json = await res.json();
                    if(json.success) {
                        Swal.fire({ icon: 'success', title: 'Added!', text: 'Resource added successfully.', timer: 1500, showConfirmButton: false });
                        
                        // Clear form
                        document.getElementById('ResourceUrl').value = '';
                        document.getElementById('resource-title-input').value = '';
                        window.resourceQuill.root.innerHTML = '';
                        document.getElementById('resource-file-name').textContent = 'No file chosen';
                        
                        if (json.data) updateLocalMaterials(lessonId, json.data, 'document', true); // true to append, not replace
                    } else { Swal.fire({ icon: 'error', title: 'Error', text: "Failed to add: " + (json.message || "Unknown error") }); }
                } else { Swal.fire({ icon: 'error', title: 'Error', text: "Failed to add resource." }); }
            } catch(e) { Swal.fire({ icon: 'error', title: 'Error', text: "Error adding resource." }); } 
            finally { btn.disabled = false; btn.textContent = 'Add Resource'; }
        };

        function updateLocalMaterials(lessonId, newMat, type, append = false) {
            const lesson = lessonsData.find(l => (l.lessonId || l.LessonId) == lessonId);
            if (lesson) {
                if (!lesson.learningMaterials) lesson.learningMaterials = [];
                if (append) {
                    lesson.learningMaterials.push(newMat);
                } else {
                    const existingIdx = lesson.learningMaterials.findIndex(m => {
                        const mType = m.materialMetadata?.file_type || 'video';
                        return mType === type;
                    });
                    if (existingIdx !== -1) lesson.learningMaterials[existingIdx] = newMat;
                    else lesson.learningMaterials.push(newMat);
                }
                const lessonIdEl = document.querySelector('.lesson-item.border-primary');
                if (lessonIdEl) selectLesson(lessonIdEl);
            }
        }

        window.submitCourseForReview = function() {
            Swal.fire({
                title: 'Submit for review?',
                text: "Are you sure you want to submit this course for review? Once submitted, administrators will review your content before it is published to students.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#006a62',
                cancelButtonColor: '#cbd5e1',
                confirmButtonText: 'Yes, submit it!'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const res = await fetch('/InstructorCourse/UpdateCourseStatus', { 
                            method: 'POST', 
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: new URLSearchParams({ courseId: courseId, status: 'published' })
                        });
                        
                        if (res.ok) {
                            const json = await res.json();
                            if (json.success) {
                                Swal.fire('Submitted!', 'Course submitted for review successfully! Status changed to Pending Review.', 'success');
                                const badge = document.querySelector('span.bg-primary-container\\/20');
                                if(badge) {
                                    badge.textContent = 'PENDING REVIEW';
                                    badge.classList.add('bg-amber-100', 'text-amber-700', 'border-amber-200');
                                    badge.classList.remove('bg-primary-container/20', 'text-primary', 'border-primary-container');
                                }
                            } else {
                                Swal.fire('Error', json.message || 'Failed to update course status.', 'error');
                            }
                        } else {
                            Swal.fire('Error', 'Failed to update course status.', 'error');
                        }
                    } catch (e) {
                        Swal.fire('Error', 'An error occurred while communicating with the server.', 'error');
                    }
                }
            });
        };


        // ─── Price Formatting & Quick Selection ───
        window.formatPrice = function(input) {
            if (!input.value) {
                input.value = "0.00";
                return;
            }
            // Parse float and format to 2 decimal places
            let val = parseFloat(input.value);
            if (isNaN(val) || val < 0) val = 0;
            input.value = val.toFixed(2);
        };

        // Format initial price (must be called AFTER formatPrice is defined)
        const priceInput = document.getElementById('course-price-input');
        if (priceInput) formatPrice(priceInput);

        window.setPrice = function(price) {
            const input = document.getElementById('course-price-input');
            if (input) {
                input.value = parseFloat(price).toFixed(2);
                // Optional: visual feedback that price changed
                input.classList.add('ring-2', 'ring-primary', 'bg-primary/5');
                setTimeout(() => {
                    input.classList.remove('ring-2', 'ring-primary', 'bg-primary/5');
                }, 500);
            }
        };
        
        // ─── Resource Upload ───
        const resourceBtnEl = document.getElementById('upload-resource-btn');
        const resourceProgressEl = document.getElementById('resource-upload-progress');
        const resourceInputEl = document.getElementById('resource-input');
        
        resourceBtnEl.addEventListener('click', () => resourceInputEl.click());
        resourceInputEl.addEventListener('change', function() {
            if (this.files.length > 0) {
                const file = this.files[0];
                resourceBtnEl.classList.add('hidden');
                resourceProgressEl.classList.remove('hidden');
                
                const CLOUD_NAME = 'df8i0azc5';
                const UPLOAD_PRESET = 'course_marketplace_preset';
                const url = `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/raw/upload`;
                const fd = new FormData(); fd.append('upload_preset', UPLOAD_PRESET); fd.append('file', file);
                
                fetch(url, { method: 'POST', body: fd })
                .then(res => res.json())
                .then(data => {
                    resourceProgressEl.classList.add('hidden');
                    resourceBtnEl.classList.remove('hidden');
                    if (data.secure_url) {
                        document.getElementById('resource-file-name').textContent = file.name;
                        document.getElementById('resource-title-input').value = file.name;
                        document.getElementById('ResourceUrl').value = data.secure_url;
                        resourceBtnEl.innerHTML = 'Change File';
                    }
                })
                .catch(err => {
                    resourceProgressEl.classList.add('hidden');
                    resourceBtnEl.classList.remove('hidden');
                    alert('Resource upload failed');
                });
            }
        });
    </script>
}
