        window.updateLessonTitleInline = function(newTitle) {
            const lessonIdEl = document.querySelector('.lesson-item.border-primary');
            if (!lessonIdEl) return;
            const lessonId = lessonIdEl.dataset.lessonId;
            const currentTitle = lessonIdEl.dataset.title;
            
            if (newTitle === currentTitle || !newTitle.trim()) {
                document.getElementById('editing-lesson-title').value = currentTitle;
                return;
            }
            
            fetch(`/InstructorCourse/UpdateLessonTitle?lessonId=${lessonId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ lessonId: lessonId, title: newTitle.trim() })
            })
            .then(res => res.json())
            .then(json => {
                if(json.success) {
                    const data = JSON.parse(json.data);
                    if (data && data.data) {
                        const updatedTitle = data.data.title;
                        lessonIdEl.dataset.title = updatedTitle;
                        const titleEl = lessonIdEl.querySelector('.lesson-title-display');
                        if (titleEl) titleEl.textContent = updatedTitle;
                        document.getElementById('editing-lesson-title').value = updatedTitle;
                        
                        // Update lessonsData array
                        const l = lessonsData.find(x => (x.lessonId || x.LessonId) == lessonId);
                        if (l) {
                            if (l.title !== undefined) l.title = updatedTitle;
                            else l.Title = updatedTitle;
                        }
                    }
                } else {
                    document.getElementById('editing-lesson-title').value = currentTitle;
                    Swal.fire('Error', json.message || 'Failed to update lesson title', 'error');
                }
            })
            .catch(err => {
                document.getElementById('editing-lesson-title').value = currentTitle;
                Swal.fire('Error', 'An error occurred', 'error');
            });
        };

        window.updateLessonInline = function(lId, field, el) {
            const lesson = lessonsData.find(x => (x.lessonId || x.LessonId) == lId);
            if (!lesson) return;
            
            const currentVal = field === 'title' ? (lesson.title || lesson.Title) : (lesson.description || lesson.Description || 'Video Lesson');
            const newVal = el.value.trim();
            if (newVal === currentVal) return;
            if (field === 'title' && !newVal) {
                el.value = currentVal; // revert
                return;
            }

            const url = field === 'title' 
                ? `/InstructorCourse/UpdateLessonTitle?lessonId=${lId}`
                : `/InstructorCourse/UpdateLessonDescription?lessonId=${lId}`;

            const payload = {};
            payload[field] = newVal;

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(json => {
                if(json.success) {
                    if (field === 'title') {
                        lesson.title = newVal;
                        lesson.Title = newVal; 
                        
                        // Update active editor if this is the currently selected lesson
                        const lessonIdEl = document.querySelector('.lesson-item.border-primary');
                        if (lessonIdEl && lessonIdEl.dataset.lessonId == lId) {
                            document.getElementById('editing-lesson-title').value = newVal;
                            lessonIdEl.dataset.title = newVal;
                        }
                    } else {
                        lesson.description = newVal;
                        lesson.Description = newVal;
                    }
                } else {
                    el.value = currentVal; // revert
                    Swal.fire('Error', json.message || 'Failed to update lesson', 'error');
                }
            })
            .catch(err => {
                el.value = currentVal;
                Swal.fire('Error', 'An error occurred', 'error');
            });
        };

