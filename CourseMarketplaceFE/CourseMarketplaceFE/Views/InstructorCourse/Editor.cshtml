@section Scripts {
    <script>
        // --- GLOBAL FUNCTIONS AT THE TOP ---
        function formatDuration(totalSeconds) {
            totalSeconds = Math.round(totalSeconds || 0);
            if (totalSeconds <= 0) {
                return "0 mins";
            }
            if (totalSeconds < 60) {
                return totalSeconds === 1 ? "1 sec" : totalSeconds + " secs";
            }
            if (totalSeconds < 3600) {
                const mins = Math.round(totalSeconds / 60);
                if (mins === 60) {
                    return "1 hr";
                }
                return mins === 1 ? "1 min" : mins + " mins";
            }
            const hrs = Math.floor(totalSeconds / 3600);
            const remainingMins = Math.round((totalSeconds % 3600) / 60);
            let displayHrs = hrs;
            let displayMins = remainingMins;
            if (displayMins === 60) {
                displayHrs += 1;
                displayMins = 0;
            }
            const hrText = displayHrs === 1 ? "1 hr" : displayHrs + " hrs";
            if (displayMins === 0) {
                return hrText;
            }
            const minText = displayMins === 1 ? "1 min" : displayMins + " mins";
            return `${hrText} ${minText}`;
        }

        const currentStatus = '@(ViewBag.CourseStatus as string ?? "Draft")';
        const isPendingGlobal = currentStatus.toLowerCase() === 'pending';
        let initialVideoDesc = "";
        let isResourceUploading = false;
        let isSubmitting = false;

        window.addNewLesson = function() {
            console.log("Add New Lesson clicked");
            const modal = document.getElementById('add-lesson-modal');
            const input = document.getElementById('new-lesson-title');
            if (!modal) { console.error("Modal not found!"); return; }
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.querySelector('div').classList.remove('scale-95');
                if (input) {
                    input.value = '';
                    input.focus();
                }
            }, 10);
        };

        window.closeLessonModal = function() {
            const modal = document.getElementById('add-lesson-modal');
            if (!modal) return;
            modal.classList.add('opacity-0');
            modal.querySelector('div').classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        };

        console.log("Editor Scripts Initializing...");


        // ─── Quill ───
        const quillConfig = {
            theme: 'snow',
            modules: { toolbar: [['bold','italic'],[{'list':'ordered'},{'list':'bullet'}],['link','code-block']] }
        };
        window.videoQuill = new Quill('#video-editor', { ...quillConfig, placeholder: 'Describe the video content...' });
        window.resourceQuill = new Quill('#resource-editor', { ...quillConfig, placeholder: 'Describe this resource...' });
        


        // Course Landing Page Quills
        window.courseDescQuill = new Quill('#course-description-editor', { ...quillConfig, placeholder: 'Detailed course description...' });
        window.courseLearnQuill = new Quill('#course-learn-editor', { ...quillConfig, placeholder: 'What will students achieve?' });
        window.courseReqQuill = new Quill('#course-req-editor', { ...quillConfig, placeholder: 'What do students need before starting?' });

        // ─── Main Tabs Switching ───
        window.switchMainTab = function(tab) {
            const btnCurriculum = document.getElementById('btn-tab-curriculum');
            const btnLanding = document.getElementById('btn-tab-landing');
            const structureContainer = document.getElementById('course-structure-container');
            const lessonEditorEmpty = document.getElementById('lesson-editor-empty');
            const lessonEditorActive = document.getElementById('lesson-editor-active');
            const landingEditor = document.getElementById('landing-page-editor');

            if (tab === 'curriculum') {
                btnCurriculum.className = "flex-1 py-3 text-sm font-bold border-b-2 border-primary text-primary";
                btnLanding.className = "flex-1 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors";
                structureContainer.classList.remove('hidden');
                
                landingEditor.classList.add('hidden');
                landingEditor.style.display = 'none';

                // Determine which curriculum state to show
                if (lessonsData.length === 0) {
                    lessonEditorEmpty.classList.remove('hidden');
                    lessonEditorEmpty.style.display = 'flex';
                    lessonEditorActive.classList.add('hidden');
                    lessonEditorActive.style.display = 'none';
                } else {
                    const activeId = document.getElementById('editing-lesson-id').textContent;
                    if (activeId !== '--') {
                        lessonEditorActive.classList.remove('hidden');
                        lessonEditorActive.style.display = 'flex';
                        lessonEditorEmpty.classList.add('hidden');
                        lessonEditorEmpty.style.display = 'none';
                    } else {
                        lessonEditorEmpty.classList.remove('hidden');
                        lessonEditorEmpty.style.display = 'flex';
                        lessonEditorActive.classList.add('hidden');
                        lessonEditorActive.style.display = 'none';
                    }
                }
            } else {
                btnLanding.className = "flex-1 py-3 text-sm font-bold border-b-2 border-primary text-primary";
                btnCurriculum.className = "flex-1 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors";
                structureContainer.classList.add('hidden');
                
                landingEditor.classList.remove('hidden');
                landingEditor.style.display = 'flex';
                
                lessonEditorEmpty.classList.add('hidden');
                lessonEditorEmpty.style.display = 'none';
                lessonEditorActive.classList.add('hidden');
                lessonEditorActive.style.display = 'none';
            }
        };

        window.saveCourseDetails = function() {
            const title = document.getElementById('course-title-input').value;
            const price = document.getElementById('course-price-input').value;
            const catId = document.getElementById('course-category-input').value;
            const thumb = document.getElementById('course-thumbnail-input').value;
            
            const desc = window.courseDescQuill ? window.courseDescQuill.root.innerHTML : '';
            
            // Validate basic required fields before checking changes
            if (!title || title.trim() === '') return;
            if (!desc || desc.trim() === '' || desc === '<p><br></p>') return;
            if (catId == "0") return;

            // Stop if there are no actual changes
            if (window.checkUnsavedChanges && !window.checkUnsavedChanges()) {
                return;
            }

            const learn = window.courseLearnQuill ? window.courseLearnQuill.root.innerHTML : '';
            const req = window.courseReqQuill ? window.courseReqQuill.root.innerHTML : '';

            const autoSaveEl = document.getElementById('landing-autosave-status');
            const autoSaveText = document.getElementById('landing-autosave-text');
            
            if (autoSaveEl) {
                autoSaveEl.classList.remove('hidden');
                autoSaveEl.className = "text-xs font-semibold text-slate-400 flex items-center gap-1";
                autoSaveEl.querySelector('.material-symbols-outlined').textContent = 'sync';
                autoSaveEl.querySelector('.material-symbols-outlined').classList.add('animate-spin');
                if (autoSaveText) autoSaveText.textContent = 'Saving...';
            }

            const fd = new FormData();
            fd.append('courseId', courseId);
            fd.append('title', title);
            fd.append('description', desc);
            fd.append('price', price);
            fd.append('categoryId', catId);
            fd.append('thumbnailUrl', thumb);
            fd.append('whatYouWillLearn', learn);
            fd.append('requirements', req);

            return fetch('/InstructorCourse/UpdateDetails', { method: 'POST', body: fd })
                .then(res => res.json())
                .then(json => {
                    if (json.success) {
                        if (json.status && json.status.toLowerCase() === 'pending') {
                            isSubmitting = true;
                            location.reload();
                        } else {
                            const h1El = document.querySelector('h1');
                            if (h1El) h1El.textContent = title;
                            const thumbPrevEl = document.getElementById('course-thumbnail-preview');
                            if (thumbPrevEl) thumbPrevEl.src = thumb || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=200";
                            
                            // Update initial data so subsequent checks work correctly
                            initialCourseData = { title, desc, price, catId, thumb, learn, req };

                            if (autoSaveEl) {
                                autoSaveEl.querySelector('.material-symbols-outlined').textContent = 'check_circle';
                                autoSaveEl.querySelector('.material-symbols-outlined').classList.remove('animate-spin');
                                autoSaveEl.className = "text-xs font-semibold text-emerald-600 flex items-center gap-1";
                                if (autoSaveText) autoSaveText.textContent = 'Saved!';
                                setTimeout(() => autoSaveEl.classList.add('hidden'), 3000);
                            }
                        }
                        return true;
                    } else {
                        if (autoSaveEl) {
                            autoSaveEl.querySelector('.material-symbols-outlined').textContent = 'error';
                            autoSaveEl.querySelector('.material-symbols-outlined').classList.remove('animate-spin');
                            autoSaveEl.className = "text-xs font-semibold text-rose-600 flex items-center gap-1";
                            if (autoSaveText) autoSaveText.textContent = 'Failed to save changes';
                            // if (autoSaveText) autoSaveText.textContent = json.message || 'Failed to save changes';
                            setTimeout(() => autoSaveEl.classList.add('hidden'), 8000);
                        }
                        Swal.fire({
                            icon: 'error',
                            title: 'Error Saving Changes',
                            text: json.message || 'Failed to save changes',
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            // confirmButtonText: 'Dismiss',
                            // confirmButtonColor: '#e11d48',
                            timer: 5000,
                            timerProgressBar: true,
                            background: '#fff1f2',
                            color: '#9f1239',
                            iconColor: '#e11d48',
                            customClass: {
                                popup: 'border-2 border-rose-300 rounded-2xl shadow-xl'
                            }
                        });
                        return false;
                    }
                })
                .catch(e => {
                    if (autoSaveEl) {
                        autoSaveEl.querySelector('.material-symbols-outlined').textContent = 'error';
                        autoSaveEl.querySelector('.material-symbols-outlined').classList.remove('animate-spin');
                        autoSaveEl.className = "text-xs font-semibold text-rose-600 flex items-center gap-1";
                        if (autoSaveText) autoSaveText.textContent = 'System error occurred';
                        setTimeout(() => autoSaveEl.classList.add('hidden'), 8000);
                    }
                });
        };

        // Debounce helper
        function debounce(func, wait) {
            let timeout;
            return function(...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        const debouncedSaveLanding = debounce(() => {
            saveCourseDetails();
        }, 1500);

        // Attach listeners for landing page fields
        ['course-title-input', 'course-category-input', 'course-price-input', 'course-thumbnail-input'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', debouncedSaveLanding);
        });

        if (window.courseDescQuill) window.courseDescQuill.on('text-change', debouncedSaveLanding);
        if (window.courseLearnQuill) window.courseLearnQuill.on('text-change', debouncedSaveLanding);
        if (window.courseReqQuill) window.courseReqQuill.on('text-change', debouncedSaveLanding);


        // Thumbnail preview sync
        document.getElementById('course-thumbnail-input').addEventListener('input', function(e) {
            document.getElementById('course-thumbnail-preview').src = e.target.value || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=400";
        });

        document.getElementById('thumb-fit-input').addEventListener('change', function(e) {
            document.getElementById('course-thumbnail-preview').style.objectFit = e.target.value;
        });

        // ─── Thumbnail Upload ───
        const thumbDropArea = document.getElementById('thumb-drop-area');
        const thumbInput = document.getElementById('thumb-file-input');
        const thumbProgress = document.getElementById('thumb-upload-progress');
        const thumbPreview = document.getElementById('course-thumbnail-preview');
        const thumbUrlInput = document.getElementById('course-thumbnail-input');

        thumbDropArea.addEventListener('click', () => thumbInput.click());
        thumbInput.addEventListener('change', function() { handleThumbUpload(this.files); });
        
        function handleThumbUpload(files) {
            if (!files.length) return;
            const file = files[0];
            if (!file.type.startsWith('image/')) { 
                Swal.fire('Invalid File', 'Please upload an image.', 'warning');
                return; 
            }

            thumbProgress.classList.remove('hidden');
            
            const CLOUD_NAME = 'df8i0azc5';
            const UPLOAD_PRESET = 'course_marketplace_preset';
            const url = `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`;
            
            const fd = new FormData();
            fd.append('upload_preset', UPLOAD_PRESET);
            fd.append('file', file);
            
            fetch(url, { method: 'POST', body: fd })
                .then(res => res.json())
                .then(data => {
                    if (data.secure_url) {
                        thumbUrlInput.value = data.secure_url;
                        thumbPreview.src = data.secure_url;
                        saveCourseDetails().then(isSaved => {
                            if (isSaved) {
                                Swal.fire({ 
                                    icon: 'success', 
                                    title: 'Image Uploaded', 
                                    text: 'Thumbnail updated successfully.', 
                                    timer: 1500,
                                    showConfirmButton: false
                                });
                            }
                        });
                    }
                })
                .catch(err => {
                    Swal.fire('Upload Failed', 'Error uploading image to server.', 'error');
                })
                .finally(() => {
                    thumbProgress.classList.add('hidden');
                });
        }


        // ─── Tabs ───
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('border-primary','text-primary','font-bold'); b.classList.add('border-transparent','text-slate-500','font-semibold'); });
                btn.classList.add('border-primary','text-primary','font-bold');
                btn.classList.remove('border-transparent','text-slate-500','font-semibold');
                document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
                document.getElementById(btn.dataset.tab).classList.remove('hidden');
            });
        });

        // ─── Render Lessons dynamically ───
        const courseId = @courseId;
        // Pass JSON directly as a JS object to avoid quote/newline issues
        let lessonsData = @Html.Raw(ViewBag.LessonsJson ?? "[]");
        let quizzesData = @Html.Raw(ViewBag.QuizzesJson ?? "[]");

        let initialCourseData = {
            title: document.getElementById('course-title-input')?.value || '',
            desc: window.courseDescQuill?.root.innerHTML || '',
            price: document.getElementById('course-price-input')?.value || '0',
            catId: document.getElementById('course-category-input')?.value || '0',
            thumb: document.getElementById('course-thumbnail-input')?.value || '',
            learn: window.courseLearnQuill?.root.innerHTML || '',
            req: window.courseReqQuill?.root.innerHTML || ''
        };

        window.checkUnsavedChanges = function() {
            const title = document.getElementById('course-title-input')?.value || '';
            const price = document.getElementById('course-price-input')?.value || '0';
            const catId = document.getElementById('course-category-input')?.value || '0';
            const thumb = document.getElementById('course-thumbnail-input')?.value || '';
            
            const desc = window.courseDescQuill?.root.innerHTML || '';
            const learn = window.courseLearnQuill?.root.innerHTML || '';
            const req = window.courseReqQuill?.root.innerHTML || '';

            const cleanHtml = (h) => {
                if (!h) return '';
                const trimmed = h.trim();
                return (trimmed === '<p><br></p>' || trimmed === '<p></p>') ? '' : trimmed;
            };

            const parsePrice = (p) => {
                const parsed = parseFloat(p);
                return isNaN(parsed) ? 0 : parsed;
            };

            return title.trim() !== (initialCourseData.title || '').trim() ||
                cleanHtml(desc) !== cleanHtml(initialCourseData.desc) ||
                catId !== initialCourseData.catId ||
                parsePrice(price) !== parsePrice(initialCourseData.price) ||
                thumb !== initialCourseData.thumb ||
                cleanHtml(learn) !== cleanHtml(initialCourseData.learn) ||
                cleanHtml(req) !== cleanHtml(initialCourseData.req);
        };

        window.addEventListener('beforeunload', function (e) {
            if (window.checkUnsavedChanges()) {
                e.preventDefault();
                e.returnValue = 'You have unsaved changes in your Course Landing Page. Are you sure you want to leave?';
                return e.returnValue;
            }
        });

        // Intercept back button click with SweetAlert confirmation
        setTimeout(() => {
            const backBtn = document.querySelector('a[href="/InstructorCourse"]');
            if (backBtn) {
                backBtn.addEventListener('click', function(e) {
                    if (window.checkUnsavedChanges()) {
                        e.preventDefault();
                        Swal.fire({
                            title: 'Unsaved Changes!',
                            text: 'Are you sure you want to go back without saving changes to the Landing Page?',
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#ef4444',
                            cancelButtonColor: '#cbd5e1',
                            confirmButtonText: 'Leave',
                            cancelButtonText: 'Stay'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                // Temporarily reset initialCourseData to bypass beforeunload warning
                                initialCourseData = {
                                    title: document.getElementById('course-title-input')?.value || '',
                                    desc: window.courseDescQuill?.root.innerHTML || '',
                                    price: document.getElementById('course-price-input')?.value || '0',
                                    catId: document.getElementById('course-category-input')?.value || '0',
                                    thumb: document.getElementById('course-thumbnail-input')?.value || '',
                                    learn: window.courseLearnQuill?.root.innerHTML || '',
                                    req: window.courseReqQuill?.root.innerHTML || ''
                                };
                                window.location.href = backBtn.href;
                            }
                        });
                    }
                });
            }
        }, 100);
        
        // Show API error if any
        @if (ViewBag.ApiError != null) {
            <text>
            console.error("API Error:", "@Html.Raw(ViewBag.ApiError)");
            
            const errBanner = document.createElement('div');
            errBanner.className = 'mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm font-semibold';
            errBanner.innerHTML = '<span class="material-symbols-outlined text-[16px] align-middle mr-1">error</span> @Html.Raw(ViewBag.ApiError) — Lesson data could not be loaded. Try logging in again.';
            document.querySelector('.p-8')?.prepend(errBanner);
