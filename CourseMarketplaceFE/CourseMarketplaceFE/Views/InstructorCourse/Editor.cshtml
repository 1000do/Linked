@{
    ViewData["Title"] = "Curriculum Editor";
    Layout = "_InstructorLayout";
    var courseId = ViewBag.CourseId ?? 1;
}

<div class="p-8 h-full flex flex-col">
    <div class="flex items-center justify-between mb-8 flex-shrink-0">
        <div class="flex items-center gap-4">
            <a href="/InstructorCourse" class="text-slate-400 hover:text-primary transition-colors"><span class="material-symbols-outlined text-[20px]">arrow_back</span></a>
            <h1 class="text-2xl font-headline font-extrabold text-slate-900">Course Structure</h1>
            <span class="px-2 py-1 bg-primary-container/20 text-primary border border-primary-container rounded text-[10px] font-bold uppercase tracking-wider">Draft</span>
        </div>
        <button class="px-4 py-2 bg-white text-slate-700 font-bold border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-2">
            <span class="material-symbols-outlined text-[18px]">visibility</span> Preview as Student
        </button>
    </div>

    <div class="flex gap-8 h-full overflow-hidden">
        <!-- LEFT: Course Structure -->
        <div class="w-80 flex-shrink-0 flex flex-col gap-4 overflow-y-auto pb-8 pr-2 custom-scrollbar">
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden border-l-4 border-l-primary">
                <div class="p-4 bg-slate-50/50 flex items-center justify-between">
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Section 1</p>
                        <h3 class="font-bold text-slate-900 text-sm">Introduction to Advanced UI</h3>
                    </div>
                    <button class="text-slate-400 hover:text-slate-600"><span class="material-symbols-outlined text-[18px]">drag_indicator</span></button>
                </div>
                <div class="p-4 space-y-2">
                    <div class="lesson-item p-3 bg-white border border-primary ring-1 ring-primary/20 rounded-lg shadow-sm flex items-start gap-3 cursor-pointer" data-lesson="1.1" data-title="Welcome to the Course" data-type="Video" data-duration="04:32">
                        <span class="material-symbols-outlined text-primary text-[20px] mt-0.5" style='font-variation-settings: "FILL" 1;'>play_circle</span>
                        <div class="flex-1">
                            <p class="font-bold text-slate-900 text-sm">1.1 Welcome to the Course</p>
                            <p class="text-[10px] text-slate-500 mt-1">Video • 04:32</p>
                        </div>
                    </div>
                    <div class="lesson-item p-3 bg-white border border-slate-100 rounded-lg flex items-start gap-3 cursor-pointer hover:border-slate-300 transition-colors" data-lesson="1.2" data-title="Required Tooling" data-type="Article" data-duration="">
                        <span class="material-symbols-outlined text-slate-400 text-[20px] mt-0.5">article</span>
                        <div class="flex-1">
                            <p class="font-semibold text-slate-700 text-sm">1.2 Required Tooling</p>
                            <p class="text-[10px] text-slate-500 mt-1">Text Article</p>
                        </div>
                    </div>
                    <button class="add-lesson-btn w-full py-3 border-2 border-dashed border-slate-200 rounded-lg text-slate-500 hover:text-primary hover:border-primary hover:bg-primary/5 transition-colors flex items-center justify-center gap-2 text-xs font-bold mt-2">
                        <span class="material-symbols-outlined text-[16px]">add_circle</span> Add Lesson
                    </button>
                </div>
            </div>

            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="p-4 bg-slate-50/50 flex items-center justify-between">
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Section 2</p>
                        <h3 class="font-bold text-slate-900 text-sm">The Digital Atheneum Philosophy</h3>
                    </div>
                    <button class="text-slate-400 hover:text-slate-600"><span class="material-symbols-outlined text-[18px]">drag_indicator</span></button>
                </div>
                <div class="p-4 space-y-2">
                    <button class="add-lesson-btn w-full py-3 border-2 border-dashed border-slate-200 rounded-lg text-slate-500 hover:text-primary hover:border-primary hover:bg-primary/5 transition-colors flex items-center justify-center gap-2 text-xs font-bold">
                        <span class="material-symbols-outlined text-[16px]">add_circle</span> Add Lesson
                    </button>
                </div>
            </div>

            <button id="add-section-btn" class="w-full py-6 bg-slate-100 border-2 border-dashed border-slate-300 rounded-xl text-slate-600 hover:text-slate-800 hover:border-slate-400 hover:bg-slate-200 transition-colors flex flex-col items-center justify-center gap-2 text-sm font-bold shadow-inner">
                <span class="material-symbols-outlined text-[24px]">post_add</span> Add New Section
            </button>
        </div>

        <!-- RIGHT: Lesson Editor -->
        <div class="flex-1 flex flex-col bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-slate-200 flex items-center justify-between bg-slate-50/50">
                <div>
                    <div class="flex items-center gap-2 text-[10px] font-bold text-primary uppercase tracking-widest mb-2">
                        <span class="material-symbols-outlined text-[14px]">edit</span> Editing Lesson <span id="editing-lesson-id">1.1</span>
                    </div>
                    <h2 id="editing-lesson-title" class="text-3xl font-headline font-extrabold text-slate-900">Welcome to the Course</h2>
                    <div class="flex items-center gap-4 mt-2 text-xs font-semibold text-slate-500">
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">schedule</span> <span id="editing-lesson-duration">4 mins</span></span>
                        <span class="flex items-center gap-1 text-primary"><span class="material-symbols-outlined text-[16px]">check_circle</span> Published</span>
                    </div>
                </div>
                <div class="flex gap-3">
                    <button id="editor-save-draft" class="px-6 py-2.5 bg-slate-200 text-slate-700 font-bold rounded-lg hover:bg-slate-300 transition-colors">Save Draft</button>
                    <button class="px-6 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors shadow-lg shadow-primary/20">Publish Lesson</button>
                </div>
            </div>

            <div class="flex-1 overflow-y-auto p-8 custom-scrollbar">
                <!-- Tabs -->
                <div class="flex border-b border-slate-200 mb-8">
                    <button class="tab-btn px-6 py-3 border-b-2 border-primary text-primary font-bold text-sm" data-tab="tab-video">Video Content</button>
                    <button class="tab-btn px-6 py-3 border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-semibold text-sm transition-colors" data-tab="tab-resources">Resources & Files</button>
                    <button class="tab-btn px-6 py-3 border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-semibold text-sm transition-colors" data-tab="tab-quiz">Quiz</button>
                </div>

                <!-- Tab: Video Content -->
                <div id="tab-video" class="tab-content">
                    <div class="max-w-2xl mx-auto mb-12">
                        <input type="hidden" id="MaterialUrl" name="MaterialUrl" />
                        <div id="video-drop-area" class="border-2 border-dashed border-slate-200 rounded-2xl p-12 text-center hover:bg-slate-50 transition-colors cursor-pointer group">
                            <div class="w-20 h-20 bg-primary-container/30 text-primary rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined text-[40px]">movie</span>
                            </div>
                            <h3 class="text-lg font-bold text-slate-900 mb-2">Upload Lesson Video</h3>
                            <p class="text-sm text-slate-500 mb-4">MP4, WebM or OGG up to 2GB</p>
                            <span class="px-6 py-2 bg-white border border-slate-200 rounded-lg text-slate-700 font-bold text-sm hover:bg-slate-50 inline-block">Browse Files</span>
                            <input type="file" id="video-input" accept="video/*" class="hidden" />
                        </div>
                        <div id="video-upload-progress" class="hidden text-center py-8">
                            <div class="w-16 h-16 bg-primary-container/30 text-primary rounded-2xl flex items-center justify-center mx-auto mb-6">
                                <span class="material-symbols-outlined text-[32px]">cloud_upload</span>
                            </div>
                            <h3 id="upload-filename-display" class="text-xl font-bold text-slate-900 mb-2"></h3>
                            <p class="text-sm text-slate-500 mb-6">Processing <span id="progress-text">0</span>% • Do not close this tab during upload.</p>
                            <div class="h-2 bg-slate-100 rounded-full w-full max-w-md mx-auto mb-8 overflow-hidden">
                                <div id="progress-bar-fill" class="h-full bg-primary-container transition-all duration-300" style="width: 0%"></div>
                            </div>
                            <div class="flex justify-center gap-4">
                                <button type="button" id="cancel-upload" class="px-6 py-2.5 bg-red-50 text-red-600 font-bold rounded-lg flex items-center gap-2 hover:bg-red-100 transition-colors">
                                    <span class="material-symbols-outlined text-[18px]">cancel</span> Cancel Upload
                                </button>
                            </div>
                        </div>
                        <div id="video-success" class="hidden border border-slate-200 rounded-2xl p-6 flex items-center justify-between bg-surface-container-low">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-primary text-white rounded-lg flex items-center justify-center">
                                    <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>play_circle</span>
                                </div>
                                <div>
                                    <h4 class="font-bold text-slate-900" id="uploaded-filename"></h4>
                                    <p class="text-xs text-slate-500">Video successfully processed</p>
                                </div>
                            </div>
                            <button class="text-slate-400 hover:text-red-500 transition-colors" onclick="resetVideoUpload()"><span class="material-symbols-outlined">delete</span></button>
                        </div>
                    </div>
                </div>

                <!-- Tab: Resources -->
                <div id="tab-resources" class="tab-content hidden">
                    <div class="max-w-2xl mx-auto text-center py-16">
                        <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <span class="material-symbols-outlined text-[40px] text-slate-400">folder_open</span>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">No resources yet</h3>
                        <p class="text-sm text-slate-500 mb-6">Upload supplementary files like PDFs, code samples, or slides.</p>
                        <button class="px-6 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors">
                            <span class="material-symbols-outlined text-[18px] align-middle mr-1">upload_file</span> Upload Resource
                        </button>
                    </div>
                </div>

                <!-- Tab: Quiz -->
                <div id="tab-quiz" class="tab-content hidden">
                    <div class="max-w-2xl mx-auto text-center py-16">
                        <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <span class="material-symbols-outlined text-[40px] text-slate-400">quiz</span>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Create a Quiz</h3>
                        <p class="text-sm text-slate-500 mb-6">Add quiz questions to test student understanding after this lesson.</p>
                        <button class="px-6 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors">
                            <span class="material-symbols-outlined text-[18px] align-middle mr-1">add</span> Add Question
                        </button>
                    </div>
                </div>

                <!-- Below-tabs content (always visible) -->
                <div class="grid grid-cols-3 gap-8 mt-4">
                    <div class="col-span-2 space-y-6">
                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <label class="text-sm font-bold text-slate-900">Lesson Description</label>
                                <button class="flex items-center gap-1.5 px-3 py-1 bg-slate-900 text-white text-[10px] font-bold uppercase tracking-widest rounded shadow-sm hover:bg-slate-800 transition-colors">
                                    <span class="material-symbols-outlined text-[14px]">auto_awesome</span> Assistant
                                </button>
                            </div>
                            <div class="bg-white rounded-xl">
                                <div id="lesson-editor"></div>
                            </div>
                        </div>
                    </div>
                    <div class="space-y-6">
                        <div class="bg-slate-50 rounded-xl p-5 border border-slate-200">
                            <label class="block text-sm font-bold text-slate-900 mb-3">Video Thumbnail</label>
                            <div id="thumb-drop" class="w-full aspect-video bg-slate-800 rounded-lg overflow-hidden relative group cursor-pointer">
                                <img id="vid-thumb-preview" src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover opacity-60" />
                                <span class="material-symbols-outlined absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-white text-[48px] opacity-80" style='font-variation-settings: "FILL" 1;'>play_arrow</span>
                                <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity">
                                    <span class="text-white text-xs font-bold px-3 py-1.5 bg-black/50 rounded-md">Change Thumbnail</span>
                                </div>
                            </div>
                            <input type="file" id="thumb-input" accept="image/*" class="hidden" />
                        </div>
                        <div class="bg-white rounded-xl p-5 border border-slate-200">
                            <label class="block text-sm font-bold text-slate-900 mb-4">Visibility & Access</label>
                            <label id="free-preview-label" class="toggle-card flex items-start gap-4 p-4 rounded-xl border border-slate-200 hover:border-primary cursor-pointer transition-all mb-3">
                                <div class="mt-0.5 text-slate-400"><span class="material-symbols-outlined text-[20px]">lock_open</span></div>
                                <div class="flex-1">
                                    <p class="font-bold text-slate-900 text-sm">Free Preview</p>
                                    <p class="text-[10px] text-slate-500 mt-1">Students can watch without buying</p>
                                </div>
                                <div class="mt-1"><input type="checkbox" id="cb-free-preview" class="w-5 h-5 border-2 border-slate-300 rounded text-primary focus:ring-primary" /></div>
                            </label>
                            <label id="downloadable-label" class="toggle-card flex items-start gap-4 p-4 rounded-xl border-2 border-primary bg-primary/5 cursor-pointer transition-all">
                                <div class="mt-0.5 text-primary"><span class="material-symbols-outlined text-[20px]">download</span></div>
                                <div class="flex-1">
                                    <p class="font-bold text-slate-900 text-sm">Downloadable</p>
                                    <p class="text-[10px] text-slate-500 mt-1">Allow students to save offline</p>
                                </div>
                                <div class="mt-1"><input type="checkbox" id="cb-downloadable" checked class="w-5 h-5 border-2 border-primary rounded text-primary focus:ring-primary" /></div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
</style>

@section Scripts {
    <script>
        // ─── Quill ───
        var lessonQuill = new Quill('#lesson-editor', {
            theme: 'snow',
            placeholder: 'Introduce this lesson to your students...',
            modules: { toolbar: [['bold','italic'],[{'list':'ordered'},{'list':'bullet'}],['link','code-block']] }
        });

        // ─── Tabs ───
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('border-primary','text-primary','font-bold'); b.classList.add('border-transparent','text-slate-500','font-semibold'); });
                btn.classList.add('border-primary','text-primary','font-bold');
                btn.classList.remove('border-transparent','text-slate-500','font-semibold');
                document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
                document.getElementById(btn.dataset.tab).classList.remove('hidden');
            });
        });

        // ─── Lesson sidebar clicks ───
        document.querySelectorAll('.lesson-item').forEach(item => {
            item.addEventListener('click', () => {
                document.querySelectorAll('.lesson-item').forEach(i => { i.classList.remove('border-primary','ring-1','ring-primary/20','shadow-sm'); i.classList.add('border-slate-100'); });
                item.classList.add('border-primary','ring-1','ring-primary/20','shadow-sm');
                item.classList.remove('border-slate-100');
                document.getElementById('editing-lesson-id').textContent = item.dataset.lesson;
                document.getElementById('editing-lesson-title').textContent = item.dataset.title;
                document.getElementById('editing-lesson-duration').textContent = item.dataset.duration ? item.dataset.duration : '--';
            });
        });

        // ─── Checkbox toggle styling ───
        function updateToggleCard(checkboxId, labelId) {
            const cb = document.getElementById(checkboxId);
            const label = document.getElementById(labelId);
            const icon = label.querySelector('.material-symbols-outlined');
            cb.addEventListener('change', () => {
                if (cb.checked) {
                    label.classList.remove('border','border-slate-200'); label.classList.add('border-2','border-primary','bg-primary/5');
                    if(icon) icon.classList.replace('text-slate-400','text-primary');
                } else {
                    label.classList.remove('border-2','border-primary','bg-primary/5'); label.classList.add('border','border-slate-200');
                    if(icon) icon.classList.replace('text-primary','text-slate-400');
                }
            });
        }
        updateToggleCard('cb-free-preview', 'free-preview-label');
        updateToggleCard('cb-downloadable', 'downloadable-label');

        // ─── Video Thumbnail click-to-upload ───
        document.getElementById('thumb-drop').addEventListener('click', () => document.getElementById('thumb-input').click());
        document.getElementById('thumb-input').addEventListener('change', function() {
            if (this.files.length > 0) {
                const reader = new FileReader();
                reader.onload = (e) => { document.getElementById('vid-thumb-preview').src = e.target.result; };
                reader.readAsDataURL(this.files[0]);
            }
        });

        // ─── Video Upload (XHR with progress) ───
        const videoDropArea = document.getElementById('video-drop-area');
        const videoInput = document.getElementById('video-input');
        const uiProgress = document.getElementById('video-upload-progress');
        const uiSuccess = document.getElementById('video-success');
        const progressBarFill = document.getElementById('progress-bar-fill');
        const progressText = document.getElementById('progress-text');
        const uploadedFilename = document.getElementById('uploaded-filename');
        const materialUrlInput = document.getElementById('MaterialUrl');
        let currentXHR = null;

        videoDropArea.addEventListener('click', () => videoInput.click());
        videoInput.addEventListener('change', function() { handleVideoUpload(this.files); });
        ['dragenter','dragover','dragleave','drop'].forEach(ev => videoDropArea.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); }, false));
        ['dragenter','dragover'].forEach(ev => videoDropArea.addEventListener(ev, () => videoDropArea.classList.add('border-primary','bg-primary/5'), false));
        ['dragleave','drop'].forEach(ev => videoDropArea.addEventListener(ev, () => videoDropArea.classList.remove('border-primary','bg-primary/5'), false));
        videoDropArea.addEventListener('drop', e => handleVideoUpload(e.dataTransfer.files), false);

        function handleVideoUpload(files) {
            if (!files.length) return;
            const file = files[0];
            if (!file.type.startsWith('video/')) { alert('Please upload a video file.'); return; }
            videoDropArea.classList.add('hidden');
            uiProgress.classList.remove('hidden');
            document.getElementById('upload-filename-display').textContent = `Uploading "${file.name}"`;
            progressBarFill.style.width = '0%'; progressText.textContent = '0';

            const CLOUD_NAME = 'df8i0azc5';
            const UPLOAD_PRESET = 'course_marketplace_preset';
            const url = `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/video/upload`;
            const fd = new FormData(); fd.append('upload_preset', UPLOAD_PRESET); fd.append('file', file);
            const xhr = new XMLHttpRequest(); currentXHR = xhr;

            xhr.upload.addEventListener('progress', e => {
                if (e.lengthComputable) { const pct = Math.round(e.loaded/e.total*100); progressBarFill.style.width=pct+'%'; progressText.textContent=pct; }
            });
            xhr.addEventListener('load', () => {
                if (xhr.status >= 200 && xhr.status < 300) {
                    const data = JSON.parse(xhr.responseText);
                    setTimeout(() => { uiProgress.classList.add('hidden'); uiSuccess.classList.remove('hidden'); uploadedFilename.textContent=file.name; materialUrlInput.value=data.secure_url; }, 400);
                } else { handleUploadError('Upload failed: ' + xhr.statusText); }
            });
            xhr.addEventListener('error', () => handleUploadError('Network error during upload.'));
            xhr.addEventListener('abort', () => resetVideoUpload());
            xhr.open('POST', url, true); xhr.send(fd);
        }

        document.getElementById('cancel-upload').addEventListener('click', () => { if(currentXHR) currentXHR.abort(); });
        function handleUploadError(msg) { alert(msg); resetVideoUpload(); }
        function resetVideoUpload() { videoDropArea.classList.remove('hidden'); uiProgress.classList.add('hidden'); uiSuccess.classList.add('hidden'); videoInput.value=''; materialUrlInput.value=''; }
        window.resetVideoUpload = resetVideoUpload;

        // ─── Save Draft ───
        document.getElementById('editor-save-draft').addEventListener('click', () => { alert('Draft saved!'); });

        // ─── Add Lesson / Section placeholders ───
        document.querySelectorAll('.add-lesson-btn').forEach(btn => { btn.addEventListener('click', () => alert('Add Lesson feature coming soon!')); });
        document.getElementById('add-section-btn').addEventListener('click', () => alert('Add Section feature coming soon!'));
    </script>
}
