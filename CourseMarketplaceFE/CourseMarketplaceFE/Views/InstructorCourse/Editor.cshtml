            let updatedTitle = field === 'title' ? newValue.trim() : currentTitle;
            let updatedDesc = field === 'description' ? newValue.trim() : currentDesc;
            
            if (field === 'title' && (newValue.trim() === currentTitle || !newValue.trim())) {
