@{
    ViewData["Title"] = "Curriculum Editor";
    Layout = "_InstructorLayout";
    var courseId = ViewBag.CourseId ?? 1;
}

<div class="p-8 h-full flex flex-col">
    <div class="flex items-center justify-between mb-8 flex-shrink-0">
        <div class="flex items-center gap-4">
            <a href="/InstructorCourse" class="text-slate-400 hover:text-primary transition-colors"><span class="material-symbols-outlined text-[20px]">arrow_back</span></a>
            <h1 class="text-2xl font-headline font-extrabold text-slate-900">Course Structure</h1>
            @{
                var courseStatus = ViewBag.CourseStatus as string ?? "Draft";
                if (courseStatus.Equals("Published", StringComparison.OrdinalIgnoreCase)) {
                    <span class="px-2 py-1 bg-primary-container/20 text-primary border border-primary-container rounded text-[10px] font-bold uppercase tracking-wider">Published</span>
                } else if (courseStatus.Equals("Pending", StringComparison.OrdinalIgnoreCase)) {
                    <span class="px-2 py-1 bg-amber-50 text-amber-600 border border-amber-200 rounded text-[10px] font-bold uppercase tracking-wider">Pending Review</span>
                } else if (courseStatus.Equals("Rejected", StringComparison.OrdinalIgnoreCase)) {
                    <span class="px-2 py-1 bg-red-50 text-red-600 border border-red-200 rounded text-[10px] font-bold uppercase tracking-wider">Rejected</span>
                } else {
                    <span class="px-2 py-1 bg-slate-100 text-slate-600 border border-slate-200 rounded text-[10px] font-bold uppercase tracking-wider">Draft</span>
                }
            }
        </div>
        <div class="flex items-center gap-3">
            <a href="/Course/Details/@courseId" target="_blank" class="px-4 py-2 bg-white text-slate-700 font-bold border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">visibility</span> Preview
            </a>
            @if (!courseStatus.Equals("Pending", StringComparison.OrdinalIgnoreCase)) {
                <button class="px-5 py-2 bg-emerald-600 text-white font-bold rounded-lg hover:bg-emerald-700 transition-colors shadow-lg shadow-emerald-600/20 flex items-center gap-2" onclick="submitCourseForReview()">
                    <span class="material-symbols-outlined text-[18px]">send</span> 
                    @(courseStatus.Equals("Published", StringComparison.OrdinalIgnoreCase) ? "Submit Changes" : "Submit for Review")
                </button>
            }
        </div>
    </div>

    <!-- Moderation Feedback Alert -->
    @{
        var moderationFeedback = ViewBag.ModerationFeedback as string;
    }
    @if (!string.IsNullOrEmpty(moderationFeedback))
    {
        <div class="mb-6 bg-amber-50 border border-amber-200 p-4 rounded-xl flex items-start gap-3 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
            <span class="material-symbols-outlined text-amber-600">report</span>
            <div class="flex-1">
                <h4 class="text-sm font-bold text-amber-900 mb-1">Moderation Feedback:</h4>
                <p class="text-sm text-amber-800 leading-relaxed">@moderationFeedback</p>
            </div>
            <button onclick="this.parentElement.remove()" class="text-amber-400 hover:text-amber-600">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
        </div>
    }

    <div class="flex gap-8 h-full overflow-hidden">
        <!-- LEFT: Course Structure -->
        <div class="w-80 flex-shrink-0 flex flex-col gap-4 overflow-hidden">
            <div class="flex border-b border-slate-200 mb-2">
                <button class="flex-1 py-3 text-sm font-bold border-b-2 border-primary text-primary" id="btn-tab-curriculum" onclick="switchMainTab('curriculum')">Curriculum</button>
                <button class="flex-1 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors" id="btn-tab-landing" onclick="switchMainTab('landing')">Course Landing Page</button>
            </div>
            
            <div id="course-structure-container" class="flex-1 flex flex-col gap-4 overflow-y-auto pb-8 pr-2 custom-scrollbar">
                <!-- Dynamic content injected by JS -->
            </div>
        </div>

        <!-- RIGHT: Lesson Editor / Landing Page Editor -->
        <div class="flex-1 flex flex-col bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden relative">
            
            <!-- Tab: Landing Page Editor (Hidden by default) -->
            <div id="landing-page-editor" class="hidden flex-1 flex-col h-full overflow-y-auto p-8 custom-scrollbar">
                <!-- Limit Banner -->
                @if (ViewBag.IsStripeActive == false)
                {
                    <div class="mb-8 p-4 bg-amber-50 border border-amber-200 rounded-xl flex items-start gap-4 shadow-sm animate-in fade-in slide-in-from-top-4 duration-500">
                        <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-amber-600">info</span>
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-amber-900">Stripe account not connected</h3>
                            <p class="text-amber-800 text-sm mt-1 leading-relaxed">
                                You are in limited mode: Maximum <strong>2 courses</strong>, <strong>5 lessons/course</strong>, <strong>1 resource/lesson</strong> and <strong>30 minutes of video</strong> in total. 
                                <a href="/Instructor/StripeOnboarding" class="font-bold underline hover:text-amber-700 ml-1">Connect Stripe now</a> to remove limits and start earning.
                            </p>
                        </div>
                    </div>
                }
                else if (ViewBag.Price == 0)
                {
                    <div class="mb-8 p-4 bg-blue-50 border border-blue-200 rounded-xl flex items-start gap-4 shadow-sm">
                        <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-blue-600">info</span>
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-blue-900">Free Course</h3>
                            <p class="text-blue-800 text-sm mt-1 leading-relaxed">
                                For free courses, total course video duration is limited to a maximum of <strong>60 minutes</strong>.
                            </p>
                        </div>
                    </div>
                }

                <div class="max-w-4xl mx-auto space-y-12">
                    <div class="flex items-center justify-end mb-8">
                        <div class="flex flex-col items-end gap-2">
                            <div id="video-duration-counter" class="text-xs font-bold px-3 py-1.5 rounded-full bg-slate-100 text-slate-600 flex items-center gap-2 border border-slate-200">
                                <span class="material-symbols-outlined text-[16px]">schedule</span>
                                <span>Total Duration: 0m / @(ViewBag.IsStripeActive == false ? "30m" : (ViewBag.Price == 0 ? "60m" : "Unlimited"))</span>
                            </div>
                            <div id="lesson-count-counter" class="text-xs font-bold px-3 py-1.5 rounded-full bg-slate-100 text-slate-600 flex items-center gap-2 border border-slate-200">
                                <span class="material-symbols-outlined text-[16px]">lists</span>
                                <span id="lesson-count-text">0 / @(ViewBag.IsStripeActive == false ? "5" : "∞") Lessons</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <h2 class="text-3xl font-headline font-extrabold text-slate-900">Course Landing Page</h2>
                            <div id="landing-autosave-status" class="hidden text-xs font-semibold text-slate-400 flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px] animate-spin">sync</span>
                                <span id="landing-autosave-text">Saving...</span>
                            </div>
                        </div>

                        <p class="text-slate-500">Your course landing page is crucial to your success. Make it stand out!</p>
                    </div>

                    <div class="grid grid-cols-1 gap-8">
                        <!-- Basic Info -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Course Title <span class="text-red-500">*</span></label>
                            <input type="text" id="course-title-input" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary" value="@ViewBag.CourseTitle" />
                        </div>

                        <!-- Description -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Course Description <span class="text-red-500">*</span></label>
                            <div class="bg-white rounded-xl">
                                <div id="course-description-editor">@Html.Raw(ViewBag.Description)</div>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-8">
                            <!-- Category -->
                            <div class="space-y-4">
                                <label class="text-sm font-bold text-slate-900 block">Category <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <select id="course-category-input" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary appearance-none pr-10 transition-all cursor-pointer">
                                        <option value="0">Select Category</option>
                                        @if (ViewBag.AvailableCategories != null)
                                        {
                                            foreach (var cat in (List<CourseMarketplaceFE.Models.CategoryViewModel>)ViewBag.AvailableCategories)
                                            {
                                                <option value="@cat.CategoryId" selected="@(ViewBag.CategoryId == cat.CategoryId)">@cat.CategoriesName</option>
                                            }
                                        }
                                    </select>
                                    <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
                                        <span class="material-symbols-outlined text-slate-400 text-[20px]">expand_all</span>
                                    </div>
                                </div>
                            </div>
                            <div class="space-y-4">
                                @{
                                    var isStripeActiveEditor = (bool)(ViewBag.IsStripeActive ?? false);
                                    var transferRate = (decimal)(ViewBag.TransferRate ?? 70.0m);
                                    var transferRateStr = transferRate.ToString("0.##");
                                }

                                @if (!isStripeActiveEditor)
                                {
                                    <div class="flex items-center justify-between">
                                        <label class="text-sm font-bold text-slate-900 block">Price (USD)</label>
                                        <span class="text-xs text-amber-600 font-bold bg-amber-50 px-2 py-1 rounded border border-amber-200">🔒 Free Only</span>
                                    </div>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                            <span class="text-slate-400 font-bold material-symbols-outlined text-[18px]">attach_money</span>
                                        </div>
                                        <input type="text" value="0.00 — Free" disabled class="w-full pl-11 pr-4 py-3 bg-slate-100 border border-slate-200 rounded-xl font-semibold text-slate-400 cursor-not-allowed" />
                                        <input type="hidden" id="course-price-input" value="0" />
                                    </div>
                                    
                                    <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-xl p-4 mt-3">
                                        <div class="flex items-start gap-3">
                                            <div class="w-10 h-10 bg-amber-100 text-amber-600 rounded-lg flex items-center justify-center shrink-0">
                                                <span class="material-symbols-outlined text-[22px]">lock</span>
                                            </div>
                                            <div class="flex-1">
                                                <p class="text-sm font-bold text-amber-900 mb-1">Want to sell premium paid courses?</p>
                                                <p class="text-xs text-amber-700 mb-2">Connect your Stripe account to unlock custom pricing.</p>
                                                <a href="/Instructor/ApplicationStatus" class="inline-flex items-center gap-1.5 px-4 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-lg shadow hover:shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 text-xs">
                                                    <span class="material-symbols-outlined text-[16px]">credit_card</span>
                                                    Set up Stripe
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="flex items-center justify-between">
                                        <label class="text-sm font-bold text-slate-900 block">Price (USD)</label>
                                        <span class="text-xs text-slate-500 font-medium bg-slate-100 px-2 py-1 rounded">Min: $0.00</span>
                                    </div>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                            <span class="text-slate-500 font-bold material-symbols-outlined text-[18px]">attach_money</span>
                                        </div>
                                        <input type="number" id="course-price-input" min="0" step="0.01" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary font-semibold text-slate-800 transition-colors" value="@ViewBag.Price" placeholder="0.00" onblur="formatPrice(this)" />
                                    </div>
                                    
                                    <div class="flex flex-wrap gap-2 mt-3">
                                        <button type="button" onclick="setPrice(0)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">Free</button>
                                        <button type="button" onclick="setPrice(9.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$9.99</button>
                                        <button type="button" onclick="setPrice(19.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$19.99</button>
                                        <button type="button" onclick="setPrice(49.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$49.99</button>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 flex gap-4 border border-slate-100 mt-4">
                                        <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center text-white shrink-0 mt-1">
                                            <span class="material-symbols-outlined text-[14px]">info</span>
                                        </div>
                                        <div>
                                            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Instructor Revenue</p>
                                            <p class="font-bold text-slate-900 text-lg">@transferRateStr% Share</p>
                                            <p class="text-[10px] text-slate-500 mt-1">Estimated payout per sale: <span id="payout-estimate">$0.00</span></p>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Promotion Section -->
                             <div class="space-y-4">
                                 <div class="flex items-center justify-between">
                                     <label class="text-sm font-black text-slate-900 block tracking-tight">Promotions & Marketing</label>
                                     <div class="flex items-center gap-1.5 px-2 py-1 bg-emerald-50 text-emerald-600 rounded-lg">
                                         <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                         <span class="text-[10px] font-black uppercase tracking-widest">Platform Funded</span>
                                     </div>
                                 </div>
                                 
                                 <!-- Toggle Switch -->
                                 <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 transition-all duration-300 hover:bg-slate-100/50 @(ViewBag.IsInAnyCart == true ? "opacity-60 cursor-not-allowed select-none" : "")">
                                     <div class="flex flex-col gap-1">
                                         <span class="text-xs font-bold text-slate-800 flex items-center gap-2">
                                             <span class="material-symbols-outlined text-emerald-600 text-[16px]">loyalty</span>
                                             Apply coupon to this course
                                         </span>
                                         <span class="text-[10px] text-slate-400">Boost enrollments with LinkedLearn-sponsored vouchers</span>
                                     </div>
                                     <label class="relative inline-flex items-center @(ViewBag.IsInAnyCart == true ? "cursor-not-allowed pointer-events-none" : "cursor-pointer")">
                                         <input type="checkbox" id="coupon-toggle" class="sr-only peer" @(ViewBag.CouponCode != null ? "checked" : "") @(ViewBag.IsInAnyCart == true ? "disabled" : "") />
                                         <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                                     </label>
                                 </div>

                                 @if (ViewBag.IsInAnyCart == true)
                                 {
                                     <div id="coupon-cart-warning" class="text-xs text-rose-600 font-semibold px-1 mt-1 flex items-center gap-1.5 bg-rose-50 border border-rose-200/50 rounded-xl p-3 animate-in fade-in slide-in-from-top-1 duration-300">
                                         <span class="material-symbols-outlined text-rose-600 text-[16px]">shopping_cart</span>
                                         <span>Cannot modify coupon because this course is currently in a user's shopping cart.</span>
                                     </div>
                                 }

                                 <div id="coupon-free-warning" class="hidden text-xs text-amber-600 font-semibold px-1 mt-1 flex items-center gap-1.5 bg-amber-50 border border-amber-200/50 rounded-xl p-3 animate-in fade-in slide-in-from-top-1 duration-300">
                                     <span class="material-symbols-outlined text-amber-600 text-[16px]">warning</span>
                                     <span>Vouchers/Coupons cannot be applied to free courses.</span>
                                 </div>
 
                                 <!-- Coupon Action Area -->
                                 <div id="voucher-action-container" class="@(ViewBag.CouponCode != null ? "" : "hidden") space-y-4 animate-in fade-in slide-in-from-top-2 duration-300">
                                     <!-- Select Button if not selected -->
                                     <div id="no-voucher-selected-state" class="@(ViewBag.CouponCode == null ? "" : "hidden") flex flex-col items-center justify-center p-6 border-2 border-dashed border-slate-200 rounded-2xl bg-slate-50/50">
                                         <span class="material-symbols-outlined text-slate-400 text-[32px] mb-2">confirmation_number</span>
                                         <p class="text-xs text-slate-500 font-bold mb-4">No voucher selected for this course yet</p>
                                         <button type="button" @(ViewBag.IsInAnyCart == true ? "disabled" : "") onclick="openCouponModal()" class="px-5 py-2.5 bg-slate-900 text-white hover:bg-slate-800 text-xs font-black rounded-xl uppercase tracking-widest transition-all active:scale-95 shadow-md flex items-center gap-2 @(ViewBag.IsInAnyCart == true ? "opacity-50 pointer-events-none cursor-not-allowed" : "")">
                                             <span class="material-symbols-outlined text-[16px]">add_circle</span>
                                             Select System Voucher
                                         </button>
                                     </div>
 
                                     <!-- Selected Voucher Card -->
                                     <div id="voucher-selected-state" class="@(ViewBag.CouponCode != null ? "" : "hidden") relative overflow-hidden bg-gradient-to-br from-emerald-500/10 to-teal-500/5 border border-emerald-500/30 rounded-3xl p-6 flex items-center justify-between gap-6 shadow-sm">
                                         <div class="flex items-center gap-5">
                                             <div class="relative">
                                                 <div class="absolute inset-0 bg-emerald-400/20 blur-lg rounded-full animate-pulse"></div>
                                                 <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center text-white shadow-lg relative z-10">
                                                     <span class="material-symbols-outlined text-[30px]">confirmation_number</span>
                                                  </div>
                                             </div>
                                             <div>
                                                 <div class="flex items-center gap-2 mb-0.5">
                                                     <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping"></span>
                                                     <p class="text-[9px] font-black text-emerald-600 uppercase tracking-widest">Active</p>
                                                 </div>
                                                 <h4 id="display-coupon-code" class="text-lg font-black text-slate-900 tracking-widest font-mono">@ViewBag.CouponCode</h4>
                                                 <div class="flex items-center gap-3 mt-1.5">
                                                     <span id="display-coupon-discount" class="px-2.5 py-0.5 bg-emerald-500 text-white text-[9px] font-black rounded-lg uppercase shadow-sm">Discount @(ViewBag.CouponType == "percentage" ? ViewBag.CouponValue + "%" : "$" + ViewBag.CouponValue)</span>
                                                 </div>
                                             </div>
                                         </div>
                                         <button type="button" @(ViewBag.IsInAnyCart == true ? "disabled" : "") onclick="openCouponModal()" class="px-4 py-2 bg-white hover:bg-slate-50 text-slate-700 hover:text-slate-900 text-[10px] font-black rounded-xl uppercase tracking-widest border border-slate-200 transition-all shadow-sm active:scale-95 flex items-center gap-1.5 @(ViewBag.IsInAnyCart == true ? "opacity-50 pointer-events-none cursor-not-allowed" : "")">
                                             <span class="material-symbols-outlined text-[14px]">edit</span> Change
                                         </button>
                                     </div>
                                 </div>
 
                                 <div class="flex items-start gap-2 px-1">
                                     <span class="material-symbols-outlined text-amber-500 text-[14px] mt-0.5">verified_user</span>
                                     <p class="text-[10px] font-bold text-slate-400 italic leading-relaxed">
                                         Discount sponsored by LinkedLearn. No additional cost to you.
                                     </p>
                                 </div>
                             </div>
                         </div>
 
                         <!-- Coupon JS - ALWAYS rendered regardless of coupon state -->
                         <script>
                             // ─── LOAD AND SELECT PLATFORM COUPONS FOR EDITOR ───
                             const couponToggle = document.getElementById('coupon-toggle');
                             const voucherActionContainer = document.getElementById('voucher-action-container');
                             const currentCouponCode = '@ViewBag.CouponCode';
                             const isCourseInAnyCart = @(ViewBag.IsInAnyCart == true ? "true" : "false");
 
                             window.syncCouponStateWithPrice = async function(price) {
                                 const val = parseFloat(price) || 0;
                                 const toggle = document.getElementById('coupon-toggle');
                                 const container = document.getElementById('voucher-action-container');
                                 const warning = document.getElementById('coupon-free-warning');
                                 const labelParent = toggle ? toggle.closest('.flex.items-center.justify-between.p-4') : null;
 
                                 if (isCourseInAnyCart) {
                                     if (toggle) {
                                         toggle.disabled = true;
                                         if (labelParent) {
                                             labelParent.classList.add('opacity-60', 'pointer-events-none');
                                         }
                                     }
                                     return;
                                 }

                                 if (val === 0) {
                                     if (toggle) {
                                         if (toggle.checked) {
                                             toggle.checked = false;
                                             // Silently remove the applied coupon
                                             try {
                                                 const res = await fetch(`/Coupon/PlatformRemove?courseId=@courseId`, { method: 'DELETE' });
                                                 const result = await res.json();
                                                 if (result.success) {
                                                     // Reset active coupon variables
                                                     const displayCode = document.getElementById('display-coupon-code');
                                                     if (displayCode) displayCode.textContent = '';
                                                     const noSelectedState = document.getElementById('no-voucher-selected-state');
                                                     if (noSelectedState) noSelectedState.classList.remove('hidden');
                                                     const selectedState = document.getElementById('voucher-selected-state');
                                                     if (selectedState) selectedState.classList.add('hidden');
                                                 }
                                             } catch (e) {
                                                 console.error("Error removing platform coupon dynamically:", e);
                                             }
                                         }
                                         toggle.disabled = true;
                                         if (labelParent) {
                                             labelParent.classList.add('opacity-60', 'pointer-events-none');
                                         }
                                     }
                                     if (container) container.classList.add('hidden');
                                     if (warning) warning.classList.remove('hidden');
                                 } else {
                                     if (toggle) {
                                         toggle.disabled = false;
                                         if (labelParent) {
                                             labelParent.classList.remove('opacity-60', 'pointer-events-none');
                                         }
                                     }
                                     if (warning) warning.classList.add('hidden');
                                     if (toggle && toggle.checked) {
                                         if (container) container.classList.remove('hidden');
                                     }
                                 }
                             };

                            window.openCouponModal = function() {
                                const modal = document.getElementById('coupon-modal');
                                if (!modal) return;
                                modal.classList.remove('hidden');
                                modal.style.display = 'flex';
                                modal.offsetHeight; // force reflow
                                modal.classList.add('modal-visible');
                                loadPlatformCoupons();
                            };

                            window.closeCouponModal = function() {
                                const modal = document.getElementById('coupon-modal');
                                if (!modal) return;
                                modal.classList.remove('modal-visible');
                                setTimeout(() => { 
                                    modal.classList.add('hidden'); 
                                    modal.style.display = ''; 
                                }, 300);
                            };

                            async function loadPlatformCoupons() {
                                const container = document.getElementById('coupon-list-container');
                                if (!container) return;
                                container.innerHTML = `
                                    <div class="flex flex-col items-center justify-center py-20 gap-4">
                                        <div class="w-10 h-10 border-4 border-slate-100 border-t-primary rounded-full animate-spin"></div>
                                        <p class="text-xs font-black text-slate-400 uppercase tracking-widest">Searching for vouchers...</p>
                                    </div>
                                `;
                                
                                try {
                                    const res = await fetch('/Coupon/PlatformActive');
                                    const result = await res.json();
                                    
                                    if (result.success && result.data && result.data.length > 0) {
                                        container.innerHTML = result.data.map(c => {
                                            const discountText = c.couponType === 'percentage' ? `${c.discountValue}%` : `$${c.discountValue}`;
                                            const expiryText = c.endDate ? new Date(c.endDate).toLocaleDateString('en-US') : 'Lifetime';
                                            const isCurrent = c.couponCode === currentCouponCode;
                                            
                                            return `
                                                <div class="group relative overflow-hidden rounded-[2rem] p-6 border-2 ${isCurrent ? 'border-emerald-500 bg-emerald-50/30' : 'border-slate-100 bg-white'} hover:border-emerald-500/40 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-500">
                                                    ${isCurrent ? '<div class="absolute top-0 right-0 bg-emerald-500 text-white text-[8px] font-black px-4 py-1.5 rounded-bl-xl uppercase tracking-widest">Selected</div>' : ''}
                                                    
                                                    <div class="flex items-center justify-between gap-6">
                                                        <div class="flex items-center gap-5">
                                                            <div class="w-16 h-16 rounded-2xl ${isCurrent ? 'bg-emerald-500' : 'bg-slate-900'} text-white flex flex-col items-center justify-center group-hover:bg-emerald-500 transition-all duration-500 shadow-lg shadow-slate-200">
                                                                <span class="text-xl font-black leading-none">${discountText}</span>
                                                                <span class="text-[9px] font-bold uppercase opacity-60 mt-1">OFF</span>
                                                            </div>
                                                            <div>
                                                                <h4 class="text-lg font-black text-slate-900 tracking-widest font-mono">${c.couponCode}</h4>
                                                                <div class="flex items-center gap-2 mt-1.5">
                                                                    <span class="material-symbols-outlined text-slate-300 text-[14px]">event_available</span>
                                                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Expires: ${expiryText}</p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        
                                                        ${isCurrent ? `
                                                            <div class="flex items-center gap-2 px-4 py-2.5 bg-emerald-100 text-emerald-600 rounded-xl font-black text-[10px] uppercase tracking-widest">
                                                                <span class="material-symbols-outlined text-[16px]">check_circle</span> Selected
                                                            </div>
                                                        ` : `
                                                            <button type="button" onclick="applyPlatformCoupon(${c.couponId})" class="px-6 py-3 bg-slate-900 text-white hover:bg-emerald-500 text-[10px] font-black rounded-xl uppercase tracking-widest transition-all duration-300 active:scale-95 shadow-lg shadow-slate-200 hover:shadow-emerald-500/20 shrink-0">Apply</button>
                                                        `}
                                                    </div>
                                                </div>
                                            `;
                                        }).join('');
                                    } else {
                                        container.innerHTML = '<div class="col-span-full py-12 text-center text-slate-400 font-bold text-sm bg-slate-50 border border-slate-100 rounded-2xl">No vouchers currently available.</div>';
                                    }
                                } catch (err) {
                                    console.error(err);
                                    container.innerHTML = '<div class="col-span-full py-8 text-center text-rose-500 font-bold text-sm bg-rose-50 border border-rose-100 rounded-2xl">System error loading voucher list.</div>';
                                }
                            }

                            couponToggle.addEventListener('change', async function() {
                                if (this.checked) {
                                    voucherActionContainer.classList.remove('hidden');
                                } else {
                                    // User toggled it OFF. Confirm removal.
                                    const confirmRemove = await Swal.fire({ 
                                        title: 'Cancel Promotion?', 
                                        text: 'The course will revert to its original price.', 
                                        icon: 'warning', 
                                        showCancelButton: true, 
                                        confirmButtonColor: '#0f172a', 
                                        confirmButtonText: 'Yes, remove', 
                                        cancelButtonText: 'Keep it' 
                                    });
                                    
                                    if (confirmRemove.isConfirmed) {
                                        await removeCoupon();
                                    } else {
                                        // Reset the toggle back to ON
                                        this.checked = true;
                                    }
                                }
                            });

                            window.applyPlatformCoupon = async function(id) {
                                try {
                                    Swal.fire({ title: 'Applying...', allowOutsideClick: false, showConfirmButton: false, didOpen: () => Swal.showLoading() });
                                    const res = await fetch('/Coupon/PlatformApply', { 
                                        method: 'POST', 
                                        headers: { 'Content-Type': 'application/json' }, 
                                        body: JSON.stringify({ courseId: parseInt(courseId), couponId: parseInt(id) }) 
                                    });
                                    const result = await res.json();
                                    if (result.success) {
                                        Swal.fire({ icon: 'success', title: 'Success!', text: 'Platform coupon applied successfully.', timer: 1500, showConfirmButton: false });
                                        setTimeout(() => location.reload(), 1500);
                                    } else {
                                        Swal.fire('Error', result.message || 'Unable to apply this coupon.', 'error');
                                    }
                                } catch (err) { 
                                    Swal.fire('Error', 'Cannot connect to server.', 'error'); 
                                }
                            };

                            window.removeCoupon = async function() {
                                try {
                                    Swal.fire({ title: 'Processing...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                                    const res = await fetch(`/Coupon/PlatformRemove?courseId=${courseId}`, { method: 'DELETE' });
                                    const result = await res.json();
                                    if (result.success) { 
                                        Swal.fire({ icon: 'success', title: 'Removed!', timer: 1500, showConfirmButton: false }); 
                                        setTimeout(() => location.reload(), 1500); 
                                    } else { 
                                        Swal.fire('Error', result.message, 'error'); 
                                        couponToggle.checked = true; // reset toggle to ON
                                    }
                                } catch (err) { 
                                    Swal.fire('Error', 'Unable to connect.', 'error'); 
                                    couponToggle.checked = true; // reset toggle to ON
                                }
                            };

                            // Load platform coupons on initialize
                            loadPlatformCoupons();
                            syncCouponStateWithPrice(@(ViewBag.Price ?? 0));
                        </script>


