        }

        // Debugging — inspect what the server gave us
        console.log("Lessons Data loaded:", lessonsData);
        if (lessonsData.length > 0) {
            console.log("First lesson keys:", Object.keys(lessonsData[0]));
            if (lessonsData[0].learningMaterials || lessonsData[0].LearningMaterials) {
                console.log("First lesson has materials:", lessonsData[0].learningMaterials || lessonsData[0].LearningMaterials);
            } else {
                console.warn("First lesson has NO learningMaterials property. Available keys:", Object.keys(lessonsData[0]));
            }
        } else {
            console.warn("lessonsData is EMPTY. API may have returned 401 or no lessons exist.");
        }

        // ─── UI Element Declarations (moved up to avoid TDZ) ───
        const videoDropArea = document.getElementById('video-drop-area');
        const videoInput = document.getElementById('video-input');
        const uiProgress = document.getElementById('video-upload-progress');
        const uiSuccess = document.getElementById('video-success');
        const progressBarFill = document.getElementById('progress-bar-fill');
        const progressText = document.getElementById('progress-text');
        const uploadedFilenameDisplay = document.getElementById('uploaded-filename-display');
        const materialUrlInput = document.getElementById('MaterialUrl');
        let currentXHR = null;

        // Remove unused resource references to avoid null errors
        function renderCourseStructure() {
            const container = document.getElementById('course-structure-container');
            container.innerHTML = '';
            
            // Render a default section wrapper (since we don't have sections API yet)
            let sectionHtml = `
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden border-l-4 border-l-primary mb-4">
                <div class="p-4 bg-slate-50/50 flex items-center justify-between">
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Course Curriculum</p>
                        <h3 class="font-bold text-slate-900 text-sm">Main Section</h3>
                    </div>
                </div>
                <div class="p-4 space-y-2">
            `;
            
            let totalDurationSeconds = 0;
            const isStripeActive = @Json.Serialize(ViewBag.IsStripeActive);
            const coursePrice = @Json.Serialize(ViewBag.Price);
            const durationLimitMin = isStripeActive === false ? 30 : (coursePrice == 0 ? 60 : Infinity);
            const lessonLimit = isStripeActive === false ? 5 : Infinity;
            const isPending = '@(ViewBag.CourseStatus as string ?? "Draft")'.toLowerCase() === 'pending';
            
            lessonsData.forEach((lesson, index) => {
                const num = index + 1;
                // Safely get lesson properties (handle both PascalCase and camelCase)
                const lId = lesson.lessonId || lesson.LessonId;
                const lTitle = lesson.title || lesson.Title;
                const lStatus = (lesson.lessonStatus || lesson.LessonStatus || '').toLowerCase();
                
                // Check if lesson has any rejected materials
                const materials = lesson.learningMaterials || lesson.LearningMaterials || [];
                materials.forEach(m => {
                    let metadata = m.materialMetadata || m.MaterialMetadata;
                    if (typeof metadata === 'string') {
                        try { metadata = JSON.parse(metadata); } catch(e) { metadata = {}; }
                    }
                    const type = (metadata?.file_type || metadata?.FileType || metadata?.fileType || 'video').toLowerCase();
                    if (type === 'video' && (m.learningStatus || m.LearningStatus || '').toLowerCase() !== 'removed') {
                        totalDurationSeconds += (metadata?.duration || metadata?.Duration || 0);
                    }
                });

                const hasRejected = lStatus === 'rejected' || materials.some(m => (m.learningStatus || m.LearningStatus || '').toLowerCase() === 'rejected');
                
                const currentEditingId = document.getElementById('editing-lesson-id').textContent;
                const isSelected = currentEditingId == num;
                let activeClasses = isSelected ? 'border-primary ring-1 ring-primary/20 shadow-sm' : 'border-slate-100 hover:border-slate-300';
                if (hasRejected && !isSelected) activeClasses = 'border-red-200 hover:border-red-300 bg-red-50/30';
                
                const iconName = hasRejected ? 'cancel' : 'play_circle';
                const iconColor = hasRejected ? 'red-500' : (isSelected ? 'primary' : 'slate-400');
                const lDesc = lesson.description || lesson.Description || 'Video Lesson';

                const statusLabel = hasRejected 
                    ? '<span class="text-[10px] font-bold text-red-500 mt-1 flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">error</span> Rejected</span>'
                    : `
                    <div class="text-[10px] text-slate-500 truncate mt-0.5">
                        ${lDesc}
                    </div>`;
                
                const removeBtnHtml = isPending ? '' : `
                    <button onclick="removeLesson(event, ${lId})" class="text-slate-400 hover:text-red-500 transition-colors p-1 rounded-full hover:bg-red-50 self-center" title="Remove Lesson">
                        <span class="material-symbols-outlined text-[18px]">delete</span>
                    </button>
                `;

                sectionHtml += `
                    <div class="lesson-item p-3 bg-white border rounded-lg flex items-start gap-3 cursor-pointer transition-colors ${activeClasses}" 
                         data-lesson-id="${lId}" data-num="${num}" data-title="${lTitle}" onclick="selectLesson(this)">
                        <span class="material-symbols-outlined text-${iconColor} text-[20px] mt-0.5" ${isSelected && !hasRejected ? "style='font-variation-settings: \"FILL\" 1;'" : ""}>${iconName}</span>
                        <div class="flex-1 overflow-hidden mr-2">
                            <div class="flex items-center gap-1">
                                <span class="font-bold text-slate-900 text-sm shrink-0">${num}.</span>
                                <span class="font-bold text-slate-900 text-sm truncate lesson-title-display">${lTitle}</span>
                            </div>
                            ${statusLabel}
                        </div>
                        ${removeBtnHtml}
                    </div>
                `;
            });
            
            if (!isPending) {
                sectionHtml += `
                    <button id="add-lesson-btn" class="w-full py-3 border-2 border-dashed border-slate-200 rounded-lg text-slate-500 hover:text-primary hover:border-primary hover:bg-primary/5 transition-colors flex items-center justify-center gap-2 text-xs font-bold mt-2" onclick="addNewLesson()">
                        <span class="material-symbols-outlined text-[16px]">add_circle</span> Add Lesson
                    </button>
                `;
            }

            sectionHtml += `
                </div>
            </div>`;
            
            // Render Quizzes Section
            sectionHtml += `
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden border-l-4 border-l-indigo-500 mb-4 mt-6">
                <div class="p-4 bg-slate-50/50 flex items-center justify-between">
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Assessments</p>
                        <h3 class="font-bold text-slate-900 text-sm">Course Quizzes</h3>
                    </div>
                    ${!isPending ? `
                    <button type="button" onclick="openAddQuizModal()" class="px-3 py-1.5 bg-indigo-50 text-indigo-600 text-xs font-bold rounded hover:bg-indigo-100 transition-colors flex items-center gap-1">
                        <span class="material-symbols-outlined text-[14px]">add</span> Add Quiz
                    </button>
                    ` : ''}
                </div>
                <div class="p-4 space-y-2">
            `;
            
            if (quizzesData && quizzesData.length > 0) {
                quizzesData.forEach((q, index) => {
                    const quizTitle = q.quiz?.title || q.quiz?.Title || q.title || q.Title || 'Untitled Quiz';
                    const isHidden = q.isHidden || q.IsHidden;
                    const cId = q.courseId || q.CourseId;
                    const qId = q.quizId || q.QuizId;
                    
                    sectionHtml += `
                        <div class="bg-white border border-slate-200 rounded-xl p-3 flex items-center justify-between transition-all hover:border-indigo-300">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded bg-indigo-50 flex items-center justify-center shrink-0">
                                    <span class="material-symbols-outlined text-[18px] text-indigo-600">quiz</span>
                                </div>
                                <div>
                                    <h4 class="text-sm font-bold text-slate-900 truncate max-w-[150px]">${quizTitle}</h4>
                                    ${isHidden ? '<span class="text-[10px] font-bold text-amber-600 bg-amber-50 px-1.5 py-0.5 rounded border border-amber-200">Hidden</span>' : ''}
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <label class="relative inline-flex items-center cursor-pointer" title="Toggle Visibility">
                                    <input type="checkbox" class="sr-only peer" ${!isHidden ? 'checked' : ''} onchange="toggleQuizVisibility(${cId}, ${qId}, this)">
                                    <div class="w-8 h-4 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-indigo-500"></div>
                                </label>
                                <button onclick="removeQuizFromCourse(${cId}, ${qId})" class="p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded transition-colors" title="Remove from Course">
                                    <span class="material-symbols-outlined text-[18px]">close</span>
                                </button>
                            </div>
                        </div>
                    `;
                });
            } else {
                sectionHtml += `
                    <div class="text-center py-6 text-slate-500 text-sm">
                        <span class="material-symbols-outlined text-[24px] text-slate-300 mb-2 block">quiz</span>
                        No quizzes added to this course yet.
                    </div>
                `;
            }
            
            sectionHtml += `
                </div>
            </div>
            `;
            
            container.innerHTML = sectionHtml;

            // Update counters
            const totalMinutes = Math.round(totalDurationSeconds / 60);
            const durationCounter = document.getElementById('video-duration-counter');
            if (durationCounter) {
                const limitText = durationLimitMin === Infinity ? "Unlimited" : durationLimitMin + "m";
                durationCounter.querySelector('span:last-child').textContent = `Total Duration: ${totalMinutes}m / ${limitText}`;
                
                if (durationLimitMin !== Infinity && totalMinutes >= durationLimitMin) {
                    durationCounter.className = "text-xs font-bold px-3 py-1.5 rounded-full bg-rose-50 text-rose-600 flex items-center gap-2 border border-rose-200 animate-pulse";
                } else if (durationLimitMin !== Infinity && totalMinutes >= durationLimitMin * 0.8) {
                    durationCounter.className = "text-xs font-bold px-3 py-1.5 rounded-full bg-amber-50 text-amber-600 flex items-center gap-2 border border-amber-200";
                } else {
                    durationCounter.className = "text-xs font-bold px-3 py-1.5 rounded-full bg-slate-100 text-slate-600 flex items-center gap-2 border border-slate-200";
                }
            }

            const lessonCounter = document.getElementById('lesson-count-counter');
            if (lessonCounter) {
                const limitText = lessonLimit === Infinity ? "∞" : lessonLimit;
                document.getElementById('lesson-count-text').textContent = `${lessonsData.length} / ${limitText} Lessons`;
                
                if (lessonLimit !== Infinity && lessonsData.length >= lessonLimit) {
                    lessonCounter.className = "text-xs font-bold px-3 py-1.5 rounded-full bg-rose-50 text-rose-600 flex items-center gap-2 border border-rose-200";
                    const addBtn = document.getElementById('add-lesson-btn');
                    if (addBtn) addBtn.classList.add('opacity-50', 'pointer-events-none');
                } else {
                    lessonCounter.className = "text-xs font-bold px-3 py-1.5 rounded-full bg-slate-100 text-slate-600 flex items-center gap-2 border border-slate-200";
                    const addBtn = document.getElementById('add-lesson-btn');
                    if (addBtn) addBtn.classList.remove('opacity-50', 'pointer-events-none');
                }
            }
            
            // Auto-select first lesson if none selected and we have lessons
            if (lessonsData.length > 0) {
                const firstLessonEl = container.querySelector('.lesson-item');
                if (firstLessonEl && (document.getElementById('lesson-editor-empty').classList.contains('z-10') || !document.getElementById('lesson-editor-empty').classList.contains('hidden'))) {
                    selectLesson(firstLessonEl);
                }
            }
        }

        let availableQuizzes = [];
        let filteredQuizzes = [];
        
        window.openAddQuizModal = async function() {
            const modal = document.getElementById('add-quiz-modal');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.firstElementChild.classList.remove('scale-95');
            }, 10);
            
            document.getElementById('add-quiz-error').classList.add('hidden');
            document.getElementById('add-quiz-search').value = '';
            document.getElementById('add-quiz-list').innerHTML = `<div class="p-8 text-center text-slate-500 text-sm">Loading your quizzes...</div>`;
            
            try {
                const cId = @courseId;
                // Fetch available quizzes for this course
                const res = await fetch(`/CourseQuiz/Available/${cId}`);
                const data = await res.json();
                
                if (data.success) {
                    availableQuizzes = data.data || [];
                    
                    // Filter out quizzes that are already in quizzesData
                    const alreadyAddedIds = new Set(quizzesData.map(q => q.quizId || q.QuizId));
                    availableQuizzes = availableQuizzes.filter(q => !alreadyAddedIds.has(q.quizId));
                    
                    filterAddQuizList();
                } else {
                    document.getElementById('add-quiz-list').innerHTML = `<div class="p-4 text-red-500">${data.message || 'Failed to load quizzes.'}</div>`;
                }
            } catch (err) {
                document.getElementById('add-quiz-list').innerHTML = `<div class="p-4 text-red-500">Network error occurred while loading quizzes.</div>`;
            }
        };

        window.closeAddQuizModal = function() {
            const modal = document.getElementById('add-quiz-modal');
            modal.classList.add('opacity-0');
            modal.firstElementChild.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        };

        window.filterAddQuizList = function() {
            const term = document.getElementById('add-quiz-search').value.toLowerCase();
            filteredQuizzes = availableQuizzes.filter(q => (q.title || '').toLowerCase().includes(term));
            renderAddQuizList();
        };

        window.renderAddQuizList = function() {
            const listEl = document.getElementById('add-quiz-list');
            if (filteredQuizzes.length === 0) {
                listEl.innerHTML = `<div class="p-8 text-center text-slate-500 text-sm">No available quizzes found.</div>`;
                return;
            }
            
            listEl.innerHTML = filteredQuizzes.map(q => `
                <div class="p-3 flex items-center justify-between hover:bg-slate-50 transition-colors">
                    <div>
                        <div class="font-bold text-slate-800 text-sm">${q.title}</div>
                        <div class="text-xs text-slate-500 mt-0.5">${q.questionCount} Questions</div>
                    </div>
                    <button onclick="addQuizToCourse(${q.quizId})" class="px-3 py-1.5 bg-primary text-white text-xs font-bold rounded shadow shadow-primary/20 hover:bg-primary/90 transition-colors">
                        Add to Course
                    </button>
                </div>
            `).join('');
        };

        window.addQuizToCourse = async function(quizId) {
            const cId = @courseId;
            try {
                // CourseQuiz/Add
                const orderIdx = quizzesData ? quizzesData.length : 0;
                const reqBody = { courseId: cId, quizId: quizId, orderIndex: orderIdx };
                
                const res = await fetch('/CourseQuiz/Add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(reqBody)
                });
                
                const data = await res.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    const errEl = document.getElementById('add-quiz-error');
                    errEl.textContent = data.message || "Failed to add quiz to course.";
                    errEl.classList.remove('hidden');
                }
            } catch(e) {
                const errEl = document.getElementById('add-quiz-error');
                errEl.textContent = "Network error occurred.";
                errEl.classList.remove('hidden');
            }
        };

        window.removeQuizFromCourse = async function(cId, qId) {
            if(!confirm("Remove this quiz from the course?")) return;
            try {
                const res = await fetch(`/CourseQuiz/Remove?courseId=${cId}&quizId=${qId}`, { method: 'DELETE' });
                if(res.ok) {
                    window.location.reload();
                } else {
                    alert("Failed to remove quiz.");
                }
            } catch(e) { alert("Network error"); }
        }

        window.toggleQuizVisibility = async function(cId, qId, checkbox) {
            const hide = !checkbox.checked;
            try {
                const res = await fetch(`/CourseQuiz/Hide?courseId=${cId}&quizId=${qId}&hide=${hide}`, { method: 'PATCH' });
                if(res.ok) {
                    window.location.reload();
                } else {
                    const data = await res.json().catch(() => null);
                    checkbox.checked = !checkbox.checked;
                    alert(data?.message || "Failed to toggle visibility. A student might be taking this quiz.");
                }
            } catch(e) { 
                checkbox.checked = !checkbox.checked;
                alert("Network error"); 
            }
        }

        window.selectLesson = function(el) {
            // Show editor, hide empty state
            const emptyState = document.getElementById('lesson-editor-empty');
            const editor = document.getElementById('lesson-editor-active');
            const landingEditor = document.getElementById('landing-page-editor');
            
            // Ensure landing page editor is hidden when selecting a lesson
            landingEditor.classList.add('hidden');
            landingEditor.style.display = 'none';

            emptyState.style.display = 'none';
            emptyState.classList.add('hidden');
            emptyState.classList.remove('z-10');
            
            editor.style.display = 'flex';
            editor.classList.remove('hidden');
            editor.classList.add('z-20');
            setTimeout(() => editor.classList.remove('opacity-0'), 10);
            
            document.querySelectorAll('.lesson-item').forEach(i => {
                i.classList.remove('border-primary','ring-1','ring-primary/20','shadow-sm'); 
                i.classList.add('border-slate-100');
                const icon = i.querySelector('.material-symbols-outlined');
                icon.classList.remove('text-primary'); icon.classList.add('text-slate-400');
                icon.style.fontVariationSettings = '';
            });
            el.classList.add('border-primary','ring-1','ring-primary/20','shadow-sm');
            el.classList.remove('border-slate-100');
            const icon = el.querySelector('.material-symbols-outlined');
            icon.classList.remove('text-slate-400'); icon.classList.add('text-primary');
            icon.style.fontVariationSettings = '"FILL" 1';

            document.getElementById('editing-lesson-id').textContent = el.dataset.num;
            document.getElementById('editing-lesson-title').value = el.dataset.title;

            // Extract duration from materialMetadata
            const lessonId = parseInt(el.dataset.lessonId);
            const lesson = lessonsData.find(l => (l.lessonId || l.LessonId) == lessonId);
            console.log("Selecting Lesson:", lessonId, lesson); // Debug log
            let durationDisplay = "0 mins";
            
            // Update Status Badge
            const statusBadge = document.getElementById('editing-lesson-status-badge');
            const statusText = document.getElementById('editing-lesson-status-text');
            if (statusBadge && statusText) {
                const lStatus = (lesson?.lessonStatus || lesson?.LessonStatus || 'draft').toLowerCase();
                
                if (lStatus === 'published') {
                    statusBadge.className = "flex items-center gap-1 text-primary";
                    statusBadge.querySelector('.material-symbols-outlined').textContent = "check_circle";
                    statusText.textContent = "Published";
                } else if (lStatus === 'rejected') {
                    statusBadge.className = "flex items-center gap-1 text-red-500";
                    statusBadge.querySelector('.material-symbols-outlined').textContent = "cancel";
                    statusText.textContent = "Rejected";
                } else {
                    statusBadge.className = "flex items-center gap-1 text-slate-400";
                    statusBadge.querySelector('.material-symbols-outlined').textContent = "pending_actions";
                    statusText.textContent = "Draft";
                }
            }
            
            // Clear current form
            if (window.videoQuill) window.videoQuill.root.innerHTML = '';
            if (window.resourceQuill) window.resourceQuill.root.innerHTML = '';
            document.getElementById('MaterialUrl').value = '';
            document.getElementById('ResourceUrl').value = '';
            document.getElementById('resource-title-input').value = '';
            document.getElementById('resource-file-name').textContent = 'No file chosen';
            resetVideoUpload();
            
            const resourcesList = document.getElementById('resources-list');
            resourcesList.innerHTML = '';
            let hasResources = false;
            
            if (lesson) {
                // Handle various casing: learningMaterials, LearningMaterials, learning_materials
                const materials = lesson.learningMaterials || lesson.LearningMaterials || lesson.learning_materials || [];
                console.log("Materials found for lesson:", lessonId, materials);
                
                if (Array.isArray(materials) && materials.length > 0) {
                    materials.forEach(material => {
                        // Extract metadata safely - it might be an object or a JSON string
                        let metadata = material.materialMetadata || material.MaterialMetadata;
                        if (typeof metadata === 'string') {
                            try { metadata = JSON.parse(metadata); } catch(e) { metadata = {}; }
                        }
                        
                        const type = (metadata?.file_type || metadata?.FileType || metadata?.fileType || 'video').toLowerCase();
                        const mUrl = material.materialUrl || material.MaterialUrl;
                        const mDesc = material.description || material.Description;
                        const mTitle = material.title || material.Title;
                        const mLearningStatus = (material.learningStatus || material.LearningStatus || '').toLowerCase();
                        const mModerationFeedback = material.moderationFeedback || material.ModerationFeedback || '';

                        if (type === 'video' && mLearningStatus !== 'removed') {
                            // Populate video description
                            if (mDesc && window.videoQuill) {
                                window.videoQuill.root.innerHTML = mDesc;
                            }
                            // Populate video UI
                            if (mUrl) {
                                document.getElementById('MaterialUrl').value = mUrl;
                                document.getElementById('video-drop-area').classList.add('hidden');
                                document.getElementById('video-success').classList.remove('hidden');
                                const displayEl = document.getElementById('uploaded-filename-display');
                                if (displayEl) displayEl.textContent = mTitle || "Lesson Video Content";
                                const inputEl = document.getElementById('video-title-input');
                                if (inputEl) inputEl.value = mTitle || "Lesson Video Content";
                                
                                const totalSeconds = metadata?.duration || metadata?.Duration || 0;
                                durationDisplay = formatDuration(totalSeconds);

                                // Load into preview player
                                const previewPlayer = document.getElementById('video-preview-player');
                                const playerWrapper = document.getElementById('video-preview-player-wrapper');
                                const placeholder = document.getElementById('video-preview-placeholder');
                                if (previewPlayer && playerWrapper && placeholder) {
                                    previewPlayer.src = mUrl;
                                    previewPlayer.load();
                                    placeholder.classList.add('hidden');
                                    playerWrapper.classList.remove('hidden');
                                }
                            }
                            // Show moderation feedback for rejected video
                            if (mLearningStatus === 'rejected' && mModerationFeedback) {
                                const videoSuccessEl = document.getElementById('video-success');
                                if (videoSuccessEl) {
                                    videoSuccessEl.insertAdjacentHTML('afterend', `
                                        <div class="mt-3 bg-red-50 border border-red-200 p-3 rounded-xl flex items-start gap-2">
                                            <span class="material-symbols-outlined text-red-500 text-[18px] mt-0.5">error</span>
                                            <div>
                                                <p class="text-xs font-bold text-red-700 mb-0.5">Moderation Feedback:</p>
                                                <p class="text-xs text-red-600">${mModerationFeedback}</p>
                                            </div>
                                        </div>
                                    `);
                                }
                            }
                        } else if (type === 'document' || type === 'file') {
                            // Skip soft-removed materials
                            if (mLearningStatus === 'removed') return;
                            // Populate resource UI list
                            if (mUrl) {
                                const mId = material.materialId || material.MaterialId;
                                hasResources = true;
                                const isRejected = mLearningStatus === 'rejected';
                                const borderColor = isRejected ? 'border-red-200' : 'border-slate-200';
                                const bgColor = isRejected ? 'bg-red-50/50' : 'bg-white';
                                const iconBg = isRejected ? 'bg-red-100 text-red-500' : 'bg-[#006a62]/10 text-[#006a62]';
                                const iconName = isRejected ? 'cancel' : 'description';
                                const rejectedHint = (isRejected && mModerationFeedback) ? `
                                    <div class="mt-2 bg-red-50 border border-red-200 p-2.5 rounded-lg flex items-start gap-2">
                                        <span class="material-symbols-outlined text-red-500 text-[16px] mt-0.5">error</span>
                                        <div>
                                            <p class="text-[11px] font-bold text-red-700 mb-0.5">Moderation Feedback:</p>
                                            <p class="text-[11px] text-red-600">${mModerationFeedback}</p>
                                        </div>
                                    </div>` : '';
                                
