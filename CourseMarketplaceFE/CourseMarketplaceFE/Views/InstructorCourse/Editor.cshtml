@{
    ViewData["Title"] = "Curriculum Editor";
    Layout = "_InstructorLayout";
    var courseId = ViewBag.CourseId ?? 1;
}

<div class="p-8 h-full flex flex-col">
    <div class="flex items-center justify-between mb-8 flex-shrink-0">
        <div class="flex items-center gap-4">
            <a href="/InstructorCourse" class="text-slate-400 hover:text-primary transition-colors"><span class="material-symbols-outlined text-[20px]">arrow_back</span></a>
            <h1 class="text-2xl font-headline font-extrabold text-slate-900">Course Structure</h1>
            @{
                var courseStatus = ViewBag.CourseStatus as string ?? "Draft";
                if (courseStatus.Equals("Published", StringComparison.OrdinalIgnoreCase)) {
                    <span class="px-2 py-1 bg-primary-container/20 text-primary border border-primary-container rounded text-[10px] font-bold uppercase tracking-wider">Published</span>
                } else if (courseStatus.Equals("Pending", StringComparison.OrdinalIgnoreCase)) {
                    <span class="px-2 py-1 bg-amber-50 text-amber-600 border border-amber-200 rounded text-[10px] font-bold uppercase tracking-wider">Pending Review</span>
                } else if (courseStatus.Equals("Rejected", StringComparison.OrdinalIgnoreCase)) {
                    <span class="px-2 py-1 bg-red-50 text-red-600 border border-red-200 rounded text-[10px] font-bold uppercase tracking-wider">Rejected</span>
                } else {
                    <span class="px-2 py-1 bg-slate-100 text-slate-600 border border-slate-200 rounded text-[10px] font-bold uppercase tracking-wider">Draft</span>
                }
            }
        </div>
        <div class="flex items-center gap-3">
            <a href="/Course/Details/@courseId" target="_blank" class="px-4 py-2 bg-white text-slate-700 font-bold border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">visibility</span> Preview
            </a>
            @if (!courseStatus.Equals("Pending", StringComparison.OrdinalIgnoreCase)) {
                <button class="px-5 py-2 bg-emerald-600 text-white font-bold rounded-lg hover:bg-emerald-700 transition-colors shadow-lg shadow-emerald-600/20 flex items-center gap-2" onclick="submitCourseForReview()">
                    <span class="material-symbols-outlined text-[18px]">send</span> 
                    @(courseStatus.Equals("Published", StringComparison.OrdinalIgnoreCase) ? "Submit Changes" : "Submit for Review")
                </button>
            }
        </div>
    </div>

    <!-- Moderation Feedback Alert -->
    @{
        var moderationFeedback = ViewBag.ModerationFeedback as string;
    }
    @if (!string.IsNullOrEmpty(moderationFeedback))
    {
        <div class="mb-6 bg-amber-50 border border-amber-200 p-4 rounded-xl flex items-start gap-3 shadow-sm animate-in fade-in slide-in-from-top-2 duration-300">
            <span class="material-symbols-outlined text-amber-600">report</span>
            <div class="flex-1">
                <h4 class="text-sm font-bold text-amber-900 mb-1">Phản hồi kiểm duyệt:</h4>
                <p class="text-sm text-amber-800 leading-relaxed">@moderationFeedback</p>
            </div>
            <button onclick="this.parentElement.remove()" class="text-amber-400 hover:text-amber-600">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
        </div>
    }

    <div class="flex gap-8 h-full overflow-hidden">
        <!-- LEFT: Course Structure -->
        <div class="w-80 flex-shrink-0 flex flex-col gap-4 overflow-hidden">
            <div class="flex border-b border-slate-200 mb-2">
                <button class="flex-1 py-3 text-sm font-bold border-b-2 border-primary text-primary" id="btn-tab-curriculum" onclick="switchMainTab('curriculum')">Curriculum</button>
                <button class="flex-1 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors" id="btn-tab-landing" onclick="switchMainTab('landing')">Course Landing Page</button>
            </div>
            
            <div id="course-structure-container" class="flex-1 flex flex-col gap-4 overflow-y-auto pb-8 pr-2 custom-scrollbar">
                <!-- Dynamic content injected by JS -->
            </div>
        </div>

        <!-- RIGHT: Lesson Editor / Landing Page Editor -->
        <div class="flex-1 flex flex-col bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden relative">
            
            <!-- Tab: Landing Page Editor (Hidden by default) -->
            <div id="landing-page-editor" class="hidden flex-1 flex-col h-full overflow-y-auto p-8 custom-scrollbar">
                <!-- Limit Banner -->
                @if (ViewBag.IsStripeActive == false)
                {
                    <div class="mb-8 p-4 bg-amber-50 border border-amber-200 rounded-xl flex items-start gap-4 shadow-sm animate-in fade-in slide-in-from-top-4 duration-500">
                        <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-amber-600">info</span>
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-amber-900">Tài khoản chưa liên kết Stripe</h3>
                            <p class="text-amber-800 text-sm mt-1 leading-relaxed">
                                Bạn đang ở chế độ giới hạn: Tối đa <strong>2 khóa học</strong>, <strong>5 bài học/khóa</strong>, <strong>1 tài liệu/bài học</strong> và <strong>30 phút video</strong> toàn khóa. 
                                <a href="/Instructor/StripeOnboarding" class="font-bold underline hover:text-amber-700 ml-1">Liên kết Stripe ngay</a> để gỡ bỏ giới hạn và bắt đầu kiếm tiền.
                            </p>
                        </div>
                    </div>
                }
                else if (ViewBag.Price == 0)
                {
                    <div class="mb-8 p-4 bg-blue-50 border border-blue-200 rounded-xl flex items-start gap-4 shadow-sm">
                        <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-blue-600">info</span>
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-blue-900">Khóa học Miễn phí</h3>
                            <p class="text-blue-800 text-sm mt-1 leading-relaxed">
                                Đối với khóa học miễn phí, tổng thời lượng video toàn khóa bị giới hạn tối đa là <strong>60 phút</strong>.
                            </p>
                        </div>
                    </div>
                }

                <div class="max-w-4xl mx-auto space-y-12">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h2 class="text-3xl font-headline font-extrabold text-slate-900">Course Curriculum</h2>
                            <p class="text-slate-500 mt-1">Design your learning path. Drag and drop to reorder.</p>
                        </div>
                        <div class="flex flex-col items-end gap-2">
                            <div id="video-duration-counter" class="text-xs font-bold px-3 py-1.5 rounded-full bg-slate-100 text-slate-600 flex items-center gap-2 border border-slate-200">
                                <span class="material-symbols-outlined text-[16px]">schedule</span>
                                <span>Total Duration: 0m / @(ViewBag.IsStripeActive == false ? "30m" : (ViewBag.Price == 0 ? "60m" : "Unlimited"))</span>
                            </div>
                            <div id="lesson-count-counter" class="text-xs font-bold px-3 py-1.5 rounded-full bg-slate-100 text-slate-600 flex items-center gap-2 border border-slate-200">
                                <span class="material-symbols-outlined text-[16px]">lists</span>
                                <span id="lesson-count-text">0 / @(ViewBag.IsStripeActive == false ? "5" : "∞") Lessons</span>
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <h2 class="text-3xl font-headline font-extrabold text-slate-900">Course Landing Page</h2>
                            <div id="landing-autosave-status" class="hidden text-xs font-semibold text-slate-400 flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px] animate-spin">sync</span> Saving...
                            </div>
                        </div>

                        <p class="text-slate-500">Your course landing page is crucial to your success. Make it stand out!</p>
                    </div>

                    <div class="grid grid-cols-1 gap-8">
                        <!-- Basic Info -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Course Title <span class="text-red-500">*</span></label>
                            <input type="text" id="course-title-input" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary" value="@ViewBag.CourseTitle" />
                        </div>

                        <!-- Description -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Course Description <span class="text-red-500">*</span></label>
                            <div class="bg-white rounded-xl">
                                <div id="course-description-editor">@Html.Raw(ViewBag.Description)</div>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-8">
                            <!-- Category -->
                            <div class="space-y-4">
                                <label class="text-sm font-bold text-slate-900 block">Category <span class="text-red-500">*</span></label>
                                <div class="relative">
                                    <select id="course-category-input" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary appearance-none pr-10 transition-all cursor-pointer">
                                        <option value="0">Select Category</option>
                                        @if (ViewBag.AvailableCategories != null)
                                        {
                                            foreach (var cat in (List<CourseMarketplaceFE.Models.CategoryViewModel>)ViewBag.AvailableCategories)
                                            {
                                                <option value="@cat.CategoryId" selected="@(ViewBag.CategoryId == cat.CategoryId)">@cat.CategoriesName</option>
                                            }
                                        }
                                    </select>
                                    <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
                                        <span class="material-symbols-outlined text-slate-400 text-[20px]">expand_all</span>
                                    </div>
                                </div>
                            </div>
                            <!-- Price -->
                            <div class="space-y-4">
                                @{
                                    var isStripeActiveEditor = (bool)(ViewBag.IsStripeActive ?? false);
                                }

                                @if (!isStripeActiveEditor)
                                {
                                    <!-- ★ Stripe chưa kích hoạt → Khóa giá = Free, hiện prompt -->
                                    <div class="flex items-center justify-between">
                                        <label class="text-sm font-bold text-slate-900 block">Price (USD)</label>
                                        <span class="text-xs text-amber-600 font-bold bg-amber-50 px-2 py-1 rounded border border-amber-200">🔒 Chỉ Free</span>
                                    </div>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                            <span class="text-slate-400 font-bold material-symbols-outlined text-[18px]">attach_money</span>
                                        </div>
                                        <input type="text" value="0.00 — Free" disabled class="w-full pl-11 pr-4 py-3 bg-slate-100 border border-slate-200 rounded-xl font-semibold text-slate-400 cursor-not-allowed" />
                                        <!-- Hidden input để gửi giá = 0 -->
                                        <input type="hidden" id="course-price-input" value="0" />
                                    </div>
                                    
                                    <!-- Stripe Registration Banner -->
                                    <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-xl p-4 mt-3">
                                        <div class="flex items-start gap-3">
                                            <div class="w-10 h-10 bg-amber-100 text-amber-600 rounded-lg flex items-center justify-center shrink-0">
                                                <span class="material-symbols-outlined text-[22px]">lock</span>
                                            </div>
                                            <div class="flex-1">
                                                <p class="text-sm font-bold text-amber-900 mb-1">Muốn bán khóa học có phí?</p>
                                                <p class="text-xs text-amber-700 mb-2">Đăng ký tài khoản Stripe để mở khóa tính năng đặt giá.</p>
                                                <a href="/Instructor/Dashboard" 
                                                   class="inline-flex items-center gap-1.5 px-4 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-lg shadow hover:shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 text-xs">
                                                    <span class="material-symbols-outlined text-[16px]">credit_card</span>
                                                    Đăng ký Stripe
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Quick Price Tiers (disabled) -->
                                    <div class="flex flex-wrap gap-2 mt-3">
                                        <span class="px-3 py-1.5 text-xs font-bold rounded-lg border border-primary bg-primary/10 text-primary">Free ✓</span>
                                        <span class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-slate-100 text-slate-400 cursor-not-allowed">$9.99 🔒</span>
                                        <span class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-slate-100 text-slate-400 cursor-not-allowed">$19.99 🔒</span>
                                        <span class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-slate-100 text-slate-400 cursor-not-allowed">$49.99 🔒</span>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 flex gap-4 border border-slate-100 mt-4">
                                        <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center text-white shrink-0 mt-1">
                                            <span class="material-symbols-outlined text-[14px]">info</span>
                                        </div>
                                        <div>
                                            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Instructor Revenue</p>
                                            <p class="font-bold text-slate-900 text-lg">Free Course</p>
                                            <p class="text-[10px] text-slate-500 mt-1">Đăng ký Stripe để bán khóa học với giá tùy chọn</p>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <!-- ✅ Stripe đã kích hoạt → Cho phép đặt giá -->
                                    <div class="flex items-center justify-between">
                                        <label class="text-sm font-bold text-slate-900 block">Price (USD)</label>
                                        <span class="text-xs text-slate-500 font-medium bg-slate-100 px-2 py-1 rounded">Min: $0.00</span>
                                    </div>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                            <span class="text-slate-500 font-bold material-symbols-outlined text-[18px]">attach_money</span>
                                        </div>
                                        <input type="number" id="course-price-input" min="0" step="0.01" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-primary focus:border-primary font-semibold text-slate-800 transition-colors" value="@ViewBag.Price" placeholder="0.00" onblur="formatPrice(this)" />
                                    </div>
                                    
                                    <!-- Quick Price Tiers -->
                                    <div class="flex flex-wrap gap-2 mt-3">
                                        <button type="button" onclick="setPrice(0)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">Free</button>
                                        <button type="button" onclick="setPrice(9.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$9.99</button>
                                        <button type="button" onclick="setPrice(19.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$19.99</button>
                                        <button type="button" onclick="setPrice(49.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$49.99</button>
                                        <button type="button" onclick="setPrice(99.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$99.99</button>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 flex gap-4 border border-slate-100 mt-4">
                                        <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center text-white shrink-0 mt-1">
                                            <span class="material-symbols-outlined text-[14px]">info</span>
                                        </div>
                                        <div>
                                            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Instructor Revenue</p>
                                            <p class="font-bold text-slate-900 text-lg">70% Share</p>
                                            <p class="text-[10px] text-slate-500 mt-1">Estimated payout per sale: <span id="payout-estimate">$0.00</span></p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- What you will learn -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">What you will learn (one per line or list)</label>
                            <div class="bg-white rounded-xl">
                                <div id="course-learn-editor">@Html.Raw(ViewBag.WhatYouWillLearn)</div>
                            </div>
                        </div>

                        <!-- Requirements -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Requirements</label>
                            <div class="bg-white rounded-xl">
                                <div id="course-req-editor">@Html.Raw(ViewBag.Requirements)</div>
                            </div>
                        </div>

                        <!-- Thumbnail -->
                        <div class="space-y-4">
                            <label class="text-sm font-bold text-slate-900 block">Course Thumbnail <span class="text-red-500">*</span></label>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-3">
                                    <div id="thumb-drop-area" class="border-2 border-dashed border-slate-200 rounded-xl p-6 text-center hover:bg-slate-50 transition-all cursor-pointer group relative overflow-hidden">
                                        <div class="py-4">
                                            <span class="material-symbols-outlined text-[32px] text-slate-300 group-hover:text-primary transition-colors">image</span>
                                            <p class="text-xs font-bold text-slate-500 mt-2">Click or drag to upload</p>
                                            <p class="text-[10px] text-slate-400">JPG, PNG or WebP (16:9 recommended)</p>
                                        </div>
                                        <input type="file" id="thumb-file-input" accept="image/*" class="hidden" />
                                        
                                        <!-- Mini Progress Overlay -->
                                        <div id="thumb-upload-progress" class="hidden absolute inset-0 bg-white/90 flex flex-col items-center justify-center">
                                            <div class="w-8 h-8 border-4 border-primary/20 border-t-primary rounded-full animate-spin mb-2"></div>
                                            <p class="text-[10px] font-bold text-primary">Uploading...</p>
                                        </div>
                                    </div>
                                    
                                    <input type="hidden" id="course-thumbnail-input" value="@ViewBag.ThumbnailUrl" />
                                </div>
                                
                                <div class="space-y-3">
                                    <div class="flex items-center justify-between">
                                        <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Preview & Alignment</label>
                                        <select id="thumb-fit-input" class="text-[10px] font-bold bg-slate-100 border-none rounded px-2 py-1 cursor-pointer focus:ring-0">
                                            <option value="cover">Cover (Fill)</option>
                                            <option value="contain">Contain (Fit)</option>
                                            <option value="fill">Stretch</option>
                                        </select>
                                    </div>
                                    <div class="aspect-video bg-slate-100 rounded-xl overflow-hidden border border-slate-200 shadow-inner flex items-center justify-center">
                                        <img id="course-thumbnail-preview" src="@(string.IsNullOrEmpty(ViewBag.ThumbnailUrl) ? "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=400" : ViewBag.ThumbnailUrl)" class="w-full h-full object-cover transition-all duration-300" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        

                    </div>
                </div>
            </div>

            <!-- Empty State -->
            <div id="lesson-editor-empty" class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center bg-white z-10">
                <div class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mb-6 border border-slate-100">
                    <span class="material-symbols-outlined text-[48px] text-slate-300">edit_document</span>
                </div>
                <h2 class="text-2xl font-headline font-extrabold text-slate-900 mb-2">No Lesson Selected</h2>
                <p class="text-slate-500 max-w-sm">Select a lesson from the curriculum on the left or create a new one to start editing.</p>
                <button onclick="addNewLesson()" class="mt-8 px-6 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors shadow-lg shadow-primary/20 flex items-center gap-2 mx-auto">
                    <span class="material-symbols-outlined text-[18px]">add</span> Create New Lesson
                </button>
            </div>

            <!-- Active Editor -->
            <div id="lesson-editor-active" class="hidden flex-1 flex-col h-full opacity-0 transition-opacity duration-300">
                <div class="p-6 border-b border-slate-200 flex items-center justify-between bg-slate-50/50">
                <div>
                    <div class="flex items-center gap-2 text-[10px] font-bold text-primary uppercase tracking-widest mb-2">
                        <span class="material-symbols-outlined text-[14px]">edit</span> Editing Lesson <span id="editing-lesson-id">--</span>
                    </div>
                    <h2 id="editing-lesson-title" class="text-3xl font-headline font-extrabold text-slate-900">Select a Lesson</h2>
                    <div class="flex items-center gap-4 mt-2 text-xs font-semibold text-slate-500">
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">schedule</span> <span id="editing-lesson-duration">0 mins</span></span>
                        <span id="editing-lesson-status-badge" class="flex items-center gap-1 text-slate-400">
                            <span class="material-symbols-outlined text-[16px]">pending_actions</span> 
                            <span id="editing-lesson-status-text">Draft</span>
                        </span>
                    </div>
                </div>
                <div class="flex gap-3">
                    <!-- Actions are now within tabs -->
                </div>
            </div>

            <div class="flex-1 overflow-y-auto p-8 custom-scrollbar">
                <!-- Tabs -->
                <div class="flex border-b border-slate-200 mb-8">
                    <button class="tab-btn px-6 py-3 border-b-2 border-primary text-primary font-bold text-sm" data-tab="tab-video">Video Content</button>
                    <button class="tab-btn px-6 py-3 border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-semibold text-sm transition-colors" data-tab="tab-resources">Resources & Files</button>
                </div>

                <!-- Tab: Video Content -->
                <div id="tab-video" class="tab-content">
                    <div class="grid grid-cols-3 gap-8">
                        <div class="col-span-2">
                            <div class="max-w-2xl mx-auto mb-12">
                                <input type="hidden" id="MaterialUrl" name="MaterialUrl" />
                                <div id="video-drop-area" class="border-2 border-dashed border-slate-200 rounded-2xl p-12 text-center hover:bg-slate-50 transition-colors cursor-pointer group">
                                    <div class="w-20 h-20 bg-primary-container/30 text-primary rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                                        <span class="material-symbols-outlined text-[40px]">movie</span>
                                    </div>
                                    <h3 class="text-lg font-bold text-slate-900 mb-2">Upload Lesson Video</h3>
                                    <p class="text-sm text-slate-500 mb-4">MP4, WebM or OGG up to 2GB</p>
                                    <span class="px-6 py-2 bg-white border border-slate-200 rounded-lg text-slate-700 font-bold text-sm hover:bg-slate-50 inline-block">Browse Files</span>
                                    <input type="file" id="video-input" accept="video/*" class="hidden" />
                                </div>
                                <div id="video-upload-progress" class="hidden text-center py-8">
                                    <div class="w-16 h-16 bg-primary-container/30 text-primary rounded-2xl flex items-center justify-center mx-auto mb-6">
                                        <span class="material-symbols-outlined text-[32px]">cloud_upload</span>
                                    </div>
                                    <h3 id="upload-filename-display" class="text-xl font-bold text-slate-900 mb-2"></h3>
                                    <p class="text-sm text-slate-500 mb-6">Processing <span id="progress-text">0</span>% • Do not close this tab during upload.</p>
                                    <div class="h-2 bg-slate-100 rounded-full w-full max-w-md mx-auto mb-8 overflow-hidden">
                                        <div id="progress-bar-fill" class="h-full bg-primary-container transition-all duration-300" style="width: 0%"></div>
                                    </div>
                                    <div class="flex justify-center gap-4">
                                        <button type="button" id="cancel-upload" class="px-6 py-2.5 bg-red-50 text-red-600 font-bold rounded-lg flex items-center gap-2 hover:bg-red-100 transition-colors">
                                            <span class="material-symbols-outlined text-[18px]">cancel</span> Cancel Upload
                                        </button>
                                    </div>
                                </div>
                                <div id="video-success" class="hidden border border-slate-200 rounded-2xl p-6 flex items-center justify-between bg-surface-container-low">
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 bg-primary text-white rounded-lg flex items-center justify-center">
                                            <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>play_circle</span>
                                        </div>
                                        <div>
                                            <h4 class="font-bold text-slate-900" id="uploaded-filename"></h4>
                                            <p class="text-xs text-slate-500" id="video-save-status">Video successfully processed</p>
                                        </div>
                                    </div>
                                    <button class="text-slate-400 hover:text-primary transition-colors" title="Replace video" onclick="document.getElementById('video-input').click()">
                                        <span class="material-symbols-outlined">edit</span>
                                    </button>
                                </div>
                            </div>
                            
                            <div class="mt-8">
                                <label class="text-sm font-bold text-slate-900 mb-2 block">Video Description</label>
                                <div class="bg-white rounded-xl">
                                    <div id="video-editor"></div>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-6">
                            <!-- Auto-save status indicator -->
                            <div id="video-autosave-status" class="hidden text-xs text-center font-semibold text-slate-400 flex items-center justify-center gap-1">
                                <span class="material-symbols-outlined text-[14px] animate-spin">sync</span> Saving...
                            </div>
                            

                        </div>
                    </div>
                </div>

                <!-- Tab: Resources -->
                <div id="tab-resources" class="tab-content hidden">
                    <div class="grid grid-cols-3 gap-8">
                        <div class="col-span-2">
                            <!-- Existing Resources -->
                            <div class="mb-8">
                                <h4 class="font-bold text-slate-900 mb-4">Uploaded Resources</h4>
                                <div id="resources-list" class="space-y-3">
                                    <div class="text-slate-500 text-sm italic py-4 text-center border-2 border-dashed border-slate-200 rounded-lg bg-slate-50">No resources uploaded yet.</div>
                                </div>
                            </div>
                            
                            <!-- Add New Resource Form -->
                            <div class="bg-slate-50 p-6 rounded-xl border border-slate-200">
                                <h4 class="font-bold text-slate-900 mb-4">Add New Resource</h4>
                                
                                <div class="mb-4">
                                    <label class="text-sm font-bold text-slate-700 block mb-2">Resource File</label>
                                    <div class="flex items-center gap-4">
                                        <input type="hidden" id="ResourceUrl" name="ResourceUrl" />
                                        <input type="file" id="resource-input" accept=".pdf,.doc,.docx,.txt,.zip,.rar,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png" class="hidden" />
                                        <button id="upload-resource-btn" class="px-4 py-2 bg-white border border-slate-300 text-slate-700 font-bold rounded-lg hover:bg-slate-50 transition-colors shadow-sm">
                                            Choose File
                                        </button>
                                        <span id="resource-upload-progress" class="hidden text-primary font-bold text-sm">Uploading...</span>
                                        <span id="resource-file-name" class="text-sm text-slate-500">No file chosen</span>
                                    </div>
                                </div>
                                
                                <div class="mb-4">
                                    <label class="text-sm font-bold text-slate-700 block mb-2">Resource Title</label>
                                    <input type="text" id="resource-title-input" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:ring-primary focus:border-primary" placeholder="e.g. Presentation Slides" />
                                </div>
                                
                                <div>
                                    <label class="text-sm font-bold text-slate-700 block mb-2">Resource Description</label>
                                    <div class="bg-white rounded-xl">
                                        <div id="resource-editor"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-6">
                            <!-- Usage Instructions -->
                            <div class="bg-amber-50 border border-amber-200 p-4 rounded-xl">
                                <h5 class="text-xs font-bold text-amber-800 uppercase tracking-wider mb-2 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[16px]">info</span> Cách thêm tài liệu
                                </h5>
                                <ul class="text-[11px] text-amber-700 space-y-1.5 leading-relaxed">
                                    <li>1. Nhập <b>Tiêu đề/Mô tả</b> trước (nếu muốn).</li>
                                    <li>2. Chọn file để bắt đầu tải lên.</li>
                                    <li>3. Hệ thống sẽ <b>tự động lưu</b> ngay khi tải xong.</li>
                                    <li>* Nếu để trống tiêu đề, hệ thống sẽ tự lấy theo tên file.</li>
                                </ul>
                            </div>

                            <!-- Status indicator -->
                            <div id="resource-autosave-status" class="hidden text-xs text-center font-semibold text-emerald-600 flex items-center justify-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">check_circle</span> <span id="resource-autosave-text">Saved!</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Lesson Modal -->
<div id="add-lesson-modal" class="fixed inset-0 bg-black/50 z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 transform scale-95 transition-transform duration-300">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-headline font-extrabold text-slate-900">Add New Lesson</h3>
            <button onclick="closeLessonModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="mb-6">
            <label class="block text-sm font-bold text-slate-700 mb-2">Lesson Title</label>
            <input type="text" id="new-lesson-title" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-900 font-medium" placeholder="e.g. 1.1 Introduction to the Course" onkeydown="if(event.key==='Enter') submitNewLesson()" />
        </div>
        <div class="flex justify-end gap-3">
            <button onclick="closeLessonModal()" class="px-5 py-2.5 bg-slate-100 text-slate-600 font-bold rounded-lg hover:bg-slate-200 transition-colors">Cancel</button>
            <button onclick="submitNewLesson()" class="px-5 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors shadow-lg shadow-primary/20" id="submit-lesson-btn">Create Lesson</button>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
</style>

@if (courseStatus.Equals("Pending", StringComparison.OrdinalIgnoreCase))
{
    <div class="fixed top-24 left-1/2 -translate-x-1/2 z-[60] animate-in slide-in-from-top-4 duration-500">
        <div class="bg-white/80 backdrop-blur-md border border-amber-200 px-6 py-3 rounded-full shadow-xl flex items-center gap-3">
            <div class="w-8 h-8 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center">
                <span class="material-symbols-outlined text-[20px]">lock</span>
            </div>
            <p class="text-sm font-bold text-slate-900">Khóa học đang chờ duyệt — Chế độ chỉ đọc</p>
        </div>
    </div>
}

@section Scripts {
    <script>
        // --- GLOBAL FUNCTIONS AT THE TOP ---
        window.addNewLesson = function() {
            console.log("Add New Lesson clicked");
            const modal = document.getElementById('add-lesson-modal');
            const input = document.getElementById('new-lesson-title');
            if (!modal) { console.error("Modal not found!"); return; }
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.querySelector('div').classList.remove('scale-95');
                if (input) {
                    input.value = '';
                    input.focus();
                }
            }, 10);
        };

        window.closeLessonModal = function() {
            const modal = document.getElementById('add-lesson-modal');
            if (!modal) return;
            modal.classList.add('opacity-0');
            modal.querySelector('div').classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        };

        console.log("Editor Scripts Initializing...");


        // ─── Quill ───
        const quillConfig = {
            theme: 'snow',
            modules: { toolbar: [['bold','italic'],[{'list':'ordered'},{'list':'bullet'}],['link','code-block']] }
        };
        window.videoQuill = new Quill('#video-editor', { ...quillConfig, placeholder: 'Describe the video content...' });
        window.resourceQuill = new Quill('#resource-editor', { ...quillConfig, placeholder: 'Describe this resource...' });
        
        // Course Landing Page Quills
        window.courseDescQuill = new Quill('#course-description-editor', { ...quillConfig, placeholder: 'Detailed course description...' });
        window.courseLearnQuill = new Quill('#course-learn-editor', { ...quillConfig, placeholder: 'What will students achieve?' });
        window.courseReqQuill = new Quill('#course-req-editor', { ...quillConfig, placeholder: 'What do students need before starting?' });

        // ─── Main Tabs Switching ───
        window.switchMainTab = function(tab) {
            const btnCurriculum = document.getElementById('btn-tab-curriculum');
            const btnLanding = document.getElementById('btn-tab-landing');
            const structureContainer = document.getElementById('course-structure-container');
            const lessonEditorEmpty = document.getElementById('lesson-editor-empty');
            const lessonEditorActive = document.getElementById('lesson-editor-active');
            const landingEditor = document.getElementById('landing-page-editor');

            if (tab === 'curriculum') {
                btnCurriculum.className = "flex-1 py-3 text-sm font-bold border-b-2 border-primary text-primary";
                btnLanding.className = "flex-1 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors";
                structureContainer.classList.remove('hidden');
                
                landingEditor.classList.add('hidden');
                landingEditor.style.display = 'none';

                // Determine which curriculum state to show
                if (lessonsData.length === 0) {
                    lessonEditorEmpty.classList.remove('hidden');
                    lessonEditorEmpty.style.display = 'flex';
                    lessonEditorActive.classList.add('hidden');
                    lessonEditorActive.style.display = 'none';
                } else {
                    const activeId = document.getElementById('editing-lesson-id').textContent;
                    if (activeId !== '--') {
                        lessonEditorActive.classList.remove('hidden');
                        lessonEditorActive.style.display = 'flex';
                        lessonEditorEmpty.classList.add('hidden');
                        lessonEditorEmpty.style.display = 'none';
                    } else {
                        lessonEditorEmpty.classList.remove('hidden');
                        lessonEditorEmpty.style.display = 'flex';
                        lessonEditorActive.classList.add('hidden');
                        lessonEditorActive.style.display = 'none';
                    }
                }
            } else {
                btnLanding.className = "flex-1 py-3 text-sm font-bold border-b-2 border-primary text-primary";
                btnCurriculum.className = "flex-1 py-3 text-sm font-semibold border-b-2 border-transparent text-slate-500 hover:text-slate-700 transition-colors";
                structureContainer.classList.add('hidden');
                
                landingEditor.classList.remove('hidden');
                landingEditor.style.display = 'flex';
                
                lessonEditorEmpty.classList.add('hidden');
                lessonEditorEmpty.style.display = 'none';
                lessonEditorActive.classList.add('hidden');
                lessonEditorActive.style.display = 'none';
            }
        };

        window.saveCourseDetails = function(skipAlert = false) {
            const btn = document.getElementById('save-course-details-btn');
            const title = document.getElementById('course-title-input').value;
            const price = document.getElementById('course-price-input').value;
            const catId = document.getElementById('course-category-input').value;
            const thumb = document.getElementById('course-thumbnail-input').value;
            
            const desc = window.courseDescQuill.root.innerHTML;
            const learn = window.courseLearnQuill.root.innerHTML;
            const req = window.courseReqQuill.root.innerHTML;

            const autoSaveEl = document.getElementById('landing-autosave-status');
            const autoSaveText = autoSaveEl?.querySelector('span:last-child') || { textContent: '' };

            // Validation (only alert if NOT auto-saving)
            if (!title || title.trim() === '') { 
                if (!skipAlert) Swal.fire('Thiếu thông tin', 'Vui lòng nhập Tiêu đề khóa học.', 'warning'); 
                return; 
            }
            if (!desc || desc.trim() === '' || desc === '<p><br></p>') { 
                if (!skipAlert) Swal.fire('Thiếu thông tin', 'Vui lòng nhập Mô tả khóa học.', 'warning'); 
                return; 
            }
            if (catId == "0") {
                if (!skipAlert) Swal.fire('Thiếu thông tin', 'Vui lòng chọn Danh mục khóa học.', 'warning');
                return;
            }

            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span> Saving...';
            }
            
            if (autoSaveEl) {
                autoSaveEl.classList.remove('hidden');
                autoSaveEl.className = "text-xs font-semibold text-slate-400 flex items-center gap-1";
                autoSaveEl.querySelector('.material-symbols-outlined').textContent = 'sync';
                autoSaveEl.querySelector('.material-symbols-outlined').classList.add('animate-spin');
                if (autoSaveText) autoSaveText.textContent = 'Saving...';
            }

            const fd = new FormData();
            fd.append('courseId', courseId);
            fd.append('title', title);
            fd.append('description', desc);
            fd.append('price', price);
            fd.append('categoryId', catId);
            fd.append('thumbnailUrl', thumb);
            fd.append('whatYouWillLearn', learn);
            fd.append('requirements', req);

            fetch('/InstructorCourse/UpdateDetails', { method: 'POST', body: fd })
                .then(res => res.json())
                .then(json => {
                    if (json.success) {
                        if (json.status && json.status.toLowerCase() === 'pending') {
                            location.reload();
                        } else {
                            if (!skipAlert) {
                                Swal.fire({ icon: 'success', title: 'Saved!', text: 'Course details updated successfully.', timer: 1500, showConfirmButton: false });
                            }
                            const h1El = document.querySelector('h1');
                            if (h1El) h1El.textContent = title;
                            const thumbPrevEl = document.getElementById('course-thumbnail-preview');
                            if (thumbPrevEl) thumbPrevEl.src = thumb || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=200";
                            
                            // Update initial data so subsequent checks work correctly
                            initialCourseData = { title, desc, price, catId, thumb, learn, req };

                            if (autoSaveEl) {
                                autoSaveEl.querySelector('.material-symbols-outlined').textContent = 'check_circle';
                                autoSaveEl.querySelector('.material-symbols-outlined').classList.remove('animate-spin');
                                autoSaveEl.className = "text-xs font-semibold text-emerald-600 flex items-center gap-1";
                                if (autoSaveText) autoSaveText.textContent = 'Saved!';
                                setTimeout(() => autoSaveEl.classList.add('hidden'), 3000);
                            }
                        }
                    } else {
                        if (!skipAlert) Swal.fire('Error', json.message || 'Failed to update details', 'error');
                        if (autoSaveEl) autoSaveEl.classList.add('hidden');
                    }
                })
                .catch(e => {
                    if (!skipAlert) Swal.fire('Error', 'An error occurred', 'error');
                    if (autoSaveEl) autoSaveEl.classList.add('hidden');
                })
                .finally(() => {
                    if (btn) {
                        btn.disabled = false;
                        btn.innerHTML = '<span class="material-symbols-outlined text-[20px]">save</span> Save Course Details';
                    }
                });
        };

        // Debounce helper
        function debounce(func, wait) {
            let timeout;
            return function(...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        const debouncedSaveLanding = debounce(() => {
            saveCourseDetails(true);
        }, 1500);

        // Attach listeners for landing page fields
        ['course-title-input', 'course-category-input', 'course-price-input', 'course-thumbnail-input'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', debouncedSaveLanding);
        });

        if (window.courseDescQuill) window.courseDescQuill.on('text-change', debouncedSaveLanding);
        if (window.courseLearnQuill) window.courseLearnQuill.on('text-change', debouncedSaveLanding);
        if (window.courseReqQuill) window.courseReqQuill.on('text-change', debouncedSaveLanding);


        // Thumbnail preview sync
        document.getElementById('course-thumbnail-input').addEventListener('input', function(e) {
            document.getElementById('course-thumbnail-preview').src = e.target.value || "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=400";
        });

        document.getElementById('thumb-fit-input').addEventListener('change', function(e) {
            document.getElementById('course-thumbnail-preview').style.objectFit = e.target.value;
        });

        // ─── Thumbnail Upload ───
        const thumbDropArea = document.getElementById('thumb-drop-area');
        const thumbInput = document.getElementById('thumb-file-input');
        const thumbProgress = document.getElementById('thumb-upload-progress');
        const thumbPreview = document.getElementById('course-thumbnail-preview');
        const thumbUrlInput = document.getElementById('course-thumbnail-input');

        thumbDropArea.addEventListener('click', () => thumbInput.click());
        thumbInput.addEventListener('change', function() { handleThumbUpload(this.files); });
        
        function handleThumbUpload(files) {
            if (!files.length) return;
            const file = files[0];
            if (!file.type.startsWith('image/')) { 
                Swal.fire('Invalid File', 'Please upload an image.', 'warning');
                return; 
            }

            thumbProgress.classList.remove('hidden');
            
            const CLOUD_NAME = 'df8i0azc5';
            const UPLOAD_PRESET = 'course_marketplace_preset';
            const url = `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`;
            
            const fd = new FormData();
            fd.append('upload_preset', UPLOAD_PRESET);
            fd.append('file', file);
            
            fetch(url, { method: 'POST', body: fd })
                .then(res => res.json())
                .then(data => {
                    if (data.secure_url) {
                        thumbUrlInput.value = data.secure_url;
                        thumbPreview.src = data.secure_url;
                        Swal.fire({ icon: 'success', title: 'Image Uploaded', text: 'Thumbnail updated successfully.', timer: 1500, showConfirmButton: false });
                    }
                })
                .catch(err => {
                    Swal.fire('Upload Failed', 'Error uploading image to server.', 'error');
                })
                .finally(() => {
                    thumbProgress.classList.add('hidden');
                });
        }


        // ─── Tabs ───
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('border-primary','text-primary','font-bold'); b.classList.add('border-transparent','text-slate-500','font-semibold'); });
                btn.classList.add('border-primary','text-primary','font-bold');
                btn.classList.remove('border-transparent','text-slate-500','font-semibold');
                document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
                document.getElementById(btn.dataset.tab).classList.remove('hidden');
            });
        });

        // ─── Render Lessons dynamically ───
        const courseId = @courseId;
        // Pass JSON directly as a JS object to avoid quote/newline issues
        let lessonsData = @Html.Raw(ViewBag.LessonsJson ?? "[]");

        let initialCourseData = {
            title: document.getElementById('course-title-input')?.value || '',
            desc: window.courseDescQuill?.root.innerHTML || '',
            price: document.getElementById('course-price-input')?.value || '0',
            catId: document.getElementById('course-category-input')?.value || '0',
            thumb: document.getElementById('course-thumbnail-input')?.value || '',
            learn: window.courseLearnQuill?.root.innerHTML || '',
            req: window.courseReqQuill?.root.innerHTML || ''
        };
        
        // Show API error if any
        @if (ViewBag.ApiError != null) {
            <text>
            console.error("API Error:", "@Html.Raw(ViewBag.ApiError)");
            // Show a warning banner at the top
            const errBanner = document.createElement('div');
            errBanner.className = 'mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm font-semibold';
            errBanner.innerHTML = '<span class="material-symbols-outlined text-[16px] align-middle mr-1">error</span> @Html.Raw(ViewBag.ApiError) — Lesson data could not be loaded. Try logging in again.';
            document.querySelector('.p-8')?.prepend(errBanner);
            </text>
        }

        // Debugging — inspect what the server gave us
        console.log("Lessons Data loaded:", lessonsData);
        if (lessonsData.length > 0) {
            console.log("First lesson keys:", Object.keys(lessonsData[0]));
            if (lessonsData[0].learningMaterials || lessonsData[0].LearningMaterials) {
                console.log("First lesson has materials:", lessonsData[0].learningMaterials || lessonsData[0].LearningMaterials);
            } else {
                console.warn("First lesson has NO learningMaterials property. Available keys:", Object.keys(lessonsData[0]));
            }
        } else {
            console.warn("lessonsData is EMPTY. API may have returned 401 or no lessons exist.");
        }

        // ─── UI Element Declarations (moved up to avoid TDZ) ───
        const videoDropArea = document.getElementById('video-drop-area');
        const videoInput = document.getElementById('video-input');
        const uiProgress = document.getElementById('video-upload-progress');
        const uiSuccess = document.getElementById('video-success');
        const progressBarFill = document.getElementById('progress-bar-fill');
        const progressText = document.getElementById('progress-text');
        const uploadedFilename = document.getElementById('uploaded-filename');
        const materialUrlInput = document.getElementById('MaterialUrl');
        let currentXHR = null;

        // Remove unused resource references to avoid null errors
        function renderCourseStructure() {
            const container = document.getElementById('course-structure-container');
            container.innerHTML = '';
            
            // Render a default section wrapper (since we don't have sections API yet)
            let sectionHtml = `
            <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden border-l-4 border-l-primary mb-4">
                <div class="p-4 bg-slate-50/50 flex items-center justify-between">
                    <div>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Course Curriculum</p>
                        <h3 class="font-bold text-slate-900 text-sm">Main Section</h3>
                    </div>
                </div>
                <div class="p-4 space-y-2">
            `;
            
            let totalDurationSeconds = 0;
            const isStripeActive = @Json.Serialize(ViewBag.IsStripeActive);
            const coursePrice = @Json.Serialize(ViewBag.Price);
            const durationLimitMin = isStripeActive === false ? 30 : (coursePrice == 0 ? 60 : Infinity);
            const lessonLimit = isStripeActive === false ? 5 : Infinity;
            const isPending = '@(ViewBag.CourseStatus as string ?? "Draft")'.toLowerCase() === 'pending';
            
            lessonsData.forEach((lesson, index) => {
                const num = index + 1;
                // Safely get lesson properties (handle both PascalCase and camelCase)
                const lId = lesson.lessonId || lesson.LessonId;
                const lTitle = lesson.title || lesson.Title;
                const lStatus = (lesson.lessonStatus || lesson.LessonStatus || '').toLowerCase();
                
                // Check if lesson has any rejected materials
