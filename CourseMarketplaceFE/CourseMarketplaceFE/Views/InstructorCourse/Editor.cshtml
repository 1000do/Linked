        videoDropArea.addEventListener('drop', e => handleVideoUpload(e.dataTransfer.files), false);

        async function handleVideoUpload(files) {
            if (!files.length) return;
            const file = files[0];
            if (!file.type.startsWith('video/')) { 
                Swal.fire('Invalid File', 'Please upload a video file.', 'warning');
                return; 
            }
            
            // Analyze file size and show tip if heavy
            const sizeInMB = file.size / (1024 * 1024);
            if (sizeInMB > 50) {
                const proceed = await Swal.fire({
                    title: 'Large File Detected',
                    text: `This video is ${sizeInMB.toFixed(1)}MB. Large files take longer to upload and might lag for students. We recommend compressing it below 20MB using a tool like "MP4 Converter" before uploading. Proceed anyway?`,
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, upload anyway',
                    cancelButtonText: 'I will compress it first'
                });
                if (!proceed.isConfirmed) { videoInput.value = ''; return; }
            }

            videoDropArea.classList.add('hidden');
            uiProgress.classList.remove('hidden');
            uiSuccess.classList.add('hidden');
            document.getElementById('upload-filename-display').textContent = `Uploading "${file.name}"`;
            progressBarFill.style.width = '0%'; progressText.textContent = '0';

            const CLOUD_NAME = 'df8i0azc5';
            const UPLOAD_PRESET = 'course_marketplace_preset';
            
            // Use Chunked Upload for stability
            const chunkSize = 6 * 1024 * 1024; // 6MB chunks
            const totalChunks = Math.ceil(file.size / chunkSize);
            const uniqueUploadId = 'vid_' + Date.now() + '_' + Math.random().toString(36).substring(7);
            
            try {
                for (let i = 0; i < totalChunks; i++) {
                    const start = i * chunkSize;
                    const end = Math.min(start + chunkSize, file.size);
                    const chunk = file.slice(start, end);
                    
                    const fd = new FormData();
                    fd.append('upload_preset', UPLOAD_PRESET);
                    fd.append('file', chunk);
                    
                    const xhr = new XMLHttpRequest();
                    currentXHR = xhr;
                    
                    const promise = new Promise((resolve, reject) => {
                        xhr.upload.addEventListener('progress', e => {
                            if (e.lengthComputable) {
                                const currentUploaded = start + e.loaded;
                                const totalPct = Math.round((currentUploaded / file.size) * 100);
                                progressBarFill.style.width = totalPct + '%';
                                progressText.textContent = totalPct;
                            }
                        });
                        
                        xhr.addEventListener('load', () => {
                            if (xhr.status >= 200 && xhr.status < 300) {
                                resolve(JSON.parse(xhr.responseText));
                            } else {
                                reject('Chunk upload failed: ' + xhr.statusText);
                            }
                        });
                        xhr.addEventListener('error', () => reject('Network error.'));
                        xhr.addEventListener('abort', () => reject('Aborted'));
                    });
                    
                    xhr.open('POST', `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/video/upload`, true);
                    xhr.setRequestHeader('X-Unique-Upload-Id', uniqueUploadId);
                    xhr.setRequestHeader('Content-Range', `bytes ${start}-${end - 1}/${file.size}`);
                    xhr.send(fd);
                    
                    const result = await promise;
                    if (i === totalChunks - 1) {
                        // Last chunk — finalize
                        setTimeout(() => {
                            uiProgress.classList.add('hidden');
                            uiSuccess.classList.remove('hidden');
                            uploadedFilename.textContent = file.name;
                            materialUrlInput.value = result.secure_url;
                            // Capture metadata for the database
                            materialUrlInput.dataset.duration = Math.round(result.duration || 0);
                            materialUrlInput.dataset.fileSize = result.bytes || 0;
                            materialUrlInput.dataset.format = result.format || '';
                            // Auto-save immediately after upload
                            saveVideoMaterial();
                        }, 400);
                    }
                }
            } catch (err) {
                if (err !== 'Aborted') handleUploadError(err);
            }
        }

        document.getElementById('cancel-upload').addEventListener('click', () => { if(currentXHR) currentXHR.abort(); });
        function handleUploadError(msg) { 
            Swal.fire('Upload Failed', msg, 'error');
            resetVideoUpload(); 
        }
        function resetVideoUpload() { videoDropArea.classList.remove('hidden'); uiProgress.classList.add('hidden'); uiSuccess.classList.add('hidden'); videoInput.value=''; materialUrlInput.value=''; document.querySelectorAll('#tab-video .bg-red-50.border-red-200').forEach(el => el.remove()); }
        window.resetVideoUpload = resetVideoUpload;

        // ─── Auto-Save Video Material ───
        window.saveVideoMaterial = function() {
            const lessonIdEl = document.querySelector('.lesson-item.border-primary');
            if (!lessonIdEl) return;
            const lessonId = lessonIdEl.dataset.lessonId;
            const title = lessonIdEl.dataset.title;
            const description = window.videoQuill.root.innerHTML;
            const materialUrl = document.getElementById('MaterialUrl').value;
            if (!materialUrl) return;

            const statusEl = document.getElementById('video-save-status');
            const autoSaveEl = document.getElementById('video-autosave-status');
            if (autoSaveEl) { autoSaveEl.classList.remove('hidden'); }
            if (statusEl) statusEl.textContent = 'Saving...';
            
            const fd = new FormData();
            fd.append('lessonId', lessonId);
            fd.append('title', title + " Video");
            if(description && description !== '<p><br></p>') fd.append('description', description);
            fd.append('materialUrl', materialUrl);
            fd.append('type', 'video');
            
            const matUrlInput = document.getElementById('MaterialUrl');
            if (matUrlInput.dataset.duration) fd.append('duration', matUrlInput.dataset.duration);
            if (matUrlInput.dataset.fileSize) fd.append('fileSize', matUrlInput.dataset.fileSize);
            if (matUrlInput.dataset.format) fd.append('fileExtension', matUrlInput.dataset.format);
            
            fetch('/InstructorCourse/AddMaterial', { method: 'POST', body: fd })
                .then(res => {
                    if(res.ok) return res.json();
                    throw new Error('HTTP ' + res.status);
                })
                .then(json => {
                    if(json.success) {
                        if (statusEl) statusEl.textContent = '✓ Saved automatically';
                        if (json.data) updateLocalMaterials(lessonId, json.data, 'video');
                    } else {
                        if (statusEl) statusEl.textContent = '✗ ' + (json.message || 'Save failed');
                    }
                })
                .catch(e => {
                    if (statusEl) statusEl.textContent = '✗ Error saving';
                })
                .finally(() => {
                    if (autoSaveEl) setTimeout(() => autoSaveEl.classList.add('hidden'), 2000);
                });
        };

        window.saveResourceMaterial = function(resourceUrl, resourceName, fileSize, fileExtension) {
            const lessonIdEl = document.querySelector('.lesson-item.border-primary');
            if (!lessonIdEl) return;
            const lessonId = lessonIdEl.dataset.lessonId;
            
            // Read latest description from editor
            const description = window.resourceQuill?.root.innerHTML || '';
            const title = resourceName || document.getElementById('resource-title-input').value || 'Resource File';

            const autoSaveEl = document.getElementById('resource-autosave-status');
            const autoSaveText = document.getElementById('resource-autosave-text');
            if (autoSaveEl) {
                autoSaveEl.classList.remove('hidden');
                autoSaveEl.className = autoSaveEl.className.replace('text-emerald-600','text-slate-400');
                if (autoSaveText) autoSaveText.textContent = 'Saving...';
                autoSaveEl.querySelector('.material-symbols-outlined').textContent = 'sync';
                autoSaveEl.querySelector('.material-symbols-outlined').classList.add('animate-spin');
            }

            const fd = new FormData();
            fd.append('lessonId', lessonId);
            fd.append('title', resourceName || 'Resource File');
            if(description && description !== '<p><br></p>') fd.append('description', description);
            fd.append('materialUrl', resourceUrl);
            fd.append('type', 'document');
            if (fileSize) fd.append('fileSize', fileSize);
            if (fileExtension) fd.append('fileExtension', fileExtension);
            
            fetch('/InstructorCourse/AddMaterial', { method: 'POST', body: fd })
                .then(res => {
                    if(res.ok) return res.json();
                    throw new Error('HTTP ' + res.status);
                })
                .then(json => {
                    if(json.success) {
                        // Clear upload form
                        document.getElementById('ResourceUrl').value = '';
                        document.getElementById('resource-title-input').value = '';
                        if (window.resourceQuill) window.resourceQuill.root.innerHTML = '';
                        document.getElementById('resource-file-name').textContent = 'No file chosen';
                        document.getElementById('upload-resource-btn').innerHTML = 'Choose File';
                        
                        if (json.data) updateLocalMaterials(lessonId, json.data, 'document', true);
                        
                        if (autoSaveEl) {
                            autoSaveEl.querySelector('.material-symbols-outlined').textContent = 'check_circle';
                            autoSaveEl.querySelector('.material-symbols-outlined').classList.remove('animate-spin');
                            autoSaveEl.className = autoSaveEl.className.replace('text-slate-400','text-emerald-600');
                            if (autoSaveText) autoSaveText.textContent = 'Saved!';
                            setTimeout(() => autoSaveEl.classList.add('hidden'), 3000);
                        }
                    } else {
                        if (autoSaveEl && autoSaveText) { autoSaveText.textContent = json.message || 'Save failed'; setTimeout(() => autoSaveEl.classList.add('hidden'), 3000); }
                    }
                })
                .catch(e => {
                    if (autoSaveEl && autoSaveText) { autoSaveText.textContent = 'Error saving'; setTimeout(() => autoSaveEl.classList.add('hidden'), 3000); }
                });
        };


        // ─── Remove Material (soft-delete) ───
        window.removeMaterial = function(materialId, btn) {
            Swal.fire({
                title: 'Remove this file?',
                text: 'The file will be marked as removed. You can re-upload it later.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'Remove'
            }).then(result => {
                if (!result.isConfirmed) return;

                const fd = new FormData();
                fd.append('materialId', materialId);
                fetch('/InstructorCourse/RemoveMaterial', { method: 'POST', body: fd })
                    .then(res => res.json())
                    .then(json => {
                        if (json.success) {
                            const card = btn.closest('[data-material-id]');
                            if (card) card.remove();
                            // Update local data
                            const lessonIdEl = document.querySelector('.lesson-item.border-primary');
                            if (lessonIdEl) {
                                const lessonId = lessonIdEl.dataset.lessonId;
                                const lesson = lessonsData.find(l => (l.lessonId || l.LessonId) == lessonId);
                                if (lesson && lesson.learningMaterials) {
                                    const mat = lesson.learningMaterials.find(m => (m.materialId || m.MaterialId) == materialId);
                                    if (mat) mat.learningStatus = 'removed';
                                }
                            }
                            Swal.fire({
                                title: 'Removed!',
                                text: 'Material moved to trash. You can restore or permanently delete it in the Trash Bin.',
                                icon: 'success',
                                confirmButtonColor: '#006a62'
                            });
                        } else {
                            Swal.fire('Error', json.message || 'Failed to remove material.', 'error');
                        }
                    })
                    .catch(e => {
                        Swal.fire('Error', 'An error occurred.', 'error');
                    });
            });
        };


        function appendResourceToUI(material) {
            const resourcesList = document.getElementById('resources-list');
            const emptyState = resourcesList.querySelector('.text-slate-500.italic');
            if (emptyState) emptyState.remove();

            const mUrl = material.materialUrl || material.MaterialUrl;
            const mId = material.materialId || material.MaterialId;
            const mTitle = material.title || material.Title || "Resource File";
            const mDesc = material.description || material.Description;
            const mLearningStatus = (material.learningStatus || material.LearningStatus || '').toLowerCase();
            const mModerationFeedback = material.moderationFeedback || material.ModerationFeedback || '';

            const isRejected = mLearningStatus === 'rejected';
            const borderColor = isRejected ? 'border-red-200' : 'border-slate-200';
            const bgColor = isRejected ? 'bg-red-50/50' : 'bg-white';
            const iconBg = isRejected ? 'bg-red-100 text-red-500' : 'bg-[#006a62]/10 text-[#006a62]';
            const iconName = isRejected ? 'cancel' : 'description';
            const rejectedHint = (isRejected && mModerationFeedback) ? `
                <div class="mt-2 bg-red-50 border border-red-200 p-2.5 rounded-lg flex items-start gap-2">
                    <span class="material-symbols-outlined text-red-500 text-[16px] mt-0.5">error</span>
                    <div>
                        <p class="text-[11px] font-bold text-red-700 mb-0.5">Phản hồi kiểm duyệt:</p>
                        <p class="text-[11px] text-red-600">${mModerationFeedback}</p>
                    </div>
                </div>` : '';
            
            const html = `
                <div class="p-3 ${bgColor} border ${borderColor} rounded-lg shadow-sm" data-material-id="${mId}">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 ${iconBg} rounded flex items-center justify-center">
                                <span class="material-symbols-outlined">${iconName}</span>
                            </div>
                            <div>
                                <p class="font-bold text-slate-900 text-sm">${mTitle}</p>
                                <p class="text-xs text-slate-500 truncate max-w-xs">${mDesc ? mDesc.replace(/<[^>]*>?/gm, '').substring(0, 50) + "..." : "No description"}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <a href="${mUrl}" target="_blank" class="text-[#006a62] hover:bg-[#006a62]/10 p-2 rounded-full transition-colors"><span class="material-symbols-outlined text-[20px]">open_in_new</span></a>
                            <button onclick="removeMaterial(${mId}, this)" class="text-slate-400 hover:text-red-500 transition-colors p-2 rounded-full hover:bg-red-50" title="Remove">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                        </div>
                    </div>
                    ${rejectedHint}
                </div>
            `;
            resourcesList.insertAdjacentHTML('afterbegin', html);
        }

        function updateLocalMaterials(lessonId, newMat, type, append = false) {
            const lesson = lessonsData.find(l => (l.lessonId || l.LessonId) == lessonId);
            if (lesson) {
                if (!lesson.learningMaterials) lesson.learningMaterials = [];
                if (append) {
                    lesson.learningMaterials.push(newMat);
                    if (type === 'document') appendResourceToUI(newMat);
                } else {
                    const existingIdx = lesson.learningMaterials.findIndex(m => {
                        const mType = m.materialMetadata?.file_type || 'video';
                        return mType === type;
                    });
                    if (existingIdx !== -1) lesson.learningMaterials[existingIdx] = newMat;
                    else {
                        lesson.learningMaterials.push(newMat);
                        if (type === 'document') appendResourceToUI(newMat);
                    }
                }
            }
        }

        window.submitCourseForReview = function() {
            // --- VALIDATION BEFORE SUBMIT ---
            const title = document.getElementById('course-title-input').value;
            const desc = window.courseDescQuill.root.innerHTML;
            const catId = document.getElementById('course-category-input').value;
            const thumb = document.getElementById('course-thumbnail-input').value;
            const price = document.getElementById('course-price-input').value;
            const learn = window.courseLearnQuill.root.innerHTML;
            const req = window.courseReqQuill.root.innerHTML;

            // 1. Check basic info
            if (!title || title.trim() === '' || !desc || desc === '<p><br></p>' || catId == "0") {
                switchMainTab('landing'); 
                Swal.fire({
                    title: 'Thông tin chưa đầy đủ',
                    text: 'Vui lòng hoàn thiện Tiêu đề, Mô tả và Danh mục tại tab "Course Landing Page" trước khi gửi duyệt.',
                    icon: 'warning',
                    confirmButtonColor: '#006a62'
                });
                return;
            }

            // 2. Check curriculum (Must have at least one lesson)
            if (!lessonsData || lessonsData.length === 0) {
                switchMainTab('curriculum');
                Swal.fire({
                    title: 'Giáo trình trống',
                    text: 'Khóa học cần có ít nhất một bài học (Lesson) để gửi duyệt.',
                    icon: 'warning',
                    confirmButtonColor: '#006a62'
                });
                return;
            }

            // Unsaved changes check
            let hasUnsavedChanges = false;
            if (title !== initialCourseData.title ||
                desc !== initialCourseData.desc ||
                catId !== initialCourseData.catId ||
                price !== initialCourseData.price ||
                thumb !== initialCourseData.thumb ||
                learn !== initialCourseData.learn ||
                req !== initialCourseData.req) {
                hasUnsavedChanges = true;
            }
            
            const proceedWithSubmit = () => {
                // 3. Check if all lessons have content
                const emptyLessons = lessonsData.filter(l => {
                    const materials = l.learningMaterials || l.LearningMaterials || [];
                    return materials.length === 0;
                });
                
                if (emptyLessons.length > 0) {
                    switchMainTab('curriculum');
                    Swal.fire({
                        title: 'Bài học chưa có nội dung',
                        text: `Bạn có ${emptyLessons.length} bài học chưa tải video hoặc tài liệu. Vui lòng bổ sung nội dung trước khi gửi duyệt.`,
                        icon: 'warning',
                        confirmButtonColor: '#006a62'
                    });
                    return;
                }

                Swal.fire({
                    title: 'Submit for review?',
                    text: "Are you sure you want to submit this course for review? Once submitted, administrators will review your content before it is published to students.",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#006a62',
                    cancelButtonColor: '#cbd5e1',
                    confirmButtonText: 'Yes, submit it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch('/InstructorCourse/UpdateCourseStatus', { 
                            method: 'POST', 
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: new URLSearchParams({ courseId: courseId, status: 'pending' })
                        })
                        .then(res => res.json())
                        .then(json => {
                            if (json.success) {
                                Swal.fire({
                                    title: 'Đã gửi xét duyệt!',
                                    html: `
                                        <div class="text-left space-y-3">
                                            <p class="text-slate-600">Khóa học của bạn đã được gửi đến đội ngũ quản trị viên.</p>
                                            <div class="bg-primary/5 border border-primary/10 p-4 rounded-xl">
                                                <div class="flex items-center gap-2 text-primary mb-1">
                                                    <span class="material-symbols-outlined text-[20px]">schedule</span>
                                                    <span class="font-bold">Thời gian dự kiến: 3-5 ngày làm việc</span>
                                                </div>
                                                <p class="text-xs text-slate-500">Chúng tôi sẽ thông báo cho bạn ngay khi có kết quả xét duyệt.</p>
                                            </div>
                                            <p class="text-xs text-amber-600 font-medium italic">Lưu ý: Khóa học sẽ bị khóa chỉnh sửa trong lúc chờ duyệt.</p>
                                        </div>
                                    `,
                                    icon: 'success',
                                    confirmButtonText: 'Đã hiểu',
                                    confirmButtonColor: '#006a62'
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Error', json.message || 'Failed to update course status.', 'error');
                            }
                        })
                        .catch(e => {
                            Swal.fire('Error', 'An error occurred while communicating with the server.', 'error');
                        });
                    }
                });
            };

            if (hasUnsavedChanges) {
                Swal.fire({
                    title: 'Unsaved Changes',
                    text: 'There are unsaved changes in Course Landing Page, do you want to save before proceed?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#006a62',
                    cancelButtonColor: '#cbd5e1',
                    confirmButtonText: 'YES',
                    cancelButtonText: 'NO'
                }).then((saveResult) => {
                    if (saveResult.isConfirmed) {
                        // YES -> save then submit
                        saveCourseDetails(true).then(() => {
                            proceedWithSubmit();
                        });
                    } else if (saveResult.dismiss === Swal.DismissReason.cancel) {
                        // NO -> continue with original data, don't save
                        proceedWithSubmit();
                    }
                });
            } else {
                proceedWithSubmit();
            }
        };


        // ─── Price Formatting & Quick Selection ───
        window.formatPrice = function(input) {
            if (!input || input.disabled) return;
            if (!input.value) {
                input.value = "0.00";
                updatePayout(0);
                return;
            }
            // Parse float and format to 2 decimal places
            let val = parseFloat(input.value);
            if (isNaN(val) || val < 0) val = 0;
            input.value = val.toFixed(2);
            updatePayout(val);
        };

        function updatePayout(val) {
            const el = document.getElementById('payout-estimate');
            if (el) el.textContent = '$' + ((parseFloat(val)||0)*0.7).toFixed(2);
        }

        // Format initial price (must be called AFTER formatPrice is defined)
        const priceInput = document.getElementById('course-price-input');
        if (priceInput) formatPrice(priceInput);

        window.setPrice = function(price) {
            const input = document.getElementById('course-price-input');
            if (input) {
                input.value = parseFloat(price).toFixed(2);
                updatePayout(price);
                // Optional: visual feedback that price changed
                input.classList.add('ring-2', 'ring-primary', 'bg-primary/5');
                setTimeout(() => {
                    input.classList.remove('ring-2', 'ring-primary', 'bg-primary/5');
                }, 500);
            }
        };
        
        // ─── Resource Upload ───
        const resourceBtnEl = document.getElementById('upload-resource-btn');
        const resourceProgressEl = document.getElementById('resource-upload-progress');
        const resourceInputEl = document.getElementById('resource-input');
        
        resourceBtnEl.addEventListener('click', () => resourceInputEl.click());
        resourceInputEl.addEventListener('change', function() {
            if (this.files.length > 0) {
                // ★ Limit: Max 1 resource for unlinked Stripe
                const isStripeActive = @Json.Serialize(ViewBag.IsStripeActive);
                if (isStripeActive === false) {
                    const lessonIdEl = document.querySelector('.lesson-item.border-primary');
                    if (lessonIdEl) {
                        const lessonId = lessonIdEl.dataset.lessonId;
                        const lesson = lessonsData.find(l => (l.lessonId || l.LessonId) == lessonId);
                        if (lesson && lesson.learningMaterials) {
                            const resources = lesson.learningMaterials.filter(m => {
                                const mStatus = (m.learningStatus || m.LearningStatus || '').toLowerCase();
                                const mMetadata = m.materialMetadata || m.MaterialMetadata;
                                let fType = mMetadata?.file_type || mMetadata?.FileType || 'video';
                                return mStatus !== 'removed' && (fType === 'document' || fType === 'file' || fType === 'raw');
                            });
                            if (resources.length >= 1) {
                                Swal.fire('Giới hạn tài liệu', 'Instructor chưa liên kết Stripe chỉ được phép đính kèm tối đa 1 tài liệu mỗi bài học.', 'warning');
                                this.value = '';
                                return;
                            }
                        }
                    }
                }

                const file = this.files[0];
                
                // ★ Block video files in resource section
                const fileName = file.name.toLowerCase();
                const videoExtensions = ['.mp4', '.mov', '.avi', '.wmv', '.flv', '.webm', '.mkv'];
                if (videoExtensions.some(ext => fileName.endsWith(ext)) || file.type.startsWith('video/')) {
                    Swal.fire({
                        title: 'Định dạng không hợp lệ',
                        text: 'Phần này chỉ dành cho tài liệu (PDF, Word, Zip...). Vui lòng upload Video ở phần "Video Content".',
                        icon: 'error',
                        confirmButtonColor: '#006a62'
                    });
                    this.value = '';
                    return;
                }

                resourceBtnEl.classList.add('hidden');
                resourceProgressEl.classList.remove('hidden');
                
                const CLOUD_NAME = 'df8i0azc5';
                const UPLOAD_PRESET = 'course_marketplace_preset';
                const url = `https://api.cloudinary.com/v1_1/${CLOUD_NAME}/raw/upload`;
                const fd = new FormData(); fd.append('upload_preset', UPLOAD_PRESET); fd.append('file', file);
                
                fetch(url, { method: 'POST', body: fd })
                .then(res => res.json())
                .then(data => {
                    resourceProgressEl.classList.add('hidden');
                    resourceBtnEl.classList.remove('hidden');
                    if (data.secure_url) {
                        document.getElementById('resource-file-name').textContent = file.name;
                        
                        // Smart Defaulting: Only set title if user hasn't typed one
                        const titleInput = document.getElementById('resource-title-input');
                        let finalTitle = titleInput.value.trim();
                        if (!finalTitle) {
                            finalTitle = file.name;
                            titleInput.value = file.name;
                        }
                        
                        const resUrlInput = document.getElementById('ResourceUrl');
                        resUrlInput.value = data.secure_url;
                        resUrlInput.dataset.fileSize = data.bytes || 0;
                        resUrlInput.dataset.format = data.format || '';
                        resourceBtnEl.innerHTML = 'Change File';
                        
                        // Auto-save immediately with LATEST values
                        saveResourceMaterial(data.secure_url, finalTitle, data.bytes || 0, data.format || '');
                    }
                })
                .catch(err => {
                    resourceProgressEl.classList.add('hidden');
                    resourceBtnEl.classList.remove('hidden');
                    Swal.fire('Resource Upload Failed', 'An error occurred while uploading your resource.', 'error');
                });
            }
        });
        
        // ─── Disable editing if Pending Review ───
        const currentStatus = '@(ViewBag.CourseStatus as string ?? "Draft")';
        if (currentStatus.toLowerCase() === 'pending') {
            // Disable all inputs, selects and textareas
            document.querySelectorAll('input, select, textarea').forEach(el => {
                el.disabled = true;
                el.classList.add('opacity-70', 'cursor-not-allowed');
            });
            
            // Disable all action buttons
            document.querySelectorAll('button').forEach(el => {
                 const text = el.textContent.trim().toLowerCase();
                 const onclick = el.getAttribute('onclick') || '';
                 
                 // Keep navigation and close buttons functional
                 if (onclick.includes('switchMainTab') || 
                     onclick.includes('selectLesson') || 
                     onclick.includes('closeModal') || 
                     onclick.includes('closeLessonModal') ||
                     onclick.includes('closeVideoModal') ||
                     onclick.includes('closeResourceModal') ||
                     el.classList.contains('text-slate-400')) { // Like back button or close icons
                     return;
                 }
                 
                 // Disable everything else
                 el.disabled = true;
                 el.classList.add('opacity-50', 'cursor-not-allowed');
                 el.style.pointerEvents = 'none';
            });

            // Disable Quill editors
            const disableQuill = (q) => { if (q) q.disable(); };
            setTimeout(() => {
                disableQuill(window.videoQuill);
                disableQuill(window.resourceQuill);
                disableQuill(window.courseDescQuill);
                disableQuill(window.courseLearnQuill);
                disableQuill(window.courseReqQuill);
            }, 500); // Small delay to ensure they are initialized
            
            // Hide specific upload buttons that might not be caught
            const hideEls = ['upload-resource-btn', 'save-course-details-btn', 'save-video-btn', 'save-resource-btn'];
            hideEls.forEach(id => {
                const el = document.getElementById(id);
                if (el) el.classList.add('hidden');
            });
        }
    </script>
}
