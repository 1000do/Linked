@model CourseMarketplaceFE.Models.CreateCourseViewModel
@{
    ViewData["Title"] = "Create New Course";
    Layout = "_InstructorLayout";
}

<div class="p-8 max-w-4xl mx-auto pb-32">
    <a href="/InstructorCourse" class="flex items-center gap-2 text-sm font-semibold text-primary mb-4 hover:underline">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Back to Courses
    </a>
    
    <h1 class="text-3xl font-headline font-extrabold text-slate-900 mb-2">Create New Course</h1>
    <p class="text-slate-500 mb-8">Design a high-impact learning experience for your students.</p>

    <!-- Progress Bar -->
    <div class="flex gap-2 mb-10">
        <div id="step-1" class="h-1 flex-1 bg-primary rounded-full transition-colors duration-300"></div>
        <div id="step-2" class="h-1 flex-1 bg-slate-200 rounded-full transition-colors duration-300"></div>
        <div id="step-3" class="h-1 flex-1 bg-slate-200 rounded-full transition-colors duration-300"></div>
    </div>

    <form method="post" asp-action="Create" id="createCourseForm">
        <input type="hidden" asp-for="CourseThumbnailUrl" id="CourseThumbnailUrl" />
        
        <!-- Section 1: Core Identity -->
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm mb-6">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-primary-container text-primary flex items-center justify-center font-bold text-sm">1</div>
                <h2 class="text-xl font-headline font-bold text-slate-900">Core Identity</h2>
            </div>
            
            <div class="mb-6">
                <label asp-for="Title" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Course Title <span class="text-red-500">*</span></label>
                <input asp-for="Title" placeholder="e.g. Advanced Architectural Principles in Modern UI" class="w-full bg-slate-50 border-none rounded-xl py-4 px-4 text-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-primary/20 outline-none font-medium" />
                <span asp-validation-for="Title" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            
            <div>
                <label asp-for="CategoryId" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Category <span class="text-red-500">*</span></label>
                <div class="relative">
                    <select asp-for="CategoryId" class="w-full bg-slate-50 border border-slate-100 rounded-xl py-4 px-4 pr-10 text-slate-800 focus:ring-2 focus:ring-primary/20 outline-none font-medium appearance-none cursor-pointer transition-all">
                        <option value="0">Select Category</option>
                        @if (Model.AvailableCategories != null)
                        {
                            @foreach (var cat in Model.AvailableCategories)
                            {
                                <option value="@cat.CategoryId">@cat.CategoriesName</option>
                            }
                        }
                    </select>
                    <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
                        <span class="material-symbols-outlined text-slate-400 text-[20px]">unfold_more</span>
                    </div>
                </div>
                <span asp-validation-for="CategoryId" class="text-red-500 text-xs mt-1 block"></span>
            </div>
        </div>

        <!-- Section 2: Course Thumbnail -->
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm mb-6">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-primary-container text-primary flex items-center justify-center font-bold text-sm">2</div>
                <h2 class="text-xl font-headline font-bold text-slate-900">Course Thumbnail</h2>
            </div>
            
            <div id="drop-area" class="border-2 border-dashed border-slate-200 rounded-2xl p-10 text-center hover:bg-slate-50 transition-colors cursor-pointer relative overflow-hidden group">
                <div id="preview-container" class="absolute inset-0 z-10 hidden bg-black">
                    <img id="thumbnail-preview" src="" class="w-full h-full object-cover opacity-80" />
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/40">
                        <span class="px-4 py-2 bg-white text-slate-900 rounded-lg font-bold text-sm">Replace Image</span>
                    </div>
                </div>
                <div class="w-16 h-16 bg-primary-container/30 text-primary rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-[32px]">cloud_upload</span>
                </div>
                <p class="font-bold text-slate-800 mb-2">Drag and drop your thumbnail here <span class="text-red-500">*</span></p>
                <p class="text-xs text-slate-500 mb-4">or <span class="text-primary hover:underline">Browse Files</span></p>
                <input type="file" id="fileElem" accept="image/*" class="hidden" />
                <div id="upload-progress" class="hidden absolute inset-0 bg-white/90 z-20 flex flex-col items-center justify-center">
                    <div class="w-8 h-8 border-4 border-slate-200 border-t-primary rounded-full animate-spin mb-3"></div>
                    <p class="text-sm font-bold text-primary">Uploading to Cloudinary...</p>
                </div>
            </div>
        </div>

        <!-- Section 3: Description & Curriculum -->
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm mb-6">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center font-bold text-sm">3</div>
                <h2 class="text-xl font-headline font-bold text-slate-900">Description & Curriculum</h2>
            </div>
            <label asp-for="Description" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Rich Text Description <span class="text-red-500">*</span></label>
            <div class="bg-white rounded-xl">
                <div id="editor" class="bg-slate-50"></div>
                <input type="hidden" asp-for="Description" id="DescriptionInput" />
            </div>
        </div>

        <!-- Section 3.1: What you will learn -->
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm mb-6">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center font-bold text-sm">3.1</div>
                <h2 class="text-xl font-headline font-bold text-slate-900">What you will learn</h2>
            </div>
            <label asp-for="WhatYouWillLearn" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">What will students achieve?</label>
            <div class="bg-white rounded-xl">
                <div id="learn-editor" class="bg-slate-50"></div>
                <input type="hidden" asp-for="WhatYouWillLearn" id="LearnInput" />
            </div>
        </div>

        <!-- Section 3.2: Requirements -->
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm mb-6">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold text-sm">3.2</div>
                <h2 class="text-xl font-headline font-bold text-slate-900">Requirements</h2>
            </div>
            <label asp-for="Requirements" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">What do students need before starting?</label>
            <div class="bg-white rounded-xl">
                <div id="req-editor" class="bg-slate-50"></div>
                <input type="hidden" asp-for="Requirements" id="ReqInput" />
            </div>
        </div>

        <!-- Section 4: Access & Pricing -->
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm mb-6">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-slate-800 text-white flex items-center justify-center font-bold text-sm">4</div>
                <h2 class="text-xl font-headline font-bold text-slate-900">Access & Pricing</h2>
            </div>

            @{
                var isStripeActive = (bool)(ViewBag.IsStripeActive ?? false);
                var transferRate = (decimal)(ViewBag.TransferRate ?? 70.0m);
                var transferRateStr = transferRate.ToString("0.##");
                var rateMultiplier = (transferRate / 100m).ToString(System.Globalization.CultureInfo.InvariantCulture);
            }

            @if (!isStripeActive)
            {
                <!-- ★ Stripe chưa kích hoạt → Chỉ cho tạo khóa Free -->
                <input type="hidden" asp-for="Price" value="0" />
                <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-xl p-6 mb-4">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-[28px]">lock</span>
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-amber-900 mb-1">Khóa học miễn phí</h3>
                            <p class="text-sm text-amber-700 mb-3">
                                Bạn chưa đăng ký Stripe nên chỉ có thể tạo khóa học <strong>miễn phí (Free)</strong>. 
                                Để bán khóa học có phí, vui lòng đăng ký tài khoản Stripe trước.
                            </p>
                            <a href="/Instructor/Dashboard" 
                               class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-xl shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 text-sm">
                                <span class="material-symbols-outlined text-lg">credit_card</span>
                                Đăng ký Stripe ngay
                            </a>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Course Price (USD)</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 font-bold text-slate-400 material-symbols-outlined text-[18px]">attach_money</span>
                            <input type="text" value="0.00 — Free" disabled class="w-full bg-slate-100 border border-slate-200 rounded-xl py-4 pl-11 pr-4 text-slate-400 font-bold cursor-not-allowed" />
                        </div>
                        <div class="flex flex-wrap gap-2 mt-3">
                            <span class="px-3 py-1.5 text-xs font-bold rounded-lg border border-primary bg-primary/10 text-primary">Free ✓</span>
                            <span class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-slate-100 text-slate-400 cursor-not-allowed" title="Vui lòng đăng ký Stripe để mở khóa">$9.99 🔒</span>
                            <span class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-slate-100 text-slate-400 cursor-not-allowed" title="Vui lòng đăng ký Stripe để mở khóa">$19.99 🔒</span>
                            <span class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-slate-100 text-slate-400 cursor-not-allowed" title="Vui lòng đăng ký Stripe để mở khóa">$49.99 🔒</span>
                        </div>
                    </div>
                    <div class="bg-slate-50 rounded-xl p-4 flex gap-4 border border-slate-100">
                        <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center text-white shrink-0 mt-1">
                            <span class="material-symbols-outlined text-[14px]">info</span>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Instructor Revenue</p>
                            <p class="font-bold text-slate-900 text-lg">Free Course</p>
                            <p class="text-[10px] text-slate-500 mt-1">Đăng ký Stripe để bán khóa học với giá tùy chọn</p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- ✅ Stripe đã kích hoạt → Cho phép đặt giá thoải mái -->
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Price" class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Course Price (USD)</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 font-bold text-slate-500 material-symbols-outlined text-[18px]">attach_money</span>
                            <input asp-for="Price" min="0" step="0.01" placeholder="0.00" class="w-full bg-slate-50 border border-slate-200 rounded-xl py-4 pl-11 pr-4 text-slate-800 font-bold focus:ring-2 focus:ring-primary/20 outline-none transition-colors" onblur="formatPrice(this)" />
                        </div>
                        <!-- Quick Price Tiers -->
                        <div class="flex flex-wrap gap-2 mt-3">
                            <button type="button" onclick="setPrice(0)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">Free</button>
                            <button type="button" onclick="setPrice(9.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$9.99</button>
                            <button type="button" onclick="setPrice(19.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$19.99</button>
                            <button type="button" onclick="setPrice(49.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$49.99</button>
                            <button type="button" onclick="setPrice(99.99)" class="px-3 py-1.5 text-xs font-bold rounded-lg border border-slate-200 bg-white hover:bg-slate-50 text-slate-600 transition-colors">$99.99</button>
                        </div>
                        <span asp-validation-for="Price" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div class="bg-slate-50 rounded-xl p-4 flex gap-4 border border-slate-100">
                        <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center text-white shrink-0 mt-1">
                            <span class="material-symbols-outlined text-[14px]">info</span>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Instructor Revenue</p>
                            <p class="font-bold text-slate-900 text-lg">@transferRateStr% Share</p>
                            <p class="text-[10px] text-slate-500 mt-1">Estimated payout per sale: <span id="payout-estimate">$0.00</span></p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Section 5: Marketing & Promotions -->
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm mb-6">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center font-bold text-sm">5</div>
                <h2 class="text-xl font-headline font-bold text-slate-900">Marketing & Promotions</h2>
            </div>
            
            <!-- Toggle Switch -->
            <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 mb-4 transition-all duration-300 hover:bg-slate-100/50">
                <div class="flex flex-col gap-1">
                    <span class="text-sm font-bold text-slate-800 flex items-center gap-2">
                        <span class="material-symbols-outlined text-emerald-600 text-[18px]">loyalty</span>
                        Áp dụng coupon cho khóa học này
                    </span>
                    <span class="text-[11px] text-slate-500">Giảm giá khóa học bằng mã giảm giá do hệ thống Linked tài trợ</span>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" id="coupon-toggle" class="sr-only peer" />
                    <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                </label>
            </div>

            <input type="hidden" asp-for="CouponId" id="CouponIdInput" />
            
            <!-- Coupon Action Area (hidden by default) -->
            <div id="voucher-action-container" class="hidden space-y-4 animate-in fade-in slide-in-from-top-2 duration-300">
                <!-- Select Button if not selected -->
                <div id="no-voucher-selected-state" class="flex flex-col items-center justify-center p-6 border-2 border-dashed border-slate-200 rounded-2xl bg-slate-50/50">
                    <span class="material-symbols-outlined text-slate-400 text-[32px] mb-2">confirmation_number</span>
                    <p class="text-xs text-slate-505 font-bold mb-4 text-slate-500">Chưa có voucher nào được áp dụng cho khóa học này</p>
                    <button type="button" onclick="openCouponModal()" class="px-5 py-2.5 bg-slate-900 text-white hover:bg-slate-800 text-xs font-black rounded-xl uppercase tracking-widest transition-all active:scale-95 shadow-md flex items-center gap-2">
                        <span class="material-symbols-outlined text-[16px]">add_circle</span>
                        Chọn Voucher từ Hệ thống
                    </button>
                </div>

                <!-- Selected Voucher Card -->
                <div id="voucher-selected-state" class="hidden relative overflow-hidden bg-gradient-to-br from-emerald-500/10 to-teal-500/5 border border-emerald-500/30 rounded-3xl p-6 flex items-center justify-between gap-6 shadow-sm">
                    <div class="flex items-center gap-5">
                        <div class="relative">
                            <div class="absolute inset-0 bg-emerald-400/20 blur-lg rounded-full animate-pulse"></div>
                            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center text-white shadow-lg relative z-10">
                                <span class="material-symbols-outlined text-[30px]">confirmation_number</span>
                            </div>
                        </div>
                        <div>
                            <div class="flex items-center gap-2 mb-0.5">
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping"></span>
                                <p class="text-[9px] font-black text-emerald-600 uppercase tracking-widest">Đang áp dụng</p>
                            </div>
                            <h4 id="display-coupon-code" class="text-lg font-black text-slate-900 tracking-widest font-mono">CODE</h4>
                            <div class="flex items-center gap-3 mt-1.5">
                                <span id="display-coupon-discount" class="px-2.5 py-0.5 bg-emerald-500 text-white text-[9px] font-black rounded-lg uppercase shadow-sm">Giảm 0%</span>
                                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-tight">HSD: <span id="display-coupon-expiry">2026</span></span>
                            </div>
                        </div>
                    </div>
                    <button type="button" onclick="openCouponModal()" class="px-4 py-2 bg-white hover:bg-slate-50 text-slate-700 hover:text-slate-900 text-[10px] font-black rounded-xl uppercase tracking-widest border border-slate-200 transition-all shadow-sm active:scale-95 flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-[14px]">edit</span> Thay đổi
                    </button>
                </div>
            </div>
        </div>

        <!-- Premium Coupon Selection Modal -->
        <div id="coupon-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 transition-all duration-300">
            <!-- Backdrop with deeper blur -->
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-[12px] opacity-0 transition-opacity duration-300 modal-backdrop" onclick="closeCouponModal()"></div>

            <!-- Modal Content -->
            <div class="bg-white/95 w-full max-w-2xl rounded-[2.5rem] shadow-[0_20px_70px_-10px_rgba(0,0,0,0.2)] relative z-10 flex flex-col overflow-hidden border border-white transform scale-90 opacity-0 transition-all duration-500 modal-content">
                <!-- Header with Glass effect -->
                <div class="px-10 py-8 border-b border-slate-100/50 flex justify-between items-center bg-white/50">
                    <div class="flex items-center gap-5">
                        <div class="w-14 h-14 rounded-2xl bg-slate-900 text-white flex items-center justify-center shadow-2xl shadow-slate-200">
                            <span class="material-symbols-outlined text-[32px]">auto_awesome</span>
                        </div>
                        <div>
                            <h3 class="text-2xl font-black text-slate-900 tracking-tight">Voucher Siêu Cấp</h3>
                            <p class="text-[11px] font-bold text-slate-400 mt-1 uppercase tracking-[0.2em] flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                                Cập nhật từ hệ thống Linked
                            </p>
                        </div>
                    </div>
                    <button type="button" onclick="closeCouponModal()" class="w-12 h-12 flex items-center justify-center rounded-2xl text-slate-400 hover:text-rose-500 hover:bg-rose-50 transition-all duration-300">
                        <span class="material-symbols-outlined text-[28px]">close</span>
                    </button>
                </div>

                <!-- Body -->
                <div class="p-10 max-h-[50vh] overflow-y-auto custom-scrollbar bg-slate-50/30">
                    <div id="coupon-list-container" class="grid grid-cols-1 gap-6">
                        <!-- Data populated by JS -->
                        <div class="flex flex-col items-center justify-center py-20 gap-4">
                            <div class="relative">
                                <div class="w-12 h-12 border-4 border-slate-100 border-t-primary rounded-full animate-spin"></div>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <div class="w-2 h-2 bg-primary rounded-full"></div>
                                </div>
                            </div>
                            <p class="text-xs font-black text-slate-400 uppercase tracking-widest">Đang săn tìm Voucher...</p>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="px-10 py-8 bg-white border-t border-slate-100 flex justify-between items-center">
                    <div class="flex flex-col gap-1">
                        <p class="text-[10px] font-black text-slate-900 uppercase tracking-widest">Trợ giúp Marketing</p>
                        <p class="text-[11px] font-medium text-slate-400">Chọn mã có tỉ lệ giảm cao nhất để thu hút học viên.</p>
                    </div>
                    <button type="button" onclick="closeCouponModal()" class="px-8 py-3.5 text-xs font-black text-white bg-slate-900 rounded-2xl hover:bg-slate-800 transition-all shadow-xl shadow-slate-200 active:scale-95 uppercase tracking-widest">
                        Đã hiểu
                    </button>
                </div>
            </div>
        </div>

        <style>
            .custom-scrollbar::-webkit-scrollbar { width: 6px; }
            .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
            .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
            .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
            
            #coupon-modal.modal-visible { display: flex !important; }
            #coupon-modal.modal-visible .modal-backdrop { opacity: 1; }
            #coupon-modal.modal-visible .modal-content { transform: scale(1); opacity: 1; }

            /* Voucher Card Styling */
            .voucher-card-glass {
                background: rgba(255, 255, 255, 0.8);
                backdrop-filter: blur(8px);
                border: 1px solid rgba(255, 255, 255, 0.5);
            }
        </style>
    </form>
</div>

<!-- Floating Action Bar -->
<div class="fixed bottom-0 left-64 right-0 bg-white/80 backdrop-blur-md border-t border-slate-200 p-4 z-50">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-2 text-sm text-slate-500">
            <span id="save-indicator" class="w-2 h-2 rounded-full bg-slate-300"></span>
            <span id="save-status">Not saved yet</span>
        </div>
        <div class="flex items-center gap-4">
            <a href="/InstructorCourse" class="px-6 py-2.5 bg-slate-200 text-slate-700 font-bold rounded-lg hover:bg-slate-300 transition-colors">Cancel</a>
            <button type="submit" form="createCourseForm" class="px-6 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-secondary transition-colors shadow-lg shadow-primary/20">Create Course</button>
        </div>
    </div>
</div>

@section Scripts {
    @if (ViewBag.ApiError != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                var errorData = @Html.Raw(Json.Serialize(ViewBag.ApiError));
                var message = errorData;
                
                try {
                    var json = JSON.parse(errorData);
                    message = json.message || errorData;
                } catch(e) {}

                Swal.fire({
                    title: 'Lỗi từ hệ thống',
                    text: message,
                    icon: 'error',
                    confirmButtonColor: '#006a62'
                });
            });
        </script>
    }
    <script>
        // Quill
        var quill = new Quill('#editor', {
            theme: 'snow', placeholder: 'Tell your students what they will achieve...',
            modules: { toolbar: [['bold','italic'],[{'list':'ordered'},{'list':'bullet'}],['link','code-block']] }
        });
        const descriptionInput = document.getElementById('DescriptionInput');
        if(descriptionInput.value) quill.clipboard.dangerouslyPasteHTML(descriptionInput.value);

        var learnQuill = new Quill('#learn-editor', {
            theme: 'snow', placeholder: 'What will students achieve?',
            modules: { toolbar: [['bold','italic'],[{'list':'ordered'},{'list':'bullet'}]] }
        });
        const learnInput = document.getElementById('LearnInput');
        if(learnInput.value) learnQuill.clipboard.dangerouslyPasteHTML(learnInput.value);

        var reqQuill = new Quill('#req-editor', {
            theme: 'snow', placeholder: 'What do students need before starting?',
            modules: { toolbar: [['bold','italic'],[{'list':'ordered'},{'list':'bullet'}]] }
        });
        const reqInput = document.getElementById('ReqInput');
        if(reqInput.value) reqQuill.clipboard.dangerouslyPasteHTML(reqInput.value);

        // Show validation summary if it has content
        const valSummary = document.querySelector('[data-valmsg-summary]') || document.querySelector('.text-red-500.bg-red-50');
        if (valSummary && valSummary.querySelector('li')) valSummary.style.display = 'block';

        // Sync Quill + submit with validation
        document.getElementById('createCourseForm').addEventListener('submit', function(e) {
            const html = quill.root.innerHTML;
            const learnHtml = learnQuill.root.innerHTML;
            const reqHtml = reqQuill.root.innerHTML;

            const title = document.getElementById('Title').value;
            const catId = document.getElementById('CategoryId').value;
            const thumb = document.getElementById('CourseThumbnailUrl').value;
            const desc = (html === '<p><br></p>') ? '' : html;
            
            descriptionInput.value = desc;
            learnInput.value = (learnHtml === '<p><br></p>') ? '' : learnHtml;
            reqInput.value = (reqHtml === '<p><br></p>') ? '' : reqHtml;

            // CLIENT-SIDE VALIDATION
            let errors = [];
            if (!title || title.trim() === '') errors.push("Tiêu đề khóa học");
            if (!catId || catId === '0') errors.push("Danh mục");
            if (!thumb || thumb === '') errors.push("Ảnh đại diện (Thumbnail)");
            if (!desc || desc.trim() === '') errors.push("Mô tả khóa học");

            if (errors.length > 0) {
                e.preventDefault(); // Stop form submission
                Swal.fire({
                    title: 'Thông tin chưa đầy đủ',
                    html: `<div class="text-left">Vui lòng hoàn thiện các mục sau:<ul class="list-disc ml-6 mt-2 text-red-600 font-semibold">${errors.map(err => `<li>${err}</li>`).join('')}</ul></div>`,
                    icon: 'warning',
                    confirmButtonColor: '#006a62'
                });
            }
        });

        // Progress bar
        function updateProgressBar() {
            const title = document.getElementById('Title').value.trim();
            const catId = document.getElementById('CategoryId').value;
            const thumb = document.getElementById('CourseThumbnailUrl').value;
            const desc = quill.getText().trim();
            const price = document.getElementById('Price').value;
            const s1 = title.length > 0 && catId !== '0';
            const s2 = thumb.length > 0;
            document.getElementById('step-2').className = 'h-1 flex-1 rounded-full transition-colors duration-300 ' + (s1 ? 'bg-primary' : 'bg-slate-200');
            document.getElementById('step-3').className = 'h-1 flex-1 rounded-full transition-colors duration-300 ' + (s1 && s2 ? 'bg-primary' : 'bg-slate-200');
        }
        ['Title','CategoryId','Price'].forEach(id => { const el = document.getElementById(id); if(el) { el.addEventListener('input', updateProgressBar); el.addEventListener('change', updateProgressBar); } });
        quill.on('text-change', updateProgressBar);
        learnQuill.on('text-change', updateProgressBar);
        reqQuill.on('text-change', updateProgressBar);

        // Cloudinary Upload
        const CLOUD_NAME = 'df8i0azc5';
        const UPLOAD_PRESET = 'course_marketplace_preset';
        const dropArea = document.getElementById('drop-area');
        const fileInput = document.getElementById('fileElem');
        const progressEl = document.getElementById('upload-progress');
        const previewContainer = document.getElementById('preview-container');
        const thumbnailPreview = document.getElementById('thumbnail-preview');
        const urlInput = document.getElementById('CourseThumbnailUrl');

        ['dragenter','dragover','dragleave','drop'].forEach(e => dropArea.addEventListener(e, ev => { ev.preventDefault(); ev.stopPropagation(); }, false));
        ['dragenter','dragover'].forEach(e => dropArea.addEventListener(e, () => dropArea.classList.add('border-primary','bg-primary/5'), false));
        ['dragleave','drop'].forEach(e => dropArea.addEventListener(e, () => dropArea.classList.remove('border-primary','bg-primary/5'), false));
        dropArea.addEventListener('drop', e => handleFiles(e.dataTransfer.files), false);
        dropArea.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', function() { handleFiles(this.files); });

        function handleFiles(files) { if (files.length > 0) uploadFile(files[0]); }
        function uploadFile(file) {
            if (!file.type.startsWith('image/')) { alert('Please select an image file.'); return; }
            progressEl.classList.remove('hidden');
            const fd = new FormData();
            fd.append('upload_preset', UPLOAD_PRESET); fd.append('file', file);
            fetch(`https://api.cloudinary.com/v1_1/${CLOUD_NAME}/upload`, { method: 'POST', body: fd })
            .then(r => { if(!r.ok) throw new Error('Upload failed'); return r.json(); })
            .then(data => {
                progressEl.classList.add('hidden'); urlInput.value = data.secure_url;
                thumbnailPreview.src = data.secure_url; previewContainer.classList.remove('hidden');
                updateProgressBar();
            })
            .catch(() => {
                progressEl.classList.add('hidden');
                const reader = new FileReader();
                reader.onload = e => { thumbnailPreview.src = e.target.result; previewContainer.classList.remove('hidden'); urlInput.value = e.target.result; updateProgressBar(); };
                reader.readAsDataURL(file);
            });
        }

        // Price calc and formatting
        const priceInput = document.getElementById('Price');
        const payoutEstimateEl = document.getElementById('payout-estimate');
        const transferRateMultiplier = @((((decimal)(ViewBag.TransferRate ?? 70.0m)) / 100m).ToString(System.Globalization.CultureInfo.InvariantCulture));
        
        function updatePayout(val) {
            if (payoutEstimateEl) {
                payoutEstimateEl.textContent = '$' + ((parseFloat(val)||0) * transferRateMultiplier).toFixed(2);
            }
        }

        window.formatPrice = function(input) {
            if (!input || !input.value) { if(input) input.value = "0.00"; return; }
            let val = parseFloat(input.value);
            if (isNaN(val) || val < 0) val = 0;
            input.value = val.toFixed(2);
            updatePayout(val);
        };

        window.setPrice = function(price) {
            if (priceInput) {
                priceInput.value = parseFloat(price).toFixed(2);
                priceInput.classList.add('ring-2', 'ring-primary', 'bg-primary/5');
                setTimeout(() => priceInput.classList.remove('ring-2', 'ring-primary', 'bg-primary/5'), 500);
                updatePayout(priceInput.value);
                updateProgressBar();
            }
        };

        if(priceInput) {
            priceInput.addEventListener('input', e => updatePayout(e.target.value));
            // Format on init if there's a value
            if (priceInput.value) formatPrice(priceInput);
        }
        updateProgressBar();

        // ─── LOAD AND SELECT PLATFORM COUPONS ───
        const couponToggle = document.getElementById('coupon-toggle');
        const voucherActionContainer = document.getElementById('voucher-action-container');
        const couponInput = document.getElementById('CouponIdInput');

        // Modal triggers
        window.openCouponModal = function() {
            const modal = document.getElementById('coupon-modal');
            if (!modal) return;
            modal.classList.remove('hidden');
            modal.style.display = 'flex';
            modal.offsetHeight; // force reflow
            modal.classList.add('modal-visible');
            loadPlatformCoupons();
        };

        window.closeCouponModal = function() {
            const modal = document.getElementById('coupon-modal');
            if (!modal) return;
            modal.classList.remove('modal-visible');
            setTimeout(() => { 
                modal.classList.add('hidden'); 
                modal.style.display = ''; 
            }, 300);
        };

        async function loadPlatformCoupons() {
            const container = document.getElementById('coupon-list-container');
            if (!container) return;
            container.innerHTML = `
                <div class="flex flex-col items-center justify-center py-20 gap-4">
                    <div class="w-10 h-10 border-4 border-slate-100 border-t-primary rounded-full animate-spin"></div>
                    <p class="text-xs font-black text-slate-400 uppercase tracking-widest">Đang săn tìm Voucher...</p>
                </div>
            `;
            
            try {
                const res = await fetch('/Coupon/PlatformActive');
                const result = await res.json();
                
                if (result.success && result.data && result.data.length > 0) {
                    container.innerHTML = result.data.map(c => {
                        const discountText = c.couponType === 'percentage' ? `${c.discountValue}%` : `$${c.discountValue}`;
                        const expiryText = c.endDate ? new Date(c.endDate).toLocaleDateString('vi-VN') : 'Vĩnh viễn';
                        const isCurrent = couponInput.value === String(c.couponId);
                        
                        return `
                            <div class="group relative overflow-hidden rounded-[2rem] p-6 border-2 ${isCurrent ? 'border-emerald-500 bg-emerald-50/30' : 'border-slate-100 bg-white'} hover:border-emerald-500/40 hover:shadow-2xl hover:shadow-emerald-500/5 transition-all duration-500">
                                ${isCurrent ? '<div class="absolute top-0 right-0 bg-emerald-500 text-white text-[8px] font-black px-4 py-1.5 rounded-bl-xl uppercase tracking-widest">Đang chọn</div>' : ''}
                                
                                <div class="flex items-center justify-between gap-6">
                                    <div class="flex items-center gap-5">
                                        <div class="w-16 h-16 rounded-2xl ${isCurrent ? 'bg-emerald-500' : 'bg-slate-900'} text-white flex flex-col items-center justify-center group-hover:bg-emerald-500 transition-all duration-500 shadow-lg shadow-slate-200">
                                            <span class="text-xl font-black leading-none">${discountText}</span>
                                            <span class="text-[9px] font-bold uppercase opacity-60 mt-1">OFF</span>
                                        </div>
                                        <div>
                                            <h4 class="text-lg font-black text-slate-900 tracking-widest font-mono">${c.couponCode}</h4>
                                            <div class="flex items-center gap-2 mt-1.5">
                                                <span class="material-symbols-outlined text-slate-300 text-[14px]">event_available</span>
                                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">Hết hạn: ${expiryText}</p>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    ${isCurrent ? `
                                        <div class="flex items-center gap-2 px-4 py-2.5 bg-emerald-100 text-emerald-600 rounded-xl font-black text-[10px] uppercase tracking-widest">
                                            <span class="material-symbols-outlined text-[16px]">check_circle</span> Đã chọn
                                        </div>
                                    ` : `
                                        <button type="button" onclick="selectPlatformCoupon(${c.couponId}, '${c.couponCode}', 'Giảm ${discountText}', '${expiryText}')" class="px-6 py-3 bg-slate-900 text-white hover:bg-emerald-500 text-[10px] font-black rounded-xl uppercase tracking-widest transition-all duration-300 active:scale-95 shadow-lg shadow-slate-200 hover:shadow-emerald-500/20 shrink-0">Áp dụng</button>
                                    `}
                                </div>
                            </div>
                        `;
                    }).join('');
                } else {
                    container.innerHTML = '<div class="col-span-full py-12 text-center text-slate-400 font-bold text-sm bg-slate-50 border border-slate-100 rounded-2xl">Hiện tại không có voucher nào khả dụng.</div>';
                }
            } catch (err) {
                console.error(err);
                container.innerHTML = '<div class="col-span-full py-8 text-center text-rose-500 font-bold text-sm bg-rose-50 border border-rose-100 rounded-2xl">Lỗi hệ thống khi tải danh sách voucher.</div>';
            }
        }

        window.selectPlatformCoupon = function(id, code, discount, expiry) {
            couponInput.value = id;
            
            // Update main view preview
            document.getElementById('display-coupon-code').textContent = code;
            document.getElementById('display-coupon-discount').textContent = discount;
            document.getElementById('display-coupon-expiry').textContent = expiry;
            
            // Switch views
            document.getElementById('no-voucher-selected-state').classList.add('hidden');
            document.getElementById('voucher-selected-state').classList.remove('hidden');
            
            closeCouponModal();
        };

        couponToggle.addEventListener('change', function() {
            if (this.checked) {
                voucherActionContainer.classList.remove('hidden');
            } else {
                voucherActionContainer.classList.add('hidden');
                // Hủy chọn coupon
                couponInput.value = '';
                document.getElementById('no-voucher-selected-state').classList.remove('hidden');
                document.getElementById('voucher-selected-state').classList.add('hidden');
            }
        });

    </script>
}
