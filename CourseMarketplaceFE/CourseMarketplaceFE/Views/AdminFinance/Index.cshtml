                                            <span class="font-mono text-xs text-slate-500 font-bold">#@w.WithdrawalId</span>
                                            @if (!string.IsNullOrEmpty(w.ManagerName))
                                            {
                                                <span class="text-[10px] text-slate-400 font-semibold mt-0.5">Manager: @w.ManagerName</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-4 py-4.5 align-middle">
                                        <span class="text-sm font-black text-rose-700 tracking-tight font-black">$@w.Amount.ToString("N2")</span>
                                    </td>
                                    <td class="px-4 py-4.5 align-middle">
                                        @if (w.Status == "paid")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-emerald-50 text-emerald-700 border border-emerald-100/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5">
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                                Paid
                                            </span>
                                        }
                                        else if (w.Status == "in_transit")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-blue-50 text-blue-700 border border-blue-100/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5 animate-pulse">
                                                <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                                                In Transit
                                            </span>
                                        }
                                        else if (w.Status == "pending")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-amber-50 text-amber-800 border border-amber-100/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5">
                                                <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
                                                Pending
                                            </span>
                                        }
                                        else if (w.Status == "failed")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-red-50 text-red-700 border border-red-100/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5">
                                                <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                                                Failed
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-slate-50 text-slate-600 border border-slate-200/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5">
                                                <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                                                Canceled
                                            </span>
                                        }
                                    </td>
                                    <td class="pl-4 pr-6 py-4.5 align-middle">
                                        <div class="flex flex-col">
                                            <span class="text-slate-900 font-bold text-xs">@w.CreatedAt.ToString("dd/MM/yyyy")</span>
                                            <span class="text-[10px] text-slate-400 font-semibold mt-0.5">@w.CreatedAt.ToString("HH:mm")</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Withdrawals.TotalPages > 1)
            {
                <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between bg-slate-50/30">
                    <p class="text-xs font-semibold text-slate-500">
                        Showing <span class="font-bold text-slate-800">@((Model.Withdrawals.Page - 1) * Model.Withdrawals.PageSize + 1)</span> – <span class="font-bold text-slate-800">@Math.Min(Model.Withdrawals.Page * Model.Withdrawals.PageSize, Model.Withdrawals.TotalCount)</span> of <span class="font-bold text-slate-800">@Model.Withdrawals.TotalCount</span>
                    </p>
                    <div class="flex items-center gap-1.5">
                        @if (Model.Withdrawals.Page > 1)
                        {
                            <a href="@Url.Action("Index", new { page = Model.Transactions.Page, pageSize = Model.Transactions.PageSize, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status, tab = "wd", year = ViewBag.Year, month = ViewBag.Month, payoutPage = ViewBag.PayoutPage, withdrawPage = Model.Withdrawals.Page - 1 })"
                               class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200/80 text-slate-500 hover:bg-white hover:text-slate-800 transition-all shadow-sm/5">
                                <span class="material-symbols-outlined text-[16px]">chevron_left</span>
