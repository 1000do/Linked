                        {
                            @foreach (var item in Model.PendingRefunds)
                            {
                                <tr class="hover:bg-slate-50/50 transition-colors group">
                                    <td class="px-5 py-3.5 font-mono text-xs text-slate-400">#@item.TransactionId</td>
                                    <td class="px-5 py-3.5 max-w-[200px]">
                                        <span class="font-medium text-slate-800 truncate block font-bold" title="@item.CourseTitle">@item.CourseTitle</span>
                                    </td>
                                    <td class="px-5 py-3.5 text-slate-600 font-medium">@item.BuyerName</td>
                                    <td class="px-5 py-3.5 text-right font-black text-slate-800">
                                        @((item.Currency ?? "USD").ToUpper()) @item.Amount.ToString("N2")
                                    </td>
                                    <td class="px-5 py-3.5 text-slate-500 text-xs whitespace-nowrap">
                                        @(item.TransactionCreatedAt.HasValue ? item.TransactionCreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "—")
                                    </td>
                                    <td class="px-5 py-3.5 text-slate-500 text-xs whitespace-nowrap">
                                        @(item.RefundRequestedAt.HasValue ? item.RefundRequestedAt.Value.ToString("dd/MM/yyyy HH:mm") : "—")
                                    </td>
                                    <td class="px-5 py-3.5 max-w-[250px]">
                                        <span class="text-xs text-slate-600 line-clamp-2 bg-slate-50 p-2 rounded-lg border border-slate-100" title="@item.RefundReason">@item.RefundReason</span>
                                    </td>
                                    <td class="px-5 py-3.5 text-center whitespace-nowrap">
                                        <div class="inline-flex items-center gap-2">
                                            <a href="@Url.Action("Detail", "Transaction", new { id = item.TransactionId })"
                                               class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-50 hover:bg-indigo-50 text-slate-600 hover:text-indigo-600 font-bold text-xs rounded-xl border border-slate-100 hover:border-indigo-200 transition-all shadow-sm active:scale-95">
                                                <span class="material-symbols-outlined text-[16px]">visibility</span>
                                                Details
                                            </a>
                                            <button type="button" 
                                                    onclick="approveRefund(@item.TransactionId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(item.CourseTitle))')"
                                                    class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-50 hover:bg-emerald-100 text-emerald-600 hover:text-emerald-700 font-bold text-xs rounded-xl border border-emerald-100 hover:border-emerald-200 transition-all shadow-sm active:scale-95">
                                                <span class="material-symbols-outlined text-[16px]">check_circle</span>
                                                Approve
                                            </button>
                                            <button type="button" 
                                                    onclick="rejectRefund(@item.TransactionId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(item.CourseTitle))')"
                                                    class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-rose-50 hover:bg-rose-100 text-rose-600 hover:text-rose-700 font-bold text-xs rounded-xl border border-rose-100 hover:border-rose-200 transition-all shadow-sm active:scale-95">
                                                <span class="material-symbols-outlined text-[16px]">cancel</span>
                                                Reject
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="px-5 py-14 text-center">
                                    <div class="flex flex-col items-center justify-center text-slate-400">
                                        <span class="material-symbols-outlined text-5xl mb-3 text-slate-200">restart_alt</span>
                                        <p class="text-sm font-medium text-slate-500">No pending refund requests.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        function switchTab(tabId) {
            document.querySelectorAll('[id^="tab-content-"]').forEach(el => el.classList.add('hidden'));
            document.getElementById('tab-content-' + tabId).classList.remove('hidden');

            document.querySelectorAll('[id^="tab-btn-"]').forEach(btn => {
                btn.className = 'whitespace-nowrap flex-1 xl:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold text-slate-500 hover:text-slate-800 transition-all duration-300';
            });
            const activeBtn = document.getElementById('tab-btn-' + tabId);
            if(tabId === 'tx') {
                activeBtn.className = 'whitespace-nowrap flex-1 xl:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold bg-white text-indigo-600 shadow-sm transition-all duration-300';
            } else if(tabId === 'po') {
                activeBtn.className = 'whitespace-nowrap flex-1 xl:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold bg-white text-emerald-600 shadow-sm transition-all duration-300';
            } else if(tabId === 'wd') {
                activeBtn.className = 'whitespace-nowrap flex-1 xl:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold bg-white text-rose-600 shadow-sm transition-all duration-300';
            } else if(tabId === 'rf') {
                activeBtn.className = 'whitespace-nowrap flex-1 xl:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold bg-white text-orange-600 shadow-sm transition-all duration-300';
            }

            document.querySelectorAll('[id^="tab-ind-"]').forEach(ind => ind.classList.add('hidden'));
            document.getElementById('tab-ind-' + tabId).classList.remove('hidden');
        }

        // SIGNALR Tự động Reload
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("http://localhost:5207/financeHub")
            .withAutomaticReconnect()
            .build();

        connection.on("UpdatePayoutStatus", function (data) {
            setTimeout(() => {
                window.location.reload();
            }, 1500);
        });

        connection.start()
            .then(function () {
                connection.invoke("JoinAdminGroup").catch(err => console.error(err));
            })
            .catch(err => console.error("❌ SignalR Error: ", err));

        async function handleWithdrawSubmit(event) {
            event.preventDefault();
            const form = event.target;
            const amount = document.getElementById('withdraw-amount').value;

            const confirmResult = await Swal.fire({
                title: 'Confirm Withdrawal',
                html: `Are you absolutely sure you want to withdraw <b class="text-emerald-600">$${amount}</b> from the Stripe balance to your corporate bank account?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Confirm & Initiate',
                cancelButtonText: 'Cancel',
                background: '#ffffff',
                customClass: {
                    popup: 'rounded-2xl border border-slate-100 shadow-xl'
                }
            });

            if (confirmResult.isConfirmed) {
                form.submit();
            }
        }

        async function handleStripePaySubmit(event) {
            event.preventDefault();
            const form = event.target;

            const confirmResult = await Swal.fire({
                title: 'Confirm Stripe Connect Transfer',
                text: 'Are you absolutely sure you want to execute a REAL-MONEY bank transfer via the Stripe Connected Account API to this Instructor?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#ef4444',
                confirmButtonText: 'Execute Payout',
                cancelButtonText: 'Cancel',
                background: '#ffffff',
                customClass: {
                    popup: 'rounded-2xl border border-slate-100 shadow-xl'
                }
            });

            if (confirmResult.isConfirmed) {
                form.submit();
            }
        }

        // AJAX Dynamic Month/Year Dropdown Loading
        document.addEventListener('DOMContentLoaded', () => {
            const filterForm = document.getElementById('periodFilterForm');
            if (filterForm) {
                const selects = filterForm.querySelectorAll('select');
                selects.forEach(select => {
                    select.addEventListener('change', () => {
                        ajaxReloadAdmin();
                    });
                });
                filterForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    ajaxReloadAdmin();
                });
            }
        });

        async function ajaxReloadAdmin() {
            const form = document.getElementById('periodFilterForm');
            if (!form) return;

            // Show a premium blurred loading overlay
            const loader = document.createElement('div');
            loader.className = 'fixed inset-0 bg-slate-900/10 backdrop-blur-[1px] flex items-center justify-center z-[9999] transition-all duration-300 opacity-0';
            loader.innerHTML = `
                <div class="bg-white p-4 rounded-2xl shadow-xl flex items-center gap-3 border border-slate-100 animate-fadeIn">
                    <div class="w-6 h-6 border-2 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>
                    <span class="text-xs font-bold text-slate-700">Recalculating monthly financials...</span>
                </div>
            `;
            document.body.appendChild(loader);
            setTimeout(() => loader.classList.remove('opacity-0'), 50);

            try {
                const formData = new FormData(form);
                const params = new URLSearchParams(formData);

                // Preserve active tab
                const activeBtn = document.querySelector('[id^="tab-btn-"].bg-white');
                const activeTab = activeBtn ? activeBtn.id.replace('tab-btn-', '') : 'tx';
                params.set('tab', activeTab);

                // Preserve search keywords/filters if present
                const searchForm = document.querySelector('form[action="/AdminFinance"]:not(#periodFilterForm)');
                if (searchForm) {
                    const searchData = new FormData(searchForm);
                    for (const [key, value] of searchData.entries()) {
                        if (value && key !== 'year' && key !== 'month' && key !== 'tab') {
                            params.set(key, value);
                        }
                    }
                }

                const url = `/AdminFinance?${params.toString()}`;
                const response = await fetch(url);
                if (response.ok) {
                    const html = await response.text();
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');

                    // 1. Swap Stats Overview Cards using robust ID
                    const oldStats = document.getElementById('stats-overview');
                    const newStats = doc.getElementById('stats-overview');
                    if (oldStats && newStats) oldStats.innerHTML = newStats.innerHTML;

                    // 2. Swap Stripe Balances Cards using robust ID
                    const oldStripe = document.getElementById('stripe-balances');
                    const newStripe = doc.getElementById('stripe-balances');
                    if (oldStripe && newStripe) oldStripe.innerHTML = newStripe.innerHTML;

                    // 3. Swap All Tab Contents to keep them synchronized
                    ['tx', 'po', 'wd', 'rf'].forEach(t => {
                        const oldTabContent = document.getElementById('tab-content-' + t);
                        const newTabContent = doc.getElementById('tab-content-' + t);
                        if (oldTabContent && newTabContent) oldTabContent.innerHTML = newTabContent.innerHTML;
                    });

                    // 4. Swap Badge Counters
                    ['tx', 'po', 'wd', 'rf'].forEach(t => {
                        const oldInd = document.getElementById('tab-ind-' + t);
                        const newInd = doc.getElementById('tab-ind-' + t);
                        if (oldInd && newInd) oldInd.innerHTML = newInd.innerHTML;
                    });

                    // 5. Update Year/Month inside all hidden forms
                    const targetYear = params.get('year');
                    const targetMonth = params.get('month');
                    document.querySelectorAll('form input[name="year"]').forEach(input => {
                        input.value = targetYear;
                    });
                    document.querySelectorAll('form input[name="month"]').forEach(input => {
                        input.value = targetMonth;
                    });

                    // Push states
                    history.pushState(null, '', url);

                    // Alert Toast
                    const Toast = Swal.mixin({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 1500,
                        timerProgressBar: true
                    });
                    Toast.fire({
                        icon: 'success',
                        title: 'Financial data updated successfully'
                    });
                }
            } catch (err) {
                console.error("AJAX error: ", err);
            } finally {
                loader.classList.add('opacity-0');
                setTimeout(() => loader.remove(), 300);
            }
        }

        document.getElementById('syncAllForm')?.addEventListener('submit', function() {
            const btn = document.getElementById('syncAllBtn');
            const icon = document.getElementById('syncAllIcon');
            if (btn && icon) {
                btn.disabled = true;
                btn.classList.add('opacity-50', 'cursor-not-allowed');
                icon.classList.add('animate-spin');
                btn.innerHTML = `<span id="syncAllIcon" class="material-symbols-outlined text-[16px] animate-spin mr-1">sync</span> Syncing...`;
            }
        });

        function approveRefund(transactionId, courseTitle) {
            Swal.fire({
                title: 'Approve Refund',
                html: `<div class="text-left font-sans">
                        <p class="text-sm text-slate-500 mb-4">Are you sure you want to approve the refund for the course <strong>${courseTitle}</strong>? 
                        The system will refund the student via Stripe Connect and revoke their learning access to this course.</p>
                       </div>`,
                input: 'textarea',
                inputPlaceholder: 'Enter feedback note for student (optional)...',
                showCancelButton: true,
                confirmButtonText: 'Approve & Refund',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#64748b',
                buttonsStyling: true,
                customClass: {
                    popup: 'rounded-3xl border border-slate-100 p-8 shadow-2xl',
                    title: 'text-xl font-black text-slate-900 tracking-tight',
                    confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all',
                    cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                },
                showLoaderOnConfirm: true,
                preConfirm: (adminNote) => {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const params = new URLSearchParams();
                    params.append('transactionId', transactionId);
                    params.append('adminNote', adminNote || '');

                    return fetch('/AdminFinance/ApproveRefundDecision', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: params
                    })
                    .then(response => {
                        return response.json().then(data => {
                            if (!response.ok || !data.success) {
                                throw new Error(data.message || response.statusText);
                            }
                            return data;
                        });
                    })
                    .catch(error => {
                        Swal.showValidationMessage(`Action failed: ${error.message}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Success!',
                        text: result.value.message,
                        icon: 'success',
                        confirmButtonText: 'Close',
                        confirmButtonColor: '#10b981',
                        customClass: {
                            popup: 'rounded-3xl',
                            title: 'text-xl font-black text-slate-900',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm'
                        }
                    }).then(() => {
                        window.location.href = '/AdminFinance?tab=rf';
                    });
                }
            });
        }

        function rejectRefund(transactionId, courseTitle) {
            Swal.fire({
                title: 'Reject Refund',
                html: `<div class="text-left font-sans">
                        <p class="text-sm text-slate-500 mb-4">You are rejecting the refund request for the course <strong>${courseTitle}</strong>. 
                        You must enter a specific reason to respond to the student.</p>
                       </div>`,
                input: 'textarea',
                inputPlaceholder: 'Enter rejection reason here...',
                showCancelButton: true,
                confirmButtonText: 'Reject Request',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#e11d48',
                cancelButtonColor: '#64748b',
                buttonsStyling: true,
                customClass: {
                    popup: 'rounded-3xl border border-slate-100 p-8 shadow-2xl',
                    title: 'text-xl font-black text-slate-900 tracking-tight',
                    confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all',
                    cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                },
                inputValidator: (value) => {
                    if (!value || value.trim() === '') {
                        return 'You must enter a rejection reason!';
                    }
                },
                showLoaderOnConfirm: true,
                preConfirm: (adminNote) => {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const params = new URLSearchParams();
                    params.append('transactionId', transactionId);
                    params.append('adminNote', adminNote);

                    return fetch('/AdminFinance/RejectRefundDecision', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: params
                    })
                    .then(response => {
                        return response.json().then(data => {
                            if (!response.ok || !data.success) {
                                throw new Error(data.message || response.statusText);
                            }
                            return data;
                        });
                    })
                    .catch(error => {
                        Swal.showValidationMessage(`Action failed: ${error.message}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Rejected!',
                        text: result.value.message,
                        icon: 'warning',
                        confirmButtonText: 'Close',
                        confirmButtonColor: '#64748b',
                        customClass: {
                            popup: 'rounded-3xl',
                            title: 'text-xl font-black text-slate-900',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm'
                        }
                    }).then(() => {
                        window.location.href = '/AdminFinance?tab=rf';
                    });
                }
            });
        }
    </script>
}
