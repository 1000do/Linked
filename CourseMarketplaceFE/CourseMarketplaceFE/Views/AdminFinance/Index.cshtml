                            {
                                <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-rose-600 text-white font-extrabold text-xs shadow-md shadow-rose-600/10">@p</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Index", new { page = Model.Transactions.Page, pageSize = Model.Transactions.PageSize, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status, tab = "wd", year = ViewBag.Year, month = ViewBag.Month, payoutPage = ViewBag.PayoutPage, withdrawPage = p })"
                                   class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200/80 text-slate-600 hover:bg-white hover:text-slate-800 font-bold text-xs transition-all shadow-sm/5 font-bold font-bold">@p</a>
                            }
                        }

                        @if (Model.Withdrawals.Page < Model.Withdrawals.TotalPages)
                        {
                            <a href="@Url.Action("Index", new { page = Model.Transactions.Page, pageSize = Model.Transactions.PageSize, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status, tab = "wd", year = ViewBag.Year, month = ViewBag.Month, payoutPage = ViewBag.PayoutPage, withdrawPage = Model.Withdrawals.Page + 1 })"
                               class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200/80 text-slate-500 hover:bg-white hover:text-slate-800 transition-all shadow-sm/5 font-bold">
                                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- TAB 4: Yêu cầu hoàn tiền (RF) -->
        <div id="tab-content-rf" class="flex flex-col animate-fadeIn @(ViewBag.ActiveTab == "rf" ? "" : "hidden")">
            <div class="px-5 py-4 border-b border-slate-200 bg-white">
                <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2">
                    <span class="material-symbols-outlined text-orange-500">pending_actions</span>
                    Pending Refund Requests
                </h3>
                <p class="text-xs text-slate-500 mt-1">Refund requests submitted by students within 14 days of purchase. You can approve (refund via Stripe & revoke course access) or reject the request.</p>
            </div>

            <div class="overflow-x-auto max-h-[600px] flex-1">
                <table class="w-full text-left border-collapse">
                    <thead class="text-[10px] text-slate-500 bg-slate-50 border-b border-slate-200 uppercase font-bold sticky top-0 z-10 shadow-sm">
                        <tr>
                            <th class="px-5 py-3 w-16">ID</th>
                            <th class="px-5 py-3">Course</th>
                            <th class="px-5 py-3">Student</th>
                            <th class="px-5 py-3 text-right">Amount</th>
                            <th class="px-5 py-3">Purchase Date</th>
                            <th class="px-5 py-3">Request Date</th>
                            <th class="px-5 py-3">Refund Reason</th>
                            <th class="px-5 py-3 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-sm">
