@using CourseMarketplaceFE.Controllers
@model CourseMarketplaceFE.Controllers.AdminFinanceController.AdminFinanceUnifiedVM
@{
    ViewData["Title"] = "Financial & Payout Management";
    Layout = "_AdminLayout";
}

<!-- Header -->
<div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-6 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-900 mb-2 tracking-tight flex items-center gap-2">
            <span class="material-symbols-outlined text-indigo-600 text-3xl">analytics</span>
            Financial Management
        </h1>
        <p class="text-slate-500">Monitor revenue splits, current Stripe balance metrics, and process manager bank withdrawals.</p>
    </div>
    <!-- Month/Year Filter Form -->
    <form id="periodFilterForm" method="get" action="/AdminFinance" class="flex items-center gap-3 bg-slate-50 p-2.5 rounded-xl border border-slate-200 shadow-sm">
        <input type="hidden" name="tab" value="@ViewBag.ActiveTab" />
        <div class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-slate-400 text-sm pl-1">calendar_month</span>
            <select name="month" class="bg-transparent border-0 text-slate-700 font-bold text-sm focus:ring-0 focus:outline-none cursor-pointer p-0 pr-6">
                @for (int m = 1; m <= 12; m++)
                {
                    var monthName = System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(m);
                    if (m == (int)ViewBag.Month)
                    {
                        <option value="@m" selected>@monthName</option>
                    }
                    else
                    {
                        <option value="@m">@monthName</option>
                    }
                }
            </select>
        </div>
        <div class="w-[1px] h-5 bg-slate-300"></div>
        <div class="flex items-center">
            <select name="year" class="bg-transparent border-0 text-slate-700 font-bold text-sm focus:ring-0 focus:outline-none cursor-pointer p-0 pr-6">
                @for (int y = DateTime.UtcNow.Year; y <= DateTime.UtcNow.Year + 5; y++)
                {
                    if (y == (int)ViewBag.Year)
                    {
                        <option value="@y" selected>@y</option>
                    }
                    else
                    {
                        <option value="@y">@y</option>
                    }
                }
            </select>
        </div>
        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-1.5 rounded-lg text-xs font-bold transition-all flex items-center gap-1.5 shadow-sm">
            <span class="material-symbols-outlined text-[14px]">filter_alt</span>
            Filter
        </button>
    </form>
</div>

@if (TempData["FinanceSuccess"] != null || TempData["WithdrawSuccess"] != null)
{
    <div class="mb-6 p-4 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-xl font-medium flex items-center gap-2">
        <span class="material-symbols-outlined">check_circle</span>
        @(TempData["FinanceSuccess"] ?? TempData["WithdrawSuccess"])
    </div>
}
@if (TempData["FinanceError"] != null || TempData["WithdrawError"] != null)
{
    <div class="mb-6 p-4 bg-rose-50 text-rose-700 border border-rose-200 rounded-xl font-medium flex items-center gap-2">
        <span class="material-symbols-outlined">error</span>
        @(TempData["FinanceError"] ?? TempData["WithdrawError"])
    </div>
}

<!-- ========================================== -->
<!-- SECTION 1: REVENUE OVERVIEW & BALANCES     -->
<!-- ========================================== -->

<!-- Thống kê tổng quan Doanh thu -->
<div id="stats-overview" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden transition-all duration-300 hover:shadow-md">
        <div class="absolute right-0 top-0 w-24 h-24 bg-indigo-500/5 rounded-bl-[100px] -z-0"></div>
        <div class="relative z-10">
            <p class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-2">Gross Revenue</p>
            <p class="text-3xl font-black text-slate-900">@Model.Dashboard.Summary.GrossRevenue.ToString("C")</p>
            <p class="text-xs text-slate-400 mt-2">Across @Model.Dashboard.Summary.TotalTransactions transactions</p>
        </div>
    </div>
    
    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden transition-all duration-300 hover:shadow-md">
        <div class="absolute right-0 top-0 w-24 h-24 bg-emerald-500/5 rounded-bl-[100px] -z-0"></div>
        <div class="relative z-10">
            <p class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-2">Paid to Instructors</p>
            <p class="text-3xl font-black text-emerald-600">@Model.Dashboard.Summary.TotalPaidOut.ToString("C")</p>
            <p class="text-xs text-slate-400 mt-2">Transferred directly to instructors</p>
        </div>
    </div>
    
    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden transition-all duration-300 hover:shadow-md">
        <div class="absolute right-0 top-0 w-24 h-24 bg-amber-500/5 rounded-bl-[100px] -z-0"></div>
        <div class="relative z-10 flex flex-col justify-between h-full">
            <div>
                <p class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-1">Escrow Funds</p>
                <div class="flex items-baseline gap-1.5">
                    <span class="text-2xl font-black text-amber-500">@Model.Dashboard.Summary.PendingEscrow.ToString("C")</span>
                    <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-amber-50 text-amber-700 border border-amber-200">Locked (< 14d)</span>
                </div>
            </div>
            <div class="mt-4 pt-3 border-t border-slate-100 flex items-center justify-between">
                <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider flex items-center gap-1">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block animate-pulse"></span>
                    Matured (Ready)
                </span>
                <span class="text-base font-black text-emerald-600">@Model.Dashboard.Summary.MaturedEscrow.ToString("C")</span>
            </div>
        </div>
    </div>
    
    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden bg-gradient-to-br from-slate-900 to-slate-800 text-white transition-all duration-300 hover:shadow-md">
        <div class="relative z-10">
            <p class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">Platform Net Profit</p>
            <p class="text-3xl font-black text-white">@Model.Dashboard.Summary.PlatformNetProfit.ToString("C")</p>
            <p class="text-xs text-slate-400 mt-2">Net platform cut after splits</p>
        </div>
    </div>
</div>

<!-- Số dư Stripe -->
<div id="stripe-balances" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gradient-to-br from-emerald-500 to-emerald-600 p-6 rounded-2xl shadow-lg shadow-emerald-500/20 text-white relative overflow-hidden">
        <div class="absolute -right-6 -top-6 w-24 h-24 bg-white/10 rounded-full"></div>
        <div class="absolute -right-2 -bottom-8 w-32 h-32 bg-white/5 rounded-full"></div>
        <div class="relative z-10">
            <p class="text-sm font-bold text-emerald-100 uppercase tracking-wider mb-2 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-lg">account_balance_wallet</span>
                Stripe Balance: Available Now
            </p>
            <p class="text-4xl font-black">$@Model.Withdraw.Balance.Available.ToString("N2")</p>
            <p class="text-xs text-emerald-200 mt-2">Available Balance</p>
        </div>
    </div>

    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden">
        <div class="absolute right-0 top-0 w-24 h-24 bg-amber-500/5 rounded-bl-[100px]"></div>
        <div class="relative z-10">
            <p class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-2 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-lg text-amber-500">schedule</span>
                Stripe Balance: In Transit
            </p>
            <p class="text-3xl font-black text-slate-900">$@Model.Withdraw.Balance.Incoming.ToString("N2")</p>
            <p class="text-xs text-slate-400 mt-2">Incoming (Pending)</p>
        </div>
    </div>

    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden">
        <div class="absolute right-0 top-0 w-24 h-24 bg-primary/5 rounded-bl-[100px]"></div>
        <div class="relative z-10">
            <p class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-2 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-lg text-primary">savings</span>
                Total Stripe Assets
            </p>
            <p class="text-3xl font-black text-slate-900">$@Model.Withdraw.Balance.Total.ToString("N2")</p>
            <p class="text-xs text-slate-400 mt-2">
                Payout Schedule:
                <span class="font-bold text-primary capitalize">@Model.Withdraw.Balance.PayoutScheduleInterval</span>
                @if (!string.IsNullOrEmpty(Model.Withdraw.Balance.PayoutScheduleAnchor))
                {
                    <span>(@Model.Withdraw.Balance.PayoutScheduleAnchor)</span>
                }
            </p>
        </div>
    </div>
</div>

<!-- ========================================== -->
<!-- SECTION 2: SETTINGS & FUNDS WITHDRAWAL     -->
<!-- ========================================== -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    
    <!-- Cài đặt tỷ lệ chia sẻ -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
        <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">tune</span>
            Revenue Share Split Rate
        </h3>
        <form action="/AdminFinance/SetTransferRate" method="post" class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            @Html.AntiForgeryToken()
            <div class="relative flex-1 w-full">
                <label class="block text-xs font-bold text-slate-500 mb-1 uppercase">Instructor Share (%)</label>
                <input type="number" name="rate" min="1" max="100" step="0.01" value="@Model.Dashboard.Summary.CurrentTransferRate" 
                       class="w-full pl-4 pr-10 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all font-mono font-bold text-slate-900" />
                <span class="absolute right-4 top-[30px] text-slate-400 font-bold">%</span>
            </div>
            <button type="submit" class="w-full sm:w-auto mt-4 sm:mt-5 py-2.5 px-6 bg-slate-900 text-white rounded-xl font-bold hover:bg-slate-800 transition-colors shadow-sm whitespace-nowrap">
                Save Rate
            </button>
        </form>
    </div>

    <!-- Form Rút tiền về Ngân hàng -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
        <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-emerald-600">payment</span>
            Withdraw Funds to Bank
        </h3>
        @{
            var isWithdrawDisabled = Model.Withdraw.Balance.Available < 0.50m;
        }
        <form action="/AdminFinance/Withdraw" method="post" class="flex flex-col gap-3" id="withdraw-form" onsubmit="handleWithdrawSubmit(event)">
            @Html.AntiForgeryToken()
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                <div class="relative flex-1 w-full">
                    <label class="block text-xs font-bold text-slate-500 mb-1 uppercase">Withdraw Amount ($)</label>
                    <input type="number" name="amount" step="0.01" min="0.50" max="@Model.Withdraw.Balance.Available" value="@Model.Withdraw.Balance.Available"
                           class="w-full pl-4 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 outline-none transition-all font-mono font-bold text-slate-900 @(isWithdrawDisabled ? "opacity-60 cursor-not-allowed" : "")"
                           id="withdraw-amount" @(isWithdrawDisabled ? "disabled" : "") />
                </div>
                <div class="relative flex-1 w-full">
                    <label class="block text-xs font-bold text-slate-500 mb-1 uppercase">Description (Optional)</label>
                    <input type="text" name="description" placeholder="e.g. May profit withdrawal"
                           class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 outline-none transition-all text-sm @(isWithdrawDisabled ? "opacity-60 cursor-not-allowed" : "")"
                           @(isWithdrawDisabled ? "disabled" : "") />
                </div>
                <button type="submit"
                        class="w-full sm:w-auto mt-4 sm:mt-5 py-2.5 px-6 font-bold rounded-xl shadow-sm transition-all whitespace-nowrap flex items-center justify-center gap-2 @(isWithdrawDisabled ? "bg-slate-100 text-slate-400 border border-slate-200 cursor-not-allowed" : "bg-emerald-600 hover:bg-emerald-700 text-white active:scale-95")"
                        @(isWithdrawDisabled ? "disabled" : "")>
                    <span class="material-symbols-outlined text-sm">send_money</span>
                    Withdraw Now
                </button>
            </div>
            @if (isWithdrawDisabled)
            {
                <p class="text-xs text-amber-600 font-bold flex items-center gap-1 mt-1 bg-amber-50 border border-amber-100 p-2.5 rounded-xl">
                    <span class="material-symbols-outlined text-[16px]">info</span>
                    The minimum available balance to withdraw is $0.50 (Current: $@Model.Withdraw.Balance.Available.ToString("N2")).
                </p>
            }
        </form>
    </div>

</div>

<!-- ========================================== -->
<!-- SECTION 3: TRANSACTION & WITHDRAWAL LOGS   -->
<!-- ========================================== -->
<div class="flex flex-col gap-8 mb-12">
    
    <!-- Tabs UI -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-12">
        <!-- Card Header with Tabs -->
        <div class="border-b border-slate-200 bg-slate-50/80 flex flex-col xl:flex-row items-center justify-between px-3 py-3 gap-4">
            <div class="flex items-center gap-1.5 w-full xl:w-auto p-1.5 bg-slate-200/50 rounded-2xl overflow-x-auto">
                <button id="tab-btn-tx" onclick="switchTab('tx')" class="whitespace-nowrap flex-1 xl:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold transition-all duration-300 @(ViewBag.ActiveTab == "tx" ? "bg-white text-indigo-600 shadow-sm" : "text-slate-500 hover:text-slate-800")">
                    <span class="material-symbols-outlined text-[18px]">receipt_long</span>
                    Transaction History
                </button>
                <button id="tab-btn-po" onclick="switchTab('po')" class="whitespace-nowrap flex-1 xl:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold transition-all duration-300 @(ViewBag.ActiveTab == "po" ? "bg-white text-emerald-600 shadow-sm" : "text-slate-500 hover:text-slate-800")">
                    <span class="material-symbols-outlined text-[18px]">payments</span>
                    Instructor Payouts
                </button>
                <button id="tab-btn-wd" onclick="switchTab('wd')" class="whitespace-nowrap flex-1 xl:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold transition-all duration-300 @(ViewBag.ActiveTab == "wd" ? "bg-white text-rose-600 shadow-sm" : "text-slate-500 hover:text-slate-800")">
                    <span class="material-symbols-outlined text-[18px]">history</span>
                    Manager Bank Withdrawals
                </button>
                <button id="tab-btn-rf" onclick="switchTab('rf')" class="whitespace-nowrap flex-1 xl:flex-none flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold transition-all duration-300 @(ViewBag.ActiveTab == "rf" ? "bg-white text-orange-600 shadow-sm" : "text-slate-500 hover:text-slate-800")">
                    <span class="material-symbols-outlined text-[18px]">restart_alt</span>
                    Refund Requests
                </button>
            </div>
            
            <!-- Indicators & Sync -->
            <div class="flex items-center gap-3 px-4 xl:px-2 w-full xl:w-auto overflow-x-auto">
                <form action="/AdminFinance/SyncAllPayouts" method="post" id="syncAllForm" class="inline-block mr-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" id="syncAllBtn" class="flex items-center gap-1.5 px-4 py-2 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-xl font-bold text-xs shadow-sm transition-all duration-300 transform active:scale-95">
                        <span id="syncAllIcon" class="material-symbols-outlined text-[16px]">sync</span>
                        Sync with Stripe
                    </button>
                </form>

                <span id="tab-ind-tx" class="whitespace-nowrap inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-bold bg-indigo-50 border border-indigo-100 text-indigo-700 shadow-sm/5 @(ViewBag.ActiveTab == "tx" ? "" : "hidden")">
                    <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span> @Model.Transactions.TotalCount transactions
                </span>
                <span id="tab-ind-po" class="whitespace-nowrap inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-bold bg-emerald-50 border border-emerald-100 text-emerald-700 shadow-sm/5 @(ViewBag.ActiveTab == "po" ? "" : "hidden")">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span> @Model.Dashboard.Payouts.Count payouts
                </span>
                <span id="tab-ind-wd" class="whitespace-nowrap inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-bold bg-rose-50 border border-rose-100 text-rose-700 shadow-sm/5 @(ViewBag.ActiveTab == "wd" ? "" : "hidden")">
                    <span class="w-1.5 h-1.5 rounded-full bg-rose-500 animate-pulse"></span> @Model.Withdraw.History.Count withdrawals
                </span>
                <span id="tab-ind-rf" class="whitespace-nowrap inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-bold bg-orange-50 border border-orange-100 text-orange-700 shadow-sm/5 @(ViewBag.ActiveTab == "rf" ? "" : "hidden")">
                    <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span> @Model.PendingRefunds.Count pending
                </span>
            </div>
        </div>

        <!-- TAB 1: Giao dịch (TX) -->
        <div id="tab-content-tx" class="flex flex-col animate-fadeIn @(ViewBag.ActiveTab == "tx" ? "" : "hidden")">
            <!-- Filter Form -->
            <div class="px-5 py-4 border-b border-slate-200 bg-white">
                <form method="get" action="/AdminFinance" class="flex flex-col md:flex-row items-center gap-3 w-full">
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@Model.Transactions.PageSize" />
                    <input type="hidden" name="tab" value="tx" id="filter-tab-input" />
                    <input type="hidden" name="year" value="@ViewBag.Year" />
                    <input type="hidden" name="month" value="@ViewBag.Month" />
                    
                    <div class="relative flex-1 w-full">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 text-[18px]">search</span>
                        <input type="text" name="keyword" value="@ViewBag.Keyword" placeholder="Search course title, student name, instructor..." 
                               class="w-full pl-9 pr-4 py-2 bg-white border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-600/20 focus:border-indigo-600 outline-none transition-all shadow-sm" />
                    </div>
                    
                    <div class="w-full md:w-40">
                        <select name="status" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-600/20 focus:border-indigo-600 outline-none shadow-sm cursor-pointer">
                            <option value="">All Statuses</option>
                            <option value="succeeded" selected="@(ViewBag.Status == "succeeded")">Succeeded</option>
                            <option value="refund_pending" selected="@(ViewBag.Status == "refund_pending")">Refund Pending</option>
                            <option value="refunded" selected="@(ViewBag.Status == "refunded")">Refunded</option>
                            <option value="failed" selected="@(ViewBag.Status == "failed")">Failed</option>
                        </select>
                    </div>

                    <div class="w-full md:w-48">
                        <select name="sortBy" class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-600/20 focus:border-indigo-600 outline-none shadow-sm cursor-pointer">
                            <option value="date_desc" selected="@(ViewBag.SortBy == "date_desc")">Date: Newest</option>
                            <option value="date_asc" selected="@(ViewBag.SortBy == "date_asc")">Date: Oldest</option>
                            <option value="amount_desc" selected="@(ViewBag.SortBy == "amount_desc")">Amount: High to Low</option>
                            <option value="amount_asc" selected="@(ViewBag.SortBy == "amount_asc")">Amount: Low to High</option>
                        </select>
                    </div>

                    <button type="submit" class="w-full md:w-auto px-5 py-2 bg-indigo-600 text-white font-medium text-sm rounded-lg hover:bg-indigo-700 transition-colors shadow-sm whitespace-nowrap">Filter</button>
                    @if (!string.IsNullOrEmpty(ViewBag.Keyword as string) || !string.IsNullOrEmpty(ViewBag.Status as string) || (ViewBag.SortBy as string) != "date_desc")
                    {
                        <a href="/AdminFinance?tab=tx" class="w-full md:w-auto px-4 py-2 bg-slate-200 text-slate-700 font-medium text-sm rounded-lg hover:bg-slate-300 transition-colors whitespace-nowrap text-center">Clear Filters</a>
                    }
                </form>
            </div>

            <div class="overflow-x-auto max-h-[600px] flex-1">
                <table class="w-full text-left border-collapse">
                    <thead class="text-[10px] text-slate-500 bg-slate-50 border-b border-slate-200 uppercase font-bold sticky top-0 z-10 shadow-sm">
                        <tr>
                            <th class="px-5 py-3 w-16">ID</th>
                            <th class="px-5 py-3">Stripe Tx ID</th>
                            <th class="px-5 py-3">Course</th>
                            <th class="px-5 py-3">Purchased By</th>
                            <th class="px-5 py-3">Instructor</th>
                            <th class="px-5 py-3 text-right">Amount</th>
                            <th class="px-5 py-3">Date</th>
                            <th class="px-5 py-3">Status</th>
                            <th class="px-5 py-3 text-center">Details</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-sm">
                        @if (Model.Transactions.Items != null && Model.Transactions.Items.Any())
                        {
                            @foreach (var item in Model.Transactions.Items)
                            {
                                <tr class="hover:bg-slate-50/50 transition-colors group">
                                    <td class="px-5 py-3.5 font-mono text-xs text-slate-400">#@item.TransactionId</td>
                                    <td class="px-5 py-3.5">
                                        @if (!string.IsNullOrEmpty(item.StripeSessionId))
                                        {
                                            <span class="font-mono text-xs text-slate-500 cursor-default" title="@item.StripeSessionId">
                                                @(item.StripeSessionId.Length > 22 ? item.StripeSessionId[..10] + "…" + item.StripeSessionId[^8..] : item.StripeSessionId)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-xs text-slate-300 italic">—</span>
                                        }
                                    </td>
                                    <td class="px-5 py-3.5 max-w-[180px]">
                                        <span class="font-medium text-slate-800 truncate block" title="@item.CourseTitle">@item.CourseTitle</span>
                                    </td>
                                    <td class="px-5 py-3.5 text-slate-600">@item.BuyerName</td>
                                    <td class="px-5 py-3.5 text-slate-600">@item.InstructorName</td>
                                    <td class="px-5 py-3.5 text-right font-semibold text-slate-800">
                                        @((item.Currency ?? "USD").ToUpper()) @item.Amount.ToString("N2")
                                    </td>
                                    <td class="px-5 py-3.5 text-slate-500 text-xs whitespace-nowrap">
                                        @(item.Date.HasValue ? item.Date.Value.ToString("dd/MM/yyyy HH:mm") : "—")
                                    </td>
                                    <td class="px-5 py-3.5">
                                        @{
                                            var (bgClass, textClass, dotClass, label) = item.Status switch
                                            {
                                                "succeeded" => ("bg-emerald-50", "text-emerald-700", "bg-emerald-500", "Succeeded"),
                                                "failed"    => ("bg-red-50",     "text-red-700",     "bg-red-500",     "Failed"),
                                                "pending"   => ("bg-amber-50",   "text-amber-700",   "bg-amber-400",   "Pending"),
                                                "refund_pending" => ("bg-orange-50", "text-orange-700", "bg-orange-500", "Refund Pending"),
                                                "refunded"  => ("bg-rose-50",    "text-rose-700",    "bg-rose-500",    "Refunded"),
                                                _           => ("bg-slate-100",  "text-slate-600",   "bg-slate-400",   item.Status ?? "—")
                                            };
                                        }
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-medium @bgClass @textClass">
                                            <span class="w-1.5 h-1.5 rounded-full @dotClass"></span>
                                            @label
                                        </span>
                                    </td>
                                    <td class="px-5 py-3.5 text-center">
                                        <a href="@Url.Action("Detail", "Transaction", new { id = item.TransactionId })"
                                           class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 border border-slate-200 hover:border-indigo-200 rounded-md transition-all">
                                            <span class="material-symbols-outlined text-[14px]">visibility</span>
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="px-5 py-14 text-center">
                                    <div class="flex flex-col items-center justify-center text-slate-400">
                                        <span class="material-symbols-outlined text-5xl mb-3 text-slate-200">receipt_long</span>
                                        <p class="text-sm font-medium text-slate-500">No transactions matched your criteria.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            @if (Model.Transactions.TotalPages > 1)
            {
                <div class="px-5 py-3 border-t border-slate-200 bg-white flex flex-col sm:flex-row items-center justify-between gap-3">
                    <p class="text-xs text-slate-500">
                        Showing @((Model.Transactions.Page - 1) * Model.Transactions.PageSize + 1)–@Math.Min(Model.Transactions.Page * Model.Transactions.PageSize, Model.Transactions.TotalCount) of <span class="font-semibold text-slate-700">@Model.Transactions.TotalCount</span> transactions
                    </p>
                    <div class="flex items-center gap-1">
                        @if (Model.Transactions.Page > 1)
                        {
                            <a href="@Url.Action("Index", new { page = Model.Transactions.Page - 1, pageSize = Model.Transactions.PageSize, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status, tab = "tx", year = ViewBag.Year, month = ViewBag.Month, payoutPage = ViewBag.PayoutPage, withdrawPage = ViewBag.WithdrawPage })"
                               class="px-3 py-1.5 text-xs font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 border border-slate-200 rounded-md transition-all">← Prev</a>
                        }

                        @for (int p = Math.Max(1, Model.Transactions.Page - 2); p <= Math.Min(Model.Transactions.TotalPages, Model.Transactions.Page + 2); p++)
                        {
                            if (p == Model.Transactions.Page)
                            {
                                <span class="px-3 py-1.5 text-xs font-semibold bg-indigo-600 text-white border border-indigo-600 rounded-md">@p</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Index", new { page = p, pageSize = Model.Transactions.PageSize, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status, tab = "tx", year = ViewBag.Year, month = ViewBag.Month, payoutPage = ViewBag.PayoutPage, withdrawPage = ViewBag.WithdrawPage })"
                                   class="px-3 py-1.5 text-xs font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 border border-slate-200 rounded-md transition-all">@p</a>
                            }
                        }

                        @if (Model.Transactions.Page < Model.Transactions.TotalPages)
                        {
                            <a href="@Url.Action("Index", new { page = Model.Transactions.Page + 1, pageSize = Model.Transactions.PageSize, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status, tab = "tx", year = ViewBag.Year, month = ViewBag.Month, payoutPage = ViewBag.PayoutPage, withdrawPage = ViewBag.WithdrawPage })"
                               class="px-3 py-1.5 text-xs font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 border border-slate-200 rounded-md transition-all font-bold">Next →</a>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- TAB 2: PAYOUTS (PO) -->
        <div id="tab-content-po" class="flex flex-col animate-fadeIn @(ViewBag.ActiveTab == "po" ? "" : "hidden")">
            <div class="overflow-x-auto max-h-[600px] flex-1">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-[10px] font-bold text-slate-400 tracking-wider bg-slate-50/40 border-b border-slate-100 uppercase sticky top-0 z-10">
                            <th class="pl-6 pr-4 py-3.5">Tx / Instructor</th>
                            <th class="px-4 py-3.5">Payout Share</th>
                            <th class="px-4 py-3.5">Stripe Status</th>
                            <th class="pl-4 pr-6 py-3.5 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-sm">
                        @if (Model.Payouts.TotalCount == 0)
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-16 text-center">
                                    <div class="flex flex-col items-center justify-center text-slate-400">
                                        <span class="material-symbols-outlined text-4xl mb-2 text-slate-300">payments</span>
                                        <p class="text-sm font-bold text-slate-700">No payouts recorded.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var p in Model.Payouts.Items)
                            {
                                <tr class="hover:bg-slate-50/50 group/row border-b border-slate-100 transition-all duration-300">
                                    <td class="pl-6 pr-4 py-4.5 align-middle">
                                        <div class="flex flex-col">
                                            <span class="text-sm font-bold text-slate-900 leading-snug group-hover/row:text-emerald-700 transition-colors">@p.InstructorName</span>
                                            <span class="text-[10px] text-slate-400 font-bold mt-0.5 font-mono">Tx ID: #@p.TransactionId</span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-4.5 align-middle">
                                        <div class="flex flex-col">
                                            <span class="text-sm font-black text-slate-900 tracking-tight font-black">@p.InstructorReceived.ToString("C")</span>
                                            <span class="text-[10px] text-slate-400 font-bold mt-0.5">Split Rate: @p.TransferRate%</span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-4.5 align-middle">
                                        @{
                                            var status = p.PayoutStatus?.ToLower() ?? (p.IsPaid ? "transferred" : "pending");
                                        }
                                        @if (status == "paid")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-emerald-50 text-emerald-700 border border-emerald-100/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5">
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                                Settled to Bank
                                            </span>
                                        }
                                        else if (status == "in_transit")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-blue-50 text-blue-700 border border-blue-100/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5 animate-pulse">
                                                <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                                                In Transit
                                            </span>
                                        }
                                        else if (status == "transferred")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-violet-50 text-violet-700 border border-violet-100/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5">
                                                <span class="w-1.5 h-1.5 rounded-full bg-violet-500 animate-pulse"></span>
                                                Stripe Wallet
                                            </span>
                                        }
                                        else if (status == "failed")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-red-50 text-red-700 border border-red-100/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5">
                                                <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                                                Failed
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-amber-50 text-amber-800 border border-amber-100/50 text-[10px] font-extrabold uppercase tracking-wide shadow-sm/5">
                                                <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
                                                Unpaid Escrow
                                            </span>
                                        }
                                    </td>
                                    <td class="pl-4 pr-6 py-4.5 text-right align-middle">
                                        @if (!p.IsPaid)
                                        {
                                            <form action="/AdminFinance/PayViaStripe" method="post" onsubmit="handleStripePaySubmit(event)">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="payoutId" value="@p.PayoutId" />
                                                <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-xs rounded-xl shadow-sm hover:shadow-md transition-all duration-200 active:scale-[0.97]">
                                                    <span class="material-symbols-outlined text-[14px]">payments</span>
                                                    Pay via Stripe
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1 px-2.5 py-1 text-slate-400 text-xs font-bold bg-slate-50 border border-slate-200/60 rounded-xl cursor-not-allowed">
                                                <span class="material-symbols-outlined text-[14px]">check_circle</span>
                                                Completed
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            
            @if (Model.Payouts.TotalPages > 1)
            {
                <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between bg-slate-50/30">
                    <p class="text-xs font-semibold text-slate-500">
                        Showing <span class="font-bold text-slate-800">@((Model.Payouts.Page - 1) * Model.Payouts.PageSize + 1)</span> – <span class="font-bold text-slate-800">@Math.Min(Model.Payouts.Page * Model.Payouts.PageSize, Model.Payouts.TotalCount)</span> of <span class="font-bold text-slate-800">@Model.Payouts.TotalCount</span>
                    </p>
                    <div class="flex items-center gap-1.5">
                        @if (Model.Payouts.Page > 1)
                        {
                            <a href="@Url.Action("Index", new { page = Model.Transactions.Page, pageSize = Model.Transactions.PageSize, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status, tab = "po", year = ViewBag.Year, month = ViewBag.Month, payoutPage = Model.Payouts.Page - 1, withdrawPage = ViewBag.WithdrawPage })"
                               class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200/80 text-slate-500 hover:bg-white hover:text-slate-800 transition-all shadow-sm/5">
                                <span class="material-symbols-outlined text-[16px]">chevron_left</span>
                            </a>
                        }

                        @for (int p = Math.Max(1, Model.Payouts.Page - 2); p <= Math.Min(Model.Payouts.TotalPages, Model.Payouts.Page + 2); p++)
                        {
                            if (p == Model.Payouts.Page)
                            {
                                <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-emerald-600 text-white font-extrabold text-xs shadow-md shadow-emerald-600/10">@p</span>
                            }
                            else
                            {
                                <a href="@Url.Action("Index", new { page = Model.Transactions.Page, pageSize = Model.Transactions.PageSize, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status, tab = "po", year = ViewBag.Year, month = ViewBag.Month, payoutPage = p, withdrawPage = ViewBag.WithdrawPage })"
                                   class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200/80 text-slate-600 hover:bg-white hover:text-slate-800 font-bold text-xs transition-all shadow-sm/5 font-bold">@p</a>
                            }
                        }

                        @if (Model.Payouts.Page < Model.Payouts.TotalPages)
                        {
                            <a href="@Url.Action("Index", new { page = Model.Transactions.Page, pageSize = Model.Transactions.PageSize, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status, tab = "po", year = ViewBag.Year, month = ViewBag.Month, payoutPage = Model.Payouts.Page + 1, withdrawPage = ViewBag.WithdrawPage })"
                               class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200/80 text-slate-500 hover:bg-white hover:text-slate-800 transition-all shadow-sm/5 font-bold">
                                <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- TAB 3: WITHDRAWALS (WD) -->
        <div id="tab-content-wd" class="flex flex-col animate-fadeIn @(ViewBag.ActiveTab == "wd" ? "" : "hidden")">
            <div class="overflow-x-auto max-h-[600px] flex-1">
