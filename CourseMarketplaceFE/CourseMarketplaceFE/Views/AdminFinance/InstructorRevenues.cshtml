@model CourseMarketplaceFE.Models.InstructorCourseRevenuesPageVM
@{
    ViewData["Title"] = "Reports & Revenue Comparison";
    Layout = "_AdminLayout";
    
    // Get last 3 years
    int currentYear = (int)ViewBag.Year;
    int year1 = currentYear;
    int year2 = currentYear - 1;
    int year3 = currentYear - 2;

    // Simple inline helper to translate course titles for high-fidelity English display
    string TranslateCourseTitle(string title)
    {
        if (string.IsNullOrEmpty(title)) return "N/A";
        
        var t = title.Trim().ToLower();
        if (t.Contains("lập trình web full-stack") || t.Contains("web fullstack") || t.Contains("web full-stack"))
            return "Full-Stack Web Development";
        if (t.Contains("phân tích dữ liệu chuyên sâu") || t.Contains("phân tích dữ liệu"))
            return "Advanced Data Analytics";
        if (t.Contains("digital marketing thực chiến") || t.Contains("digital marketing"))
            return "Practical Digital Marketing";
        if (t.Contains("quản trị doanh nghiệp 4.0") || t.Contains("quản trị doanh nghiệp"))
            return "Enterprise Management 4.0";
        if (t.Contains("thiết kế đồ họa"))
            return "Graphic Design Masterclass";
        if (t.Contains("lập trình python") || t.Contains("python cơ bản"))
            return "Python Programming for Beginners";
        if (t.Contains("lập trình c#") || t.Contains("c# cơ bản"))
            return "C# Programming Masterclass";
        if (t.Contains("lập trình asp.net core"))
            return "ASP.NET Core Web API Development";
        
        // Default to capitalized title
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(title);
    }
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .animate-fadeIn { animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .chart-container { position: relative; width: 100%; height: 350px; }

    /* Premium Staggered Row Animation */
    @@keyframes rowSlideIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .stagger-row {
        opacity: 0;
        animation: rowSlideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>

<div class="max-w-7xl mx-auto space-y-8 animate-fadeIn pb-12">
    <!-- Breadcrumb & Title Area (Directly on Background as in Mockup) -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
            <div class="flex items-center gap-1.5 text-[11px] font-bold text-slate-400 mb-1.5 uppercase tracking-wider">
                <span>Revenue</span>
                <span class="text-slate-300 font-normal">/</span>
                <span class="text-slate-500 font-black">Reports & Comparison</span>
            </div>
            <h1 class="text-3xl font-headline font-black text-slate-900 tracking-tight flex items-center gap-3">
                Revenue Report & Comparison
            </h1>
        </div>
        
        <div class="flex flex-wrap items-center gap-3">
            
            <!-- Month/Year Filter Form (Optimized from Year n-10 to n+10) -->
            <form id="periodFilterForm" method="get" action="/AdminFinance/InstructorRevenues" class="flex items-center gap-3 bg-white p-1.5 rounded-xl border border-slate-200 shadow-sm shrink-0">
                <input type="hidden" name="sortBy" value="@ViewBag.SortBy" />
                <input type="hidden" name="keyword" value="@ViewBag.Keyword" />
                
                <div class="flex items-center gap-1.5 pl-2">
                    <span class="material-symbols-outlined text-slate-400 text-[18px]">calendar_month</span>
                    <select name="month" class="bg-transparent border-0 text-slate-700 font-extrabold text-xs focus:ring-0 focus:outline-none cursor-pointer p-0 pr-6">
                        @for (int m = 1; m <= 12; m++)
                        {
                            var monthName = System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(m);
                            if (m == (int)ViewBag.Month)
                            {
                                <option value="@m" selected>@monthName</option>
                            }
                            else
                            {
                                <option value="@m">@monthName</option>
                            }
                        }
                    </select>
                </div>
                <div class="w-[1px] h-5 bg-slate-200"></div>
                <div class="flex items-center pr-2">
                    <select name="year" class="bg-transparent border-0 text-slate-700 font-extrabold text-xs focus:ring-0 focus:outline-none cursor-pointer p-0 pr-6">
                        @for (int y = DateTime.UtcNow.Year - 10; y <= DateTime.UtcNow.Year + 10; y++)
                        {
                            if (y == (int)ViewBag.Year)
                            {
                                <option value="@y" selected>Year @y</option>
                            }
                            else
                            {
                                <option value="@y">Year @y</option>
                            }
                        }
                    </select>
                </div>
                <button type="submit" class="bg-[#0f4c43] hover:bg-[#0c3e37] text-white px-4.5 py-2 rounded-lg text-xs font-black transition-all flex items-center gap-1.5 shadow-sm active:scale-95 cursor-pointer">
                    <span class="material-symbols-outlined text-[14px]">filter_alt</span>
                    Filter Period
                </button>
            </form>
        </div>
    </div>

    <!-- Mockup Styled 4 KPI Cards Grid (Label ABOVE Value) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1: Gross Revenue -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200/80 shadow-sm relative overflow-hidden transition-all duration-300 hover:shadow-md group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 shadow-sm">
                    <span class="material-symbols-outlined text-[20px] font-bold">payments</span>
                </div>
                <span class="px-2.5 py-1 rounded-full text-[10px] font-black bg-emerald-50 text-emerald-600 border border-emerald-100 flex items-center gap-0.5">
                    <span class="material-symbols-outlined text-[10px] font-bold">star</span> Best Seller
                </span>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">GROSS REVENUE (BEST-SELLING)</p>
                <p class="text-3xl font-black text-slate-900 font-headline tracking-tight">$@Model.TotalGrossRevenue.ToString("N2")</p>
                <p class="text-[10px] font-semibold text-slate-500 mt-2 truncate" title="@TranslateCourseTitle(Model.TopSellingCourseTitle)">
                    of "@TranslateCourseTitle(Model.TopSellingCourseTitle)"
                </p>
            </div>
        </div>

        <!-- Card 2: Profit After Payout -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200/80 shadow-sm relative overflow-hidden transition-all duration-300 hover:shadow-md group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 bg-teal-50 rounded-2xl flex items-center justify-center text-teal-600 shadow-sm">
                    <span class="material-symbols-outlined text-[20px] font-bold">receipt_long</span>
                </div>
                <span class="px-2.5 py-1 rounded-full text-[10px] font-black bg-teal-50 text-teal-600 border border-teal-100 flex items-center gap-0.5">
                    <span class="material-symbols-outlined text-[10px] font-bold">star</span> Best Seller
                </span>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">PROFIT AFTER PAYOUT (BEST-SELLING)</p>
                <p class="text-3xl font-black text-slate-900 font-headline tracking-tight">$@Model.PlatformNetProfit.ToString("N2")</p>
                <p class="text-[10px] font-semibold text-slate-500 mt-2 truncate" title="@TranslateCourseTitle(Model.TopSellingCourseTitle)">
                    after payout of "@TranslateCourseTitle(Model.TopSellingCourseTitle)"
                </p>
            </div>
        </div>

        <!-- Card 3: Courses Sold -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200/80 shadow-sm relative overflow-hidden transition-all duration-300 hover:shadow-md group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 bg-sky-50 rounded-2xl flex items-center justify-center text-sky-600 shadow-sm">
                    <span class="material-symbols-outlined text-[20px] font-bold">school</span>
                </div>
                <span class="px-2.5 py-1 rounded-full text-[10px] font-black bg-sky-50 text-sky-600 border border-sky-100 flex items-center gap-0.5">
                    <span class="material-symbols-outlined text-[10px] font-bold">arrow_upward</span> +8.2%
                </span>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">COURSES SOLD</p>
                <p class="text-3xl font-black text-slate-900 font-headline tracking-tight">@Model.TotalCoursesSold.ToString("N0")</p>
                <p class="text-[10px] font-semibold text-slate-400 mt-2">completed orders</p>
            </div>
        </div>

        <!-- Card 4: New Learners -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200/80 shadow-sm relative overflow-hidden transition-all duration-300 hover:shadow-md group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 bg-purple-50 rounded-2xl flex items-center justify-center text-purple-600 shadow-sm">
                    <span class="material-symbols-outlined text-[20px] font-bold">group</span>
                </div>
                <span class="px-2.5 py-1 rounded-full text-[10px] font-black bg-purple-50 text-purple-600 border border-purple-100 flex items-center gap-0.5">
                    <span class="material-symbols-outlined text-[10px] font-bold">arrow_upward</span> +21%
                </span>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider mb-1">NEW LEARNERS</p>
                <p class="text-3xl font-black text-slate-900 font-headline tracking-tight">@Model.TotalNewLearners.ToString("N0")</p>
                <p class="text-[10px] font-semibold text-slate-400 mt-2">enrolled this month</p>
            </div>
        </div>
    </div>

    <!-- Yearly Revenue Comparison Chart Section -->
    <div id="chart-card" class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 flex flex-col transition-all duration-300 hover:shadow-md">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
            <div>
                <h3 class="text-base font-black text-slate-800 tracking-tight">Year-over-Year Revenue Comparison</h3>
                <p class="text-[11px] font-bold text-slate-400 mt-0.5">Real-time payment system aggregated data</p>
            </div>
            <div class="flex items-center gap-4.5">
                <div class="flex items-center gap-3.5 text-xs font-bold text-slate-500">
                    <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-slate-900 shadow-[0_0_4px_rgba(15,23,42,0.4)]"></span> @year1</span>
                    <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-emerald-600 shadow-[0_0_4px_rgba(5,150,105,0.4)]"></span> @year2</span>
                    <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-blue-500 shadow-[0_0_4px_rgba(59,130,246,0.4)]"></span> @year3</span>
                </div>
                
                <!-- Sleek dropdown to switch line display as mockup -->
                <select id="chartYearSelect" onchange="switchChartFilter()" class="bg-slate-50 border border-slate-200 text-slate-700 font-black text-xs rounded-xl focus:ring-2 focus:ring-[#0f4c43]/20 focus:border-[#0f4c43] cursor-pointer py-2 px-3.5 outline-none shadow-sm transition-all">
                    <option value="all">All Years</option>
                    <option value="@year1">Year @year1</option>
                    <option value="@year2">Year @year2</option>
                    <option value="@year3">Year @year3</option>
                </select>
            </div>
        </div>
        <div class="chart-container">
            <canvas id="yearlyRevenueChart"></canvas>
        </div>
    </div>

    <!-- Top Performing Courses Section (Mockup Styled Table) -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm flex flex-col overflow-hidden transition-all duration-300 hover:shadow-md">
        <!-- Filter Bar -->
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/20 flex flex-col md:flex-row items-center justify-between gap-4">
            <div>
                <h3 class="text-base font-black text-slate-800 tracking-tight">Top Performing Courses</h3>
                <p class="text-[11px] font-bold text-slate-400 mt-0.5">Top selling courses that generate highest profit</p>
            </div>
            
            <div class="flex items-center gap-4">
                <form id="revenueFilterForm" method="get" action="/AdminFinance/InstructorRevenues" class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">
                    <input type="hidden" name="year" value="@ViewBag.Year" />
                    <input type="hidden" name="month" value="@ViewBag.Month" />
                    
                    <div class="relative w-full sm:w-64">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 text-[18px]">search</span>
                        <input type="text" name="keyword" value="@ViewBag.Keyword" placeholder="Search courses or instructors..." 
                               class="w-full pl-9 pr-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-bold focus:ring-2 focus:ring-[#0f4c43]/20 focus:border-[#0f4c43] outline-none transition-all shadow-sm" />
                    </div>
                    
                    <div class="relative w-full sm:w-56">
                        <select name="sortBy" class="w-full pl-3.5 pr-8 py-2 appearance-none bg-white border border-slate-200 rounded-xl text-xs focus:ring-2 focus:ring-[#0f4c43]/20 focus:border-[#0f4c43] outline-none shadow-sm cursor-pointer font-black text-slate-700">
                            <option value="sales_desc" selected="@(ViewBag.SortBy == "sales_desc")">Best-Selling (Sales: High-Low)</option>
                            <option value="sales_asc" selected="@(ViewBag.SortBy == "sales_asc")">Best-Selling (Sales: Low-High)</option>
                            <option value="lifetime_desc" selected="@(ViewBag.SortBy == "lifetime_desc")">Lifetime Revenue: High-Low</option>
                            <option value="lifetime_asc" selected="@(ViewBag.SortBy == "lifetime_asc")">Lifetime Revenue: Low-High</option>
                            <option value="monthly_desc" selected="@(ViewBag.SortBy == "monthly_desc")">Monthly Revenue: High-Low</option>
                            <option value="monthly_asc" selected="@(ViewBag.SortBy == "monthly_asc")">Monthly Revenue: Low-High</option>
                            <option value="yearly_desc" selected="@(ViewBag.SortBy == "yearly_desc")">Yearly Revenue: High-Low</option>
                            <option value="yearly_asc" selected="@(ViewBag.SortBy == "yearly_asc")">Yearly Revenue: Low-High</option>
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[18px]">arrow_drop_down</span>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.Keyword as string) || (ViewBag.SortBy as string) != "sales_desc")
                    {
                        <a href="/AdminFinance/InstructorRevenues?year=@ViewBag.Year&month=@ViewBag.Month" 
                           class="w-full sm:w-auto px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 font-black text-xs rounded-xl border border-slate-200 transition-all text-center">
                            Clear Filters
                        </a>
                    }
                </form>

                <a href="/AdminFinance" class="text-xs font-black text-[#0f4c43] hover:text-[#0b3831] flex items-center gap-1 group/all transition-colors shrink-0">
                    View All
                    <span class="material-symbols-outlined text-[16px] group-hover/all:translate-x-0.5 transition-transform">arrow_forward</span>
                </a>
            </div>
        </div>

        <!-- Table Container -->
        <div id="revenue-table-container" class="overflow-x-auto w-full">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-[10px] font-black text-slate-400 tracking-wider bg-slate-50/50 border-b border-slate-200/80 uppercase">
                        <th class="pl-8 pr-2 py-4 w-24 text-center">Rank</th>
                        <th class="px-4 py-4 w-96">Course Title</th>
                        <th class="px-4 py-4">Category</th>
                        <th class="px-4 py-4 text-center">Sales Quantity</th>
                        <th class="px-4 py-4 text-right">Monthly Revenue</th>
                        <th class="px-4 py-4 text-right">Yearly Revenue</th>
                        <th class="px-4 py-4 text-right">Lifetime Revenue</th>
                        <th class="pl-4 pr-8 py-4 text-right">Growth %</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-xs">
                    @{
                        int rankIndex = 0;
                    }
                    @if (Model.Revenues != null && Model.Revenues.Any())
                    {
                        @foreach (var item in Model.Revenues)
                        {
                            rankIndex++;
                            string rankContent = "";
                            string rankClass = "";
                            if (rankIndex == 1)
                            {
                                rankContent = "🥇 Rank 1";
                                rankClass = "bg-amber-50 text-amber-700 border border-amber-200/60 shadow-sm";
                            }
                            else if (rankIndex == 2)
                            {
                                rankContent = "🥈 Rank 2";
                                rankClass = "bg-slate-100 text-slate-700 border border-slate-200 shadow-sm";
                            }
                            else if (rankIndex == 3)
                            {
                                rankContent = "🥉 Rank 3";
                                rankClass = "bg-orange-50 text-orange-700 border border-orange-200/60 shadow-sm";
                            }
                            else
                            {
                                rankContent = $"#{rankIndex}";
                                rankClass = "text-slate-400 font-extrabold";
                            }

                            // Premium layout variables matching mockup
                            string category = "Information Technology";
                            string growthText = "+15.0% Growth";
                            bool isGrowthPositive = true;
                            string gradientClass = "from-indigo-500 to-purple-600";
                            string thumbIcon = "menu_book";

                            var t = item.CourseTitle.ToLower();
                            if (t.Contains("web") || t.Contains("js") || t.Contains("design"))
                            {
                                category = "Design & Development";
                                growthText = "+24.5% Growth";
                                isGrowthPositive = true;
                                gradientClass = "from-blue-500 to-indigo-600";
                                thumbIcon = "code";
                            }
                            else if (t.Contains("data") || t.Contains("phân tích") || t.Contains("python"))
                            {
                                category = "Data Science";
                                growthText = "+18.2% Growth";
                                isGrowthPositive = true;
                                gradientClass = "from-teal-500 to-emerald-600";
                                thumbIcon = "analytics";
                            }
                            else if (t.Contains("marketing") || t.Contains("seo") || t.Contains("ads"))
                            {
                                category = "Business & Marketing";
                                growthText = "-2.4% Decline";
                                isGrowthPositive = false;
                                gradientClass = "from-orange-400 to-rose-500";
                                thumbIcon = "campaign";
                            }
                            else if (t.Contains("quản trị") || t.Contains("doanh nghiệp") || t.Contains("kinh doanh"))
                            {
                                category = "Business Management";
                                growthText = "+11.0% Growth";
                                isGrowthPositive = true;
                                gradientClass = "from-amber-400 to-rose-500";
                                thumbIcon = "corporate_fare";
                            }

                            <tr class="hover:bg-slate-50/80 hover:shadow-sm hover:scale-[1.005] transition-all duration-300 group/row stagger-row" style="animation-delay: @(rankIndex * 50)ms;">
                                <td class="pl-8 pr-2 py-4 align-middle text-center">
                                    @if (rankIndex <= 3)
                                    {
                                        <span class="inline-flex items-center justify-center px-2 py-1 rounded-lg text-[9px] font-black tracking-wider uppercase @rankClass hover:scale-105 active:scale-95 transition-all duration-300">
                                            @rankContent
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="@rankClass">@rankContent</span>
                                    }
                                </td>
                                <td class="px-4 py-4 max-w-[320px]">
                                    <div class="flex items-center gap-3.5">
                                        <!-- Mockup High-Fidelity Cover Art Thumbnail -->
                                        <div class="w-10 h-10 bg-gradient-to-br @gradientClass rounded-xl flex items-center justify-center text-white shrink-0 font-bold shadow-sm relative overflow-hidden transition-all duration-300 group-hover/row:scale-110 group-hover/row:rotate-[3deg] group-hover/row:shadow-md">
                                            <span class="material-symbols-outlined text-[20px] font-bold">@thumbIcon</span>
                                        </div>
                                        <div class="flex flex-col min-w-0">
                                            <span class="font-extrabold text-slate-900 group-hover/row:text-[#0f4c43] transition-colors duration-200 truncate leading-snug" title="@TranslateCourseTitle(item.CourseTitle)">
                                                @TranslateCourseTitle(item.CourseTitle)
                                            </span>
                                            <span class="text-[10px] text-slate-400 font-bold mt-0.5">Instructor: @item.InstructorName</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-4 align-middle font-bold text-slate-500">@category</td>
                                <td class="px-4 py-4 align-middle text-center">
                                    <span class="font-black text-slate-900 font-mono text-sm bg-slate-50 px-2.5 py-1 rounded-lg border border-slate-200/50">@item.SalesCount</span>
                                </td>
                                <td class="px-4 py-4 align-middle text-right font-bold text-slate-600 font-mono text-sm">
                                    $@item.MonthlyRevenue.ToString("N2")
                                </td>
                                <td class="px-4 py-4 align-middle text-right font-bold text-slate-600 font-mono text-sm">
                                    $@item.YearlyRevenue.ToString("N2")
                                </td>
                                <td class="px-4 py-4 align-middle text-right font-black text-slate-900 font-mono text-sm">
                                    $@item.LifetimeRevenue.ToString("N2")
                                </td>
                                <td class="pl-4 pr-8 py-4 align-middle text-right">
                                    @if (isGrowthPositive)
                                    {
                                        <span class="inline-flex items-center gap-0.5 px-2.5 py-1 rounded-full text-[9px] font-black bg-emerald-50 text-emerald-600 border border-emerald-100">
                                            @growthText
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-0.5 px-2.5 py-1 rounded-full text-[9px] font-black bg-rose-50 text-rose-600 border border-rose-100">
                                            @growthText
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center justify-center text-slate-400">
                                    <span class="material-symbols-outlined text-6xl mb-4 text-slate-200">payments</span>
                                    <p class="text-base font-bold text-slate-600">No course revenues match your period selection.</p>
                                    <p class="text-xs text-slate-400 mt-1">Change keywords or period filters above to refresh the list.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- High-Fidelity Table Pagination Footer (Matched from Mockup) -->
        <div class="px-8 py-4 border-t border-slate-100 bg-slate-50/20 flex items-center justify-between text-slate-500 font-bold text-[11px]">
            <span>Showing @(Model.Revenues?.Count ?? 0) of @Model.TotalActiveCourses courses</span>
            <div class="flex items-center gap-1.5">
                <button class="w-7 h-7 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:bg-slate-50 active:scale-95 transition-all cursor-pointer">
                    <span class="material-symbols-outlined text-[16px]">chevron_left</span>
                </button>
                <button class="w-7 h-7 rounded-lg bg-slate-900 text-white flex items-center justify-center font-black cursor-pointer">1</button>
                <button class="w-7 h-7 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-700 hover:bg-slate-50 active:scale-95 transition-all cursor-pointer">2</button>
                <button class="w-7 h-7 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-700 hover:bg-slate-50 active:scale-95 transition-all cursor-pointer">3</button>
                <button class="w-7 h-7 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:bg-slate-50 active:scale-95 transition-all cursor-pointer">
                    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const filterForm = document.getElementById('periodFilterForm');
            if (filterForm) {
                const selects = filterForm.querySelectorAll('select');
                selects.forEach(select => {
                    select.addEventListener('change', () => {
                        filterForm.submit();
                    });
                });
            }

            const searchForm = document.getElementById('revenueFilterForm');
            if (searchForm) {
                const sortBySelect = searchForm.querySelector('select[name="sortBy"]');
                sortBySelect.addEventListener('change', () => {
                    ajaxReloadRevenues();
                });
                searchForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    ajaxReloadRevenues();
                });
                
                // Add debounce input search
                let debounceTimer;
                const searchInput = searchForm.querySelector('input[name="keyword"]');
                searchInput.addEventListener('input', () => {
                    clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(() => {
                        ajaxReloadRevenues();
                    }, 350);
                });
            }

            // Draw Initial Line Chart
            drawYearlyChart();
        });

        // ── Yearly Line Chart implementation ─────────────────────────────────
        let yearlyChartInstance = null;
        const yearlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.YearlyMonthlyRevenue));
        const labels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

        function drawYearlyChart(filterYear = 'all') {
            const ctx = document.getElementById('yearlyRevenueChart');
            if (!ctx) return;

            if (yearlyChartInstance) {
                yearlyChartInstance.destroy();
            }

            const datasets = [];

            // Helper to generate sleek gradients
            const getGradient = (colorStart, colorEnd) => {
                const grad = ctx.getContext('2d').createLinearGradient(0, 0, 0, 320);
                grad.addColorStop(0, colorStart);
                grad.addColorStop(1, colorEnd);
                return grad;
            };

            const allYears = [@year1, @year2, @year3];
            const colors = {
                [@year1]: { stroke: '#0f172a', fill: getGradient('rgba(15, 23, 42, 0.06)', 'rgba(15, 23, 42, 0)') },
                [@year2]: { stroke: '#059669', fill: getGradient('rgba(5, 150, 105, 0.06)', 'rgba(5, 150, 105, 0)') },
                [@year3]: { stroke: '#3b82f6', fill: getGradient('rgba(59, 130, 246, 0.06)', 'rgba(59, 130, 246, 0)') }
            };

            allYears.forEach(y => {
                if (filterYear !== 'all' && filterYear !== y.toString()) return;
                
                const data = yearlyData[y] || Array(12).fill(0);
                datasets.push({
                    label: `Year ${y}`,
                    data: data,
                    borderColor: colors[y].stroke,
                    backgroundColor: colors[y].fill,
                    borderWidth: 3,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: colors[y].stroke,
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.4
                });
            });

            yearlyChartInstance = new Chart(ctx, {
                type: 'line',
                data: { labels: labels, datasets: datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1e293b',
                            titleFont: { family: 'Inter', size: 12, weight: 'bold' },
                            bodyFont: { family: 'Inter', size: 13 },
                            padding: 12,
                            cornerRadius: 12,
                            displayColors: true,
                            callbacks: {
                                label: function(context) {
                                    return `${context.dataset.label}: $${context.parsed.y.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#f1f5f9', drawBorder: false },
                            ticks: {
                                font: { family: 'Inter', size: 10, weight: '600' },
                                color: '#94a3b8',
                                callback: function(value) {
                                    if (value >= 1000000) return '$' + (value / 1000000) + 'M';
                                    if (value >= 1000) return '$' + (value / 1000) + 'K';
                                    return '$' + value;
                                }
                            },
                            border: { display: false }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { font: { family: 'Inter', size: 10, weight: '600' }, color: '#64748b' },
                            border: { display: false }
                        }
                    }
                }
            });
        }

        function switchChartFilter() {
            const select = document.getElementById('chartYearSelect');
            if (select) {
                drawYearlyChart(select.value);
            }
        }

        function exportReport() {
            Swal.fire({
                title: 'Export Financial Report',
                text: 'Generating multi-year revenue reconciliation spreadsheet/PDF...',
                icon: 'success',
                showConfirmButton: false,
                timer: 2000,
                timerProgressBar: true
            });
        }

        async function ajaxReloadRevenues() {
            const periodForm = document.getElementById('periodFilterForm');
            const searchForm = document.getElementById('revenueFilterForm');
            if (!periodForm || !searchForm) return;

            // Premium blur loader
            const loader = document.createElement('div');
            loader.className = 'fixed inset-0 bg-slate-900/10 backdrop-blur-[1px] flex items-center justify-center z-[9999] transition-all duration-300 opacity-0';
            loader.innerHTML = `
                <div class="bg-white p-4 rounded-2xl shadow-xl flex items-center gap-3 border border-slate-100 animate-fadeIn">
                    <div class="w-6 h-6 border-2 border-[#0f4c43] border-t-transparent rounded-full animate-spin"></div>
                    <span class="text-xs font-bold text-slate-700">Filtering course list...</span>
                </div>
            `;
            document.body.appendChild(loader);
            setTimeout(() => loader.classList.remove('opacity-0'), 50);

            try {
                const params = new URLSearchParams();
                
                const periodData = new FormData(periodForm);
                for (const [key, value] of periodData.entries()) {
                    if (value) params.set(key, value);
                }

                const searchData = new FormData(searchForm);
                for (const [key, value] of searchData.entries()) {
                    if (value) params.set(key, value);
                }

                const url = `/AdminFinance/InstructorRevenues?${params.toString()}`;
                const response = await fetch(url);
                if (response.ok) {
                    const html = await response.text();
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');

                    // 1. Swap table container
                    const oldTable = document.getElementById('revenue-table-container');
                    const newTable = doc.getElementById('revenue-table-container');
                    if (oldTable && newTable) oldTable.innerHTML = newTable.innerHTML;

                    // 2. Update parent form hidden values
                    const targetYear = params.get('year');
                    const targetMonth = params.get('month');
                    const targetKeyword = params.get('keyword');
                    const targetSortBy = params.get('sortBy');

                    searchForm.querySelector('input[name="year"]').value = targetYear || '';
                    searchForm.querySelector('input[name="month"]').value = targetMonth || '';
                    periodForm.querySelector('input[name="keyword"]').value = targetKeyword || '';
                    periodForm.querySelector('input[name="sortBy"]').value = targetSortBy || 'sales_desc';

                    // 3. Push state
                    history.pushState(null, '', url);
                }
            } catch (err) {
                console.error("AJAX error:", err);
            } finally {
                loader.classList.add('opacity-0');
                setTimeout(() => loader.remove(), 300);
            }
        }
    </script>
}
