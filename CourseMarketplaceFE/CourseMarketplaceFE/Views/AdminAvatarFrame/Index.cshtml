@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Avatar Frames";
}

<div class="p-8">
    <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-slate-800">Manage & Grant Avatar Frames</h1>
        <p class="text-slate-500">Grant dynamic frame ownership to special learners.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- FORM TẶNG KHUNG -->
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
            <div class="flex items-center gap-3 mb-6">
                <div class="bg-amber-100 p-3 rounded-2xl text-amber-600">
                    <span class="material-symbols-outlined">card_giftcard</span>
                </div>
                <h2 class="text-xl font-bold text-slate-800">Grant Frame to User</h2>
            </div>

            <form id="grantFrameForm" class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">User ID (GUID)</label>
                    <input type="text" id="userId" required 
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-primary/20 outline-none"
                           placeholder="Enter user identifier...">
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Select Avatar Frame</label>
                    <select id="frameId" required
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-primary/20 outline-none bg-white">
                        <option value="">Loading frames list...</option>
                    </select>
                </div>

                <button type="submit" 
                        class="w-full py-4 bg-primary text-white font-bold rounded-2xl hover:opacity-90 transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">send</span>
                    Confirm Grant Frame
                </button>
            </form>
        </div>

        <!-- DANH SÁCH KHUNG ĐANG CÓ -->
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm">
            <div class="flex items-center gap-3 mb-6">
                <div class="bg-indigo-100 p-3 rounded-2xl text-indigo-600">
                    <span class="material-symbols-outlined">category</span>
                </div>
                <h2 class="text-xl font-bold text-slate-800">System Frames List</h2>
            </div>

            <div id="framesList" class="grid grid-cols-2 gap-4">
                <!-- Sẽ load bằng JS -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE = "/api/admin/avatar-frames";
        const token = "@Html.Raw(Context.Request.Cookies["AccessToken"])";

        // 1. Load danh sách khung
        async function loadFrames() {
            try {
                const res = await fetch(`${API_BASE}/list`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const result = await res.json();
                const frames = result.data;

                // Cập nhật Select
                const select = document.getElementById('frameId');
                select.innerHTML = '<option value="">-- Select frame --</option>' + 
                    frames.map(f => `<option value="${f.id}">${f.name}</option>`).join('');

                // Cập nhật List preview
                const list = document.getElementById('framesList');
                list.innerHTML = frames.map(f => `
                    <div class="p-4 border border-slate-100 rounded-2xl flex flex-col items-center gap-2">
                        <img src="${f.imageUrl}" class="w-16 h-16 object-contain" />
                        <span class="text-xs font-bold text-slate-600">${f.name}</span>
                        <span class="text-[10px] text-slate-400">ID: ${f.id}</span>
                    </div>
                `).join('');
            } catch (err) {
                console.error("Error loading frames:", err);
            }
        }

        // 2. Xử lý submit tặng khung
        document.getElementById('grantFrameForm').onsubmit = async (e) => {
            e.preventDefault();
            const data = {
                userId: document.getElementById('userId').value,
                frameId: parseInt(document.getElementById('frameId').value)
            };

            try {
                const res = await fetch(`${API_BASE}/grant`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                
                if (res.ok) {
                    Swal.fire({
                        title: 'Frame Granted Successfully!',
                        text: result.message || "The avatar frame was successfully granted to the user.",
                        icon: 'success',
                        confirmButtonColor: '#10b981',
                        background: '#ffffff',
                        customClass: { popup: 'rounded-2xl shadow-xl' }
                    });
                    e.target.reset();
                } else {
                    Swal.fire({
                        title: 'Grant Frame Failed',
                        text: result.message || "An error occurred while granting the frame.",
                        icon: 'error',
                        confirmButtonColor: '#10b981',
                        background: '#ffffff',
                        customClass: { popup: 'rounded-2xl shadow-xl' }
                    });
                }
            } catch (err) {
                Swal.fire({
                    title: 'Connection Error',
                    text: "Could not connect to the frame management server.",
                    icon: 'error',
                    confirmButtonColor: '#10b981',
                    background: '#ffffff',
                    customClass: { popup: 'rounded-2xl shadow-xl' }
                });
            }
        };

        loadFrames();
    </script>
}
