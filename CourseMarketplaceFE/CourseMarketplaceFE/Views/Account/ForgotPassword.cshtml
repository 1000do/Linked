@{
    ViewData["Title"] = "Quên mật khẩu";
}

<main class="flex-grow flex items-center justify-center px-6 py-12 min-h-[70vh]">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-xl shadow-[0px_12px_32px_rgba(19,29,30,0.04)] p-8 md:p-10 relative overflow-hidden">
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary-container/20 rounded-full blur-3xl"></div>
            <div class="relative z-10">
                <div class="mb-8 flex justify-center">
                    <div class="w-16 h-16 rounded-full bg-surface-container-low flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary text-3xl">lock_reset</span>
                    </div>
                </div>
                <div class="text-center mb-8">
                    <h1 class="font-headline font-extrabold text-3xl text-on-surface tracking-tight mb-3">Quên mật khẩu?</h1>
                    <p class="text-slate-500 text-sm leading-relaxed">
                        Nhập email của bạn để nhận mã OTP xác thực.
                    </p>
                </div>

                <form asp-action="ForgotPassword" method="post" class="space-y-6">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl text-sm">
                            @ViewBag.ErrorMessage
                        </div>
                    }

                    <div class="space-y-2">
                        <label class="block text-xs font-bold uppercase text-slate-500 px-1">Email Address</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">mail</span>

                            <!-- QUAN TRỌNG: name="email" -->
                            <input name="email"
                                   class="w-full pl-12 pr-4 py-4 bg-slate-50 border-none rounded-lg focus:ring-2 focus:ring-primary/20 outline-none transition-all"
                                   placeholder="yourname@gmail.com"
                                   required
                                   type="email" />
                        </div>
                    </div>

                    <button class="w-full bg-gradient-to-br from-primary to-primary-container text-white font-headline font-bold py-4 rounded-full shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all"
                            type="submit">
                        Gửi mã OTP
                    </button>
                </form>

                <div class="mt-8 text-center">
                    <a class="inline-flex items-center gap-2 text-primary font-semibold hover:gap-3 transition-all text-sm" href="/Account/Login">
                        <span class="material-symbols-outlined text-lg">arrow_back</span> Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</main>