@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<main class="flex-grow flex items-center justify-center px-4 py-12 min-h-[70vh]">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-lg p-8 shadow-[0px_12px_32px_rgba(19,29,30,0.04)]">
            <div class="mb-8 text-center">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary-container/20 mb-4">
                    <span class="material-symbols-outlined text-primary text-3xl">lock_reset</span>
                </div>
                <h1 class="font-headline text-3xl font-extrabold text-on-surface mb-2">Reset Password</h1>
                <p class="text-slate-500 text-sm">Create a strong, unique password for your account.</p>
            </div>
            <form class="space-y-6">
                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase text-slate-500">New Password</label>
                    <input class="w-full px-4 py-3 bg-slate-50 border-none rounded-lg focus:ring-2 focus:ring-primary/20 outline-none" placeholder="••••••••" type="password" />
                </div>
                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase text-slate-500">Confirm Password</label>
                    <input class="w-full px-4 py-3 bg-slate-50 border-none rounded-lg focus:ring-2 focus:ring-primary/20 outline-none" placeholder="••••••••" type="password" />
                </div>
                <button class="w-full bg-gradient-to-br from-primary to-primary-container text-white font-bold py-4 rounded-full shadow-lg hover:shadow-xl transition-all" type="submit">
                    Reset Password
                </button>
            </form>
        </div>
    </div>
</main>