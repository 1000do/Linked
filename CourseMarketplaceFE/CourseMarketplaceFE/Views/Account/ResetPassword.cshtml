@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    var email = ViewBag.Email as string;
    var otp = ViewBag.Otp as string;
}

<main class="flex-grow flex items-center justify-center px-4 py-12 min-h-[70vh]">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-lg p-8 shadow-[0px_12px_32px_rgba(19,29,30,0.04)]">

            <!-- HEADER -->
            <div class="mb-8 text-center">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary-container/20 mb-4">
                    <span class="material-symbols-outlined text-primary text-3xl">lock_reset</span>
                </div>
                <h1 class="font-headline text-3xl font-extrabold text-on-surface mb-2">
                    Đặt lại mật khẩu
                </h1>
                <p class="text-slate-500 text-sm">
                    Tạo mật khẩu mới cho tài khoản của bạn.
                </p>
            </div>

            <!-- ERROR -->
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl text-sm mb-4">
                    @ViewBag.ErrorMessage
                </div>
            }

            <!-- FORM -->
            <form asp-action="ResetPassword" method="post" class="space-y-6">

                <!-- hidden data -->
                <input type="hidden" name="email" value="@ViewBag.Email" />
                <input type="hidden" name="otp" value="@ViewBag.Otp" />

                <!-- NEW PASSWORD -->
                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase text-slate-500">
                        Mật khẩu mới
                    </label>
                    <input name="newPassword"
                           id="newPassword"
                           class="w-full px-4 py-3 bg-slate-50 border-none rounded-lg focus:ring-2 focus:ring-primary/20 outline-none"
                           placeholder="••••••••"
                           type="password"
                           required />
                </div>

                <!-- CONFIRM -->
                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase text-slate-500">
                        Xác nhận mật khẩu
                    </label>
                    <input id="confirmPassword"
                           class="w-full px-4 py-3 bg-slate-50 border-none rounded-lg focus:ring-2 focus:ring-primary/20 outline-none"
                           placeholder="••••••••"
                           type="password"
                           required />
                </div>

                <!-- ERROR CONFIRM -->
                <div id="confirmError" class="text-red-500 text-sm hidden">
                    Mật khẩu không khớp
                </div>

                <button class="w-full bg-gradient-to-br from-primary to-primary-container text-white font-bold py-4 rounded-full shadow-lg hover:shadow-xl transition-all"
                        type="submit">
                    Đổi mật khẩu
                </button>
            </form>
        </div>
    </div>
</main>

<script>
    const form = document.querySelector("form");
    const newPass = document.getElementById("newPassword");
    const confirmPass = document.getElementById("confirmPassword");
    const error = document.getElementById("confirmError");

    form.addEventListener("submit", function (e) {
        if (newPass.value !== confirmPass.value) {
            e.preventDefault();
            error.classList.remove("hidden");
        }
    });
</script>