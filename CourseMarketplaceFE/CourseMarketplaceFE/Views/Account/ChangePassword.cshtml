@{
    ViewData["Title"] = "Change Password";
}

<div class="min-h-screen bg-[#f8fafc] relative overflow-hidden pb-16">
    @* Decorative background elements *@
    <div class="absolute top-0 left-0 w-full h-64 bg-gradient-to-br from-primary/5 to-transparent -z-10"></div>
    <div class="absolute top-40 -right-20 w-80 h-80 bg-primary/5 rounded-full blur-3xl -z-10"></div>
    
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 relative">
        <div class="flex flex-col lg:flex-row gap-10">
            @* Sidebar *@
            @await Html.PartialAsync("_AccountSidebar", "ChangePassword")

            @* Main Content *@
            <div class="flex-grow space-y-8">
                <div>
                    <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-2">Change Password</h1>
                    <p class="text-slate-500 font-medium">Update your password to protect your account and keep it secure.</p>
                </div>

            <section class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100 max-w-2xl">
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="bg-red-50 text-red-500 px-6 py-4 rounded-2xl font-medium flex items-center gap-3 mb-6">
                        <span class="material-symbols-outlined">error</span>
                        @ViewBag.ErrorMessage
                    </div>
                }

                <form action="/Account/ChangePassword" method="post" class="space-y-6" id="changePasswordForm">
                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase text-slate-400 ml-1">Current Password</label>
                        <div class="relative">
                            <span class="absolute left-5 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 text-lg">password</span>
                            <input type="password" name="currentPassword" required class="w-full bg-slate-50 border-none rounded-2xl pl-12 pr-5 py-4 focus:ring-2 focus:ring-primary/20 transition-all" placeholder="Enter current password" />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase text-slate-400 ml-1">New Password</label>
                        <div class="relative">
                            <span class="absolute left-5 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 text-lg">lock</span>
                            <input type="password" name="newPassword" id="newPwd" required minlength="6" class="w-full bg-slate-50 border-none rounded-2xl pl-12 pr-5 py-4 focus:ring-2 focus:ring-primary/20 transition-all" placeholder="Enter new password (minimum 6 characters)" />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase text-slate-400 ml-1">Confirm New Password</label>
                        <div class="relative">
                            <span class="absolute left-5 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 text-lg">lock_check</span>
                            <input type="password" name="confirmNewPassword" id="confirmPwd" required minlength="6" class="w-full bg-slate-50 border-none rounded-2xl pl-12 pr-5 py-4 focus:ring-2 focus:ring-primary/20 transition-all" placeholder="Confirm new password" />
                        </div>
                        <p id="pwdError" class="text-xs text-red-500 font-medium ml-1 hidden mt-1">Confirm password does not match!</p>
                    </div>

                    <div class="pt-6">
                        <button type="submit" class="px-10 py-4 w-full md:w-auto bg-primary text-white font-bold rounded-2xl shadow-lg shadow-primary/20 hover:opacity-90 active:scale-95 transition-all">
                            Update Password
                        </button>
                    </div>
                </form>
            </section>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
            const newPwd = document.getElementById('newPwd').value;
            const confirmPwd = document.getElementById('confirmPwd').value;
            const errorMsg = document.getElementById('pwdError');
            
            if (newPwd !== confirmPwd) {
                e.preventDefault();
                errorMsg.classList.remove('hidden');
                document.getElementById('confirmPwd').classList.add('ring-2', 'ring-red-500/50');
            } else {
                errorMsg.classList.add('hidden');
                document.getElementById('confirmPwd').classList.remove('ring-2', 'ring-red-500/50');
            }
        });
    </script>
}
