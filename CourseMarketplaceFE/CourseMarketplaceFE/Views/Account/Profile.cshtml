@model LinkedLearn.Models.UserVM.UserProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    var userRole = (Context.Request.Cookies["UserRole"] ?? "learner").ToLower();
}

<div class="min-h-screen bg-[#f8fafc] relative overflow-hidden pb-16">
    @* Decorative background elements *@
    <div class="absolute top-0 left-0 w-full h-64 bg-gradient-to-br from-primary/5 to-transparent -z-10"></div>
    <div class="absolute top-40 -right-20 w-80 h-80 bg-primary/5 rounded-full blur-3xl -z-10"></div>
    
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 relative">
        <div class="flex flex-col lg:flex-row gap-10">
            @* Sidebar *@
            @await Html.PartialAsync("_AccountSidebar", "Profile")

            @* Main Content *@
            <div class="flex-grow space-y-8">
                <div>
                    <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-2">My Profile</h1>
                    <p class="text-slate-500 font-medium">View and manage your public profile information.</p>
                </div>

            <section class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100 flex flex-col md:flex-row items-center gap-8">
                @await Html.PartialAsync("_UserAvatar", new { 
                    Url = Model.AvatarUrl, 
                    Role = userRole, 
                    Name = Model.FullName, 
                    Size = "2xl",
                    ShowFrame = true,
                    FrameUrl = ""
                })
                @if(userRole == "admin" || userRole == "staff") {
                    <div class="absolute -top-2 -right-2 bg-amber-500 text-white text-[10px] font-bold px-2 py-1 rounded-full shadow-lg animate-bounce z-20">
                        PREMIUM FRAME
                    </div>
                }
                <div class="flex-grow text-center md:text-left">
                    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-4">
                        <div>
                            <h2 class="text-3xl font-bold text-slate-800">@Model.FullName</h2>
                            <p class="text-primary font-medium">@Model.Email</p>

                            @if (!Model.IsVerified)
                            {
                                <div class="mt-2 flex items-center gap-3">
                                    <span class="text-red-500 text-sm font-semibold">
                                        Email unverified
                                    </span>

                                    <a href="/Account/SendVerifyOtp"
                                       class="bg-red-500 text-white px-4 py-1.5 rounded-lg text-sm font-bold hover:opacity-90">
                                        Verify
                                    </a>
                                </div>
                            }
                            else
                            {
                                <span class="text-green-500 text-sm font-semibold">
                                    ✔ Verified
                                </span>
                            }

                        </div>
                        <a href="/Account/EditProfile" class="bg-primary text-white px-6 py-2.5 rounded-xl font-bold hover:opacity-90 transition-all flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">edit</span> Edit Profile
                        </a>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100">
                        <p class="text-sm italic text-slate-600">@(string.IsNullOrEmpty(Model.Bio) ? "No bio written yet." : Model.Bio)</p>
                    </div>
                </div>
            </section>

            @* Thêm thông tin liên hệ *@
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
                    <div class="bg-blue-50 p-3 rounded-2xl text-blue-600"><span class="material-symbols-outlined">call</span></div>
                    <div>
                        <p class="text-xs text-slate-400 font-bold uppercase">Phone Number</p>
                        <p class="font-bold text-slate-700">@(Model.PhoneNumber ?? "Not updated")</p>
                    </div>
                </div>
            </div>

            @* ── BỘ SƯU TẬP KHUNG AVATAR ────────────────────────── *@
            <section class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100">
                <div class="flex items-center gap-3 mb-8">
                    <div class="bg-amber-100 p-3 rounded-2xl">
                        <span class="material-symbols-outlined text-amber-600 text-xl">military_tech</span>
                    </div>
                    <div>
                        <h3 class="text-xl font-extrabold text-slate-800">Avatar Frames & Achievements</h3>
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-widest">Showcase your status</p>
                    </div>
                </div>

                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
                    <!-- Khung hiện tại -->
                    <div class="relative p-4 rounded-3xl border-2 border-primary bg-primary/5 flex flex-col items-center gap-3">
                        @await Html.PartialAsync("_UserAvatar", new { 
                            Url = Model.AvatarUrl, 
                            Role = userRole, 
                            Name = Model.FullName, 
                            Size = "xl",
                            ShowFrame = true,
                            FrameUrl = ""
                        })
                        <span class="text-[10px] font-extrabold text-primary uppercase mt-2">Active</span>
                        <p class="text-xs font-bold text-slate-700">@userRole.ToUpper() Frame</p>
                    </div>

                    <!-- Khung khóa (Dành cho sự kiện) -->
                    <div class="relative p-4 rounded-3xl border border-slate-100 bg-slate-50/50 opacity-60 flex flex-col items-center gap-3 group grayscale hover:grayscale-0 transition-all cursor-not-allowed">
                        <div class="absolute inset-0 flex items-center justify-center z-10">
                            <span class="material-symbols-outlined text-slate-400 group-hover:hidden">lock</span>
                        </div>
                        <div class="w-20 h-20 border-2 border-slate-100 rounded-2xl flex items-center justify-center bg-white">
                            <span class="material-symbols-outlined text-slate-200 text-4xl">workspace_premium</span>
                        </div>
                        <span class="text-[10px] font-extrabold text-slate-400 uppercase">Locked</span>
                        <p class="text-xs font-bold text-slate-500">Top Learner</p>
                    </div>
                    
                    <div class="relative p-4 rounded-3xl border border-slate-100 bg-slate-50/50 opacity-60 flex flex-col items-center gap-3 group grayscale hover:grayscale-0 transition-all cursor-not-allowed">
                        <div class="absolute inset-0 flex items-center justify-center z-10">
                            <span class="material-symbols-outlined text-slate-400 group-hover:hidden">lock</span>
                        </div>
                        <div class="w-20 h-20 border-2 border-slate-100 rounded-2xl flex items-center justify-center bg-white">
                            <span class="material-symbols-outlined text-slate-200 text-4xl">local_fire_department</span>
                        </div>
                        <span class="text-[10px] font-extrabold text-slate-400 uppercase">Locked</span>
                        <p class="text-xs font-bold text-slate-500">7-Day Streak</p>
                    </div>
                </div>
            </section>

            @* ── THÔNG TIN GIẢNG VIÊN ────────────────────────────── *@
            @if (Model.IsInstructor)
            {
                @* Đã đăng ký giảng viên → hiển thị thông tin *@
                <section class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100">
                    <div class="flex items-center justify-between mb-6">
                        <div class="flex items-center gap-3">
                            <div class="bg-gradient-to-br from-primary to-secondary p-3 rounded-2xl">
                                <span class="material-symbols-outlined text-white text-xl">school</span>
                            </div>
                            <h3 class="text-xl font-extrabold text-slate-800">Instructor Profile</h3>
                        </div>

                        @* Badge trạng thái *@
                        @{
                            var statusColor = Model.ApprovalStatus switch
                            {
                                "Approved" => "bg-green-100 text-green-700",
                                "Rejected" => "bg-red-100 text-red-700",
                                _ => "bg-amber-100 text-amber-700"
                            };
                            var statusText = Model.ApprovalStatus switch
                            {
                                "Approved" => "✔ Approved",
                                "Rejected" => "✘ Rejected",
                                _ => "⏳ Pending Approval"
                            };
                        }
                        <span class="px-4 py-1.5 rounded-full text-xs font-bold @statusColor">
                            @statusText
                        </span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="material-symbols-outlined text-primary text-lg">badge</span>
                                <p class="text-xs text-slate-400 font-bold uppercase">Professional Title</p>
                            </div>
                            <p class="font-bold text-slate-700">@(Model.ProfessionalTitle ?? "Not updated")</p>
                        </div>

                        <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="material-symbols-outlined text-primary text-lg">category</span>
                                <p class="text-xs text-slate-400 font-bold uppercase">Expertise Area</p>
                            </div>
                            <p class="font-bold text-slate-700">@(Model.ExpertiseCategories ?? "Not updated")</p>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.LinkedinUrl))
                        {
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100 md:col-span-2">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="material-symbols-outlined text-primary text-lg">link</span>
                                    <p class="text-xs text-slate-400 font-bold uppercase">LinkedIn Profile</p>
                                </div>
                                <a href="@Model.LinkedinUrl" target="_blank"
                                   class="font-bold text-primary hover:underline break-all">
                                    @Model.LinkedinUrl
                                </a>
                            </div>
                        }
                    </div>

                    @if (Model.ApprovalStatus == "Rejected")
                    {
                        <div class="mt-6 pt-6 border-t border-slate-100 flex items-center justify-between">
                            <p class="text-sm text-slate-500">Your application has been rejected. You can resubmit again.</p>
                            <a href="/Instructor/Apply"
                               class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-xl hover:scale-[1.01] active:scale-[0.99] transition-all text-sm">
                                <span class="material-symbols-outlined text-lg">refresh</span>
                                Resubmit Application
                            </a>
                        </div>
                    }
                </section>
            }
            else
            {
                @* Chưa đăng ký giảng viên → hiển thị section bị khóa *@
                <section class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100 relative overflow-hidden">
                    @* Overlay mờ *@
                    <div class="absolute inset-0 bg-slate-50/80 backdrop-blur-[2px] z-10 flex flex-col items-center justify-center">
                        <div class="text-center">
                            <div class="inline-flex items-center justify-center w-16 h-16 bg-slate-200 rounded-full mb-4">
                                <span class="material-symbols-outlined text-slate-400 text-3xl">lock</span>
                            </div>
                            <h3 class="text-lg font-bold text-slate-600 mb-2">Not Registered as Instructor</h3>
                            <p class="text-sm text-slate-500 mb-5 max-w-sm">
                                Apply to become an instructor to unlock professional details and publish courses.
                            </p>
                            <a href="/Instructor/Apply"
                               class="inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-xl hover:scale-[1.01] active:scale-[0.99] transition-all duration-300 text-sm">
                                <span class="material-symbols-outlined text-lg">school</span>
                                Apply to Become Instructor
                            </a>
                        </div>
                    </div>

                    @* Nội dung placeholder phía dưới (bị mờ) *@
                    <div class="opacity-40 pointer-events-none select-none">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="bg-gradient-to-br from-primary to-secondary p-3 rounded-2xl">
                                <span class="material-symbols-outlined text-white text-xl">school</span>
                            </div>
                            <h3 class="text-xl font-extrabold text-slate-800">Instructor Profile</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                                <p class="text-xs text-slate-400 font-bold uppercase mb-2">Professional Title</p>
                                <div class="h-5 bg-slate-200 rounded-lg w-3/4"></div>
                            </div>
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                                <p class="text-xs text-slate-400 font-bold uppercase mb-2">Expertise Area</p>
                                <div class="h-5 bg-slate-200 rounded-lg w-2/3"></div>
                            </div>
                        </div>
                    </div>
                </section>
            }
            </div>
        </div>
    </div>
</div>