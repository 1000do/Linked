@model LinkedLearn.Models.UserVM.UserProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="max-w-7xl mx-auto px-6 lg:px-12 py-10">
    <div class="flex flex-col lg:flex-row gap-8">
        <aside class="w-full lg:w-72 flex-shrink-0">
            <div class="bg-white rounded-[2rem] p-6 shadow-sm border border-slate-100 sticky top-24">
                <nav class="flex flex-col gap-2">
                    <a href="/Account/Profile" class="flex items-center gap-4 px-4 py-3 rounded-2xl bg-primary-container/30 text-primary font-bold transition-all">
                        <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>person</span>
                        <span>Profile</span>
                    </a>
                    <a href="/Account/EditProfile" class="flex items-center gap-4 px-4 py-3 rounded-2xl text-slate-500 hover:bg-slate-50 transition-all">
                        <span class="material-symbols-outlined">edit_square</span>
                        <span>Edit Profile</span>
                    </a>
                    <a href="/Account/ChangePassword" class="flex items-center gap-4 px-4 py-3 rounded-2xl text-slate-500 hover:bg-slate-50 transition-all mt-2 border-t border-slate-100 pt-4">
                        <span class="material-symbols-outlined">lock</span>
                        <span>Đổi mật khẩu</span>
                    </a>
                </nav>
            </div>
        </aside>

        <div class="flex-grow space-y-8">
            <div class="mb-4">
                <h1 class="text-3xl font-extrabold text-slate-800">My Profile</h1>
            </div>

            <section class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100 flex flex-col md:flex-row items-center gap-8">
                <div class="relative">
                    <div class="w-32 h-32 rounded-[2rem] overflow-hidden ring-4 ring-slate-50 shadow-lg">
                        <img class="w-full h-full object-cover" src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? $"https://ui-avatars.com/api/?name={Model.FullName}&background=006a62&color=fff" : Model.AvatarUrl)" />
                    </div>
                </div>
                <div class="flex-grow text-center md:text-left">
                    <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-4">
                        <div>
                            <h2 class="text-3xl font-bold text-slate-800">@Model.FullName</h2>
                            <p class="text-primary font-medium">@Model.Email</p>

                            @if (!Model.IsVerified)
                            {
                                <div class="mt-2 flex items-center gap-3">
                                    <span class="text-red-500 text-sm font-semibold">
                                        Email chưa xác thực
                                    </span>

                                    <a href="/Account/SendVerifyOtp"
                                       class="bg-red-500 text-white px-4 py-1.5 rounded-lg text-sm font-bold hover:opacity-90">
                                        Xác thực
                                    </a>
                                </div>
                            }
                            else
                            {
                                <span class="text-green-500 text-sm font-semibold">
                                    ✔ Đã xác thực
                                </span>
                            }

                        </div>
                        <a href="/Account/EditProfile" class="bg-primary text-white px-6 py-2.5 rounded-xl font-bold hover:opacity-90 transition-all flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">edit</span> Edit Profile
                        </a>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100">
                        <p class="text-sm italic text-slate-600">@(string.IsNullOrEmpty(Model.Bio) ? "Chưa có giới thiệu." : Model.Bio)</p>
                    </div>
                </div>
            </section>

            @* Thêm thông tin liên hệ *@
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
                    <div class="bg-blue-50 p-3 rounded-2xl text-blue-600"><span class="material-symbols-outlined">call</span></div>
                    <div>
                        <p class="text-xs text-slate-400 font-bold uppercase">Số điện thoại</p>
                        <p class="font-bold text-slate-700">@(Model.PhoneNumber ?? "Chưa cập nhật")</p>
                    </div>
                </div>
                <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
                    <div class="bg-purple-50 p-3 rounded-2xl text-purple-600"><span class="material-symbols-outlined">calendar_today</span></div>
                    <div>
                        <p class="text-xs text-slate-400 font-bold uppercase">Ngày sinh</p>
                        <p class="font-bold text-slate-700">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</p>
                    </div>
                </div>
            </div>

            @* ── THÔNG TIN GIẢNG VIÊN ────────────────────────────── *@
            @if (Model.IsInstructor)
            {
                @* Đã đăng ký giảng viên → hiển thị thông tin *@
                <section class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100">
                    <div class="flex items-center justify-between mb-6">
                        <div class="flex items-center gap-3">
                            <div class="bg-gradient-to-br from-primary to-secondary p-3 rounded-2xl">
                                <span class="material-symbols-outlined text-white text-xl">school</span>
                            </div>
                            <h3 class="text-xl font-extrabold text-slate-800">Thông tin Giảng viên</h3>
                        </div>

                        @* Badge trạng thái *@
                        @{
                            var statusColor = Model.ApprovalStatus switch
                            {
                                "Approved" => "bg-green-100 text-green-700",
                                "Rejected" => "bg-red-100 text-red-700",
                                _ => "bg-amber-100 text-amber-700"
                            };
                            var statusText = Model.ApprovalStatus switch
                            {
                                "Approved" => "✔ Đã duyệt",
                                "Rejected" => "✘ Bị từ chối",
                                _ => "⏳ Đang chờ duyệt"
                            };
                        }
                        <span class="px-4 py-1.5 rounded-full text-xs font-bold @statusColor">
                            @statusText
                        </span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="material-symbols-outlined text-primary text-lg">badge</span>
                                <p class="text-xs text-slate-400 font-bold uppercase">Chức danh chuyên môn</p>
                            </div>
                            <p class="font-bold text-slate-700">@(Model.ProfessionalTitle ?? "Chưa cập nhật")</p>
                        </div>

                        <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="material-symbols-outlined text-primary text-lg">category</span>
                                <p class="text-xs text-slate-400 font-bold uppercase">Lĩnh vực chuyên môn</p>
                            </div>
                            <p class="font-bold text-slate-700">@(Model.ExpertiseCategories ?? "Chưa cập nhật")</p>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.LinkedinUrl))
                        {
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100 md:col-span-2">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="material-symbols-outlined text-primary text-lg">link</span>
                                    <p class="text-xs text-slate-400 font-bold uppercase">LinkedIn</p>
                                </div>
                                <a href="@Model.LinkedinUrl" target="_blank"
                                   class="font-bold text-primary hover:underline break-all">
                                    @Model.LinkedinUrl
                                </a>
                            </div>
                        }
                    </div>

                    @if (Model.ApprovalStatus == "Rejected")
                    {
                        <div class="mt-6 pt-6 border-t border-slate-100 flex items-center justify-between">
                            <p class="text-sm text-slate-500">Đơn đăng ký đã bị từ chối. Bạn có thể nộp lại đơn.</p>
                            <a href="/Instructor/Apply"
                               class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-xl hover:scale-[1.01] active:scale-[0.99] transition-all text-sm">
                                <span class="material-symbols-outlined text-lg">refresh</span>
                                Nộp lại đơn
                            </a>
                        </div>
                    }
                </section>
            }
            else
            {
                @* Chưa đăng ký giảng viên → hiển thị section bị khóa *@
                <section class="bg-white rounded-[2.5rem] p-8 md:p-10 shadow-sm border border-slate-100 relative overflow-hidden">
                    @* Overlay mờ *@
                    <div class="absolute inset-0 bg-slate-50/80 backdrop-blur-[2px] z-10 flex flex-col items-center justify-center">
                        <div class="text-center">
                            <div class="inline-flex items-center justify-center w-16 h-16 bg-slate-200 rounded-full mb-4">
                                <span class="material-symbols-outlined text-slate-400 text-3xl">lock</span>
                            </div>
                            <h3 class="text-lg font-bold text-slate-600 mb-2">Chưa đăng ký Giảng viên</h3>
                            <p class="text-sm text-slate-500 mb-5 max-w-sm">
                                Trở thành giảng viên để mở khóa thông tin chuyên môn và bắt đầu tạo khóa học.
                            </p>
                            <a href="/Instructor/Apply"
                               class="inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-xl hover:scale-[1.01] active:scale-[0.99] transition-all duration-300 text-sm">
                                <span class="material-symbols-outlined text-lg">school</span>
                                Đăng ký làm Giảng viên
                            </a>
                        </div>
                    </div>

                    @* Nội dung placeholder phía dưới (bị mờ) *@
                    <div class="opacity-40 pointer-events-none select-none">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="bg-gradient-to-br from-primary to-secondary p-3 rounded-2xl">
                                <span class="material-symbols-outlined text-white text-xl">school</span>
                            </div>
                            <h3 class="text-xl font-extrabold text-slate-800">Thông tin Giảng viên</h3>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                                <p class="text-xs text-slate-400 font-bold uppercase mb-2">Chức danh chuyên môn</p>
                                <div class="h-5 bg-slate-200 rounded-lg w-3/4"></div>
                            </div>
                            <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100">
                                <p class="text-xs text-slate-400 font-bold uppercase mb-2">Lĩnh vực chuyên môn</p>
                                <div class="h-5 bg-slate-200 rounded-lg w-2/3"></div>
                            </div>
                        </div>
                    </div>
                </section>
            }
        </div>
    </div>
</div>