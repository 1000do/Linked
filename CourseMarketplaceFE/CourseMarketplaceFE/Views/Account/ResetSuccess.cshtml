@{
    ViewData["Title"] = "Thành công";
}

<main class="w-full max-w-md mx-auto py-20">
    <div class="bg-white p-10 md:p-12 rounded-xl shadow-[0px_12px_32px_rgba(19,29,30,0.04)] text-center relative overflow-hidden">
        <div class="mb-8 flex justify-center">
            <div class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center">
                <span class="material-symbols-outlined text-emerald-600 text-6xl">check_circle</span>
            </div>
        </div>
        <div class="space-y-4 mb-10">
            <h2 class="font-headline text-3xl font-bold text-on-surface">Password Updated</h2>
            <p class="text-slate-500">Your password has been updated. You can now log in with your new credentials.</p>
        </div>
        <a class="inline-flex items-center justify-center w-full px-8 py-4 bg-gradient-to-br from-primary to-primary-container text-white font-bold rounded-full shadow-lg hover:scale-[0.98] transition-transform" href="/Account/Login">
            Back to Login
        </a>
    </div>
</main>