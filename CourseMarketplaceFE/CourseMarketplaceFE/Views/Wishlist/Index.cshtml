@model List<CourseMarketplaceFE.Controllers.WishlistResponse>
@{
    ViewData["Title"] = "My Wishlist";
}

<div class="min-h-screen bg-[#f8fafc] relative overflow-hidden pb-16">
    @* Decorative background elements *@
    <div class="absolute top-0 left-0 w-full h-64 bg-gradient-to-br from-primary/5 to-transparent -z-10"></div>
    <div class="absolute top-40 -right-20 w-80 h-80 bg-primary/5 rounded-full blur-3xl -z-10"></div>
    
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 relative">
        <div class="flex flex-col lg:flex-row gap-10">
            @* Sidebar *@
            @await Html.PartialAsync("_AccountSidebar", "Wishlist")

            @* Main Content *@
            <div class="flex-grow space-y-8">
                <!-- Header Section -->
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
                    <div>
                        <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-2">My Wishlist</h1>
                        <p class="text-slate-500 font-medium">Courses you've saved to explore and learn later.</p>
                    </div>
                    <div class="flex items-center gap-2 text-primary font-bold bg-white border border-slate-100 px-4 py-2 rounded-2xl shadow-sm">
                        <span class="material-symbols-outlined text-[20px]" style='font-variation-settings:"FILL" 1;'>favorite</span>
                        <span>@Model.Count courses</span>
                    </div>
                </div>

        @if (Model == null || !Model.Any())
        {
            @* ── Empty State ─────────────────────────────────────────── *@
            <div class="bg-white rounded-3xl border border-dashed border-slate-200 p-20 text-center shadow-sm">
                <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-slate-50 text-slate-200 mb-6">
                    <span class="material-symbols-outlined text-5xl" style='font-variation-settings: "FILL" 1;'>favorite</span>
                </div>
                <h3 class="text-2xl font-bold text-slate-800 mb-3">Your Wishlist is Empty</h3>
                <p class="text-slate-500 max-w-sm mx-auto mb-10 leading-relaxed">
                    You haven't saved any courses yet. Start exploring thousands of high-quality courses today!
                </p>
                <a href="/Course" class="inline-flex items-center gap-2 bg-primary text-white font-bold px-10 py-4 rounded-2xl shadow-lg shadow-primary/20 hover:shadow-xl hover:scale-105 active:scale-95 transition-all duration-300">
                    <span class="material-symbols-outlined">explore</span>
                    Explore Now
                </a>
            </div>
        }
        else
        {
            @* ── Wishlist Search, Sort, Filter Bar ───────────────────── *@
            <div class="bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex flex-col md:flex-row items-center gap-4 mb-8">
                <div class="relative w-full md:w-1/3">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                    <input type="text" id="wishlist-search" placeholder="Search by course title or instructor..." 
                           class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-800 placeholder:text-slate-400 bg-slate-50 focus:bg-white" />
                </div>
                
                <div class="flex flex-wrap items-center gap-4 w-full md:w-auto md:ml-auto">
                    <div class="relative w-full sm:w-auto">
                        <select id="wishlist-filter-price" class="w-full sm:w-auto appearance-none border border-slate-200 rounded-xl pl-4 pr-10 py-2.5 text-sm font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-700 cursor-pointer">
                            <option value="all">All Prices</option>
                            <option value="free">Free</option>
                            <option value="paid">Paid</option>
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
                    </div>

                    <div class="relative w-full sm:w-auto">
                        <select id="wishlist-sort" class="w-full sm:w-auto appearance-none border border-slate-200 rounded-xl pl-4 pr-10 py-2.5 text-sm font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-700 cursor-pointer">
                            <option value="newest">Recently Added</option>
                            <option value="oldest">Oldest Added</option>
                            <option value="price-asc">Price: Low to High</option>
                            <option value="price-desc">Price: High to Low</option>
                            <option value="rating">Highest Rated</option>
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
                    </div>

                    <button type="button" id="wishlist-clear" class="w-full sm:w-auto px-4 py-2.5 text-sm font-bold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl transition-all flex items-center justify-center gap-1.5 shrink-0">
                        <span class="material-symbols-outlined text-[18px]">filter_alt_off</span>
                        Reset Filters
                    </button>
                </div>
            </div>

            @* ── Dynamic Course Grid ─────────────────────────────────── *@
            <div id="wishlist-grid-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var item in Model)
                {
                    <div class="flex flex-col h-full bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-2xl hover:shadow-slate-200/50 hover:-translate-y-1 transition-all duration-300 ease-out-expo group cursor-pointer" 
                          onclick="location.href='/Course/Details/@item.CourseId'">
                        
                        @* Card Image *@
                        <div class="relative w-full aspect-[16/9] overflow-hidden bg-slate-100 shrink-0">
                            <img src="@(string.IsNullOrEmpty(item.CourseThumbnailUrl) ? "https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=800&auto=format&fit=crop" : item.CourseThumbnailUrl)" 
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out-expo" 
                                 alt="@item.Title" loading="lazy" />
                            <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors"></div>

                            @* Wishlist Toggle (Always filled red here) *@
                            <button type="button" 
                                    class="absolute top-3 right-3 z-30 w-9 h-9 rounded-full bg-white/90 text-red-500 flex items-center justify-center hover:bg-white hover:scale-110 shadow-sm transition-all duration-300"
                                    onclick="event.stopPropagation(); toggleWishlist(this, @item.CourseId);">
                                <span class="material-symbols-outlined text-[20px]" style='font-variation-settings: "FILL" 1;'>favorite</span>
                            </button>
                        </div>

                        @* Card Content *@
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="text-lg font-bold text-slate-900 line-clamp-2 leading-snug mb-2 group-hover:text-primary transition-colors">
                                @item.Title
                            </h3>
                            <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
                                <span class="material-symbols-outlined text-[18px]">person</span>
                                <span class="truncate">@item.InstructorName</span>
                            </div>

                            @* Rating & Students *@
                            <div class="flex items-center gap-1.5 mb-6">
                                <span class="text-sm font-bold text-slate-800">@item.RatingAverage.ToString("F1")</span>
                                <div class="flex text-amber-400">
                                    @for(int i=0; i<Math.Floor((double)item.RatingAverage); i++) { <span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star</span> }
                                    @if((double)item.RatingAverage - Math.Floor((double)item.RatingAverage) >= 0.5) { <span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star_half</span> }
                                </div>
                                <span class="text-xs text-slate-400 font-medium">(@item.TotalStudents)</span>
                            </div>

                            @* Price & Action *@
                            <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                                <div class="text-xl font-extrabold text-slate-900 tracking-tight">
                                    @if (item.Price == 0)
                                    {
                                        <span class="text-emerald-600 uppercase text-lg">Free</span>
                                    }
                                    else
                                    {
                                        <span>$@item.Price.ToString("N2")</span>
                                    }
                                </div>

                                @if (item.IsEnrolled)
                                {
                                    <div class="w-10 h-10 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center shadow-sm" title="Enrolled">
                                        <span class="material-symbols-outlined text-[18px]">check_circle</span>
                                    </div>
                                }
                                else
                                {
                                    <form asp-action="AddToCart" asp-controller="Cart" method="post" class="m-0 z-20">
                                        <input type="hidden" name="courseId" value="@item.CourseId" />
                                        <input type="hidden" name="returnUrl" value="/Wishlist" />
                                        <button type="submit" 
                                                class="w-10 h-10 rounded-full bg-slate-50 text-slate-500 flex items-center justify-center hover:bg-primary hover:text-white hover:scale-110 active:scale-95 shadow-sm transition-all duration-300"
                                                onclick="event.stopPropagation();"
                                                title="Add to Cart">
                                            <span class="material-symbols-outlined text-[18px]" style='font-variation-settings:"FILL" 1;'>add_shopping_cart</span>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hide wishlist badge in header when on this page
        function hideWishlistBadge() {
            const badge = document.getElementById('wishlist-badge');
            if (badge) {
                badge.classList.add('hidden');
                badge.setAttribute('data-manual-hide', 'true');
            }
        }

        // Live JSON data serialized from C# Model
        let wishlistData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

        function renderWishlist(items) {
            const grid = document.getElementById('wishlist-grid-container');
            if (!grid) return;

            if (items.length === 0) {
                grid.className = "block w-full";
                grid.innerHTML = `
                    <div class="bg-white rounded-3xl border border-dashed border-slate-200 p-20 text-center shadow-sm w-full">
                        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-slate-50 text-slate-300 mb-6">
                            <span class="material-symbols-outlined text-4xl">search_off</span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-800 mb-2">No Results Found</h3>
                        <p class="text-slate-500 max-w-sm mx-auto mb-2 text-sm leading-relaxed">
                            Try adjusting your filter settings or search terms.
                        </p>
                    </div>
                `;
                return;
            }

            grid.className = "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8";
            grid.innerHTML = items.map(item => {
                const thumbnailUrl = item.CourseThumbnailUrl || 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=800&auto=format&fit=crop';
                const priceText = item.Price === 0 
                    ? `<span class="text-emerald-600 uppercase text-lg">Free</span>` 
                    : `<span>$${item.Price.toFixed(2)}</span>`;

                let stars = '';
                const rating = item.RatingAverage || 0;
                for (let i = 0; i < Math.floor(rating); i++) {
                    stars += `<span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star</span>`;
                }
                if (rating - Math.floor(rating) >= 0.5) {
                    stars += `<span class="material-symbols-outlined text-[16px]" style='font-variation-settings:"FILL" 1;'>star_half</span>`;
                }

                const actionHtml = item.IsEnrolled
                    ? `<div class="w-10 h-10 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center shadow-sm" title="Enrolled">
                            <span class="material-symbols-outlined text-[18px]">check_circle</span>
                       </div>`
                    : `<form action="/Cart/AddToCart" method="post" class="m-0 z-20">
                            <input type="hidden" name="courseId" value="${item.CourseId}" />
                            <input type="hidden" name="returnUrl" value="/Wishlist" />
                            <button type="submit" 
                                    class="w-10 h-10 rounded-full bg-slate-50 text-slate-500 flex items-center justify-center hover:bg-primary hover:text-white hover:scale-110 active:scale-95 shadow-sm transition-all duration-300"
                                    onclick="event.stopPropagation();"
                                    title="Add to Cart">
                                <span class="material-symbols-outlined text-[18px]" style='font-variation-settings:"FILL" 1;'>add_shopping_cart</span>
                            </button>
                       </form>`;

                return `
                    <div class="flex flex-col h-full bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-2xl hover:shadow-slate-200/50 hover:-translate-y-1 transition-all duration-300 ease-out-expo group cursor-pointer" 
                          onclick="location.href='/Course/Details/${item.CourseId}'">
                        
                        <div class="relative w-full aspect-[16/9] overflow-hidden bg-slate-100 shrink-0">
                            <img src="${thumbnailUrl}" 
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out-expo" 
                                 alt="${item.Title}" loading="lazy" />
                            <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors"></div>

                            <button type="button" 
                                    class="absolute top-3 right-3 z-30 w-9 h-9 rounded-full bg-white/90 text-red-500 flex items-center justify-center hover:bg-white hover:scale-110 shadow-sm transition-all duration-300"
                                    onclick="event.stopPropagation(); toggleWishlist(this, ${item.CourseId});">
                                <span class="material-symbols-outlined text-[20px]" style='font-variation-settings: "FILL" 1;'>favorite</span>
                            </button>
                        </div>

                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="text-lg font-bold text-slate-900 line-clamp-2 leading-snug mb-2 group-hover:text-primary transition-colors">
                                ${item.Title}
                            </h3>
                            <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
                                <span class="material-symbols-outlined text-[18px]">person</span>
                                <span class="truncate">${item.InstructorName || ''}</span>
                            </div>

                            <div class="flex items-center gap-1.5 mb-6">
                                <span class="text-sm font-bold text-slate-800">${rating.toFixed(1)}</span>
                                <div class="flex text-amber-400">
                                    ${stars}
                                </div>
                                <span class="text-xs text-slate-400 font-medium font-bold">(${item.TotalStudents})</span>
                            </div>

                            <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                                <div class="text-xl font-extrabold text-slate-900 tracking-tight font-black">
                                    ${priceText}
                                </div>
                                ${actionHtml}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function applyWishlistFilters() {
            const query = document.getElementById('wishlist-search').value.toLowerCase().trim();
            const filterPrice = document.getElementById('wishlist-filter-price').value;
            const sortVal = document.getElementById('wishlist-sort').value;

            let filtered = [...wishlistData];

            // 1. Search filter
            if (query) {
                filtered = filtered.filter(x => 
                    x.Title.toLowerCase().includes(query) || 
                    (x.InstructorName && x.InstructorName.toLowerCase().includes(query))
                );
            }

            // 2. Price filter
            if (filterPrice === 'free') {
                filtered = filtered.filter(x => x.Price === 0);
            } else if (filterPrice === 'paid') {
                filtered = filtered.filter(x => x.Price > 0);
            }

            // 3. Sorting
            if (sortVal === 'newest') {
                filtered.sort((a, b) => new Date(b.AddedDate) - new Date(a.AddedDate));
            } else if (sortVal === 'oldest') {
                filtered.sort((a, b) => new Date(a.AddedDate) - new Date(b.AddedDate));
            } else if (sortVal === 'price-asc') {
                filtered.sort((a, b) => a.Price - b.Price);
            } else if (sortVal === 'price-desc') {
                filtered.sort((a, b) => b.Price - a.Price);
            } else if (sortVal === 'rating') {
                filtered.sort((a, b) => b.RatingAverage - a.RatingAverage);
            }

            renderWishlist(filtered);
        }

        // Live override for toggleWishlist ajax response
        window.toggleWishlist = async function(btn, courseId) {
            try {
                const res = await fetch(`/Wishlist/ToggleAjax?courseId=${courseId}`, { method: 'POST' });
                const data = await res.json();
                if (data.success && !data.isInWishlist) {
                    wishlistData = wishlistData.filter(x => x.CourseId !== courseId);
                    applyWishlistFilters();
                    
                    // Also update counts shown on page header
                    const countEl = document.querySelector('.text-primary.font-bold span');
                    if (countEl) {
                        countEl.innerText = `${wishlistData.length} courses`;
                    }
                }
            } catch(e) {}
        }

        document.addEventListener('DOMContentLoaded', () => {
            hideWishlistBadge();
            
            // Override the global update function to keep it hidden on this page
            const originalUpdate = window.updateWishlistBadge;
            window.updateWishlistBadge = async () => {
                if (typeof originalUpdate === 'function') {
                    await originalUpdate();
                }
                hideWishlistBadge();
            };

            // Hook up event listeners for instant filtering
            const searchInput = document.getElementById('wishlist-search');
            const priceSelect = document.getElementById('wishlist-filter-price');
            const sortSelect = document.getElementById('wishlist-sort');
            const clearBtn = document.getElementById('wishlist-clear');

            if (searchInput) {
                searchInput.addEventListener('input', applyWishlistFilters);
                priceSelect.addEventListener('change', applyWishlistFilters);
                sortSelect.addEventListener('change', applyWishlistFilters);
                
                clearBtn.addEventListener('click', () => {
                    searchInput.value = '';
                    priceSelect.value = 'all';
                    sortSelect.value = 'newest';
                    applyWishlistFilters();
                });
            }
        });
    </script>
}
