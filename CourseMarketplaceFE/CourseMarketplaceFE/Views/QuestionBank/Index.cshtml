@{
    ViewData["Title"] = "Question Bank";
    Layout = "_InstructorLayout";
}

<div class="py-8 px-8 max-w-6xl mx-auto flex flex-col gap-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-headline font-extrabold text-slate-900">Question Bank</h1>
            <p class="text-slate-500 mt-1">Manage questions per course and lesson to use in your quizzes.</p>
        </div>
    </div>

    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm font-semibold text-slate-500" aria-label="Breadcrumb" id="breadcrumb-nav">
        <button onclick="showView('courses')" class="hover:text-primary transition-colors flex items-center gap-1">
            <span class="material-symbols-outlined text-[18px]">folder_open</span> Courses
        </button>
        <!-- Dynamic Breadcrumbs injected here -->
    </nav>

    <!-- VIEW 1: Courses -->
    <div id="view-courses" class="space-y-4">
        <h2 class="text-lg font-bold text-slate-800">Select a Course</h2>
        <div id="courseGrid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            <div class="p-8 text-center text-slate-500 col-span-full">
                <span class="material-symbols-outlined animate-spin text-3xl">refresh</span>
            </div>
        </div>
    </div>

    <!-- VIEW 2: Lessons -->
    <div id="view-lessons" class="hidden space-y-4">
        <h2 class="text-lg font-bold text-slate-800">Select a Lesson</h2>
        <div id="lessonGrid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        </div>
    </div>

    <!-- VIEW 3: Questions -->
    <div id="view-questions" class="hidden space-y-4">
        <div class="flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-800">Questions in <span id="lblCurrentLesson" class="text-primary"></span></h2>
            <button onclick="openQuestionForm(0)" class="px-5 py-2 bg-primary text-white rounded-lg font-bold shadow-sm shadow-primary/30 hover:bg-primary/90 flex items-center gap-2 transition-all">
                <span class="material-symbols-outlined text-[18px]">add</span> Add Question
            </button>
        </div>
        <div id="questionsList" class="flex flex-col gap-4">
        </div>
    </div>

    <!-- VIEW 4: Question Form (Popup Modal) -->
    <div id="view-question-form" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="bg-white p-6 md:p-8 rounded-2xl shadow-xl border border-slate-200 w-full max-w-2xl max-h-[90vh] overflow-y-auto">
            <h2 class="text-xl font-headline font-extrabold text-slate-800 mb-6 border-b border-slate-100 pb-4" id="formTitle">Add Question</h2>
            
            <input type="hidden" id="editingQuestionId" value="0">
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Question Type</label>
                    <select id="qType" onchange="onTypeChanged()" class="w-full max-w-sm px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/20 outline-none bg-slate-50 font-medium">
                        <option value="0">Single Choice</option>
                        <option value="1">Multiple Choice</option>
                        <option value="2">True/False</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Question Text <span class="text-red-500">*</span></label>
                    <textarea id="qText" rows="3" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/20 outline-none font-medium text-slate-800 placeholder-slate-400" placeholder="Enter your question here..."></textarea>
                </div>
                
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Explanation (Note) <span class="text-slate-400 font-normal text-xs ml-1">- Optional. Shows to user after completing quiz.</span></label>
                    <textarea id="qExplanation" rows="2" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary/20 outline-none text-slate-700 placeholder-slate-400 text-sm" placeholder="Explain why the answer is correct..."></textarea>
                </div>

                <div class="pt-4 border-t border-slate-100">
                    <div class="flex items-center justify-between mb-4">
                        <label class="block text-sm font-semibold text-slate-700">Options <span class="text-red-500">*</span></label>
                        <button type="button" id="btnAddOption" onclick="addOptionField()" class="text-sm font-bold text-primary hover:underline flex items-center gap-1">
                            <span class="material-symbols-outlined text-[16px]">add</span> Add Option
                        </button>
                    </div>
                    <div id="optionsContainer" class="space-y-3">
                        <!-- Dynamic options -->
                    </div>
                </div>

                <div class="pt-6 mt-6 border-t border-slate-100 flex justify-end gap-3">
                    <button onclick="closeQuestionForm()" class="px-6 py-2.5 text-slate-600 font-bold hover:bg-slate-100 rounded-xl transition-colors">Cancel</button>
                    <button onclick="saveQuestion()" id="btnSaveQuestion" class="px-8 py-2.5 bg-primary text-white font-bold rounded-xl shadow-sm shadow-primary/30 hover:bg-primary/90 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">save</span> Save
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // State
        let state = {
            view: 'courses', // courses, lessons, questions, form
            courseId: null,
            courseTitle: null,
            lessonId: null,
            lessonTitle: null,
            questions: []
        };
        let optionCounter = -1;

        document.addEventListener('DOMContentLoaded', async () => {
            await loadCourses();
            renderView();
        });

        // --- Navigation ---
        function showView(viewName) {
            state.view = viewName;
            renderView();
        }

        function renderView() {
            // Hide all main views
            ['view-courses', 'view-lessons', 'view-questions'].forEach(id => {
                document.getElementById(id).classList.add('hidden');
            });

            // Show current
            document.getElementById(`view-${state.view}`).classList.remove('hidden');

            // Render breadcrumbs
            const nav = document.getElementById('breadcrumb-nav');
            let crumbs = `
                <button onclick="showView('courses')" class="hover:text-primary transition-colors flex items-center gap-1 ${state.view === 'courses' ? 'text-slate-800' : ''}">
                    <span class="material-symbols-outlined text-[18px] ${state.view === 'courses' ? 'text-primary' : ''}">folder_open</span> Courses
                </button>
            `;

            if (state.courseId) {
                crumbs += `
                    <span class="material-symbols-outlined text-[16px] text-slate-300">chevron_right</span>
                    <button onclick="showView('lessons')" class="hover:text-primary transition-colors ${state.view === 'lessons' ? 'text-slate-800 font-bold' : ''}">
                        ${state.courseTitle}
                    </button>
                `;
            }

            if (state.lessonId && (state.view === 'questions' || state.view === 'question-form')) {
                crumbs += `
                    <span class="material-symbols-outlined text-[16px] text-slate-300">chevron_right</span>
                    <button onclick="showView('questions')" class="hover:text-primary transition-colors ${state.view === 'questions' ? 'text-slate-800 font-bold' : ''}">
                        ${state.lessonTitle}
                    </button>
                `;
            }

            if (state.view === 'question-form') {
                const isEdit = document.getElementById('editingQuestionId').value !== "0";
                crumbs += `
                    <span class="material-symbols-outlined text-[16px] text-slate-300">chevron_right</span>
                    <span class="text-slate-800 font-bold">${isEdit ? 'Edit Question' : 'Add Question'}</span>
                `;
            }

            nav.innerHTML = crumbs;
        }

        // --- Data Fetching & Rendering ---

        async function loadCourses() {
            try {
                const resp = await fetch("/QuestionBank/GetCourses");
                const grid = document.getElementById('courseGrid');
                if (resp.ok) {
                    const data = await resp.json();
                    if (data.data && data.data.items && data.data.items.length > 0) {
                        grid.innerHTML = data.data.items.map(c => `
                            <button onclick="openCourse(${c.courseId}, '${c.title.replace(/'/g, "\\'")}')" class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col items-start gap-3 hover:border-primary/50 hover:shadow-md hover:-translate-y-1 transition-all text-left group">
                                <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                                    <span class="material-symbols-outlined text-2xl">folder</span>
                                </div>
                                <div>
                                    <h3 class="font-bold text-slate-800 line-clamp-2">${c.title}</h3>
                                    <p class="text-xs text-slate-400 mt-1 uppercase tracking-wider font-semibold">Open Course</p>
                                </div>
                            </button>
                        `).join('');
                    } else {
                        grid.innerHTML = `<div class="col-span-full p-8 text-center text-slate-500 bg-slate-50 rounded-2xl border border-dashed border-slate-200">No courses available.</div>`;
                    }
                }
            } catch (err) {
                console.error(err);
                document.getElementById('courseGrid').innerHTML = `<div class="col-span-full text-red-500 text-center p-4">Error loading courses.</div>`;
            }
        }

        async function openCourse(courseId, title) {
            state.courseId = courseId;
            state.courseTitle = title;
            state.lessonId = null;
            state.lessonTitle = null;
            
            const grid = document.getElementById('lessonGrid');
            grid.innerHTML = '<div class="col-span-full p-8 text-center text-slate-500"><span class="material-symbols-outlined animate-spin text-3xl">refresh</span></div>';
            showView('lessons');

            try {
                const resp = await fetch(`/QuestionBank/GetLessons?courseId=${courseId}`);
                if (resp.ok) {
                    const data = await resp.json();
                    if (data.data && data.data.lessons && data.data.lessons.length > 0) {
                        grid.innerHTML = data.data.lessons.map(l => `
                            <button onclick="openLesson(${l.lessonId}, '${l.title.replace(/'/g, "\\'")}')" class="bg-white border border-slate-200 rounded-2xl p-5 flex items-center gap-4 hover:border-emerald-500/50 hover:shadow-md hover:-translate-y-1 transition-all text-left group">
                                <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center group-hover:bg-emerald-500 group-hover:text-white transition-colors shrink-0">
                                    <span class="material-symbols-outlined text-[20px]">topic</span>
                                </div>
                                <div class="flex-1">
                                    <h3 class="font-bold text-slate-800 line-clamp-1 text-sm">${l.title}</h3>
                                    <p class="text-xs text-slate-400 mt-0.5">Manage Questions</p>
                                </div>
                                <span class="material-symbols-outlined text-slate-300 group-hover:text-emerald-500">chevron_right</span>
                            </button>
                        `).join('');
                    } else {
                        grid.innerHTML = `<div class="col-span-full p-8 text-center text-slate-500 bg-slate-50 rounded-2xl border border-dashed border-slate-200">No lessons in this course.</div>`;
                    }
                } else {
                    grid.innerHTML = '<div class="col-span-full text-red-500 text-center p-4">Failed to load lessons.</div>';
                }
            } catch (err) {
                console.error(err);
                grid.innerHTML = '<div class="col-span-full text-red-500 text-center p-4">System error.</div>';
            }
        }

        async function openLesson(lessonId, title) {
            state.lessonId = lessonId;
            state.lessonTitle = title;
            document.getElementById('lblCurrentLesson').innerText = title;
            
            showView('questions');
            await loadQuestions();
        }

        async function loadQuestions() {
            const container = document.getElementById('questionsList');
            container.innerHTML = '<div class="p-8 text-center text-slate-500"><span class="material-symbols-outlined animate-spin text-3xl">refresh</span></div>';
            
            try {
                const resp = await fetch(`/QuestionBank/GetQuestions?lessonId=${state.lessonId}`);
                if (resp.ok) {
                    state.questions = await resp.json();
                    renderQuestions();
                } else {
                    const text = await resp.text();
                    container.innerHTML = `<div class="text-red-500 text-center p-4">Error loading questions. Code: ${resp.status}, Body: ${text}</div>`;
                }
            } catch (err) {
                container.innerHTML = `<div class="text-red-500 text-center p-4">System error: ${err.message}</div>`;
            }
        }

        function renderQuestions() {
            const container = document.getElementById('questionsList');
            if (state.questions.length === 0) {
                container.innerHTML = `
                    <div class="bg-white border border-slate-200 border-dashed p-12 rounded-3xl flex flex-col items-center justify-center text-slate-400">
                        <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-3xl text-slate-300">inbox</span>
                        </div>
                        <h3 class="font-bold text-slate-700 text-lg mb-1">No questions yet</h3>
                        <p class="text-sm font-medium">Click "Add Question" to create your first question for this lesson.</p>
                        <button onclick="openQuestionForm(0)" class="mt-6 px-6 py-2 bg-slate-900 text-white rounded-lg font-bold hover:bg-slate-800 transition-colors">Add Question</button>
                    </div>`;
                return;
            }

            container.innerHTML = state.questions.map((q, idx) => {
                const qTypeStr = q.questionType === 0 ? 'Single Choice' : q.questionType === 1 ? 'Multiple Choice' : 'True/False';
                
                return `
                    <div class="bg-white p-6 rounded-2xl shadow-[0_2px_10px_-3px_rgba(6,81,237,0.1)] border border-slate-100 relative group flex flex-col gap-4">
                        <div class="absolute top-6 right-6 flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity bg-white pl-4">
                            <button onclick="openQuestionForm(${q.questionId})" class="w-9 h-9 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center hover:bg-indigo-600 hover:text-white transition-colors" title="Edit">
                                <span class="material-symbols-outlined text-[18px]">edit</span>
                            </button>
                            <button onclick="deleteQuestion(${q.questionId})" class="w-9 h-9 rounded-xl bg-rose-50 text-rose-600 flex items-center justify-center hover:bg-rose-600 hover:text-white transition-colors" title="Delete">
                                <span class="material-symbols-outlined text-[18px]">delete</span>
                            </button>
                        </div>
                        
                        <div class="flex items-start gap-4 pr-24">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center font-extrabold text-slate-400 shrink-0 text-sm border border-slate-100 shadow-sm">${idx + 1}</div>
                            <div class="flex-1 pt-1">
                                <p class="text-slate-800 font-semibold text-base leading-relaxed">${q.questionText}</p>
                                <div class="mt-2 text-[11px] font-bold uppercase tracking-wider text-primary bg-primary/10 inline-block px-2.5 py-1 rounded-md">${qTypeStr}</div>
                            </div>
                        </div>
                        
                        <div class="ml-14 grid grid-cols-1 sm:grid-cols-2 gap-2 mt-2">
                            ${q.options.map(o => `
                                <div class="flex items-start gap-3 p-3 rounded-xl border ${o.isCorrect ? 'border-emerald-200 bg-emerald-50/50' : 'border-slate-100 bg-slate-50/50'} text-sm ${o.isCorrect ? 'font-bold text-emerald-700' : 'text-slate-600 font-medium'}">
                                    <span class="material-symbols-outlined text-[18px] shrink-0 mt-0.5 ${o.isCorrect ? 'text-emerald-500' : 'text-slate-300'}">${o.isCorrect ? 'check_circle' : 'radio_button_unchecked'}</span>
                                    <span class="leading-snug">${o.optionText}</span>
                                </div>
                            `).join('')}
                        </div>

                        ${q.explanation ? `
                        <div class="ml-14 mt-1 p-3.5 bg-indigo-50/70 border border-indigo-100 rounded-xl text-sm text-indigo-800 flex gap-2 items-start">
                            <span class="material-symbols-outlined text-[16px] shrink-0 mt-0.5 text-indigo-500">info</span>
                            <span class="leading-relaxed">${q.explanation}</span>
                        </div>
                        ` : ''}
                    </div>
                `;
            }).join('');
        }

        // --- Form Logic (No Popup) ---

        function openQuestionForm(qId = 0) {
            const isEdit = qId > 0;
            document.getElementById('formTitle').innerText = isEdit ? 'Edit Question' : 'Add Question';
            document.getElementById('editingQuestionId').value = qId;
            document.getElementById('btnSaveQuestion').disabled = false;

            if (isEdit) {
                const q = state.questions.find(x => x.questionId === qId);
                document.getElementById('qType').value = q.questionType;
                document.getElementById('qText').value = q.questionText;
                document.getElementById('qExplanation').value = q.explanation || '';
                renderOptionsForm(q.options, q.questionType);
            } else {
                document.getElementById('qType').value = 0;
                document.getElementById('qText').value = '';
                document.getElementById('qExplanation').value = '';
                renderOptionsForm([{ optionText: '', isCorrect: true }, { optionText: '', isCorrect: false }], 0);
            }
            onTypeChanged();
            document.getElementById('view-question-form').classList.remove('hidden');
        }

        function closeQuestionForm() {
            document.getElementById('view-question-form').classList.add('hidden');
        }

        function onTypeChanged() {
            const type = parseInt(document.getElementById('qType').value);
            const btnAddOpt = document.getElementById('btnAddOption');
            
            if (type === 2) {
                btnAddOpt.classList.add('hidden');
                renderOptionsForm([
                    { optionText: 'True', isCorrect: true, fixed: true },
                    { optionText: 'False', isCorrect: false, fixed: true }
                ], 2);
            } else {
                btnAddOpt.classList.remove('hidden');
                const currentOpts = getOptionsFromForm();
                if (currentOpts.length > 0 && currentOpts[0].optionText !== 'True') {
                    renderOptionsForm(currentOpts, type);
                } else {
                    renderOptionsForm([{ optionText: '', isCorrect: true }, { optionText: '', isCorrect: false }], type);
                }
            }
        }

        function renderOptionsForm(opts, type) {
            const container = document.getElementById('optionsContainer');
            container.innerHTML = '';
            const isSingleCorrect = type === 0 || type === 2;
            
            opts.forEach((o, i) => {
                const id = optionCounter--;
                const fixed = type === 2;
                container.innerHTML += `
                    <div class="flex items-center gap-3 bg-slate-50 p-2 pl-4 rounded-xl border border-slate-100 group" id="opt_${id}">
                        ${isSingleCorrect ? 
                            `<input type="radio" name="correctOpt" value="${id}" ${o.isCorrect ? 'checked' : ''} class="w-4 h-4 text-primary bg-white border-slate-300 focus:ring-primary cursor-pointer">` :
                            `<input type="checkbox" name="correctOptCheck" value="${id}" ${o.isCorrect ? 'checked' : ''} class="w-4 h-4 text-primary bg-white border-slate-300 rounded focus:ring-primary cursor-pointer">`
                        }
                        <input type="text" class="flex-1 px-4 py-2.5 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-primary/20 outline-none text-sm font-medium opt-text shadow-sm" value="${o.optionText}" placeholder="Option text..." ${fixed ? 'readonly' : ''} required>
                        ${!fixed && opts.length > 2 ? `<button type="button" onclick="document.getElementById('opt_${id}').remove()" class="text-slate-400 hover:text-red-500 p-2 rounded-lg hover:bg-red-50 transition-colors"><span class="material-symbols-outlined text-[20px]">delete</span></button>` : '<div class="w-10"></div>'}
                    </div>
                `;
            });
        }

        function addOptionField() {
            const container = document.getElementById('optionsContainer');
            const type = parseInt(document.getElementById('qType').value);
            const isSingleCorrect = type === 0;
            const id = optionCounter--;
            
            const div = document.createElement('div');
            div.className = "flex items-center gap-3 bg-slate-50 p-2 pl-4 rounded-xl border border-slate-100 group";
            div.id = `opt_${id}`;
            div.innerHTML = `
                ${isSingleCorrect ? 
                    `<input type="radio" name="correctOpt" value="${id}" class="w-4 h-4 text-primary bg-white border-slate-300 focus:ring-primary cursor-pointer">` :
                    `<input type="checkbox" name="correctOptCheck" value="${id}" class="w-4 h-4 text-primary bg-white border-slate-300 rounded focus:ring-primary cursor-pointer">`
                }
                <input type="text" class="flex-1 px-4 py-2.5 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-primary/20 outline-none text-sm font-medium opt-text shadow-sm" placeholder="Option text..." required>
                <button type="button" onclick="this.parentElement.remove()" class="text-slate-400 hover:text-red-500 p-2 rounded-lg hover:bg-red-50 transition-colors"><span class="material-symbols-outlined text-[20px]">delete</span></button>
            `;
            container.appendChild(div);
            
            if (container.children.length > 2 && type !== 2) {
                Array.from(container.children).forEach(c => {
                    const btn = c.querySelector('button');
                    if (btn) btn.style.display = 'block';
                });
            }
        }

        function getOptionsFromForm() {
            const type = parseInt(document.getElementById('qType').value);
            const isSingleCorrect = type === 0 || type === 2;
            const container = document.getElementById('optionsContainer');
            const opts = [];
            
            Array.from(container.children).forEach((c, i) => {
                const textEl = c.querySelector('.opt-text');
                const text = textEl ? textEl.value : c.innerText.trim();
                const radio = c.querySelector('input[type="radio"]');
                const checkbox = c.querySelector('input[type="checkbox"]');
                const isCorrect = radio ? radio.checked : (checkbox ? checkbox.checked : false);
                opts.push({ optionText: text, isCorrect: isCorrect, orderIndex: i });
            });
            return opts;
        }

        async function saveQuestion() {
            const qId = parseInt(document.getElementById('editingQuestionId').value);
            const qText = document.getElementById('qText').value.trim();
            const qType = parseInt(document.getElementById('qType').value);
            const qExplanation = document.getElementById('qExplanation').value.trim();
            const options = getOptionsFromForm();

            if (!qText) return Swal.fire('Error', 'Question text is required', 'error');
            if (options.length < 2) return Swal.fire('Error', 'At least 2 options are required', 'error');
            if (!options.some(o => o.isCorrect)) return Swal.fire('Error', 'At least 1 correct option is required', 'error');

            const req = {
                lessonId: state.lessonId,
                questionText: qText,
                explanation: qExplanation || null,
                questionType: qType,
                options: options
            };

            document.getElementById('btnSaveQuestion').disabled = true;

            try {
                let url = qId === 0 ? `/QuestionBank/CreateQuestion?courseId=${state.courseId}` : `/QuestionBank/UpdateQuestion?qId=${qId}`;
                let method = qId === 0 ? 'POST' : 'PUT';

                const resp = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(req)
                });

                if (resp.ok) {
                    await loadQuestions();
                    closeQuestionForm();
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: 'Question saved successfully',
                        timer: 1500,
                        showConfirmButton: false
                    });
                } else {
                    const data = await resp.json();
                    Swal.fire('Error', data.message || 'Failed to save', 'error');
                }
            } catch (err) {
                Swal.fire('Error', 'System error', 'error');
            } finally {
                document.getElementById('btnSaveQuestion').disabled = false;
            }
        }

        async function deleteQuestion(qId) {
            const res = await Swal.fire({
                title: 'Delete this question?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Yes, delete it!'
            });

            if (res.isConfirmed) {
                try {
                    const resp = await fetch(`/QuestionBank/DeleteQuestion?qId=${qId}`, { method: 'DELETE' });
                    if (resp.ok) {
                        await loadQuestions();
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Deleted!', showConfirmButton: false, timer: 2000 });
                    } else {
                        const data = await resp.json();
                        Swal.fire('Error', data.message || 'Failed to delete', 'error');
                    }
                } catch (err) {
                    Swal.fire('Error', 'System error', 'error');
                }
            }
        }
    </script>
}
