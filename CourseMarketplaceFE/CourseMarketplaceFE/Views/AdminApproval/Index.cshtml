@using System.Net
@model List<CourseMarketplaceFE.Models.InstructorApprovalViewModel>
@{
    ViewData["Title"] = "Quản lý xét duyệt";
    Layout = null; // Tùy chỉnh theo yêu cầu của bạn, hoặc để mặc định nếu dùng Layout chung

    var managerName = Context.Request.Cookies["UserName"] ?? "Admin";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - Instructor Approval</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#10b981', // Màu xanh emerald giống bên Notification
                        secondary: '#059669',
                        surface: '#ffffff',
                        border: '#e2e8f0'
                    },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        .no-shadow {
            box-shadow: none !important;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-thumb {
            background: #10b981;
            border-radius: 10px;
        }
    </style>
</head>
<body class="bg-white text-slate-800 flex h-screen overflow-hidden">

    <aside class="w-64 border-r border-border flex flex-col bg-white">
        <div class="h-16 flex items-center px-6 border-b border-border">
            <span class="text-primary font-bold text-xl flex items-center gap-2">
                <span class="material-symbols-outlined">shield_person</span> Quản trị
            </span>
        </div>
        <nav class="flex-1 p-4 space-y-2">
            <a href="/AdminApproval" class="flex items-center gap-3 p-3 rounded-lg bg-emerald-50 text-primary font-semibold transition-colors">
                <span class="material-symbols-outlined">verified_user</span> Xét duyệt
            </a>
            <a href="/Notification/Admin" class="flex items-center gap-3 p-3 rounded-lg text-slate-500 hover:bg-slate-50 transition-all">
                <span class="material-symbols-outlined">notifications</span> Thông báo
            </a>
            <a href="/" class="flex items-center gap-3 p-3 rounded-lg text-slate-500 hover:bg-slate-50 transition-all">
                <span class="material-symbols-outlined">home</span> Trang chủ
            </a>
        </nav>
    </aside>

    <main class="flex-1 flex flex-col bg-white overflow-hidden">
        <header class="h-16 border-b border-border flex items-center justify-between px-8 bg-white">
            <div class="flex items-center gap-3">
                <h2 class="font-semibold text-lg text-slate-700">Đơn đăng ký giảng viên</h2>
                <span class="text-[10px] bg-slate-100 px-2 py-1 rounded-full text-slate-500 font-bold uppercase tracking-wider">
                    Admin: @managerName
                </span>
            </div>
        </header>

        <div class="flex-1 p-6 flex flex-col overflow-hidden">
            <div class="flex-1 border border-border rounded-xl overflow-hidden bg-white flex flex-col no-shadow">
                <div class="flex-1 overflow-auto">
                    <table class="w-full text-left border-collapse table-fixed">
                        <thead class="bg-slate-50 border-b border-border sticky top-0 z-10">
                            <tr>
                                <th class="p-4 text-xs font-bold text-slate-400 uppercase w-[25%]">Giảng viên</th>
                                <th class="p-4 text-xs font-bold text-slate-400 uppercase w-[30%]">Chuyên môn</th>
                                <th class="p-4 text-xs font-bold text-slate-400 uppercase w-[25%]">Tài liệu hồ sơ</th>
                                <th class="p-4 text-xs font-bold text-slate-400 uppercase w-[20%] text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="approval-table-body" class="divide-y divide-slate-100">
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr id="row-@item.InstructorId" class="hover:bg-slate-50 transition-colors">
                                        <td class="p-4">
                                            <div class="text-sm font-bold text-slate-700 truncate">
                                                @item.FullName
                                            </div>
                                            <div class="text-[11px] text-slate-400 truncate">
                                                @item.Email
                                            </div>
                                        </td>
                                        <td class="p-4">
                                            <div class="text-sm font-bold text-slate-800 truncate">@item.ProfessionalTitle</div>
                                            <div class="text-xs text-slate-400">@item.ExpertiseCategories</div>
                                        </td>
                                        <td class="p-4">
                                            @if (!string.IsNullOrEmpty(item.DocumentUrl))
                                            {
                                                <a href="@item.DocumentUrl" target="_blank" class="text-xs text-primary font-bold flex items-center gap-1 hover:underline">
                                                    <span class="material-symbols-outlined text-sm">description</span> Xem chứng chỉ/CV
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-xs text-slate-300 italic">Không có tài liệu</span>
                                            }
                                        </td>
                                        <td class="p-4 text-center">
                                            <div class="relative inline-block text-left group">
                                                <button class="flex items-center gap-1 px-3 py-1.5 bg-slate-50 border border-border rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-100 transition-all">
                                                    <span class="material-symbols-outlined text-sm text-amber-500">pending</span>
                                                    Xử lý
                                                    <span class="material-symbols-outlined text-xs ml-1 transition-transform group-hover:rotate-180">expand_more</span>
                                                </button>

                                                <div class="absolute right-0 mt-1 w-40 bg-white border border-border rounded-xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 overflow-hidden">
                                                    <div class="py-1">
                                                        <button onclick="processAction(@item.InstructorId, 'Approved')"
                                                                class="w-full flex items-center gap-2 px-4 py-2 text-xs text-emerald-600 hover:bg-emerald-50 transition-colors">
                                                            <span class="material-symbols-outlined text-sm">check_circle</span>
                                                            Duyệt hồ sơ
                                                        </button>
                                                        <button onclick="processAction(@item.InstructorId, 'Rejected')"
                                                                class="w-full flex items-center gap-2 px-4 py-2 text-xs text-red-600 hover:bg-red-50 transition-colors border-t border-slate-50">
                                                            <span class="material-symbols-outlined text-sm">cancel</span>
                                                            Từ chối
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="p-12 text-center text-slate-400 text-sm italic">
                                        Hiện không có đơn đăng ký nào cần xử lý
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <script>
        async function processAction(id, status) {
            const actionText = status === 'Approved' ? 'duyệt' : 'từ chối';
            if (!confirm(`Xác nhận ${actionText} đơn đăng ký này?`)) return;

            try {
                const response = await fetch(`/AdminApproval/Process?id=${id}&status=${status}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const result = await response.json();
                if (result.success) {
                    const row = document.getElementById(`row-${id}`);
                    row.style.opacity = '0';
                    row.style.transform = 'translateX(20px)';
                    row.style.transition = 'all 0.4s ease';

                    setTimeout(() => {
                        row.remove();
                        if (document.querySelectorAll('#approval-table-body tr').length === 0) {
                            location.reload(); // Reload để hiện trạng thái trống
                        }
                    }, 400);
                } else {
                    alert(result.message || "Lỗi khi xử lý.");
                }
            } catch (err) {
                alert("Lỗi kết nối server.");
            }
        }
    </script>
</body>
</html>