@using System.Net
@model List<CourseMarketplaceFE.Models.InstructorApprovalViewModel>
@{
    ViewData["Title"] = "Quản lý xét duyệt";
    ViewData["PageHeader"] = "Đơn đăng ký giảng viên";
    Layout = "_AdminLayout";
}

<div class="bg-white border border-slate-200 rounded-lg shadow-sm flex flex-col">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-slate-200 bg-slate-50/50">
                    <th class="px-5 py-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Giảng viên</th>
                    <th class="px-5 py-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Chuyên môn</th>
                    <th class="px-5 py-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider text-center">LinkedIn</th>
                    <th class="px-5 py-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Hồ sơ</th>
                    <th class="px-5 py-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="approval-table-body" class="divide-y divide-slate-100 text-sm">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr id="row-@item.InstructorId" class="hover:bg-slate-50/50 transition-colors group">
                            <td class="px-5 py-4 align-top">
                                <div class="flex items-center gap-3">
                                    <img src="@(string.IsNullOrEmpty(item.AvatarUrl) ? "/img/default-avatar.png" : item.AvatarUrl)"
                                         class="w-9 h-9 rounded-full object-cover border border-slate-200" />
                                    <div class="flex flex-col">
                                        <span class="font-medium text-slate-900">@item.FullName</span>
                                        <span class="text-xs text-slate-500">@item.Email</span>
                                    </div>
                                </div>
                            </td>

                            <td class="px-5 py-4 align-top">
                                <div class="font-medium text-slate-900">@item.ProfessionalTitle</div>
                                <div class="text-[11px] text-slate-500 uppercase tracking-wider mt-0.5">@item.ExpertiseCategories</div>
                            </td>

                            <td class="px-5 py-4 align-top text-center">
                                @if (!string.IsNullOrEmpty(item.LinkedInUrl) && item.LinkedInUrl != "#")
                                {
                                    <a href="@item.LinkedInUrl" target="_blank"
                                       class="inline-flex text-slate-400 hover:text-blue-600 transition-colors" title="Xem LinkedIn">
                                        <span class="material-symbols-outlined text-[20px]">link</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400 italic">Trống</span>
                                }
                            </td>

                            <td class="px-5 py-4 align-top">
                                @if (!string.IsNullOrEmpty(item.DocumentUrl))
                                {
                                    var fileName = item.DocumentUrl.Split('/').Last();
                                    <a href="@item.DocumentUrl" target="_blank"
                                       class="inline-flex items-center gap-2 text-slate-600 hover:text-emerald-600 transition-colors">
                                        <span class="material-symbols-outlined text-[18px]">description</span>
                                        <span class="text-xs font-medium truncate max-w-[120px]" title="@fileName">@fileName</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400 italic">Không có</span>
                                }
                            </td>

                            <td class="px-5 py-4 align-top text-right">
                                <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button onclick="processAction(@item.InstructorId, 'Approved')" class="px-3 py-1.5 text-xs font-medium bg-emerald-50 text-emerald-700 hover:bg-emerald-100 rounded-md transition-colors border border-emerald-200">
                                        Duyệt
                                    </button>
                                    <button onclick="processAction(@item.InstructorId, 'Rejected')" class="px-3 py-1.5 text-xs font-medium bg-white text-slate-600 hover:bg-slate-50 hover:text-red-600 border border-slate-200 rounded-md transition-colors">
                                        Từ chối
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="px-5 py-12 text-center">
                            <div class="flex flex-col items-center justify-center text-slate-400">
                                <span class="material-symbols-outlined text-4xl mb-2 text-slate-300">inbox</span>
                                <p class="text-sm">Không có đơn đăng ký nào chờ duyệt.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        async function processAction(id, status) {
            const actionText = status === 'Approved' ? 'duyệt' : 'từ chối';
            if (!confirm(`Xác nhận ${actionText} hồ sơ này?`)) return;

            try {
                const response = await fetch(`/AdminApproval/Process?id=${id}&status=${status}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const result = await response.json();
                if (result.success) {
                    const row = document.getElementById(`row-${id}`);
                    row.style.opacity = '0';
                    setTimeout(() => {
                        row.remove();
                        if (document.querySelectorAll('#approval-table-body tr').length === 0) {
                            location.reload();
                        }
                    }, 200);
                } else {
                    alert(result.message || "Lỗi khi xử lý.");
                }
            } catch (err) {
                alert("Lỗi kết nối server.");
            }
        }
    </script>
}