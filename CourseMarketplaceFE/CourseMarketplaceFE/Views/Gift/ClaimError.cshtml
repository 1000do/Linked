@{
    ViewData["Title"] = "Invalid Gift Card";
    var error = ViewBag.ErrorMessage as string ?? "This gift card is invalid or has expired.";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: radial-gradient(circle at 50% 50%, #fef9f8 0%, #f6f0ec 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .error-card {
        max-width: 500px;
        background: #fff;
        padding: 40px;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        text-align: center;
        border: 1px solid rgba(0,0,0,0.02);
    }

    .error-icon {
        font-size: 4rem;
        margin-bottom: 20px;
    }

    .error-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: 1.6rem;
        color: #2D3436;
        margin: 0 0 10px 0;
    }

    .error-desc {
        color: #636E72;
        line-height: 1.6;
        margin-bottom: 30px;
    }

    .home-btn {
        background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
        color: #fff;
        border: none;
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 6px 15px rgba(255,107,107,0.3);
        display: inline-block;
        transition: all 0.3s ease;
    }

    .home-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 20px rgba(255,107,107,0.4);
        color: #fff;
    }
</style>

<div class="error-card">
    <div class="error-icon">⚠️</div>
    <h3 class="error-title">Gift Card Error</h3>
    <p class="error-desc">@error</p>
    <a href="/" class="home-btn">Go to Homepage</a>
</div>
