@model CourseMarketplaceFE.Models.GiftSetupViewModel
@{
    ViewData["Title"] = "Gift Course - " + (ViewBag.Course?.Title ?? "Setup");
    var course = ViewBag.Course as CourseMarketplaceFE.Models.PublicCourseViewModel;
}

<style>
    .form-control.input-validation-error {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.15) !important;
    }

    .field-validation-error {
        margin-top: 8px;
        padding: 10px 14px;
        background-color: #fef2f2;
        border: 1px solid #fee2e2;
        color: #ef4444;
        border-radius: 16px;
        font-size: 0.8rem;
        font-weight: 600;
        display: flex !important;
        align-items: center;
        gap: 6px;
    }

    .field-validation-error::before {
        content: "warning";
        font-family: 'Material Symbols Outlined';
        font-size: 16px;
        color: #ef4444;
    }

    .theme-option {
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 12px 10px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        user-select: none;
        background: #ffffff;
        color: #475569;
    }

    .theme-option:hover {
        border-color: #cbd5e1;
        background: #f8fafc;
    }

    .theme-option.active {
        border-color: #006a62;
        background: rgba(0, 106, 98, 0.08);
        color: #006a62;
        box-shadow: 0 4px 12px rgba(0, 106, 98, 0.1);
    }

    .card-preview-wrapper {
        border-radius: 24px;
        padding: 24px;
        color: #ffffff;
        min-height: 220px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
    }

    .theme-classic {
        background: linear-gradient(135deg, #0f172a 0%, #006a62 50%, #004d47 100%);
    }

    .theme-birthday {
        background: linear-gradient(135deg, #f43f5e 0%, #ec4899 50%, #fbbf24 100%);
    }

    .theme-thanks {
        background: linear-gradient(135deg, #059669 0%, #10b981 50%, #06b6d4 100%);
    }

    .theme-congrats {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #db2777 100%);
    }
</style>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 grid grid-cols-1 lg:grid-cols-12 gap-8 font-body">
    <div class="lg:col-span-7 bg-white rounded-3xl p-8 border border-slate-100 shadow-xl shadow-slate-100/40">
        <h2 class="font-headline text-3xl font-extrabold text-slate-800 tracking-tight mb-2">Gift Details</h2>
        <p class="text-slate-500 font-medium mb-8">Personalize your gift card design and greeting message.</p>

        <form asp-action="Setup" method="post" id="giftForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CourseId" />
            <input type="hidden" asp-for="CardTheme" id="cardThemeInput" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-5 font-semibold"></div>

            <div class="mb-6">
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-2" asp-for="RecipientEmail"></label>
                <input asp-for="RecipientEmail" class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white transition-all text-slate-800 placeholder:text-slate-400 font-semibold text-sm" placeholder="example@email.com" id="recipientEmailInput" />
                <span asp-validation-for="RecipientEmail" class="text-danger text-xs font-semibold mt-1 block"></span>
            </div>

            <div class="mb-6">
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-2" asp-for="RecipientName"></label>
                <input asp-for="RecipientName" class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white transition-all text-slate-800 placeholder:text-slate-400 font-semibold text-sm" placeholder="Alex Carter" id="recipientNameInput" />
            </div>

            <div class="mb-6">
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-2">Choose Card Theme</label>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                    <div class="theme-option active" data-theme="classic">Classic</div>
                    <div class="theme-option" data-theme="birthday">Birthday 🎂</div>
                    <div class="theme-option" data-theme="thanks">Thanks 🙏</div>
                    <div class="theme-option" data-theme="congrats">Congrats 🎉</div>
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-xs font-bold uppercase tracking-wider text-slate-600 mb-2" asp-for="GiftMessage"></label>
                <textarea asp-for="GiftMessage" class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-white transition-all text-slate-800 placeholder:text-slate-400 font-semibold text-sm" rows="4" placeholder="Happy learning! Hope you enjoy this course..." id="messageInput" maxlength="1000"></textarea>
                <div class="text-right text-[10px] font-bold text-slate-400 mt-1.5"><span id="charCount">0</span>/1000 characters</div>
            </div>

            <button type="submit" class="w-full py-4 bg-primary hover:bg-[#005750] text-white font-bold text-sm rounded-2xl shadow-lg shadow-primary/25 hover:shadow-primary/35 transition-all duration-300 active:scale-[0.98] flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[20px]">payment</span>
                Proceed to Payment
            </button>
        </form>
    </div>

    <div class="lg:col-span-5 space-y-6">
        <div class="bg-white rounded-3xl border border-slate-100 shadow-xl shadow-slate-100/40 overflow-hidden">
            @if (course != null)
            {
                <img src="@(string.IsNullOrEmpty(course.CourseThumbnailUrl) ? "/img/default-course.jpg" : course.CourseThumbnailUrl)" class="w-full h-48 object-cover" alt="@course.Title" />
                <div class="p-6 space-y-3">
                    <span class="inline-block text-[9px] font-black uppercase tracking-wider text-slate-400 bg-slate-100 px-2.5 py-1 rounded-full">You are gifting:</span>
                    <h3 class="text-lg font-extrabold text-slate-800 font-headline leading-tight">@course.Title</h3>
                    <div class="text-2xl font-black text-primary font-mono">$@course.Price</div>
                </div>
            }
        </div>

        <div class="bg-white/70 backdrop-blur-md p-6 rounded-3xl border border-dashed border-slate-200 shadow-md">
            <h4 class="font-headline text-base font-extrabold text-slate-800 tracking-tight mb-1">Live Gift Card Preview</h4>
            <p class="text-[11px] font-semibold text-slate-400 mb-4">This is exactly how the email card will display to the recipient.</p>

            <div class="card-preview-wrapper theme-classic" id="cardPreview">
                <div class="flex items-center justify-between z-10">
                    <span class="preview-badge bg-white/20 backdrop-blur-md px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-wider border border-white/10 text-white">Special Gift</span>
                    <span class="text-xs font-black tracking-wider text-white">LinkedLearn</span>
                </div>
                <div class="preview-msg text-sm italic font-medium leading-relaxed my-6 break-words whitespace-pre-wrap text-white/90 z-10" id="previewMsg">Happy learning! Hope you enjoy this course...</div>
                <div class="flex justify-between items-end z-10">
                    <div class="preview-names">
                        <h4 class="text-sm font-black text-white mb-0.5" id="previewRecipient">To: Someone Special</h4>
                        <p class="text-[10px] text-white/80 font-medium">Enjoy a new learning experience!</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const themeOptions = document.querySelectorAll(".theme-option");
        const themeInput = document.getElementById("cardThemeInput");
        const cardPreview = document.getElementById("cardPreview");
        
        const messageInput = document.getElementById("messageInput");
        const previewMsg = document.getElementById("previewMsg");
        const charCount = document.getElementById("charCount");

        const recipientInput = document.getElementById("recipientNameInput");
        const previewRecipient = document.getElementById("previewRecipient");

        // Theme switching
        themeOptions.forEach(opt => {
            opt.addEventListener("click", function () {
                themeOptions.forEach(o => o.classList.remove("active"));
                this.classList.add("active");
                
                const theme = this.dataset.theme;
                themeInput.value = theme;

                // Reset preview classes
                cardPreview.className = "card-preview-wrapper theme-" + theme;
            });
        });

        // Sync message
        messageInput.addEventListener("input", function () {
            const val = this.value;
            previewMsg.textContent = val.trim() !== "" ? val : "Happy learning! Hope you enjoy this course...";
            charCount.textContent = val.length;
        });

        // Sync recipient
        recipientInput.addEventListener("input", function () {
            const val = this.value;
            previewRecipient.textContent = val.trim() !== "" ? "To: " + val : "To: Someone Special";
        });

        // Real-time recipient enrollment check
        const emailInput = document.getElementById("recipientEmailInput");
        const courseId = document.querySelector('input[name="CourseId"]').value;
        const submitBtn = document.querySelector(".submit-btn");
        let errorSpan = document.querySelector('[data-valmsg-for="RecipientEmail"]');

        let timeout = null;

        function validateRecipientEmail() {
            const email = emailInput.value.trim();
            if (!email) {
                if (errorSpan) errorSpan.textContent = "";
                submitBtn.disabled = false;
                submitBtn.style.opacity = "";
                submitBtn.style.cursor = "";
                return;
            }

            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!emailRegex.test(email)) {
                return; // Let standard validation handle layout
            }

            fetch(`/Gift/CheckRecipient?email=${encodeURIComponent(email)}&courseId=${courseId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.enrolled) {
                        if (errorSpan) {
                            errorSpan.textContent = "The recipient has already owned/joined this course.";
                            errorSpan.className = "text-danger field-validation-error";
                        }
                        emailInput.classList.add("input-validation-error");
                        submitBtn.disabled = true;
                        submitBtn.style.opacity = "0.6";
                        submitBtn.style.cursor = "not-allowed";
                    } else {
                        if (errorSpan && errorSpan.textContent === "The recipient has already owned/joined this course.") {
                            errorSpan.textContent = "";
                            errorSpan.className = "text-danger field-validation-valid";
                        }
                        emailInput.classList.remove("input-validation-error");
                        submitBtn.disabled = false;
                        submitBtn.style.opacity = "";
                        submitBtn.style.cursor = "";
                    }
                })
                .catch(err => {
                    console.error("Error checking enrollment:", err);
                });
        }

        emailInput.addEventListener("blur", validateRecipientEmail);
        emailInput.addEventListener("input", function() {
            clearTimeout(timeout);
            timeout = setTimeout(validateRecipientEmail, 500);
        });
    });
</script>
