@model IEnumerable<CourseMarketplaceFE.Models.EnrolledCourseViewModel>
@{
    ViewData["Title"] = "My Enrolled Courses";
}

<div class="min-h-screen bg-[#f8fafc] relative overflow-hidden pb-16">
    @* Decorative background elements *@
    <div class="absolute top-0 left-0 w-full h-64 bg-gradient-to-br from-primary/5 to-transparent -z-10"></div>
    <div class="absolute top-40 -right-20 w-80 h-80 bg-primary/5 rounded-full blur-3xl -z-10"></div>
    
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 relative">
        <div class="flex flex-col lg:flex-row gap-10">
            @* Sidebar *@
            @await Html.PartialAsync("_AccountSidebar", "MyCourses")

            @* Main Content *@
            <div class="flex-grow space-y-8">
                <!-- Header Section -->
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
                    <div>
                        <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-2">My Enrolled Courses</h1>
                        <p class="text-slate-500 font-medium">Continue your learning journey and track your course progress.</p>
                    </div>
                    <div class="flex items-center gap-4">
                        <a href="@Url.Action("Index", "Course")" 
                           class="group flex items-center gap-2 bg-white border-2 border-slate-100 hover:border-primary px-6 py-3.5 rounded-2xl text-slate-600 hover:text-primary font-bold transition-all duration-300 shadow-sm hover:shadow-md">
                            <span class="material-symbols-outlined group-hover:rotate-12 transition-transform">explore</span>
                            Explore More
                        </a>
                    </div>
                </div>

    @if (Model == null || !Model.Any())
    {
        <!-- Empty State Design -->
        <div class="relative overflow-hidden bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8 md:p-16 text-center">
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-emerald-500/5 rounded-full blur-3xl"></div>
            
            <div class="relative z-10 max-w-2xl mx-auto">
                <div class="mb-10 transform transition-all duration-700 hover:scale-105">
                    <img src="/img/empty_courses.png" alt="No courses" class="mx-auto w-64 md:w-80 h-auto drop-shadow-2xl">
                </div>
                
                <h3 class="text-2xl md:text-3xl font-headline font-extrabold text-slate-900 mb-4">
                    Ready for new knowledge?
                </h3>
                <p class="text-slate-500 text-lg mb-10 leading-relaxed">
                    You haven't enrolled in any courses yet. Start your learning journey by finding a course that suits your goals.
                </p>
                
                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    <a href="@Url.Action("Index", "Course")" 
                       class="w-full sm:w-auto bg-primary hover:bg-emerald-700 text-white px-10 py-4 rounded-2xl font-bold text-lg shadow-lg shadow-primary/20 transition-all duration-300 hover:-translate-y-1">
                        Browse Courses
                    </a>
                    <button class="w-full sm:w-auto px-10 py-4 rounded-2xl font-bold text-slate-600 hover:bg-slate-50 transition-all">
                        Learn about pathways
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Course List (Horizontal Rows) -->
        <div class="space-y-6">
            @foreach (var item in Model)
            {
                <div class="group bg-white rounded-3xl p-5 border border-slate-100 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 flex flex-col md:flex-row items-center gap-6">
                    <!-- Thumbnail Container -->
                    <div class="relative w-full md:w-56 aspect-video rounded-2xl overflow-hidden bg-slate-100 flex-shrink-0">
                        <img src="@(string.IsNullOrEmpty(item.CourseThumbnailUrl) ? "/img/default-course.png" : item.CourseThumbnailUrl)" 
                             onerror="this.onerror=null; this.src='/img/default-course.png';"
                             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
                             alt="@item.Title">
                        
                        @if (item.IsCompleted)
                        {
                            <div class="absolute inset-0 bg-emerald-500/10 backdrop-blur-[1px] flex items-center justify-center">
                                <span class="bg-emerald-500 text-white text-[9px] font-black uppercase tracking-wider px-2.5 py-1 rounded-full shadow-md flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px] fill-current">check_circle</span>
                                    Completed
                                </span>
                            </div>
                        }
                    </div>

                    <!-- Content -->
                    <div class="flex-grow space-y-4 text-center md:text-left min-w-0">
                        <div>
                            <span class="text-[9px] font-black uppercase tracking-widest text-slate-400">Course</span>
                            <h3 class="text-xl font-bold text-slate-900 group-hover:text-primary transition-colors line-clamp-1 mt-0.5 leading-snug">
                                @item.Title
                            </h3>
                            <div class="flex items-center justify-center md:justify-start gap-2 mt-1.5 text-xs text-slate-500 font-medium">
                                <span class="material-symbols-outlined text-sm">person</span>
                                <span>@item.InstructorName</span>
                            </div>
                        </div>

                        <!-- Progress Section -->
                        <div class="bg-slate-50 rounded-2xl p-4 border border-slate-100 max-w-md">
                            <div class="flex justify-between items-center mb-1.5">
                                <span class="text-[9px] font-bold uppercase tracking-wider text-slate-400">Progress</span>
                                <span class="text-xs font-black text-primary">@item.ProgressPercentage%</span>
                            </div>
                            <div class="w-full h-2 bg-slate-200 rounded-full overflow-hidden">
                                <div class="h-full rounded-full transition-all duration-1000 ease-out @(item.IsCompleted ? "bg-emerald-500" : "bg-primary")"
                                     style="width: @item.ProgressPercentage%;">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Button -->
                    <div class="flex-shrink-0 w-full md:w-auto">
                        <a href="@Url.Action("Learn", "Course", new { id = item.CourseId })" 
                           class="flex items-center justify-center gap-2 w-full md:w-auto px-8 py-4 rounded-2xl font-bold transition-all duration-300 @(item.IsCompleted ? "bg-emerald-50/80 text-emerald-600 hover:bg-emerald-500 hover:text-white border border-emerald-100 shadow-sm" : "bg-slate-900 text-white hover:bg-primary shadow-lg shadow-slate-900/10")">
                            <span class="material-symbols-outlined text-[20px]">@(item.IsCompleted ? "replay" : "play_arrow")</span>
                            <span>@(item.IsCompleted ? "Review" : "Continue learning")</span>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        @@keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }
        .float-animation {
            animation: float 4s ease-in-out infinite;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            @if (TempData["CartSuccess"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '🎉 Purchase Successful!',
                    text: '@Html.Raw(TempData["CartSuccess"].ToString().Replace("'", "\\'"))',
                    confirmButtonColor: '#006a62',
                    background: '#ffffff',
                    customClass: {
                        popup: 'rounded-[2rem] border border-slate-100 p-8 shadow-2xl',
                        title: 'text-xl font-black text-slate-900 tracking-tight',
                        confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all bg-primary hover:bg-emerald-700'
                    }
                });
                </text>
            }

            @if (TempData["CartError"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Purchase Notification',
                    text: '@Html.Raw(TempData["CartError"].ToString().Replace("'", "\\'"))',
                    confirmButtonColor: '#ef4444',
                    background: '#ffffff',
                    customClass: {
                        popup: 'rounded-[2rem] border border-slate-100 p-8 shadow-2xl',
                        title: 'text-xl font-black text-slate-900 tracking-tight',
                        confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all bg-red-600 hover:bg-red-700'
                    }
                });
                </text>
            }
        });
    </script>
}
