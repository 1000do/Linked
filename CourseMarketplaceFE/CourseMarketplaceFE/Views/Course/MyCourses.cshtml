@model IEnumerable<CourseMarketplaceFE.Models.EnrolledCourseViewModel>
@{
    ViewData["Title"] = "Khóa học của tôi";
}

<div class="container py-5" style="min-height: 70vh;">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="fw-bold mb-1">Khóa học của tôi</h1>
            <p class="text-muted">Tiếp tục hành trình chinh phục tri thức của bạn.</p>
        </div>
        <div class="d-none d-md-block">
            <a href="@Url.Action("Index", "Course")" class="btn btn-outline-primary rounded-pill px-4">
                <i class="bi bi-search me-2"></i>Khám phá thêm
            </a>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 bg-light rounded-4 border border-dashed">
            <div class="mb-4">
                <i class="bi bi-journal-x display-1 text-muted"></i>
            </div>
            <h3>Bạn chưa tham gia khóa học nào</h3>
            <p class="text-muted mb-4">Hãy bắt đầu hành trình học tập bằng cách chọn một khóa học phù hợp.</p>
            <a href="@Url.Action("Index", "Course")" class="btn btn-primary btn-lg rounded-pill px-5">
                Xem danh sách khóa học
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border-0 shadow-sm hover-lift overflow-hidden course-card">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(item.CourseThumbnailUrl) ? "/images/course-default.jpg" : item.CourseThumbnailUrl)" 
                                 class="card-img-top course-thumbnail" alt="@item.Title" 
                                 style="height: 160px; object-fit: cover;">
                            @if (item.IsCompleted)
                            {
                                <div class="position-absolute top-0 end-0 m-2">
                                    <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm">
                                        <i class="bi bi-patch-check-fill me-1"></i>Hoàn thành
                                    </span>
                                </div>
                            }
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title fw-bold mb-2 line-clamp-2">@item.Title</h5>
                            <p class="text-muted small mb-3">Giảng viên: <span class="fw-semibold text-dark">@item.InstructorName</span></p>
                            
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small text-muted">Tiến độ</span>
                                    <span class="small fw-bold text-primary">@item.ProgressPercentage%</span>
                                </div>
                                <div class="progress mb-4" style="height: 8px; border-radius: 4px; background-color: #e9ecef;">
                                    <div class="progress-bar progress-bar-striped progress-bar-animated @(item.IsCompleted ? "bg-success" : "bg-primary")" 
                                         role="progressbar" 
                                         style="width: @item.ProgressPercentage%;" 
                                         aria-valuenow="@item.ProgressPercentage" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100"></div>
                                </div>
                                
                                <a href="@Url.Action("Learn", "Course", new { id = item.CourseId })" 
                                   class="btn @(item.IsCompleted ? "btn-outline-success" : "btn-primary") w-100 rounded-pill py-2 fw-bold">
                                    @(item.IsCompleted ? "Xem lại bài học" : "Tiếp tục học")
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-lift {
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
    }
    .course-card {
        border-radius: 1.25rem;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .course-thumbnail {
        transition: transform 0.5s ease;
    }
    .course-card:hover .course-thumbnail {
        transform: scale(1.05);
    }
    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
        background-color: #f8f9fa !important;
    }
</style>
