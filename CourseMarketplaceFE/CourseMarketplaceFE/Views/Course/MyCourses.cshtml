@model IEnumerable<CourseMarketplaceFE.Models.EnrolledCourseViewModel>
@{
    ViewData["Title"] = "My Enrolled Courses";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 min-h-[80vh]">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div>
            <nav class="flex mb-4" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-xs font-semibold uppercase tracking-widest text-slate-400">
                    <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
                    <li><span class="material-symbols-outlined text-[14px]">chevron_right</span></li>
                    <li class="text-primary">My Courses</li>
                </ol>
            </nav>
            <h1 class="text-4xl md:text-5xl font-headline font-extrabold text-slate-900 tracking-tight">
                Your <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-emerald-500">Learning Journey</span>
            </h1>
            <p class="text-slate-500 mt-4 text-lg max-w-2xl leading-relaxed">
                Upgrade your skills and conquer knowledge with LinkedLearn. Continue your progress!
            </p>
        </div>
        <div class="flex items-center gap-4">
            <a href="@Url.Action("Index", "Course")" 
               class="group flex items-center gap-2 bg-white border-2 border-slate-100 hover:border-primary px-6 py-3 rounded-2xl text-slate-600 hover:text-primary font-bold transition-all duration-300 shadow-sm hover:shadow-md">
                <span class="material-symbols-outlined group-hover:rotate-12 transition-transform">explore</span>
                Khám phá thêm
            </a>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <!-- Empty State Design -->
        <div class="relative overflow-hidden bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 p-8 md:p-16 text-center">
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-emerald-500/5 rounded-full blur-3xl"></div>
            
            <div class="relative z-10 max-w-2xl mx-auto">
                <div class="mb-10 transform transition-all duration-700 hover:scale-105">
                    <img src="/img/empty_courses.png" alt="No courses" class="mx-auto w-64 md:w-80 h-auto drop-shadow-2xl">
                </div>
                
                <h3 class="text-2xl md:text-3xl font-headline font-extrabold text-slate-900 mb-4">
                    Ready for new knowledge?
                </h3>
                <p class="text-slate-500 text-lg mb-10 leading-relaxed">
                    You haven't enrolled in any courses yet. Start your learning journey by finding a course that suits your goals.
                </p>
                
                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    <a href="@Url.Action("Index", "Course")" 
                       class="w-full sm:w-auto bg-primary hover:bg-emerald-700 text-white px-10 py-4 rounded-2xl font-bold text-lg shadow-lg shadow-primary/20 transition-all duration-300 hover:-translate-y-1">
                        Browse Courses
                    </a>
                    <button class="w-full sm:w-auto px-10 py-4 rounded-2xl font-bold text-slate-600 hover:bg-slate-50 transition-all">
                        Learn about pathways
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Course Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            @foreach (var item in Model)
            {
                <div class="group bg-white rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-2xl hover:shadow-primary/10 transition-all duration-500 overflow-hidden flex flex-col h-full">
                    <!-- Thumbnail Container -->
                    <div class="relative aspect-video overflow-hidden">
                        <img src="@(string.IsNullOrEmpty(item.CourseThumbnailUrl) ? "https://images.unsplash.com/photo-1497633762265-9d179a990aa6?w=800" : item.CourseThumbnailUrl)" 
                             class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
                             alt="@item.Title">
                        
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                        
                        @if (item.IsCompleted)
                        {
                            <div class="absolute top-4 right-4 z-10">
                                <span class="flex items-center gap-1.5 bg-emerald-500 text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full shadow-lg">
                                    <span class="material-symbols-outlined text-[14px] fill-current">check_circle</span>
                                    Completed
                                </span>
                            </div>
                        }
                        
                        <div class="absolute bottom-4 left-4 z-10 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                            <span class="text-white text-xs font-medium">Click to continue learning</span>
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="p-6 flex flex-col flex-1">
                        <div class="mb-4">
                            <h3 class="text-lg font-bold text-slate-900 line-clamp-2 leading-snug group-hover:text-primary transition-colors min-h-[3rem]">
                                @item.Title
                            </h3>
                            <div class="flex items-center gap-2 mt-3">
                                <div class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-[14px] text-slate-400">person</span>
                                </div>
                                <span class="text-xs font-semibold text-slate-500">@item.InstructorName</span>
                            </div>
                        </div>

                        <div class="mt-auto space-y-4">
                            <!-- Progress Section -->
                            <div class="bg-slate-50 rounded-2xl p-4">
                                <div class="flex justify-between items-center mb-2">
                                    <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Progress</span>
                                    <span class="text-xs font-bold text-primary">@item.ProgressPercentage%</span>
                                </div>
                                <div class="w-full h-2 bg-slate-200 rounded-full overflow-hidden">
                                    <div class="h-full rounded-full transition-all duration-1000 ease-out @(item.IsCompleted ? "bg-emerald-500" : "bg-primary")"
                                         style="width: @item.ProgressPercentage%;">
                                    </div>
                                </div>
                            </div>

                            <a href="@Url.Action("Learn", "Course", new { id = item.CourseId })" 
                               class="flex items-center justify-center gap-2 w-full py-3.5 rounded-2xl font-bold transition-all duration-300 @(item.IsCompleted ? "bg-emerald-50/50 text-emerald-600 hover:bg-emerald-500 hover:text-white border border-emerald-100" : "bg-slate-900 text-white hover:bg-primary shadow-lg shadow-slate-900/10")">
                                <span class="material-symbols-outlined text-[20px]">@(item.IsCompleted ? "replay" : "play_arrow")</span>
                                @(item.IsCompleted ? "Review" : "Continue learning")
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Styles {
    <style>
        @@keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }
        .float-animation {
            animation: float 4s ease-in-out infinite;
        }
    </style>
}
