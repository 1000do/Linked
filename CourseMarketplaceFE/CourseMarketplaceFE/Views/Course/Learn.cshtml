@model CourseMarketplaceFE.Models.CourseDetailViewModel
@{
    ViewData["Title"] = "Learning: " + Model.Title;
    Layout = null; // No layout for full-screen player experience
    var firstMaterial = Model.Lessons.SelectMany(l => l.LearningMaterials).FirstOrDefault();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/img/default-avatar.png" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f0fcfb; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #006a6233; border-radius: 3px; }
        .active-material { background-color: #e0f2f1; border-left: 4px solid #006a62; }
        .fill-1 { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>
<body class="bg-[#f0fcfb] text-[#191c1b] h-screen flex flex-col overflow-hidden">

    <!-- Header -->
    <header class="h-14 bg-[#006a62] text-white flex items-center justify-between px-6 shrink-0 z-50 shadow-md">
        <div class="flex items-center gap-4">
            <a href="/Course/Details/@Model.CourseId" class="hover:opacity-80 transition-all">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div class="h-6 w-px bg-white/20"></div>
            <div class="flex flex-col">
                <h1 class="font-bold text-sm truncate max-w-md">@Model.Title</h1>
                <div class="flex items-center gap-2 mt-0.5">
                    <div class="w-32 h-1.5 bg-white/20 rounded-full overflow-hidden">
                        <div id="top-progress-bar" class="h-full bg-[#43e8d8] transition-all duration-500" style="width: 0%"></div>
                    </div>
                    <span id="top-progress-text" class="text-[10px] font-bold text-white/70">0% complete</span>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-6 text-sm font-bold">
            <button onclick="showCertificate()" class="flex items-center gap-2 hover:opacity-80 transition-all">
                <span class="material-symbols-outlined text-[#43e8d8]">workspace_premium</span>
                <span>Get Certificate</span>
            </button>
            <button class="bg-[#43e8d8] text-[#00201d] px-4 py-1.5 rounded text-xs hover:opacity-90 transition-all">Share</button>
        </div>
    </header>

    <!-- Certificate Modal (Hidden) -->
    <div id="certificate-modal" class="fixed inset-0 z-[100] hidden flex items-center justify-center bg-black/80 p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-3xl overflow-hidden animate-in zoom-in duration-300">
            <div class="p-8 text-center border-b border-slate-100">
                <div class="mb-6 relative inline-block">
                    <div class="w-24 h-24 bg-[#006a62]/10 rounded-full flex items-center justify-center mx-auto text-[#006a62]">
                        <span class="material-symbols-outlined text-[64px]">workspace_premium</span>
                    </div>
                    <div class="absolute -top-2 -right-2 bg-amber-400 text-white rounded-full p-1 shadow-lg">
                        <span class="material-symbols-outlined text-[24px]">stars</span>
                    </div>
                </div>
                <h2 class="text-3xl font-bold text-slate-900 mb-2">Congratulations!</h2>
                <p class="text-slate-500">You have successfully completed this course.</p>
            </div>
            
            <!-- The Certificate UI -->
            <div id="certificate-content" class="p-12 bg-slate-50 flex flex-col items-center justify-center border-8 border-white shadow-inner m-4 rounded-lg relative overflow-hidden select-none">
                <!-- Ornate corners -->
                <div class="absolute top-4 left-4 w-12 h-12 border-t-4 border-l-4 border-[#006a62]/20"></div>
                <div class="absolute top-4 right-4 w-12 h-12 border-t-4 border-r-4 border-[#006a62]/20"></div>
                <div class="absolute bottom-4 left-4 w-12 h-12 border-b-4 border-l-4 border-[#006a62]/20"></div>
                <div class="absolute bottom-4 right-4 w-12 h-12 border-b-4 border-r-4 border-[#006a62]/20"></div>

                <h1 class="text-4xl font-serif text-[#006a62] font-bold mb-8">Certificate of Completion</h1>
                <p class="text-lg text-slate-600 mb-2 italic">This is to certify that</p>
                <p class="text-3xl font-bold text-slate-900 mb-8 border-b-2 border-slate-900 px-12 py-2">@User.Identity?.Name</p>
                <p class="text-lg text-slate-600 mb-2 italic">has successfully completed the course</p>
                <h3 class="text-2xl font-bold text-slate-800 text-center mb-12">@Model.Title</h3>
                
                <div class="flex justify-between w-full mt-8 border-t border-slate-200 pt-8">
                    <div class="text-center">
                        <p class="font-bold text-slate-900">@Model.InstructorName</p>
                        <p class="text-xs text-slate-500">Lead Instructor</p>
                    </div>
                    <div class="text-center">
                        <p class="font-bold text-slate-900">@DateTime.Now.ToString("dd/MM/yyyy")</p>
                        <p class="text-xs text-slate-500">Completion Date</p>
                    </div>
                    <div class="text-center">
                        <p class="font-bold text-[#006a62]">LINKED ACADEMY</p>
                        <p class="text-xs text-slate-500">Online Learning Platform</p>
                    </div>
                </div>
            </div>

            <div class="p-6 bg-white flex justify-center gap-4">
                <button onclick="downloadCertificate()" class="flex items-center gap-2 bg-[#006a62] text-white px-8 py-3 rounded-xl font-bold hover:bg-[#00534c] transition-all shadow-lg shadow-[#006a62]/20">
                    <span class="material-symbols-outlined">download</span>
                    Download Certificate (PDF)
                </button>
                <button onclick="closeCertificate()" class="flex items-center gap-2 border border-slate-200 text-slate-500 px-6 py-3 rounded-xl font-bold hover:bg-slate-50 transition-all">
                    Close
                </button>
            </div>
        </div>
    </div>

    <div class="flex-1 flex overflow-hidden">
        <!-- Main Content -->
        <main class="flex-1 flex flex-col relative bg-white overflow-y-auto custom-scrollbar">
            @{
                bool isFirstVideo = true;
                var fileType = firstMaterial?.MaterialMetadata?.FileType;
                if (!string.IsNullOrEmpty(fileType))
                {
                    isFirstVideo = fileType.StartsWith("video") || fileType == "mp4";
                }
            }
            <!-- Media Area -->
            <div class="w-full bg-[#191c1b] flex items-center justify-center relative group min-h-[500px] h-[80vh] shrink-0" oncontextmenu="return false;">
                <!-- Video Player -->
                <video id="main-video" class="w-full h-full @(isFirstVideo ? "" : "hidden")" controls autoplay controlsList="nodownload" oncontextmenu="return false;">
                    <source id="video-source" src="@(firstMaterial?.MaterialUrl ?? "")" type="video/mp4">
                </video>

                <!-- Document Viewer (Embed) -->
                <div id="document-viewer" class="w-full h-full bg-[#f0fcfb] flex flex-col @(isFirstVideo ? "hidden" : "")">
                    <div class="flex items-center justify-between px-6 py-3 bg-[#006a62]/10 border-b border-[#006a62]/20 shrink-0 select-none">
                        <div class="flex items-center gap-2 text-[#006a62] font-bold">
                            <span class="material-symbols-outlined text-[20px]">description</span>
                            <span id="doc-title" class="text-sm">@(firstMaterial?.Title)</span>
                        </div>
                        <div class="flex gap-3">
                            <span class="text-xs text-[#006a62] font-semibold bg-[#006a62]/10 px-2 py-1 rounded">Protected Material</span>
                        </div>
                    </div>
                    @{
                        bool isTxt = false;
                        if (!isFirstVideo && firstMaterial != null && !string.IsNullOrEmpty(firstMaterial.MaterialUrl))
                        {
                            isTxt = firstMaterial.MaterialUrl.EndsWith(".txt", StringComparison.OrdinalIgnoreCase);
                        }
                    }
                    <iframe id="doc-iframe" src="@(isTxt ? firstMaterial?.MaterialUrl : "")" class="w-full flex-1 bg-white hidden" frameborder="0"></iframe>
                    
                    <!-- Text Viewer -->
                    <div id="doc-txt-viewer" class="w-full flex-1 bg-white overflow-y-auto p-8 @(isTxt && !isFirstVideo ? "" : "hidden")">
                        <pre id="doc-txt-content" class="text-sm font-mono text-slate-800 whitespace-pre-wrap word-break"></pre>
                    </div>
                    
                    <div id="doc-download-fallback" class="w-full flex-1 bg-slate-50 flex flex-col items-center justify-center @(!isTxt && !isFirstVideo ? "" : "hidden")">
                        <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 text-center max-w-sm">
                            <div class="w-16 h-16 bg-[#006a62]/10 text-[#006a62] rounded-full flex items-center justify-center mx-auto mb-4">
                                <span class="material-symbols-outlined text-[32px]">download_for_offline</span>
                            </div>
                            <h3 class="text-lg font-bold text-slate-800 mb-2">Attached Resource</h3>
                            <p class="text-sm text-slate-500 mb-6">This file format is not supported for direct viewing in the browser. Please download to view.</p>
                            <a id="doc-download-btn" href="@(!isFirstVideo ? firstMaterial?.MaterialUrl : "#")" target="_blank" download class="bg-[#006a62] text-white px-6 py-2.5 rounded-full font-bold hover:bg-[#00544e] transition-colors flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[20px]">download</span>
                                Download Resource
                            </a>
                        </div>
                    </div>
                </div>
                
                <!-- Loading Overlay -->
                <div id="video-loader" class="absolute inset-0 bg-black/60 hidden flex items-center justify-center z-10">
                    <div class="w-12 h-12 border-4 border-[#006a62] border-t-[#43e8d8] rounded-full animate-spin"></div>
                </div>
            </div>

            <!-- Content Info Tabs -->
            <div class="flex-1 bg-white border-t border-slate-100 p-8 pb-20">
                <div class="max-w-4xl mx-auto">
                    <div class="flex gap-8 border-b border-slate-100 mb-6 sticky top-0 bg-white z-10 pt-2">
                        <button onclick="switchTab('overview', this)" class="tab-btn pb-4 border-b-2 border-[#006a62] text-[#006a62] font-bold text-sm">Overview</button>
                        <button class="pb-4 text-slate-400 font-bold text-sm hover:text-[#006a62] transition-colors">Notes</button>
                        <button class="pb-4 text-slate-400 font-bold text-sm hover:text-[#006a62] transition-colors">Announcements</button>
                        <button onclick="switchTab('reviews', this)" class="tab-btn pb-4 text-slate-400 font-bold text-sm hover:text-[#006a62] transition-colors">Reviews</button>
                    </div>
                    
                    <!-- Overview Tab Content -->
                    <div id="tab-overview" class="tab-content">
                        <h2 id="current-material-title" class="text-2xl font-bold mb-4">@(firstMaterial?.Title ?? "Select a lesson to start")</h2>
                        <div id="current-material-desc" class="text-slate-600 leading-relaxed prose prose-slate max-w-none">
                            @(Html.Raw(firstMaterial?.Description ?? "No description available."))
                        </div>
                    </div>

                    <!-- Reviews Tab Content -->
                    <div id="tab-reviews" class="tab-content hidden text-slate-700">
                        <h2 class="text-xl font-extrabold mb-6 text-[#191c1b]">Student Feedback</h2>
                        
                        <!-- Dynamic stats (populated via JS) -->
                        <div class="flex flex-col md:flex-row gap-8 mb-10 items-start">
                            <div class="text-center w-32 shrink-0">
                                <p id="learn-stats-avg" class="text-5xl font-extrabold text-[#006a62] mb-1">—</p>
                                <div id="learn-stats-stars" class="flex justify-center text-amber-500 mb-1"></div>
                                <p id="learn-stats-total" class="text-xs font-bold text-[#006a62]">Course Rating</p>
                            </div>
                            
                            <div id="learn-stats-bars" class="flex-1 w-full space-y-1.5 max-w-md">
                                <!-- Dynamic bars -->
                            </div>
                        </div>

                        <div class="space-y-6">
                            <h3 class="font-bold text-lg text-[#191c1b] mb-4">Reviews</h3>
                            
                            <!-- Submit Review Form (conditionally shown by JS) -->
                            <div id="learn-review-form" class="hidden">
                                <div class="bg-gradient-to-r from-[#006a62]/5 to-[#43e8d8]/10 p-6 rounded-2xl border border-[#006a62]/20 mb-8">
                                    <h4 class="font-bold text-sm mb-1 text-[#006a62]">✍️ Write your review</h4>
                                    <p class="text-xs text-slate-500 mb-4">Review after you have experienced the lesson</p>
                                    <div class="flex gap-1 mb-4" id="rating-input">
                                        @for (int i = 1; i <= 5; i++) {
                                            <button onclick="setRating(@i)" class="star-btn text-slate-300 hover:text-amber-500 transition-colors">
                                                <span class="material-symbols-outlined text-3xl">star</span>
                                            </button>
                                        }
                                        <input type="hidden" id="selected-rating" value="0" />
                                    </div>
                                    <textarea id="review-comment" rows="3" class="w-full bg-white border border-slate-200 rounded-lg p-4 text-sm focus:outline-none focus:ring-2 focus:ring-[#006a62]/20 mb-4" placeholder="Share your learning experience..."></textarea>
                                    <button onclick="submitReview()" id="submit-review-btn" class="bg-[#006a62] text-white px-6 py-2.5 rounded-full font-bold text-sm hover:bg-[#00544e] transition-all flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">send</span>
                                        Submit Review
                                    </button>
                                </div>
                            </div>

                            <!-- Blocked message for users who haven't learned yet -->
                            <div id="learn-review-blocked" class="hidden mb-8">
                                <div class="bg-slate-50 border border-slate-200 rounded-xl p-5 flex items-start gap-3">
                                    <span class="material-symbols-outlined text-[#006a62] text-xl mt-0.5">school</span>
                                    <div>
                                        <p id="learn-blocked-msg" class="text-sm font-medium text-slate-700"></p>
                                        <p class="text-xs text-slate-500 mt-1">Complete at least 1 lesson to unlock the review feature.</p>
                                    </div>
                                </div>
                            </div>

                            <div id="learn-reviews-list" class="space-y-6">
                                <!-- Loaded via JS -->
                            </div>

                            <div id="course-reviews-section" class="mt-12 pt-8 border-t border-slate-200">
                                <h3 class="font-bold text-lg text-[#191c1b] mb-4">Overall Course Reviews</h3>
                                <div id="course-reviews-list" class="space-y-6">
                                    <!-- Loaded via JS -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <!-- Sidebar (Curriculum) -->
        <aside class="w-[350px] bg-white border-l border-slate-100 flex flex-col shrink-0 shadow-sm">
            <div class="p-4 border-b border-slate-100 font-bold flex items-center justify-between text-[#191c1b]">
                <span>Course Content</span>
                <button class="text-slate-400 hover:text-[#006a62]"><span class="material-symbols-outlined">close</span></button>
            </div>
            
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                @foreach (var lesson in Model.Lessons)
                {
                    <div class="lesson-section border-b border-slate-50" data-lesson-id="@lesson.LessonId">
                        <button class="w-full px-4 py-3 bg-slate-50 flex items-center justify-between text-left hover:bg-slate-100 transition-colors"
                                onclick="this.nextElementSibling.classList.toggle('hidden')">
                            <div>
                                <p class="text-xs font-bold text-[#006a62] uppercase tracking-tighter">Section @(Model.Lessons.IndexOf(lesson) + 1)</p>
                                <div class="flex items-center gap-2">
                                    <h3 class="font-bold text-sm text-[#191c1b]">@lesson.Title</h3>
                                    <span class="lesson-rating-badge hidden text-[11px] font-bold text-amber-600 bg-amber-50 border border-amber-200 px-1.5 py-0.5 rounded-md leading-none"></span>
                                </div>
                            </div>
                            <span class="material-symbols-outlined text-slate-400">expand_more</span>
                        </button>
                        <div class="lesson-items bg-white">
                            @foreach (var material in lesson.LearningMaterials)
                            {
                                string mFileType = material.MaterialMetadata?.FileType;
                                if (string.IsNullOrEmpty(mFileType)) {
                                    mFileType = (material.MaterialUrl?.EndsWith(".mp4") == true || material.MaterialUrl?.EndsWith(".webm") == true) ? "video" : "document";
                                }

                                <div class="material-item group cursor-pointer border-b border-slate-50 @(material == firstMaterial ? "active-material" : "")"
                                      onclick="playMaterial('@material.MaterialUrl', '@material.Title', '@(material.Description?.Replace("'", "\\'"))', this, '@mFileType', @material.MaterialId, @lesson.LessonId)">
                                    <div class="px-4 py-4 flex gap-3">
                                        <div class="flex flex-col items-center pt-1 shrink-0">
                                            @if (mFileType.StartsWith("video") || mFileType == "mp4") {
                                                <span class="material-symbols-outlined text-[20px] text-slate-400 group-hover:text-[#006a62]">play_circle</span>
                                            } else {
                                                <span class="material-symbols-outlined text-[20px] text-slate-400 group-hover:text-[#006a62]">description</span>
                                            }
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-sm font-medium leading-tight mb-1 group-hover:text-[#006a62] transition-colors">@material.Title</p>
                                            <div class="flex items-center justify-between">
                                                <div class="flex items-center gap-2 text-[11px] text-slate-400">
                                                    @{
                                                        bool isVid = mFileType.StartsWith("video") || mFileType == "mp4";
                                                    }
                                                    <span class="material-symbols-outlined text-[14px]">@(isVid ? "ondemand_video" : "description")</span>
                                                    <span>@(isVid ? $"{(material.MaterialMetadata?.Duration / 60 ?? 0)} min" : "Document")</span>
                                                </div>
                                                <div id="check-@material.MaterialId" class="hidden text-emerald-500">
                                                    <span class="material-symbols-outlined fill-1 text-[18px]">check_circle</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </aside>
    </div>

    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const videoPlayer = document.getElementById('main-video');
        const videoSource = document.getElementById('video-source');
        const videoLoader = document.getElementById('video-loader');
        const docViewer = document.getElementById('document-viewer');
        const docTitle = document.getElementById('doc-title');
        const docIframe = document.getElementById('doc-iframe');
        const docDownloadFallback = document.getElementById('doc-download-fallback');
        const docDownloadBtn = document.getElementById('doc-download-btn');
        const titleEl = document.getElementById('current-material-title');
        const descEl = document.getElementById('current-material-desc');

        let currentMaterialId = 0;
        let currentLessonId = 0;

        async function loadProgress() {
            try {
                const res = await fetch('/Course/GetProgress/@Model.CourseId');
                const result = await res.json();
                if (result.success) {
                    const data = result.data;
                    const pct = Math.round(data.progressPercentage);
                    document.getElementById('top-progress-bar').style.width = pct + '%';
                    document.getElementById('top-progress-text').textContent = pct + '% complete';

                    // Update checkmarks in sidebar
                    if (data.completedMaterialIds) {
                        data.completedMaterialIds.forEach(id => {
                            const checkIcon = document.getElementById('check-' + id);
                            if (checkIcon) checkIcon.classList.remove('hidden');
                        });
                    }
                }
            } catch (e) {}
        }

        async function markAsCompleted(materialId) {
            try {
                await fetch('/Course/UpdateProgress', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ courseId: @Model.CourseId, materialId: materialId })
                });
                loadProgress();
                // Re-check eligibility after progress update (user might now be able to review)
                loadLearnEligibility();
            } catch (e) {}
        }

        videoPlayer.onended = () => {
            if (currentMaterialId) markAsCompleted(currentMaterialId);
        };

        // ── Stats (dynamic from DB) ────────────────────────────────
        async function loadLearnStats() {
            try {
                const res = await fetch('/Course/GetReviewStats/@Model.CourseId');
                const result = await res.json();
                if (result.success && result.data) {
                    const d = result.data;
                    document.getElementById('learn-stats-avg').textContent = (d.averageRating || 0).toFixed(1);
                    document.getElementById('learn-stats-total').textContent = `${d.totalReviews || 0} reviews`;
                    const avg = Math.round(d.averageRating || 0);
                    document.getElementById('learn-stats-stars').innerHTML = Array(5).fill(0).map((_, i) =>
                        `<span class="material-symbols-outlined text-[20px] ${i < avg ? 'fill-1' : ''}">star</span>`
                    ).join('');
                    const bars = [
                        { n: 5, pct: d.star5Pct },
                        { n: 4, pct: d.star4Pct },
                        { n: 3, pct: d.star3Pct },
                        { n: 2, pct: d.star2Pct },
                        { n: 1, pct: d.star1Pct }
                    ];
                    document.getElementById('learn-stats-bars').innerHTML = bars.map(b => `
                        <div class="flex items-center gap-3 group cursor-pointer">
                            <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                                <div class="h-full bg-[#006a62] transition-all duration-700" style="width: ${b.pct}%"></div>
                            </div>
                            <div class="flex items-center gap-1 w-28 shrink-0">
                                <div class="flex text-amber-500">
                                    ${Array(5).fill(0).map((_, i) => `<span class="material-symbols-outlined text-[14px] ${i < b.n ? 'fill-1' : ''}">star</span>`).join('')}
                                </div>
                                <span class="text-xs text-[#006a62] font-bold">${b.pct}%</span>
                            </div>
                        </div>
                    `).join('');
                }
            } catch(e) {}
        }

        // ── Eligibility Check ──────────────────────────────────────
        async function loadLearnEligibility() {
            try {
                const res = await fetch('/Course/GetReviewEligibility/@Model.CourseId');
                const result = await res.json();
                if (result.success && result.data) {
                    const d = result.data;
                    if (d.canReview) {
                        document.getElementById('learn-review-form').classList.remove('hidden');
                        document.getElementById('learn-review-blocked').classList.add('hidden');
                    } else {
                        document.getElementById('learn-review-form').classList.add('hidden');
                        document.getElementById('learn-review-blocked').classList.remove('hidden');
                        document.getElementById('learn-blocked-msg').textContent = 
                            d.reviewBlockedReason || 'You need to complete at least 1 lesson before reviewing.';
                    }
                }
            } catch(e) {}
        }

        // ── Rating Input ───────────────────────────────────────────
        function setRating(n) {
            document.getElementById('selected-rating').value = n;
            const stars = document.querySelectorAll('.star-btn');
            stars.forEach((btn, i) => {
                const icon = btn.querySelector('.material-symbols-outlined');
                if (i < n) {
                    btn.classList.add('text-amber-500');
                    btn.classList.remove('text-slate-300');
                    icon.classList.add('fill-1');
                } else {
                    btn.classList.remove('text-amber-500');
                    btn.classList.add('text-slate-300');
                    icon.classList.remove('fill-1');
                }
            });
        }

        // ── Submit Review (source=learn) ───────────────────────────
        async function submitReview() {
            const rating = document.getElementById('selected-rating').value;
            const comment = document.getElementById('review-comment').value;
            if (rating == 0) return Swal.fire('Error', 'Please select a rating.', 'warning');
            if (!comment.trim()) return Swal.fire('Error', 'Please write a comment.', 'warning');

            const btn = document.getElementById('submit-review-btn');
            btn.disabled = true;
            btn.innerHTML = '<span class="animate-spin material-symbols-outlined text-[18px]">sync</span> Submitting...';

            try {
                const response = await fetch('/Course/SubmitReview?source=learn', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        courseId: @Model.CourseId, 
                        rating: parseFloat(rating), 
                        comment: comment,
                        lessonId: currentLessonId
                    })
                });
                const result = await response.json();
                if (result.success) {
                    Swal.fire('Success!', 'Lesson review has been submitted.', 'success');
                    document.getElementById('review-comment').value = '';
                    setRating(0);
                    loadReviews();
                    loadLearnStats();
                    loadLessonRatings();
                } else {
                    Swal.fire('Error', result.message || 'Could not submit review.', 'error');
                }
            } catch (e) {
                Swal.fire('Error', 'Could not submit review.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">send</span> Submit Review';
            }
        }

        // ── Load Reviews List ──────────────────────────────────────
        async function loadReviews() {
            const lessonList = document.getElementById('learn-reviews-list');
            const courseList = document.getElementById('course-reviews-list');
            
            // Load Lesson Reviews
            if (currentLessonId) {
                try {
                    const res = await fetch('/Course/GetLessonReviews/' + currentLessonId);
                    const result = await res.json();
                    if (result.success && result.data && result.data.items && result.data.items.length > 0) {
                        lessonList.innerHTML = result.data.items.map(r => renderReviewItem(r)).join('');
                    } else {
                        lessonList.innerHTML = '<p class="text-slate-400 italic">No reviews yet for this lesson.</p>';
                    }
                } catch (e) { lessonList.innerHTML = '<p class="text-red-400">Error loading lesson reviews.</p>'; }
            }

            // Load Course Reviews
            try {
                const res = await fetch('/Course/GetReviews/@Model.CourseId');
                const result = await res.json();
                if (result.success && result.data && result.data.items && result.data.items.length > 0) {
                    courseList.innerHTML = result.data.items.map(r => renderReviewItem(r)).join('');
                } else {
                    courseList.innerHTML = '<p class="text-slate-400 italic">No general reviews yet for this course.</p>';
                }
            } catch (e) { courseList.innerHTML = '<p class="text-red-400">Error loading course reviews.</p>'; }
        }

        async function reportReview(reviewId, type) {
            const { value: reason } = await Swal.fire({
                title: 'Report Review',
                input: 'select',
                inputOptions: {
                    'spam': 'Spam content',
                    'offensive': 'Offensive/Harassment',
                    'fake': 'Fake review',
                    'other': 'Other reason'
                },
                inputPlaceholder: 'Select report reason',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Submit Report'
            });

            if (reason) {
                try {
                    const response = await fetch('/Course/ReportReview', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ reviewId, type, reason })
                    });
                    const result = await response.json();
                    if (result.success) {
                        Swal.fire('Reported', 'Thank you for your feedback, a moderator will review this.', 'success');
                    } else {
                        Swal.fire('Error', 'Could not send report at this time.', 'error');
                    }
                } catch (e) {
                    Swal.fire('Error', 'Server connection error.', 'error');
                }
            }
        }

        // ── currentUserId từ JWT ────────────────────────────────────────────────────
        const currentUserId = parseInt('@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0")') || 0;

        function renderReviewItem(r) {
            const isOwn = currentUserId > 0 && r.userId === currentUserId;
            const createdTime = r.createdAt ? new Date(r.createdAt).getTime() : 0;
            const updatedTime = r.updatedAt ? new Date(r.updatedAt).getTime() : 0;
            const isEdited = updatedTime && updatedTime > (createdTime + 60000);
            const isRemoved = r.isRemoved;
            return `
                <div class="border-t border-slate-100 pt-6 group" id="review-card-${r.reviewId}">
                    <div class="flex gap-4 mb-3">
                        <div class="w-10 h-10 rounded-full bg-[#191c1b] text-white flex items-center justify-center font-bold text-sm shrink-0 overflow-hidden">
                            ${r.userAvatarUrl ? `<img src="${r.userAvatarUrl}" class="w-full h-full object-cover" />` : r.userFullName.charAt(0)}
                        </div>
                        <div class="flex-1">
                            <div class="flex items-center justify-between mb-1">
                                <h4 class="font-bold text-sm text-[#191c1b]">
                                    ${r.userFullName}
                                    ${r.isInstructor ? '<span class="ml-2 bg-[#006a62]/10 text-[#006a62] text-[10px] px-2 py-0.5 rounded-full border border-[#006a62]/20">Instructor</span>' : ''}
                                </h4>
                                <div class="relative flex items-center gap-2">
                                    <span class="text-[11px] text-slate-400 font-medium">${new Date(r.createdAt).toLocaleDateString('vi-VN')}</span>
                                    ${(isEdited && !isRemoved) ? '<span class="text-[10px] text-slate-400 italic">(edited)</span>' : ''}
                                    ${!isRemoved ? `
                                    <div class="relative opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button onclick="toggleLearnMenu(this)" class="w-7 h-7 flex items-center justify-center rounded-full hover:bg-slate-100 text-slate-400 hover:text-slate-700 transition-colors" title="More options">
                                            <span class="material-symbols-outlined text-[18px]">more_vert</span>
                                        </button>
                                        <div class="learn-review-menu hidden absolute right-0 top-8 z-30 min-w-[160px] bg-white border border-slate-200 rounded-2xl shadow-xl py-1.5">
                                            ${isOwn ? `
                                            <button onclick="editLearnReview(${r.reviewId}, '${r.lessonId ? 'lesson' : 'course'}', ${r.rating}, ${JSON.stringify(r.comment).replace(/"/g, '&quot;')}); closeAllLearnMenus()" class="w-full text-left px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 flex items-center gap-2">
                                                <span class="material-symbols-outlined text-[16px] text-blue-500">edit</span> Edit
                                            </button>
                                            <button onclick="deleteLearnReview(${r.reviewId}, '${r.lessonId ? 'lesson' : 'course'}'); closeAllLearnMenus()" class="w-full text-left px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50 flex items-center gap-2">
                                                <span class="material-symbols-outlined text-[16px]">delete</span> Delete
                                            </button>
                                            ` : `
                                            <button onclick="reportReview(${r.reviewId}, '${r.lessonId ? 'lesson' : 'course'}'); closeAllLearnMenus()" class="w-full text-left px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50 flex items-center gap-2">
                                                <span class="material-symbols-outlined text-[16px] text-orange-500">flag</span> Report
                                            </button>
                                            `}
                                        </div>
                                    </div>` : ''}
                                </div>
                            </div>
                            <div class="flex items-center gap-3 mb-2">
                                ${(!isRemoved && r.rating > 0) ? `
                                <div class="flex text-amber-500">
                                    ${Array(5).fill(0).map((_, i) => `
                                        <span class="material-symbols-outlined text-[14px] ${i < r.rating ? 'fill-1' : ''}">star</span>
                                    `).join('')}
                                </div>` : ''}
                                ${r.lessonTitle ? `
                                    <div class="flex items-center gap-1 bg-slate-100 text-slate-500 text-[10px] px-2 py-0.5 rounded border border-slate-200">
                                        <span class="material-symbols-outlined text-[12px]">menu_book</span>
                                        ${r.lessonTitle}
                                    </div>
                                ` : `
                                    <div class="flex items-center gap-1 bg-amber-50 text-amber-600 text-[10px] px-2 py-0.5 rounded border border-amber-200">
                                        <span class="material-symbols-outlined text-[12px]">auto_awesome</span>
                                        General review
                                    </div>
                                `}
                            </div>
                            <p class="text-sm ${isRemoved ? 'text-slate-400 italic' : 'text-slate-700'} leading-relaxed" id="review-text-${r.reviewId}">${r.comment}</p>
                            <!-- Edit form (hidden) -->
                            ${!isRemoved ? `
                            <div id="edit-form-${r.reviewId}" class="hidden mt-3 p-3 bg-slate-50 rounded-2xl border border-slate-200">
                                <div class="flex gap-1 mb-2" id="edit-stars-${r.reviewId}">
                                    ${Array(5).fill(0).map((_, i) => `
                                        <button type="button" onclick="setLearnEditRating(${r.reviewId}, ${i+1})" class="learn-edit-star text-slate-300 hover:text-amber-500 transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">star</span>
                                        </button>
                                    `).join('')}
                                    <input type="hidden" id="edit-rating-${r.reviewId}" value="${r.rating}" />
                                </div>
                                <textarea id="edit-comment-${r.reviewId}" rows="3" class="w-full rounded-xl border-slate-200 text-sm p-2 focus:ring-[#006a62] resize-none">${r.comment}</textarea>
                                <div class="flex gap-2 mt-2">
                                    <button onclick="saveLearnEditReview(${r.reviewId}, '${r.lessonId ? 'lesson' : 'course'}')" class="px-4 py-1.5 bg-[#006a62] text-white text-xs font-bold rounded-xl hover:bg-[#004d48] transition-colors">Save</button>
                                    <button onclick="cancelLearnEdit(${r.reviewId})" class="px-4 py-1.5 bg-slate-100 text-slate-600 text-xs font-bold rounded-xl hover:bg-slate-200 transition-colors">Cancel</button>
                                </div>
                            </div>` : ''}
                        </div>
                    </div>
                </div>
            `;
        }

        // ── Menu helpers ─────────────────────────────────────────────────
        function toggleLearnMenu(btn) {
            closeAllLearnMenus();
            btn.nextElementSibling.classList.toggle('hidden');
            setTimeout(() => document.addEventListener('click', closeAllLearnMenus, { once: true }), 0);
        }
        function closeAllLearnMenus() {
            document.querySelectorAll('.learn-review-menu').forEach(m => m.classList.add('hidden'));
        }

        // ── Edit helpers ────────────────────────────────────────────────
        function editLearnReview(reviewId, type, currentRating, currentComment) {
            document.getElementById(`edit-form-${reviewId}`).classList.remove('hidden');
            document.getElementById(`review-text-${reviewId}`).classList.add('hidden');
            setLearnEditRating(reviewId, Math.round(currentRating));
        }
        function cancelLearnEdit(reviewId) {
            document.getElementById(`edit-form-${reviewId}`).classList.add('hidden');
            document.getElementById(`review-text-${reviewId}`).classList.remove('hidden');
        }
        function setLearnEditRating(reviewId, n) {
            document.getElementById(`edit-rating-${reviewId}`).value = n;
            document.querySelectorAll(`#edit-stars-${reviewId} .learn-edit-star`).forEach((btn, i) => {
                const icon = btn.querySelector('.material-symbols-outlined');
                if (i < n) { btn.classList.add('text-amber-500'); btn.classList.remove('text-slate-300'); icon.classList.add('fill-1'); }
                else { btn.classList.remove('text-amber-500'); btn.classList.add('text-slate-300'); icon.classList.remove('fill-1'); }
            });
        }
        async function saveLearnEditReview(reviewId, type) {
            const rating = parseFloat(document.getElementById(`edit-rating-${reviewId}`).value);
            const comment = document.getElementById(`edit-comment-${reviewId}`).value.trim();
            if (!rating || rating < 1) return Swal.fire('Error', 'Please select a rating.', 'warning');
            if (!comment) return Swal.fire('Error', 'Comment cannot be empty.', 'warning');
            try {
                const res = await fetch(`/Course/UpdateReview?reviewId=${reviewId}&type=${type}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ rating, comment, type })
                });
                const result = await res.json();
                if (result.success) {
                    Swal.fire({ icon: 'success', title: 'Updated!', timer: 1500, showConfirmButton: false });
                    loadReviews();
                    loadLessonRatings();
                } else {
                    Swal.fire('Error', result.message || 'Could not update review.', 'error');
                }
            } catch { Swal.fire('Error', 'Could not connect to server.', 'error'); }
        }
        async function deleteLearnReview(reviewId, type) {
            const confirm = await Swal.fire({
                title: 'Delete this review?', text: 'This action cannot be undone.',
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#ef4444', confirmButtonText: 'Yes, delete it',
                customClass: { popup: 'rounded-3xl' }
            });
            if (!confirm.isConfirmed) return;
            try {
                const res = await fetch(`/Course/DeleteReview?reviewId=${reviewId}&type=${type}`, { method: 'DELETE' });
                const result = await res.json();
            if (result.success) {
                loadReviews();
                loadLessonRatings();
                Swal.fire({ icon: 'success', title: 'Deleted', timer: 1200, showConfirmButton: false });
            } else {
                    Swal.fire('Error', result.message || 'Could not delete review.', 'error');
                }
            } catch { Swal.fire('Error', 'Could not connect to server.', 'error'); }
        }

        // ── Sidebar: Load lesson avg ratings ──────────────────────────────
        let lessonRatingMap = {}; // { lessonId: { averageRating, totalReviews } }
        async function loadLessonRatings() {
            try {
                const res = await fetch('/Course/GetLessonRatings/@Model.CourseId');
                const result = await res.json();
                if (result.success && Array.isArray(result.data)) {
                    lessonRatingMap = {};
                    result.data.forEach(x => {
                        const lid = x.lessonId !== undefined ? x.lessonId : x.LessonId;
                        if (lid !== undefined) {
                            lessonRatingMap[lid] = x;
                        }
                    });
                    // Cập nhật badge rating trên tất cả lesson items
                    document.querySelectorAll('[data-lesson-id]').forEach(el => {
                        const lid = parseInt(el.dataset.lessonId);
                        const ratingInfo = lessonRatingMap[lid];
                        const badge = el.querySelector('.lesson-rating-badge');
                        if (badge) {
                            if (ratingInfo) {
                                const avg = ratingInfo.averageRating !== undefined ? ratingInfo.averageRating : ratingInfo.AverageRating;
                                if (avg !== undefined && avg !== null) {
                                    badge.textContent = `★ ${parseFloat(avg).toFixed(1)}`;
                                    badge.classList.remove('hidden');
                                    return;
                                }
                            }
                            badge.classList.add('hidden');
                        }
                    });
                }
            } catch (e) { console.error('Error loading lesson ratings:', e); }
        }


        // ── Tab Switching ──────────────────────────────────────────
        function switchTab(tabId, element) {
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('border-b-2', 'border-[#006a62]', 'text-[#006a62]');
                btn.classList.add('text-slate-400');
            });
            element.classList.add('border-b-2', 'border-[#006a62]', 'text-[#006a62]');
            element.classList.remove('text-slate-400');

            document.querySelectorAll('.tab-content').forEach(content => content.classList.add('hidden'));
            document.getElementById('tab-' + tabId).classList.remove('hidden');

            if (tabId === 'reviews') {
                loadReviews();
                loadLearnStats();
                loadLearnEligibility();
            }
        }

        function playMaterial(url, title, description, element, type, materialId, lessonId) {
            if (!url) {
                Swal.fire({
                    title: 'Empty Material',
                    text: 'This lesson does not have any uploaded materials yet.',
                    icon: 'info',
                    confirmButtonColor: '#006a62',
                    background: '#ffffff',
                    customClass: { popup: 'rounded-2xl shadow-xl' }
                });
                return;
            }
            currentMaterialId = materialId;
            currentLessonId = lessonId;

            // UI feedback
            document.querySelectorAll('.material-item').forEach(el => el.classList.remove('active-material'));
            element.classList.add('active-material');

            // Update Info
            titleEl.textContent = title;
            descEl.innerHTML = description || 'No description available.';

            const isVideo = type.startsWith('video') || type === 'mp4';

            if (isVideo) {
                docViewer.classList.add('hidden');
                videoPlayer.classList.remove('hidden');
                videoLoader.classList.remove('hidden');
                
                if (docIframe) {
                    docIframe.src = '';
                    docIframe.classList.add('hidden');
                }
                if (docDownloadFallback) docDownloadFallback.classList.add('hidden');

                let optimizedUrl = url;
                if (url.includes('cloudinary.com/df8i0azc5/video/upload/')) {
                    optimizedUrl = url.replace('/video/upload/', '/video/upload/f_auto,q_auto/');
                }

                videoSource.src = optimizedUrl;
                videoPlayer.load();
                videoPlayer.play().catch(e => console.log('Auto-play blocked or failed:', e));
                
                videoPlayer.onloadeddata = () => {
                    videoLoader.classList.add('hidden');
                };
            } else {
                videoPlayer.classList.add('hidden');
                videoPlayer.pause();
                docViewer.classList.remove('hidden');
                docTitle.textContent = title;
                
                var lowerUrl = url.toLowerCase();
                if (lowerUrl.endsWith('.txt')) {
                    if (docIframe) {
                        docIframe.src = '';
                        docIframe.classList.add('hidden');
                    }
                    if (docDownloadFallback) docDownloadFallback.classList.add('hidden');
                    
                    const txtViewer = document.getElementById('doc-txt-viewer');
                    const txtContent = document.getElementById('doc-txt-content');
                    if (txtViewer) txtViewer.classList.remove('hidden');
                    if (txtContent) txtContent.textContent = 'Loading content...';

                    fetch(url)
                        .then(res => res.arrayBuffer())
                        .then(buffer => {
                            const decoder = new TextDecoder('utf-8');
                            txtContent.textContent = decoder.decode(buffer);
                        })
                        .catch(err => {
                            txtContent.textContent = 'Error loading file: ' + err.message;
                        });
                    
                    markAsCompleted(materialId); // Mark text as completed immediately on view
                } else {
                    if (docIframe) {
                        docIframe.src = '';
                        docIframe.classList.add('hidden');
                    }
                    const txtViewer = document.getElementById('doc-txt-viewer');
                    if (txtViewer) txtViewer.classList.add('hidden');

                    if (docDownloadFallback) docDownloadFallback.classList.remove('hidden');
                    
                    let downloadUrl = url;
                    if (url.includes('cloudinary.com') && !url.includes('fl_attachment')) {
                        downloadUrl = url.replace(/\/upload\//, '/upload/fl_attachment/');
                    }
                    if (docDownloadBtn) {
                        docDownloadBtn.href = downloadUrl;
                        docDownloadBtn.onclick = () => markAsCompleted(materialId); // Mark when downloaded
                    }
                }
            }
        }

        async function showCertificate() {
            // Check if progress is 100%
            try {
                const res = await fetch('/Course/GetProgress/@Model.CourseId');
                const result = await res.json();
                if (result.success && result.data) {
                    const d = result.data;
                    const total = d.totalMaterialCount || 1;
                    const learned = d.learnedMaterialCount || 0;
                    const pct = (learned / total) * 100;
                    
                    if (pct < 100) {
                        Swal.fire({
                            title: 'Not Completed',
                            text: `You have only completed ${Math.round(pct)}%. Complete 100% of the lessons to receive your certificate!`,
                            icon: 'warning'
                        });
                        return;
                    }
                }
            } catch (e) {}

            document.getElementById('certificate-modal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeCertificate() {
            document.getElementById('certificate-modal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function downloadCertificate() {
            Swal.fire({
                title: 'Generating PDF',
                text: 'The system is generating a PDF copy of your certificate...',
                timer: 2000,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            }).then(() => {
                Swal.fire('Success!', 'Certificate has been downloaded.', 'success');
            });
        }

        window.addEventListener('DOMContentLoaded', () => {
            const firstItem = document.querySelector('.material-item');
            if (firstItem) {
                firstItem.classList.remove('active-material');
                firstItem.click();
            }
            loadProgress();
            loadLessonRatings();
        });
    </script>
</body>
</html>
