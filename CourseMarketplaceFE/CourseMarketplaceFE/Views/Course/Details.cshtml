@model CourseMarketplaceFE.Models.CourseDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}

<style>
    .prose p { margin-bottom: 1em; }
    .sticky-card {
        top: 24px;
        transition: all 0.3s ease;
    }
</style>

<!-- Hero Section -->
<div class="bg-[#1c1d1f] text-white py-12 px-8 border-b border-slate-700">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
            <nav class="flex gap-2 text-sm font-bold text-[#cec0fc] mb-4 uppercase tracking-wider">
                <a href="/" class="hover:text-white transition-colors">Home</a>
                <span>/</span>
                <a href="#" class="hover:text-white transition-colors">@(Model.CategoryName ?? "Category")</a>
            </nav>
            <h1 class="font-headline text-4xl font-extrabold mb-4 leading-tight">@Model.Title</h1>
            <div class="text-lg text-slate-300 mb-6 prose max-w-none line-clamp-2">
                @Html.Raw(Model.Description)
            </div>
            
            <div class="flex flex-wrap items-center gap-4 text-sm mb-6">
                <div class="flex items-center gap-1">
                    <span id="header-rating-avg" class="font-bold text-[#f3ca8c] text-base">@Model.RatingAverage.ToString("F1")</span>
                    <div id="header-rating-stars" class="flex text-[#f3ca8c]">
                        @for(int i=0; i<Math.Floor((double)Model.RatingAverage); i++) { <span class="material-symbols-outlined text-[18px] fill-1">star</span> }
                        @if((double)Model.RatingAverage - Math.Floor((double)Model.RatingAverage) >= 0.5) { <span class="material-symbols-outlined text-[18px] fill-1">star_half</span> }
                    </div>
                </div>
                <a href="#reviews" class="text-[#cec0fc] underline hover:text-white" id="header-rating-count">(@Model.TotalReviews ratings)</a>
                <span class="text-slate-300">@Model.TotalStudents students</span>
            </div>
            
            <div class="flex items-center gap-2 text-sm text-slate-300">
                <span>Created by <a href="#" class="text-[#cec0fc] hover:text-white underline font-bold">@Model.InstructorName</a></span>
            </div>
            
            <div class="mt-4 flex items-center gap-6 text-sm text-slate-300">
                <div class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">new_releases</span>
                    <span>Last updated @(Model.CreatedAt?.ToString("MM/yyyy") ?? "04/2026")</span>
                </div>
                <div class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">language</span>
                    <span>English</span>
                </div>
            </div>
        </div>
        
        <!-- Sticky Sidebar Card -->
        <div class="relative">
            <div class="lg:absolute top-0 right-0 w-full bg-white text-slate-900 rounded-xl shadow-2xl overflow-hidden border border-slate-200 z-20">
                <div class="aspect-video relative group cursor-pointer" onclick="openPreviewModal()">
                    @{
                        var thumbUrl = string.IsNullOrEmpty(Model.CourseThumbnailUrl) 
                            ? "https://images.unsplash.com/photo-1498050108023-c5249f4df085?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" 
                            : Model.CourseThumbnailUrl;
                        if (thumbUrl.Contains("cloudinary.com")) {
                            thumbUrl = thumbUrl.Replace("/image/upload/", "/image/upload/f_auto,q_auto,w_600/");
                        }
                    }
                    <img src="@thumbUrl" class="w-full h-full object-cover" />
                    <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-4xl text-slate-900">play_arrow</span>
                        </div>
                    </div>
                </div>
                
                <div class="p-6">
                    <div class="text-3xl font-extrabold mb-4">
                        @if (Model.Price == 0)
                        {
                            <span class="text-primary">FREE</span>
                        }
                        else
                        {
                            <span>$@Model.Price.ToString("F2")</span>
                        }
                    </div>
                    <div id="enrollment-actions" class="flex flex-col gap-3">
                        @if (Model.IsEnrolled || Model.IsOwner)
                        {
                            <a href="/Course/Learn/@Model.CourseId" class="w-full bg-slate-900 text-white text-center font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">play_circle</span>
                                Go to learning
                            </a>
                        }
                        else if (Model.Price == 0)
                        {
                            <button onclick="enrollFree(@Model.CourseId)" class="w-full bg-primary text-white font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">person_add</span>
                                Enroll Now
                            </button>
                        }
                        else
                        {
                            <button onclick="addToCart(@Model.CourseId)" class="w-full bg-primary text-white font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
                                Add to cart
                            </button>
                            <button onclick="buyNow(@Model.CourseId)" class="w-full border-2 border-slate-900 font-bold py-3 rounded-lg hover:bg-slate-50 transition-all">Buy now</button>
                        }
                        
                        <button type="button" 
                                onclick="toggleWishlist(this, @Model.CourseId);"
                                class="w-full border border-slate-200 font-bold py-3 rounded-lg hover:bg-slate-50 transition-all flex items-center justify-center gap-2 @(Model.IsInWishlist ? "text-red-500" : "text-slate-700")">
                            <span class="material-symbols-outlined @(Model.IsInWishlist ? "text-red-500" : "text-slate-400")" style='font-variation-settings: "FILL" @(Model.IsInWishlist ? "1" : "0");'>favorite</span>
                            <span class="wishlist-text">@(Model.IsInWishlist ? "Saved to Wishlist" : "Add to Wishlist")</span>
                        </button>
                    </div>
                    <p class="text-[11px] text-slate-500 text-center mt-4">30-Day Money-Back Guarantee</p>
                    
                    <div class="mt-6">
                        <p class="font-bold text-sm mb-3">This course includes:</p>
                        <ul class="text-sm space-y-2">
                            @{
                                var totalDurationInSeconds = Model.Lessons.SelectMany(l => l.LearningMaterials)
                                    .Where(m => m.MaterialMetadata?.FileType == "video")
                                    .Sum(m => m.MaterialMetadata?.Duration ?? 0);
                                var totalResources = Model.Lessons.SelectMany(l => l.LearningMaterials)
                                    .Count(m => m.MaterialMetadata?.FileType != "video");
                                var heroTotalHours = Math.Round(totalDurationInSeconds / 3600.0, 1);
                            }
                            <li class="flex items-center gap-3 text-slate-600">
                                <span class="material-symbols-outlined text-[18px]">ondemand_video</span>
                                <span>@(heroTotalHours > 0 ? heroTotalHours.ToString("F1") : "0") hours on-demand video</span>
                            </li>
                            <li class="flex items-center gap-3 text-slate-600">
                                <span class="material-symbols-outlined text-[18px]">description</span>
                                <span>@totalResources downloadable resources</span>
                            </li>
                            <li class="flex items-center gap-3 text-slate-600">
                                <span class="material-symbols-outlined text-[18px]">all_inclusive</span>
                                <span>Full lifetime access</span>
                            </li>
                            <li class="flex items-center gap-3 text-slate-600">
                                <span class="material-symbols-outlined text-[18px]">devices</span>
                                <span>Access on mobile and TV</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-8 py-12 grid grid-cols-1 lg:grid-cols-3 gap-12">
    <div class="lg:col-span-2">
        <!-- What you'll learn -->
        <div class="border border-slate-200 p-6 rounded mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">What you'll learn</h2>
            <div class="prose max-w-none text-sm text-slate-700">
                @if (!string.IsNullOrEmpty(Model.WhatYouWillLearn) && Model.WhatYouWillLearn != "<p><br></p>")
                {
                    @Html.Raw(Model.WhatYouWillLearn)
                }
                else
                {
                    <p class="italic text-slate-400">Instructor hasn't added this information yet.</p>
                }
            </div>
        </div>

        <!-- Course Content -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Course content</h2>
            @{
                var totalSeconds = Model.Lessons.SelectMany(l => l.LearningMaterials).Sum(m => m.MaterialMetadata?.Duration ?? 0);
                var totalHours = totalSeconds / 3600;
                var totalMinutes = (totalSeconds % 3600) / 60;
                var remainingSeconds = totalSeconds % 60;
                
                string totalDurationDisplay;
                if (totalHours > 0)
                {
                    totalDurationDisplay = $"{totalHours}h {totalMinutes}m {remainingSeconds}s";
                }
                else if (totalMinutes > 0)
                {
                    totalDurationDisplay = $"{totalMinutes}m {remainingSeconds}s";
                }
                else
                {
                    totalDurationDisplay = $"{remainingSeconds}s";
                }
            }
            <div class="flex justify-between items-center text-sm text-slate-600 mb-2">
                <span>@Model.Lessons.Count sections • @Model.Lessons.SelectMany(l => l.LearningMaterials).Count() lectures • @totalDurationDisplay total length</span>
                <button id="toggleSectionsBtn" class="flex items-center gap-1 text-[#a435f0] font-bold hover:text-[#8710d8]" onclick="toggleAllSections()">
                    <span>Expand all sections</span>
                    <span class="material-symbols-outlined text-[18px]">keyboard_arrow_down</span>
                </button>
            </div>
            
            <div class="border border-slate-200">
                @foreach (var lesson in Model.Lessons)
                {
                    var lessonSeconds = lesson.LearningMaterials.Sum(m => m.MaterialMetadata?.Duration ?? 0);
                    var lessonHours = lessonSeconds / 3600;
                    var lessonMins = (lessonSeconds % 3600) / 60;
                    var lessonSecs = lessonSeconds % 60;
                    
                    string lessonDurationDisplay;
                    if (lessonHours > 0)
                    {
                        lessonDurationDisplay = $"{lessonHours}h {lessonMins}m {lessonSecs}s";
                    }
                    else if (lessonMins > 0)
                    {
                        lessonDurationDisplay = $"{lessonMins}m {lessonSecs}s";
                    }
                    else
                    {
                        lessonDurationDisplay = $"{lessonSecs}s";
                    }

                    <div class="border-b border-slate-200 last:border-0">
                        <button class="w-full px-6 py-4 flex items-center justify-between bg-slate-50/50 hover:bg-slate-50 transition-colors text-left" onclick="this.nextElementSibling.classList.toggle('hidden')">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-slate-500 text-[20px]">expand_more</span>
                                <span class="font-bold text-slate-800">@lesson.Title</span>
                            </div>
                            <span class="text-sm text-slate-600">@lesson.LearningMaterials.Count lectures • @lessonDurationDisplay</span>
                        </button>
                        <div class="hidden px-6 py-2 bg-white">
                            @{ int materialIndex = 0; }
                            @foreach (var material in lesson.LearningMaterials)
                            {
                                var isFirstMaterial = materialIndex == 0 && lesson == Model.Lessons.First();
                                var isLocked = !Model.IsEnrolled && !isFirstMaterial;
                                
                                <div class="flex items-center justify-between text-sm py-3 @(isLocked ? "opacity-60" : "")">
                                    <div class="flex items-center gap-3 text-slate-700 flex-1">
                                        <span class="material-symbols-outlined text-slate-400 text-[18px]">
                                            @if (isLocked)
                                            {
                                                <text>lock</text>
                                            }
                                            else
                                            {
                                                @(material.MaterialMetadata?.FileType?.ToLower() == "video" || (material.MaterialUrl != null && (material.MaterialUrl.Contains(".mp4") || material.MaterialUrl.Contains("video/upload"))) ? "play_circle" : "description")
                                            }
                                        </span>
                                        
                                        @if (isFirstMaterial)
                                        {
                                            <button onclick="openPreviewModal()" class="text-[#a435f0] font-bold hover:underline cursor-pointer text-left">@material.Title</button>
                                            <span class="text-[10px] bg-emerald-100 text-emerald-700 px-1.5 py-0.5 rounded font-black uppercase tracking-tighter">Preview</span>
                                        }
                                        else if (isLocked)
                                        {
                                            <span class="cursor-not-allowed">@material.Title</span>
                                        }
                                        else
                                        {
                                            <a href="/Course/Learn/@Model.CourseId" class="hover:text-[#a435f0] hover:underline cursor-pointer">@material.Title</a>
                                        }
                                    </div>
                                    <div class="flex items-center gap-8">
                                        @if (isFirstMaterial)
                                        {
                                            <button onclick="openPreviewModal()" class="text-[#a435f0] font-bold hover:underline text-xs">Preview</button>
                                        }
                                        
                                        <span class="text-slate-500 text-xs w-12 text-right">
                                            @{
                                                var isVideoMat = material.MaterialMetadata?.FileType?.ToLower() == "video" || 
                                                                 (material.MaterialUrl != null && (material.MaterialUrl.Contains(".mp4") || material.MaterialUrl.Contains("video/upload")));
                                                if (isVideoMat)
                                                {
                                                    @(material.MaterialMetadata?.Duration > 0 
                                                        ? $"{(material.MaterialMetadata.Duration / 60):00}:{(material.MaterialMetadata.Duration % 60):00}" 
                                                        : "--:--")
                                                }
                                                else
                                                {
                                                    <span class="material-symbols-outlined text-[16px] opacity-40">@(isLocked ? "lock" : "description")</span>
                                                }
                                            }
                                        </span>
                                    </div>
                                </div>
                                materialIndex++;
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Requirements -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Requirements</h2>
            <div class="prose max-w-none text-sm text-slate-700">
                @if (!string.IsNullOrEmpty(Model.Requirements) && Model.Requirements != "<p><br></p>")
                {
                    @Html.Raw(Model.Requirements)
                }
                else
                {
                    <p class="italic text-slate-400">No specific requirements mentioned.</p>
                }
            </div>
        </div>

        <!-- Description -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Description</h2>
            <div class="text-slate-700 text-sm leading-relaxed prose max-w-none">
                @Html.Raw(Model.Description)
            </div>
        </div>

        <!-- Instructor -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Instructor</h2>
            <div class="flex flex-col gap-4">
                <div>
                    <h3 class="text-[#a435f0] font-bold text-lg underline hover:text-[#8710d8] cursor-pointer">@Model.InstructorName</h3>
                    <p class="text-slate-500 text-sm">@(string.IsNullOrEmpty(Model.InstructorProfessionalTitle) ? "Instructor" : Model.InstructorProfessionalTitle)</p>
                </div>
                <div class="flex gap-4 items-start">
                    <div class="w-32 h-32 rounded-full bg-slate-200 shrink-0 overflow-hidden">
                        <img src="@(string.IsNullOrEmpty(Model.InstructorAvatarUrl) ? $"https://ui-avatars.com/api/?name={Model.InstructorName?.Replace(" ", "+")}&background=random" : Model.InstructorAvatarUrl)" class="w-full h-full object-cover" />
                    </div>
                    <div class="space-y-2 text-sm text-slate-700">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-[18px] fill-1">star</span>
                            <span class="font-bold">@Model.RatingAverage.ToString("F1") Instructor Rating</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-[18px]">workspace_premium</span>
                            <span class="font-bold">@Model.InstructorReviewCount Reviews</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-[18px]">group</span>
                            <span class="font-bold">@Model.InstructorStudentsCount Students</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-[18px]">play_circle</span>
                            <span class="font-bold">@Model.InstructorCoursesCount Courses</span>
                        </div>
                        @if (!Model.IsOwner)
                        {
                            <button onclick="startChatWithInstructor(@Model.InstructorId)" 
                                    class="mt-4 px-6 py-2.5 bg-primary/10 text-primary rounded-xl font-bold text-sm hover:bg-primary hover:text-white transition-all flex items-center justify-center gap-2 group border border-primary/20">
                                <span class="material-symbols-outlined text-sm group-hover:rotate-12 transition-transform">chat</span>
                                Nhắn tin cho giảng viên
                            </button>
                        }
                    </div>
                </div>
                <div class="text-sm text-slate-700 mt-2 leading-relaxed prose max-w-none">
                    @if (!string.IsNullOrEmpty(Model.InstructorBio))
                    {
                        @Html.Raw(Model.InstructorBio)
                    }
                    else
                    {
                        <p>With years of experience in the industry, @Model.InstructorName is dedicated to helping students master new skills.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        <div class="mb-12" id="reviews-section">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold text-slate-900">Student feedback</h2>
            </div>
            
            <!-- Dynamic stats area (populated via JS) -->
            <div id="review-stats-area" class="flex flex-col md:flex-row gap-8 mb-10 items-start">
                <div class="text-center w-32 shrink-0">
                    <p id="stats-avg" class="text-5xl font-extrabold text-[#a435f0] mb-1">—</p>
                    <div id="stats-stars" class="flex justify-center text-amber-500 mb-1"></div>
                    <p id="stats-total" class="text-xs font-bold text-[#a435f0]">Course Rating</p>
                </div>
                
                <div id="stats-bars" class="flex-1 w-full space-y-2 max-w-md">
                    <!-- Dynamic bars -->
                </div>
            </div>

            <!-- Review Form (conditionally shown by JS) -->
            <div id="detail-review-form" class="hidden mb-10">
                <div class="bg-gradient-to-r from-[#a435f0]/5 to-[#a435f0]/10 p-6 rounded-2xl border border-[#a435f0]/20">
                    <h4 class="font-bold text-sm mb-1 text-[#a435f0]">✍️ Viết đánh giá của bạn</h4>
                    <p class="text-xs text-slate-500 mb-4">Chia sẻ trải nghiệm học tập của bạn với cộng đồng</p>
                    <div class="flex gap-1 mb-4" id="detail-rating-input">
                        @for (int ri = 1; ri <= 5; ri++) {
                            <button onclick="setDetailRating(@ri)" class="detail-star-btn text-slate-300 hover:text-amber-500 transition-colors">
                                <span class="material-symbols-outlined text-3xl">star</span>
                            </button>
                        }
                        <input type="hidden" id="detail-selected-rating" value="0" />
                    </div>
                    <textarea id="detail-review-comment" rows="3" class="w-full bg-white border border-slate-200 rounded-lg p-4 text-sm focus:outline-none focus:ring-2 focus:ring-[#a435f0]/30 mb-4" placeholder="Khóa học này đã giúp bạn như thế nào?"></textarea>
                    <button onclick="submitDetailReview()" id="detail-submit-btn" class="bg-[#a435f0] text-white px-6 py-2.5 rounded-full font-bold text-sm hover:bg-[#8710d8] transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">send</span>
                        Gửi đánh giá
                    </button>
                </div>
            </div>

            <!-- Status message (for users who haven't completed) -->
            <div id="detail-review-blocked" class="hidden mb-10">
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 flex items-start gap-3">
                    <span class="material-symbols-outlined text-amber-500 text-xl mt-0.5">info</span>
                    <div>
                        <p id="detail-blocked-msg" class="text-sm font-medium text-amber-800"></p>
                        <p class="text-xs text-amber-600 mt-1">Hoàn thành tất cả bài học để mở khóa chức năng đánh giá.</p>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-between mb-8 pb-4 border-b border-slate-100">
                <h3 class="text-xl font-bold text-slate-900">Đánh giá từ học viên</h3>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-slate-500 font-medium">Lọc theo:</span>
                    <select id="review-star-filter" onchange="loadReviews()" class="bg-white border border-slate-200 rounded-lg px-4 py-2 text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#a435f0]/20">
                        <option value="">Tất cả xếp hạng</option>
                        <option value="5">5 sao</option>
                        <option value="4">4 sao</option>
                        <option value="3">3 sao</option>
                        <option value="2">2 sao</option>
                        <option value="1">1 sao</option>
                    </select>
                </div>
            </div>

            <div class="space-y-6" id="reviews-list">
                <div class="flex items-center justify-center py-10 text-slate-400">
                    <span class="animate-spin material-symbols-outlined mr-2">sync</span>
                    Loading reviews...
                </div>
            </div>
        </div>

<!-- Video Preview Modal -->
<div id="previewModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center bg-black/90 p-4" onclick="closePreviewModal()">
    <div class="relative w-full max-w-4xl aspect-video bg-black rounded-xl overflow-hidden shadow-2xl" onclick="event.stopPropagation()">
        <button class="absolute top-4 right-4 text-white hover:text-slate-300 z-10 bg-black/50 rounded-full p-2" onclick="closePreviewModal()">
            <span class="material-symbols-outlined">close</span>
        </button>
        @{
            var firstVideo = Model.Lessons
                .SelectMany(l => l.LearningMaterials)
                .FirstOrDefault(m => m.MaterialMetadata?.FileType?.ToLower() == "video" || (m.MaterialUrl != null && m.MaterialUrl.Contains(".mp4")));
        }
        @if (firstVideo != null)
        {
            <video id="previewVideo" class="w-full h-full" controls controlsList="nodownload">
                @{
                    var previewUrl = firstVideo.MaterialUrl;
                    if (previewUrl.Contains("cloudinary.com")) {
                        previewUrl = previewUrl.Replace("/video/upload/", "/video/upload/f_auto,q_auto/");
                    }
                }
                <source src="@previewUrl" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        }
        else
        {
            <div class="w-full h-full flex flex-col items-center justify-center text-white gap-4">
                <span class="material-symbols-outlined text-6xl opacity-30">videocam_off</span>
                <p class="text-lg font-medium">No preview video available for this course.</p>
            </div>
        }
    </div>
</div>

<script>
    let allExpanded = false;

    function toggleAllSections() {
        allExpanded = !allExpanded;
        const sections = document.querySelectorAll('.border-b.border-slate-200 > div');
        const btn = document.getElementById('toggleSectionsBtn');
        const btnText = btn.querySelector('span:first-child');
        const btnIcon = btn.querySelector('.material-symbols-outlined');

        sections.forEach(section => {
            if (allExpanded) {
                section.classList.remove('hidden');
            } else {
                section.classList.add('hidden');
            }
        });

        // Toggle section icons
        const sectionIcons = document.querySelectorAll('.border-b.border-slate-200 button .material-symbols-outlined');
        sectionIcons.forEach(icon => {
            if (allExpanded) {
                icon.innerText = 'expand_less';
            } else {
                icon.innerText = 'expand_more';
            }
        });

        if (allExpanded) {
            btnText.innerText = 'Collapse all sections';
            btnIcon.innerText = 'keyboard_arrow_up';
        } else {
            btnText.innerText = 'Expand all sections';
            btnIcon.innerText = 'keyboard_arrow_down';
        }
    }

    function openPreviewModal() {
        const modal = document.getElementById('previewModal');
        const video = document.getElementById('previewVideo');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        if (video) video.play();
    }

    function closePreviewModal() {
        const modal = document.getElementById('previewModal');
        const video = document.getElementById('previewVideo');
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
        if (video) {
            video.pause();
            video.currentTime = 0;
        }
    }

    async function enrollFree(courseId) {
        const btn = event.currentTarget;
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="animate-spin material-symbols-outlined">sync</span> Enrolling...';

        try {
            const response = await fetch('/Course/EnrollFree/' + courseId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await response.json();
            
            if (result.success) {
                // 1. Update Buttons
                const actionContainer = document.getElementById('enrollment-actions');
                if (actionContainer) {
                    actionContainer.innerHTML = `
                        <a href="/Course/Learn/${courseId}" class="w-full bg-slate-900 text-white text-center font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">play_circle</span>
                            Go to learning
                        </a>
                        <button type="button" onclick="toggleWishlist(this, ${courseId});" class="w-full border border-slate-200 font-bold py-3 rounded-lg hover:bg-slate-50 transition-all flex items-center justify-center gap-2 text-slate-700">
                            <span class="material-symbols-outlined text-slate-400">favorite</span>
                            <span class="wishlist-text">Add to Wishlist</span>
                        </button>
                    `;
                }

                // 2. Unlock Curriculum
                document.querySelectorAll('.opacity-60').forEach(el => {
                    el.classList.remove('opacity-60');
                    // Replace lock icons with play_circle or description
                    const icon = el.querySelector('.material-symbols-outlined');
                    if (icon && icon.innerText === 'lock') {
                        icon.innerText = 'play_circle'; 
                    }
                    // Enable links
                    const titleSpan = el.querySelector('.cursor-not-allowed');
                    if (titleSpan) {
                        const link = document.createElement('a');
                        link.href = `/Course/Learn/${courseId}`;
                        link.className = 'hover:text-[#a435f0] hover:underline cursor-pointer';
                        link.innerText = titleSpan.innerText;
                        titleSpan.parentNode.replaceChild(link, titleSpan);
                    }
                    // Update metadata locks
                    el.querySelectorAll('.material-symbols-outlined.opacity-40').forEach(metaIcon => {
                        if (metaIcon.innerText === 'lock') metaIcon.innerText = 'description';
                    });
                });

                Swal.fire({
                    title: 'Thành công!',
                    text: 'Bạn đã ghi danh khóa học thành công.',
                    icon: 'success',
                    showCancelButton: true,
                    confirmButtonText: 'Bắt đầu học ngay',
                    cancelButtonText: 'Ở lại trang này'
                }).then((res) => {
                    if (res.isConfirmed) {
                        window.location.href = '/Course/Learn/' + courseId;
                    }
                });
            } else {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
                Swal.fire('Lỗi', result.message, 'error');
            }
        } catch (error) {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            Swal.fire('Lỗi', 'Không thể kết nối với máy chủ.', 'error');
        }
    }

