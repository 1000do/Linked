 @model CourseMarketplaceFE.Models.CourseDetailViewModel
@functions {
    public static string FormatDuration(int totalSeconds)
    {
        if (totalSeconds <= 0) return "0 mins";
        if (totalSeconds < 60) return totalSeconds == 1 ? "1 sec" : $"{totalSeconds} secs";
        
        if (totalSeconds < 3600)
        {
            var mins = (int)Math.Round(totalSeconds / 60.0);
            if (mins == 60) return "1 hr";
            return mins == 1 ? "1 min" : $"{mins} mins";
        }
        
        var hrs = totalSeconds / 3600;
        var remainingMins = (int)Math.Round((totalSeconds % 3600) / 60.0);
        if (remainingMins == 60)
        {
            hrs += 1;
            remainingMins = 0;
        }
        
        var hrText = hrs == 1 ? "1 hr" : $"{hrs} hrs";
        if (remainingMins == 0) return hrText;
        
        var minText = remainingMins == 1 ? "1 min" : $"{remainingMins} mins";
        return $"{hrText} {minText}";
    }
}
@{
    ViewData["Title"] = Model.Title;
    var userRole = Context.Request.Cookies["UserRole"]?.ToLower();
    var isManager = userRole == "admin" || userRole == "staff";
    
}

<style>
    .prose p { margin-bottom: 1em; }
    .sticky-card {
        top: 24px;
        transition: all 0.3s ease;
    }
    .review-menu-container.menu-open {
        opacity: 1 !important;
    }
</style>

<!-- Status Banner -->
@if (!Model.CourseStatus.Equals("published", StringComparison.OrdinalIgnoreCase))
{
    <div class="bg-amber-500 text-amber-950 font-bold text-center py-2 shadow-md w-full sticky top-20 z-[40]">
        WARNING: This course is currently in @Model.CourseStatus.ToUpper() state.
    </div>
}

<!-- Hero Section -->
<div class="bg-[#1c1d1f] text-white py-12 px-8 border-b border-slate-700">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
            <nav class="flex gap-2 text-sm font-bold text-[#cec0fc] mb-4 uppercase tracking-wider">
                <a href="/" class="hover:text-white transition-colors">Home</a>
                <span>/</span>
                <a href="#" class="hover:text-white transition-colors">@(Model.CategoryName ?? "Category")</a>
            </nav>
            <h1 class="font-headline text-4xl font-extrabold mb-4 leading-tight">@Model.Title</h1>
            <div class="text-lg text-slate-300 mb-6 prose max-w-none line-clamp-2">
                @Html.Raw(Model.Description)
            </div>
            
            <div class="flex flex-wrap items-center gap-4 text-sm mb-6">
                <div class="flex items-center gap-1">
                    <span id="header-rating-avg" class="font-bold text-[#f3ca8c] text-base">@Model.RatingAverage.ToString("F1")</span>
                    <div id="header-rating-stars" class="flex text-[#f3ca8c]">
                        @for(int i=0; i<Math.Floor((double)Model.RatingAverage); i++) { <span class="material-symbols-outlined text-[18px] fill-1">star</span> }
                        @if((double)Model.RatingAverage - Math.Floor((double)Model.RatingAverage) >= 0.5) { <span class="material-symbols-outlined text-[18px] fill-1">star_half</span> }
                    </div>
                </div>
                <a href="#reviews" class="text-[#cec0fc] underline hover:text-white" id="header-rating-count">(@Model.TotalReviews ratings)</a>
                <span class="text-slate-300">@Model.TotalStudents students</span>
            </div>
            
            <div class="flex items-center gap-2 text-sm text-slate-300">
                <span>Created by <a href="/Instructor/Profile/@Model.InstructorId" class="text-[#cec0fc] hover:text-white underline font-bold">@Model.InstructorName</a></span>
            </div>
            
            <div class="mt-4 flex items-center gap-6 text-sm text-slate-300">
                <div class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">new_releases</span>
                    <span>Last updated @(Model.CreatedAt?.ToString("MM/yyyy") ?? "04/2026")</span>
                </div>
                <div class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">language</span>
                    <span>English</span>
                </div>
            </div>
        </div>
        
        <!-- Sticky Sidebar Card -->
        <div class="relative">
            <div class="lg:absolute top-0 right-0 w-full bg-white text-slate-900 rounded-xl shadow-2xl overflow-hidden border border-slate-200 z-20">
                <div class="aspect-video relative group cursor-pointer" onclick="openPreviewModal()">
                    @{
                        var thumbUrl = string.IsNullOrEmpty(Model.CourseThumbnailUrl) 
                            ? "/img/default-course.png" 
                            : Model.CourseThumbnailUrl;
                        if (thumbUrl.Contains("cloudinary.com")) {
                            thumbUrl = thumbUrl.Replace("/image/upload/", "/image/upload/f_auto,q_auto,w_600/");
                        }
                    }
                    <img src="@thumbUrl" onerror="this.onerror=null; this.src='/img/default-course.png';" class="w-full h-full object-cover" />
                    <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-4xl text-slate-900">play_arrow</span>
                        </div>
                    </div>
                    
                    <!-- Report button container -->
                    <div id="course-report-container">
                        @if (Model.IsEnrolled && !Model.IsOwner && !isManager)
                        {
                            var isPermanentlyLocked = Model.CourseStatus?.Equals("archived", StringComparison.OrdinalIgnoreCase) == true && Model.FlagCount >= 3;
                            var hideReportBtn = (Model.CourseStatus?.Equals("pending", StringComparison.OrdinalIgnoreCase) == true) || 
                                                (Model.CourseStatus?.Equals("draft", StringComparison.OrdinalIgnoreCase) == true) || 
                                                isPermanentlyLocked;
                          
                            if (!hideReportBtn)
                            {
                                <button type="button" 
                                        onclick="event.stopPropagation(); reportCourse(@Model.CourseId);"
                                        class="absolute top-3 right-3 z-30 w-9 h-9 flex items-center justify-center rounded-lg bg-black/40 text-white/80 hover:bg-white hover:text-red-600 transition-all shadow-md backdrop-blur-sm"
                                        title="Report this course">
                                    <span class="material-symbols-outlined text-[20px]">flag</span>
                                </button>
                            }
                        }
                    </div>
                </div>
                
                <div class="p-6">
                    <div class="text-3xl font-extrabold mb-4">
                        @if (Model.Price == 0)
                        {
                            <span class="text-primary">FREE</span>
                        }
                        else
                        {
                            <span>$@Model.Price.ToString("F2")</span>
                        }
                    </div>
                    <div id="enrollment-actions" class="flex flex-col gap-3">
                        @if (Model.IsEnrolled && !Model.IsOwner)
                        {
                            <a href="/Course/Learn/@Model.CourseId" class="w-full bg-slate-900 text-white text-center font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">play_circle</span>
                                Go to learning
                            </a>
                            @if (Model.Price > 0)
                            {
                                <a href="/Gift/Setup?courseId=@Model.CourseId" class="w-full border-2 border-primary text-primary font-bold py-3 rounded-lg hover:bg-primary/5 transition-all flex items-center justify-center gap-2 text-center decoration-none">
                                    <span class="material-symbols-outlined text-[20px]">redeem</span>
                                    Gift this course
                                </a>
                            }
                        }
                        else if (Model.IsOwner || isManager)
                        {
                            <a href="/Course/Learn/@Model.CourseId" class="w-full bg-slate-900 text-white text-center font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">play_circle</span>
                                @(Model.IsOwner ? "Preview your course" : "Preview course")
                            </a>
                        }
                        else if (Model.Price == 0)
                        {
                            <button onclick="enrollFree(@Model.CourseId)" class="w-full bg-primary text-white font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">person_add</span>
                                Enroll Now
                            </button>
                        }
                        else
                        {
                            <button onclick="addToCart(@Model.CourseId, this)" class="w-full bg-primary text-white font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[20px]">add_shopping_cart</span>
                                Add to cart
                            </button>
                            <a href="/Gift/Setup?courseId=@Model.CourseId" class="w-full border-2 border-primary text-primary font-bold py-3 rounded-lg hover:bg-primary/5 transition-all flex items-center justify-center gap-2 text-center decoration-none">
                                <span class="material-symbols-outlined text-[20px]">redeem</span>
                                Gift this course
                            </a>
                        }
                        
                        @if (!Model.IsOwner && !isManager)
                        {
                            <button type="button" 
                                    onclick="toggleWishlist(this, @Model.CourseId);"
                                    class="w-full border border-slate-200 font-bold py-3 rounded-lg hover:bg-slate-50 transition-all flex items-center justify-center gap-2 @(Model.IsInWishlist ? "text-red-500" : "text-slate-700")">
                                <span class="material-symbols-outlined @(Model.IsInWishlist ? "text-red-500" : "text-slate-400")" style='font-variation-settings: "FILL" @(Model.IsInWishlist ? "1" : "0");'>favorite</span>
                                <span class="wishlist-text">@(Model.IsInWishlist ? "Saved to Wishlist" : "Add to Wishlist")</span>
                            </button>


                        }
                    </div>
                    @if (!Model.IsOwner && !isManager)
                    {
                        <p class="text-[11px] text-slate-500 text-center mt-4">14-Day Money-Back Guarantee</p>
                    }
                    
                    <div class="mt-6">
                        <p class="font-bold text-sm mb-3">This course includes:</p>
                        <ul class="text-sm space-y-2">
                            @{
                                var totalDurationInSeconds = Model.Lessons.SelectMany(l => l.LearningMaterials)
                                    .Where(m => m.MaterialMetadata?.FileType == "video")
                                    .Sum(m => m.MaterialMetadata?.Duration ?? 0);
                                var totalResources = Model.Lessons.SelectMany(l => l.LearningMaterials)
                                    .Count(m => m.MaterialMetadata?.FileType != "video");
                                var heroTotalHours = Math.Round(totalDurationInSeconds / 3600.0, 1);
                            }
                            <li class="flex items-center gap-3 text-slate-600">
                                <span class="material-symbols-outlined text-[18px]">ondemand_video</span>
                                <span>@(heroTotalHours > 0 ? heroTotalHours.ToString("F1") : "0") hours on-demand video</span>
                            </li>
                            <li class="flex items-center gap-3 text-slate-600">
                                <span class="material-symbols-outlined text-[18px]">description</span>
                                <span>@totalResources downloadable resources</span>
                            </li>
                            <li class="flex items-center gap-3 text-slate-600">
                                <span class="material-symbols-outlined text-[18px]">all_inclusive</span>
                                <span>Full lifetime access</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-8 py-12 grid grid-cols-1 lg:grid-cols-3 gap-12">
    <div class="lg:col-span-2">
        <!-- What you'll learn -->
        <div class="border border-slate-200 p-6 rounded mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">What you'll learn</h2>
            <div class="prose max-w-none text-sm text-slate-700">
                @if (!string.IsNullOrEmpty(Model.WhatYouWillLearn) && Model.WhatYouWillLearn != "<p><br></p>")
                {
                    @Html.Raw(Model.WhatYouWillLearn)
                }
                else
                {
                    <p class="italic text-slate-400">Instructor hasn't added this information yet.</p>
                }
            </div>
        </div>

        <!-- Course Content -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Course content</h2>
            @{
                var totalSeconds = Model.Lessons.SelectMany(l => l.LearningMaterials).Sum(m => m.MaterialMetadata?.Duration ?? 0);
                string totalDurationDisplay = FormatDuration(totalSeconds);
            }
            <div class="flex justify-between items-center text-sm text-slate-600 mb-2">
                <span>@Model.Lessons.Count sections • @Model.Lessons.SelectMany(l => l.LearningMaterials).Count() lectures • @totalDurationDisplay total length</span>
                <button id="toggleSectionsBtn" class="flex items-center gap-1 text-[#a435f0] font-bold hover:text-[#8710d8]" onclick="toggleAllSections()">
                    <span>Expand all sections</span>
                    <span class="material-symbols-outlined text-[18px]">keyboard_arrow_down</span>
                </button>
            </div>
            
            <div class="border border-slate-200">
                @foreach (var lesson in Model.Lessons)
                {
                    var lessonSeconds = lesson.LearningMaterials.Sum(m => m.MaterialMetadata?.Duration ?? 0);
                    string lessonDurationDisplay = FormatDuration(lessonSeconds);

                    <div class="border-b border-slate-200 last:border-0">
                        <button class="w-full px-6 py-4 flex items-center justify-between bg-slate-50/50 hover:bg-slate-50 transition-colors text-left" onclick="this.nextElementSibling.classList.toggle('hidden')">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-slate-500 text-[20px]">expand_more</span>
                                <span class="font-bold text-slate-800">@lesson.Title</span>
                                @if (isManager && Model.LastApprovedAt.HasValue && lesson.UpdatedAt > Model.LastApprovedAt)
                                {
                                    <span class="bg-amber-100 text-amber-700 text-[10px] px-2 py-0.5 rounded-full border border-amber-200 font-bold uppercase tracking-wider ml-1">Edited Section</span>
                                }
                            </div>
                            <span class="text-sm text-slate-600">@lesson.LearningMaterials.Count lectures • @lessonDurationDisplay</span>
                        </button>
                        <div class="hidden px-6 py-2 bg-white">
                            @{ int materialIndex = 0; }
                            @foreach (var material in lesson.LearningMaterials)
                            {
                                var isFirstMaterial = materialIndex == 0 && lesson == Model.Lessons.First();
                                var isLocked = !Model.IsEnrolled && !isFirstMaterial && !isManager && !Model.IsOwner;
                                
                                <div class="flex items-center justify-between text-sm py-3 @(isLocked ? "opacity-60" : "")">
                                    <div class="flex items-center gap-3 text-slate-700 flex-1">
                                        <span class="material-symbols-outlined text-slate-400 text-[18px]">
                                            @if (isLocked)
                                            {
                                                <text>lock</text>
                                            }
                                            else
                                            {
                                                @(material.MaterialMetadata?.FileType?.ToLower() == "video" || (material.MaterialUrl != null && (material.MaterialUrl.Contains(".mp4") || material.MaterialUrl.Contains("video/upload"))) ? "play_circle" : "description")
                                            }
                                        </span>
                                        
                                        @if (isFirstMaterial)
                                        {
                                            <button onclick="openPreviewModal()" class="text-[#a435f0] font-bold hover:underline cursor-pointer text-left">@material.Title</button>
                                            <span class="text-[10px] bg-emerald-100 text-emerald-700 px-1.5 py-0.5 rounded font-black uppercase tracking-tighter">Preview</span>
                                        }
                                        else if (isLocked)
                                        {
                                            <span class="cursor-not-allowed">@material.Title</span>
                                        }
                                        else
                                        {
                                            <a href="/Course/Learn/@Model.CourseId" class="hover:text-[#a435f0] hover:underline cursor-pointer">@material.Title</a>
                                        }

                                        @if (isManager && Model.LastApprovedAt.HasValue && material.UpdatedAt > Model.LastApprovedAt)
                                        {
                                            <span class="bg-orange-100 text-orange-700 text-[10px] px-2 py-0.5 rounded border border-orange-200 font-black uppercase tracking-tighter ml-1">New Content</span>
                                        }
                                    </div>
                                    <div class="flex items-center gap-8">
                                        @if (isFirstMaterial)
                                        {
                                            <button onclick="openPreviewModal()" class="text-[#a435f0] font-bold hover:underline text-xs">Preview</button>
                                        }
                                        
                                        <span class="text-slate-500 text-xs w-12 text-right">
                                            @{
                                                var isVideoMat = material.MaterialMetadata?.FileType?.ToLower() == "video" || 
                                                                 (material.MaterialUrl != null && (material.MaterialUrl.Contains(".mp4") || material.MaterialUrl.Contains("video/upload")));
                                                if (isVideoMat)
                                                {
                                                    @(material.MaterialMetadata?.Duration > 0 
                                                        ? $"{(material.MaterialMetadata.Duration / 60):00}:{(material.MaterialMetadata.Duration % 60):00}" 
                                                        : "--:--")
                                                }
                                                else
                                                {
                                                    <span class="material-symbols-outlined text-[16px] opacity-40">@(isLocked ? "lock" : "description")</span>
                                                }
                                            }
                                        </span>
                                    </div>
                                </div>
                                materialIndex++;
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Requirements -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Requirements</h2>
            <div class="prose max-w-none text-sm text-slate-700">
                @if (!string.IsNullOrEmpty(Model.Requirements) && Model.Requirements != "<p><br></p>")
                {
                    @Html.Raw(Model.Requirements)
                }
                else
                {
                    <p class="italic text-slate-400">No specific requirements mentioned.</p>
                }
            </div>
        </div>

        <!-- Description -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Description</h2>
            <div class="text-slate-700 text-sm leading-relaxed prose max-w-none">
                @Html.Raw(Model.Description)
            </div>
        </div>

        <!-- Instructor -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Instructor</h2>
            <div class="flex flex-col gap-4">
                    <div class="flex items-center justify-between">
                        <div>
                            <a href="/Instructor/Profile/@Model.InstructorId">
                                <h3 class="text-[#a435f0] font-bold text-lg underline hover:text-[#8710d8] cursor-pointer">@Model.InstructorName</h3>
                            </a>
                            <p class="text-slate-500 text-sm">@(string.IsNullOrEmpty(Model.InstructorProfessionalTitle) ? "Instructor" : Model.InstructorProfessionalTitle)</p>
                        </div>
                        @if (!Model.IsOwner && !isManager)
                        {
                            <button onclick="startChatWithInstructor(@Model.InstructorId)" 
                                    class="flex items-center gap-2 px-5 py-2 rounded-xl border-2 border-[#a435f0]/10 text-[#a435f0] text-sm font-bold hover:bg-[#a435f0] hover:text-white hover:border-[#a435f0] transition-all duration-300 group shadow-sm">
                                <span class="material-symbols-outlined text-[20px] group-hover:rotate-12 transition-transform">chat_bubble</span>
                                Message Instructor
                            </button>
                        }
                    </div>
                <div class="flex gap-4 items-start">
                    @await Html.PartialAsync("_UserAvatar", new { 
                        Url = Model.InstructorAvatarUrl, 
                        Role = "instructor", 
                        Name = Model.InstructorName, 
                        Size = "xl",
                        ShowFrame = true,
                        FrameUrl = ""
                    })
                    <div class="space-y-2 text-sm text-slate-700">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-[18px] fill-1">star</span>
                            <span class="font-bold">@Model.RatingAverage.ToString("F1") Instructor Rating</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-[18px]">workspace_premium</span>
                            <span class="font-bold">@Model.InstructorReviewCount Reviews</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-[18px]">group</span>
                            <span class="font-bold">@Model.InstructorStudentsCount Students</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-[18px]">play_circle</span>
                            <span class="font-bold">@Model.InstructorCoursesCount Courses</span>
                        </div>
                        @* Đã chuyển lên sidebar *@
                    </div>
                </div>
                <div class="text-sm text-slate-700 mt-2 leading-relaxed prose max-w-none">
                    @if (!string.IsNullOrEmpty(Model.InstructorBio))
                    {
                        @Html.Raw(Model.InstructorBio)
                    }
                    else
                    {
                        <p>With years of experience in the industry, @Model.InstructorName is dedicated to helping students master new skills.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        <div class="mb-12" id="reviews-section">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold text-slate-900">Student feedback</h2>
            </div>
            
            <!-- Dynamic stats area (populated via JS) -->
            <div id="review-stats-area" class="flex flex-col md:flex-row gap-8 mb-10 items-start">
                <div class="text-center w-32 shrink-0">
                    <p id="stats-avg" class="text-5xl font-extrabold text-[#a435f0] mb-1">—</p>
                    <div id="stats-stars" class="flex justify-center text-amber-500 mb-1"></div>
                    <p id="stats-total" class="text-xs font-bold text-[#a435f0]">Course Rating</p>
                </div>
                
                <div id="stats-bars" class="flex-1 w-full space-y-2 max-w-md">
                    <!-- Dynamic bars -->
                </div>
            </div>

            <!-- Review Form (conditionally shown by JS) -->
            <div id="detail-review-form" class="hidden mb-10">
                <div class="bg-gradient-to-r from-[#a435f0]/5 to-[#a435f0]/10 p-6 rounded-2xl border border-[#a435f0]/20">
                    <h4 class="font-bold text-sm mb-1 text-[#a435f0]">Write your review</h4>
                    <p class="text-xs text-slate-500 mb-4">Share your learning experience with the community</p>
                    <div class="flex gap-1 mb-4" id="detail-rating-input">
                        @for (int ri = 1; ri <= 5; ri++) {
                            <button onclick="setDetailRating(@ri)" class="detail-star-btn text-slate-300 hover:text-amber-500 transition-colors">
                                <span class="material-symbols-outlined text-3xl">star</span>
                            </button>
                        }
                        <input type="hidden" id="detail-selected-rating" value="0" />
                    </div>
                    <textarea id="detail-review-comment" rows="3" class="w-full bg-white border border-slate-200 rounded-lg p-4 text-sm focus:outline-none focus:ring-2 focus:ring-[#a435f0]/30 mb-4" placeholder="How has this course helped you?"></textarea>
                    <button onclick="submitDetailReview()" id="detail-submit-btn" class="bg-[#a435f0] text-white px-6 py-2.5 rounded-full font-bold text-sm hover:bg-[#8710d8] transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">send</span>
                        Submit Review
                    </button>
                </div>
            </div>

            <!-- Status message (for users who haven't completed) -->
            <div id="detail-review-blocked" class="hidden mb-10">
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 flex items-start gap-3">
                    <span class="material-symbols-outlined text-amber-500 text-xl mt-0.5">info</span>
                    <div>
                        <p id="detail-blocked-msg" class="text-sm font-medium text-amber-800"></p>
                        <p class="text-xs text-amber-600 mt-1">Complete all lessons to unlock the review feature.</p>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-between mb-8 pb-4 border-b border-slate-100">
                <h3 class="text-xl font-bold text-slate-900">Student Reviews</h3>
                <div class="flex items-center gap-3">
                    <span class="text-sm text-slate-500 font-medium">Filter by:</span>
                    <select id="review-star-filter" onchange="loadReviews()" class="bg-white border border-slate-200 rounded-lg px-4 py-2 text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#a435f0]/20">
                        <option value="">All Ratings</option>
                        <option value="5">5 stars</option>
                        <option value="4">4 stars</option>
                        <option value="3">3 stars</option>
                        <option value="2">2 stars</option>
                        <option value="1">1 star</option>
                    </select>
                </div>
            </div>

            <div class="space-y-6" id="reviews-list">
                <div class="flex items-center justify-center py-10 text-slate-400">
                    <span class="animate-spin material-symbols-outlined mr-2">sync</span>
                    Loading reviews...
                </div>
            </div>
        </div>

<!-- Video Preview Modal -->
<div id="previewModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center bg-black/90 p-4" onclick="closePreviewModal()">
    <div class="relative w-full max-w-4xl aspect-video bg-black rounded-xl overflow-hidden shadow-2xl" onclick="event.stopPropagation()">
        <button class="absolute top-4 right-4 text-white hover:text-slate-300 z-10 bg-black/50 rounded-full p-2" onclick="closePreviewModal()">
            <span class="material-symbols-outlined">close</span>
        </button>
        @{
            var firstVideo = Model.Lessons
                .SelectMany(l => l.LearningMaterials)
                .FirstOrDefault(m => !string.IsNullOrEmpty(m.MaterialUrl) && (m.MaterialMetadata?.FileType?.ToLower() == "video" || m.MaterialUrl.Contains(".mp4")));
        }
        @if (firstVideo != null && !string.IsNullOrEmpty(firstVideo.MaterialUrl))
        {
            <video id="previewVideo" class="w-full h-full" controls controlsList="nodownload">
                @{
                    var previewUrl = firstVideo.MaterialUrl;
                    if (!string.IsNullOrEmpty(previewUrl) && previewUrl.Contains("cloudinary.com")) {
                        previewUrl = previewUrl.Replace("/video/upload/", "/video/upload/f_auto,q_auto/");
                    }
                }
                <source src="@previewUrl" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        }
        else
        {
            <div class="w-full h-full flex flex-col items-center justify-center text-white gap-4">
                <span class="material-symbols-outlined text-6xl opacity-30">videocam_off</span>
                <p class="text-lg font-medium">No preview video available for this course.</p>
            </div>
        }
    </div>
</div>

<script>
    const localDetailsToken = `@Html.Raw(Context.Request.Cookies["AccessToken"] ?? "")`.trim();
    console.log("localDetailsToken",localDetailsToken);
    let allExpanded = false;
    
    function decodeToken(token) {
        try {
            const base64Url = token.split('.')[1];
            const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
            const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {
                return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
            }).join(''));
            console.log("Decoded token: " + jsonPayload);
            return JSON.parse(jsonPayload);
        } catch (e) {
            console.error("Failed to decode token", e);
            return null;
        }
    }
   
    

    function toggleAllSections() {
        allExpanded = !allExpanded;
        const sections = document.querySelectorAll('.border-b.border-slate-200 > div');
        const btn = document.getElementById('toggleSectionsBtn');
        const btnText = btn.querySelector('span:first-child');
        const btnIcon = btn.querySelector('.material-symbols-outlined');

        sections.forEach(section => {
            if (allExpanded) {
                section.classList.remove('hidden');
            } else {
                section.classList.add('hidden');
            }
        });

        // Toggle section icons
        const sectionIcons = document.querySelectorAll('.border-b.border-slate-200 button .material-symbols-outlined');
        sectionIcons.forEach(icon => {
            if (allExpanded) {
                icon.innerText = 'expand_less';
            } else {
                icon.innerText = 'expand_more';
            }
        });

        if (allExpanded) {
            btnText.innerText = 'Collapse all sections';
            btnIcon.innerText = 'keyboard_arrow_up';
        } else {
            btnText.innerText = 'Expand all sections';
            btnIcon.innerText = 'keyboard_arrow_down';
        }
    }

    function openPreviewModal() {
        const modal = document.getElementById('previewModal');
        const video = document.getElementById('previewVideo');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        if (video) video.play();
    }

    function closePreviewModal() {
        const modal = document.getElementById('previewModal');
        const video = document.getElementById('previewVideo');
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
        if (video) {
            video.pause();
            video.currentTime = 0;
        }
    }

    async function enrollFree(courseId) {
        if (!currentToken) {
            Swal.fire({
                title: 'Login Required',
                text: 'You need to log in to enroll in this course.',
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: 'Log In Now',
                cancelButtonText: 'Later'
            }).then((res) => { if (res.isConfirmed) window.location.href = '/Account/Login'; });
            return;
        }
        const btn = event.currentTarget;
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="animate-spin material-symbols-outlined">sync</span> Enrolling...';

        try {
            const response = await fetch('/Course/EnrollFree/' + courseId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            if (response.status === 401) {
                Swal.fire('Login Required', 'Please log in to continue.', 'warning')
                    .then(() => { window.location.href = '/Account/Login'; });
                return;
            }

            const result = await response.json();
            
            if (result.success) {
                // 1. Update Buttons
                const actionContainer = document.getElementById('enrollment-actions');
                if (actionContainer) {
                    actionContainer.innerHTML = `
                        <a href="/Course/Learn/${courseId}" class="w-full bg-slate-900 text-white text-center font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">play_circle</span>
                            Go to learning
                        </a>
                        <button type="button" onclick="toggleWishlist(this, ${courseId});" class="w-full border border-slate-200 font-bold py-3 rounded-lg hover:bg-slate-50 transition-all flex items-center justify-center gap-2 text-slate-700">
                            <span class="material-symbols-outlined text-slate-400">favorite</span>
                            <span class="wishlist-text">Add to Wishlist</span>
                        </button>
                    `;
                }

                // Update Report Button container dynamically
                const reportContainer = document.getElementById('course-report-container');
                if (reportContainer) {
                    reportContainer.innerHTML = `
                        <button type="button" 
                                onclick="event.stopPropagation(); reportCourse(${courseId});"
                                class="absolute top-3 right-3 z-30 w-9 h-9 flex items-center justify-center rounded-lg bg-black/40 text-white/80 hover:bg-white hover:text-red-600 transition-all shadow-md backdrop-blur-sm"
                                title="Report this course">
                            <span class="material-symbols-outlined text-[20px]">flag</span>
                        </button>
                    `;
                }

                // 2. Unlock Curriculum
                document.querySelectorAll('.opacity-60').forEach(el => {
                    el.classList.remove('opacity-60');
                    // Replace lock icons with play_circle or description
                    const icon = el.querySelector('.material-symbols-outlined');
                    if (icon && icon.innerText === 'lock') {
                        icon.innerText = 'play_circle'; 
                    }
                    // Enable links
                    const titleSpan = el.querySelector('.cursor-not-allowed');
                    if (titleSpan) {
                        const link = document.createElement('a');
                        link.href = `/Course/Learn/${courseId}`;
                        link.className = 'hover:text-[#a435f0] hover:underline cursor-pointer';
                        link.innerText = titleSpan.innerText;
                        titleSpan.parentNode.replaceChild(link, titleSpan);
                    }
                    // Update metadata locks
                    el.querySelectorAll('.material-symbols-outlined.opacity-40').forEach(metaIcon => {
                        if (metaIcon.innerText === 'lock') metaIcon.innerText = 'description';
                    });
                });

                Swal.fire({
                    title: 'Success!',
                    text: 'You have enrolled in the course successfully.',
                    icon: 'success',
                    showCancelButton: true,
                    confirmButtonText: 'Start Learning Now',
                    cancelButtonText: 'Stay on Page'
                }).then((res) => {
                    if (res.isConfirmed) {
                        window.location.href = '/Course/Learn/' + courseId;
                    }
                });
            } else {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
                Swal.fire('Error', result.message, 'error');
            }
        } catch (error) {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            if (error.status === 401) window.location.href = '/Account/Login';
            else Swal.fire('Error', 'An error occurred during enrollment.', 'error');
        }
    }



    async function loadReviewStats() {
        try {
            const res = await fetch('/Course/GetReviewStats/@Model.CourseId');
            const result = await res.json();
            if (result.success && result.data) {
                const d = result.data;
                // Average
                const avgVal = d.averageRating || 0;
                const totalVal = d.totalReviews || 0;
                
                document.getElementById('stats-avg').textContent = avgVal.toFixed(1);
                document.getElementById('stats-total').textContent = `${totalVal} reviews`;
                
                // Header update
                const headerAvg = document.getElementById('header-rating-avg');
                if (headerAvg) headerAvg.textContent = avgVal.toFixed(1);
                const headerCount = document.getElementById('header-rating-count');
                if (headerCount) headerCount.textContent = `(${totalVal} ratings)`;

                // Stars
                const roundedAvg = Math.round(avgVal);
                document.getElementById('stats-stars').innerHTML = Array(5).fill(0).map((_, i) =>
                    `<span class="material-symbols-outlined text-[20px] ${i < roundedAvg ? 'fill-1' : ''}">star</span>`
                ).join('');

                // Header Stars
                const headerStars = document.getElementById('header-rating-stars');
                if (headerStars) {
                    let starHtml = '';
                    for (let i = 0; i < 5; i++) {
                        if (i < Math.floor(avgVal)) {
                            starHtml += '<span class="material-symbols-outlined text-[18px] fill-1">star</span>';
                        } else if (i === Math.floor(avgVal) && (avgVal % 1) >= 0.5) {
                            starHtml += '<span class="material-symbols-outlined text-[18px] fill-1">star_half</span>';
                        } else {
                            starHtml += '<span class="material-symbols-outlined text-[18px]">star</span>';
                        }
                    }
                    headerStars.innerHTML = starHtml;
                }
                // Bars
                const bars = [
                    { n: 5, pct: d.star5Pct },
                    { n: 4, pct: d.star4Pct },
                    { n: 3, pct: d.star3Pct },
                    { n: 2, pct: d.star2Pct },
                    { n: 1, pct: d.star1Pct }
                ];
                document.getElementById('stats-bars').innerHTML = bars.map(b => `
                    <div class="flex items-center gap-3">
                        <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                            <div class="h-full bg-[#a435f0] transition-all duration-700" style="width: ${b.pct}%"></div>
                        </div>
                        <div class="flex items-center gap-1 w-28 shrink-0">
                            <div class="flex text-amber-500">
                                ${Array(5).fill(0).map((_, i) => `<span class="material-symbols-outlined text-[14px] ${i < b.n ? 'fill-1' : ''}">star</span>`).join('')}
                            </div>
                            <span class="text-xs text-[#a435f0] font-bold">${b.pct}%</span>
                        </div>
                    </div>
                `).join('');
                } else {
                    document.getElementById('stats-bars').innerHTML = renderErrorState('Failed to load rating statistics.', 'loadReviewStats()');
                }
        } catch(e) {
            console.warn('Stats load failed', e);
            document.getElementById('stats-bars').innerHTML = renderErrorState('Failed to load rating statistics.', 'loadReviewStats()');
        }
    }
    

    async function loadReviewEligibility() {
        try {
            const res = await fetch('/Course/GetReviewEligibility/@Model.CourseId');
            const result = await res.json();
            if (result.success && result.data) {
                const d = result.data;
                if (d.isEnrolled && d.isCompleted) {
                    document.getElementById('detail-review-form').classList.remove('hidden');
                    document.getElementById('detail-review-blocked').classList.add('hidden');
                } else if (d.isEnrolled && !d.isCompleted) {
                    document.getElementById('detail-review-form').classList.add('hidden');
                    document.getElementById('detail-review-blocked').classList.remove('hidden');
                    const pct = Math.round(d.progressPercentage || 0);
                    document.getElementById('detail-blocked-msg').textContent =
                        `Current progress: ${pct}%. You need to complete 100% of the course to write a review here.`;
                }
                // Not enrolled → both hidden (default)
            }
        } catch(e) { /* user not logged in → just hide form */ }
    }

    function setDetailRating(n) {
        document.getElementById('detail-selected-rating').value = n;
        const stars = document.querySelectorAll('.detail-star-btn');
        stars.forEach((btn, i) => {
            const icon = btn.querySelector('.material-symbols-outlined');
            if (i < n) {
                btn.classList.add('text-amber-500');
                btn.classList.remove('text-slate-300');
                icon.classList.add('fill-1');
            } else {
                btn.classList.remove('text-amber-500');
                btn.classList.add('text-slate-300');
                icon.classList.remove('fill-1');
            }
        });
    }

    async function submitDetailReview() {
        const rating = document.getElementById('detail-selected-rating').value;
        const comment = document.getElementById('detail-review-comment').value;
        if (rating == 0) return Swal.fire('Error', 'Please select a rating.', 'warning');
        if (!comment.trim()) return Swal.fire('Error', 'Please write a comment.', 'warning');

        const btn = document.getElementById('detail-submit-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="animate-spin material-symbols-outlined text-[18px]">sync</span> Submitting...';

        try {
            const response = await fetch('/Course/SubmitReview?source=detail', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ courseId: @Model.CourseId, rating: parseFloat(rating), comment: comment })
            });
            const result = await response.json();
            if (result.success) {
                Swal.fire('Success!', 'Your review has been submitted.', 'success');
                document.getElementById('detail-review-comment').value = '';
                setDetailRating(0);
                loadReviews();
                loadReviewStats();
            } else {
                Swal.fire('Error', result.message || 'Could not submit review.', 'error');
            }
        } catch (e) {
            Swal.fire('Error', 'Could not connect to server.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">send</span> Submit Review';
        }
    }

    
    const decoded = decodeToken(localDetailsToken);
    const localCurrentUserId = decoded ? parseInt(decoded["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"] || decoded["nameid"]) : null;
    const currentUserRole = decoded ? (decoded["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || decoded["role"]) : null;
    
    let currentReviewPage = 1;
    const REVIEW_PAGE_SIZE = 5;

    
    async function loadReviews(page = 1) {
        
        currentReviewPage = page;
        const list = document.getElementById('reviews-list');
        const filter = document.getElementById('review-star-filter').value;
        const starFilterParam = filter ? `&starFilter=${filter}` : '';
        try {
            const res = await fetch(`/Course/GetReviews/@Model.CourseId?page=${page}&pageSize=${REVIEW_PAGE_SIZE}${starFilterParam}`);
            const result = await res.json();

            if (result.success && result.data && result.data.items && result.data.items.length > 0) {
                const data = result.data.items;

                list.innerHTML = data.map(r => {
                    console.log("r.userId: ",r.userId);
                    console.log("r.UserId : ",r.UserId);
                    const isOwn = localCurrentUserId > 0 && (r.userId == localCurrentUserId || r.UserId == localCurrentUserId);
                    const createdTime = r.createdAt ? new Date(r.createdAt).getTime() : 0;
                    const updatedTime = r.updatedAt ? new Date(r.updatedAt).getTime() : 0;
                    const isEdited = updatedTime && updatedTime > (createdTime + 60000);
                    const isRemoved = r.isRemoved;
                    return `
                    ${(r.isRemoved && r.reviewStatus === 'violating') ? `
                    <div class="border-t border-slate-100 pt-6" id="review-card-${r.reviewId}">
                        <div class="flex gap-3 items-start">
                            <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-[16px] text-slate-400">gavel</span>
                            </div>
                            <p class="text-sm text-slate-400 italic pt-1">${r.comment}</p>
                        </div>
                    </div>
                    ` : r.isRemoved ? `
                    <div class="border-t border-slate-100 pt-6" id="review-card-${r.reviewId}">
                        <div class="flex gap-3 items-start">
                            <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-[16px] text-slate-400">delete</span>
                            </div>
                            <p class="text-sm text-slate-400 italic pt-1">This review was removed by the author.</p>
                        </div>
                    </div>
                    ` : `
                    <div class="border-t border-slate-100 pt-6 group" id="review-card-${r.reviewId}">
                        <div class="flex gap-4 mb-3">
                            <div class="w-10 h-10 rounded-full bg-slate-900 text-white flex items-center justify-center font-bold text-sm shrink-0 overflow-hidden">
                                ${r.userAvatarUrl ? `<img src="${r.userAvatarUrl}" class="w-full h-full object-cover" />` : r.userFullName.charAt(0)}
                            </div>
                            <div class="flex-1">
                                <div class="flex items-center justify-between mb-1">
                                    <h4 class="font-bold text-sm text-slate-900">
                                        ${r.userFullName}
                                        ${r.isInstructor ? '<span class="ml-2 bg-[#a435f0]/10 text-[#a435f0] text-[10px] px-2 py-0.5 rounded-full border border-[#a435f0]/20">Instructor</span>' : ''}
                                    </h4>
                                    <div class="relative flex items-center gap-2">
                                        <span class="text-[11px] text-slate-400 font-medium">${new Date(r.createdAt).toLocaleDateString('en-US')}</span>
                                        ${(isEdited && !isRemoved) ? '<span class="text-[10px] text-slate-400 italic">(edited)</span>' : ''}
                                        <!-- ⋮ dropdown - only for others -->
                                        ${(!isRemoved && !isOwn) ? `
                                        <div class="relative opacity-0 group-hover:opacity-100 focus-within:opacity-100 transition-opacity review-menu-container">
                                            <button onclick="toggleReviewMenu(event, this)" class="w-7 h-7 flex items-center justify-center rounded-full hover:bg-slate-100 text-slate-400 hover:text-slate-700 transition-colors" title="More options">
                                                <span class="material-symbols-outlined text-[18px]">more_vert</span>
                                            </button>
                                            <div class="review-menu hidden absolute right-0 top-8 z-30 min-w-[160px] bg-white border border-slate-200 rounded-2xl shadow-xl py-1.5">
                                                <button onclick="reportReview(${r.reviewId}, '${r.lessonId ? 'lesson' : 'course'}'); closeAllMenus()" class="w-full text-left px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50 flex items-center gap-2">
                                                    <span class="material-symbols-outlined text-[16px] text-orange-500">flag</span> Report
                                                </button>
                                            </div>
                                        </div>` : ''}
                                    </div>
                                </div>
                                <div class="flex items-center gap-3 mb-2">
                                    ${(!isRemoved && r.rating > 0) ? `
                                    <div class="flex text-amber-500">
                                        ${Array(5).fill(0).map((_, i) => `
                                            <span class="material-symbols-outlined text-[14px] ${i < r.rating ? 'fill-1' : ''}">star</span>
                                        `).join('')}
                                    </div>` : ''}
                                    ${r.lessonTitle ? `
                                        <div class="flex items-center gap-1 bg-slate-100 text-slate-500 text-[10px] px-2 py-0.5 rounded border border-slate-200">
                                            <span class="material-symbols-outlined text-[12px]">menu_book</span>
                                            ${r.lessonTitle}
                                        </div>
                                    ` : `
                                        <div class="flex items-center gap-1 bg-purple-50 text-purple-600 text-[10px] px-2 py-0.5 rounded border border-purple-200">
                                            <span class="material-symbols-outlined text-[12px]">auto_awesome</span>
                                            General review
                                        </div>
                                    `}
                                </div>
                                <p class="text-sm ${isRemoved ? 'text-slate-400 italic' : 'text-slate-700'} leading-relaxed" id="review-text-${r.reviewId}">${r.comment}</p>
                                ${(isOwn && !isRemoved) ? `
                                <div class="flex items-center gap-3 mt-2">
                                    <button onclick="editReview(${r.reviewId}, '${r.lessonId ? 'lesson' : 'course'}', ${r.rating}, ${JSON.stringify(r.comment).replace(/"/g, '&quot;')})" class="flex items-center gap-1 text-xs font-semibold text-slate-500 hover:text-blue-600 transition-colors">
                                        <span class="material-symbols-outlined text-[14px]">edit</span> Edit
                                    </button>
                                    <button onclick="deleteReview(${r.reviewId}, '${r.lessonId ? 'lesson' : 'course'}')" class="flex items-center gap-1 text-xs font-semibold text-slate-500 hover:text-red-600 transition-colors">
                                        <span class="material-symbols-outlined text-[14px]">delete</span> Delete
                                    </button>
                                </div>` : ''}
                                <!-- Edit form (hidden by default) -->
                                ${!isRemoved ? `
                                <div id="edit-form-${r.reviewId}" class="hidden mt-3 p-3 bg-slate-50 rounded-2xl border border-slate-200">
                                    <div class="flex gap-1 mb-2" id="edit-stars-${r.reviewId}">
                                        ${Array(5).fill(0).map((_, i) => `
                                            <button type="button" onclick="setEditRating(${r.reviewId}, ${i+1})" class="edit-star-btn text-slate-300 hover:text-amber-500 transition-colors">
                                                <span class="material-symbols-outlined text-[20px]">star</span>
                                            </button>
                                        `).join('')}
                                        <input type="hidden" id="edit-rating-${r.reviewId}" value="${r.rating}" />
                                    </div>
                                    <textarea id="edit-comment-${r.reviewId}" rows="3" class="w-full rounded-xl border-slate-200 text-sm p-2 focus:ring-[#a435f0] resize-none">${r.comment}</textarea>
                                    <div class="flex gap-2 mt-2">
                                        <button onclick="saveEditReview(${r.reviewId}, '${r.lessonId ? 'lesson' : 'course'}')" class="px-4 py-1.5 bg-[#a435f0] text-white text-xs font-bold rounded-xl hover:bg-[#8710d8] transition-colors">Save</button>
                                        <button onclick="cancelEdit(${r.reviewId})" class="px-4 py-1.5 bg-slate-100 text-slate-600 text-xs font-bold rounded-xl hover:bg-slate-200 transition-colors">Cancel</button>
                                    </div>
                                </div>` : ''}
                            </div>
                        </div>
                    </div>`}
                `}).join('');

                const totalPages = Math.ceil(result.data.totalCount / REVIEW_PAGE_SIZE);
                if (totalPages > 1) {
                    list.innerHTML += `
                        <div class="flex justify-center items-center gap-2 mt-6 pb-4">
                            <button onclick="loadReviews(${page - 1})" class="px-3 py-1 rounded-xl border border-slate-200 text-sm font-semibold text-slate-600 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors" ${page === 1 ? 'disabled' : ''}>Prev</button>
                            <span class="text-sm font-semibold text-slate-600">Page ${page} of ${totalPages}</span>
                            <button onclick="loadReviews(${page + 1})" class="px-3 py-1 rounded-xl border border-slate-200 text-sm font-semibold text-slate-600 hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors" ${page === totalPages ? 'disabled' : ''}>Next</button>
                        </div>
                    `;
                }
            } else {
                const filter = document.getElementById('review-star-filter').value;
                list.innerHTML = filter
                    ? `<p class="text-slate-400 italic text-center py-10">No ${filter}-star reviews found.</p>`
                    : `<p class="text-slate-400 italic text-center py-10">No reviews yet for this course.</p>`;
            }

            setTimeout(() => {
                if (window.location.hash && window.location.hash.startsWith('#review-card-')) {
                    const el = document.querySelector(window.location.hash);
                    if (el) {
                        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        el.classList.add('bg-yellow-100', 'transition-colors', 'duration-1000');
                        setTimeout(() => el.classList.remove('bg-yellow-100'), 3000);
                        history.replaceState(null, null, ' ');
                    }
                }
            }, 100);

        } catch (e) {
            list.innerHTML = renderErrorState('Could not load reviews.', `loadReviews(${page})`);
        }
    }

    function renderErrorState(message, retryFuncStr) {
        return `
            <div class="flex flex-col items-center justify-center py-8 px-4 text-center max-w-sm mx-auto">
                <div class="w-12 h-12 bg-red-50 text-red-500 rounded-full flex items-center justify-center mb-3">
                    <span class="material-symbols-outlined text-[24px]">error_outline</span>
                </div>
                <h4 class="text-slate-800 font-bold text-sm mb-1">Failed to load content</h4>
                <p class="text-slate-400 text-xs mb-4 leading-relaxed">${message}</p>
                ${retryFuncStr ? `
                <button onclick="${retryFuncStr}" class="px-4 py-1.5 bg-[#a435f0] hover:bg-[#8710d8] text-white text-xs font-bold rounded-xl transition-all flex items-center gap-1.5 shadow-sm">
                    <span class="material-symbols-outlined text-[14px]">refresh</span> Retry
                </button>
                ` : ''}
            </div>
        `;
    }

    // ── Toggle / close dropdown menus ─────────────────────────────────
    function toggleReviewMenu(event, btn) {
        event.stopPropagation();
        const menu = btn.nextElementSibling;
        const container = btn.parentElement;
        const isHidden = menu.classList.contains('hidden');
        closeAllMenus();
        if (isHidden) {
            menu.classList.remove('hidden');
            if (container) container.classList.add('menu-open');
        }
    }
    function closeAllMenus() {
        document.querySelectorAll('.review-menu').forEach(m => m.classList.add('hidden'));
        document.querySelectorAll('.review-menu-container').forEach(c => c.classList.remove('menu-open'));
    }

    document.addEventListener('click', function(e) {
        if (!e.target.closest('.review-menu')) {
            closeAllMenus();
        }
    });

    // ── Edit review ───────────────────────────────────────────────────
    function editReview(reviewId, type, currentRating, currentComment) {
        document.getElementById(`edit-form-${reviewId}`).classList.remove('hidden');
        document.getElementById(`review-text-${reviewId}`).classList.add('hidden');
        document.getElementById(`edit-rating-${reviewId}`).value = currentRating;
        setEditRating(reviewId, Math.round(currentRating));
    }
    function cancelEdit(reviewId) {
        document.getElementById(`edit-form-${reviewId}`).classList.add('hidden');
        document.getElementById(`review-text-${reviewId}`).classList.remove('hidden');
    }
    function setEditRating(reviewId, n) {
        document.getElementById(`edit-rating-${reviewId}`).value = n;
        const btns = document.querySelectorAll(`#edit-stars-${reviewId} .edit-star-btn`);
        btns.forEach((btn, i) => {
            const icon = btn.querySelector('.material-symbols-outlined');
            if (i < n) { btn.classList.add('text-amber-500'); btn.classList.remove('text-slate-300'); icon.classList.add('fill-1'); }
            else { btn.classList.remove('text-amber-500'); btn.classList.add('text-slate-300'); icon.classList.remove('fill-1'); }
        });
    }
    async function saveEditReview(reviewId, type) {
        const rating = parseFloat(document.getElementById(`edit-rating-${reviewId}`).value);
        const comment = document.getElementById(`edit-comment-${reviewId}`).value.trim();
        if (!rating || rating < 1) return Swal.fire('Error', 'Please select a rating.', 'warning');
        if (!comment) return Swal.fire('Error', 'Comment cannot be empty.', 'warning');
        try {
            const res = await fetch(`/Course/UpdateReview?reviewId=${reviewId}&type=${type}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ rating, comment, type })
            });
            const result = await res.json();
            if (result.success) {
                Swal.fire({ icon: 'success', title: 'Updated!', text: 'Your review has been updated.', timer: 1500, showConfirmButton: false });
                loadReviews(currentReviewPage);
                loadReviewStats();
            } else {
                Swal.fire('Error', result.message || 'Could not update review.', 'error');
            }
        } catch { Swal.fire('Error', 'Could not connect to server.', 'error'); }
    }

    // ── Delete review ────────────────────────────────────────────────
    async function deleteReview(reviewId, type) {
        const confirm = await Swal.fire({
            title: 'Delete this review?',
            text: 'This action cannot be undone.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            confirmButtonText: 'Yes, delete it',
            cancelButtonText: 'Cancel',
            customClass: { popup: 'rounded-3xl' }
        });
        if (!confirm.isConfirmed) return;
        try {
            const res = await fetch(`/Course/DeleteReview?reviewId=${reviewId}&type=${type}`, { method: 'DELETE' });
            const result = await res.json();
            if (result.success) {
                loadReviews(currentReviewPage);
                loadReviewStats();
                Swal.fire({ icon: 'success', title: 'Deleted', timer: 1200, showConfirmButton: false });
            } else if (res.status === 400 && result.message && result.message.includes('moderation')) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Under Moderation',
                    text: 'This review is currently under review by our moderation team and cannot be deleted at this time.',
                    confirmButtonText: 'OK',
                    customClass: { popup: 'rounded-3xl' }
                });
            } else {
                Swal.fire('Error', result.message || 'Could not delete review.', 'error');
            }
        } catch { Swal.fire('Error', 'Could not connect to server.', 'error'); }
    }

    window.addEventListener('DOMContentLoaded', () => {
        loadReviews();
        loadReviewStats();
        loadReviewEligibility();
    });

    async function reportCourse(courseId) {
        if (!currentToken) {
            Swal.fire({
                title: 'Login Required',
                text: 'You need to log in to report a course.',
                icon: 'info',
                confirmButtonText: 'Log In Now'
            }).then(() => { window.location.href = '/Account/Login'; });
            return;
        }

        let reportCount = 1;
        const getReportItemHtml = (index) => `
            <div class="report-item relative border border-slate-200 rounded-2xl p-4 mb-4 bg-slate-50" data-index="${index}">
                ${index > 1 ? `<button type="button" class="absolute top-2 right-2 text-slate-400 hover:text-red-500" onclick="this.closest('.report-item').remove()">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                </button>` : ''}
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Reason</label>
                    <select class="report-reason w-full rounded-xl border-slate-200 focus:ring-[#a435f0] text-sm font-semibold mb-4">
                        <option value="Misleading content">Misleading content / False claims</option>
                        <option value="Copyright violation">Copyright violation / Plagiarism</option>
                        <option value="Spam">Spam / Low quality content</option>
                        <option value="Adult content">Adult content / Inappropriate content</option>
                        <option value="Other">Other violation</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Description (Required, min 20 chars)</label>
                    <textarea class="report-desc w-full rounded-xl border-slate-200 focus:ring-[#a435f0] text-sm h-24" placeholder="Describe the issue in detail..."></textarea>
                </div>
            </div>
        `;

        const { value: formValues } = await Swal.fire({
            title: 'Report this course',
            html: `
                <div class="text-left px-1 max-h-[60vh] overflow-y-auto" id="report-items-container">
                    ${getReportItemHtml(1)}
                </div>
                <button type="button" id="add-report-btn" class="w-full py-2 border-2 border-dashed border-slate-300 rounded-xl text-slate-500 font-bold hover:border-primary hover:text-primary transition-colors flex items-center justify-center gap-2 mt-2">
                    <span class="material-symbols-outlined text-[18px]">add</span> Add another reason
                </button>
            `,
            focusConfirm: false,
            showCancelButton: true,
            confirmButtonText: 'Submit Report',
            confirmButtonColor: '#ef4444',
            cancelButtonText: 'Cancel',
            customClass: {
                popup: 'rounded-[32px] p-8',
                title: 'font-display font-extrabold text-slate-900 mb-6',
                confirmButton: 'rounded-xl font-bold px-8 py-3 text-xs',
                cancelButton: 'rounded-xl font-bold px-8 py-3 text-xs bg-slate-100 text-slate-700'
            },
            didOpen: () => {
                document.getElementById('add-report-btn').addEventListener('click', () => {
                    reportCount++;
                    document.getElementById('report-items-container').insertAdjacentHTML('beforeend', getReportItemHtml(reportCount));
                });
            },
            preConfirm: () => {
                const items = document.querySelectorAll('.report-item');
                const reports = [];
                const selectedReasons = new Set();
                for (let i = 0; i < items.length; i++) {
                    const reason = items[i].querySelector('.report-reason').value;
                    const desc = items[i].querySelector('.report-desc').value.trim();
                    if (desc.length < 20) {
                        Swal.showValidationMessage(`Please provide a description of at least 20 characters for Reason ${i + 1}.`);
                        return false;
                    }
                    if (selectedReasons.has(reason)) {
                        Swal.showValidationMessage(`You cannot select the same reason "${reason}" multiple times.`);
                        return false;
                    }
                    selectedReasons.add(reason);
                    reports.push({ reason, description: desc });
                }
                return reports;
            }
        });

        if (formValues && formValues.length > 0) {
            Swal.showLoading();
            try {
                let lastResult = null;
                for (let i = 0; i < formValues.length; i++) {
                    const response = await fetch('/Report/ReportCourse', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ courseId, reason: formValues[i].reason, description: formValues[i].description })
                    });
                    lastResult = await response.json();
                    if (!response.ok || !lastResult.success) {
                        throw new Error(lastResult.message || 'Failed to submit report');
                    }
                }
                Swal.fire({
                    icon: 'success',
                    title: 'Report Submitted',
                    text: 'Your report has been submitted and will be reviewed by our moderation team.',
                    confirmButtonColor: '#10b981',
                    customClass: { popup: 'rounded-3xl' }
                });
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Submission Failed',
                    text: error.message || 'Could not submit report at this time.',
                    confirmButtonColor: '#ef4444',
                    customClass: { popup: 'rounded-3xl' }
                });
            }
        }
    }

    async function reportReview(reviewId, type) {
        if (!currentToken) {
            Swal.fire({
                title: 'Login Required',
                text: 'You need to log in to report a review.',
                icon: 'info',
                confirmButtonText: 'Log In Now'
            }).then(() => { window.location.href = '/Account/Login'; });
            return;
        }

        const { value: formValues } = await Swal.fire({
            title: 'Report Review',
            html:
                '<div class="text-left space-y-4 px-1">' +
                '<div>' +
                '<label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Reason</label>' +
                '<select id="swal-review-reason" class="w-full rounded-xl border-slate-200 focus:ring-[#a435f0] text-sm font-semibold">' +
                '<option value="spam">Spam content</option>' +
                '<option value="offensive">Offensive / Harassment</option>' +
                '<option value="fake">Fake review</option>' +
                '<option value="other">Other reason</option>' +
                '</select>' +
                '</div>' +
                '<div>' +
                '<label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Description (optional)</label>' +
                '<textarea id="swal-review-desc" class="w-full rounded-xl border-slate-200 focus:ring-[#a435f0] text-sm h-24" placeholder="Briefly describe the violation..."></textarea>' +
                '</div>' +
                '</div>',
            focusConfirm: false,
            showCancelButton: true,
            confirmButtonText: 'Submit Report',
            confirmButtonColor: '#ef4444',
            cancelButtonText: 'Cancel',
            customClass: {
                popup: 'rounded-[32px] p-8',
                title: 'font-display font-extrabold text-slate-900 mb-6',
                confirmButton: 'rounded-xl font-bold px-8 py-3 text-xs',
                cancelButton: 'rounded-xl font-bold px-8 py-3 text-xs bg-slate-100 text-slate-700'
            },
            preConfirm: () => {
                return {
                    reason: document.getElementById('swal-review-reason').value,
                    description: document.getElementById('swal-review-desc').value
                }
            }
        });

        if (formValues) {
            Swal.showLoading();
            try {
                const endpoint = type === 'lesson' ? '/Report/ReportLessonReview' : '/Report/ReportCourseReview';
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reviewId, reason: formValues.reason, description: formValues.description })
                });
                const result = await response.json();
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Report Submitted',
                        text: result.message || 'Thank you for your feedback, a moderator will review this.',
                        confirmButtonColor: '#10b981',
                        customClass: { popup: 'rounded-3xl' }
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Submission Failed',
                        text: result.message || 'Could not submit report at this time.',
                        confirmButtonColor: '#ef4444',
                        customClass: { popup: 'rounded-3xl' }
                    });
                }
            } catch (err) {
                console.error(err);
                Swal.fire({ icon: 'error', title: 'Network Error', text: 'An unexpected connection error occurred.', confirmButtonColor: '#ef4444' });
            }
        }
    }

    async function startChatWithInstructor(instructorId) {
        const token = "@(Context.Request.Cookies["AccessToken"] ?? "")";
        if (!token) {
            Swal.fire({
                title: 'Please Log In',
                text: 'You need to log in to message the instructor.',
                icon: 'info',
                confirmButtonText: 'Log In',
                showCancelButton: true
            }).then((result) => {
                if (result.isConfirmed) window.location.href = '/Account/Login';
            });
            return;
        }

        try {
            // Hiển thị loading
            Swal.fire({
                title: 'Connecting...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            const response = await fetch('/Chat/CreateDirectChat', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    TargetAccountId: instructorId,
                    contextType: 'course',
                    contextId: @Model.CourseId
                })
            });

            const result = await response.json();
            if (response.ok) {
                Swal.close();
                const fallbackName = encodeURIComponent('@Html.Raw(Model.InstructorName.Replace("'", "\\'"))');
                const fallbackAvatar = encodeURIComponent('@Html.Raw(Model.InstructorAvatarUrl ?? "/img/default-avatar.png")');
                window.location.href = `/Chat/Index?chatId=${result.chatId}&fallbackName=${fallbackName}&fallbackAvatar=${fallbackAvatar}`;
            } else {
                Swal.fire('Error', result.message || 'Could not start conversation.', 'error');
            }
        } catch (e) {
            Swal.fire('Error', 'Chat server connection error.', 'error');
        }
    }
</script>
