@model List<CourseMarketplaceFE.Models.PublicCourseViewModel>
@{
    ViewData["Title"] = "Explore Courses";
    var currentQuery = ViewBag.Query as string;
    var currentCategory = ViewBag.Category as string;
    var currentSort = ViewBag.Sort as string;
    var currentPrice = ViewBag.Price as string;
    var currentRating = ViewBag.Rating as string;
    var sidebarCategories = ViewBag.Categories as List<CourseMarketplaceFE.Models.CategoryViewModel> ?? new List<CourseMarketplaceFE.Models.CategoryViewModel>();
}

<style>
    .ease-out-expo {
        transition-timing-function: cubic-bezier(0.19, 1, 0.22, 1);
    }
    
    /* Grid to List dynamic transition styling */
    .view-container-list {
        display: flex !important;
        flex-direction: column !important;
        gap: 1.25rem !important;
    }
    .view-container-list .course-card-custom {
        display: flex !important;
        flex-direction: row !important;
        width: 100% !important;
        height: auto !important;
    }
    .view-container-list .course-card-custom .img-wrapper {
        width: 16rem !important;
        aspect-ratio: 16/9 !important;
        flex-shrink: 0 !important;
    }
    .view-container-list .course-card-custom .desc-text {
        display: -webkit-box !important;
    }
    
    @@media (max-width: 640px) {
        .view-container-list .course-card-custom {
            flex-direction: column !important;
        }
        .view-container-list .course-card-custom .img-wrapper {
            width: 100% !important;
        }
    }
</style>

<div class="bg-surface min-h-screen py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Header Title Section (No banner as requested) -->
        <div class="mb-10 fade-in-up">
            <h1 class="font-headline text-3xl font-extrabold text-slate-800 tracking-tight mb-2">
                Explore Courses
            </h1>
            <p class="text-slate-500 text-sm md:text-base font-light">
                Search from thousands of high-quality courses to upgrade your skills and advance your career.
            </p>
        </div>

        <!-- Dynamic Wrapping Category Pills Section (Clean wrapping rows, not cut off) -->
        <div class="mb-8 fade-in-up" style="animation-delay: 0.05s;">
            <div class="flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-primary text-[20px]">category</span>
                <h3 class="font-headline font-bold text-base text-slate-800">
                    Course Categories
                </h3>
            </div>
            
            <div class="flex flex-wrap gap-2.5 pb-2">
                <!-- All Categories pill -->
                <button type="button" onclick="selectCategoryPill('')" data-category-pill=""
                        class="category-pill px-5 py-2.5 rounded-full text-xs md:text-sm font-semibold border transition-all duration-300 flex items-center gap-2 @(string.IsNullOrEmpty(currentCategory) ? "bg-primary border-primary text-white shadow-md shadow-primary/20 scale-105" : "bg-white border-slate-200 text-slate-600 hover:border-primary/30 hover:text-primary hover:bg-slate-50/50")">
                    <span class="material-symbols-outlined text-[18px]" style='font-variation-settings: "FILL" @(string.IsNullOrEmpty(currentCategory) ? "1" : "0")'>apps</span>
                    All Categories
                </button>

                @foreach (var cat in sidebarCategories)
                {
                    var isCatActive = currentCategory == cat.CategoriesName;
                    var catIcon = "school";
                    if (cat.CategoriesName.Contains("Lập trình") || cat.CategoriesName.Contains("Công nghệ")) catIcon = "code";
                    else if (cat.CategoriesName.Contains("Thiết kế") || cat.CategoriesName.Contains("Art")) catIcon = "palette";
                    else if (cat.CategoriesName.Contains("Kinh doanh") || cat.CategoriesName.Contains("Business")) catIcon = "trending_up";
                    else if (cat.CategoriesName.Contains("Ngoại ngữ") || cat.CategoriesName.Contains("Tiếng")) catIcon = "translate";
                    else if (cat.CategoriesName.Contains("Marketing")) catIcon = "campaign";
                    else if (cat.CategoriesName.Contains("Kỹ năng") || cat.CategoriesName.Contains("Soft")) catIcon = "psychology";

                    <button type="button" onclick="selectCategoryPill('@cat.CategoriesName')" data-category-pill="@cat.CategoriesName"
                            class="category-pill px-5 py-2.5 rounded-full text-xs md:text-sm font-semibold border transition-all duration-300 flex items-center gap-2 @(isCatActive ? "bg-primary border-primary text-white shadow-md shadow-primary/20 scale-105" : "bg-white border-slate-200 text-slate-600 hover:border-primary/30 hover:text-primary hover:bg-slate-50/50")">
                        <span class="material-symbols-outlined text-[18px]" style='font-variation-settings: "FILL" @(isCatActive ? "1" : "0")'>@catIcon</span>
                        @cat.CategoriesName
                    </button>
                }
            </div>
        </div>

        <div class="flex flex-col lg:flex-row gap-8 items-start fade-in-up" style="animation-delay: 0.1s;">
            
            <!-- Sidebar / Advanced Filters -->
            <div class="w-full lg:w-1/4 shrink-0">
                <form method="get" action="/Course" id="filter-form" class="bg-white p-6 rounded-3xl border border-slate-200/60 shadow-sm sticky top-24">
                    <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-100">
                        <h3 class="font-headline font-bold text-base text-slate-800 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-[20px]">filter_list</span>
                            Filter Results
                        </h3>
                    </div>
                    
                    <!-- Search Input -->
                    <div class="mb-5">
                        <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Search Keyword</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px] pointer-events-none">search</span>
                            <input type="text" name="query" value="@currentQuery" placeholder="Course title, skills..." 
                                   class="w-full pl-10 pr-9 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-300 outline-none" />
                            <button type="button" id="btn-clear-search" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors @(string.IsNullOrEmpty(currentQuery) ? "hidden" : "")">
                                <span class="material-symbols-outlined text-[18px]">close</span>
                            </button>
                        </div>
                    </div>

                    <!-- Hidden Category Input (in sync with pills) -->
                    <input type="hidden" name="category" value="@currentCategory" />

                    <!-- Sort Selector -->
                    <div class="mb-5">
                        <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Sort By</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px] pointer-events-none">sort</span>
                            <select name="sort" class="w-full pl-10 pr-10 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-800 appearance-none focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all duration-300 outline-none cursor-pointer">
                                <option value="newest" selected="@(currentSort == "newest")">Newest</option>
                                <option value="rating" selected="@(currentSort == "rating")">Highest Rated</option>
                                <option value="price_asc" selected="@(currentSort == "price_asc")">Price: Low to High</option>
                                <option value="price_desc" selected="@(currentSort == "price_desc")">Price: High to Low</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-[18px] pointer-events-none">expand_more</span>
                        </div>
                    </div>

                    <!-- Advanced Filter Accordion: Ratings -->
                    <div class="border-t border-slate-100 py-4 mb-1">
                        <button type="button" onclick="toggleAccordion('rating-accordion')" class="flex items-center justify-between w-full font-bold text-xs text-slate-700 uppercase tracking-wider">
                            <span>Rating</span>
                            <span id="rating-accordion-icon" class="material-symbols-outlined text-[18px]">expand_more</span>
                        </button>
                        <div id="rating-accordion" class="mt-3 space-y-2 transition-all duration-300">
                            <label class="flex items-center gap-2.5 text-xs text-slate-600 cursor-pointer hover:text-slate-800 transition-colors">
                                <input type="radio" name="rating" value="all" checked="@(string.IsNullOrEmpty(currentRating) || currentRating == "all")" class="w-4 h-4 rounded-full border-slate-300 text-primary focus:ring-primary/20 transition-all" />
                                <span>All Ratings</span>
                            </label>
                            <label class="flex items-center gap-2.5 text-xs text-slate-600 cursor-pointer hover:text-slate-800 transition-colors">
                                <input type="radio" name="rating" value="4.5" checked="@(currentRating == "4.5")" class="w-4 h-4 rounded-full border-slate-300 text-primary focus:ring-primary/20 transition-all" />
                                <span class="flex items-center gap-1">4.5 <span class="material-symbols-outlined text-[13px] text-amber-400" style='font-variation-settings: "FILL" 1;'>star</span> and up</span>
                            </label>
                            <label class="flex items-center gap-2.5 text-xs text-slate-600 cursor-pointer hover:text-slate-800 transition-colors">
                                <input type="radio" name="rating" value="4.0" checked="@(currentRating == "4.0")" class="w-4 h-4 rounded-full border-slate-300 text-primary focus:ring-primary/20 transition-all" />
                                <span class="flex items-center gap-1">4.0 <span class="material-symbols-outlined text-[13px] text-amber-400" style='font-variation-settings: "FILL" 1;'>star</span> and up</span>
                            </label>
                            <label class="flex items-center gap-2.5 text-xs text-slate-600 cursor-pointer hover:text-slate-800 transition-colors">
                                <input type="radio" name="rating" value="3.5" checked="@(currentRating == "3.5")" class="w-4 h-4 rounded-full border-slate-300 text-primary focus:ring-primary/20 transition-all" />
                                <span class="flex items-center gap-1">3.5 <span class="material-symbols-outlined text-[13px] text-amber-400" style='font-variation-settings: "FILL" 1;'>star</span> and up</span>
                            </label>
                        </div>
                    </div>

                    <!-- Advanced Filter Accordion: Price -->
                    <div class="border-t border-slate-100 py-4 mb-6">
                        <button type="button" onclick="toggleAccordion('price-accordion')" class="flex items-center justify-between w-full font-bold text-xs text-slate-700 uppercase tracking-wider">
                            <span>Price</span>
                            <span id="price-accordion-icon" class="material-symbols-outlined text-[18px]">expand_more</span>
                        </button>
                        <div id="price-accordion" class="mt-3 space-y-2 transition-all duration-300">
                            <label class="flex items-center gap-2.5 text-xs text-slate-600 cursor-pointer hover:text-slate-800 transition-colors">
                                <input type="radio" name="price" value="all" checked="@(string.IsNullOrEmpty(currentPrice) || currentPrice == "all")" class="w-4 h-4 rounded-full border-slate-300 text-primary focus:ring-primary/20 transition-all" />
                                <span>All Prices</span>
                            </label>
                            <label class="flex items-center gap-2.5 text-xs text-slate-600 cursor-pointer hover:text-slate-800 transition-colors">
                                <input type="radio" name="price" value="free" checked="@(currentPrice == "free")" class="w-4 h-4 rounded-full border-slate-300 text-primary focus:ring-primary/20 transition-all" />
                                <span>Free</span>
                            </label>
                            <label class="flex items-center gap-2.5 text-xs text-slate-600 cursor-pointer hover:text-slate-800 transition-colors">
                                <input type="radio" name="price" value="paid" checked="@(currentPrice == "paid")" class="w-4 h-4 rounded-full border-slate-300 text-primary focus:ring-primary/20 transition-all" />
                                <span>Paid</span>
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="w-full bg-primary text-white font-bold py-3 rounded-xl hover:bg-primary/95 transition-all duration-300 shadow-md shadow-primary/15 hover:scale-[1.02] active:scale-[0.98]">
                        Apply Filters
                    </button>
                    <button type="button" id="btn-clear-filters" class="w-full bg-slate-50 hover:bg-slate-100/80 text-slate-500 font-bold py-3 rounded-xl transition-all duration-300 flex items-center justify-center gap-1.5 text-sm hover:text-slate-600 mt-3">
                        <span class="material-symbols-outlined text-[18px]">filter_alt_off</span>
                        Clear Filters
                    </button>
                </form>
            </div>

            <!-- Course Catalog Panel -->
            <div class="flex-grow w-full lg:w-3/4" id="courses-container" style="transition: opacity 0.25s ease-in-out;">
                
                @if (Model == null || !Model.Any())
                {
                    <!-- Premium Empty State (Suggested recommendations removed as requested) -->
                    <div class="bg-white rounded-3xl border border-slate-200/60 p-12 md:p-16 text-center shadow-sm max-w-xl mx-auto my-4 fade-in-up">
                        <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner">
                            <span class="material-symbols-outlined text-4xl text-primary font-light">search_off</span>
                        </div>
                        <h3 class="font-headline font-bold text-xl md:text-2xl text-slate-800 mb-3">No courses found</h3>
                        <p class="text-slate-500 text-sm md:text-base mb-8 max-w-sm mx-auto leading-relaxed">
                            We couldn't find any courses matching your criteria. Try using different keywords or clear the filters to start fresh.
                        </p>
                        
                        <button type="button" onclick="clearAllFilters()" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-xl hover:bg-primary/95 transition-all duration-300 shadow-md shadow-primary/15 hover:scale-105 active:scale-95 text-sm">
                            <span class="material-symbols-outlined text-[18px]">filter_alt_off</span>
                            Clear All Filters
                        </button>
                    </div>
                }
                else
                {
                    <!-- Active Filter Badges Container -->
                    <div id="active-filters-badges" class="mb-5 flex flex-wrap items-center gap-2 @(string.IsNullOrEmpty(currentQuery) && string.IsNullOrEmpty(currentCategory) && currentSort == "newest" && string.IsNullOrEmpty(currentPrice) && string.IsNullOrEmpty(currentRating) ? "hidden" : "")">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mr-1">Active Filters:</span>
                        
                        @if (!string.IsNullOrEmpty(currentQuery))
                        {
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-100 text-[11px] font-semibold text-slate-600 rounded-lg">
                                Keyword: "@currentQuery"
                                <button type="button" onclick="removeFilter('query')" class="text-slate-400 hover:text-slate-600 flex"><span class="material-symbols-outlined text-[12px]">close</span></button>
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(currentCategory))
                        {
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-100 text-[11px] font-semibold text-slate-600 rounded-lg">
                                Category: @currentCategory
                                <button type="button" onclick="removeFilter('category')" class="text-slate-400 hover:text-slate-600 flex"><span class="material-symbols-outlined text-[12px]">close</span></button>
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(currentPrice) && currentPrice != "all")
                        {
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-100 text-[11px] font-semibold text-slate-600 rounded-lg">
                                Price: @(currentPrice == "free" ? "Free" : "Paid")
                                <button type="button" onclick="removeFilter('price')" class="text-slate-400 hover:text-slate-600 flex"><span class="material-symbols-outlined text-[12px]">close</span></button>
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(currentRating) && currentRating != "all")
                        {
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-100 text-[11px] font-semibold text-slate-600 rounded-lg">
                                Rating: >= @currentRating ★
                                <button type="button" onclick="removeFilter('rating')" class="text-slate-400 hover:text-slate-600 flex"><span class="material-symbols-outlined text-[12px]">close</span></button>
                            </span>
                        }
                    </div>

                    <!-- View Switcher Toolbar -->
                    <div class="bg-white px-5 py-4 rounded-2xl border border-slate-200/60 mb-6 flex items-center justify-between shadow-sm">
                        <p class="text-slate-500 text-xs md:text-sm font-medium">
                            Found <span class="font-bold text-slate-800 text-sm md:text-base">@ViewBag.TotalItems</span> matching courses
                        </p>
                        
                        <!-- Toggle switcher icons -->
                        <div class="flex items-center gap-1 bg-slate-100/80 p-1 rounded-xl">
                            <button type="button" onclick="setViewMode('grid')" id="btn-view-grid" 
                                    class="p-2 rounded-lg transition-all duration-300 flex text-slate-500 hover:text-slate-700 bg-white shadow-sm" title="Grid view">
                                <span class="material-symbols-outlined text-[20px]">grid_view</span>
                            </button>
                            <button type="button" onclick="setViewMode('list')" id="btn-view-list" 
                                    class="p-2 rounded-lg transition-all duration-300 flex text-slate-500 hover:text-slate-700" title="List view">
                                <span class="material-symbols-outlined text-[20px]">view_list</span>
                            </button>
                        </div>
                    </div>

                    <!-- Catalog Courses List Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 transition-all duration-300 ease-out-expo" id="catalog-list-wrapper">
                        @foreach (var course in Model)
                        {
                            <div class="course-card-custom flex flex-col h-full bg-white rounded-3xl border border-slate-200/60 overflow-hidden hover:shadow-xl hover:shadow-slate-100/80 hover:-translate-y-1 transition-all duration-300 ease-out-expo group cursor-pointer" 
                                 onclick="location.href='/Course/Details/@course.CourseId'">
                                
                                <!-- Card Thumbnail aspect ratio -->
                                <div class="img-wrapper relative w-full aspect-[16/9] overflow-hidden bg-slate-50 shrink-0">
                                    <img src="@(string.IsNullOrEmpty(course.CourseThumbnailUrl) ? "https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=800&auto=format&fit=crop" : course.CourseThumbnailUrl)" 
                                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out-expo" 
                                         alt="@course.Title" loading="lazy" />
                                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/10 via-transparent to-transparent"></div>
                                    
                                    <!-- Dynamic price tag in corner of grid card -->
                                    <span class="absolute bottom-3 left-3 z-30 px-3 py-1 bg-white/90 backdrop-blur-md text-xs font-bold text-slate-800 rounded-lg shadow-sm border border-slate-200/20">
                                        @if (course.Price == 0)
                                        {
                                            <span class="text-emerald-600 uppercase">Free</span>
                                        }
                                        else
                                        {
                                            <span>$@course.Price.ToString("N2")</span>
                                        }
                                    </span>
                                    
                                    <!-- Wishlist Heart Icon Toggle -->
                                    <button type="button" 
                                            class="absolute top-3 right-3 z-30 w-9 h-9 rounded-full bg-white/95 backdrop-blur-md @(course.IsInWishlist ? "text-red-500 shadow-md shadow-red-500/10 scale-105" : "text-slate-400 hover:text-red-500") flex items-center justify-center hover:scale-110 shadow-sm transition-all duration-300"
                                            onclick="event.stopPropagation(); toggleWishlist(this, @course.CourseId);">
                                        <span class="material-symbols-outlined text-[20px]" style='font-variation-settings: "FILL" @(course.IsInWishlist ? "1" : "0");'>favorite</span>
                                    </button>
                                </div>

                                <!-- Card Content -->
                                <div class="p-5 md:p-6 flex flex-col flex-grow">
                                    <span class="inline-block px-2.5 py-1 bg-slate-50 border border-slate-100 text-[10px] font-bold text-slate-500 uppercase rounded-md mb-2.5 max-w-fit leading-none">
                                        @course.CategoryName
                                    </span>
                                    
                                    <h3 class="text-base font-bold text-slate-800 line-clamp-2 leading-snug mb-2 group-hover:text-primary transition-colors duration-200">
                                        @course.Title
                                    </h3>
                                    
                                    <!-- Short Description shown on horizontal List layout -->
                                    <p class="desc-text hidden text-xs text-slate-500 line-clamp-2 font-light leading-relaxed mb-3 mt-1">
                                        @course.Description
                                    </p>
                                    
                                    <div class="flex items-center gap-2 text-xs text-slate-400 font-medium mb-3 mt-auto">
                                        <span class="material-symbols-outlined text-[15px]">person</span>
                                        <span class="truncate">@course.InstructorName</span>
                                    </div>

                                    <!-- Stars Rating -->
                                    <div class="flex items-center gap-1.5 mb-4">
                                        <span class="text-xs font-bold text-slate-700">@course.RatingAverage.ToString("F1")</span>
                                        <div class="flex text-amber-400">
                                            @for(int i=0; i<Math.Floor((double)course.RatingAverage); i++) { 
                                                <span class="material-symbols-outlined text-[15px]" style='font-variation-settings:"FILL" 1;'>star</span> 
                                            }
                                            @if((double)course.RatingAverage - Math.Floor((double)course.RatingAverage) >= 0.5) { 
                                                <span class="material-symbols-outlined text-[15px]" style='font-variation-settings:"FILL" 1;'>star_half</span> 
                                            }
                                        </div>
                                        <span class="text-[10px] text-slate-400">(@course.TotalStudents)</span>
                                    </div>

                                    <!-- Footer row -->
                                    <div class="pt-4 border-t border-slate-100 flex items-center justify-between">
                                        <div class="text-base font-extrabold text-slate-800 tracking-tight">
                                            @if (course.Price == 0)
                                            {
                                                <span class="text-emerald-600 uppercase text-xs font-bold">Free</span>
                                            }
                                            else
                                            {
                                                <span>$@course.Price.ToString("N2")</span>
                                            }
                                        </div>
                                        
                                        @if (course.IsEnrolled)
                                        {
                                            <div class="w-9 h-9 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100" title="You already own this course">
                                                <span class="material-symbols-outlined text-[18px]">check_circle</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <form asp-action="AddToCart" asp-controller="Cart" method="post" class="m-0 z-20">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="courseId" value="@course.CourseId" />
                                                <input type="hidden" name="returnUrl" value="/Course" />
                                                <button type="submit" 
                                                        class="w-9 h-9 rounded-full bg-slate-50 text-slate-500 flex items-center justify-center hover:bg-primary hover:text-white hover:scale-110 active:scale-95 border border-slate-200/60 hover:border-primary shadow-sm transition-all ease-out-expo duration-200"
                                                        onclick="event.stopPropagation();"
                                                        title="Add to cart">
                                                    <span class="material-symbols-outlined text-[17px]" style='font-variation-settings:"FILL" 1;'>add_shopping_cart</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Dynamic Pagination -->
                    @if (ViewBag.TotalPages > 1)
                    {
                        <div class="mt-12 flex justify-center items-center gap-1.5" id="pagination-controls">
                            @{
                                int totalPages = ViewBag.TotalPages;
                                int currentPage = ViewBag.CurrentPage;
                            }
                            
                            <a href="@Url.Action("Index", "Course", new { query = currentQuery, category = currentCategory, sort = currentSort, price = currentPrice, rating = currentRating, page = currentPage - 1 })" 
                               class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 hover:border-primary hover:text-primary transition-all duration-300 @(currentPage <= 1 ? "pointer-events-none opacity-50" : "")" data-page-link="@(currentPage - 1)">
                                <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                            </a>

                            @for (int i = 1; i <= totalPages; i++)
                            {
                                if (i == 1 || i == totalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                                {
                                    <a href="@Url.Action("Index", "Course", new { query = currentQuery, category = currentCategory, sort = currentSort, price = currentPrice, rating = currentRating, page = i })" 
                                       class="w-10 h-10 flex items-center justify-center rounded-xl font-semibold border @(i == currentPage ? "bg-primary border-primary text-white shadow-md shadow-primary/10" : "bg-white border-slate-200 text-slate-500 hover:border-primary hover:text-primary") transition-all duration-300 text-sm" data-page-link="@i">
                                        @i
                                    </a>
                                }
                                else if (i == 2 || i == totalPages - 1)
                                {
                                    <span class="w-8 text-center text-slate-300">...</span>
                                }
                            }

                            <a href="@Url.Action("Index", "Course", new { query = currentQuery, category = currentCategory, sort = currentSort, price = currentPrice, rating = currentRating, page = currentPage + 1 })" 
                               class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-500 hover:border-primary hover:text-primary transition-all duration-300 @(currentPage >= totalPages ? "pointer-events-none opacity-50" : "")" data-page-link="@(currentPage + 1)">
                                <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                            </a>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Elements references
        const filterForm = document.getElementById('filter-form');
        const queryInput = document.querySelector('input[name="query"]');
        const categoryInput = document.querySelector('input[name="category"]');
        const sortSelect = document.querySelector('select[name="sort"]');
        const coursesContainer = document.getElementById('courses-container');
        const btnClearSearch = document.getElementById('btn-clear-search');

        if (!queryInput || !categoryInput || !sortSelect || !coursesContainer) return;

        // Toggle clear search icon visible status
        if (queryInput) {
            queryInput.addEventListener('input', () => {
                if (queryInput.value.trim().length > 0) {
                    btnClearSearch?.classList.remove('hidden');
                } else {
                    btnClearSearch?.classList.add('hidden');
                }
            });
        }

        if (btnClearSearch) {
            btnClearSearch.addEventListener('click', () => {
                queryInput.value = '';
                btnClearSearch.classList.add('hidden');
                updateFilters(1);
            });
        }

        // Restore filters from localStorage if URL has no parameters (persists on re-loading)
        const urlParams = new URLSearchParams(window.location.search);
        const hasUrlParams = urlParams.has('query') || urlParams.has('category') || urlParams.has('sort') || urlParams.has('price') || urlParams.has('rating') || urlParams.has('page');

        if (!hasUrlParams) {
            const savedQuery = localStorage.getItem('course_query');
            const savedCategory = localStorage.getItem('course_category');
            const savedSort = localStorage.getItem('course_sort');
            const savedPrice = localStorage.getItem('course_price');
            const savedRating = localStorage.getItem('course_rating');

            let shouldUpdate = false;
            if (savedQuery !== null) {
                queryInput.value = savedQuery;
                shouldUpdate = true;
            }
            if (savedCategory !== null) {
                categoryInput.value = savedCategory;
                shouldUpdate = true;
            }
            if (savedSort !== null) {
                sortSelect.value = savedSort;
                shouldUpdate = true;
            }
            if (savedPrice !== null && savedPrice !== 'all') {
                const radio = document.querySelector(`input[name="price"][value="${savedPrice}"]`);
                if (radio) { radio.checked = true; shouldUpdate = true; }
            }
            if (savedRating !== null && savedRating !== 'all') {
                const radio = document.querySelector(`input[name="rating"][value="${savedRating}"]`);
                if (radio) { radio.checked = true; shouldUpdate = true; }
            }

            if (shouldUpdate) {
                updateFilters(1);
            }
        } else {
            // Save initial URL params to localStorage
            const priceVal = urlParams.get('price') || 'all';
            const ratingVal = urlParams.get('rating') || 'all';
            
            localStorage.setItem('course_query', queryInput.value.trim());
            localStorage.setItem('course_category', categoryInput.value);
            localStorage.setItem('course_sort', sortSelect.value);
            localStorage.setItem('course_price', priceVal);
            localStorage.setItem('course_rating', ratingVal);
        }

        // Intercept standard form submit
        if (filterForm) {
            filterForm.addEventListener('submit', (e) => {
                e.preventDefault();
                updateFilters(1);
            });
        }

        // Debounce helper
        let debounceTimer;
        function debounce(func, delay) {
            return function(...args) {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(() => func.apply(this, args), delay);
            };
        }

        // Real-time AJAX Database Query filters updater
        async function updateFilters(page = 1) {
            const query = queryInput.value.trim();
            const category = categoryInput.value;
            const sort = sortSelect.value;
            
            // Extract selected radio button values
            const priceRadio = document.querySelector('input[name="price"]:checked');
            const ratingRadio = document.querySelector('input[name="rating"]:checked');
            const price = priceRadio ? priceRadio.value : 'all';
            const rating = ratingRadio ? ratingRadio.value : 'all';

            // Save active filters to localStorage
            localStorage.setItem('course_query', query);
            localStorage.setItem('course_category', category);
            localStorage.setItem('course_sort', sort);
            localStorage.setItem('course_price', price);
            localStorage.setItem('course_rating', rating);

            // Dim down container during load
            coursesContainer.style.opacity = '0.45';
            coursesContainer.style.pointerEvents = 'none';

            const params = new URLSearchParams();
            if (query) params.append('query', query);
            if (category) params.append('category', category);
            if (sort) params.append('sort', sort);
            if (price && price !== 'all') params.append('price', price);
            if (rating && rating !== 'all') params.append('rating', rating);
            if (page > 1) params.append('page', page);

            const newUrl = `/Course?${params.toString()}`;
            
            try {
                const response = await fetch(newUrl);
                if (response.ok) {
                    const html = await response.text();
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newContainer = doc.getElementById('courses-container');
                    
                    if (newContainer) {
                        coursesContainer.innerHTML = newContainer.innerHTML;
                        // Smoothly restore opacity
                        coursesContainer.style.opacity = '1';
                        // Update browser URL history bar without page reload
                        window.history.pushState({ path: newUrl }, '', newUrl);
                        
                        // Re-initialize correct active UI state
                        const currentMode = localStorage.getItem('course_view_mode') || 'grid';
                        setViewMode(currentMode);
                        
                        // Sync clear-search status
                        if (queryInput.value.trim().length > 0) {
                            document.getElementById('btn-clear-search')?.classList.remove('hidden');
                        }
                    }
                }
            } catch (err) {
                console.error("Error loading course list:", err);
                coursesContainer.style.opacity = '1';
            } finally {
                coursesContainer.style.pointerEvents = 'auto';
            }
        }

        // Attach event listeners for real-time changes
        queryInput.addEventListener('input', debounce(() => updateFilters(1), 350));
        sortSelect.addEventListener('change', () => updateFilters(1));

        // Advanced filter radio changes
        document.querySelectorAll('input[name="price"]').forEach(el => {
            el.addEventListener('change', () => updateFilters(1));
        });
        document.querySelectorAll('input[name="rating"]').forEach(el => {
            el.addEventListener('change', () => updateFilters(1));
        });

        // Intercept click on the "Clear filters" button in sidebar
        const clearBtn = document.getElementById('btn-clear-filters');
        if (clearBtn) {
            clearBtn.addEventListener('click', (e) => {
                e.preventDefault();
                clearAllFilters();
            });
        }

        // Intercept clicks on pagination links using event delegation
        coursesContainer.addEventListener('click', (e) => {
            const pageLink = e.target.closest('[data-page-link]');
            if (pageLink) {
                e.preventDefault();
                const page = pageLink.getAttribute('data-page-link');
                updateFilters(page);
                
                // Smooth scroll to top of courses container
                window.scrollTo({
                    top: document.getElementById('courses-container').offsetTop - 120,
                    behavior: 'smooth'
                });
            }
        });

        // Hoisted local function declarations to prevent initialization ordering ReferenceErrors
        function selectCategoryPill(categoryName) {
            categoryInput.value = categoryName;
            
            // Update active pill UI class list
            document.querySelectorAll('.category-pill').forEach(pill => {
                const pillVal = pill.getAttribute('data-category-pill') || '';
                const icon = pill.querySelector('.material-symbols-outlined');
                
                if (pillVal === categoryName) {
                    pill.className = "category-pill px-5 py-2.5 rounded-full text-xs md:text-sm font-semibold border transition-all duration-300 flex items-center gap-2 bg-primary border-primary text-white shadow-md shadow-primary/20 scale-105";
                    if (icon) icon.style.fontVariationSettings = '"FILL" 1';
                } else {
                    pill.className = "category-pill px-5 py-2.5 rounded-full text-xs md:text-sm font-semibold border transition-all duration-300 flex items-center gap-2 bg-white border-slate-200 text-slate-600 hover:border-primary/30 hover:text-primary hover:bg-slate-50/50";
                    if (icon) icon.style.fontVariationSettings = '"FILL" 0';
                }
            });

            // Also keep standard sidebar fallback select option in sync
            const sideSelect = document.querySelector('select[name="category"]');
            if (sideSelect) {
                sideSelect.value = categoryName;
            }

            updateFilters(1);
        }

        function clearAllFilters() {
            queryInput.value = '';
            categoryInput.value = '';
            sortSelect.value = 'newest';
            
            const firstPrice = document.querySelector('input[name="price"][value="all"]');
            if (firstPrice) firstPrice.checked = true;
            
            const firstRating = document.querySelector('input[name="rating"][value="all"]');
            if (firstRating) firstRating.checked = true;

            // Reset Category pills
            document.querySelectorAll('.category-pill').forEach(pill => {
                const pillVal = pill.getAttribute('data-category-pill') || '';
                const icon = pill.querySelector('.material-symbols-outlined');
                if (pillVal === '') {
                    pill.className = "category-pill px-5 py-2.5 rounded-full text-xs md:text-sm font-semibold border transition-all duration-300 flex items-center gap-2 bg-primary border-primary text-white shadow-md shadow-primary/20 scale-105";
                    if (icon) icon.style.fontVariationSettings = '"FILL" 1';
                } else {
                    pill.className = "category-pill px-5 py-2.5 rounded-full text-xs md:text-sm font-semibold border transition-all duration-300 flex items-center gap-2 bg-white border-slate-200 text-slate-600 hover:border-primary/30 hover:text-primary hover:bg-slate-50/50";
                    if (icon) icon.style.fontVariationSettings = '"FILL" 0';
                }
            });

            // Clear localStorage
            localStorage.removeItem('course_query');
            localStorage.removeItem('course_category');
            localStorage.removeItem('course_sort');
            localStorage.removeItem('course_price');
            localStorage.removeItem('course_rating');

            btnClearSearch?.classList.add('hidden');

            updateFilters(1);
        }

        function removeFilter(filterType) {
            if (filterType === 'query') {
                queryInput.value = '';
                btnClearSearch?.classList.add('hidden');
            } else if (filterType === 'category') {
                categoryInput.value = '';
                document.querySelectorAll('.category-pill').forEach(pill => {
                    const pillVal = pill.getAttribute('data-category-pill') || '';
                    const icon = pill.querySelector('.material-symbols-outlined');
                    if (pillVal === '') {
                        pill.className = "category-pill px-5 py-2.5 rounded-full text-xs md:text-sm font-semibold border transition-all duration-300 flex items-center gap-2 bg-primary border-primary text-white shadow-md shadow-primary/20 scale-105";
                        if (icon) icon.style.fontVariationSettings = '"FILL" 1';
                    } else {
                        pill.className = "category-pill px-5 py-2.5 rounded-full text-xs md:text-sm font-semibold border transition-all duration-300 flex items-center gap-2 bg-white border-slate-200 text-slate-600 hover:border-primary/30 hover:text-primary hover:bg-slate-50/50";
                        if (icon) icon.style.fontVariationSettings = '"FILL" 0';
                    }
                });
            } else if (filterType === 'price') {
                const radio = document.querySelector('input[name="price"][value="all"]');
                if (radio) radio.checked = true;
            } else if (filterType === 'rating') {
                const radio = document.querySelector('input[name="rating"][value="all"]');
                if (radio) radio.checked = true;
            }
            updateFilters(1);
        }

        function toggleAccordion(id) {
            const el = document.getElementById(id);
            const icon = document.getElementById(id + '-icon');
            if (el && icon) {
                if (el.classList.contains('hidden')) {
                    el.classList.remove('hidden');
                    icon.textContent = 'expand_more';
                } else {
                    el.classList.add('hidden');
                    icon.textContent = 'chevron_right';
                }
            }
        }

        function setViewMode(mode) {
            const listWrapper = document.getElementById('catalog-list-wrapper');
            const btnGrid = document.getElementById('btn-view-grid');
            const btnList = document.getElementById('btn-view-list');
            
            if (!listWrapper || !btnGrid || !btnList) return;

            localStorage.setItem('course_view_mode', mode);

            if (mode === 'list') {
                listWrapper.className = "view-container-list transition-all duration-300 ease-out-expo";
                btnList.classList.add('bg-white', 'shadow-sm');
                btnGrid.classList.remove('bg-white', 'shadow-sm');
                
                // Show desc-text block on all cards
                document.querySelectorAll('.course-card-custom .desc-text').forEach(el => {
                    el.classList.remove('hidden');
                });
            } else {
                listWrapper.className = "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 transition-all duration-300 ease-out-expo";
                btnGrid.classList.add('bg-white', 'shadow-sm');
                btnList.classList.remove('bg-white', 'shadow-sm');
                
                // Hide desc-text block on all cards
                document.querySelectorAll('.course-card-custom .desc-text').forEach(el => {
                    el.classList.add('hidden');
                });
            }
        }

        // Set dynamic view mode (Grid / List) from localStorage
        const savedViewMode = localStorage.getItem('course_view_mode') || 'grid';
        setViewMode(savedViewMode);

        // Make window level helpers available to inline clicks
        window.selectCategoryPill = selectCategoryPill;
        window.clearAllFilters = clearAllFilters;
        window.removeFilter = removeFilter;
        window.toggleAccordion = toggleAccordion;
        window.setViewMode = setViewMode;
    });

    // Wishlist Toggle handler (global scope, can be called from inline onclick)
    async function toggleWishlist(button, courseId) {
        const icon = button.querySelector('.material-symbols-outlined');
        const isActive = icon.style.fontVariationSettings.includes('"FILL" 1') || button.classList.contains('text-red-500');

        try {
            const url = isActive ? '/Wishlist/Remove' : '/Wishlist/Add';
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `courseId=${courseId}`
            });

            if (response.ok) {
                if (isActive) {
                    button.className = "absolute top-3 right-3 z-30 w-9 h-9 rounded-full bg-white/95 backdrop-blur-md text-slate-400 hover:text-red-500 flex items-center justify-center hover:scale-110 shadow-sm transition-all duration-300";
                    icon.style.fontVariationSettings = '"FILL" 0';
                    Swal.fire({
                        title: 'Removed from Wishlist',
                        text: 'Course has been removed from your wishlist.',
                        icon: 'info',
                        timer: 2000,
                        showConfirmButton: false,
                        position: 'top-end',
                        toast: true
                    });
                } else {
                    button.className = "absolute top-3 right-3 z-30 w-9 h-9 rounded-full bg-white/95 backdrop-blur-md text-red-500 shadow-md shadow-red-500/10 flex items-center justify-center hover:scale-110 shadow-sm transition-all duration-300";
                    icon.style.fontVariationSettings = '"FILL" 1';
                    Swal.fire({
                        title: 'Added to Wishlist',
                        text: 'Course has been added to your wishlist.',
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false,
                        position: 'top-end',
                        toast: true
                    });
                }
            }
        } catch (error) {
            console.error("Error toggling wishlist status:", error);
        }
    }
</script>
