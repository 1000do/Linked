@model CourseMarketplaceFE.Models.PagedResult<CourseMarketplaceFE.Models.CourseModerationViewModel>
@using CourseMarketplaceFE.Models
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Course Moderation Queue";
    ViewData["PageHeader"] = "Course Moderation Queue";
}

<div class="space-y-6">
    <!-- Stats Overview -->
    <div id="stats-container" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center">
                <span class="material-symbols-outlined text-emerald-600">pending_actions</span>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Pending Review</p>
                <h3 class="text-2xl font-display font-extrabold text-slate-900">@(ViewBag.PendingCount ?? 0)</h3>
            </div>
        </div>
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-12 h-12 bg-blue-50 rounded-2xl flex items-center justify-center">
                <span class="material-symbols-outlined text-blue-600">task_alt</span>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Resolved Today</p>
                <h3 class="text-2xl font-display font-extrabold text-slate-900">@(ViewBag.ResolvedTodayCount ?? 0)</h3>
            </div>
        </div>
        <div class="bg-accent p-6 rounded-3xl shadow-lg shadow-emerald-900/20 flex items-center gap-4">
            <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center">
                <span class="material-symbols-outlined text-white">verified</span>
            </div>
            <div>
                <p class="text-xs font-bold text-white/60 uppercase tracking-widest">Platform</p>
                <h3 class="text-lg font-display font-bold text-white">Moderation Active</h3>
            </div>
        </div>
    </div>
    
    <!-- Filter Bar -->
    <div class="bg-white p-6 rounded-[32px] border border-slate-100 shadow-sm mb-6">
        <form id="filter-form" method="get" action="/AdminModeration/Courses" class="flex flex-wrap items-end gap-4" onsubmit="event.preventDefault();">
            <div class="flex-1 min-w-[300px]">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block ml-1">Search</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                    <input type="text" name="search" id="search-input" value="@ViewBag.Search" placeholder="Search course title or instructor name..." 
                           class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-sm outline-none" />
                </div>
            </div>
            
            <div class="w-48 relative">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block ml-1">Category</label>
                <select name="category" id="category-select" class="w-full pl-4 pr-10 py-3 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-sm appearance-none cursor-pointer outline-none">
                    <option value="0">All Categories</option>
                    @if (ViewBag.Categories != null)
                    {
                        var cats = System.Text.Json.JsonSerializer.Deserialize<List<CourseMarketplaceFE.Models.CategoryViewModel>>(ViewBag.Categories as string, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                        foreach (var cat in cats)
                        {
                            <option value="@cat.CategoryId" selected="@(ViewBag.Category == cat.CategoryId.ToString())">@cat.CategoriesName</option>
                        }
                    }
                </select>
                <span class="material-symbols-outlined absolute right-3 bottom-3 text-slate-400 pointer-events-none">arrow_drop_down</span>
            </div>

            <div class="w-40 relative">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block ml-1">Status</label>
                <select name="status" id="status-select" class="w-full pl-4 pr-10 py-3 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-sm appearance-none cursor-pointer outline-none">
                    <option value="all" selected="@(ViewBag.Status == "all" || string.IsNullOrEmpty(ViewBag.Status))">All</option>
                    <option value="pending" selected="@(ViewBag.Status == "pending")">Pending</option>
                    <option value="published" selected="@(ViewBag.Status == "published")">Approved</option>
                    <option value="rejected" selected="@(ViewBag.Status == "rejected")">Rejected</option>
                    <option value="archived" selected="@(ViewBag.Status == "archived")">Archived</option>
                    <option value="permanently_locked" selected="@(ViewBag.Status == "permanently_locked")">Permanently Locked</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 bottom-3 text-slate-400 pointer-events-none">arrow_drop_down</span>
            </div>

            <div class="w-48 relative">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block ml-1">Sort By</label>
                <select name="sortBy" id="sort-select" class="w-full pl-4 pr-10 py-3 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-sm appearance-none cursor-pointer outline-none">
                    <option value="threat_desc" selected="@(ViewBag.SortBy == "threat_desc")">Threat Level (High to Low)</option>
                    <option value="threat_asc" selected="@(ViewBag.SortBy == "threat_asc")">Threat Level (Low to High)</option>
                    <option value="oldest" selected="@(ViewBag.SortBy == "oldest")">Oldest (Priority)</option>
                    <option value="newest" selected="@(ViewBag.SortBy == "newest")">Newest</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 bottom-3 text-slate-400 pointer-events-none">arrow_drop_down</span>
            </div>

            <button type="button" id="btn-clear-filters" class="h-[46px] px-4 flex items-center justify-center bg-slate-100 text-slate-400 rounded-2xl hover:bg-slate-200 transition-all cursor-pointer">
                <span class="material-symbols-outlined">refresh</span>
            </button>
        </form>
    </div>

    <!-- Table Container -->
    <div id="moderation-table-container" class="bg-white rounded-[32px] border border-slate-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-8 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Course Info</th>
                        <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Instructor</th>
                        <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Category</th>
                        <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Price</th>
                        <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Priority Level</th>
                        <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Status</th>
                        <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Submission Date</th>
                        <th class="px-6 py-5 text-center text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Preview</th>
                        <th class="px-8 py-5 text-center text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="9" class="px-8 py-20 text-center">
                                <div class="flex flex-col items-center">
                                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                                        <span class="material-symbols-outlined text-slate-300 text-4xl">inventory_2</span>
                                    </div>
                                    <h4 class="text-slate-900 font-display font-bold">No Courses Pending Review</h4>
                                    <p class="text-slate-400 text-sm">Excellent! The moderation queue is completely empty.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        var isPending = item.CourseStatus?.Equals("pending", StringComparison.OrdinalIgnoreCase) ?? false;
                        
                        string threatRowClass = "";
                        string threatBadgeClass = "";
                        string threatIcon = "";
                        string threatLabel = "";

                        switch (item.ThreatLevel)
                        {
                            case AiThreatLevel.FlaggedOrRejected:
                                threatRowClass = "bg-red-50/30 border-l-4 border-l-red-500 hover:bg-red-50/50 opacity-100";
                                threatBadgeClass = "bg-red-100 text-red-700 border-red-200 animate-pulse";
                                threatIcon = "warning";
                                threatLabel = "CRITICAL THREAT";
                                break;
                            case AiThreatLevel.ManualAudit:
                                threatRowClass = "bg-amber-50/30 border-l-4 border-l-amber-500 hover:bg-amber-50/50 opacity-100";
                                threatBadgeClass = "bg-amber-100 text-amber-700 border-amber-200";
                                threatIcon = "error";
                                threatLabel = "HIGH THREAT";
                                break;
                            case AiThreatLevel.Approved:
                                threatRowClass = "bg-emerald-50/30 border-l-4 border-l-emerald-500 hover:bg-emerald-50/50 opacity-100";
                                threatBadgeClass = "bg-emerald-100 text-emerald-700 border-emerald-200";
                                threatIcon = "check_circle";
                                threatLabel = "CLEAN";
                                break;
                            default:
                                threatRowClass = isPending ? "opacity-100" : "opacity-40 hover:opacity-100 grayscale-[0.5] hover:grayscale-0";
                                threatBadgeClass = "bg-slate-100 text-slate-600 border-slate-200";
                                threatIcon = "pending";
                                threatLabel = "PENDING / NONE";
                                break;
                        }
                        
                        <tr data-course-id="@item.CourseId" class="group transition-all duration-300 @threatRowClass">
                            <td class="px-8 py-6">
                                <div class="flex items-center gap-4">
                                    <div class="w-14 h-10 rounded-lg overflow-hidden shrink-0 border border-slate-100 shadow-sm">
                                        <img src="@(string.IsNullOrEmpty(item.CourseThumbnailUrl) ? "/img/default-course.png" : item.CourseThumbnailUrl)" 
                                             onerror="this.onerror=null; this.src='/img/default-course.png';"
                                             class="w-full h-full object-cover" alt="Thumbnail" />
                                    </div>
                                    <div>
                                        <a href="/Course/Details/@item.CourseId" target="_blank" class="font-display font-extrabold text-slate-900 leading-tight hover:text-primary transition-colors block">
                                            @item.Title
                                        </a>
                                        <div class="flex items-center gap-2 mt-1">
                                            <p class="text-[11px] text-slate-400 font-medium">ID: #@item.CourseId</p>
                                            @if (item.FlagCount > 0)
                                            {
                                                <div class="flex gap-0.5">
                                                    @for (int i = 1; i <= 3; i++)
                                                    {
                                                        if (i <= item.FlagCount)
                                                        {
                                                            var flagColor = i == 1 ? "bg-amber-400" : i == 2 ? "bg-orange-500" : "bg-red-600";
                                                            var flagTitle = i == 1 ? "Strike 1: Friendly Reminder" : i == 2 ? "Strike 2: Severe Warning" : "Strike 3: Critical Infraction";
                                                            <div class="w-3 h-1 rounded-full @flagColor" title="@flagTitle"></div>
                                                        }
                                                        else
                                                        {
                                                            <div class="w-3 h-1 rounded-full bg-slate-200" title="No infraction recorded"></div>
                                                        }
                                                    }
                                                </div>
                                                <span class="text-[9px] font-black text-red-600 uppercase tracking-tighter">Violation Strike @item.FlagCount</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-6">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center text-[10px] font-bold text-slate-500">
                                        @item.InstructorName[..1].ToUpper()
                                    </div>
                                    <span class="text-sm font-semibold text-slate-700">@item.InstructorName</span>
                                </div>
                            </td>
                            <td class="px-6 py-6">
                                <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-[11px] font-bold uppercase tracking-wider">
                                    @item.CategoryName
                                </span>
                            </td>
                            <td class="px-6 py-6 font-display font-black text-primary">
                                @item.Price.ToString("C2", new System.Globalization.CultureInfo("en-US"))
                            </td>
                            <td class="px-6 py-6">
                                <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border @threatBadgeClass shadow-sm">
                                    <span class="material-symbols-outlined text-[14px]">@threatIcon</span>
                                    <span class="text-[10px] font-black uppercase tracking-wider">@threatLabel</span>
                                </div>
                            </td>
                            <td class="px-6 py-6">
                                @{
                                    var statusLabel = item.CourseStatus?.ToLower() switch {
                                        "published" => "Approved",
                                        "rejected" => "Rejected",
                                        "archived" => "Archived",
                                        "pending" => "Pending",
                                        "permanently_locked" => "Permanently Locked",
                                        _ => item.CourseStatus
                                    };
                                    var statusColor = item.CourseStatus?.ToLower() switch {
                                        "published" => "bg-emerald-500 text-white",
                                        "rejected" => "bg-red-500 text-white",
                                        "archived" => "bg-slate-500 text-white",
                                        "pending" => "bg-amber-500 text-white",
                                        "permanently_locked" => "bg-red-800 text-white shadow-lg shadow-red-900/20",
                                        _ => "bg-slate-100 text-slate-600"
                                    };
                                }
                                <span class="inline-block whitespace-nowrap px-3 py-1 @statusColor rounded-full text-[10px] font-black uppercase tracking-wider shadow-sm">
                                    @statusLabel
                                </span>
                            </td>
                            <td class="px-6 py-6">
                                <p class="text-sm text-slate-500 font-medium">@item.CreatedAt?.ToString("dd/MM/yyyy")</p>
                                <p class="text-[10px] text-slate-400 font-bold uppercase">@item.CreatedAt?.ToString("HH:mm")</p>
                            </td>
                            <td class="px-6 py-6 text-center">
                                <a href="/Course/Details/@item.CourseId" target="_blank" class="inline-flex w-9 h-9 items-center justify-center bg-slate-100 text-slate-400 rounded-xl hover:bg-primary hover:text-white transition-all active:scale-95" title="Preview course details">
                                    <span class="material-symbols-outlined text-[20px]">visibility</span>
                                </a>
                            </td>
                            <td class="px-8 py-6 text-center">
                                <div class="flex items-stretch gap-2">
                                    @{
                                        var statusStr = item.CourseStatus?.ToLower() ?? "";
                                    }

                                    <!-- Column 1: Approve / Reject -->
                                    <div class="flex flex-col justify-center gap-2 w-[125px]">
                                        @if (statusStr == "pending")
                                        {
                                            <button onclick="approveCourse(@item.CourseId)" class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl text-xs font-bold transition-all shadow-lg shadow-emerald-500/20 active:scale-95">
                                                <span class="material-symbols-outlined text-[18px]">done</span> Approve
                                            </button>
                                        }
                                        else if (statusStr == "rejected" || statusStr == "archived" || statusStr == "permanently_locked")
                                        {
                                            <button onclick="approveCourse(@item.CourseId)" class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-xs font-bold transition-all shadow-lg shadow-emerald-600/20 active:scale-95">
                                                <span class="material-symbols-outlined text-[18px]">settings_backup_restore</span> Re-approve
                                            </button>
                                        }

                                        @if (statusStr == "pending" || statusStr == "published")
                                        {
                                            <button onclick="rejectCourse(@item.CourseId)" class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-white hover:bg-red-50 text-red-600 border border-red-100 rounded-xl text-xs font-bold transition-all active:scale-95">
                                                <span class="material-symbols-outlined text-[18px]">close</span> Reject
                                            </button>
                                        }
                                    </div>

                                    <!-- Column 2: Flag / Unflag -->
                                    <div class="flex flex-col justify-center gap-2 w-[95px]">
                                        @if ((statusStr == "pending" || statusStr == "published" || statusStr == "rejected" || statusStr == "archived") && item.FlagCount < 3)
                                        {
                                            <button onclick="flagCourse(@item.CourseId)" class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-accent text-white rounded-xl hover:bg-red-600 transition-all shadow-lg shadow-red-900/20 active:scale-95 text-xs font-bold" title="Flag for violation">
                                                <span class="material-symbols-outlined text-[18px]">flag</span> Flag
                                            </button>
                                        }

                                        @if ((statusStr == "pending" || statusStr == "published" || statusStr == "rejected" || statusStr == "archived" || statusStr == "permanently_locked") && item.FlagCount > 0)
                                        {
                                            <button onclick="unflagCourse(@item.CourseId)" class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-slate-100 text-slate-700 hover:bg-slate-200 rounded-xl text-xs font-bold transition-all shadow-sm active:scale-95" title="Unflag course">
                                                <span class="material-symbols-outlined text-[18px]">undo</span> Unflag
                                            </button>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination UI -->
        @if (Model.TotalPages > 1)
        {
            <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between bg-slate-50/30">
                <p class="text-xs font-semibold text-slate-500">
                    Showing <span class="font-bold text-slate-800">@((Model.Page - 1) * Model.PageSize + 1)</span> ?" <span class="font-bold text-slate-800">@Math.Min(Model.Page * Model.PageSize, Model.TotalCount)</span> of <span class="font-bold text-slate-800">@Model.TotalCount</span>
                </p>
                <div class="flex items-center gap-1.5">
                    @if (Model.Page > 1)
                    {
                        <a href="@Url.Action("Courses", new { page = Model.Page - 1, pageSize = Model.PageSize, search = ViewBag.Search, category = ViewBag.Category, status = ViewBag.Status, sortBy = ViewBag.SortBy })"
                           class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200/80 text-slate-500 hover:bg-white hover:text-slate-800 transition-all shadow-sm/5">
                            <span class="material-symbols-outlined text-[16px]">chevron_left</span>
                        </a>
                    }

                    @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                    {
                        if (p == Model.Page)
                        {
                            <span class="w-8 h-8 flex items-center justify-center rounded-lg bg-emerald-600 text-white font-extrabold text-xs shadow-md shadow-emerald-600/10">@p</span>
                        }
                        else
                        {
                            <a href="@Url.Action("Courses", new { page = p, pageSize = Model.PageSize, search = ViewBag.Search, category = ViewBag.Category, status = ViewBag.Status, sortBy = ViewBag.SortBy })"
                               class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200/80 text-slate-500 hover:bg-white hover:text-slate-800 transition-all shadow-sm/5 font-semibold text-xs">@p</a>
                        }
                    }

                    @if (Model.Page < Model.TotalPages)
                    {
                        <a href="@Url.Action("Courses", new { page = Model.Page + 1, pageSize = Model.PageSize, search = ViewBag.Search, category = ViewBag.Category, status = ViewBag.Status, sortBy = ViewBag.SortBy })"
                           class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200/80 text-slate-500 hover:bg-white hover:text-slate-800 transition-all shadow-sm/5 font-bold">
                            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Reject Modal -->
<div id="reject-modal" class="fixed inset-0 bg-black/60 z-50 hidden flex items-center justify-center p-6 backdrop-blur-sm">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-3xl max-h-[85vh] flex flex-col overflow-hidden">
        <!-- Header -->
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <div>
                <h3 class="text-xl font-display font-extrabold text-slate-900">Reject Course</h3>
                <p class="text-sm text-slate-500 mt-1">Tag violating elements and provide constructive rejection reasons</p>
            </div>
            <button onclick="closeRejectModal()" class="w-9 h-9 flex items-center justify-center bg-slate-100 rounded-xl text-slate-400 hover:bg-slate-200 hover:text-slate-600 transition-all">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>

        <!-- Body -->
        <div class="flex-1 overflow-y-auto p-6 custom-scrollbar">
            <div id="reject-loading" class="flex items-center justify-center py-12 text-slate-400">
                <span class="material-symbols-outlined animate-spin mr-2">sync</span> Loading course metadata...
            </div>
            <div id="reject-items-container" class="hidden space-y-3">
                <!-- Dynamic rows will be inserted here -->
            </div>
            <button id="add-reject-item-btn" onclick="addRejectRow()" class="hidden mt-4 w-full py-3 border-2 border-dashed border-slate-200 rounded-xl text-slate-500 hover:text-primary hover:border-primary hover:bg-primary/5 transition-colors flex items-center justify-center gap-2 text-sm font-bold">
                <span class="material-symbols-outlined text-[18px]">add_circle</span> Add Rejection Item
            </button>
        </div>

        <!-- Footer -->
        <div class="p-6 border-t border-slate-100 flex justify-end gap-3">
            <button onclick="closeRejectModal()" class="px-6 py-2.5 bg-slate-100 text-slate-600 font-bold rounded-xl hover:bg-slate-200 transition-colors">Cancel</button>
            <button onclick="submitDetailedReject()" id="submit-reject-btn" class="px-6 py-2.5 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-all shadow-lg shadow-red-500/20 flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">close</span> Submit Rejection
            </button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let rejectCourseId = null;
    let rejectCourseData = null;
    let rejectRowCounter = 0;
    let debounceTimer;

    // AJAX fetching for courses
    function triggerAjaxFetch() {
        const searchVal = document.getElementById("search-input").value.trim();
        const categoryVal = document.getElementById("category-select").value;
        const statusVal = document.getElementById("status-select").value;
        const sortByVal = document.getElementById("sort-select").value;

        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            fetchCourses(searchVal, categoryVal, statusVal, sortByVal);
        }, 300);
    }

    async function fetchCourses(search, category, status, sortBy) {
        const container = document.getElementById("moderation-table-container");
        if (container) {
            container.style.opacity = "0.5";
            container.style.transition = "opacity 0.15s ease-in-out";
        }

        const url = `/AdminModeration/Courses?search=${encodeURIComponent(search)}&category=${category}&status=${status}&sortBy=${sortBy}`;
        try {
            const resp = await fetch(url);
            const htmlText = await resp.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(htmlText, "text/html");

            const newContent = doc.getElementById("moderation-table-container");
            if (newContent && container) {
                container.innerHTML = newContent.innerHTML;
            }

            const newStats = doc.getElementById("stats-container");
            const currentStats = document.getElementById("stats-container");
            if (newStats && currentStats) {
                currentStats.innerHTML = newStats.innerHTML;
            }
        } catch (err) {
            console.error("AJAX Error:", err);
        } finally {
            if (container) {
                container.style.opacity = "1";
            }
        }
    }

    // Dim row smoothly instead of deleting it
    function dimCourseRowInDOM(courseId) {
        const row = document.querySelector(`tr[data-course-id="${courseId}"]`);
        if (row) {
            row.style.transition = "all 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
            row.style.opacity = "0.4";
            row.classList.add("opacity-40", "grayscale-[0.5]");
            row.classList.remove("opacity-100");
        }
        
        // Refresh AJAX to sync list filters and stats badge
        triggerAjaxFetch();
    }

    async function approveCourse(id) {
        const { value: feedback } = await Swal.fire({
            title: 'Approve Course',
            text: 'Would you like to send a positive or encouraging message to the instructor?',
            input: 'textarea',
            inputPlaceholder: 'e.g., Your course curriculum looks phenomenal! We are excited to launch it.',
            showCancelButton: true,
            confirmButtonText: 'Approve & Publish',
            confirmButtonColor: '#10b981',
            cancelButtonText: 'Cancel',
            background: '#ffffff',
            customClass: {
                title: 'font-display font-extrabold text-slate-900',
                confirmButton: 'rounded-xl font-bold px-6 py-3',
                cancelButton: 'rounded-xl font-bold px-6 py-3',
                input: 'rounded-2xl border-slate-200 focus:ring-primary focus:border-primary'
            }
        });

        if (feedback === undefined) return;

        Swal.showLoading();
        const response = await fetch(`/AdminModeration/ApproveCourse/${id}`, { 
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `feedback=${encodeURIComponent(feedback)}`
        });
        
        const result = await response.json();
        if (result.success) {
            Swal.fire({
                icon: 'success',
                title: 'Course Approved!',
                text: 'The course is now active and live on the marketplace.',
                confirmButtonColor: '#10b981',
                customClass: { popup: 'rounded-3xl' }
            }).then(() => dimCourseRowInDOM(id));
        } else {
            Swal.fire('Error', 'An error occurred while approving this course.', 'error');
        }
    }

    async function rejectCourse(id) {
        rejectCourseId = id;
        rejectRowCounter = 0;
        const modal = document.getElementById('reject-modal');
        const loading = document.getElementById('reject-loading');
        const container = document.getElementById('reject-items-container');
        const addBtn = document.getElementById('add-reject-item-btn');
        
        modal.classList.remove('hidden');
        loading.classList.remove('hidden');
        container.classList.add('hidden');
        addBtn.classList.add('hidden');
        container.innerHTML = '';

        try {
            const res = await fetch(`/AdminModeration/GetCourseDetails?id=${id}`);
            const json = await res.json();
            rejectCourseData = json.data || json;
            
            loading.classList.add('hidden');
            container.classList.remove('hidden');
            addBtn.classList.remove('hidden');
            
            // Add first row by default
            addRejectRow();
        } catch(e) {
            loading.innerHTML = '<span class="text-red-500">Failed to load course details.</span>';
        }
    }

    function buildTargetOptions() {
        if (!rejectCourseData) return '';
        let opts = `<optgroup label="Course Level">
            <option value="course.title">@@course.title</option>
            <option value="course.description">@@course.description</option>
            <option value="course.thumbnail">@@course.thumbnail</option>
            <option value="course.what_you_will_learn">@@course.what_you_will_learn</option>
            <option value="course.requirements">@@course.requirements</option>
        </optgroup>`;

        const lessons = rejectCourseData.lessons || [];
        if (lessons.length > 0) {
            opts += `<optgroup label="Lesson">`;
            lessons.forEach(l => {
                const lId = l.lessonId || l.LessonId;
                const lTitle = l.title || l.Title;
                opts += `<option value="lesson.title" data-lesson-id="${lId}" data-lesson-title="${lTitle}">@@lesson: ${lTitle}</option>`;
            });
            opts += `</optgroup>`;

            opts += `<optgroup label="File / Material">`;
            lessons.forEach(l => {
                const lId = l.lessonId || l.LessonId;
                const lTitle = l.title || l.Title;
                const materials = l.learningMaterials || l.LearningMaterials || [];
                materials.forEach(m => {
                    const mId = m.materialId || m.MaterialId;
                    const mTitle = m.title || m.Title;
                    opts += `<option value="file" data-lesson-id="${lId}" data-material-id="${mId}" data-material-title="${mTitle}" data-lesson-title="${lTitle}">@@file: ${mTitle} (Lesson: ${lTitle})</option>`;
                });
            });
            opts += `</optgroup>`;
        }
        return opts;
    }

    function addRejectRow() {
        rejectRowCounter++;
        const container = document.getElementById('reject-items-container');
        const row = document.createElement('div');
        row.className = 'reject-row flex gap-3 items-start bg-slate-50 p-4 rounded-xl border border-slate-200';
        row.dataset.rowId = rejectRowCounter;
        row.innerHTML = `
            <div class="flex-1 space-y-3">
                <div class="relative custom-dropdown" data-row-id="${rejectRowCounter}">
                    <label class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 flex items-center gap-2">
                        Violating Element
                        <span class="normal-case tracking-normal text-[10px] text-slate-400 font-medium bg-slate-200/50 px-2 py-0.5 rounded-full flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">info</span> Type @@ to search quickly</span>
                    </label>
                    <select class="reject-target hidden">
                        <option value="">— Select element —</option>
                        ${buildTargetOptions()}
                    </select>
                    <div class="relative">
                        <input type="text" class="dropdown-search w-full px-3 py-2.5 bg-white border border-slate-200 rounded-xl text-sm font-semibold text-slate-700 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all shadow-sm" 
                            placeholder="Type @@ to search elements (e.g., @@course, @@lesson...)" 
                            onfocus="openDropdown(${rejectRowCounter})" 
                            onkeyup="filterDropdown(${rejectRowCounter}, this.value)"
                            autocomplete="off">
                        <span class="material-symbols-outlined absolute right-3 top-2.5 text-slate-400 pointer-events-none">search</span>
                    </div>
                    <div class="dropdown-menu absolute z-50 w-full mt-1 bg-white border border-slate-100 rounded-xl shadow-xl hidden flex-col overflow-hidden max-h-60 overflow-y-auto">
                        <div class="dropdown-list py-1"></div>
                    </div>
                </div>
                <div>
                    <label class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-1.5 block">Rejection Reason</label>
                    <textarea class="reject-reason w-full px-3 py-2.5 bg-white border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary shadow-sm" rows="2" placeholder="Describe why this specific element is being rejected..."></textarea>
                </div>
            </div>
            <button onclick="this.closest('.reject-row').remove()" class="mt-7 w-9 h-9 flex items-center justify-center text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all shrink-0">
                <span class="material-symbols-outlined text-[20px]">delete</span>
            </button>
        `;
        container.appendChild(row);
        initCustomDropdown(rejectRowCounter);
    }

    function closeRejectModal() {
        document.getElementById('reject-modal').classList.add('hidden');
        rejectCourseId = null;
        rejectCourseData = null;
    }

    async function submitDetailedReject() {
        const rows = document.querySelectorAll('.reject-row');
        const items = [];
        let valid = true;

        rows.forEach(row => {
            const select = row.querySelector('.reject-target');
            const reason = row.querySelector('.reject-reason').value.trim();
            const target = select.value;

            if (!target || !reason) {
                valid = false;
                return;
            }

            const selectedOption = select.options[select.selectedIndex];
            const item = {
                target,
                reason,
                lessonId: selectedOption.dataset.lessonId ? parseInt(selectedOption.dataset.lessonId) : null,
                materialId: selectedOption.dataset.materialId ? parseInt(selectedOption.dataset.materialId) : null,
                lessonTitle: selectedOption.dataset.lessonTitle || null,
                materialTitle: selectedOption.dataset.materialTitle || null
            };
            items.push(item);
        });

        if (!valid || items.length === 0) {
            Swal.fire('Information Missing', 'Please select a specific element and type a reason for each rejection row.', 'warning');
            return;
        }

        const btn = document.getElementById('submit-reject-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span> Processing...';

        try {
            const res = await fetch('/AdminModeration/RejectCourseDetailed', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ courseId: rejectCourseId, items })
            });
            const result = await res.json();

            if (result.success) {
                closeRejectModal();
                Swal.fire({
                    icon: 'info',
                    title: 'Rejection Submitted',
                    text: 'The course has been rejected and the instructor was notified with your detailed logs.',
                    confirmButtonColor: '#10b981'
                }).then(() => dimCourseRowInDOM(rejectCourseId));
            } else {
                Swal.fire('Error', 'An error occurred during submission.', 'error');
            }
        } catch(e) {
            Swal.fire('Error', 'Cannot connect to server.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">close</span> Submit Rejection';
        }
    }

    async function flagCourse(id) {
        const { value: reason } = await Swal.fire({
            title: 'Flag Violation',
            html: '<p class="text-sm text-slate-500 mb-4">This action will unpublish/lock the course and issue a formal violation strike to the instructor.</p>',
            input: 'textarea',
            inputPlaceholder: 'Describe the violation in detail (e.g., Copyright infringement, Harmful/Spam content...)',
            inputValidator: (value) => {
                if (!value) return 'You must enter a violation reason!';
            },
            showCancelButton: true,
            confirmButtonText: 'Confirm Flag',
            confirmButtonColor: '#064e3b',
            cancelButtonText: 'Cancel',
            customClass: {
                title: 'font-display font-extrabold text-red-600',
                input: 'rounded-2xl border-slate-200 focus:ring-primary focus:border-primary'
            }
        });

        if (!reason) return;

        Swal.showLoading();
        const response = await fetch(`/AdminModeration/FlagCourse`, { 
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${id}&reason=${encodeURIComponent(reason)}`
        });
        
        const result = await response.json();
        if (result.success) {
            Swal.fire({
                icon: 'success',
                title: 'Course Flagged',
                text: 'The course has been hidden from the marketplace and restricted.',
                confirmButtonColor: '#10b981'
            }).then(() => dimCourseRowInDOM(id));
        } else {
            Swal.fire('Error', 'An error occurred while flagging this course.', 'error');
        }
    }

    async function unflagCourse(id) {
        const confirmVal = await Swal.fire({
            title: 'Unflag Course?',
            text: "Are you sure you want to remove 1 strike from this course? This action will restore its visibility if the strike count drops below the locking threshold.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Yes, unflag',
            cancelButtonText: 'Cancel',
            confirmButtonColor: '#10b981'
        });

        if (!confirmVal.isConfirmed) return;

        Swal.showLoading();
        const response = await fetch(`/AdminModeration/UnflagCourse`, { 
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${id}`
        });
        
        const result = await response.json();
        if (result.success) {
            Swal.fire('Success', 'The course has been unflagged.', 'success')
                .then(() => location.reload());
        } else {
            Swal.fire('Error', 'An error occurred while unflagging this course.', 'error');
        }
    }

    // Custom Searchable Dropdown Logic
    function initCustomDropdown(rowId) {
        const row = document.querySelector(`.reject-row[data-row-id="${rowId}"]`);
        const select = row.querySelector('.reject-target');
        const listContainer = row.querySelector('.dropdown-list');
        
        let html = '';
        let globalIndex = 1;
        Array.from(select.children).forEach(child => {
            if (child.tagName === 'OPTGROUP') {
                html += `<div class="px-3 py-2 text-[10px] font-black text-slate-400 uppercase tracking-[0.1em] bg-slate-50 sticky top-0 border-b border-slate-100 z-10">${child.label}</div>`;
                Array.from(child.children).forEach(opt => {
                    const textSafe = opt.innerText.replace(/'/g, "\\'");
                    let icon = 'data_object';
                    if (opt.value.startsWith('course')) icon = 'library_books';
                    if (opt.value.startsWith('lesson')) icon = 'play_lesson';
                    if (opt.value.startsWith('file')) icon = 'draft';
                    
                    html += `<div class="dropdown-item px-3 py-2.5 text-sm text-slate-700 hover:bg-emerald-50 hover:text-emerald-700 cursor-pointer transition-colors flex items-center gap-3 border-b border-slate-50 last:border-0" 
                                onclick="selectOption(${rowId}, ${globalIndex}, '${textSafe}')">
                                <span class="material-symbols-outlined text-[18px] ${opt.value.startsWith('file') ? 'text-amber-500' : 'text-primary'}">${icon}</span>
                                <span class="font-medium">${opt.innerText}</span>
                             </div>`;
                    globalIndex++;
                });
            }
        });
        listContainer.innerHTML = html;
    }

    window.openDropdown = function(rowId) {
        document.querySelectorAll('.dropdown-menu').forEach(menu => menu.classList.add('hidden'));
        const row = document.querySelector(`.reject-row[data-row-id="${rowId}"]`);
        row.querySelector('.dropdown-menu').classList.remove('hidden');
    };

    window.filterDropdown = function(rowId, text) {
        const row = document.querySelector(`.reject-row[data-row-id="${rowId}"]`);
        const items = row.querySelectorAll('.dropdown-item');
        const query = text.toLowerCase().replace(/@@/g, '');
        
        items.forEach(item => {
            const val = item.innerText.toLowerCase();
            if (val.includes(query)) {
                item.style.display = 'flex';
            } else {
                item.style.display = 'none';
            }
        });
    };

    window.selectOption = function(rowId, index, text) {
        const row = document.querySelector(`.reject-row[data-row-id="${rowId}"]`);
        const select = row.querySelector('.reject-target');
        select.selectedIndex = index;
        
        const input = row.querySelector('.dropdown-search');
        input.value = text;
        row.querySelector('.dropdown-menu').classList.add('hidden');
        
        input.classList.remove('border-slate-200');
        input.classList.add('border-emerald-500', 'bg-emerald-50/30', 'text-emerald-700');
    };
    
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.custom-dropdown')) {
            document.querySelectorAll('.dropdown-menu').forEach(menu => menu.classList.add('hidden'));
        }
    });

    // Wire up filter controls
    document.addEventListener("DOMContentLoaded", () => {
        const searchInput = document.getElementById("search-input");
        const categorySelect = document.getElementById("category-select");
        const statusSelect = document.getElementById("status-select");
        const sortSelect = document.getElementById("sort-select");
        const clearBtn = document.getElementById("btn-clear-filters");

        searchInput.addEventListener("input", triggerAjaxFetch);
        categorySelect.addEventListener("change", triggerAjaxFetch);
        statusSelect.addEventListener("change", triggerAjaxFetch);
        sortSelect.addEventListener("change", triggerAjaxFetch);

        clearBtn.addEventListener("click", () => {
            searchInput.value = "";
            categorySelect.value = "0";
            statusSelect.value = "all";
            sortSelect.value = "oldest";
            triggerAjaxFetch();
        });
    });
</script>
}
