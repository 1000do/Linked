@model CourseMarketplaceFE.Models.ReportModerationPageViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Report Center";
    ViewData["PageHeader"] = "Report Center";
    var userRole = (Context.Request.Cookies["UserRole"] ?? "admin").ToLower();
}

<div class="space-y-6">
    <!-- Top Stats Overview (Small Cards) -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-4">
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-12 h-12 bg-red-50 rounded-2xl flex items-center justify-center">
                <span class="material-symbols-outlined text-red-600">flag</span>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Pending Course</p>
                <h3 id="stat-pending-courses" class="text-2xl font-display font-extrabold text-slate-900">@Model.Stats.TotalPendingCourseReports</h3>
            </div>
        </div>
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-12 h-12 bg-amber-50 rounded-2xl flex items-center justify-center">
                <span class="material-symbols-outlined text-amber-600">comment</span>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Pending Reviews</p>
                <h3 id="stat-pending-reviews" class="text-2xl font-display font-extrabold text-slate-900">@(Model.Stats.TotalPendingCourseReviewReports + Model.Stats.TotalPendingLessonReviewReports)</h3>
            </div>
        </div>
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center">
                <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Resolved Today</p>
                <h3 id="stat-resolved-today" class="text-2xl font-display font-extrabold text-slate-900">@Model.Stats.TotalResolvedToday</h3>
            </div>
        </div>
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center gap-4">
            <div class="w-12 h-12 bg-slate-100 rounded-2xl flex items-center justify-center">
                <span class="material-symbols-outlined text-slate-500">cancel</span>
            </div>
            <div>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Rejected Today</p>
                <h3 id="stat-rejected-today" class="text-2xl font-display font-extrabold text-slate-900">@Model.Stats.TotalRejectedToday</h3>
            </div>
        </div>
    </div>

    <!-- Main Navigation Tabs -->
    <div class="flex border-b border-slate-200 gap-4 mb-6">
        <button onclick="switchTab('course-reports')" id="tab-btn-course-reports" class="tab-btn px-6 py-3 font-display font-extrabold text-sm border-b-2 transition-all flex items-center gap-2 border-primary text-primary" data-tab="course-reports">
            <span class="material-symbols-outlined text-[18px]">menu_book</span>
            Course Reports
        </button>
        <button onclick="switchTab('review-reports')" id="tab-btn-review-reports" class="tab-btn px-6 py-3 font-display font-extrabold text-sm border-b-2 transition-all flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700" data-tab="review-reports">
            <span class="material-symbols-outlined text-[18px]">forum</span>
            Review Reports
        </button>

        <button onclick="switchTab('stats')" id="tab-btn-stats" class="tab-btn px-6 py-3 font-display font-extrabold text-sm border-b-2 transition-all flex items-center gap-2 border-transparent text-slate-500 hover:text-slate-700" data-tab="stats">
            <span class="material-symbols-outlined text-[18px]">analytics</span>
            Detailed Stats
        </button>
    </div>

    <!-- Panel 1: Course Reports -->
    <div id="panel-course-reports" class="tab-panel space-y-4">
        <!-- Filters & Tools -->
        <div class="flex justify-between items-center bg-white px-6 py-4 rounded-2xl border border-slate-100 shadow-sm">
            <h4 class="font-display font-bold text-slate-950">Manage Course Reports</h4>
            <div class="flex items-center gap-2">
                <label class="text-xs font-bold text-slate-400 uppercase">Filter Status:</label>
                <select id="course-status-filter" onchange="loadCourseReports(1, this.value)" class="rounded-xl border-slate-200 focus:ring-primary focus:border-primary text-xs font-semibold py-1.5 pr-8 pl-3">
                    <option value="all" selected>All Statuses</option>
                    <option value="pending">Pending</option>
                    <option value="resolved">Resolved</option>
                    <option value="rejected">Rejected</option>
                    <option value="escalated">Escalated</option>
                    <option value="under_review">Under Review</option>
                </select>
            </div>
        </div>

        <div class="bg-white rounded-[32px] border border-slate-100 shadow-sm overflow-hidden">
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-100">
                            <th class="px-8 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Reporter</th>
                            <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Reported Course</th>
                            <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Reason & Description</th>
                            <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Submitted At</th>
                            <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Status</th>
                            <th class="px-8 py-5 text-right text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="course-reports-tbody" class="divide-y divide-slate-50">
                        <partial name="_CourseReportsPartial" model="Model.CourseReports" />
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Panel 2: Review Reports -->
    <div id="panel-review-reports" class="tab-panel hidden space-y-4">
        <!-- Filters & Subtabs -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-white px-6 py-4 rounded-2xl border border-slate-100 shadow-sm">
            <!-- Sub tabs -->
            <div class="flex gap-2 bg-slate-100 p-1 rounded-xl">
                <button onclick="switchReviewSubTab('course')" id="subtab-btn-course" class="sub-tab-btn px-4 py-1.5 rounded-lg text-xs font-bold transition-all bg-white text-slate-800 shadow-sm" data-subtab="course">
                    Course Reviews
                </button>
                <button onclick="switchReviewSubTab('lesson')" id="subtab-btn-lesson" class="sub-tab-btn px-4 py-1.5 rounded-lg text-xs font-bold transition-all text-slate-500 hover:text-slate-700" data-subtab="lesson">
                    Lesson Reviews
                </button>
            </div>
            
            <div class="flex items-center gap-2">
                <label class="text-xs font-bold text-slate-400 uppercase">Filter Status:</label>
                <select id="review-status-filter" onchange="loadReviewReports(1, this.value)" class="rounded-xl border-slate-200 focus:ring-primary focus:border-primary text-xs font-semibold py-1.5 pr-8 pl-3">
                    <option value="all" selected>All Statuses</option>
                    <option value="pending">Pending</option>
                    <option value="resolved">Resolved</option>
                    <option value="rejected">Rejected</option>
                    <option value="escalated">Escalated</option>
                    <option value="under_review">Under Review</option>
                </select>
            </div>
        </div>

        <div class="bg-white rounded-[32px] border border-slate-100 shadow-sm overflow-hidden">
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-100">
                            <th class="px-8 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Reporter</th>
                            <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Review Comment</th>
                            <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Reason & Description</th>
                            <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Submitted At</th>
                            <th class="px-6 py-5 text-left text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Status</th>
                            <th class="px-8 py-5 text-right text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="review-reports-tbody" class="divide-y divide-slate-50">
                        <partial name="_ReviewReportsPartial" model="Model.CourseReviewReports" />
                    </tbody>
                </table>
            </div>
        </div>
    </div>


    <!-- Panel 3: Stats Details -->
    <div id="panel-stats" class="tab-panel hidden bg-white p-8 rounded-[32px] border border-slate-100 shadow-sm space-y-6">
        <h4 class="font-display font-extrabold text-lg text-slate-900">Detailed Report Statistics</h4>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100">
                <h5 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Pending Items</h5>
                <div class="space-y-2 mt-4 text-sm font-semibold">
                    <div class="flex justify-between">
                        <span class="text-slate-500">Course Reports:</span>
                        <span id="detailed-pending-courses" class="text-slate-900 font-extrabold">@Model.Stats.TotalPendingCourseReports</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-500">Course Review Reports:</span>
                        <span id="detailed-pending-creviews" class="text-slate-900 font-extrabold">@Model.Stats.TotalPendingCourseReviewReports</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-500">Lesson Review Reports:</span>
                        <span id="detailed-pending-lreviews" class="text-slate-900 font-extrabold">@Model.Stats.TotalPendingLessonReviewReports</span>
                    </div>
                    <div class="border-t border-slate-200 my-2 pt-2 flex justify-between text-primary font-bold">
                        <span>Total Pending:</span>
                        <span id="detailed-pending-total">@Model.Stats.TotalPending</span>
                    </div>
                </div>
            </div>

            <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100">
                <h5 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Platform Moderation Health</h5>
                <p class="text-xs text-slate-400 mt-1">Status of today's resolved/rejected actions.</p>
                <div class="space-y-2 mt-4 text-sm font-semibold">
                    <div class="flex justify-between text-emerald-600">
                        <span>Resolved Today:</span>
                        <span id="detailed-resolved-today">@Model.Stats.TotalResolvedToday</span>
                    </div>
                    <div class="flex justify-between text-slate-500">
                        <span>Rejected Today:</span>
                        <span id="detailed-rejected-today">@Model.Stats.TotalRejectedToday</span>
                    </div>
                </div>
            </div>

            <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 flex flex-col justify-between">
                <div>
                    <h5 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Status Policy</h5>
                    <p class="text-xs text-slate-400">Reports marked as "resolved" and removed will soft-delete content. Under escalation, senior admins are notified. Only Administrators are allowed to permanently delete courses.</p>
                </div>
                <div class="mt-4 pt-4 border-t border-slate-150 flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-primary"></span>
                    <span class="text-xs font-bold text-slate-500 uppercase">Role Level: @userRole.ToUpper()</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let activeTab = 'course-reports';
    let activeReviewSubTab = 'course'; // course | lesson
    const currentRole = '@userRole';

    document.addEventListener("DOMContentLoaded", () => {
        // Parse URL params to open correct tab
        const urlParams = new URLSearchParams(window.location.search);
        const tabParam = urlParams.get('tab');
        const subtabParam = urlParams.get('subtab');

        if (subtabParam) {
            activeReviewSubTab = subtabParam;
            document.querySelectorAll('.sub-tab-btn').forEach(btn => {
                if (btn.getAttribute('data-subtab') === subtabParam) {
                    btn.classList.add('bg-white', 'text-slate-800', 'shadow-sm');
                    btn.classList.remove('text-slate-500');
                } else {
                    btn.classList.remove('bg-white', 'text-slate-800', 'shadow-sm');
                    btn.classList.add('text-slate-500');
                }
            });
        }
        
        if (tabParam && tabParam !== 'course-reports') {
            switchTab(tabParam);
        }
    });

    function switchTab(tab) {
        activeTab = tab;
        document.querySelectorAll('.tab-btn').forEach(btn => {
            if (btn.getAttribute('data-tab') === tab) {
                btn.classList.add('border-primary', 'text-primary');
                btn.classList.remove('border-transparent', 'text-slate-500');
            } else {
                btn.classList.remove('border-primary', 'text-primary');
                btn.classList.add('border-transparent', 'text-slate-500');
            }
        });

        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.add('hidden'));
        document.getElementById(`panel-${tab}`).classList.remove('hidden');

        if (tab === 'course-reports') {
            loadCourseReports();
        } else if (tab === 'review-reports') {
            loadReviewReports();
        }
    }

    function switchReviewSubTab(subtab) {
        activeReviewSubTab = subtab;
        document.querySelectorAll('.sub-tab-btn').forEach(btn => {
            if (btn.getAttribute('data-subtab') === subtab) {
                btn.classList.add('bg-white', 'text-slate-800', 'shadow-sm');
                btn.classList.remove('text-slate-500');
            } else {
                btn.classList.remove('bg-white', 'text-slate-800', 'shadow-sm');
                btn.classList.add('text-slate-500');
            }
        });
        loadReviewReports();
    }

    // ── Get Stats ──
    async function refreshStats() {
        try {
            const res = await fetch('/AdminModeration/GetReportStats');
            if (res.ok) {
                const apiRes = await res.json();
                if (apiRes.success && apiRes.data) {
                    const stats = apiRes.data;
                    document.getElementById('stat-pending-courses').innerText = stats.totalPendingCourseReports;
                    document.getElementById('stat-pending-reviews').innerText = stats.totalPendingCourseReviewReports + stats.totalPendingLessonReviewReports;
                    document.getElementById('stat-resolved-today').innerText = stats.totalResolvedToday;
                    document.getElementById('stat-rejected-today').innerText = stats.totalRejectedToday;

                    // Detail stats panel
                    document.getElementById('detailed-pending-courses').innerText = stats.totalPendingCourseReports;
                    document.getElementById('detailed-pending-creviews').innerText = stats.totalPendingCourseReviewReports;
                    document.getElementById('detailed-pending-lreviews').innerText = stats.totalPendingLessonReviewReports;
                    document.getElementById('detailed-pending-total').innerText = stats.totalPending;
                    document.getElementById('detailed-resolved-today').innerText = stats.totalResolvedToday;
                    document.getElementById('detailed-rejected-today').innerText = stats.totalRejectedToday;
                }
            }
        } catch (err) {
            console.error('Failed to load report stats', err);
        }
    }

    // ── Load Course Reports ──
    async function loadCourseReports(page = 1, status = null) {
        const tbody = document.getElementById('course-reports-tbody');
        const filter = status || document.getElementById('course-status-filter').value;
        tbody.innerHTML = `<tr><td colspan="6" class="text-center py-10 text-slate-400 font-semibold">Loading course reports...</td></tr>`;

        try {
            const res = await fetch(`/AdminModeration/GetCourseReports?status=${filter}&page=${page}`);
            if (res.ok) {
                const html = await res.text();
                tbody.innerHTML = html;
            } else {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center py-10 text-red-500">HTTP Error loading reports.</td></tr>`;
            }
        } catch (err) {
            console.error(err);
            tbody.innerHTML = `<tr><td colspan="6" class="text-center py-10 text-red-500">An unexpected error occurred. Please try again later.</td></tr>`;
        }
    }

    // ── Load Review Reports ──
    async function loadReviewReports(page = 1, status = null) {
        const tbody = document.getElementById('review-reports-tbody');
        const filter = status || document.getElementById('review-status-filter').value;
        tbody.innerHTML = `<tr><td colspan="6" class="text-center py-10 text-slate-400 font-semibold">Loading review reports...</td></tr>`;

        try {
            const apiEndpoint = activeReviewSubTab === 'course' 
                ? `/AdminModeration/GetCourseReviewReports?status=${filter}&page=${page}`
                : `/AdminModeration/GetLessonReviewReports?status=${filter}&page=${page}`;

            const res = await fetch(apiEndpoint);
            if (res.ok) {
                const html = await res.text();
                tbody.innerHTML = html;
            } else {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center py-10 text-red-500">HTTP Error loading reports.</td></tr>`;
            }
        } catch (err) {
            console.error(err);
            tbody.innerHTML = `<tr><td colspan="6" class="text-center py-10 text-red-500">An unexpected error occurred. Please try again later.</td></tr>`;
        }
    }

    // ── Moderate Course Report modal ──
    async function moderateCourseReport(reportId, courseTitle, courseId, initialValues = null) {
        // Build SweetAlert modal content dynamically
        const showEscalate = !currentRole.includes('admin');

        const { value: formValues } = await Swal.fire({
            title: 'Moderate Course Report',
            html:
                `<div class="text-left space-y-4 px-1 text-slate-700">
                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 text-xs font-bold mb-4">
                        <span class="text-slate-400 block uppercase tracking-wider text-[10px]">Reported Content</span>
                        <span class="text-slate-800">${escapeHtml(courseTitle)} (Course ID: ${courseId})</span>
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Resolution Status</label>
                        <select id="swal-status" class="w-full rounded-xl border-slate-200 focus:ring-primary focus:border-primary text-xs font-bold">
                            <option value="resolved">Accept Report (Valid / Policy Violation)</option>
                            <option value="rejected">Dismiss Report (Invalid / Discard)</option>
                            <option value="under_review">Under Review</option>
                            ${showEscalate ? '<option value="escalated">Escalate to Senior Admin</option>' : ''}
                        </select>
                    </div>
                    <div class="flex items-center gap-2 py-1">
                        <input type="checkbox" id="swal-remove-content" class="rounded text-primary focus:ring-primary border-slate-200 w-4.5 h-4.5" />
                        <label for="swal-remove-content" class="text-xs font-bold text-slate-700 cursor-pointer">Flag Course (Hide from marketplace)</label>
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Moderator Note</label>
                        <textarea id="swal-note" class="p-4 w-full rounded-xl border-slate-200 focus:ring-primary focus:border-primary text-xs font-semibold h-20" placeholder="Write internal moderation notes..."></textarea>
                    </div>
                    </div>
                </div>`,
            focusConfirm: false,
            showCancelButton: true,
            confirmButtonText: 'Submit Decision',
            confirmButtonColor: '#10b981',
            cancelButtonText: 'Close',
            customClass: {
                popup: 'rounded-[32px] p-8',
                title: 'font-display font-extrabold text-slate-900 mb-4',
                confirmButton: 'rounded-xl font-bold px-8 py-3 text-xs',
                cancelButton: 'rounded-xl font-bold px-8 py-3 text-xs bg-slate-100 text-slate-700'
            },
            didOpen: () => {
                const statusSelect = document.getElementById('swal-status');
                const removeCheck = document.getElementById('swal-remove-content');
                const noteTextarea = document.getElementById('swal-note');

                if (initialValues) {
                    statusSelect.value = initialValues.status;
                    removeCheck.checked = initialValues.removeContent;
                    noteTextarea.value = initialValues.resolutionNote;
                }

                statusSelect.addEventListener('change', (e) => {
                    if (e.target.value !== 'resolved') {
                        removeCheck.checked = false;
                        removeCheck.disabled = true;
                    } else {
                        removeCheck.disabled = false;
                    }
                });
                removeCheck.addEventListener('change', async (e) => {
                    if (e.target.checked) {
                        e.target.checked = false;
                        
                        const currentValues = {
                            status: statusSelect.value,
                            removeContent: false,
                            resolutionNote: noteTextarea.value
                        };

                        const confirmVal = await Swal.fire({
                            title: 'Are you sure?',
                            text: "Are you sure you want to flag this course? This action will hide it from the marketplace and give the instructor a strike.",
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonText: 'Yes, flag course',
                            cancelButtonText: 'Cancel',
                            confirmButtonColor: '#ef4444',
                            customClass: {
                                popup: 'rounded-[32px] p-8',
                                title: 'font-display font-extrabold text-slate-900 mb-2',
                                confirmButton: 'rounded-xl font-bold px-6 py-3 text-xs',
                                cancelButton: 'rounded-xl font-bold px-6 py-3 text-xs bg-slate-100 text-slate-700'
                            }
                        });

                        if (confirmVal.isConfirmed) {
                            currentValues.removeContent = true;
                        }
                        
                        moderateCourseReport(reportId, courseTitle, courseId, currentValues);
                    }
                });
            },
            preConfirm: () => {
                return {
                    status: document.getElementById('swal-status').value,
                    removeContent: document.getElementById('swal-remove-content').checked,
                    resolutionNote: document.getElementById('swal-note').value
                }
            }
        });

        if (formValues) {
            Swal.showLoading();
            try {
                const response = await fetch(`/AdminModeration/ResolveCourseReport?reportId=${reportId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formValues)
                });

                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Report Moderated',
                        text: 'The course report has been successfully resolved.',
                        confirmButtonColor: '#10b981',
                        customClass: { popup: 'rounded-3xl' }
                    });
                    loadCourseReports();
                    refreshStats();
                } else {
                    const errResult = await response.json().catch(() => ({}));
                    Swal.fire({ icon: 'error', title: 'Moderation Error', text: errResult?.message || errResult?.Message || 'HTTP communication failed.', confirmButtonColor: '#ef4444' });
                }
            } catch (err) {
                console.error(err);
                Swal.fire({ icon: 'error', title: 'Network Error', text: 'An unexpected connection error occurred.', confirmButtonColor: '#ef4444' });
            }
        }
    }

    // ── Moderate Review Report modal ──
    async function moderateReviewReport(reportId, reviewComment, reviewType, initialValues = null) {
        const showEscalate = !currentRole.includes('admin');

        const { value: formValues } = await Swal.fire({
            title: 'Moderate Review Report',
            html:
                `<div class="text-left space-y-4 px-1 text-slate-700">
                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 text-xs font-bold mb-4">
                        <span class="text-slate-400 block uppercase tracking-wider text-[10px]">Reported Review</span>
                        <span class="text-slate-800 italic">"${escapeHtml(reviewComment)}"</span>
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Resolution Status</label>
                        <select id="swal-status" class="w-full rounded-xl border-slate-200 focus:ring-primary focus:border-primary text-xs font-bold">
                            <option value="resolved">Accept Report (Valid / Policy Violation)</option>
                            <option value="rejected">Dismiss Report (Invalid / Discard)</option>
                            <option value="under_review">Under Review</option>
                            ${showEscalate ? '<option value="escalated">Escalate to Senior Admin</option>' : ''}
                        </select>
                    </div>
                    <div class="flex items-center gap-2 py-1">
                        <input type="checkbox" id="swal-remove-content" class="rounded text-primary focus:ring-primary border-slate-200 w-4.5 h-4.5" />
                        <label for="swal-remove-content" class="text-xs font-bold text-slate-700 cursor-pointer">Remove content (Soft-delete review)</label>
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Moderator Note</label>
                        <textarea id="swal-note" class="p-4 w-full rounded-xl border-slate-200 focus:ring-primary focus:border-primary text-xs font-semibold h-20" placeholder="Write internal moderation notes..."></textarea>
                    </div>
                </div>`,
            focusConfirm: false,
            showCancelButton: true,
            confirmButtonText: 'Submit Decision',
            confirmButtonColor: '#10b981',
            cancelButtonText: 'Close',
            customClass: {
                popup: 'rounded-[32px] p-8',
                title: 'font-display font-extrabold text-slate-900 mb-4',
                confirmButton: 'rounded-xl font-bold px-8 py-3 text-xs',
                cancelButton: 'rounded-xl font-bold px-8 py-3 text-xs bg-slate-100 text-slate-700'
            },
            didOpen: () => {
                const statusSelect = document.getElementById('swal-status');
                const removeCheck = document.getElementById('swal-remove-content');
                const noteTextarea = document.getElementById('swal-note');

                if (initialValues) {
                    statusSelect.value = initialValues.status;
                    removeCheck.checked = initialValues.removeContent;
                    noteTextarea.value = initialValues.resolutionNote;
                }

                statusSelect.addEventListener('change', (e) => {
                    if (e.target.value !== 'resolved') {
                        removeCheck.checked = false;
                        removeCheck.disabled = true;
                    } else {
                        removeCheck.disabled = false;
                    }
                });
                removeCheck.addEventListener('change', async (e) => {
                    if (e.target.checked) {
                        e.target.checked = false;

                        const currentValues = {
                            status: statusSelect.value,
                            removeContent: false,
                            resolutionNote: noteTextarea.value
                        };

                        const confirmVal = await Swal.fire({
                            title: 'Are you sure?',
                            text: "Are you sure you want to soft-delete this content?",
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonText: 'Yes, soft-delete',
                            cancelButtonText: 'Cancel',
                            confirmButtonColor: '#ef4444',
                            customClass: {
                                popup: 'rounded-[32px] p-8',
                                title: 'font-display font-extrabold text-slate-900 mb-2',
                                confirmButton: 'rounded-xl font-bold px-6 py-3 text-xs',
                                cancelButton: 'rounded-xl font-bold px-6 py-3 text-xs bg-slate-100 text-slate-700'
                            }
                        });

                        if (confirmVal.isConfirmed) {
                            currentValues.removeContent = true;
                        }

                        moderateReviewReport(reportId, reviewComment, reviewType, currentValues);
                    }
                });
            },
            preConfirm: () => {
                return {
                    status: document.getElementById('swal-status').value,
                    removeContent: document.getElementById('swal-remove-content').checked,
                    resolutionNote: document.getElementById('swal-note').value
                }
            }
        });

        if (formValues) {
            Swal.showLoading();
            try {
                const actionController = reviewType === 'lesson_review' 
                    ? 'ResolveLessonReviewReport' 
                    : 'ResolveCourseReviewReport';

                const response = await fetch(`/AdminModeration/${actionController}?reportId=${reportId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formValues)
                });

                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Report Moderated',
                        text: 'The review report has been successfully resolved.',
                        confirmButtonColor: '#10b981',
                        customClass: { popup: 'rounded-3xl' }
                    });
                    loadReviewReports();
                    refreshStats();
                } else {
                    const errResult = await response.json().catch(() => ({}));
                    Swal.fire({ icon: 'error', title: 'Moderation Error', text: errResult?.message || errResult?.Message || 'HTTP communication failed.', confirmButtonColor: '#ef4444' });
                }
            } catch (err) {
                console.error(err);
                Swal.fire({ icon: 'error', title: 'Network Error', text: 'An unexpected connection error occurred.', confirmButtonColor: '#ef4444' });
            }
        }
    }

    // ── Remove Course Action (Admin only) ──
    async function hardDeleteCourseAction(courseId, reportId) {
        // Close parent Swal first
        Swal.close();

        const confirmVal = await Swal.fire({
            title: 'Are you absolutely sure?',
            text: "This action will remove the course from the platform and archive it.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Remove',
            cancelButtonText: 'Cancel',
            confirmButtonColor: '#ef4444',
            customClass: {
                popup: 'rounded-[32px] p-8',
                title: 'font-display font-extrabold text-slate-900 mb-2',
                confirmButton: 'rounded-xl font-bold px-6 py-3 text-xs',
                cancelButton: 'rounded-xl font-bold px-6 py-3 text-xs bg-slate-100 text-slate-700'
            }
        });

        if (confirmVal.isConfirmed) {
            Swal.showLoading();
            try {
                const response = await fetch(`/AdminModeration/RemoveCourse?courseId=${courseId}`, {
                    method: 'POST'
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        await Swal.fire({
                            icon: 'success',
                            title: 'Permanently Deleted',
                            text: 'The course has been completely expunged from the database.',
                            confirmButtonColor: '#10b981',
                            customClass: { popup: 'rounded-3xl' }
                        });
                        loadCourseReports();
                        refreshStats();
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Deletion Failed',
                            text: result.message || 'Only administrators can perform this command.',
                            confirmButtonColor: '#ef4444'
                        });
                    }
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Server error processing hard-delete.', confirmButtonColor: '#ef4444' });
                }
            } catch (err) {
                console.error(err);
                Swal.fire({ icon: 'error', title: 'Network Error', text: 'Network failure while dispatching command.', confirmButtonColor: '#ef4444' });
            }
        }
    }

    // ── Details Click Handlers ──
    function handleCourseRowClick(event, reportId) {
        const interactiveTags = ['BUTTON', 'A', 'SELECT', 'INPUT', 'TEXTAREA', 'LABEL', 'SPAN'];
        let target = event.target;
        while (target && target !== event.currentTarget) {
            if (interactiveTags.includes(target.tagName) || target.onclick || target.classList.contains('cursor-pointer')) {
                return;
            }
            target = target.parentNode;
        }
        
        try {
            const reportData = event.currentTarget.getAttribute('data-report');
            if (reportData) {
                const r = JSON.parse(reportData);
                showCourseReportDetail(r);
            }
        } catch (e) {
            console.error('Failed to parse report data', e);
        }
    }

