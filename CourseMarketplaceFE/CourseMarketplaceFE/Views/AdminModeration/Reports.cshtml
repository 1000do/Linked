                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Deletion Failed',
                            text: result.message || 'Only administrators can perform this command.',
                            confirmButtonColor: '#ef4444'
                        });
                    }
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Server error processing hard-delete.', confirmButtonColor: '#ef4444' });
