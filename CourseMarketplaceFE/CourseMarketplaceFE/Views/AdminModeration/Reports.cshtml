                    actionBtn = `<button onclick="moderateReviewReport(${r.reportId}, '${escapeJsString(r.reviewComment || "Review")}', '${r.reviewType}')" class="flex items-center gap-1 px-4 py-2 bg-primary hover:bg-secondary text-white rounded-xl text-xs font-bold transition-all shadow-lg active:scale-95">
                        <span class="material-symbols-outlined text-[16px]">verified_user</span> Moderate
                    </button>`;
                }
            } else {
                actionBtn = `<button onclick="showResolutionDetails('${escapeJsString(r.resolverEmail || "N/A")}', '${escapeJsString(r.resolutionNote || "No notes provided.")}', '${r.resolvedAt}')" class="px-3 py-1.5 text-xs font-bold text-slate-500 hover:text-slate-700 bg-slate-100 rounded-xl">Info</button>`;
            }

            tr.innerHTML = `
                <td class="px-8 py-6">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-full bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-500">
                            ${(r.reporterName || "U").charAt(0).toUpperCase()}
                        </div>
                        <div>
                            <span class="font-bold text-slate-900 block">${escapeHtml(r.reporterName)}</span>
                            <span class="text-[10px] text-slate-400 block">${escapeHtml(r.reporterEmail)}</span>
                        </div>
                    </div>
                </td>
                <td class="px-6 py-6 max-w-[280px]">
                    <div class="space-y-1">
                        <p class="text-xs text-slate-900 italic font-semibold line-clamp-2">"${escapeHtml(r.reviewComment || 'No comments')}"</p>
                        <div class="flex flex-col gap-0.5 text-slate-400 text-[10px]">
                            <div class="flex items-center gap-1">
                                <span>Author: <span class="font-bold text-slate-700">${escapeHtml(r.reviewAuthorName || 'Unknown User')}</span></span>
                                ${r.reviewRating ? `<span>• Rating: <span class="font-bold text-amber-500">${r.reviewRating}⭐</span></span>` : ''}
                            </div>
                            ${r.courseTitle ? `<div class="mt-1"><span>Course: <a href="/Course/Detail/${r.courseId}" target="_blank" class="font-bold text-primary hover:underline">${escapeHtml(r.courseTitle)}</a></span></div>` : ''}
