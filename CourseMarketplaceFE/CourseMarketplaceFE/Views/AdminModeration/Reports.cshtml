                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Resolution Status</label>
                        <select id="swal-status" class="w-full rounded-xl border-slate-200 focus:ring-primary focus:border-primary text-xs font-bold">
                            <option value="resolved">Accept Report (Valid / Policy Violation)</option>
                            <option value="rejected">Dismiss Report (Invalid / Discard)</option>
                            <option value="under_review">Under Review</option>
