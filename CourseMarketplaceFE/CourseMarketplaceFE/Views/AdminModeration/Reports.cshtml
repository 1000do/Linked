    // ── Moderate Course Report modal ──
    async function moderateCourseReport(reportId, courseTitle, courseId, initialValues = null) {
        // Build SweetAlert modal content dynamically
        const showEscalate = !currentRole.includes('admin');

        const { value: formValues } = await Swal.fire({
            title: 'Moderate Course Report',
            html:
                `<div class="text-left space-y-4 px-1 text-slate-700">
                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 text-xs font-bold mb-4">
                        <span class="text-slate-400 block uppercase tracking-wider text-[10px]">Reported Content</span>
