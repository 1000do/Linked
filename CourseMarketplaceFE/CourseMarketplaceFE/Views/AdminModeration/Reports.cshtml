        const resDateStr = r.resolvedAt ? new Date(r.resolvedAt).toLocaleString('en-GB') : 'N/A';
        const isLesson = r.reviewType === 'lesson_review';
        const title = isLesson ? 'Lesson Review Report Detail' : 'Course Review Report Detail';

        let resolutionHtml = '';
        if (r.status === 'resolved' || r.status === 'rejected') {
            resolutionHtml = `
                <div class="mt-4 pt-4 border-t border-slate-100">
                    <h5 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Resolution Details</h5>
                    <div class="grid grid-cols-2 gap-4 mb-3">
                        <div>
                            <span class="text-slate-400 block text-[10px] uppercase">Moderator</span>
                            <span class="text-slate-800 font-bold text-xs">${escapeHtml(r.resolverEmail || 'N/A')}</span>
                        </div>
                        <div>
                            <span class="text-slate-400 block text-[10px] uppercase">Resolved At</span>
                            <span class="text-slate-800 font-bold text-xs">${resDateStr}</span>
                        </div>
                    </div>
                    <div>
                        <span class="text-slate-400 block text-[10px] uppercase mb-1">Resolution Note</span>
                        <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 text-slate-800 text-xs leading-relaxed whitespace-pre-wrap">${escapeHtml(r.resolutionNote || 'No resolution note provided.')}</div>
                    </div>
                </div>
            `;
        }

        Swal.fire({
            title: title,
            html: `
            <div class="text-left space-y-4 px-1 text-slate-700">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <span class="text-slate-400 block text-[10px] uppercase tracking-wider">Reporter</span>
                        <span class="text-slate-800 font-bold text-xs block">${escapeHtml(r.reporterName || 'Unknown')}</span>
                        <span class="text-slate-400 text-[10px] block">${escapeHtml(r.reporterEmail || 'N/A')}</span>
                    </div>
                    <div>
                        <span class="text-slate-400 block text-[10px] uppercase tracking-wider">Submitted At</span>
                        <span class="text-slate-800 font-bold text-xs block">${dStr}</span>
                        <span class="text-slate-400 text-[10px] block">Status: <span class="font-extrabold uppercase text-primary">${r.status}</span></span>
                    </div>
                </div>
                
                <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 text-xs">
                    <span class="text-slate-400 block uppercase tracking-wider text-[10px] font-bold mb-1">Reported Review</span>
                    <p class="text-slate-800 italic font-semibold">"${escapeHtml(r.reviewComment || 'No comments')}"</p>
                    <div class="flex flex-col gap-0.5 mt-2 text-[10px] text-slate-500">
                        <div>Author: <span class="font-bold text-slate-750">${escapeHtml(r.reviewAuthorName || 'Unknown User')}</span> ${r.reviewRating ? `• Rating: <span class="font-bold text-amber-500">${r.reviewRating}⭐</span>` : ''}</div>
                        ${r.courseTitle ? `<div class="mt-1">Course: <a href="/Course/Detail/${r.courseId}" target="_blank" class="font-bold text-primary hover:underline">${escapeHtml(r.courseTitle)}</a></div>` : ''}
                        ${r.lessonTitle ? `<div>Lesson: <span class="font-bold text-slate-600">${escapeHtml(r.lessonTitle)}</span></div>` : ''}
                    </div>
                </div>

                <div>
                    <span class="text-slate-400 block text-[10px] uppercase tracking-wider mb-1">Reason</span>
                    <span class="px-2 py-0.5 bg-red-50 text-red-600 rounded text-[10px] font-black uppercase tracking-wider">${escapeHtml(r.reason)}</span>
                </div>

                <div>
                    <span class="text-slate-400 block text-[10px] uppercase tracking-wider mb-1">Description</span>
                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 text-slate-800 text-xs leading-relaxed whitespace-pre-wrap">${escapeHtml(r.description || 'No description provided.')}</div>
                </div>

                ${resolutionHtml}
            </div>`,
            showCancelButton: false,
            confirmButtonText: 'Close',
            confirmButtonColor: '#10b981',
            customClass: {
                popup: 'rounded-[32px] p-8',
                title: 'font-display font-extrabold text-slate-900 mb-4',
                confirmButton: 'rounded-xl font-bold px-8 py-3 text-xs w-full'
            }
        });
    }

    // ── Helper escaping ──
    function showResolutionDetails(resolverEmail, note, resolvedAt) {
        const dStr = resolvedAt ? new Date(resolvedAt).toLocaleString('en-GB') : 'N/A';
        Swal.fire({
            title: 'Report Resolution Details',
            html: `
            <div class="text-left space-y-4 px-1 text-slate-700 text-xs font-semibold">
                <div>
                    <span class="text-slate-400 block uppercase tracking-wider text-[10px]">Moderator</span>
                    <span class="text-slate-800 font-bold">${escapeHtml(resolverEmail)}</span>
                </div>
                <div>
                    <span class="text-slate-400 block uppercase tracking-wider text-[10px]">Moderated At</span>
                    <span class="text-slate-800 font-bold">${dStr}</span>
                </div>
                <div>
                    <span class="text-slate-400 block uppercase tracking-wider text-[10px]">Resolution Note</span>
                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 text-slate-800 leading-relaxed max-h-32 overflow-y-auto whitespace-pre-wrap">${escapeHtml(note)}</div>
                </div>
            </div>
            `,
            confirmButtonText: 'OK',
            confirmButtonColor: '#10b981',
            customClass: {
                popup: 'rounded-[32px] p-8',
                title: 'font-display font-extrabold text-slate-900 mb-4',
                confirmButton: 'rounded-xl font-bold px-8 py-3 text-xs'
            }
        });
    }



    // ── Helper escaping ──
    function escapeJsString(str) {
        if (!str) return '';
        return str.replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/"/g, '\\"').replace(/\n/g, '\\n').replace(/\r/g, '\\r');
    }

    function escapeHtml(str) {
        if (!str) return '';
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }
</script>
}
