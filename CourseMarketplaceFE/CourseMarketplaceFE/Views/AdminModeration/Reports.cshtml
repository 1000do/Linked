            } catch (err) {
                console.error(err);
                Swal.fire({ icon: 'error', title: 'Network Error', text: 'Network failure while dispatching command.', confirmButtonColor: '#ef4444' });
            }
        }
    }

    // ── Details Click Handlers ──
    function handleCourseRowClick(event, reportId) {
        const interactiveTags = ['BUTTON', 'A', 'SELECT', 'INPUT', 'TEXTAREA', 'LABEL', 'SPAN'];
        let target = event.target;
        while (target && target !== event.currentTarget) {
            if (interactiveTags.includes(target.tagName) || target.onclick || target.classList.contains('cursor-pointer')) {
                return;
            }
            target = target.parentNode;
        }
        
        const r = window.courseReportsMap[reportId];
        if (r) {
            showCourseReportDetail(r);
        }
    }

    function handleReviewRowClick(event, reportId) {
        const interactiveTags = ['BUTTON', 'A', 'SELECT', 'INPUT', 'TEXTAREA', 'LABEL', 'SPAN'];
        let target = event.target;
        while (target && target !== event.currentTarget) {
            if (interactiveTags.includes(target.tagName) || target.onclick || target.classList.contains('cursor-pointer')) {
                return;
            }
            target = target.parentNode;
        }
        
        const r = window.reviewReportsMap[reportId];
        if (r) {
            showReviewReportDetail(r);
        }
    }

