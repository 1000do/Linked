@{
    var actor = ViewBag.Actor as string ?? "Learner";
    if (actor == "Admin") { Layout = "_AdminLayout"; }
    else if (actor == "Instructor") { Layout = "_InstructorLayout"; }
    else { Layout = "_Layout"; }
    
    ViewData["Title"] = "Tin nhắn & Hỗ trợ";
    
    // Lấy Token từ Cookie
    var token = Context.Request.Cookies["AccessToken"] ?? "";
    
    // FE không map JWT vào User — AccountId lấy từ cookie UserId (set khi login), fallback claim nếu có
    var currentAccountId = Context.Request.Cookies["UserId"]
        ?? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
        ?? "0";
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
}

<div class="chat-wrapper shadow-sm" style="height: @(actor == "Admin" ? "calc(100vh - 120px)" : "calc(100vh - 80px)"); margin: @(actor == "Admin" ? "0" : "-20px 0"); width: 100%; box-sizing: border-box;">
    <!-- SIDEBAR -->
    <aside class="chat-sidebar">
        <div class="sidebar-header">
            <h4 class="m-0 font-bold text-slate-800">Trò chuyện</h4>
            <div class="search-box">
                <span class="material-symbols-outlined">search</span>
                <input type="text" id="search-chats" placeholder="Tìm kiếm người dùng...">
            </div>
        </div>
        <div id="chat-list" class="chat-list-container custom-scroll">
            <!-- Render JS -->
        </div>
    </aside>

    <!-- MAIN CHAT -->
    <main class="chat-main-area">
        <div id="empty-state" class="empty-chat">
            <div class="p-5 bg-white rounded-circle shadow-sm mb-4">
                <span class="material-symbols-outlined text-4xl text-emerald-500">forum</span>
            </div>
            <h5 class="font-bold text-slate-700">Chào mừng trở lại!</h5>
            <p class="text-sm">Chọn một cuộc hội thoại để bắt đầu kết nối.</p>
        </div>

        <div id="chat-content" class="chat-content-panel flex-1 flex flex-col min-h-0 overflow-hidden" style="display:none;">
            <header class="chat-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar-wrapper">
                        <img id="header-avatar" src="" class="avatar-img shadow-sm">
                        <div class="status-dot"></div>
                    </div>
                    <div>
                        <h6 id="header-name" class="m-0 font-bold text-slate-800">...</h6>
                        <span id="header-status" class="text-[10px] text-emerald-500 font-bold uppercase tracking-wider">Đang trực tuyến</span>
                    </div>
                </div>
            </header>

            <div id="message-list" class="message-viewport custom-scroll">
                <!-- Tin nhắn -->
            </div>

            <div id="typing-box" class="px-4 py-2 text-[11px] text-emerald-600 italic" style="display:none;">...</div>

            <footer class="chat-footer">
                <div class="input-group-premium">
                    @if (ViewBag.EnableAttachments == true)
                    {
                        <input type="file" id="file-input" style="display:none;" onchange="handleFileSelect(this)" />
                        <button type="button" class="btn-attach" onclick="document.getElementById('file-input').click()">
                            <span class="material-symbols-outlined text-slate-400 hover:text-emerald-500 transition-colors">attach_file</span>
                        </button>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-slate-200 cursor-not-allowed" title="Tính năng gửi file đang bị tắt">attach_file</span>
                    }
                    <div id="attachment-preview" class="hidden absolute bottom-full left-0 right-0 bg-white border-t border-slate-100 p-2 flex gap-2 overflow-x-auto shadow-lg rounded-t-xl">
                        <!-- Preview selected files -->
                    </div>
                    <textarea id="msg-input" class="chat-input-area custom-scroll" placeholder="Viết gì đó cho đối phương..." rows="1"></textarea>
                    <button id="btn-send" class="btn-chat-send">
                        <span class="material-symbols-outlined">send</span>
                    </button>
                </div>
            </footer>
        </div>
    </main>
</div>


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const API_URL = "http://localhost:5207";
        const token = "@token";

        // ★ Lấy AccountId từ JWT token (đáng tin hơn cookie UserId)
        function getAccountIdFromToken(jwt) {
            try {
                if (!jwt) return 0;
                const payload = JSON.parse(atob(jwt.split('.')[1]));
                // .NET dùng ClaimTypes.NameIdentifier → serialize thành key dài
                const sid = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier']
                         ?? payload['sub']
                         ?? payload['nameid']
                         ?? payload['nameidentifier']
                         ?? 0;
                return parseInt(sid, 10) || 0;
            } catch(e) { return 0; }
        }

        // Fallback: cookie
        const cookieUserId = parseInt("@currentAccountId", 10) || 0;
        const myAccountId = getAccountIdFromToken(token) || cookieUserId;

        console.log('[Chat Debug] myAccountId =', myAccountId, '| cookieUserId =', cookieUserId);

        function senderIdOf(m) {
            const v = m.senderId ?? m.SenderId;
            const n = Number(v);
            return Number.isFinite(n) ? n : NaN;
        }

        let activeChatId = null;
        let connection = null;
        let selectedFiles = []; // Danh sách file đang chờ gửi

        // 1. Khởi tạo SignalR
        async function initSignalR() {
            if (!token) return;

            connection = new signalR.HubConnectionBuilder()
                .withUrl(`${API_URL}/chatHub`, {
                    accessTokenFactory: () => token
                })
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveMessage", (msg) => {
                if (activeChatId === msg.chatId) {
                    appendMessage(msg);
                }
                loadChats(); 
            });

            connection.on("UserTyping", (data) => {
                const typingBox = document.getElementById('typing-box');
                if (activeChatId === data.chatId && data.accountId !== myAccountId) {
                    typingBox.innerText = `${data.name} đang soạn tin...`;
                    typingBox.style.display = data.isTyping ? 'block' : 'none';
                }
            });

            try {
                await connection.start();
                console.log("SignalR Connected.");
            } catch (err) {
                console.error("SignalR Connection Error: ", err);
            }
        }

        // 2. Load danh sách chat
        async function loadChats() {
            try {
                const res = await fetch(`${API_URL}/api/chat/list`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const chats = await res.json();
                
                const container = document.getElementById('chat-list');
                container.innerHTML = chats.map(c => `
                    <div class="chat-card ${activeChatId === c.chatId ? 'active' : ''}" 
                         onclick="selectChat(${c.chatId}, '${c.partnerName}', '${c.partnerAvatar}')">
                        <div class="avatar-wrapper">
                            <img src="${c.partnerAvatar || '/img/default-avatar.png'}" class="avatar-img">
                            <div class="status-dot" style="background: #10b981"></div>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="text-sm font-bold m-0 truncate">${c.partnerName}</h6>
                                <span class="text-[10px] text-slate-400">${c.lastMessageAt ? new Date(c.lastMessageAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : ''}</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-1">
                                <p class="text-xs text-slate-500 m-0 truncate">${c.lastMessage || 'Bắt đầu trò chuyện...'}</p>
                                ${c.unreadCount > 0 ? `<span class="unread-count">${c.unreadCount}</span>` : ''}
                            </div>
                        </div>
                    </div>
                `).join('');
            } catch (err) {
                console.error("Load chats error:", err);
            }
        }

        // 3. Chọn cuộc hội thoại
        async function selectChat(chatId, name, avatar) {
            if (activeChatId === chatId) return;
            activeChatId = chatId;
            
            document.getElementById('empty-state').style.display = 'none';
            document.getElementById('chat-content').style.display = 'flex';
            document.getElementById('header-name').innerText = name;
            document.getElementById('header-avatar').src = avatar || '/img/default-avatar.png';

            loadChats(); // Update active class

            try {
                const res = await fetch(`${API_URL}/api/chat/history?roomId=${chatId}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const messages = await res.json();
                
                const list = document.getElementById('message-list');
                list.innerHTML = "";
                messages.forEach(m => appendMessage(m));
                scrollToBottom();
            } catch (err) {
                console.error("Load history error:", err);
            }
        }

        function appendMessage(m) {
            const list = document.getElementById('message-list');
            const sid = senderIdOf(m);
            const isMe = sid === myAccountId && myAccountId > 0;
            const attachments = m.attachments || m.Attachments || [];
            
            let attachmentHtml = "";
            if (attachments.length > 0) {
                attachmentHtml = `
                    <div class="msg-attachments mt-2 flex flex-col gap-2">
                        ${attachments.map(a => {
                            if (a.fileType === 'image') {
                                return `<a href="${a.fileUrl}" target="_blank" class="block rounded-lg overflow-hidden border border-slate-100 shadow-sm max-w-[200px]">
                                            <img src="${a.fileUrl}" class="w-full h-auto" />
                                        </a>`;
                            } else {
                                return `<a href="${a.fileUrl}" target="_blank" class="flex items-center gap-2 p-2 bg-slate-50 rounded-lg border border-slate-100 hover:bg-slate-100 transition-colors text-xs text-slate-700 max-w-[250px]">
                                            <span class="material-symbols-outlined text-slate-400">description</span>
                                            <span class="truncate flex-1">${a.fileName || 'Tài liệu'}</span>
                                            <span class="material-symbols-outlined text-slate-400 text-sm">download</span>
                                        </a>`;
                            }
                        }).join('')}
                    </div>
                `;
            }
            
            const getFallbackAvatar = (role) => {
                const r = (role || "").toLowerCase();
                if (r === 'admin') return '/img/default-admin.png';
                if (r === 'staff') return '/img/default-staff.png';
                if (r === 'instructor') return '/img/default-instructor.png';
                return '/img/default-learner.png';
            };

            const fallback = getFallbackAvatar(m.senderRole);
            const html = `
                <div class="msg-row ${isMe ? 'me' : 'them'}">
                    <img src="${m.senderAvatar || fallback}" 
                         onerror="this.src='${fallback}'"
                         class="bubble-avatar shadow-sm">
                    <div class="bubble-container">
                        <div class="sender-name">${isMe ? 'Bạn' : m.senderName}</div>
                        <div class="bubble shadow-sm">
                            <div>${m.content}</div>
                            ${attachmentHtml}
                            <div class="msg-time">${new Date(m.sentAt || Date.now()).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</div>
                        </div>
                    </div>
                </div>
            `;
            list.insertAdjacentHTML('beforeend', html);
            scrollToBottom();
        }

        function scrollToBottom() {
            const list = document.getElementById('message-list');
            list.scrollTo({ top: list.scrollHeight, behavior: 'smooth' });
        }

        async function sendMsg() {
            const input = document.getElementById('msg-input');
            const content = input.value.trim();
            if (!activeChatId) return;
            if (!content && selectedFiles.length === 0) return;

            // 1. Upload files trước nếu có
            const attachments = [];
            for (const file of selectedFiles) {
                const uploaded = await uploadFile(file);
                if (uploaded) attachments.push(uploaded);
            }

            try {
                await connection.invoke("SendMessage", {
                    chatId: activeChatId,
                    content: content || (attachments.length > 0 ? "Đã gửi tệp đính kèm" : ""),
                    attachments: attachments
                });
                input.value = "";
                selectedFiles = [];
                renderAttachmentPreview();
                await connection.invoke("Typing", activeChatId, false);
            } catch (err) {
                console.error("Send message error:", err);
            }
        }

        async function uploadFile(file) {
            const formData = new FormData();
            formData.append('file', file);
            try {
                const res = await fetch(`${API_URL}/api/chatattachment/upload`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}` },
                    body: formData
                });
                if (!res.ok) throw new Error("Upload failed");
                return await res.json();
            } catch (e) {
                console.error("Upload error:", e);
                return null;
            }
        }

        function handleFileSelect(input) {
            if (input.files && input.files[0]) {
                selectedFiles.push(input.files[0]);
                renderAttachmentPreview();
                input.value = ""; // Reset để chọn lại cùng file
            }
        }

        function renderAttachmentPreview() {
            const preview = document.getElementById('attachment-preview');
            if (selectedFiles.length === 0) {
                preview.classList.add('hidden');
                return;
            }
            preview.classList.remove('hidden');
            preview.innerHTML = selectedFiles.map((f, i) => `
                <div class="relative bg-slate-50 p-2 pr-8 rounded-lg border border-slate-200 text-xs flex items-center gap-2 min-w-[120px]">
                    <span class="material-symbols-outlined text-slate-400">description</span>
                    <span class="truncate max-w-[100px]">${f.name}</span>
                    <button onclick="removeSelectedFile(${i})" class="absolute top-1 right-1 text-slate-400 hover:text-red-500">
                        <span class="material-symbols-outlined text-sm">close</span>
                    </button>
                </div>
            `).join('');
        }

        function removeSelectedFile(index) {
            selectedFiles.splice(index, 1);
            renderAttachmentPreview();
        }

        // Typing & Auto-resize logic
        const msgInput = document.getElementById('msg-input');
        let typingTimeout;

        msgInput.addEventListener('input', function() {
            // Auto resize
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';

            if (!activeChatId) return;
            connection.invoke("Typing", activeChatId, true);
            
            clearTimeout(typingTimeout);
            typingTimeout = setTimeout(() => {
                connection.invoke("Typing", activeChatId, false);
            }, 3000);
        });

        msgInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMsg();
            }
        });

        document.getElementById('btn-send').addEventListener('click', sendMsg);

        document.addEventListener('DOMContentLoaded', async () => {
            await initSignalR();
            await loadChats();

            const urlParams = new URLSearchParams(window.location.search);
            const chatId = urlParams.get('chatId');
            if (chatId) {
                selectChat(parseInt(chatId), "Hỗ trợ kỹ thuật", "");
            }
        });
    </script>
}
