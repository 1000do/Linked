@{
    var actor = ViewBag.Actor as string ?? "Learner";
    if (actor == "Admin") { Layout = "_AdminLayout"; }
    else if (actor == "Instructor") { Layout = "_InstructorLayout"; }
    else { Layout = "_Layout"; }
    
    ViewData["Title"] = "Messages & Support";
    
    // Lấy Token từ Cookie
    var token = Context.Request.Cookies["AccessToken"] ?? "";
    
    // FE không map JWT vào User — AccountId lấy từ cookie UserId (set khi login), fallback claim nếu có
    var currentAccountId = Context.Request.Cookies["UserId"]
        ?? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
        ?? "0";
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
}

<div class="chat-wrapper shadow-sm" style="height: @(actor == "Admin" ? "calc(100vh - 120px)" : "calc(100vh - 80px)"); margin: @(actor == "Admin" ? "0" : "-20px 0"); width: 100%; box-sizing: border-box;">
    <!-- SIDEBAR -->
    <aside class="chat-sidebar">
        <div class="sidebar-header flex flex-col gap-3">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="m-0 font-bold text-slate-800">Chats</h4>
                @{ var roleCheck = Context.Request.Cookies["UserRole"]?.ToLower(); }
                @if (roleCheck == "staff")
                {
                    <button onclick="contactAdmin()" class="bg-indigo-50 text-indigo-600 hover:bg-indigo-100 px-2 py-1.5 rounded-lg flex items-center gap-1 transition-colors" title="Chat with Admin">
                        <span class="material-symbols-outlined text-[16px]">admin_panel_settings</span>
                        <span class="text-[11px] font-bold">Contact Admin</span>
                    </button>
                }
            </div>
            
            <div class="search-box">
                <span class="material-symbols-outlined">search</span>
                <input type="text" id="search-chats" placeholder="Search users...">
            </div>

            @* Compact Premium Sort and Filter controls *@
            <div class="flex gap-2 items-center w-full">
                <div class="relative flex-1">
                    <select id="chat-filter-status" class="w-full appearance-none border border-slate-200 rounded-lg pl-2.5 pr-8 py-1.5 text-xs font-semibold bg-white focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-slate-600 cursor-pointer shadow-sm">
                        <option value="all">All Messages</option>
                        <option value="unread">Unread</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-1.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[16px]">arrow_drop_down</span>
                </div>

                <div class="relative flex-1">
                    <select id="chat-sort" class="w-full appearance-none border border-slate-200 rounded-lg pl-2.5 pr-8 py-1.5 text-xs font-semibold bg-white focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-slate-600 cursor-pointer shadow-sm">
                        <option value="recent">Recently Active</option>
                        <option value="name">Name (A-Z)</option>
                        <option value="unread-first">Unread First</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-1.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[16px]">arrow_drop_down</span>
                </div>
            </div>
        </div>
        <div id="pending-requests-container" class="px-3 pt-2 pb-0" style="display: none;">
            <div class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2 flex justify-between items-center">
                <span>Pending Requests</span>
                <span id="pending-count" class="bg-red-100 text-red-600 px-1.5 py-0.5 rounded text-[10px]">0</span>
            </div>
            <div id="pending-requests-list" class="flex flex-col gap-2 mb-3">
                <!-- Render JS -->
            </div>
            <hr class="border-slate-100 m-0">
        </div>
        <div id="chat-list" class="chat-list-container custom-scroll">
            <!-- Render JS -->
        </div>
    </aside>

    <!-- MAIN CHAT -->
    <main class="chat-main-area">
        <div id="empty-state" class="empty-chat">
            <div class="p-5 bg-white rounded-circle shadow-sm mb-4">
                <span class="material-symbols-outlined text-4xl text-emerald-500">forum</span>
            </div>
            <h5 class="font-bold text-slate-700">Welcome back!</h5>
            <p class="text-sm">Select a conversation to start chatting.</p>
        </div>

        <div id="chat-content" class="chat-content-panel flex-1 flex flex-col min-h-0 overflow-hidden" style="display:none;">
            <header class="chat-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar-wrapper">
                        <img id="header-avatar" src="" class="avatar-img shadow-sm" onerror="this.src='/img/default-avatar.png'">
                        <div class="status-dot"></div>
                    </div>
                    <div>
                        <h6 id="header-name" class="m-0 font-bold text-slate-800">...</h6>
                        <span id="header-status" class="text-[10px] text-emerald-500 font-bold uppercase tracking-wider">Online</span>
                    </div>
                </div>
                <div>
                    <button type="button" onclick="confirmDeleteChat()" class="btn btn-light btn-sm text-danger d-flex align-items-center gap-1 bg-transparent hover:bg-red-50 border-0" title="Clear chat history">
                        <span class="material-symbols-outlined" style="font-size: 20px;">delete</span>
                    </button>
                </div>
            </header>

            <div id="message-list" class="message-viewport custom-scroll">
                <!-- Tin nhắn -->
            </div>

            <div id="typing-box" class="px-4 py-2 text-[11px] text-emerald-600 italic" style="display:none;">...</div>

            <footer class="chat-footer flex flex-col">
                <div class="input-group-premium relative">
                    @if (ViewBag.EnableAttachments == true)
                    {
                        <input type="file" id="file-input" style="display:none;" onchange="handleFileSelect(this)" />
                        <button type="button" class="btn-attach" onclick="document.getElementById('file-input').click()">
                            <span class="material-symbols-outlined text-slate-400 hover:text-emerald-500 transition-colors">attach_file</span>
                        </button>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-slate-200 cursor-not-allowed" title="File sharing is currently disabled">attach_file</span>
                    }
                    <textarea id="msg-input" class="chat-input-area custom-scroll" placeholder="Type a message..." rows="1"></textarea>
                    <button id="btn-send" class="btn-chat-send">
                        <span class="material-symbols-outlined">send</span>
                    </button>
                </div>

                <div id="attachment-preview" class="hidden flex-col gap-2 w-full pt-3 mt-2 border-t border-slate-100">
                    <div class="flex justify-between items-center px-1">
                        <span id="attachment-count-text" class="text-[14px] font-bold text-slate-800"></span>
                        <button onclick="removeAllFiles()" class="text-[13px] text-slate-500 hover:text-red-500 transition-colors bg-transparent border-none cursor-pointer">Clear all</button>
                    </div>
                    <div id="attachment-thumbnails" class="flex gap-3 overflow-x-auto px-1 pb-2 custom-scroll">
                        <!-- JS injected thumbnails -->
                    </div>
                </div>
            </footer>
        </div>
    </main>
</div>


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const CHAT_API_URL = "";
        const chatPageToken = "@token";

        // ★ Lấy AccountId từ JWT token (đáng tin hơn cookie UserId)
        function getAccountIdFromToken(jwt) {
            try {
                if (!jwt) return 0;
                const payload = JSON.parse(atob(jwt.split('.')[1]));
                // .NET dùng ClaimTypes.NameIdentifier → serialize thành key dài
                const sid = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier']
                         ?? payload['sub']
                         ?? payload['nameid']
                         ?? payload['nameidentifier']
                         ?? 0;
                return parseInt(sid, 10) || 0;
            } catch(e) { return 0; }
        }

        // Fallback: cookie
        const chatCookieUserId = parseInt("@currentAccountId", 10) || 0;
        const chatMyAccountId = getAccountIdFromToken(chatPageToken) || chatCookieUserId;

        console.log('[Chat Debug] chatMyAccountId =', chatMyAccountId, '| chatCookieUserId =', chatCookieUserId);

        function senderIdOf(m) {
            const v = m.senderId ?? m.SenderId;
            const n = Number(v);
            return Number.isFinite(n) ? n : NaN;
        }

        let activeChatId = null;
        let chatPageConnection = null;
        let selectedFiles = []; // Danh sách file đang chờ gửi

        // 1. Khởi tạo SignalR
        async function initSignalR() {
            if (!chatPageToken) return;

            chatPageConnection = new signalR.HubConnectionBuilder()
                .withUrl(`${CHAT_API_URL}/chatHub`, {
                    accessTokenFactory: () => chatPageToken
                })
                .withAutomaticReconnect()
                .build();

            chatPageConnection.on("ReceiveMessage", async (msg) => {
                if (activeChatId === msg.chatId) {
                    appendMessage(msg);
                    try {
                        await chatPageConnection.invoke("MarkAsRead", activeChatId);
                    } catch (err) {
                        console.error("MarkAsRead error:", err);
                    }
                }
                await loadChats(); 
                if (typeof loadUnreadSummary === 'function') loadUnreadSummary();
            });

            chatPageConnection.on("UserTyping", (data) => {
                const typingBox = document.getElementById('typing-box');
                if (activeChatId === data.chatId && data.accountId !== chatMyAccountId) {
                    typingBox.innerText = `${data.name} is typing...`;
                    typingBox.style.display = data.isTyping ? 'block' : 'none';
                }
            });

            chatPageConnection.on("UserOnlineStatus", (data) => {
                // Update specific chat list items
                const chatCard = allChats.find(c => c.partnerId === data.accountId);
                if (chatCard) {
                    chatCard.isOnline = data.isOnline;
                    applyChatFilters(); // Re-render chat list to update green dot
                }

                // Update header if this is the active chat
                if (chatCard && activeChatId === chatCard.chatId) {
                    const statusText = document.getElementById('header-status');
                    if (data.isOnline) {
                        statusText.innerText = 'Online';
                        statusText.classList.remove('text-slate-400');
                        statusText.classList.add('text-emerald-500');
                    } else {
                        statusText.innerText = 'Offline';
                        statusText.classList.remove('text-emerald-500');
                        statusText.classList.add('text-slate-400');
                    }
                }
            });

            chatPageConnection.on("MessageRead", (data) => {
                if (activeChatId === data.chatId && data.accountId !== chatMyAccountId) {
                    // Update all my sent messages in this chat to show double blue ticks
                    const ticks = document.querySelectorAll('.msg-row.me .read-receipt');
                    ticks.forEach(tick => {
                        tick.innerText = 'done_all';
                        tick.classList.add('text-blue-500');
                    });
                }
            });

            chatPageConnection.on("NewSupportRequest", (ticket) => {
                loadPendingRequests();
            });

            chatPageConnection.on("RemoveSupportRequest", (ticketId) => {
                loadPendingRequests();
            });

            try {
                await chatPageConnection.start();
                console.log("SignalR Connected.");
            } catch (err) {
                console.error("SignalR Connection Error: ", err);
            }
        }

        // 2. Load danh sách chat
        let allChats = [];
        let defaultChats = [];
        let chatSearchDebounceTimer;

        function renderChatList(chats) {
            const container = document.getElementById('chat-list');
            if (!container) return;

            if (chats.length === 0) {
                container.innerHTML = `
                    <div class="p-6 text-center text-xs text-slate-400">
                        No conversations found.
                    </div>
                `;
                return;
            }

            container.innerHTML = chats.map(c => `
                <div class="chat-card ${activeChatId === c.chatId ? 'active' : ''}" 
                     onclick="selectChat(${c.chatId}, '${(c.partnerName || 'Support Team').replace(/'/g, "\\'")}', '${c.partnerAvatar || ''}', ${c.isOnline})">
                    <div class="avatar-wrapper">
                        <img src="${c.partnerAvatar || '/img/default-avatar.png'}" class="avatar-img" onerror="this.src='/img/default-avatar.png'">
                        ${c.isOnline ? '<div class="status-dot" style="background: #10b981"></div>' : ''}
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="text-sm font-bold m-0 truncate">${c.partnerName || 'Support Team'}</h6>
                            <span class="text-[10px] text-slate-400">${c.lastMessageAt ? new Date(c.lastMessageAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : ''}</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-1">
                            <p class="text-xs text-slate-500 m-0 truncate">${c.lastMessage || 'Start chatting...'}</p>
                            ${c.unreadCount > 0 ? `<span class="unread-count">${c.unreadCount}</span>` : ''}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function applyChatFilters() {
            const filterVal = document.getElementById('chat-filter-status').value;
            const sortVal = document.getElementById('chat-sort').value;

            let filtered = [...allChats];

            // 1. Filter status
            if (filterVal === 'unread') {
                filtered = filtered.filter(c => c.unreadCount > 0);
            }

            // 2. Sorting
            if (sortVal === 'recent') {
                filtered.sort((a, b) => new Date(b.lastMessageAt || 0) - new Date(a.lastMessageAt || 0));
            } else if (sortVal === 'name') {
                filtered.sort((a, b) => a.partnerName.localeCompare(b.partnerName, 'en'));
            } else if (sortVal === 'unread-first') {
                filtered.sort((a, b) => (b.unreadCount || 0) - (a.unreadCount || 0));
            }

            renderChatList(filtered);
        }

        async function loadChats() {
            try {
                const res = await fetch(`/Chat/GetList`);
                defaultChats = await res.json();
                
                const query = document.getElementById('search-chats').value.trim();
                if (!query) {
                    allChats = [...defaultChats];
                    applyChatFilters();
                }
            } catch (err) {
                console.error("Load chats error:", err);
            }
        }

        // --- Pending Requests Logic --- //
        let pendingRequests = [];

        async function loadPendingRequests() {
            try {
                const res = await fetch(`/Chat/GetPendingRequests`);
                pendingRequests = await res.json();
                renderPendingRequests();
            } catch (err) {
                console.error("Load pending requests error:", err);
            }
        }

        function renderPendingRequests() {
            const container = document.getElementById('pending-requests-container');
            const list = document.getElementById('pending-requests-list');
            const count = document.getElementById('pending-count');

            if (!pendingRequests || pendingRequests.length === 0) {
                container.style.display = 'none';
                return;
            }

            container.style.display = 'block';
            count.innerText = pendingRequests.length;

            const actor = '@actor'; // From Razor view
            const isStaffOrAdmin = actor === 'Admin' || actor === 'Staff';

            list.innerHTML = pendingRequests.map(t => `
                <div class="bg-orange-50 border border-orange-100 rounded-xl p-2 cursor-pointer hover:bg-orange-100 transition-colors">
                    <div class="flex items-center gap-2 mb-1">
                        <img src="${t.senderAvatar || '/img/default-avatar.png'}" class="w-6 h-6 rounded-full object-cover" onerror="this.src='/img/default-avatar.png'" />
                        <span class="text-xs font-bold text-slate-700 truncate flex-1">${t.senderName || 'User'}</span>
                        <span class="text-[9px] text-slate-400">${new Date(t.requestedAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
                    </div>
                    <div class="text-[11px] text-slate-600 line-clamp-1 mb-2">${t.initialMessage}</div>
                    ${isStaffOrAdmin ? `
                        <button onclick="acceptSupport('${t.ticketId}')" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white text-[10px] font-bold py-1.5 rounded-lg transition-colors">
                            Accept Request
                        </button>
                    ` : `
                        <div class="text-[10px] text-orange-600 font-semibold italic text-center w-full py-1">Waiting for support staff...</div>
                    `}
                </div>
            `).join('');
        }

        async function acceptSupport(ticketId) {
            try {
                const ticket = pendingRequests.find(t => t.ticketId === ticketId);
                const senderName = ticket ? ticket.senderName : "Support Session";
                const senderAvatar = ticket ? ticket.senderAvatar : "/img/default-avatar.png";

                const res = await fetch(`/Chat/AcceptSupport?ticketId=${ticketId}`, {
                    method: 'POST'
                });
                
                if (res.ok) {
                    const data = await res.json();
                    await loadChats();
                    selectChat(data.chatId, senderName, senderAvatar, true);
                    loadPendingRequests(); // Refresh the list to remove the accepted ticket
                } else {
                    const error = await res.json();
                    Swal.fire('Error', error.message || 'Failed to accept request.', 'error');
                }
            } catch (err) {
                console.error('Accept support error:', err);
            }
        }

        async function contactAdmin() {
            try {
                const res = await fetch("/Chat/GetAdminAccount");
                if (!res.ok) {
                    Swal.fire('Error', 'Admin account is currently unavailable.', 'error');
                    return;
                }
                const admin = await res.json();
                
                const createRes = await fetch("/Chat/CreateDirectChat", {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        targetAccountId: admin.accountId,
                        contextType: 'system'
                    })
                });
                
                if (createRes.ok) {
                    const data = await createRes.json();
                    await loadChats();
                    selectChat(data.chatId, admin.fullName, admin.avatarUrl, true);
                } else {
                    const err = await createRes.json();
                    Swal.fire('Error', err.message || 'Failed to connect with Admin.', 'error');
                }
            } catch (err) {
                console.error("Contact admin error:", err);
            }
        }
        // ------------------------------ //

        function handleSearchInput() {
            const query = document.getElementById('search-chats').value.trim();
            
            if (!query) {
                allChats = [...defaultChats];
                applyChatFilters();
                return;
            }
            
            clearTimeout(chatSearchDebounceTimer);
            chatSearchDebounceTimer = setTimeout(async () => {
                const currentQuery = document.getElementById('search-chats').value.trim();
                if (!currentQuery) return;
                
                try {
                    const res = await fetch(`/Chat/Search?q=${encodeURIComponent(currentQuery)}`);
                    allChats = await res.json();
                    applyChatFilters();
                } catch (err) {
                    console.error("Search chats error:", err);
                }
            }, 300);
        }

        // 3. Chọn cuộc hội thoại
        async function selectChat(chatId, name, avatar, isOnline = true) {
            if (activeChatId === chatId) return;
            
            // Clear typing state for previous chat if any
            if (activeChatId && typeof chatPageTypingTimeout !== 'undefined') {
                try {
                    chatPageConnection.invoke("Typing", activeChatId, false);
                    clearTimeout(chatPageTypingTimeout);
                } catch(e) {}
            }
            
            activeChatId = chatId;
            
            // Try to resolve name and avatar from allChats list for absolute correctness
            let displayName = name;
            let displayAvatar = avatar;
            let displayOnline = isOnline;
            const existingChat = allChats.find(c => c.chatId === chatId);
            if (existingChat) {
                displayName = existingChat.partnerName || displayName;
                displayAvatar = existingChat.partnerAvatar || displayAvatar;
                displayOnline = existingChat.isOnline;
            }
            
            // Reset input box
            const msgInput = document.getElementById('msg-input');
            if (msgInput) {
                msgInput.value = "";
                msgInput.style.height = 'auto';
            }
            
            // Reset attachments
            if (typeof selectedFiles !== 'undefined') {
                selectedFiles = [];
                if (typeof renderAttachmentPreview === 'function') renderAttachmentPreview();
            }

            // Join SignalR group to receive typing and read events for newly created chats
            if (chatPageConnection && chatPageConnection.state === signalR.HubConnectionState.Connected) {
                try {
                    await chatPageConnection.invoke("JoinChat", chatId);
                } catch (e) { console.error("JoinChat error:", e); }
            }

            document.getElementById('empty-state').style.display = 'none';
            document.getElementById('chat-content').style.display = 'flex';
            document.getElementById('header-name').innerText = displayName;
            
            const statusText = document.getElementById('header-status');
            if (displayOnline) {
                statusText.innerText = 'Online';
                statusText.classList.remove('text-slate-400');
                statusText.classList.add('text-emerald-500');
            } else {
                statusText.innerText = 'Offline';
                statusText.classList.remove('text-emerald-500');
                statusText.classList.add('text-slate-400');
            }

            let cleanAvatar = displayAvatar;
            if (!cleanAvatar || cleanAvatar === 'null' || cleanAvatar === 'undefined' || cleanAvatar.trim() === '') {
                cleanAvatar = '/img/default-avatar.png';
            }
            document.getElementById('header-avatar').src = cleanAvatar;

            loadChats(); // Update active class

            try {
                const res = await fetch(`/Chat/GetHistory?roomId=${chatId}`);
                const messages = await res.json();
                
                const list = document.getElementById('message-list');
                list.innerHTML = "";
                messages.forEach(m => appendMessage(m));
                scrollToBottom();

                // Broadcast read receipt
                chatPageConnection.invoke("MarkAsRead", chatId);
                
                // Refresh local chat list and global sidebar unread badge
                await loadChats();
                if (typeof loadUnreadSummary === 'function') loadUnreadSummary();
            } catch (err) {
                console.error("Load history error:", err);
            }
        }

        function appendMessage(m) {
            console.log('appendMessage received:', m);
            const list = document.getElementById('message-list');
            const sid = senderIdOf(m);
            const isMe = sid === chatMyAccountId && chatMyAccountId > 0;
            const attachments = m.attachments || m.Attachments || [];
            
            let attachmentHtml = "";
            if (attachments.length > 0) {
                attachmentHtml = `
                    <div class="msg-attachments mt-2 flex flex-col gap-2">
                        ${attachments.map(a => {
                            const fType = a.fileType || a.FileType;
                            const fUrl = a.fileUrl || a.FileUrl;
                            const fName = a.fileName || a.FileName || 'Document';
                            
                            if (fType === 'image') {
                                return `<a href="${fUrl}" target="_blank" class="block rounded-lg overflow-hidden border border-slate-100 shadow-sm max-w-[200px]">
                                            <img src="${fUrl}" class="w-full h-auto" />
                                        </a>`;
                            } else {
                                return `<a href="${fUrl}" target="_blank" class="flex items-center gap-2 p-2 bg-slate-50 rounded-lg border border-slate-100 hover:bg-slate-100 transition-colors text-xs text-slate-700 max-w-[250px]">
                                            <span class="material-symbols-outlined text-slate-400">description</span>
                                            <span class="truncate flex-1">${fName}</span>
                                            <span class="material-symbols-outlined text-slate-400 text-sm">download</span>
                                        </a>`;
                            }
                        }).join('')}
                    </div>
                `;
            }
            
            const getFallbackAvatar = (role) => {
                const r = (role || "").toLowerCase();
                if (r === 'admin') return '/img/default-admin.png';
                if (r === 'staff') return '/img/default-staff.png';
                if (r === 'instructor') return '/img/default-instructor.png';
                return '/img/default-learner.png';
            };

            const getFrameClass = (role) => {
                const r = (role || "").toLowerCase();
                if (r === 'admin') return 'frame-admin';
                if (r === 'staff') return 'frame-staff';
                if (r === 'instructor') return 'frame-instructor';
                return 'frame-learner';
            };

            const fallback = getFallbackAvatar(m.senderRole);
            const frameClass = getFrameClass(m.senderRole);
            
            // Determine ticks for sent messages
            let tickHtml = '';
            if (isMe) {
                // Temporary logic: if the message was sent a while ago, assume it might be seen, 
                // but real logic should rely on m.isSeen or real-time events.
                const isSeen = m.isSeen || false; 
                tickHtml = `<span class="material-symbols-outlined read-receipt text-[14px] ${isSeen ? 'text-blue-500' : 'text-slate-300'} ml-1" style="vertical-align: middle;">${isSeen ? 'done_all' : 'done'}</span>`;
            }

            const html = `
                <div class="msg-row ${isMe ? 'me' : 'them'}">
                    <div class="avatar-container ${frameClass}">
                        <img src="${m.senderAvatar || fallback}" 
                             onerror="this.src='${fallback}'"
                             class="bubble-avatar shadow-sm">
                    </div>
                    <div class="bubble-container">
                        <div class="sender-name">${isMe ? 'You' : m.senderName}</div>
                        <div class="bubble shadow-sm"><div class="bubble-text">${m.content}</div>${attachmentHtml}<div class="msg-time">${new Date(m.sentAt || Date.now()).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}${tickHtml}</div></div>
                    </div>
                </div>
            `;
            list.insertAdjacentHTML('beforeend', html);
            scrollToBottom();
        }

        function scrollToBottom() {
            const list = document.getElementById('message-list');
            list.scrollTo({ top: list.scrollHeight, behavior: 'smooth' });
        }

        async function sendMsg() {
            const input = document.getElementById('msg-input');
            const content = input.value.trim();
            if (!activeChatId) {
                Swal.fire('Error', 'Please select a valid chat first.', 'error');
                return;
            }
            if (!content && selectedFiles.length === 0) return;
            
            // Disable button during upload
            const sendBtn = document.getElementById('btn-send');
            sendBtn.disabled = true;
            sendBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">sync</span>';

            // 1. Upload files trước nếu có
            const attachments = [];
            for (const file of selectedFiles) {
                const uploaded = await uploadFile(file);
                if (uploaded) {
                    attachments.push({
                        FileUrl: uploaded.fileUrl || uploaded.FileUrl,
                        FileName: uploaded.fileName || uploaded.FileName,
                        FileType: uploaded.fileType || uploaded.FileType,
                        FileSize: uploaded.fileSize || uploaded.FileSize
                    });
                }
            }

            try {
                await chatPageConnection.invoke("SendMessage", {
                    ChatId: activeChatId,
                    Content: content || (attachments.length > 0 ? "Sent an attachment" : ""),
                    Attachments: attachments
                });
                input.value = "";
                selectedFiles = [];
                renderAttachmentPreview();
                await chatPageConnection.invoke("Typing", activeChatId, false);
            } catch (err) {
                console.error("Send message error:", err);
                Swal.fire('Error', 'Failed to send message.', 'error');
            } finally {
                sendBtn.disabled = false;
                sendBtn.innerHTML = '<span class="material-symbols-outlined">send</span>';
            }
        }

        async function uploadFile(file) {
            const formData = new FormData();
            formData.append('file', file);
            try {
                const res = await fetch(`/Chat/UploadAttachment`, {
                    method: 'POST',
                    body: formData
                });
                if (!res.ok) throw new Error("Upload failed");
                return await res.json();
            } catch (e) {
                console.error("Upload error:", e);
                return null;
            }
        }

        function handleFileSelect(input) {
            if (input.files && input.files[0]) {
                selectedFiles.push(input.files[0]);
                console.log('In handleFileSelect, selectedFiles',selectedFiles);  
                renderAttachmentPreview();
                input.value = ""; // Reset để chọn lại cùng file
            }
        }

        function removeAllFiles() {
            selectedFiles = [];
            renderAttachmentPreview();
        }

        function renderAttachmentPreview() {
            const previewContainer = document.getElementById('attachment-preview');
            const countText = document.getElementById('attachment-count-text');
            const thumbnailsContainer = document.getElementById('attachment-thumbnails');
            
            if (selectedFiles.length === 0) {
                previewContainer.classList.add('hidden');
                previewContainer.classList.remove('flex');
                return;
            }
            
            previewContainer.classList.remove('hidden');
            previewContainer.classList.add('flex');
            
            const imgCount = selectedFiles.filter(f => f.type.startsWith('image/')).length;
            const docCount = selectedFiles.length - imgCount;
            let title = [];
            if (imgCount > 0) title.push(`${imgCount} ${imgCount === 1 ? 'image' : 'images'}`);
            if (docCount > 0) title.push(`${docCount} ${docCount === 1 ? 'file' : 'files'}`);
            countText.textContent = title.join(', ');

            thumbnailsContainer.innerHTML = selectedFiles.map((f, i) => {
                const isImage = f.type.startsWith('image/');
                const previewUrl = isImage ? URL.createObjectURL(f) : '';
                
                if (isImage) {
                    return `
                        <div class="relative w-[60px] h-[60px] flex-shrink-0 rounded-lg border border-slate-200 overflow-hidden group">
                            <img src="${previewUrl}" class="w-full h-full object-cover" />
                            <button onclick="removeSelectedFile(${i})" class="absolute top-0.5 right-0.5 bg-black/50 text-white rounded-full w-5 h-5 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                <span class="material-symbols-outlined text-[14px]">close</span>
                            </button>
                        </div>
                    `;
                } else {
                    return `
                        <div class="relative w-[60px] h-[60px] flex-shrink-0 bg-slate-50 rounded-lg border border-slate-200 flex flex-col items-center justify-center p-1 group">
                            <span class="material-symbols-outlined text-slate-400 text-[24px]">description</span>
                            <span class="text-[9px] text-slate-500 truncate w-full text-center mt-1 px-1">${f.name}</span>
                            <button onclick="removeSelectedFile(${i})" class="absolute top-0.5 right-0.5 bg-black/50 text-white rounded-full w-5 h-5 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                <span class="material-symbols-outlined text-[14px]">close</span>
                            </button>
                        </div>
                    `;
                }
            }).join('') + `
                <button onclick="document.getElementById('file-input').click()" class="w-[60px] h-[60px] flex-shrink-0 bg-slate-50 hover:bg-slate-100 transition-colors rounded-lg border border-dashed border-slate-300 flex items-center justify-center text-slate-400 hover:text-slate-600">
                    <span class="material-symbols-outlined">add</span>
                </button>
            `;
        }

        function removeSelectedFile(index) {
            selectedFiles.splice(index, 1);
            console.log('In removeSelectedFile, selectedFiles',selectedFiles); 
            renderAttachmentPreview();
        }

        async function confirmDeleteChat() {
            if (!activeChatId) return;
            
            const confirmResult = await Swal.fire({
                title: 'Confirm Clear Chat',
                text: "Are you sure you want to clear this chat history? This cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Clear',
                cancelButtonText: 'Cancel',
                background: '#ffffff',
                customClass: { popup: 'rounded-2xl shadow-xl' }
            });

            if (confirmResult.isConfirmed) {
                try {
                    const res = await fetch(`/Chat/ClearHistory?chatId=${activeChatId}`, {
                        method: 'DELETE'
                    });
                    
                    if (res.ok) {
                        // Clear message list UI
                        document.getElementById('message-list').innerHTML = "";
                        
                        // Hide chat content panel
                        activeChatId = null;
                        document.getElementById('chat-content').style.display = 'none';
                        document.getElementById('empty-state').style.display = 'block';
                        
                        // Refresh sidebar
                        loadChats();
                        
                        // Update global sidebar unread badge
                        if (typeof loadUnreadSummary === 'function') loadUnreadSummary();

                        Swal.fire({
                            title: 'Cleared!',
                            text: 'The chat history was successfully cleared.',
                            icon: 'success',
                            timer: 1500,
                            showConfirmButton: false,
                            background: '#ffffff',
                            customClass: { popup: 'rounded-2xl shadow-xl' }
                        });
                    } else {
                        Swal.fire('Error', 'Failed to clear chat history.', 'error');
                    }
                } catch (err) {
                    console.error("Clear chat error:", err);
                    Swal.fire('Error', 'An error occurred while clearing chat history.', 'error');
                }
            }
        }

        // Typing & Auto-resize logic
        const msgInput = document.getElementById('msg-input');
        let chatPageTypingTimeout;

        msgInput.addEventListener('input', function() {
            // Auto resize
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';

            if (!activeChatId) return;
            chatPageConnection.invoke("Typing", activeChatId, true);
            
            clearTimeout(chatPageTypingTimeout);
            chatPageTypingTimeout = setTimeout(() => {
                chatPageConnection.invoke("Typing", activeChatId, false);
            }, 3000);
        });

        msgInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMsg();
            }
        });

        document.getElementById('btn-send').addEventListener('click', sendMsg);

        document.addEventListener('DOMContentLoaded', async () => {
            await initSignalR();
            await loadChats();
            await loadPendingRequests();

            // Hook up event listeners for instant chat filtering
            const searchChats = document.getElementById('search-chats');
            const chatFilter = document.getElementById('chat-filter-status');
            const chatSort = document.getElementById('chat-sort');

            if (searchChats) {
                searchChats.addEventListener('input', handleSearchInput);
                chatFilter.addEventListener('change', applyChatFilters);
                chatSort.addEventListener('change', applyChatFilters);
            }

            const urlParams = new URLSearchParams(window.location.search);
            const chatId = urlParams.get('chatId');
            if (chatId) {
                const parsedId = parseInt(chatId);
                const foundChat = allChats.find(c => c.chatId === parsedId);
                if (foundChat) {
                    selectChat(parsedId, foundChat.partnerName, foundChat.partnerAvatar, foundChat.isOnline);
                } else {
                    const fallbackName = urlParams.get('fallbackName') || "User";
                    const fallbackAvatar = urlParams.get('fallbackAvatar') || "/img/default-avatar.png";
                    selectChat(parsedId, fallbackName, fallbackAvatar, false);
                }
            }
        });
    </script>
}
