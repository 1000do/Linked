@model dynamic
@{
    // Hàm helper để đọc thuộc tính dynamic an toàn
    Func<string, dynamic, dynamic> getProp = (name, obj) => {
        try {
            var prop = obj.GetType().GetProperty(name);
            return prop != null ? prop.GetValue(obj, null) : null;
        } catch { return null; }
    };

    string avatarUrl = getProp("Url", Model) ?? "";
    string role = (getProp("Role", Model) ?? "learner").ToString().ToLower();
    if (role == "user") role = "learner"; // Map 'user' to 'learner' for default image

    string size = getProp("Size", Model) ?? "md"; 
    string name = getProp("Name", Model) ?? "User";

    // Logic Avatar mặc định
    var defaultAvatar = $"/img/default-{role}.png";
    // Đảm bảo có fallback nếu role không có ảnh riêng
    var fallbackAvatar = "/img/default-avatar.png";

    // Kích thước
    var sizeClasses = size switch {
        "xs" => "w-8 h-8",
        "sm" => "w-10 h-10",
        "md" => "w-12 h-12",
        "lg" => "w-20 h-20",
        "xl" => "w-32 h-32",
        "2xl" => "w-40 h-40",
        _ => "w-12 h-12"
    };

    var borderRadius = (size == "xl" || size == "2xl") ? "rounded-[2rem]" : "rounded-full";
}

<div class="flex items-center justify-center shrink-0">
    <!-- Lớp ảnh đại diện -->
    <div class="@sizeClasses @borderRadius overflow-hidden border-2 border-white shadow-sm z-0 relative">
        @if (!string.IsNullOrEmpty(avatarUrl) && avatarUrl != "null")
        {
            <img class="w-full h-full object-cover relative z-10" src="@avatarUrl" alt="@name"
                 onerror="this.onerror=function(){this.src='@fallbackAvatar'}; this.src='@defaultAvatar';" />
        }
        else
        {
            <img class="w-full h-full object-cover relative z-10" src="@defaultAvatar" alt="@name"
                 onerror="this.src='@fallbackAvatar'" />
        }
    </div>
</div>
