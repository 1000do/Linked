@using Microsoft.AspNetCore.Http
<nav class="fixed top-0 w-full z-50 bg-[#f0fcfb]/40 border-b border-primary/10 glass-nav">
    <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
        <div class="flex items-center gap-8">
            <a href="/" class="text-2xl font-headline font-extrabold tracking-tight text-primary">LinkedLearn</a>
        </div>

        <div class="flex items-center gap-4">
            @{
                var userName = Context.Request.Cookies["UserName"];
                var avatarUrl = Context.Request.Cookies["AvatarUrl"];
            }

            @if (string.IsNullOrEmpty(userName))
            {
                <a href="/Account/Login" class="px-6 py-2 text-sm font-semibold text-primary rounded-full hover:bg-primary/5 transition-colors">Login</a>
                <a href="/Account/Register" class="px-6 py-2 text-sm font-semibold bg-primary text-white rounded-full shadow-md shadow-primary/20 hover:opacity-90 transition-all">Register</a>
            }
            else
            {
                <div class="flex items-center gap-3 pl-4 border-l border-slate-200">

                    <div class="relative" id="notification-dropdown">
                        <button onclick="toggleNoti()" class="p-2 text-slate-600 hover:bg-slate-100 rounded-full transition-colors relative">
                            <span class="material-symbols-outlined text-[24px]">notifications</span>
                            <span id="noti-badge" class="hidden absolute top-2 right-2 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-white"></span>
                        </button>

                        <div id="noti-box" class="hidden absolute right-0 mt-3 w-80 bg-white rounded-2xl shadow-xl border border-slate-100 overflow-hidden z-[60]">
                            <div class="p-4 border-b border-slate-50 flex justify-between items-center bg-slate-50/50">
                                <span class="font-bold text-slate-800 text-sm">Thông báo</span>
                                <a href="/Notification" class="text-[11px] text-primary font-bold hover:underline">Xem tất cả</a>
                            </div>
                            <div id="notification-items-container" class="max-h-80 overflow-y-auto">
                                <div class="p-4 text-center text-slate-400 text-xs">Đang tải...</div>
                            </div>
                        </div>
                    </div>

                    <div class="hidden sm:flex flex-col items-end">
                        <span class="text-xs font-bold text-slate-700">Chào, @userName</span>
                        <a href="/Account/Logout" class="text-[10px] text-red-500 hover:underline font-medium">Logout</a>
                    </div>

                    <a asp-controller="Account" asp-action="Profile"
                       class="w-10 h-10 rounded-full overflow-hidden border-2 border-primary/20 hover:border-primary hover:scale-105 transition-all shadow-sm">
                        @if (!string.IsNullOrEmpty(avatarUrl) && avatarUrl != "null")
                        {
                            <img class="w-full h-full object-cover" src="@avatarUrl" alt="User avatar"
                                 onerror="this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(userName)&background=006a62&color=fff'" />
                        }
                        else
                        {
                            <img class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(userName)&background=006a62&color=fff" alt="Default avatar" />
                        }
                    </a>
                </div>
            }
        </div>
    </div>
</nav>

<script>
       function toggleNoti() {
        const box = document.getElementById('noti-box');
        box.classList.toggle('hidden');
        if (!box.classList.contains('hidden')) {
            document.getElementById('noti-badge').classList.add('hidden');
           
        }
    }

    

    window.addEventListener('click', function(e) {
        const dropdown = document.getElementById('notification-dropdown');
        if (dropdown && !dropdown.contains(e.target)) {
            document.getElementById('noti-box').classList.add('hidden');
        }
    });
</script>