@using System.Security.Claims
@{
   
    var tokenForLayout = Context.Request.Cookies["AccessToken"]
                         ?? Context.Request.Cookies[".AspNetCore.Identity.Application"];
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/img/default-avatar.png" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
	<!-- cloudinary -->
	<link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="dns-prefetch" href="https://res.cloudinary.com">

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#006a62",
                        "primary-container": "#43e8d8",
                        "on-primary": "#ffffff",
                        "secondary": "#006b60",
                        "surface": "#f0fcfb",
                        "on-surface": "#131d1e",
                        "surface-container-low": "#eaf6f5",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"]
                    }
                }
            }
        }
    </script>
    
    

    <style>
        .glass-nav {
            backdrop-filter: blur(12px);
        }

        .hero-gradient {
            background: linear-gradient(135deg, #006a62 0%, #43e8d8 100%);
        }

        /* Floating Chat Button - Emerald Style */
        .floating-chat-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 56px;
            height: 56px;
            background: #059669; /* Emerald 600 */
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(5, 150, 105, 0.4);
            cursor: pointer;
            z-index: 1000;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: none;
        }

        .floating-chat-btn:hover {
            transform: scale(1.1) rotate(5deg);
            background: #047857;
        }

        /* Support Popup */
        .support-popup {
            position: fixed;
            bottom: 100px;
            right: 30px;
            width: 350px;
            max-height: 500px;
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            z-index: 1001;
            display: none;
            flex-direction: column;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            animation: slideUp 0.3s ease;
        }

        @@keyframes slideUp {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .support-header {
            background: #059669;
            color: white;
            padding: 15px;
            text-align: center;
        }

        .support-content {
            height: 300px;
            padding: 15px;
            overflow-y: auto;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .support-footer {
            padding: 10px 15px;
            border-top: 1px solid #e2e8f0;
            background: white;
            display: flex;
            gap: 8px;
        }

        .support-input {
            flex: 1;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            padding: 8px 15px;
            font-size: 13px;
            outline: none;
        }

        .support-input:focus { border-color: #059669; }

        .support-send {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #059669;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border: none;
            cursor: pointer;
        }

        .mini-msg {
            max-width: 85%;
            padding: 8px 12px;
            border-radius: 15px;
            font-size: 13px;
            line-height: 1.4;
        }
        .mini-msg.them { background: #f1f5f9; align-self: flex-start; border-bottom-left-radius: 2px; }
        .mini-msg.me { background: #059669; color: white; align-self: flex-end; border-bottom-right-radius: 2px; }

        .mini-sender-name {
            font-size: 10px;
            font-weight: 700;
            color: #64748b;
            margin-bottom: 2px;
            padding: 0 4px;
        }
        .mini-msg-container {
            display: flex;
            flex-direction: column;
            max-width: 85%;
        }
        .mini-msg-container.me { align-self: flex-end; }
        .mini-msg-container.them { align-self: flex-start; }
        .mini-msg-container.me .mini-sender-name { text-align: right; }

        .chat-badge {
            position: absolute;
            top: -2px;
            right: -2px;
            background: #ef4444;
            color: white;
            font-size: 10px;
            font-weight: bold;
            padding: 2px 6px;
            border-radius: 10px;
            border: 2px solid white;
        }
        /* Avatar Frames System */
        .avatar-container {
            position: relative;
            display: inline-block;
            padding: 4px; /* Space for the frame */
        }
        
        .avatar-frame {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: inherit;
            pointer-events: none;
            z-index: 1;
        }

        /* Admin Frame: Golden Animated Glow */
        .frame-admin {
            border: 3px solid transparent;
            background: linear-gradient(white, white) padding-box,
                        linear-gradient(45deg, #f59e0b, #fbbf24, #d97706, #f59e0b) border-box;
            background-size: 200% 200%;
            animation: frame-rotate 3s linear infinite;
            box-shadow: 0 0 15px rgba(245, 158, 11, 0.4);
            border-radius: 2rem;
        }

        /* Staff Frame: Indigo Pulsing Glow */
        .frame-staff {
            border: 3px solid #6366f1;
            animation: frame-pulse-indigo 2s ease-in-out infinite;
            border-radius: 2rem;
        }

        /* Instructor Frame: Emerald Pulsing Glow */
        .frame-instructor {
            border: 3px solid #10b981;
            animation: frame-pulse-emerald 2s ease-in-out infinite;
            border-radius: 2rem;
        }

        /* Learner Frame: Static Teal Border */
        .frame-learner {
            border: 3px solid #2dd4bf;
            border-radius: 2rem;
            box-shadow: 0 2px 8px rgba(45, 212, 191, 0.2);
        }

        @@keyframes frame-rotate {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @@keyframes frame-pulse-indigo {
            0% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(99, 102, 241, 0); }
            100% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0); }
        }

        @@keyframes frame-pulse-emerald {
            0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
            100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }
    </style>

    <!-- GOOGLE LOGIN SCRIPT -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="bg-surface font-body text-on-surface antialiased">

    <!-- HEADER -->
    @await Html.PartialAsync("_Header")

    <!-- CONTENT -->
    <main role="main" class="pt-20">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    @await Html.PartialAsync("_Footer")


    @if (ViewData["Title"]?.ToString() != "Messages & Support")
    {
        <div id="support-chat-popup" class="support-popup">
            <div class="support-header">
                <h6 class="mb-0 fw-bold">Online Support</h6>
                <div class="d-flex align-items-center justify-content-center gap-1 text-[10px] opacity-75 mt-1">
                    <span class="w-1.5 h-1.5 rounded-circle bg-emerald-300"></span>
                    Online & Ready
                </div>
            </div>
            <div class="support-content" id="mini-chat-content">
                <div class="text-center py-4">
                    <p class="text-xs text-slate-400">Loading support history...</p>
                </div>
            </div>
            <div class="support-footer">
                <input type="text" id="mini-chat-input" class="support-input" placeholder="Type a message..." onkeypress="if(event.key === 'Enter') sendMiniMsg()">
                <button class="support-send" onclick="sendMiniMsg()">
                    <i class="material-symbols-outlined text-sm">send</i>
                </button>
            </div>
        </div>

        <!-- FLOATING CHAT BUTTON -->
        <button class="floating-chat-btn" onclick="toggleSupportPopup()" title="Support">
            <i class="material-symbols-outlined" style="font-size: 28px;">support_agent</i>
            <span class="chat-badge" style="display: none;" id="global-chat-badge">1</span>
        </button>
    }


   

    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        // 1. Initialize global variables
        const currentToken = `@Html.Raw(Context.Request.Cookies["AccessToken"] ?? "")`.trim();

        // --- GLOBAL LOGIC MOVED FROM SITE.JS ---
        async function toggleWishlist(btn, courseId) {
            if (!courseId) return;

            if (typeof currentToken === 'undefined' || !currentToken) {
                window.location.href = '/Account/Login';
                return;
            }

            try {
                btn.style.pointerEvents = 'none';
                btn.style.opacity = '0.7';

                const response = await fetch(`http://localhost:5207/api/Wishlist/toggle/${courseId}`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${currentToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                if (response.ok) {
                    const result = await response.json();
                    const icon = btn.querySelector('.material-symbols-outlined');
                    
                    if (result.isInWishlist) {
                        btn.classList.remove('text-slate-400', 'text-slate-700');
                        btn.classList.add('text-red-500');
                        if (icon) {
                            icon.style.fontVariationSettings = "'FILL' 1";
                            icon.classList.remove('text-slate-400');
                            icon.classList.add('text-red-500');
                        }
                        const textSpan = btn.querySelector('.wishlist-text');
                        if (textSpan) textSpan.innerText = "Saved to Wishlist";
                    } else {
                        btn.classList.remove('text-red-500');
                        const textSpan = btn.querySelector('.wishlist-text');
                        if (textSpan) {
                            btn.classList.add('text-slate-700');
                            textSpan.innerText = "Add to Wishlist";
                            if (icon) {
                                icon.classList.remove('text-red-500');
                                icon.classList.add('text-slate-400');
                            }
                        } else {
                            btn.classList.add('text-slate-400');
                        }
                        if (icon) icon.style.fontVariationSettings = "'FILL' 0";

                        if (window.location.pathname.toLowerCase() === '/wishlist') {
                            const card = btn.closest('.group');
                            if (card) {
                                card.style.transition = 'all 0.3s ease';
                                card.style.opacity = '0';
                                card.style.transform = 'scale(0.9)';
                                setTimeout(() => card.remove(), 300);
                            }
                        }
                    }
                } else if (response.status === 401) {
                    window.location.href = '/Account/Login';
                } else {
                    console.error('Failed to toggle wishlist:', response.statusText);
                }
            } catch (error) {
                console.error('Error toggling wishlist:', error);
            } finally {
                btn.style.pointerEvents = 'auto';
                btn.style.opacity = '1';
            }
        }

        window.addEventListener('unhandledrejection', function(event) {
            if (event.reason === undefined) {
                console.warn('Caught undefined promise rejection.');
                event.preventDefault();
            }
        });
        // ----------------------------------------

        // ★ Decode AccountId from JWT token (more reliable than cookie)
        function getAccountIdFromJwt(jwt) {
            try {
                if (!jwt) return 0;
                const payload = JSON.parse(atob(jwt.split('.')[1]));
                const sid = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier']
                         ?? payload['sub'] ?? payload['nameid'] ?? 0;
                return parseInt(sid, 10) || 0;
            } catch(e) { return 0; }
        }

        const cookieUserId = parseInt(`@Html.Raw(Context.Request.Cookies["UserId"] ?? "0")`.trim(), 10) || 0;
        const currentUserId = getAccountIdFromJwt(currentToken) || cookieUserId;
        console.log('[MiniChat] currentUserId =', currentUserId);

        function getMiniSenderId(m) {
            const v = m.senderId ?? m.SenderId;
            const n = Number(v);
            return Number.isFinite(n) ? n : NaN;
        }

        function getMiniSenderName(m) {
            return m.senderName ?? m.SenderName ?? m.fullName ?? m.FullName ?? "User";
        }
        
        let miniChatId = null;
        let miniChatConn = null;

        // 2. Logic cho Support Popup (Mini Chat)
        function toggleSupportPopup() {
            const popup = document.getElementById('support-chat-popup');
            if (!popup) return;
            const isVisible = popup.style.display === 'flex';
            popup.style.display = isVisible ? 'none' : 'flex';
            
            if (!isVisible) {
                const badge = document.getElementById('global-chat-badge');
                if (badge) badge.style.display = 'none';
                initMiniChat();
            }
        }

        async function initMiniChat() {
            if (!currentToken) {
                window.location.href = "/Account/Login";
                return;
            }
            if (miniChatId) return;

            try {
                // Ensure SignalR connection is ready
                if (!miniChatConn || miniChatConn.state !== signalR.HubConnectionState.Connected) {
                    console.log("[MiniChat] Waiting for connection...");
                    await new Promise(resolve => {
                        const interval = setInterval(() => {
                            if (miniChatConn && miniChatConn.state === signalR.HubConnectionState.Connected) {
                                clearInterval(interval);
                                resolve();
                            }
                        }, 500);
                        setTimeout(() => { clearInterval(interval); resolve(); }, 5000); // Timeout 5s
                    });
                }

                // Get support staff ID
                const staffRes = await fetch("http://localhost:5207/api/chat/support-account", {
                    headers: { 'Authorization': `Bearer ${currentToken}` }
                });
                const staff = await staffRes.json();
                
                // Create/Get chat room
                const createRes = await fetch("http://localhost:5207/api/chat/create", {
                    method: 'POST',
                    headers: { 
                        'Authorization': `Bearer ${currentToken}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ targetAccountId: staff.accountId, contextType: 'system' })
                });
                const chatData = await createRes.json();
                miniChatId = chatData.chatId;

                // Join SignalR group
                if (miniChatConn && miniChatConn.state === signalR.HubConnectionState.Connected) {
                    await miniChatConn.invoke("JoinChat", miniChatId);
                }

                await loadMiniHistory();
            } catch (err) {
                console.error("Init mini chat error:", err);
                document.getElementById('mini-chat-content').innerHTML = `<div class="text-center py-4 text-xs text-red-500">Unable to connect to support.</div>`;
            }
        }

        async function loadMiniHistory() {
            if (!miniChatId) return;
            try {
                const res = await fetch(`http://localhost:5207/api/chat/history?roomId=${miniChatId}`, {
                    headers: { 'Authorization': `Bearer ${currentToken}` }
                });
                const msgs = await res.json();
                const container = document.getElementById('mini-chat-content');
                container.innerHTML = msgs.map(m => {
                    const sid = getMiniSenderId(m);
                    const isMe = sid === currentUserId && currentUserId > 0;
                    const name = getMiniSenderName(m);
                    return `
                        <div class="mini-msg-container ${isMe ? 'me' : 'them'}">
                            <div class="mini-sender-name">${isMe ? 'You' : name}</div>
                            <div class="mini-msg ${isMe ? 'me' : 'them'}">${m.content}</div>
                        </div>`;
                }).join('');
                container.scrollTop = container.scrollHeight;
            } catch (err) {
                console.error("Load mini history error:", err);
            }
        }

        async function sendMiniMsg() {
            const input = document.getElementById('mini-chat-input');
            const content = input.value.trim();
            if (!content || !miniChatId || !miniChatConn) return;

            try {
                await miniChatConn.invoke("SendMessage", {
                    chatId: miniChatId,
                    content: content
                });
                input.value = "";
            } catch (err) {
                console.error("Send mini msg error:", err);
            }
        }

        function appendMiniMsg(m) {
            const container = document.getElementById('mini-chat-content');
            if (!container) return;
            const sid = getMiniSenderId(m);
            const isMe = sid === currentUserId && currentUserId > 0;
            const name = getMiniSenderName(m);
            const html = `
                <div class="mini-msg-container ${isMe ? 'me' : 'them'}">
                    <div class="mini-sender-name">${isMe ? 'You' : name}</div>
                    <div class="mini-msg ${isMe ? 'me' : 'them'}">${m.content}</div>
                </div>`;
            container.insertAdjacentHTML('beforeend', html);
            container.scrollTop = container.scrollHeight;
        }

        // 3. Notifications & Global SignalR logic
        function timeSince(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return "Just now";
            const interval = Math.floor(seconds / 60);
            if (interval < 60) return interval + " minutes ago";
            const hours = Math.floor(interval / 60);
            if (hours < 24) return hours + " hours ago";
            return date.toLocaleDateString('en-US');
        }

        async function loadTopNotifications() {
            const container = document.getElementById('notification-items-container');
            const badge = document.getElementById('noti-badge');
            if (!container || !currentToken) return;

            try {
                const response = await fetch("http://localhost:5207/api/Notification", {
                    headers: { 'Authorization': `Bearer ${currentToken}` }
                });
                if (response.ok) {
                    const result = await response.json();
                    const notifications = Array.isArray(result) ? result : (result.data || []);
                    const hasUnread = notifications.some(n => n.isRead === false);
                    if (badge) hasUnread ? badge.classList.remove('hidden') : badge.classList.add('hidden');

                    const top3 = notifications.slice(0, 3);
                    if (top3.length === 0) {
                        container.innerHTML = `<div class="px-4 py-8 text-center text-slate-400 text-sm italic">No new notifications</div>`;
                        return;
                    }
                    container.innerHTML = top3.map(n => `
                        <div class="p-4 border-b border-slate-50 hover:bg-emerald-50/50 transition-all cursor-pointer" onclick="location.href='${n.linkAction ? n.linkAction : '/Notification'}'">
                            <p class="text-xs font-bold text-slate-800 truncate">${n.title}</p>
                            <p class="text-[11px] text-slate-500 mt-1 line-clamp-2">${n.content}</p>
                            <p class="text-[9px] text-slate-300 mt-2 uppercase font-bold">${timeSince(new Date(n.createdAt))}</p>
                        </div>
                    `).join('');
                }
            } catch (err) { console.error("Noti error:", err); }
        }

        document.addEventListener("DOMContentLoaded", () => {
            loadTopNotifications();
            
            if (currentToken) {
                // SignalR Noti
                const notiConn = new signalR.HubConnectionBuilder()
                    .withUrl("http://localhost:5207/notificationHub", { accessTokenFactory: () => currentToken })
                    .withAutomaticReconnect().build();
                notiConn.on("ReceiveNotification", () => loadTopNotifications());
                notiConn.on("UpdateWishlistCount", () => {
                    if (typeof updateWishlistBadge === 'function') {
                        updateWishlistBadge();
                    }
                });
                notiConn.start().catch(err => console.error("Noti Hub Error", err));

                // SignalR Chat
                miniChatConn = new signalR.HubConnectionBuilder()
                    .withUrl("http://localhost:5207/chatHub", { accessTokenFactory: () => currentToken })
                    .withAutomaticReconnect().build();

                miniChatConn.on("ReceiveMessage", function (message) {
                    const popup = document.getElementById('support-chat-popup');
                    const msgChatId = message.chatId ?? message.ChatId;
                    if (popup && popup.style.display === 'flex' && msgChatId == miniChatId) {
                        appendMiniMsg(message);
                    } else if (window.location.pathname.toLowerCase() !== "/chat") {
                        const chatBadge = document.getElementById('global-chat-badge');
                        if (chatBadge) {
                            chatBadge.style.display = 'block';
                            const current = parseInt(chatBadge.innerText || "0");
                            chatBadge.innerText = current + 1;
                        }
                    }
                });

                miniChatConn.start().then(() => {
                    fetch("http://localhost:5207/api/chat/unread-count", {
                        headers: { 'Authorization': `Bearer ${currentToken}` }
                    }).then(res => res.json()).then(data => {
                        if (data.count > 0 && window.location.pathname.toLowerCase() !== "/chat") {
                            const b = document.getElementById('global-chat-badge');
                            if (b) { b.style.display = 'block'; b.innerText = data.count; }
                        }
                    });
                }).catch(err => console.error("Chat Hub Error", err));
            }
        });
    </script>
</body>
</html>