@using System.Security.Claims
@{
   
    var tokenForLayout = Context.Request.Cookies["AccessToken"]
                         ?? Context.Request.Cookies[".AspNetCore.Identity.Application"];
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/img/default-avatar.png" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
	<!-- cloudinary -->
	<link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="dns-prefetch" href="https://res.cloudinary.com">

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#006a62",
                        "primary-container": "#43e8d8",
                        "on-primary": "#ffffff",
                        "secondary": "#006b60",
                        "surface": "#f0fcfb",
                        "on-surface": "#131d1e",
                        "surface-container-low": "#eaf6f5",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"]
                    }
                }
            }
        }
    </script>
    
    

    <style>
        .glass-nav {
            backdrop-filter: blur(12px);
        }

        .hero-gradient {
            background: linear-gradient(135deg, #006a62 0%, #43e8d8 100%);
        }

        /* Floating Chat Button - Emerald Style */
        .floating-chat-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 56px;
            height: 56px;
            background: #059669; /* Emerald 600 */
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(5, 150, 105, 0.4);
            cursor: pointer;
            z-index: 1000;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: none;
        }

        .floating-chat-btn:hover {
            transform: scale(1.1) rotate(5deg);
            background: #047857;
        }

        /* Support Popup */
        .support-popup {
            position: fixed;
            bottom: 100px;
            right: 30px;
            width: 360px;
            height: 500px;
            z-index: 1001;
            display: none;
            flex-direction: column;
            animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @@keyframes slideUp {
            from { transform: translateY(30px) scale(0.95); opacity: 0; }
            to { transform: translateY(0) scale(1); opacity: 1; }
        }

        /* Minimal scrollbar for chat */
        .chat-scroll::-webkit-scrollbar {
            width: 6px;
        }
        .chat-scroll::-webkit-scrollbar-track {
            background: transparent;
        }
        .chat-scroll::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 10px;
        }

        .chat-badge {
            position: absolute;
            top: -2px;
            right: -2px;
            background: #ef4444;
            color: white;
            font-size: 10px;
            font-weight: bold;
            padding: 2px 6px;
            border-radius: 10px;
            border: 2px solid white;
        }
        /* Avatar Frames System */
        .avatar-container {
            position: relative;
            display: inline-block;
            padding: 4px; /* Space for the frame */
        }
        
        .avatar-frame {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: inherit;
            pointer-events: none;
            z-index: 1;
        }

        /* Admin Frame: Golden Animated Glow */
        .frame-admin {
            border: 3px solid transparent;
            background: linear-gradient(white, white) padding-box,
                        linear-gradient(45deg, #f59e0b, #fbbf24, #d97706, #f59e0b) border-box;
            background-size: 200% 200%;
            animation: frame-rotate 3s linear infinite;
            box-shadow: 0 0 15px rgba(245, 158, 11, 0.4);
            border-radius: 2rem;
        }

        /* Staff Frame: Indigo Pulsing Glow */
        .frame-staff {
            border: 3px solid #6366f1;
            animation: frame-pulse-indigo 2s ease-in-out infinite;
            border-radius: 2rem;
        }

        /* Instructor Frame: Emerald Pulsing Glow */
        .frame-instructor {
            border: 3px solid #10b981;
            animation: frame-pulse-emerald 2s ease-in-out infinite;
            border-radius: 2rem;
        }

        /* Learner Frame: Static Teal Border */
        .frame-learner {
            border: 3px solid #2dd4bf;
            border-radius: 2rem;
            box-shadow: 0 2px 8px rgba(45, 212, 191, 0.2);
        }

        @@keyframes frame-rotate {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @@keyframes frame-pulse-indigo {
            0% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(99, 102, 241, 0); }
            100% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0); }
        }

        @@keyframes frame-pulse-emerald {
            0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
            100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }
    </style>

    <!-- GOOGLE LOGIN SCRIPT -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Prevent SweetAlert from altering the body height/padding, which breaks the fixed layout
        window.Swal = window.Swal.mixin({
            heightAuto: false,
            scrollbarPadding: false
        });
    </script>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="bg-surface font-body text-on-surface antialiased">

    <!-- HEADER -->
    @await Html.PartialAsync("_Header")

    <!-- CONTENT -->
    <main role="main" class="pt-20">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    @await Html.PartialAsync("_Footer")


    @{
        bool isHome = ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index";
        bool isLoggedIn = !string.IsNullOrEmpty(tokenForLayout);
    }
    @if (isLoggedIn && isHome)
    {
        <div id="support-chat-popup" class="support-popup bg-white rounded-3xl shadow-[0_20px_60px_-15px_rgba(0,0,0,0.2)] border border-slate-100 overflow-hidden flex-col" style="display: none;">
            <!-- Header -->
            <div class="bg-gradient-to-r from-emerald-600 to-teal-500 px-5 py-4 text-white flex items-center justify-between shadow-md relative z-10">
                <div class="flex items-center gap-3">
                    <div class="relative">
                        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center backdrop-blur-sm overflow-hidden">
                            <img id="support-avatar" src="" alt="Support" class="w-full h-full object-cover hidden" />
                            <span id="support-icon" class="material-symbols-outlined text-[22px]">support_agent</span>
                        </div>
                        <div class="absolute bottom-0 right-0 w-3 h-3 bg-green-400 border-2 border-emerald-600 rounded-full"></div>
                    </div>
                    <div>
                        <h6 id="support-name" class="font-display font-bold text-[15px] leading-tight m-0 text-white">Online Support</h6>
                        <p class="text-[11px] font-medium text-emerald-50 m-0 opacity-90">Typically replies instantly</p>
                    </div>
                </div>
                <button onclick="toggleSupportPopup()" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-white/20 transition-colors text-white border-0 bg-transparent">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
            </div>
            
            <!-- Chat Content -->
            <div class="flex-1 bg-slate-50/50 p-4 overflow-y-auto overflow-x-hidden flex flex-col gap-3 chat-scroll relative" id="mini-chat-content">
                <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-5 pointer-events-none"></div>
                <div class="text-center py-6 w-full relative z-10">
                    <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-3 animate-pulse">
                        <span class="material-symbols-outlined">hourglass_empty</span>
                    </div>
                    <p class="text-xs font-medium text-slate-400">Loading conversation...</p>
                </div>
            </div>
            
            <!-- Chat Input Footer -->
            <div class="p-4 bg-white border-t border-slate-100 relative z-10">
                <div class="flex items-end gap-2 bg-slate-50 border border-slate-200 rounded-[24px] p-1.5 focus-within:ring-2 focus-within:ring-emerald-500/20 focus-within:border-emerald-500/50 transition-all shadow-sm">
                    <input type="text" id="mini-chat-input" class="flex-1 bg-transparent border-none focus:ring-0 px-3 py-2 text-[14px] text-slate-700 placeholder:text-slate-400 w-full" placeholder="Type your message..." autocomplete="off" oninput="handleInputTyping()" onkeypress="if(event.key === 'Enter') sendMiniMsg()">
                    <button class="w-[40px] h-[40px] shrink-0 rounded-full bg-emerald-600 hover:bg-emerald-700 text-white flex items-center justify-center transition-transform hover:scale-105 active:scale-95 border-0" onclick="sendMiniMsg()">
                        <span class="material-symbols-outlined text-[18px] ml-0.5">send</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- FLOATING CHAT BUTTON -->
        <div class="fixed bottom-[30px] right-[30px] z-[1000] flex flex-col items-end gap-3 pointer-events-none" id="floating-chat-container">
            <!-- Unread Preview Bubble -->
            <div id="unread-preview-bubble" class="hidden bg-white p-3.5 rounded-2xl rounded-br-sm shadow-[0_10px_40px_rgba(0,0,0,0.15)] border border-slate-100 max-w-[280px] pointer-events-auto cursor-pointer animate-[slideUp_0.3s_ease] transition-transform hover:scale-105 origin-bottom-right" onclick="toggleSupportPopup()">
                <div class="flex items-center gap-1.5 mb-1.5">
                    <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                    <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">New Message</span>
                </div>
                <p class="text-[13px] text-slate-700 m-0 line-clamp-2 leading-relaxed" id="preview-content">...</p>
            </div>
            
            <button class="w-[56px] h-[56px] bg-emerald-600 hover:bg-emerald-700 text-white rounded-full flex items-center justify-center shadow-[0_4px_20px_rgba(5,150,105,0.4)] cursor-pointer transition-all duration-300 hover:scale-110 hover:-rotate-6 border-none pointer-events-auto relative" onclick="toggleSupportPopup()" title="Support">
                <i class="material-symbols-outlined text-[28px]">support_agent</i>
                <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full border-2 border-white" style="display: none;" id="global-chat-badge">1</span>
            </button>
        </div>
    }


   

    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        // 1. Initialize global variables
        const currentToken = `@Html.Raw(Context.Request.Cookies["AccessToken"] ?? "")`.trim();

        // --- GLOBAL LOGIC MOVED FROM SITE.JS ---
        async function toggleWishlist(btn, courseId) {
            if (!courseId) return;

            if (typeof currentToken === 'undefined' || !currentToken) {
                window.location.href = '/Account/Login';
                return;
            }

            try {
                btn.style.pointerEvents = 'none';
                btn.style.opacity = '0.7';

                const response = await fetch(`http://localhost:5207/api/Wishlist/toggle/${courseId}`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${currentToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                if (response.ok) {
                    const result = await response.json();
                    const icon = btn.querySelector('.material-symbols-outlined');
                    
                    if (result.isInWishlist) {
                        btn.classList.remove('text-slate-400', 'text-slate-700');
                        btn.classList.add('text-red-500');
                        if (icon) {
                            icon.style.fontVariationSettings = "'FILL' 1";
                            icon.classList.remove('text-slate-400');
                            icon.classList.add('text-red-500');
                        }
                        const textSpan = btn.querySelector('.wishlist-text');
                        if (textSpan) textSpan.innerText = "Saved to Wishlist";
                    } else {
                        btn.classList.remove('text-red-500');
                        const textSpan = btn.querySelector('.wishlist-text');
                        if (textSpan) {
                            btn.classList.add('text-slate-700');
                            textSpan.innerText = "Add to Wishlist";
                            if (icon) {
                                icon.classList.remove('text-red-500');
                                icon.classList.add('text-slate-400');
                            }
                        } else {
                            btn.classList.add('text-slate-400');
                        }
                        if (icon) icon.style.fontVariationSettings = "'FILL' 0";

                        if (window.location.pathname.toLowerCase() === '/wishlist') {
                            const card = btn.closest('.group');
                            if (card) {
                                card.style.transition = 'all 0.3s ease';
                                card.style.opacity = '0';
                                card.style.transform = 'scale(0.9)';
                                setTimeout(() => card.remove(), 300);
                            }
                        }
                    }
                } else if (response.status === 401) {
                    window.location.href = '/Account/Login';
                } else {
                    console.error('Failed to toggle wishlist:', response.statusText);
                }
            } catch (error) {
                console.error('Error toggling wishlist:', error);
            } finally {
                btn.style.pointerEvents = 'auto';
                btn.style.opacity = '1';
            }
        }

        window.addEventListener('unhandledrejection', function(event) {
            if (event.reason === undefined) {
                console.warn('Caught undefined promise rejection.');
                event.preventDefault();
            }
        });
        // ----------------------------------------

        // ★ Decode AccountId from JWT token (more reliable than cookie)
        function getAccountIdFromJwt(jwt) {
            try {
                if (!jwt) return 0;
                const payload = JSON.parse(atob(jwt.split('.')[1]));
                const sid = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier']
                         ?? payload['sub'] ?? payload['nameid'] ?? 0;
                return parseInt(sid, 10) || 0;
            } catch(e) { return 0; }
        }

        const cookieUserId = parseInt(`@Html.Raw(Context.Request.Cookies["UserId"] ?? "0")`.trim(), 10) || 0;
        const currentUserId = getAccountIdFromJwt(currentToken) || cookieUserId;
        console.log('[MiniChat] currentUserId =', currentUserId);

        function getMiniSenderId(m) {
            const v = m.senderId ?? m.SenderId;
            const n = Number(v);
            return Number.isFinite(n) ? n : NaN;
        }

        function getMiniSenderName(m) {
            return m.senderName ?? m.SenderName ?? m.fullName ?? m.FullName ?? "User";
        }
        
        let miniChatId = null;
        let miniChatConn = null;

        // 2. Logic cho Support Popup (Mini Chat)
        function toggleSupportPopup() {
            const popup = document.getElementById('support-chat-popup');
            if (!popup) return;
            const isVisible = popup.style.display === 'flex';
            popup.style.display = isVisible ? 'none' : 'flex';
            
            if (!isVisible) {
                const badge = document.getElementById('global-chat-badge');
                if (badge) badge.style.display = 'none';
                initMiniChat();
            }
        }

        async function initMiniChat() {
            if (!currentToken) {
                window.location.href = "/Account/Login";
                return;
            }
            if (miniChatId) return;

            try {
                // Ensure SignalR connection is ready
                if (!miniChatConn || miniChatConn.state !== signalR.HubConnectionState.Connected) {
                    console.log("[MiniChat] Waiting for connection...");
                    await new Promise(resolve => {
                        const interval = setInterval(() => {
                            if (miniChatConn && miniChatConn.state === signalR.HubConnectionState.Connected) {
                                clearInterval(interval);
                                resolve();
                            }
                        }, 500);
                        setTimeout(() => { clearInterval(interval); resolve(); }, 5000); // Timeout 5s
                    });
                }

                // Get support staff ID
                const staffRes = await fetch("http://localhost:5207/api/chat/support-account", {
                    headers: { 'Authorization': `Bearer ${currentToken}` }
                });
                
                if (!staffRes.ok) {
                    const errorContainer = document.getElementById('mini-chat-content');
                    if (errorContainer) {
                        errorContainer.innerHTML = '<div class="text-center p-4 text-red-500 text-sm mt-4">Unable to connect to support.</div>';
                    }
                    return;
                }
                
                const staff = await staffRes.json();
                
                if (!staff || !staff.accountId) {
                    const errorContainer = document.getElementById('mini-chat-content');
                    if (errorContainer) {
                        errorContainer.innerHTML = '<div class="text-center p-4 text-red-500 text-sm mt-4">Unable to connect to support.</div>';
                    }
                    return;
                }
                
                document.getElementById('support-name').innerText = staff.fullName || 'Support Team';
                if (staff.avatarUrl) {
                    const img = document.getElementById('support-avatar');
                    img.src = staff.avatarUrl;
                    img.classList.remove('hidden');
                    document.getElementById('support-icon').classList.add('hidden');
                }
                
                // Create/Get chat room
                const createRes = await fetch("http://localhost:5207/api/chat/create", {
                    method: 'POST',
                    headers: { 
                        'Authorization': `Bearer ${currentToken}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ targetAccountId: staff.accountId, contextType: 'system' })
                });
                
                if (!createRes.ok) {
                    const errorData = await createRes.json();
                    console.error("Create chat error", errorData);
                    const errorContainer = document.getElementById('mini-chat-content');
                    if (errorContainer) {
                        errorContainer.innerHTML = `<div class="text-center p-4 text-red-500 text-sm mt-4">${errorData.message || 'Unable to connect to support.'}</div>`;
                    }
                    return;
                }
                
                const chatData = await createRes.json();
                miniChatId = chatData.chatId;

                // Join SignalR group
                if (miniChatConn && miniChatConn.state === signalR.HubConnectionState.Connected) {
                    await miniChatConn.invoke("JoinChat", miniChatId);
                }

                await loadMiniHistory();
            } catch (err) {
                console.error("Init mini chat error:", err);
                document.getElementById('mini-chat-content').innerHTML = `<div class="text-center py-4 text-xs text-red-500">Unable to connect to support.</div>`;
            }
        }

        async function loadMiniHistory() {
            if (!miniChatId) return;
            try {
                const res = await fetch(`http://localhost:5207/api/chat/history?roomId=${miniChatId}`, {
                    headers: { 'Authorization': `Bearer ${currentToken}` }
                });
                const msgs = await res.json();
                const container = document.getElementById('mini-chat-content');
                let html = '';
                const staffName = document.getElementById('support-name').innerText;
                
                if (msgs.length === 0) {
                    html += `
                        <div class="flex flex-col w-fit max-w-[85%] self-start relative z-10 mb-1 mt-2">
                            <div class="text-[10px] font-bold text-slate-400 mb-1 px-1 text-left">${staffName}</div>
                            <div class="text-[13.5px] px-4 py-2.5 rounded-2xl leading-relaxed shadow-sm bg-white border border-slate-100 text-slate-700 rounded-bl-sm">
                                Hello! 👋 Thanks for reaching out. How can we help you today?
                            </div>
                        </div>
                        <div class="flex flex-wrap gap-2 mb-4" id="quick-replies">
                            <button onclick="sendQuickReply('I need to ask about course content')" class="text-[12px] px-3 py-1.5 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-full hover:bg-emerald-100 transition-colors cursor-pointer">Ask about course</button>
                            <button onclick="sendQuickReply('I encountered a payment error')" class="text-[12px] px-3 py-1.5 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-full hover:bg-emerald-100 transition-colors cursor-pointer">Payment error</button>
                            <button onclick="sendQuickReply('I need more advice')" class="text-[12px] px-3 py-1.5 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-full hover:bg-emerald-100 transition-colors cursor-pointer">Need advice</button>
                        </div>`;
                }

                html += msgs.map(m => {
                    const sid = getMiniSenderId(m);
                    const isMe = sid === currentUserId && currentUserId > 0;
                    const name = getMiniSenderName(m);
                    return `
                        <div class="flex flex-col w-fit max-w-[85%] ${isMe ? 'self-end' : 'self-start'} relative z-10 mb-1">
                            <div class="text-[10px] font-bold text-slate-400 mb-1 px-1 ${isMe ? 'text-right' : 'text-left'}">${isMe ? 'You' : name}</div>
                            <div class="text-[13.5px] px-4 py-2.5 rounded-2xl leading-relaxed shadow-sm ${isMe ? 'bg-gradient-to-br from-emerald-600 to-emerald-500 text-white rounded-br-sm' : 'bg-white border border-slate-100 text-slate-700 rounded-bl-sm'}">${m.content}</div>
                        </div>`;
                }).join('');
                
                html += `
                    <div id="typing-indicator" class="hidden flex-col w-fit max-w-[85%] self-start relative z-10 mt-1">
                        <div class="text-[10px] font-bold text-slate-400 mb-1 px-1 text-left" id="typing-name">${staffName}</div>
                        <div class="px-4 py-3 rounded-2xl bg-white border border-slate-100 rounded-bl-sm shadow-sm flex items-center gap-1 h-[36px]">
                            <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0s"></div>
                            <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0.15s"></div>
                            <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0.3s"></div>
                        </div>
                    </div>`;
                    
                container.innerHTML = html;
                container.scrollTop = container.scrollHeight;
            } catch (err) {
                console.error("Load mini history error:", err);
            }
        }

        window.sendQuickReply = async function(text) {
            const input = document.getElementById('mini-chat-input');
            input.value = text;
            await sendMiniMsg();
            const qr = document.getElementById('quick-replies');
            if (qr) qr.style.display = 'none';
        };

        let typingTimeout;
        window.handleInputTyping = function() {
            if (!miniChatConn || !miniChatId) return;
            miniChatConn.invoke("Typing", miniChatId, true).catch(e => console.error(e));
            clearTimeout(typingTimeout);
            typingTimeout = setTimeout(() => {
                if (miniChatConn.state === signalR.HubConnectionState.Connected) {
                    miniChatConn.invoke("Typing", miniChatId, false).catch(e => console.error(e));
                }
            }, 2000);
        };

        async function sendMiniMsg() {
            const input = document.getElementById('mini-chat-input');
            const content = input.value.trim();
            if (!content || !miniChatId || !miniChatConn) return;

            try {
                await miniChatConn.invoke("SendMessage", {
                    chatId: miniChatId,
                    content: content
                });
                input.value = "";
                miniChatConn.invoke("Typing", miniChatId, false).catch(e=>console.error(e));
            } catch (err) {
                console.error("Send mini msg error:", err);
            }
        }

        function appendMiniMsg(m) {
            const container = document.getElementById('mini-chat-content');
            if (!container) return;
            const sid = getMiniSenderId(m);
            const isMe = sid === currentUserId && currentUserId > 0;
            const name = getMiniSenderName(m);
            const html = `
                <div class="flex flex-col w-fit max-w-[85%] ${isMe ? 'self-end' : 'self-start'} relative z-10 mb-1">
                    <div class="text-[10px] font-bold text-slate-400 mb-1 px-1 ${isMe ? 'text-right' : 'text-left'}">${isMe ? 'You' : name}</div>
                    <div class="text-[13.5px] px-4 py-2.5 rounded-2xl leading-relaxed shadow-sm ${isMe ? 'bg-gradient-to-br from-emerald-600 to-emerald-500 text-white rounded-br-sm' : 'bg-white border border-slate-100 text-slate-700 rounded-bl-sm'}">${m.content}</div>
                </div>`;
            const indicator = document.getElementById('typing-indicator');
            if (indicator) {
                indicator.insertAdjacentHTML('beforebegin', html);
            } else {
                container.insertAdjacentHTML('beforeend', html);
            }
            container.scrollTop = container.scrollHeight;
        }

        // 3. Notifications & Global SignalR logic
        function timeSince(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return "Just now";
            const interval = Math.floor(seconds / 60);
            if (interval < 60) return interval + " minutes ago";
            const hours = Math.floor(interval / 60);
            if (hours < 24) return hours + " hours ago";
            return date.toLocaleDateString('en-US');
        }

        async function loadTopNotifications() {
            const container = document.getElementById('notification-items-container');
            const badge = document.getElementById('noti-badge');
            if (!container || !currentToken) return;

            try {
                const response = await fetch("http://localhost:5207/api/Notification", {
                    headers: { 'Authorization': `Bearer ${currentToken}` }
                });
                if (response.ok) {
                    const result = await response.json();
                    const notifications = Array.isArray(result) ? result : (result.data || []);
                    const hasUnread = notifications.some(n => n.isRead === false);
                    if (badge) hasUnread ? badge.classList.remove('hidden') : badge.classList.add('hidden');

                    const top3 = notifications.slice(0, 3);
                    if (top3.length === 0) {
                        container.innerHTML = `<div class="px-4 py-8 text-center text-slate-400 text-sm italic">No new notifications</div>`;
                        return;
                    }
                    container.innerHTML = top3.map(n => `
                        <div class="p-4 border-b border-slate-50 hover:bg-emerald-50/50 transition-all cursor-pointer" onclick="location.href='${n.linkAction ? n.linkAction : '/Notification'}'">
                            <p class="text-xs font-bold text-slate-800 truncate">${n.title}</p>
                            <p class="text-[11px] text-slate-500 mt-1 line-clamp-2">${n.content}</p>
                            <p class="text-[9px] text-slate-300 mt-2 uppercase font-bold">${timeSince(new Date(n.createdAt))}</p>
                        </div>
                    `).join('');
                }
            } catch (err) { console.error("Noti error:", err); }
        }

        document.addEventListener("DOMContentLoaded", () => {
            loadTopNotifications();
            
            if (currentToken) {
                // SignalR Noti
                const notiConn = new signalR.HubConnectionBuilder()
                    .withUrl("http://localhost:5207/notificationHub", { accessTokenFactory: () => currentToken })
                    .withAutomaticReconnect().build();
                notiConn.on("ReceiveNotification", () => loadTopNotifications());
                notiConn.on("UpdateWishlistCount", () => {
                    if (typeof updateWishlistBadge === 'function') {
                        updateWishlistBadge();
                    }
                });
                notiConn.start().catch(err => console.error("Noti Hub Error", err));

                // SignalR Chat
                miniChatConn = new signalR.HubConnectionBuilder()
                    .withUrl("http://localhost:5207/chatHub", { accessTokenFactory: () => currentToken })
                    .withAutomaticReconnect().build();

                miniChatConn.on("ReceiveMessage", function (message) {
                    const popup = document.getElementById('support-chat-popup');
                    const msgChatId = message.chatId ?? message.ChatId;
                    if (popup && popup.style.display === 'flex' && msgChatId == miniChatId) {
                        appendMiniMsg(message);
                    } else if (window.location.pathname.toLowerCase() !== "/chat") {
                        const chatBadge = document.getElementById('global-chat-badge');
                        if (chatBadge) {
                            chatBadge.style.display = 'block';
                            const current = parseInt(chatBadge.innerText || "0");
                            chatBadge.innerText = current + 1;
                        }
                        const bubble = document.getElementById('unread-preview-bubble');
                        const previewContent = document.getElementById('preview-content');
                        if (bubble && previewContent && document.getElementById('support-chat-popup').style.display !== 'flex') {
                            previewContent.innerText = message.content;
                            bubble.classList.remove('hidden');
                            bubble.classList.add('block');
                            setTimeout(() => {
                                bubble.classList.add('hidden');
                                bubble.classList.remove('block');
                            }, 5000);
                        }
                    }
                });

                miniChatConn.on("UserTyping", function(data) {
                    if (data.chatId == miniChatId && data.accountId !== currentUserId) {
                        const indicator = document.getElementById('typing-indicator');
                        if (indicator) {
                            if (data.isTyping) {
                                document.getElementById('typing-name').innerText = data.name || "Support Team";
                                indicator.classList.remove('hidden');
                                indicator.classList.add('flex');
                                const container = document.getElementById('mini-chat-content');
                                container.scrollTop = container.scrollHeight;
                            } else {
                                indicator.classList.add('hidden');
                                indicator.classList.remove('flex');
                            }
                        }
                    }
                });

                miniChatConn.start().then(() => {
                    fetch("http://localhost:5207/api/chat/unread-count", {
                        headers: { 'Authorization': `Bearer ${currentToken}` }
                    }).then(res => res.json()).then(data => {
                        if (data.count > 0 && window.location.pathname.toLowerCase() !== "/chat") {
                            const b = document.getElementById('global-chat-badge');
                            if (b) { b.style.display = 'block'; b.innerText = data.count; }
                        }
                    });
                }).catch(err => console.error("Chat Hub Error", err));
            }
        });
    </script>
</body>
</html>