        async function updateCartButtons() {
            if (typeof currentToken === 'undefined' || !currentToken) return;

            try {
                const res = await fetch('http://localhost:5207/api/cart/summary', {
                    headers: { 'Authorization': `Bearer ${currentToken}` }
                });
                if (!res.ok) return;

                const result = await res.json();
                const items = result?.data?.items ?? [];
                const cartCourseIds = items.map(item => item.courseId);

                const allButtons = document.querySelectorAll('button[onclick*="addToCart"]');
                allButtons.forEach(btn => {
                    const onclickText = btn.getAttribute('onclick') || '';
                    const match = onclickText.match(/addToCart\(\s*(\d+)/);
                    if (match && match[1]) {
                        const courseId = parseInt(match[1]);
                        if (cartCourseIds.includes(courseId)) {
                            btn.title = "Already in cart";
                            
                            // Check if this is the large button (e.g. Details page)
                            if (btn.classList.contains('w-full') || btn.innerText.toLowerCase().includes('add to cart')) {
                                btn.className = "w-full bg-emerald-600 text-white font-bold py-3 rounded-lg hover:bg-emerald-700 transition-all flex items-center justify-center gap-2 decoration-none border-0";
                                btn.innerHTML = '<span class="material-symbols-outlined text-[20px]">check_circle</span> Go to Cart';
                                btn.onclick = function(e) {
                                    e.stopPropagation();
                                    e.preventDefault();
                                    showAlreadyInCartPopup();
                                };
                            } else {
                                // Small round button
                                btn.className = "w-10 h-10 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center shadow-sm z-20 transition-all duration-300";
                                // Check if it's the smaller 9x9 button from Course Catalog
                                if (btn.classList.contains('w-9') || btn.classList.contains('h-9')) {
                                    btn.className = "w-9 h-9 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100 z-20 transition-all duration-300";
                                }
                                btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">check</span>';
                                btn.onclick = function(e) {
                                    e.stopPropagation();
                                    e.preventDefault();
                                    showAlreadyInCartPopup();
                                };
                            }
                        } else {
                            // Restore original if it was checked
                            if (btn.classList.contains('bg-emerald-100') || btn.classList.contains('bg-emerald-50') || btn.classList.contains('bg-emerald-600')) {
                                if (btn.classList.contains('w-full')) {
                                    btn.className = "w-full bg-primary text-white font-bold py-3 rounded-lg hover:opacity-90 transition-all flex items-center justify-center gap-2";
                                    btn.innerHTML = '<span class="material-symbols-outlined text-[20px]">add_shopping_cart</span> Add to cart';
                                    btn.onclick = function(e) {
                                        addToCart(courseId, btn);
                                    };
                                } else {
                                    if (btn.classList.contains('w-9')) {
                                        btn.className = "w-9 h-9 rounded-full bg-slate-50 text-slate-500 flex items-center justify-center hover:bg-primary hover:text-white hover:scale-110 active:scale-95 border border-slate-200/60 hover:border-primary shadow-sm transition-all ease-out-expo duration-200 z-20";
                                        btn.innerHTML = '<span class="material-symbols-outlined text-[17px]" style=\'font-variation-settings:"FILL" 1;\'>add_shopping_cart</span>';
                                    } else {
                                        btn.className = "w-10 h-10 rounded-full bg-slate-50 text-slate-500 flex items-center justify-center hover:bg-primary hover:text-white hover:scale-110 active:scale-95 shadow-sm transition-all duration-300 z-20";
                                        btn.innerHTML = '<span class="material-symbols-outlined text-[18px]" style=\'font-variation-settings:"FILL" 1;\'>add_shopping_cart</span>';
                                    }
                                    btn.title = "Add to cart";
                                    btn.onclick = function(e) {
                                        e.stopPropagation();
                                        addToCart(courseId, btn);
                                    };
                                }
                            }
                        }
                    }
                });
            } catch (err) {
                console.error("Error updating cart buttons:", err);
            }
        }
        window.updateCartButtons = updateCartButtons;

        window.addEventListener('unhandledrejection', function(event) {
