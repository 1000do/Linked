@{
   
    var tokenForLayout = Context.Request.Cookies["AuthToken"]
                         ?? Context.Request.Cookies[".AspNetCore.Identity.Application"];
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
	<!-- cloudinary -->
	<link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="dns-prefetch" href="https://res.cloudinary.com">

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#006a62",
                        "primary-container": "#43e8d8",
                        "on-primary": "#ffffff",
                        "secondary": "#006b60",
                        "surface": "#f0fcfb",
                        "on-surface": "#131d1e",
                        "surface-container-low": "#eaf6f5",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"]
                    }
                }
            }
        }
    </script>
    <script>
        
        const LAYOUT_TOKEN = '@tokenForLayout';
    </script>
    

    <style>
        .glass-nav {
            backdrop-filter: blur(12px);
        }

        .hero-gradient {
            background: linear-gradient(135deg, #006a62 0%, #43e8d8 100%);
        }
    </style>
</head>

<body class="bg-surface font-body text-on-surface antialiased">

    <!-- HEADER -->
    @await Html.PartialAsync("_Header")

    <!-- CONTENT -->
    <main role="main" class="pt-20">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    @await Html.PartialAsync("_Footer")

    <!-- CHAT BUTTON -->
    <div class="fixed bottom-6 right-6 z-[100] group">
        <span class="absolute right-full mr-3 top-1/2 -translate-y-1/2 px-3 py-1.5 bg-slate-800 text-white text-xs font-bold rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
            Chat với hỗ trợ viên
        </span>

        <button class="w-14 h-14 bg-primary-container text-primary rounded-2xl shadow-2xl shadow-primary/30 flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-300 relative">
            <span class="material-symbols-outlined text-[28px]" style='font-variation-settings: "FILL" 1;'>
                chat_bubble
            </span>

            <span class="absolute -top-1 -right-1 w-5 h-5 bg-orange-500 text-white text-[10px] font-bold flex items-center justify-center rounded-full border-2 border-surface">
                1
            </span>
        </button>
    </div>
   

    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>


            const connection = new signalR.HubConnectionBuilder()
        .withUrl("http://localhost:5207/notificationHub", {
            
            accessTokenFactory: () => LAYOUT_TOKEN
        })
        .withAutomaticReconnect()
        .build();

                // Trong _Layout.cshtml
        connection.on("ReceiveNotification", function (noti) {
            // 1. Luôn cập nhật chuông và popup ở Header (nếu có)
            const badge = document.getElementById('noti-badge');
            if(badge) badge.classList.remove('hidden');
            if (typeof loadTopNotifications === "function") loadTopNotifications();

            // 2. Tự động cập nhật trang danh sách (NẾU ĐANG Ở TRANG ĐÓ)
            const path = window.location.pathname.toLowerCase();

            // Kiểm tra nếu đang ở trang Admin
            if (path.includes("/notification/admin")) {
                if (typeof loadAdminHistory === "function") {
                    console.log("SignalR: Đang cập nhật lịch sử Admin...");
                    loadAdminHistory();
                }
            }
            // Kiểm tra nếu đang ở trang Thông báo cá nhân
            else if (path.includes("/notification")) {
                if (typeof loadNotifications === "function") {
                    console.log("SignalR: Đang cập nhật danh sách User...");
                    loadNotifications();
                }
            }
        });

        connection.start().catch(err => console.error("SignalR Error: ", err));

        // 3. Hàm lấy dữ liệu Top 3
        async function loadTopNotifications() {
            const container = document.getElementById('notification-items-container');
            if (!container) return;

            if (!LAYOUT_TOKEN || LAYOUT_TOKEN === "") {
                container.innerHTML = `<div class="p-4 text-center text-xs text-slate-400">Vui lòng đăng nhập</div>`;
                return;
            }

            try {
                const response = await fetch("http://localhost:5207/api/Notification", {
                    headers: { 'Authorization': `Bearer ${LAYOUT_TOKEN}` }
                });

                if (response.ok) {
                    const data = await response.json();
                    // Chỉ lấy 3 cái mới nhất
                    const top3 = data.slice(0, 3);

                    if (top3.length === 0) {
                        container.innerHTML = `<div class="px-4 py-8 text-center text-slate-400 text-sm">Không có thông báo mới</div>`;
                        return;
                    }
                                   container.innerHTML = top3.map(n => `
            <div class="p-4 border-b border-slate-50 hover:bg-slate-50 transition-colors cursor-pointer"
                 onclick="location.href='/Notification'">
                <div class="flex gap-3">
                    <div class="flex-1">
                        <div class="flex items-center gap-2">
                            ${!n.isRead ? '<span class="w-2 h-2 bg-primary rounded-full shrink-0"></span>' : ''}
                            <p class="text-xs font-bold text-slate-800 truncate">${n.title}</p>
                        </div>
                        <p class="text-[11px] text-slate-500 mt-1 line-clamp-2">${n.content}</p>
                        <div class="flex justify-between items-center mt-2">
                            <p class="text-[9px] text-slate-300 uppercase font-medium">
                                ${new Date(n.createdAt).toLocaleTimeString('vi-VN')}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        `).join('');
        }
            } catch (err) {
                console.error("Fetch error:", err);
                container.innerHTML = `<div class="p-4 text-center text-xs text-red-400">Lỗi kết nối máy chủ</div>`;
            }
        }

        // Tự động chạy khi load trang
        document.addEventListener("DOMContentLoaded", loadTopNotifications);
    </script>

</body>
</html>