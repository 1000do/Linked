@{
   
    var tokenForLayout = Context.Request.Cookies["AccessToken"]
                         ?? Context.Request.Cookies[".AspNetCore.Identity.Application"];
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
	<!-- cloudinary -->
	<link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="dns-prefetch" href="https://res.cloudinary.com">

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#006a62",
                        "primary-container": "#43e8d8",
                        "on-primary": "#ffffff",
                        "secondary": "#006b60",
                        "surface": "#f0fcfb",
                        "on-surface": "#131d1e",
                        "surface-container-low": "#eaf6f5",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"]
                    }
                }
            }
        }
    </script>
    
    

    <style>
        .glass-nav {
            backdrop-filter: blur(12px);
        }

        .hero-gradient {
            background: linear-gradient(135deg, #006a62 0%, #43e8d8 100%);
        }
    </style>

    <!-- GOOGLE LOGIN SCRIPT -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
</head>

<body class="bg-surface font-body text-on-surface antialiased">

    <!-- HEADER -->
    @await Html.PartialAsync("_Header")

    <!-- CONTENT -->
    <main role="main" class="pt-20">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    @await Html.PartialAsync("_Footer")

    <!-- CHAT BUTTON -->
    <div class="fixed bottom-6 right-6 z-[100] group">
        <span class="absolute right-full mr-3 top-1/2 -translate-y-1/2 px-3 py-1.5 bg-slate-800 text-white text-xs font-bold rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
            Chat với hỗ trợ viên
        </span>

        <button class="w-14 h-14 bg-primary-container text-primary rounded-2xl shadow-2xl shadow-primary/30 flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-300 relative">
            <span class="material-symbols-outlined text-[28px]" style='font-variation-settings: "FILL" 1;'>
                chat_bubble
            </span>

            <span class="absolute -top-1 -right-1 w-5 h-5 bg-orange-500 text-white text-[10px] font-bold flex items-center justify-center rounded-full border-2 border-surface">
                1
            </span>
        </button>
    </div>
   

    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        // 1. Lấy token an toàn từ Server-side (Razor)

               // Dùng thêm .trim() để đảm bảo chuỗi sạch
        const currentToken = `@Html.Raw(tokenForLayout ?? "")`.trim();

        // Hàm bổ trợ tính thời gian
        function timeSince(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return "Vừa xong";
            const interval = Math.floor(seconds / 60);
            if (interval < 60) return interval + " phút trước";
            const hours = Math.floor(interval / 60);
            if (hours < 24) return hours + " giờ trước";
            return date.toLocaleDateString('vi-VN');
        }

        // 2. Hàm load danh sách thông báo và cập nhật giao diện
        async function loadTopNotifications() {
            const container = document.getElementById('notification-items-container');
            const badge = document.getElementById('noti-badge');
            if (!container) return;

            // Nếu không có token, báo đăng nhập
            if (!currentToken || currentToken === "") {
                container.innerHTML = `<div class="p-4 text-center text-xs text-slate-400">Vui lòng đăng nhập</div>`;
                if (badge) badge.classList.add('hidden');
                return;
            }

            try {
                const response = await fetch("http://localhost:5207/api/Notification", {
                    method: 'GET',
                    headers: {
                        'Authorization': `Bearer ${currentToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                   if (response.ok) {
        const result = await response.json();

        // Kiểm tra: nếu result là mảng thì dùng luôn, nếu là object có .data thì lấy .data
        const notifications = Array.isArray(result) ? result : (result.data || []);

        // 1. Cập nhật chấm đỏ
        const hasUnread = notifications.some(n => n.isRead === false);
        if (badge) {
            if (hasUnread) badge.classList.remove('hidden');
            else badge.classList.add('hidden');
        }

        // 2. Lấy Top 3 để hiện dropdown
        const top3 = notifications.slice(0, 3);
        if (top3.length === 0) {
            container.innerHTML = `<div class="px-4 py-8 text-center text-slate-400 text-sm italic">Không có thông báo mới</div>`;
            return;
        }

                    container.innerHTML = top3.map(n => `
                        <div class="p-4 border-b border-slate-50 hover:bg-emerald-50/50 transition-all cursor-pointer"
                             onclick="location.href='/Notification'">
                            <div class="flex gap-3">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2">
                                        ${!n.isRead ? '<span class="w-1.5 h-1.5 bg-primary rounded-full shrink-0"></span>' : ''}
                                        <p class="text-xs font-bold text-slate-800 truncate">${n.title}</p>
                                    </div>
                                    <p class="text-[11px] text-slate-500 mt-1 line-clamp-2 leading-relaxed">${n.content}</p>
                                    <div class="flex justify-between items-center mt-2">
                                        <p class="text-[9px] text-slate-300 font-bold uppercase tracking-wider">
                                            ${timeSince(new Date(n.createdAt))}
                                        </p>
                                        ${!n.isRead ? '<span class="text-[9px] text-primary font-bold">Mới</span>' : ''}
                                    </div>
                                </div>
                            </div>
                        </div>
                    `).join('');
                } else {
                    console.error("API trả lỗi:", response.status);
                }
            } catch (err) {
                console.error("Lỗi fetch:", err);
                container.innerHTML = `<div class="p-4 text-center text-xs text-red-400">Lỗi đồng bộ dữ liệu</div>`;
            }
        }

        // 3. Khởi tạo SignalR (Dùng luôn currentToken đã lấy ở trên)
        if (currentToken) {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("http://localhost:5207/notificationHub", {
                    accessTokenFactory: () => currentToken // Dùng trực tiếp biến const
                })
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveNotification", function (noti) {
                loadTopNotifications();
                if (typeof loadHistory === "function") loadHistory();
                if (typeof loadNotifications === "function") loadNotifications();
            });

            connection.start().catch(err => console.error("SignalR Error: ", err));
        }

        // Wishlist Toggle AJAX
        async function toggleWishlist(btn, courseId) {
            if (!currentToken || currentToken === "") {
                window.location.href = "/Account/Login";
                return;
            }

            try {
                // Thêm hiệu ứng loading
                const icon = btn.querySelector('.material-symbols-outlined');
                const originalFill = icon.style.fontVariationSettings;
                btn.style.pointerEvents = 'none';
                btn.style.opacity = '0.5';

                const response = await fetch(`/Wishlist/ToggleAjax?courseId=${courseId}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        // Cập nhật UI
                        const textEl = btn.querySelector('.wishlist-text');
                        if (result.isInWishlist) {
                            btn.classList.remove('text-slate-400', 'text-slate-700');
                            btn.classList.add('text-red-500');
                            icon.style.fontVariationSettings = '"FILL" 1';
                            if (textEl) textEl.textContent = "Saved to Wishlist";
                        } else {
                            btn.classList.remove('text-red-500');
                            btn.classList.add('text-slate-400', 'text-slate-700');
                            icon.style.fontVariationSettings = '"FILL" 0';
                            if (textEl) textEl.textContent = "Add to Wishlist";
                        }
                        
                        // Nếu đang ở trang wishlist mà xóa thì ẩn item đó luôn
                        if (window.location.pathname.toLowerCase() === "/wishlist") {
                            const card = btn.closest('.group');
                            if (card) {
                                card.style.opacity = '0';
                                setTimeout(() => card.remove(), 300);
                            }
                        }
                    }
                }
            } catch (err) {
                console.error("Wishlist error:", err);
            } finally {
                btn.style.pointerEvents = 'auto';
                btn.style.opacity = '1';
            }
        }

        // Chạy khi load trang
        document.addEventListener("DOMContentLoaded", loadTopNotifications);
    </script>
</body>
</html>