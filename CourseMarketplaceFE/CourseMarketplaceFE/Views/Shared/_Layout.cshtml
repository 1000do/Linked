                        }
                    }).then((res) => {
                        if (res.isConfirmed) {
                            window.location.href = '/Course/Learn/' + courseId;
                        } else {
                            window.location.reload();
                        }
                    });
                } else {
                    Swal.fire({
                        title: 'Enrollment Failed',
