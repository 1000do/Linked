@using System.Security.Claims
@{
   
    var tokenForLayout = Context.Request.Cookies["AccessToken"]
                         ?? Context.Request.Cookies[".AspNetCore.Identity.Application"];
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/img/default-avatar.png" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
	<!-- cloudinary -->
	<link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="dns-prefetch" href="https://res.cloudinary.com">

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#006a62",
                        "primary-container": "#43e8d8",
                        "on-primary": "#ffffff",
                        "secondary": "#006b60",
                        "surface": "#f0fcfb",
                        "on-surface": "#131d1e",
                        "surface-container-low": "#eaf6f5",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"]
                    }
                }
            }
        }
    </script>
    
    

    <style>
        .fill-1 {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .glass-nav {
            backdrop-filter: blur(12px);
        }

        .hero-gradient {
            background: linear-gradient(135deg, #006a62 0%, #43e8d8 100%);
        }

        /* Floating Chat Button - Emerald Style */
        .floating-chat-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 56px;
            height: 56px;
            background: #059669; /* Emerald 600 */
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(5, 150, 105, 0.4);
            cursor: pointer;
            z-index: 1000;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: none;
        }

        .floating-chat-btn:hover {
            transform: scale(1.1) rotate(5deg);
            background: #047857;
        }

        /* Support Popup */
        .support-popup {
            position: fixed;
            bottom: 100px;
            right: 30px;
            width: 360px;
            height: 500px;
            z-index: 1001;
            display: none;
            flex-direction: column;
            animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @@keyframes slideUp {
            from { transform: translateY(30px) scale(0.95); opacity: 0; }
            to { transform: translateY(0) scale(1); opacity: 1; }
        }

        /* Minimal scrollbar for chat */
        .chat-scroll::-webkit-scrollbar {
            width: 6px;
        }
        .chat-scroll::-webkit-scrollbar-track {
            background: transparent;
        }
        .chat-scroll::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 10px;
        }

        .chat-badge {
            position: absolute;
            top: -2px;
            right: -2px;
            background: #ef4444;
            color: white;
            font-size: 10px;
            font-weight: bold;
            padding: 2px 6px;
            border-radius: 10px;
            border: 2px solid white;
        }
        /* Avatar Frames System */
        .avatar-container {
            position: relative;
            display: inline-block;
            padding: 4px; /* Space for the frame */
        }
        
        .avatar-frame {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: inherit;
            pointer-events: none;
            z-index: 1;
        }

        /* Admin Frame: Golden Animated Glow */
        .frame-admin {
            border: 3px solid transparent;
            background: linear-gradient(white, white) padding-box,
                        linear-gradient(45deg, #f59e0b, #fbbf24, #d97706, #f59e0b) border-box;
            background-size: 200% 200%;
            animation: frame-rotate 3s linear infinite;
            box-shadow: 0 0 15px rgba(245, 158, 11, 0.4);
            border-radius: 2rem;
        }

        /* Staff Frame: Indigo Pulsing Glow */
        .frame-staff {
            border: 3px solid #6366f1;
            animation: frame-pulse-indigo 2s ease-in-out infinite;
            border-radius: 2rem;
        }

        /* Instructor Frame: Emerald Pulsing Glow */
        .frame-instructor {
            border: 3px solid #10b981;
            animation: frame-pulse-emerald 2s ease-in-out infinite;
            border-radius: 2rem;
        }

        /* Learner Frame: Static Teal Border */
        .frame-learner {
            border: 3px solid #2dd4bf;
            border-radius: 2rem;
            box-shadow: 0 2px 8px rgba(45, 212, 191, 0.2);
        }

        @@keyframes frame-rotate {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @@keyframes frame-pulse-indigo {
            0% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(99, 102, 241, 0); }
            100% { box-shadow: 0 0 0 0 rgba(99, 102, 241, 0); }
        }

        @@keyframes frame-pulse-emerald {
            0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
            100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }
    </style>

    <!-- GOOGLE LOGIN SCRIPT -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Prevent SweetAlert from altering the body height/padding, which breaks the fixed layout
        window.Swal = window.Swal.mixin({
            heightAuto: false,
            scrollbarPadding: false
        });
    </script>

    @await RenderSectionAsync("Styles", required: false)
</head>

