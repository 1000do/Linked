    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        // 1. Initialize global variables
        const currentToken = `@Html.Raw(Context.Request.Cookies["AccessToken"] ?? "")`.trim();

        // --- GLOBAL LOGIC MOVED FROM SITE.JS ---
        async function toggleWishlist(btn, courseId) {
            if (!courseId) return;

            if (typeof currentToken === 'undefined' || !currentToken) {
                Swal.fire({
                    title: 'Login Required',
                    text: 'You need to log in to save this course to your wishlist.',
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: 'Log In Now',
                    cancelButtonText: 'Later',
                    confirmButtonColor: '#006a62',
                    cancelButtonColor: '#64748b',
                    background: '#ffffff',
                    customClass: {
                        popup: 'rounded-[2rem] border border-slate-100 p-8 shadow-2xl',
                        title: 'text-xl font-black text-slate-900 tracking-tight',
                        confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all bg-primary hover:bg-emerald-700',
                        cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                    }
                }).then((res) => {
                    if (res.isConfirmed) {
                        window.location.href = '/Account/Login';
                    }
                });
                return;
            }

            try {
                btn.style.pointerEvents = 'none';
                btn.style.opacity = '0.7';

                const response = await fetch(`http://localhost:5207/api/Wishlist/toggle/${courseId}`, {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${currentToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                if (response.ok) {
                    const result = await response.json();
                    const icon = btn.querySelector('.material-symbols-outlined');
                    
                    if (result.isInWishlist) {
                        btn.classList.remove('text-slate-400', 'text-slate-700');
                        btn.classList.add('text-red-500');
                        if (icon) {
                            icon.style.fontVariationSettings = "'FILL' 1";
                            icon.classList.remove('text-slate-400');
                            icon.classList.add('text-red-500');
                        }
                        const textSpan = btn.querySelector('.wishlist-text');
                        if (textSpan) textSpan.innerText = "Saved to Wishlist";

                        Swal.fire({
                            title: 'Added to Wishlist',
                            text: 'Course has been added to your wishlist.',
                            icon: 'success',
                            timer: 2000,
                            showConfirmButton: false,
                            position: 'top-end',
                            toast: true
                        });
                    } else {
                        btn.classList.remove('text-red-500');
                        const textSpan = btn.querySelector('.wishlist-text');
                        if (textSpan) {
                            btn.classList.add('text-slate-700');
                            textSpan.innerText = "Add to Wishlist";
                            if (icon) {
                                icon.classList.remove('text-red-500');
                                icon.classList.add('text-slate-400');
                            }
                        } else {
                            btn.classList.add('text-slate-400');
                        }
                        if (icon) icon.style.fontVariationSettings = "'FILL' 0";

                        Swal.fire({
                            title: 'Removed from Wishlist',
                            text: 'Course has been removed from your wishlist.',
                            icon: 'info',
                            timer: 2000,
                            showConfirmButton: false,
                            position: 'top-end',
                            toast: true
                        });

                        if (window.location.pathname.toLowerCase() === '/wishlist') {
                            const card = btn.closest('.group') || btn.closest('.course-card-custom') || btn.closest('[onclick*="/Course/Details"]');
                            if (card) {
                                card.style.transition = 'all 0.3s ease';
                                card.style.opacity = '0';
                                card.style.transform = 'scale(0.9)';
                                setTimeout(() => card.remove(), 300);
                            }
                        }
                    }
                } else if (response.status === 401) {
                    Swal.fire({
                        title: 'Login Required',
                        text: 'You need to log in to save this course to your wishlist.',
                        icon: 'info',
                        showCancelButton: true,
                        confirmButtonText: 'Log In Now',
                        cancelButtonText: 'Later',
                        confirmButtonColor: '#006a62',
                        cancelButtonColor: '#64748b',
                        background: '#ffffff',
                        customClass: {
                            popup: 'rounded-[2rem] border border-slate-100 p-8 shadow-2xl',
                            title: 'text-xl font-black text-slate-900 tracking-tight',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all bg-primary hover:bg-emerald-700',
                            cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                        }
                    }).then((res) => {
                        if (res.isConfirmed) {
                            window.location.href = '/Account/Login';
                        }
                    });
                } else {
                    console.error('Failed to toggle wishlist:', response.statusText);
                }
            } catch (error) {
                console.error('Error toggling wishlist:', error);
            } finally {
                btn.style.pointerEvents = 'auto';
                btn.style.opacity = '1';
            }
        }

        async function addToCart(courseId, btn) {
            if (!courseId) return;

            if (typeof currentToken === 'undefined' || !currentToken) {
                Swal.fire({
                    title: 'Login Required',
                    text: 'You need to log in to add this course to your cart.',
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: 'Log In Now',
                    cancelButtonText: 'Later',
                    confirmButtonColor: '#006a62',
                    cancelButtonColor: '#64748b',
                    background: '#ffffff',
                    customClass: {
                        popup: 'rounded-[2rem] border border-slate-100 p-8 shadow-2xl',
                        title: 'text-xl font-black text-slate-900 tracking-tight',
                        confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all bg-primary hover:bg-emerald-700',
                        cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                    }
                }).then((res) => { 
                    if (res.isConfirmed) {
                        window.location.href = '/Account/Login'; 
                    }
                });
                return;
            }

            let originalContent = '';
            let disabledState = false;
            if (btn) {
                originalContent = btn.innerHTML;
                disabledState = btn.disabled;
                btn.disabled = true;
                btn.innerHTML = '<span class="animate-spin material-symbols-outlined text-[18px]">sync</span>';
            }

            try {
                const response = await fetch('/Cart/AddToCartAjax/' + courseId, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                if (response.status === 401) {
                    Swal.fire({
                        title: 'Login Required',
                        text: 'Please log in to continue.',
                        icon: 'warning',
                        confirmButtonColor: '#006a62',
                        background: '#ffffff',
                        customClass: {
                            popup: 'rounded-[2rem] border border-slate-100 p-8 shadow-2xl',
                            title: 'text-xl font-black text-slate-900 tracking-tight',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all bg-primary hover:bg-emerald-700'
                        }
                    }).then(() => { 
                        window.location.href = '/Account/Login'; 
                    });
                    return;
                }

                const result = await response.json();
                if (result.success) {
                    // Dispatch global event so the header badge and header mini-dropdown updates too!
                    document.dispatchEvent(new CustomEvent('cartUpdated'));

                    Swal.fire({
                        title: 'Added Successfully!',
                        text: 'The course has been added to your cart.',
                        icon: 'success',
                        showCancelButton: true,
                        confirmButtonText: 'Go to Cart',
                        cancelButtonText: 'Continue Browsing',
                        confirmButtonColor: '#006a62',
                        cancelButtonColor: '#64748b',
                        background: '#ffffff',
                        customClass: {
                            popup: 'rounded-[2rem] border border-slate-100 p-8 shadow-2xl',
                            title: 'text-xl font-black text-slate-900 tracking-tight',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all bg-primary hover:bg-emerald-700',
                            cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                        }
                    }).then((res) => {
                        if (res.isConfirmed) {
                            window.location.href = '/Cart';
                        }
                    });
                } else {
                    Swal.fire({
                        title: 'Notification',
                        text: result.message || 'Could not add to cart.',
                        icon: 'warning',
                        confirmButtonColor: '#006a62',
                        background: '#ffffff',
                        customClass: {
                            popup: 'rounded-[2rem] border border-slate-100 p-8 shadow-2xl',
                            title: 'text-xl font-black text-slate-900 tracking-tight',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all bg-primary hover:bg-emerald-700'
                        }
                    });
                }
            } catch (error) {
                console.error('Error adding to cart:', error);
                Swal.fire({
                    title: 'Error',
                    text: 'An error occurred while adding to cart.',
                    icon: 'error',
                    confirmButtonColor: '#ef4444',
                    background: '#ffffff',
                    customClass: {
                        popup: 'rounded-[2rem] border border-slate-100 p-8 shadow-2xl',
                        title: 'text-xl font-black text-slate-900 tracking-tight',
                        confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all bg-red-600 hover:bg-red-700'
                    }
                });
            } finally {
                if (btn) {
                    btn.disabled = disabledState;
                    btn.innerHTML = originalContent;
                }
            }
        }

        async function enrollFree(courseId, btn) {
            if (!courseId) return;

            if (typeof currentToken === 'undefined' || !currentToken) {
                Swal.fire({
                    title: 'Login Required',
