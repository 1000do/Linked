        // ----------------------------------------

        // ★ Decode AccountId from JWT token (more reliable than cookie)
        function getAccountIdFromJwt(jwt) {
            try {
                if (!jwt) return 0;
                const payload = JSON.parse(atob(jwt.split('.')[1]));
                const sid = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier']
                         ?? payload['sub'] ?? payload['nameid'] ?? 0;
                return parseInt(sid, 10) || 0;
            } catch(e) { return 0; }
        }

        const cookieUserId = parseInt(`@Html.Raw(Context.Request.Cookies["UserId"] ?? "0")`.trim(), 10) || 0;
        const currentUserId = getAccountIdFromJwt(currentToken) || cookieUserId;
        console.log('[MiniChat] currentUserId =', currentUserId);

        function getMiniSenderId(m) {
            const v = m.senderId ?? m.SenderId;
            const n = Number(v);
            return Number.isFinite(n) ? n : NaN;
        }

        function getMiniSenderName(m) {
            return m.senderName ?? m.SenderName ?? m.fullName ?? m.FullName ?? "User";
        }
        
        let miniChatId = null;
        let miniChatConn = null;

        // 2. Logic cho Support Popup (Mini Chat)
        function toggleSupportPopup() {
            const popup = document.getElementById('support-chat-popup');
            if (!popup) return;
            const isVisible = popup.style.display === 'flex';
            popup.style.display = isVisible ? 'none' : 'flex';
            
            if (!isVisible) {
                const badge = document.getElementById('global-chat-badge');
                if (badge) badge.style.display = 'none';
                initMiniChat();
            }
        }

        let isWaitingForSupport = false;
        let allMiniChats = [];

        function toggleMiniChatDropdown() {
            const dd = document.getElementById('mini-chat-dropdown');
            if (dd) dd.classList.toggle('hidden');
        }

        document.addEventListener('click', (e) => {
            const btn = document.getElementById('mini-chat-selector-btn');
            const dd = document.getElementById('mini-chat-dropdown');
            if (btn && dd && !btn.contains(e.target) && !dd.contains(e.target)) {
                dd.classList.add('hidden');
            }
        });

        async function selectMiniChat(chatId, toggleDropdown = true) {
            if (toggleDropdown) toggleMiniChatDropdown();
            
            const chat = allMiniChats.find(c => c.chatId === chatId);
            if (!chat) return;

            miniChatId = chat.chatId;
            isWaitingForSupport = false;

            document.getElementById('support-name').innerText = chat.partnerName || 'Support Team';
            
            // Clear the input field when switching chats
            const inputField = document.getElementById('mini-chat-input');
            if (inputField) inputField.value = '';
            if (chat.partnerAvatar) {
                const img = document.getElementById('support-avatar');
                img.src = chat.partnerAvatar;
                img.classList.remove('hidden');
                document.getElementById('support-icon').classList.add('hidden');
            } else {
                document.getElementById('support-avatar').classList.add('hidden');
                document.getElementById('support-icon').classList.remove('hidden');
            }
            
            renderMiniChatDropdown(); // update active styling
            
            // Join SignalR group
            if (miniChatConn && miniChatConn.state === signalR.HubConnectionState.Connected) {
                try { await miniChatConn.invoke("JoinChat", miniChatId); } catch(e) {}
            }
            
            await loadMiniHistory();
        }

        function renderMiniChatDropdown() {
            const list = document.getElementById('mini-chat-list');
            if (!list) return;
            
            let html = '';
            
            if (allMiniChats.length === 0) {
                html += `<div class="p-4 text-center text-xs text-slate-500">No conversations yet</div>`;
            } else {
                html += allMiniChats.map(c => `
                    <button onclick="selectMiniChat(${c.chatId})" class="w-full text-left px-4 py-3 flex items-center gap-3 hover:bg-slate-50 transition-colors border-0 bg-transparent border-b border-slate-50 cursor-pointer ${c.chatId === miniChatId ? 'bg-emerald-50/50' : ''}">
                        <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center shrink-0 overflow-hidden">
                            ${c.partnerAvatar ? `<img src="${c.partnerAvatar}" class="w-full h-full object-cover">` : `<span class="material-symbols-outlined text-[16px] text-slate-500">support_agent</span>`}
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-center mb-0.5">
                                <h6 class="text-xs font-bold text-slate-800 m-0 truncate ${c.unreadCount > 0 ? 'text-emerald-600' : ''}">${c.partnerName || 'Support Team'}</h6>
                                ${c.unreadCount > 0 ? `<span class="w-2 h-2 bg-red-500 rounded-full"></span>` : ''}
                            </div>
                            <p class="text-[10px] text-slate-500 m-0 truncate">${c.lastMessage || (c.contextType==='system'?'Support Session':'Conversation')}</p>
                        </div>
                    </button>
                `).join('');
            }
            
            // Add a permanent button to contact support if they don't have a system chat open
            const hasSystemChat = allMiniChats.some(c => c.contextType === 'system');
            if (!hasSystemChat) {
                html += `
                    <div class="p-3 bg-slate-50 border-t border-slate-100">
                        <button onclick="startNewSupportChat()" class="w-full bg-white border border-slate-200 text-slate-600 hover:text-emerald-600 hover:border-emerald-200 hover:bg-emerald-50 px-3 py-2 rounded-lg text-[11px] font-bold transition-all flex items-center justify-center gap-2 cursor-pointer shadow-sm">
                            <span class="material-symbols-outlined text-[16px]">help</span>
                            Contact Support
                        </button>
                    </div>
                `;
            }
            
            list.innerHTML = html;
        }

        async function startNewSupportChat() {
            toggleMiniChatDropdown(); // Close dropdown
            miniChatId = null; // Clear active chat ID
            isWaitingForSupport = false;
            
            document.getElementById('support-name').innerText = 'Support Team';
            document.getElementById('support-avatar').src = '/img/default-avatar.png';
            
            // Clear the input field when switching to new support chat
            const inputField = document.getElementById('mini-chat-input');
            if (inputField) inputField.value = '';
            
            // Check for pending requests first
            try {
                const pendingRes = await fetch("/Chat/GetPendingRequests");
                if (pendingRes.ok) {
                    const pendings = await pendingRes.json();
                    if (pendings && pendings.length > 0) {
                        isWaitingForSupport = true;
                        document.getElementById('mini-chat-content').innerHTML = ''; // Clear container
                        
                        // Show the message we sent
                        appendMiniMsg({ senderId: currentUserId, content: pendings[0].initialMessage });
                        
                        // Show waiting UI
                        const waitingHtml = `
                            <div class="text-center py-6 w-full relative z-10" id="waiting-support-ui">
                                <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-3 animate-pulse">
                                    <span class="material-symbols-outlined">support_agent</span>
                                </div>
                                <p class="text-xs font-medium text-slate-500">Your request is in queue.</p>
                                <p class="text-[10px] text-slate-400">Waiting for support staff...</p>
                            </div>
                        `;
                        document.getElementById('mini-chat-content').insertAdjacentHTML('beforeend', waitingHtml);
                        return;
                    }
                }
            } catch (err) {}
            
            // Show welcome state if no pending requests
            showMiniWelcomeState();
        }

        async function initMiniChat() {
            if (!currentToken) {
                window.location.href = "/Account/Login";
                return;
            }
            
            // If already connected and have chat, do nothing
            if (miniChatId) return;

            try {
                // Ensure SignalR connection is ready
                if (!miniChatConn || miniChatConn.state !== signalR.HubConnectionState.Connected) {
                    console.log("[MiniChat] Waiting for connection...");
                    await new Promise(resolve => {
                        const interval = setInterval(() => {
                            if (miniChatConn && miniChatConn.state === signalR.HubConnectionState.Connected) {
                                clearInterval(interval);
                                resolve();
                            }
                        }, 500);
                        setTimeout(() => { clearInterval(interval); resolve(); }, 5000); // Timeout 5s
                    });
                }

                // Fetch chats via BFF Proxy
                const res = await fetch("/Chat/GetList");
                if (res.ok) {
                    const chats = await res.json();
                    allMiniChats = chats;
                    renderMiniChatDropdown();
                    
                    let targetChat = chats.find(c => c.chatId === miniChatId) || chats.find(c => c.contextType === 'system');
                    if (!targetChat && chats.length > 0) targetChat = chats[0];

                    if (targetChat) {
                        await selectMiniChat(targetChat.chatId, false);
                        return;
                    }
                }
                
                // No active chat found. Check if there's a pending request.
                const pendingRes = await fetch("/Chat/GetPendingRequests");
                if (pendingRes.ok) {
                    const pendings = await pendingRes.json();
                    if (pendings && pendings.length > 0) {
                        isWaitingForSupport = true;
                        document.getElementById('support-name').innerText = 'Support Team';
                        document.getElementById('mini-chat-content').innerHTML = ''; // Clear container
                        
                        // Show the message we sent
                        appendMiniMsg({ senderId: currentUserId, content: pendings[0].initialMessage });
                        
                        // Show waiting UI
                        const waitingHtml = `
                            <div class="text-center py-6 w-full relative z-10" id="waiting-support-ui">
                                <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-3 animate-pulse">
                                    <span class="material-symbols-outlined">support_agent</span>
                                </div>
                                <p class="text-xs font-medium text-slate-500">Your request is in queue.</p>
                                <p class="text-[10px] text-slate-400">Waiting for support staff...</p>
                            </div>
                        `;
                        document.getElementById('mini-chat-content').insertAdjacentHTML('beforeend', waitingHtml);
                        return;
                    }
                }
                
                // No pending request found. Show welcome state.
                document.getElementById('support-name').innerText = 'Support Team';
                showMiniWelcomeState();
            } catch (err) {
                console.error("Init mini chat error:", err);
                document.getElementById('mini-chat-content').innerHTML = `<div class="text-center py-4 text-xs text-red-500">Unable to connect to support.</div>`;
            }
        }

        function showMiniWelcomeState() {
            const container = document.getElementById('mini-chat-content');
            let html = `
                <div class="flex flex-col w-fit max-w-[85%] self-start relative z-10 mb-1 mt-2">
                    <div class="text-[10px] font-bold text-slate-400 mb-1 px-1 text-left">Support Team</div>
                    <div class="text-[13.5px] px-4 py-2.5 rounded-2xl leading-relaxed shadow-sm bg-white border border-slate-100 text-slate-700 rounded-bl-sm">
                        Hello! 👋 Thanks for reaching out. Please send us your issue and someone will be with you shortly.
                    </div>
                </div>
                <div class="flex flex-wrap gap-2 mb-4" id="quick-replies">
                    <button onclick="sendQuickReply('I need to ask about course content')" class="text-[12px] px-3 py-1.5 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-full hover:bg-emerald-100 transition-colors cursor-pointer">Ask about course</button>
                    <button onclick="sendQuickReply('I encountered a payment error')" class="text-[12px] px-3 py-1.5 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-full hover:bg-emerald-100 transition-colors cursor-pointer">Payment error</button>
                    <button onclick="sendQuickReply('I need more advice')" class="text-[12px] px-3 py-1.5 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-full hover:bg-emerald-100 transition-colors cursor-pointer">Need advice</button>
                </div>`;
            container.innerHTML = html;
        }

        async function loadMiniHistory() {
            if (!miniChatId) return;
            try {
                // Use BFF Proxy
                const res = await fetch(`/Chat/GetHistory?roomId=${miniChatId}`);
                const msgs = await res.json();
                const container = document.getElementById('mini-chat-content');
                let html = '';
                const staffName = document.getElementById('support-name').innerText;
                
                html += msgs.map(m => {
                    const sid = getMiniSenderId(m);
                    const isMe = sid === currentUserId && currentUserId > 0;
                    const name = getMiniSenderName(m);
                    const attachments = m.attachments || m.Attachments || [];
                    let attachmentHtml = "";
                    if (attachments.length > 0) {
                        attachmentHtml = `
                            <div class="mt-1.5 flex flex-col gap-1.5">
                                ${attachments.map(a => {
                                    const fType = a.fileType || a.FileType;
                                    const fUrl = a.fileUrl || a.FileUrl;
                                    const fName = a.fileName || a.FileName || 'Document';
                                    
                                    if (fType === 'image') {
                                        return `<a href="${fUrl}" target="_blank" class="block rounded-lg overflow-hidden border ${isMe ? 'border-emerald-400' : 'border-slate-200'} shadow-sm max-w-[150px]">
                                                    <img src="${fUrl}" class="w-full h-auto" />
                                                </a>`;
                                    } else {
                                        return `<a href="${fUrl}" target="_blank" class="flex items-center gap-1.5 p-1.5 ${isMe ? 'bg-black/10 hover:bg-black/20 text-white' : 'bg-slate-50 hover:bg-slate-100 text-slate-700'} rounded-lg border border-transparent transition-colors text-[11px] max-w-[180px]">
                                                    <span class="material-symbols-outlined text-[14px]">description</span>
                                                    <span class="truncate flex-1">${fName}</span>
                                                </a>`;
                                    }
                                }).join('')}
                            </div>
                        `;
                    }
                    return `
                        <div class="flex flex-col w-fit max-w-[85%] ${isMe ? 'self-end' : 'self-start'} relative z-10 mb-1">
                            <div class="text-[10px] font-bold text-slate-400 mb-1 px-1 ${isMe ? 'text-right' : 'text-left'}">${isMe ? 'You' : name}</div>
                            <div class="text-[13.5px] px-4 py-2.5 rounded-2xl leading-relaxed shadow-sm ${isMe ? 'bg-gradient-to-br from-emerald-600 to-emerald-500 text-white rounded-br-sm' : 'bg-white border border-slate-100 text-slate-700 rounded-bl-sm'}">
                                ${m.content}${attachmentHtml}
                            </div>
                        </div>`;
                }).join('');
                
                html += `
                    <div id="typing-indicator" class="hidden flex-col w-fit max-w-[85%] self-start relative z-10 mt-1">
                        <div class="text-[10px] font-bold text-slate-400 mb-1 px-1 text-left" id="typing-name">${staffName}</div>
                        <div class="px-4 py-3 rounded-2xl bg-white border border-slate-100 rounded-bl-sm shadow-sm flex items-center gap-1 h-[36px]">
                            <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0s"></div>
                            <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0.15s"></div>
                            <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0.3s"></div>
                        </div>
                    </div>`;
                    
                container.innerHTML = html;
                container.scrollTop = container.scrollHeight;
            } catch (err) {
                console.error("Load mini history error:", err);
            }
        }

        window.sendQuickReply = async function(text) {
            const input = document.getElementById('mini-chat-input');
            input.value = text;
            await sendMiniMsg();
            const qr = document.getElementById('quick-replies');
            if (qr) qr.style.display = 'none';
        };

        let typingTimeout;
        window.handleInputTyping = function() {
            if (!miniChatConn || !miniChatId) return;
            miniChatConn.invoke("Typing", miniChatId, true).catch(e => console.error(e));
            clearTimeout(typingTimeout);
            typingTimeout = setTimeout(() => {
                if (miniChatConn.state === signalR.HubConnectionState.Connected) {
                    miniChatConn.invoke("Typing", miniChatId, false).catch(e => console.error(e));
                }
            }, 2000);
        };

        async function sendMiniMsg() {
            const input = document.getElementById('mini-chat-input');
            const content = input.value.trim();
            if (!content) return;
            
            if (isWaitingForSupport) {
                let warningMsg = document.getElementById('spam-warning');
                if (!warningMsg) {
                    warningMsg = document.createElement('div');
                    warningMsg.id = 'spam-warning';
                    warningMsg.className = 'text-[11px] text-red-500 font-semibold mb-2 ml-1 animate-pulse';
                    warningMsg.innerText = '⚠️ Hang tight! Someone from our team will be right with you...';
                    
                    // Insert just before the input container
                    input.parentElement.parentElement.insertBefore(warningMsg, input.parentElement);
                    
                    setTimeout(() => {
                        const w = document.getElementById('spam-warning');
                        if (w) w.remove();
                    }, 3000);
                }
                return;
            }

            // If we don't have an active chat yet, we are creating a ticket
            if (!miniChatId) {
                try {
                    isWaitingForSupport = true;
                    const res = await fetch("/Chat/RequestSupport", {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ content: content, targetRole: 'staff' })
                    });
                    
                    if (res.ok) {
                        input.value = "";
                        const container = document.getElementById('mini-chat-content');
                        
                        // Append our own message visually
                        appendMiniMsg({ senderId: currentUserId, content: content });
                        
                        // Show waiting state
                        const qr = document.getElementById('quick-replies');
                        if (qr) qr.style.display = 'none';
                        
                        const waitingHtml = `
                            <div class="text-center py-6 w-full relative z-10" id="waiting-support-ui">
                                <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-3 animate-pulse">
                                    <span class="material-symbols-outlined">support_agent</span>
                                </div>
                                <p class="text-xs font-medium text-slate-500">Your request has been sent.</p>
                                <p class="text-[10px] text-slate-400">Waiting for support staff...</p>
                            </div>
                        `;
                        container.insertAdjacentHTML('beforeend', waitingHtml);
                        container.scrollTop = container.scrollHeight;
                    }
                } catch (err) {
                    console.error("Request support error:", err);
                    isWaitingForSupport = false;
                }
                return;
            }

            // Normal sending if chat is established
            if (!miniChatConn) return;

            try {
                await miniChatConn.invoke("SendMessage", {
                    chatId: miniChatId,
                    content: content
                });
                input.value = "";
                miniChatConn.invoke("Typing", miniChatId, false).catch(e=>console.error(e));
            } catch (err) {
                console.error("Send mini msg error:", err);
            }
        }

        function appendMiniMsg(m) {
            const container = document.getElementById('mini-chat-content');
            if (!container) return;
            const sid = getMiniSenderId(m);
            const isMe = sid === currentUserId && currentUserId > 0;
            const name = getMiniSenderName(m);
            const attachments = m.attachments || m.Attachments || [];
            let attachmentHtml = "";
            if (attachments.length > 0) {
                attachmentHtml = `
                    <div class="mt-1.5 flex flex-col gap-1.5">
                        ${attachments.map(a => {
                            const fType = a.fileType || a.FileType;
                            const fUrl = a.fileUrl || a.FileUrl;
                            const fName = a.fileName || a.FileName || 'Document';
                            
                            if (fType === 'image') {
                                return `<a href="${fUrl}" target="_blank" class="block rounded-lg overflow-hidden border ${isMe ? 'border-emerald-400' : 'border-slate-200'} shadow-sm max-w-[150px]">
                                            <img src="${fUrl}" class="w-full h-auto" />
                                        </a>`;
                            } else {
                                return `<a href="${fUrl}" target="_blank" class="flex items-center gap-1.5 p-1.5 ${isMe ? 'bg-black/10 hover:bg-black/20 text-white' : 'bg-slate-50 hover:bg-slate-100 text-slate-700'} rounded-lg border border-transparent transition-colors text-[11px] max-w-[180px]">
                                            <span class="material-symbols-outlined text-[14px]">description</span>
                                            <span class="truncate flex-1">${fName}</span>
                                        </a>`;
                            }
                        }).join('')}
                    </div>
                `;
            }

            const html = `
                <div class="flex flex-col w-fit max-w-[85%] ${isMe ? 'self-end' : 'self-start'} relative z-10 mb-1">
                    <div class="text-[10px] font-bold text-slate-400 mb-1 px-1 ${isMe ? 'text-right' : 'text-left'}">${isMe ? 'You' : name}</div>
                    <div class="text-[13.5px] px-4 py-2.5 rounded-2xl leading-relaxed shadow-sm ${isMe ? 'bg-gradient-to-br from-emerald-600 to-emerald-500 text-white rounded-br-sm' : 'bg-white border border-slate-100 text-slate-700 rounded-bl-sm'}">
                        ${m.content}${attachmentHtml}
                    </div>
                </div>`;
            const indicator = document.getElementById('typing-indicator');
            if (indicator) {
                indicator.insertAdjacentHTML('beforebegin', html);
            } else {
                container.insertAdjacentHTML('beforeend', html);
            }
            container.scrollTop = container.scrollHeight;
        }

        // 3. Notifications & Global SignalR logic
        function timeSince(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return "Just now";
            const interval = Math.floor(seconds / 60);
            if (interval < 60) return interval + " minutes ago";
            const hours = Math.floor(interval / 60);
            if (hours < 24) return hours + " hours ago";
            return date.toLocaleDateString('en-US');
        }

        async function loadTopNotifications() {
            const container = document.getElementById('notification-items-container');
            const badge = document.getElementById('noti-badge');
            if (!container || !currentToken) return;

            try {
                const response = await fetch("/Notification/GetMyNotifications");
                if (response.ok) {
                    const result = await response.json();
                    const notifications = result.data?.items || [];
                    const hasUnread = notifications.some(n => n.isRead === false);
                    if (badge) hasUnread ? badge.classList.remove('hidden') : badge.classList.add('hidden');

                    const top3 = notifications.slice(0, 3);
                    if (top3.length === 0) {
                        container.innerHTML = `<div class="px-4 py-8 text-center text-slate-400 text-sm italic">No new notifications</div>`;
                        return;
                    }
                    container.innerHTML = top3.map(n => `
                        <div class="p-4 border-b border-slate-50 hover:bg-emerald-50/50 transition-all cursor-pointer" onclick="location.href='${n.linkAction ? n.linkAction : '/Notification'}'">
                            <p class="text-xs font-bold text-slate-800 truncate">${n.title}</p>
                            <p class="text-[11px] text-slate-500 mt-1 line-clamp-2">${n.content}</p>
                            <p class="text-[9px] text-slate-300 mt-2 uppercase font-bold">${timeSince(new Date(n.createdAt))}</p>
                        </div>
                    `).join('');
                }
            } catch (err) { console.error("Noti error:", err); }
        }

        document.addEventListener("DOMContentLoaded", () => {
            loadTopNotifications();
            updateCartButtons();
            document.addEventListener('cartUpdated', updateCartButtons);
            
            if (currentToken) {
                if (localStorage.getItem("AccountLocked") === "true") {
                    localStorage.removeItem("AccountLocked");
                    const form = document.getElementById('global-logout-form');
                    if(form) { form.submit(); }
                    return;
                }

                // SignalR Noti
                const notiConn = new signalR.HubConnectionBuilder()
                    .withUrl("http://localhost:5207/notificationHub", { accessTokenFactory: () => currentToken })
                    .withAutomaticReconnect().build();
                notiConn.on("ReceiveNotification", (noti) => {
                    loadTopNotifications();
                    document.dispatchEvent(new CustomEvent("ReceiveNotificationEvent"));

                    if (noti && noti.title && localStorage.getItem("AccountLocked") !== "true") {
                        const truncateText = (text, maxLength = 20) => {
                            if (!text) return "";
                            return text.length > maxLength ? text.substring(0, maxLength) + "..." : text;
                        };

                        const displayTitle = truncateText(noti.title, 20);
                        const displayContent = truncateText(noti.content, 20);

                        const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 6000,
                            timerProgressBar: true,
                            didOpen: (toast) => {
                                toast.addEventListener('mouseenter', Swal.stopTimer);
                                toast.addEventListener('mouseleave', Swal.resumeTimer);
                                
                                // Make entire toast clickable
                                toast.style.cursor = 'pointer';
                                toast.addEventListener('click', (e) => {
                                    if (e.target.tagName !== 'A' && e.target.tagName !== 'BUTTON') {
                                        const targetUrl = noti.linkAction || '/Notification';
                                        window.location.href = targetUrl;
                                    }
                                });
                            }
                        });

                        Toast.fire({
                            icon: 'info',
                            title: displayTitle,
                            html: `
                                <div class="text-left font-body">
                                    <p class="text-[12px] text-slate-600 mt-1 leading-relaxed">${displayContent}</p>
                                    ${noti.linkAction ? `<a href="${noti.linkAction}" class="inline-block mt-2 text-[12px] font-bold text-emerald-600 hover:text-emerald-700 transition-colors">View Detail &rarr;</a>` : ''}
                                </div>
                            `
                        });
                    }
                });
                notiConn.on("UpdateWishlistCount", () => {
                    if (typeof updateWishlistBadge === 'function') {
                        updateWishlistBadge();
                    }
                });
                notiConn.on("AccountLockedOut", () => {
                    localStorage.setItem("AccountLocked", "true");
                    Swal.fire({
                        icon: 'error',
                        title: 'Account Locked',
                        text: 'Your account has been locked due to a policy violation. You will be logged out automatically.',
                        timer: 5000,
                        timerProgressBar: true,
                        showConfirmButton: false,
                        allowOutsideClick: false,
                        allowEscapeKey: false
                    }).then(() => {
                        document.getElementById('global-logout-form').submit();
                    });
                });
                notiConn.start().catch(err => console.error("Noti Hub Error", err));

                // SignalR Chat
                miniChatConn = new signalR.HubConnectionBuilder()
                    .withUrl("http://localhost:5207/chatHub", { accessTokenFactory: () => currentToken })
                    .withAutomaticReconnect().build();

                miniChatConn.on("ReceiveMessage", function (message) {
                    const popup = document.getElementById('support-chat-popup');
                    const msgChatId = message.chatId ?? message.ChatId;
                    
                    // Update allMiniChats list for dropdown
                    if (typeof allMiniChats !== 'undefined') {
                        const existingChat = allMiniChats.find(c => c.chatId == msgChatId);
                        if (existingChat) {
                            existingChat.lastMessage = message.content;
                            // move to top
                            allMiniChats = [existingChat, ...allMiniChats.filter(c => c.chatId != msgChatId)];
                            if (typeof renderMiniChatDropdown === 'function') renderMiniChatDropdown();
                        } else {
                            fetch("/Chat/GetList").then(res => res.json()).then(chats => {
                                allMiniChats = chats;
                                if (typeof renderMiniChatDropdown === 'function') renderMiniChatDropdown();
                            }).catch(e=>{});
                        }
                    }

                    if (popup && popup.style.display === 'flex' && msgChatId == miniChatId) {
                        appendMiniMsg(message);
                    } else if (window.location.pathname.toLowerCase() !== "/chat") {
                        const chatBadge = document.getElementById('global-chat-badge');
                        if (chatBadge) {
                            chatBadge.style.display = 'block';
                            const current = parseInt(chatBadge.innerText || "0");
                            chatBadge.innerText = current + 1;
                        }
                        const bubble = document.getElementById('unread-preview-bubble');
                        const previewContent = document.getElementById('preview-content');
                        if (bubble && previewContent && document.getElementById('support-chat-popup') && document.getElementById('support-chat-popup').style.display !== 'flex') {
                            previewContent.innerText = message.content;
                            bubble.classList.remove('hidden');
                            bubble.classList.add('block');
                            setTimeout(() => {
                                bubble.classList.add('hidden');
                                bubble.classList.remove('block');
                            }, 5000);
                        }
                    }
                });

                miniChatConn.on("SupportRequestAccepted", async function(data) {
                    miniChatId = data.chatId ?? data.ChatId;
                    isWaitingForSupport = false;
                    
                    // Remove waiting UI
                    const waitingUi = document.getElementById('waiting-support-ui');
                    if (waitingUi) waitingUi.remove();
                    
                    if (miniChatConn && miniChatConn.state === signalR.HubConnectionState.Connected) {
                        await miniChatConn.invoke("JoinChat", miniChatId);
                    }
                    
                    // Refresh dropdown
                    try {
                        const res = await fetch("/Chat/GetList");
                        if (res.ok) {
                            allMiniChats = await res.json();
                            const activeChat = allMiniChats.find(c => c.chatId == miniChatId);
                            if (activeChat) {
                                document.getElementById('support-name').innerText = activeChat.partnerName || 'Support Team';
                                if (activeChat.partnerAvatar) {
                                    const img = document.getElementById('support-avatar');
                                    img.src = activeChat.partnerAvatar;
                                    img.classList.remove('hidden');
                                    document.getElementById('support-icon').classList.add('hidden');
                                }
                            }
                            if (typeof renderMiniChatDropdown === 'function') renderMiniChatDropdown();
                        }
                    } catch(e) {}
                    
                    await loadMiniHistory();
                });

                miniChatConn.on("UserTyping", function(data) {
                    if (data.chatId == miniChatId && data.accountId !== currentUserId) {
                        const indicator = document.getElementById('typing-indicator');
                        if (indicator) {
                            if (data.isTyping) {
                                document.getElementById('typing-name').innerText = data.name || "Support Team";
                                indicator.classList.remove('hidden');
                                indicator.classList.add('flex');
                                const container = document.getElementById('mini-chat-content');
                                container.scrollTop = container.scrollHeight;
                            } else {
                                indicator.classList.add('hidden');
                                indicator.classList.remove('flex');
                            }
                        }
                    }
                });

                miniChatConn.start().then(() => {
                    fetch("/Chat/GetUnreadCount").then(res => res.json()).then(data => {
                        if (data.count > 0 && window.location.pathname.toLowerCase() !== "/chat") {
                            const b = document.getElementById('global-chat-badge');
                            if (b) { b.style.display = 'block'; b.innerText = data.count; }
                        }
                    });
                }).catch(err => console.error("Chat Hub Error", err));
            }

            // --- Global Email Verification Interceptor ---
            function getCookie(name) {
                const value = `; ${document.cookie}`;
                const parts = value.split(`; ${name}=`);
                if (parts.length === 2) return parts.pop().split(';').shift();
                return null;
            }

            function checkEmailVerification(event, actionName) {
                const token = getCookie('AccessToken');
                if (!token) return true; // Let them click, they'll be redirected to login anyway

                const isVerified = getCookie('IsVerified');
                if (isVerified !== 'true') {
                    event.preventDefault();
                    event.stopPropagation();

                    Swal.fire({
                        title: 'Email Verification Required',
                        text: `Please verify your email address to ${actionName}.`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#006a62',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Verify Now',
                        cancelButtonText: 'Cancel'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = '/Account/SendVerifyOtp';
                        }
                    });
                    return false;
                }
                return true;
            }

            // Intercept form submissions
            document.addEventListener('submit', (e) => {
                const action = e.target.getAttribute('action') || '';
                const id = e.target.getAttribute('id') || '';
                if (action.includes('Checkout') || action.includes('Cart') || id.includes('checkout') || id.includes('cart')) {
                    checkEmailVerification(e, 'complete checkout');
                }
            }, true);

            // Intercept button/link clicks
            document.addEventListener('click', (e) => {
                const target = e.target.closest('a, button');
                if (!target) return;

                const onclickAttr = target.getAttribute('onclick') || '';
                const hrefAttr = target.getAttribute('href') || '';
                const idAttr = target.getAttribute('id') || '';
                const classAttr = target.getAttribute('class') || '';

                if (onclickAttr.includes('addToCart') || hrefAttr.includes('Cart/add') || idAttr.includes('add-to-cart') || classAttr.includes('add-to-cart')) {
                    checkEmailVerification(e, 'add courses to cart');
                } else if (onclickAttr.includes('enrollFree') || hrefAttr.includes('Enrollment/free') || idAttr.includes('enroll-btn') || classAttr.includes('enroll-btn')) {
                    checkEmailVerification(e, 'enroll in this course');
                }
            }, true);
        });
    </script>
</body>
</html>