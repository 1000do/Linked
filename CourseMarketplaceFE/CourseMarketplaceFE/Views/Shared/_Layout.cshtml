@using System.Security.Claims
@{
   
    var tokenForLayout = Context.Request.Cookies["AccessToken"]
                         ?? Context.Request.Cookies[".AspNetCore.Identity.Application"];
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
	<!-- cloudinary -->
	<link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="dns-prefetch" href="https://res.cloudinary.com">

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#006a62",
                        "primary-container": "#43e8d8",
                        "on-primary": "#ffffff",
                        "secondary": "#006b60",
                        "surface": "#f0fcfb",
                        "on-surface": "#131d1e",
                        "surface-container-low": "#eaf6f5",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"]
                    }
                }
            }
        }
    </script>
    
    

    <style>
        .glass-nav {
            backdrop-filter: blur(12px);
        }

        .hero-gradient {
            background: linear-gradient(135deg, #006a62 0%, #43e8d8 100%);
        }

        /* Floating Chat Button - Emerald Style */
        .floating-chat-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 56px;
            height: 56px;
            background: #059669; /* Emerald 600 */
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 20px rgba(5, 150, 105, 0.4);
            cursor: pointer;
            z-index: 1000;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: none;
        }

        .floating-chat-btn:hover {
            transform: scale(1.1) rotate(5deg);
            background: #047857;
        }

        /* Support Popup */
        .support-popup {
            position: fixed;
            bottom: 100px;
            right: 30px;
            width: 350px;
            max-height: 500px;
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            z-index: 1001;
            display: none;
            flex-direction: column;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            animation: slideUp 0.3s ease;
        }

        @@keyframes slideUp {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .support-header {
            background: #059669;
            color: white;
            padding: 20px;
            text-align: center;
        }

        .support-content {
            padding: 15px;
            overflow-y: auto;
            background: #f8fafc;
        }

        .quick-question {
            background: white;
            border: 1px solid #e2e8f0;
            padding: 10px 15px;
            border-radius: 10px;
            margin-bottom: 8px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
            color: #475569;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .quick-question:hover {
            border-color: #059669;
            color: #059669;
            background: #f0fdf4;
        }

        .chat-badge {
            position: absolute;
            top: -2px;
            right: -2px;
            background: #ef4444;
            color: white;
            font-size: 10px;
            font-weight: bold;
            padding: 2px 6px;
            border-radius: 10px;
            border: 2px solid white;
        }
    </style>

    <!-- GOOGLE LOGIN SCRIPT -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="bg-surface font-body text-on-surface antialiased">

    <!-- HEADER -->
    @await Html.PartialAsync("_Header")

    <!-- CONTENT -->
    <main role="main" class="pt-20">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    @await Html.PartialAsync("_Footer")

    <!-- SUPPORT POPUP -->
    <div id="support-chat-popup" class="support-popup">
        <div class="support-header">
            <h5 class="mb-1 fw-bold">Hỗ trợ trực tuyến</h5>
            <p class="mb-0 text-xs opacity-75">Chào bạn, chúng tôi có thể giúp gì?</p>
        </div>
        <div class="support-content">
            <p class="text-xs text-slate-500 mb-3 fw-bold uppercase">Câu hỏi thường gặp</p>
            <div class="quick-question" onclick="askSupport('Làm sao để đăng ký khóa học?')">
                <i class="material-symbols-outlined text-sm">payments</i>
                Cách thức đăng ký khóa học?
            </div>
            <div class="quick-question" onclick="askSupport('Tôi bị quên mật khẩu')">
                <i class="material-symbols-outlined text-sm">lock_reset</i>
                Tôi bị quên mật khẩu
            </div>
            <div class="quick-question" onclick="askSupport('Chính sách hoàn tiền như thế nào?')">
                <i class="material-symbols-outlined text-sm">reusable_item</i>
                Chính sách hoàn tiền
            </div>
            <div class="quick-question" onclick="askSupport('Báo lỗi kỹ thuật')">
                <i class="material-symbols-outlined text-sm">bug_report</i>
                Báo lỗi kỹ thuật
            </div>
            
            <hr class="my-3 border-slate-200">
            
            <div class="text-center">
                <a href="/Chat" class="btn btn-sm btn-outline-success w-100 rounded-pill">
                    Kết nối với nhân viên hỗ trợ
                </a>
            </div>
        </div>
    </div>

    <!-- FLOATING CHAT BUTTON -->
    <button class="floating-chat-btn" onclick="toggleSupportPopup()" title="Hỗ trợ">
        <i class="material-symbols-outlined" style="font-size: 28px;">support_agent</i>
        <span class="chat-badge" style="display: none;" id="global-chat-badge">1</span>
    </button>


   

    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        function toggleSupportPopup() {
            const popup = document.getElementById('support-chat-popup');
            const isVisible = popup.style.display === 'flex';
            popup.style.display = isVisible ? 'none' : 'flex';
            
            // Ẩn chấm đỏ khi đã mở
            if (!isVisible) {
                const badge = document.getElementById('global-chat-badge');
                if (badge) badge.style.display = 'none';
            }
        }

        async function askSupport(question) {
            alert("Hệ thống đang chuyển yêu cầu: " + question);
            // Sau này sẽ tích hợp tự động gửi tin nhắn vào Chat chính
            window.location.href = "/Chat?autoMessage=" + encodeURIComponent(question);
        }

        // 1. Lấy token an toàn từ Server-side (Razor)
        const currentToken = `@Html.Raw(tokenForLayout ?? "")`.trim();

        // Hàm bổ trợ tính thời gian
        function timeSince(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return "Vừa xong";
            const interval = Math.floor(seconds / 60);
            if (interval < 60) return interval + " phút trước";
            const hours = Math.floor(interval / 60);
            if (hours < 24) return hours + " giờ trước";
            return date.toLocaleDateString('vi-VN');
        }

        // 2. Hàm load danh sách thông báo và cập nhật giao diện
        async function loadTopNotifications() {
            const container = document.getElementById('notification-items-container');
            const badge = document.getElementById('noti-badge');
            if (!container) return;

            // Nếu không có token, báo đăng nhập
            if (!currentToken || currentToken === "") {
                container.innerHTML = `<div class="p-4 text-center text-xs text-slate-400">Vui lòng đăng nhập</div>`;
                if (badge) badge.classList.add('hidden');
                return;
            }

            try {
                const response = await fetch("http://localhost:5207/api/Notification", {
                    method: 'GET',
                    headers: {
                        'Authorization': `Bearer ${currentToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                   if (response.ok) {
        const result = await response.json();

        // Kiểm tra: nếu result là mảng thì dùng luôn, nếu là object có .data thì lấy .data
        const notifications = Array.isArray(result) ? result : (result.data || []);

        // 1. Cập nhật chấm đỏ
        const hasUnread = notifications.some(n => n.isRead === false);
        if (badge) {
            if (hasUnread) badge.classList.remove('hidden');
            else badge.classList.add('hidden');
        }

        // 2. Lấy Top 3 để hiện dropdown
        const top3 = notifications.slice(0, 3);
        if (top3.length === 0) {
            container.innerHTML = `<div class="px-4 py-8 text-center text-slate-400 text-sm italic">Không có thông báo mới</div>`;
            return;
        }

                    container.innerHTML = top3.map(n => `
                        <div class="p-4 border-b border-slate-50 hover:bg-emerald-50/50 transition-all cursor-pointer"
                             onclick="location.href='/Notification'">
                            <div class="flex gap-3">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2">
                                        ${!n.isRead ? '<span class="w-1.5 h-1.5 bg-primary rounded-full shrink-0"></span>' : ''}
                                        <p class="text-xs font-bold text-slate-800 truncate">${n.title}</p>
                                    </div>
                                    <p class="text-[11px] text-slate-500 mt-1 line-clamp-2 leading-relaxed">${n.content}</p>
                                    <div class="flex justify-between items-center mt-2">
                                        <p class="text-[9px] text-slate-300 font-bold uppercase tracking-wider">
                                            ${timeSince(new Date(n.createdAt))}
                                        </p>
                                        ${!n.isRead ? '<span class="text-[9px] text-primary font-bold">Mới</span>' : ''}
                                    </div>
                                </div>
                            </div>
                        </div>
                    `).join('');
                } else {
                    console.error("API trả lỗi:", response.status);
                }
            } catch (err) {
                console.error("Lỗi fetch:", err);
                container.innerHTML = `<div class="p-4 text-center text-xs text-red-400">Lỗi đồng bộ dữ liệu</div>`;
            }
        }

        // 3. Khởi tạo SignalR (Dùng luôn currentToken đã lấy ở trên)
        if (currentToken) {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("http://localhost:5207/notificationHub", {
                    accessTokenFactory: () => currentToken // Dùng trực tiếp biến const
                })
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveNotification", function (noti) {
                loadTopNotifications();
                if (typeof loadHistory === "function") loadHistory();
                if (typeof loadNotifications === "function") loadNotifications();
            });

            connection.start().catch(err => console.error("SignalR Error: ", err));

            // 4. Kết nối tới ChatHub để hiện chấm đỏ
            const chatConn = new signalR.HubConnectionBuilder()
                .withUrl("http://localhost:5207/chatHub", {
                    accessTokenFactory: () => currentToken
                })
                .withAutomaticReconnect()
                .build();

            chatConn.on("ReceiveMessage", function (message) {
                // Nếu không ở trang chat thì hiện chấm đỏ
                if (window.location.pathname.toLowerCase() !== "/chat") {
                    const chatBadge = document.getElementById('global-chat-badge');
                    if (chatBadge) chatBadge.style.display = 'block';
                }
            });

            chatConn.start().catch(err => console.error("Chat SignalR Error: ", err));
        }

        // Wishlist Toggle AJAX
        async function toggleWishlist(btn, courseId) {
            if (!currentToken || currentToken === "") {
                window.location.href = "/Account/Login";
                return;
            }

            try {
                // Thêm hiệu ứng loading
                const icon = btn.querySelector('.material-symbols-outlined');
                const originalFill = icon.style.fontVariationSettings;
                btn.style.pointerEvents = 'none';
                btn.style.opacity = '0.5';

                const response = await fetch(`/Wishlist/ToggleAjax?courseId=${courseId}`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        // Cập nhật UI
                        const textEl = btn.querySelector('.wishlist-text');
                        if (result.isInWishlist) {
                            btn.classList.remove('text-slate-400', 'text-slate-700');
                            btn.classList.add('text-red-500');
                            icon.style.fontVariationSettings = '"FILL" 1';
                            if (textEl) textEl.textContent = "Saved to Wishlist";
                        } else {
                            btn.classList.remove('text-red-500');
                            btn.classList.add('text-slate-400', 'text-slate-700');
                            icon.style.fontVariationSettings = '"FILL" 0';
                            if (textEl) textEl.textContent = "Add to Wishlist";
                        }
                        
                        // Nếu đang ở trang wishlist mà xóa thì ẩn item đó luôn
                        if (window.location.pathname.toLowerCase() === "/wishlist") {
                            const card = btn.closest('.group');
                            if (card) {
                                card.style.opacity = '0';
                                setTimeout(() => card.remove(), 300);
                            }
                        }
                    }
                }
            } catch (err) {
                console.error("Wishlist error:", err);
            } finally {
                btn.style.pointerEvents = 'auto';
                btn.style.opacity = '1';
            }
        }



        // Chạy khi load trang
        document.addEventListener("DOMContentLoaded", () => {
            loadTopNotifications();
        });
    </script>
</body>
</html>