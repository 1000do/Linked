@{
    var tokenForLayout = Context.Request.Cookies["AuthToken"] ?? Context.Request.Cookies[".AspNetCore.Identity.Application"];
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Instructor Studio</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
	<!-- Cloudinary -->
	<link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="dns-prefetch" href="https://res.cloudinary.com">
    
    <!-- Quill Rich Text Editor CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#006a62",
                        "primary-container": "#43e8d8",
                        "on-primary": "#ffffff",
                        "secondary": "#006b60",
                        "surface": "#f0fcfb",
                        "on-surface": "#131d1e",
                        "surface-container-low": "#eaf6f5",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"]
                    }
                }
            }
        }
    </script>
    <script>
        const LAYOUT_TOKEN = '@tokenForLayout';
    </script>

    <style>
        /* Custom styles for Quills editor to match Tailwind */
        .ql-toolbar.ql-snow { border-radius: 0.5rem 0.5rem 0 0; border-color: #e2e8f0; background-color: #f8fafc; }
        .ql-container.ql-snow { border-radius: 0 0 0.5rem 0.5rem; border-color: #e2e8f0; min-height: 150px; font-family: 'Inter', sans-serif; }
    </style>
</head>

<body class="bg-slate-50 font-body text-on-surface antialiased flex h-screen overflow-hidden">

    <!-- SIDEBAR -->
    <aside class="w-64 bg-white border-r border-slate-200 flex-shrink-0 flex flex-col hidden md:flex">
        <div class="h-20 flex items-center px-6">
            <div class="flex flex-col">
                <span class="text-xl font-headline font-extrabold text-primary">LinkedLearn</span>
                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Instructor Studio</span>
            </div>
        </div>
        
        <nav class="flex-1 px-4 py-6 space-y-2">
            <a href="#" class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-xl transition-colors">
                <span class="material-symbols-outlined text-[20px]">dashboard</span>
                <span class="text-sm font-semibold">Dashboard</span>
            </a>
            <a href="/InstructorCourse" class="flex items-center gap-3 px-4 py-3 bg-primary/10 text-primary rounded-xl transition-colors relative">
                <span class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-primary rounded-r-full"></span>
                <span class="material-symbols-outlined text-[20px]">library_books</span>
                <span class="text-sm font-bold">My Courses</span>
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-xl transition-colors">
                <span class="material-symbols-outlined text-[20px]">edit_document</span>
                <span class="text-sm font-semibold">Curriculum Editor</span>
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-xl transition-colors">
                <span class="material-symbols-outlined text-[20px]">bar_chart</span>
                <span class="text-sm font-semibold">Analytics</span>
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-xl transition-colors">
                <span class="material-symbols-outlined text-[20px]">settings</span>
                <span class="text-sm font-semibold">Settings</span>
            </a>
        </nav>
        
        <div class="p-6">
            <a href="/InstructorCourse/Create" class="w-full bg-primary text-white py-3 rounded-xl font-semibold flex items-center justify-center gap-2 hover:bg-secondary transition-colors">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Create New Course
            </a>
        </div>
    </aside>

    <!-- MAIN WRAPPER -->
    <div class="flex-1 flex flex-col h-full overflow-hidden">
        
        <!-- TOP APP BAR -->
        <header class="h-20 bg-white border-b border-slate-200 flex items-center justify-between px-8 flex-shrink-0">
            <div class="w-96 relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                <input type="text" placeholder="Search courses or resources..." class="w-full bg-slate-100 border-none rounded-full py-2.5 pl-10 pr-4 text-sm focus:ring-2 focus:ring-primary/20 outline-none placeholder:text-slate-400" />
            </div>
            
            <div class="flex items-center gap-6">
                <a href="#" class="text-sm font-semibold text-slate-600 hover:text-primary">View Site</a>
                <a href="#" class="text-sm font-semibold text-slate-600 hover:text-primary">Support</a>
                <a href="#" class="text-sm font-semibold text-slate-600 hover:text-primary">Resources</a>
                
                <div class="w-px h-6 bg-slate-200 mx-2"></div>
                
                <button class="relative text-slate-500 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border border-white"></span>
                </button>
                <button class="text-slate-500 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined">help</span>
                </button>
                
                <button class="w-10 h-10 rounded-full overflow-hidden border-2 border-slate-200">
                    <img src="https://ui-avatars.com/api/?name=Instructor&background=006a62&color=fff" alt="Avatar" class="w-full h-full object-cover" />
                </button>
            </div>
        </header>

        <!-- MAIN CONTENT AREA -->
        <main role="main" class="flex-1 overflow-y-auto bg-slate-50">
            @RenderBody()
        </main>
    </div>

    <!-- Quill JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
