@{
    var tokenForLayout = Context.Request.Cookies["AccessToken"] ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn Instructor</title>
    <link rel="icon" type="image/png" href="~/img/default-avatar.png" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
	<!-- Cloudinary -->
	<link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="dns-prefetch" href="https://res.cloudinary.com">
    
    <!-- Quill Rich Text Editor CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Prevent SweetAlert from altering the body height/padding, which breaks the fixed layout
        window.Swal = window.Swal.mixin({
            heightAuto: false,
            scrollbarPadding: false
        });
    </script>

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#006a62",
                        "primary-container": "#43e8d8",
                        "on-primary": "#ffffff",
                        "secondary": "#006b60",
                        "surface": "#f0fcfb",
                        "on-surface": "#131d1e",
                        "surface-container-low": "#eaf6f5",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"]
                    }
                }
            }
        }
    </script>
    <script>
        const LAYOUT_TOKEN = '@tokenForLayout';
    </script>

    <style>
        /* Custom styles for Quills editor to match Tailwind */
        .ql-toolbar.ql-snow { border-radius: 0.5rem 0.5rem 0 0; border-color: #e2e8f0; background-color: #f8fafc; }
        .ql-container.ql-snow { border-radius: 0 0 0.5rem 0.5rem; border-color: #e2e8f0; min-height: 150px; font-family: 'Inter', sans-serif; }

        /* Top Progress Bar Page Transition */
        #top-progress-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #006a62, #43e8d8, #006b60);
            z-index: 9999;
            width: 0%;
            transition: width 0.4s cubic-bezier(0.08, 0.82, 0.17, 1);
            box-shadow: 0 0 8px #006a62;
            pointer-events: none;
        }

        /* Premium Page Entry Transition */
        @@keyframes pageFadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .page-transition-enter {
            animation: pageFadeIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        /* Custom scrollbar for modern feel */
        .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
        
        aside .custom-scrollbar::-webkit-scrollbar-thumb { background: transparent; }
        aside:hover .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; }

        /* Smooth Nav Item Transition */
        .nav-item {
            transition: all 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="bg-slate-50 font-body text-on-surface antialiased flex h-screen overflow-hidden">

    <!-- SIDEBAR -->
    <aside class="w-[260px] bg-white border-r border-slate-100 flex-shrink-0 flex-col hidden md:flex z-20 shadow-[2px_0_16px_rgba(0,0,0,0.02)] relative">
        <a href="/InstructorCourse" class="h-16 flex items-center px-7 border-b border-slate-100 transition-colors">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-teal-50 rounded-xl flex items-center justify-center border border-teal-100 shrink-0">
                    <span class="material-symbols-outlined text-teal-600 text-[18px]">co_present</span>
                </div>
                <div class="flex flex-col">
                    <span class="font-display font-extrabold text-slate-800 text-lg tracking-tight leading-none">Linked<span class="text-teal-600">Learn</span></span>
                    <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">Instructor Studio</span>
                </div>
            </div>
        </a>
        
        @{
            bool isIndex = currentAction == "Index" && currentController == "InstructorCourse";
            bool isCreate = currentAction == "Create" && currentController == "InstructorCourse";
            bool isEditor = currentAction == "Editor" && currentController == "InstructorCourse";
            bool isMyCourses = isIndex || isCreate;
            bool isCurriculumEditor = isEditor;
        }
        
        @{
            var approvalStatus = Context.Request.Cookies["InstructorApprovalStatus"];
            bool isApproved = approvalStatus == "Approved";
            string disabledClass = !isApproved ? "opacity-50 pointer-events-none cursor-not-allowed" : "";
            
            // Helper for active styling
            string GetNavClass(bool isActive) => isActive 
                ? "nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-semibold bg-[#f0fcfb] text-[#006a62] group" 
                : "nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group";
                
            string GetIconClass(bool isActive) => isActive 
                ? "material-symbols-outlined text-[18px] text-[#006b60]" 
                : "material-symbols-outlined text-[18px] text-slate-400 group-hover:text-teal-600 transition-colors duration-300";
        }
        
        <nav class="flex-1 px-4 py-6 space-y-1.5 overflow-y-auto custom-scrollbar">
            <div class="px-3 mb-3 text-[10px] font-bold text-slate-400 uppercase tracking-wider leading-none">Studio Menu</div>

            <a href="/InstructorCourse" class="@GetNavClass(isMyCourses)">
                <span class="@GetIconClass(isMyCourses)">dashboard</span>
                Dashboard
            </a>
            <a href="#" class="@GetNavClass(false) @disabledClass">
                <span class="@GetIconClass(false)">bar_chart</span>
                Analytics
            </a>

            @{
                bool isTransaction = currentController == "Transaction" && (currentAction == "Instructor" || currentAction == "InstructorDetail");
            }
            <a href="/Transaction/Instructor" class="@GetNavClass(isTransaction) @disabledClass">
                <span class="@GetIconClass(isTransaction)">account_balance_wallet</span>
                Earnings
            </a>

            @{
                bool isNotifications = currentAction == "Notifications" && currentController == "Instructor";
            }
            <a href="/Instructor/Notifications" class="@GetNavClass(isNotifications) @disabledClass relative">
                <span class="@GetIconClass(isNotifications)">notifications</span>
                Notifications
                <span id="sidebar-noti-badge" class="absolute right-3.5 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-rose-500 hidden"></span>
            </a>

            @{
                bool isChat = currentController == "Chat";
            }
            <a href="/Chat/Instructor" class="@GetNavClass(isChat) @disabledClass relative">
                <span class="@GetIconClass(isChat)">chat_bubble</span>
                Messages
                <span id="sidebar-msg-badge" class="absolute right-3.5 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-rose-500 hidden"></span>
            </a>
            
            <div class="h-px bg-slate-100 my-4 mx-3"></div>
            
            <div class="px-3 mb-3 mt-2 text-[10px] font-bold text-slate-400 uppercase tracking-wider leading-none">More</div>

            <a href="/" class="@GetNavClass(false)">
                <span class="@GetIconClass(false)">school</span>
                View as Learner
            </a>

            <a href="#" class="@GetNavClass(false)">
                <span class="@GetIconClass(false)">help</span>
                Support
            </a>
            
            @{
                bool isSettings = currentController == "Instructor" && currentAction == "ApplicationStatus";
            }
            <a href="/Instructor/ApplicationStatus" class="@GetNavClass(isSettings)">
                <span class="@GetIconClass(isSettings)">settings</span>
                Settings
            </a>
        </nav>
        
        <div class="p-4 border-t border-slate-100">
            @{
                var userName = Context.Request.Cookies["UserName"] ?? "Instructor";
                var avatarUrl = Context.Request.Cookies["AvatarUrl"];
            }
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-white border border-slate-100 shadow-[0_4px_12px_rgba(0,0,0,0.02)] hover:border-teal-100 hover:shadow-[0_4px_12px_rgba(0,106,98,0.05)] transition-all duration-300 cursor-pointer" onclick="location.href='/Account/Profile'">
                <div class="relative shrink-0">
                    @await Html.PartialAsync("_UserAvatar", new { 
                        Url = avatarUrl, 
                        Role = "instructor", 
                        Name = userName, 
                        Size = "md",
                        ShowFrame = true,
                        FrameUrl = ""
                    })
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-teal-500 border-2 border-white rounded-full"></span>
                </div>
                <div class="flex flex-col flex-1 overflow-hidden">
                    <span class="text-xs font-bold text-slate-800 truncate">@userName</span>
                    <span class="text-[10px] text-slate-400 font-medium truncate uppercase tracking-wider mt-0.5">Instructor</span>
                    <form id="global-logout-form" asp-controller="Account" asp-action="Logout" method="post" class="m-0 mt-1.5" onclick="event.stopPropagation();">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-[11px] text-slate-400 hover:text-rose-500 font-semibold flex items-center gap-1 bg-transparent border-none p-0 cursor-pointer text-left transition-colors duration-200">Logout</button>
                    </form>
                </div>
            </div>
        </div>
    </aside>

    <!-- MAIN WRAPPER -->
    <div class="flex-1 flex flex-col h-full overflow-hidden">
        


        <!-- MAIN CONTENT AREA -->
        <main role="main" class="flex-1 overflow-y-auto bg-slate-50 page-transition-enter">
            @RenderBody()
        </main>
    </div>

    <!-- Quill JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        function toggleNoti() {
            const box = document.getElementById('noti-box');
            box?.classList.toggle('hidden');
            if (!box?.classList.contains('hidden')) {
                document.getElementById('noti-badge')?.classList.add('hidden');
            }
        }

        document.addEventListener('click', function(e) {
            const dropdown = document.getElementById('notification-dropdown');
            if (dropdown && !dropdown.contains(e.target)) {
                document.getElementById('noti-box')?.classList.add('hidden');
            }
        });
        
        if (LAYOUT_TOKEN) {
            if (localStorage.getItem("AccountLocked") === "true") {
                localStorage.removeItem("AccountLocked");
                const form = document.getElementById('global-logout-form');
                if(form) { form.submit(); }
            }
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("http://localhost:5207/notificationHub", {
                accessTokenFactory: () => LAYOUT_TOKEN
            })
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotification", function (noti) {
            // 1. Hiện chấm đỏ ở chuông
            const badge = document.getElementById('noti-badge');
            if(badge) badge.classList.remove('hidden');

            // 2. Cập nhật danh sách nhỏ ở chuông
            if (typeof loadTopNotifications === "function") loadTopNotifications();

            // Dispatch event for child views
            document.dispatchEvent(new CustomEvent("ReceiveNotificationEvent"));

            // 3. KIỂM TRA: Nếu trang hiện tại có hàm prependNotification thì gọi nó ngay
            if (typeof prependNotification === "function") {
                prependNotification(noti);
            }
            else {
                const path = window.location.pathname.toLowerCase();
                if (path.includes("/notification/admin")) {
                    if (typeof loadAdminHistory === "function") loadAdminHistory();
                } else if (path.includes("/notification")) {
                    if (typeof loadNotifications === "function") loadNotifications();
                }
            }

            // Show a premium real-time toast alert
            if (noti && noti.title && localStorage.getItem("AccountLocked") !== "true") {
                const truncateText = (text, maxLength = 20) => {
                    if (!text) return "";
                    return text.length > maxLength ? text.substring(0, maxLength) + "..." : text;
                };

                const displayTitle = truncateText(noti.title, 20);
                const displayContent = truncateText(noti.content, 20);

                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 6000,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer);
                        toast.addEventListener('mouseleave', Swal.resumeTimer);
                        
                        // Make entire toast clickable
                        toast.style.cursor = 'pointer';
                        toast.addEventListener('click', (e) => {
                            if (e.target.tagName !== 'A' && e.target.tagName !== 'BUTTON') {
                                const targetUrl = noti.linkAction || '/Instructor/Notifications';
                                window.location.href = targetUrl;
                            }
                        });
                    }
                });

                Toast.fire({
                    icon: 'info',
                    title: displayTitle,
                    html: `
                        <div class="text-left font-body">
                            <p class="text-[12px] text-slate-600 mt-1 leading-relaxed">${displayContent}</p>
                            ${noti.linkAction ? `<a href="${noti.linkAction}" class="inline-block mt-2 text-[12px] font-bold text-teal-600 hover:text-teal-700 transition-colors">View Detail &rarr;</a>` : ''}
                        </div>
                    `
                });
            }

            // 4. Cập nhật Sidebar badge
            loadUnreadSummary();
        });

        // Thêm SignalR cho Chat để cập nhật Message badge
        const chatConnection = new signalR.HubConnectionBuilder()
            .withUrl("http://localhost:5207/chatHub", {
                accessTokenFactory: () => LAYOUT_TOKEN
            })
            .withAutomaticReconnect()
            .build();

        chatConnection.on("ReceiveMessage", function() {
            loadUnreadSummary();
        });

        connection.on("AccountLockedOut", () => {
            localStorage.setItem("AccountLocked", "true");
            Swal.fire({
                icon: 'error',
                title: 'Account Locked',
                text: 'Your account has been locked due to a policy violation. You will be logged out automatically.',
                timer: 5000,
                timerProgressBar: true,
                showConfirmButton: false,
                allowOutsideClick: false,
                allowEscapeKey: false
            }).then(() => {
                document.getElementById('global-logout-form').submit();
            });
        });

        connection.start().catch(err => console.error("SignalR Error: ", err));
        chatConnection.start().catch(err => console.error("Chat SignalR Error: ", err));

        async function loadUnreadSummary() {
            if (!LAYOUT_TOKEN) return;
            try {
                const response = await fetch("http://localhost:5207/api/Notification/unread-summary", {
                    headers: { 'Authorization': `Bearer ${LAYOUT_TOKEN}` }
                });
                if (response.ok) {
                    const data = await response.json();
                    
                    // Cập nhật Sidebar Notification Badge
                    const sidebarNotiBadge = document.getElementById('sidebar-noti-badge');
                    if (sidebarNotiBadge) {
                        if (data.notificationCount > 0) sidebarNotiBadge.classList.remove('hidden');
                        else sidebarNotiBadge.classList.add('hidden');
                    }

                    // Cập nhật Sidebar Message Badge
                    const sidebarMsgBadge = document.getElementById('sidebar-msg-badge');
                    if (sidebarMsgBadge) {
                        if (data.chatCount > 0) sidebarMsgBadge.classList.remove('hidden');
                        else sidebarMsgBadge.classList.add('hidden');
                    }

                    // Cập nhật Header chuông badge (nếu có)
                    const headerNotiBadge = document.getElementById('noti-badge');
                    if (headerNotiBadge) {
                        if (data.notificationCount > 0) headerNotiBadge.classList.remove('hidden');
                        else headerNotiBadge.classList.add('hidden');
                    }
                }


            } catch (err) { console.error("Summary error:", err); }
        }

        async function loadTopNotifications() {
            const container = document.getElementById('notification-items-container');
            if (!container) return;

            if (!LAYOUT_TOKEN || LAYOUT_TOKEN === "") {
                container.innerHTML = `<div class="p-4 text-center text-xs text-slate-400">Please log in</div>`;
                return;
            }

            try {
                const response = await fetch("http://localhost:5207/api/Notification", {
                    headers: { 'Authorization': `Bearer ${LAYOUT_TOKEN}` }
                });

                if (response.ok) {
                    const data = await response.json();
                    const top3 = data.slice(0, 3);

                    if (top3.length === 0) {
                        container.innerHTML = `<div class="px-4 py-8 text-center text-slate-400 text-sm">No new notifications</div>`;
                        return;
                    }
                    container.innerHTML = top3.map(n => `
                        <div class="p-4 border-b border-slate-50 hover:bg-slate-50 transition-colors cursor-pointer" onclick="location.href='${n.linkAction ? n.linkAction : '/Notification'}'">
                            <div class="flex gap-3">
                                <div class="flex-1">
                                    <div class="flex items-center gap-2">
                                        ${!n.isRead ? '<span class="w-2 h-2 bg-primary rounded-full shrink-0"></span>' : ''}
                                        <p class="text-xs font-bold text-slate-800 truncate">${n.title}</p>
                                    </div>
                                    <p class="text-[11px] text-slate-500 mt-1 line-clamp-2">${n.content}</p>
                                    <div class="flex justify-between items-center mt-2">
                                        <p class="text-[9px] text-slate-300 uppercase font-medium">
                                            ${new Date(n.createdAt).toLocaleTimeString('en-US')}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `).join('');
                }
            } catch (err) {
                console.error("Fetch error:", err);
                container.innerHTML = `<div class="p-4 text-center text-xs text-red-400">Server connection error</div>`;
            }
        }

        document.addEventListener("DOMContentLoaded", () => {
            loadTopNotifications();
            loadUnreadSummary();

            // Create beautiful top progress bar element
            const progressBar = document.createElement('div');
            progressBar.id = 'top-progress-bar';
            document.body.appendChild(progressBar);

            // Intercept internal sidebar & system navigation clicks for high-end loading feedback
            document.querySelectorAll('a').forEach(link => {
                const href = link.getAttribute('href');
                if (href && href.startsWith('/') && !href.startsWith('#') && !link.getAttribute('target')) {
                    link.addEventListener('click', (e) => {
                        if (e.metaKey || e.ctrlKey) return;
                        
                        // Slide progress bar to 70% instantly
                        progressBar.style.width = '70%';
                        
                        // Gently dim and scale-out the active content area
                        const mainContent = document.querySelector('main');
                        if (mainContent) {
                            mainContent.style.transition = 'opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';
                            mainContent.style.opacity = '0.5';
                            mainContent.style.transform = 'scale(0.995)';
                        }
                    });
                }
            });
        });
    </script>
</body>
</html>
