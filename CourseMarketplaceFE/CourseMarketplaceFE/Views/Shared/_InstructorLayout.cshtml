@{
    var tokenForLayout = Context.Request.Cookies["AccessToken"] ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn Instructor</title>
    <link rel="icon" type="image/png" href="~/img/default-avatar.png" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
	<!-- Cloudinary -->
	<link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
    <link rel="dns-prefetch" href="https://res.cloudinary.com">
    
    <!-- Quill Rich Text Editor CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#006a62",
                        "primary-container": "#43e8d8",
                        "on-primary": "#ffffff",
                        "secondary": "#006b60",
                        "surface": "#f0fcfb",
                        "on-surface": "#131d1e",
                        "surface-container-low": "#eaf6f5",
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"]
                    }
                }
            }
        }
    </script>
    <script>
        const LAYOUT_TOKEN = '@tokenForLayout';
    </script>

    <style>
        /* Custom styles for Quills editor to match Tailwind */
        .ql-toolbar.ql-snow { border-radius: 0.5rem 0.5rem 0 0; border-color: #e2e8f0; background-color: #f8fafc; }
        .ql-container.ql-snow { border-radius: 0 0 0.5rem 0.5rem; border-color: #e2e8f0; min-height: 150px; font-family: 'Inter', sans-serif; }

        /* Top Progress Bar Page Transition */
        #top-progress-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #006a62, #43e8d8, #006b60);
            z-index: 9999;
            width: 0%;
            transition: width 0.4s cubic-bezier(0.08, 0.82, 0.17, 1);
            box-shadow: 0 0 8px #006a62;
            pointer-events: none;
        }

        /* Premium Page Entry Transition */
        @@keyframes pageFadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .page-transition-enter {
            animation: pageFadeIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="bg-slate-50 font-body text-on-surface antialiased flex h-screen overflow-hidden">

    <!-- SIDEBAR -->
    <aside class="w-64 bg-white border-r border-slate-200 flex-shrink-0 flex flex-col hidden md:flex">
        <a href="/InstructorCourse" class="h-20 flex items-center px-6 hover:bg-slate-50 transition-colors">
            <div class="flex flex-col">
                <span class="text-xl font-headline font-extrabold text-primary">LinkedLearn</span>
                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Instructor Studio</span>
            </div>
        </a>
        
        @{
            bool isIndex = currentAction == "Index" && currentController == "InstructorCourse";
            bool isCreate = currentAction == "Create" && currentController == "InstructorCourse";
            bool isEditor = currentAction == "Editor" && currentController == "InstructorCourse";
            bool isMyCourses = isIndex || isCreate;
            bool isCurriculumEditor = isEditor;
        }
        
        @{
            var approvalStatus = Context.Request.Cookies["InstructorApprovalStatus"];
            bool isApproved = approvalStatus == "Approved";
            string disabledClass = !isApproved ? "opacity-50 pointer-events-none cursor-not-allowed" : "";
        }
        
        <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto custom-scrollbar">
            <a href="/InstructorCourse" class="flex items-center gap-3 px-4 py-3 @(isMyCourses ? "bg-primary/10 text-primary" : "text-slate-600 hover:bg-slate-50") rounded-xl transition-colors relative">
                @if (isMyCourses) {
                    <span class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-primary rounded-r-full"></span>
                }
                <span class="material-symbols-outlined text-[20px]">dashboard</span>
                <span class="text-sm @(isMyCourses ? "font-bold" : "font-semibold")">Dashboard</span>
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-xl transition-colors @disabledClass">
                <span class="material-symbols-outlined text-[20px]">bar_chart</span>
                <span class="text-sm font-semibold">Analytics</span>
            </a>

            @{
                bool isTransaction = currentController == "Transaction" && (currentAction == "Instructor" || currentAction == "InstructorDetail");
            }
            <a href="/Transaction/Instructor" class="flex items-center gap-3 px-4 py-3 @(isTransaction ? "bg-primary/10 text-primary" : "text-slate-600 hover:bg-slate-50") rounded-xl transition-colors relative @disabledClass">
                @if (isTransaction) {
                    <span class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-primary rounded-r-full"></span>
                }
                <span class="material-symbols-outlined text-[20px]">account_balance_wallet</span>
                <span class="text-sm @(isTransaction ? "font-bold" : "font-semibold")">Earnings</span>
            </a>

            @{
                bool isNotifications = currentAction == "Notifications" && currentController == "Instructor";
            }
            <a href="/Instructor/Notifications"
               class="flex items-center gap-3 px-4 py-3 @(isNotifications ? "bg-primary/10 text-primary" : "text-slate-600 hover:bg-slate-50") rounded-xl transition-colors relative @disabledClass">
                @if (isNotifications)
                {
                    <span class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-primary rounded-r-full"></span>
                }
                <div class="relative">
                    <span class="material-symbols-outlined text-[20px]">notifications</span>
                    <span id="sidebar-noti-badge" class="hidden absolute -top-1 -right-1 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-white"></span>
                </div>
                <span class="text-sm @(isNotifications ? "font-bold" : "font-semibold")">Notifications</span>
            </a>

            @{
                bool isChat = currentController == "Chat";
            }
            <a href="/Chat/Instructor"
               class="flex items-center gap-3 px-4 py-3 @(isChat ? "bg-primary/10 text-primary" : "text-slate-600 hover:bg-slate-50") rounded-xl transition-colors relative @disabledClass">
                @if (isChat)
                {
                    <span class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-primary rounded-r-full"></span>
                }
                <div class="relative">
                    <span class="material-symbols-outlined text-[20px]">chat_bubble</span>
                    <span id="sidebar-msg-badge" class="hidden absolute -top-1 -right-1 w-2.5 h-2.5 bg-red-500 rounded-full border-2 border-white"></span>
                </div>
                <span class="text-sm @(isChat ? "font-bold" : "font-semibold")">Messages</span>
            </a>
            
            <div class="h-px bg-slate-200 my-4 mx-2"></div>

            <a href="/" class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-xl transition-colors">
                <span class="material-symbols-outlined text-[20px]">school</span>
                <span class="text-sm font-semibold">View as Learner</span>
            </a>

            <a href="#" class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-xl transition-colors">
                <span class="material-symbols-outlined text-[20px]">help</span>
                <span class="text-sm font-semibold">Support</span>
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-3 text-slate-600 hover:bg-slate-50 rounded-xl transition-colors">
                <span class="material-symbols-outlined text-[20px]">menu_book</span>
                <span class="text-sm font-semibold">Resources</span>
            </a>
            @{
                bool isSettings = currentController == "Instructor" && currentAction == "ApplicationStatus";
            }
            <a href="/Instructor/ApplicationStatus" class="flex items-center gap-3 px-4 py-3 @(isSettings ? "bg-primary/10 text-primary" : "text-slate-600 hover:bg-slate-50") rounded-xl transition-colors relative">
                @if (isSettings) {
                    <span class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-primary rounded-r-full"></span>
                }
                <span class="material-symbols-outlined text-[20px]">settings</span>
                <span class="text-sm @(isSettings ? "font-bold" : "font-semibold")">Settings</span>
            </a>
        </nav>
        
        <div class="p-4 border-t border-slate-200">
            @{
                var userName = Context.Request.Cookies["UserName"] ?? "Instructor";
                var avatarUrl = Context.Request.Cookies["AvatarUrl"];
            }
            <div class="flex items-center gap-3 p-2 rounded-xl hover:bg-slate-50 transition-colors">
                <a asp-controller="Account" asp-action="Profile" class="hover:scale-105 transition-all">
                    @await Html.PartialAsync("_UserAvatar", new { 
                        Url = avatarUrl, 
                        Role = "instructor", 
                        Name = userName, 
                        Size = "md",
                        ShowFrame = true,
                        FrameUrl = ""
                    })
                </a>
                <div class="flex flex-col flex-1 overflow-hidden">
                    <span class="text-xs font-bold text-slate-700 truncate">Hi, @userName</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-[10px] text-red-500 hover:underline font-medium bg-transparent border-none p-0 cursor-pointer text-left">Logout</button>
                    </form>
                </div>
            </div>
        </div>
    </aside>

    <!-- MAIN WRAPPER -->
    <div class="flex-1 flex flex-col h-full overflow-hidden">
        


        <!-- MAIN CONTENT AREA -->
        <main role="main" class="flex-1 overflow-y-auto bg-slate-50 page-transition-enter">
            @RenderBody()
        </main>
    </div>

    <!-- Quill JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        function toggleNoti() {
            const box = document.getElementById('noti-box');
            box.classList.toggle('hidden');
            if (!box.classList.contains('hidden')) {
                document.getElementById('noti-badge').classList.add('hidden');
            }
        }

        window.addEventListener('click', function(e) {
            const dropdown = document.getElementById('notification-dropdown');
            if (dropdown && !dropdown.contains(e.target)) {
                document.getElementById('noti-box').classList.add('hidden');
            }
        });

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("http://localhost:5207/notificationHub", {
                accessTokenFactory: () => LAYOUT_TOKEN
            })
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotification", function (noti) {
            // 1. Hiện chấm đỏ ở chuông
            const badge = document.getElementById('noti-badge');
            if(badge) badge.classList.remove('hidden');

            // 2. Cập nhật danh sách nhỏ ở chuông
            if (typeof loadTopNotifications === "function") loadTopNotifications();

            // 3. KIỂM TRA: Nếu trang hiện tại có hàm prependNotification thì gọi nó ngay
            if (typeof prependNotification === "function") {
                prependNotification(noti);
            }
            else {
                const path = window.location.pathname.toLowerCase();
                if (path.includes("/notification/admin")) {
                    if (typeof loadAdminHistory === "function") loadAdminHistory();
                } else if (path.includes("/notification")) {
                    if (typeof loadNotifications === "function") loadNotifications();
                }
            }

            // 4. Cập nhật Sidebar badge
            loadUnreadSummary();
        });

        // Thêm SignalR cho Chat để cập nhật Message badge
        const chatConnection = new signalR.HubConnectionBuilder()
            .withUrl("http://localhost:5207/chatHub", {
                accessTokenFactory: () => LAYOUT_TOKEN
            })
            .withAutomaticReconnect()
            .build();

        chatConnection.on("ReceiveMessage", function() {
            loadUnreadSummary();
        });

        connection.start().catch(err => console.error("SignalR Error: ", err));
        chatConnection.start().catch(err => console.error("Chat SignalR Error: ", err));

        async function loadUnreadSummary() {
            if (!LAYOUT_TOKEN) return;
            try {
                const response = await fetch("http://localhost:5207/api/Notification/unread-summary", {
                    headers: { 'Authorization': `Bearer ${LAYOUT_TOKEN}` }
                });
                if (response.ok) {
                    const data = await response.json();
                    
                    // Cập nhật Sidebar Notification Badge
                    const sidebarNotiBadge = document.getElementById('sidebar-noti-badge');
                    if (sidebarNotiBadge) {
                        if (data.notificationCount > 0) sidebarNotiBadge.classList.remove('hidden');
                        else sidebarNotiBadge.classList.add('hidden');
                    }

                    // Cập nhật Sidebar Message Badge
                    const sidebarMsgBadge = document.getElementById('sidebar-msg-badge');
                    if (sidebarMsgBadge) {
                        if (data.chatCount > 0) sidebarMsgBadge.classList.remove('hidden');
                        else sidebarMsgBadge.classList.add('hidden');
                    }

                    // Cập nhật Header chuông badge (nếu có)
                    const headerNotiBadge = document.getElementById('noti-badge');
                    if (headerNotiBadge) {
                        if (data.notificationCount > 0) headerNotiBadge.classList.remove('hidden');
                        else headerNotiBadge.classList.add('hidden');
                    }
                }
            } catch (err) { console.error("Summary error:", err); }
        }

        async function loadTopNotifications() {
            const container = document.getElementById('notification-items-container');
            if (!container) return;

            if (!LAYOUT_TOKEN || LAYOUT_TOKEN === "") {
                container.innerHTML = `<div class="p-4 text-center text-xs text-slate-400">Please log in</div>`;
                return;
            }

            try {
                const response = await fetch("http://localhost:5207/api/Notification", {
                    headers: { 'Authorization': `Bearer ${LAYOUT_TOKEN}` }
                });

                if (response.ok) {
                    const data = await response.json();
                    const top3 = data.slice(0, 3);

                    if (top3.length === 0) {
                        container.innerHTML = `<div class="px-4 py-8 text-center text-slate-400 text-sm">No new notifications</div>`;
                        return;
                    }
                    container.innerHTML = top3.map(n => `
                        <div class="p-4 border-b border-slate-50 hover:bg-slate-50 transition-colors cursor-pointer" onclick="location.href='${n.linkAction ? n.linkAction : '/Notification'}'">
                            <div class="flex gap-3">
                                <div class="flex-1">
                                    <div class="flex items-center gap-2">
                                        ${!n.isRead ? '<span class="w-2 h-2 bg-primary rounded-full shrink-0"></span>' : ''}
                                        <p class="text-xs font-bold text-slate-800 truncate">${n.title}</p>
                                    </div>
                                    <p class="text-[11px] text-slate-500 mt-1 line-clamp-2">${n.content}</p>
                                    <div class="flex justify-between items-center mt-2">
                                        <p class="text-[9px] text-slate-300 uppercase font-medium">
                                            ${new Date(n.createdAt).toLocaleTimeString('en-US')}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `).join('');
                }
            } catch (err) {
                console.error("Fetch error:", err);
                container.innerHTML = `<div class="p-4 text-center text-xs text-red-400">Server connection error</div>`;
            }
        }

        document.addEventListener("DOMContentLoaded", () => {
            loadTopNotifications();
            loadUnreadSummary();

            // Create beautiful top progress bar element
            const progressBar = document.createElement('div');
            progressBar.id = 'top-progress-bar';
            document.body.appendChild(progressBar);

            // Intercept internal sidebar & system navigation clicks for high-end loading feedback
            document.querySelectorAll('a').forEach(link => {
                const href = link.getAttribute('href');
                if (href && href.startsWith('/') && !href.startsWith('#') && !link.getAttribute('target')) {
                    link.addEventListener('click', (e) => {
                        if (e.metaKey || e.ctrlKey) return;
                        
                        // Slide progress bar to 70% instantly
                        progressBar.style.width = '70%';
                        
                        // Gently dim and scale-out the active content area
                        const mainContent = document.querySelector('main');
                        if (mainContent) {
                            mainContent.style.transition = 'opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';
                            mainContent.style.opacity = '0.5';
                            mainContent.style.transform = 'scale(0.995)';
                        }
                    });
                }
            });
        });
    </script>
</body>
</html>
