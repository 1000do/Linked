@using System.Net
@{
    var managerName = Context.Request.Cookies["UserName"] ?? "Admin";
    var token = Context.Request.Cookies["AccessToken"] ?? "";
    var userRole = (Context.Request.Cookies["UserRole"] ?? "admin").ToLower();
    var isStaff = userRole == "staff";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn Admin</title>
    <link rel="icon" type="image/png" href="~/img/default-avatar.png" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Fonts: Inter for UI, Manrope for display -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#10b981', // Emerald 500
                        secondary: '#059669', // Emerald 600
                        accent: '#064e3b', // Emerald 900 (Deep)
                    },
                    fontFamily: { 
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        display: ['Manrope', 'system-ui', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; }
        h1, h2, h3, h4, h5, h6, .font-display { font-family: 'Manrope', system-ui, sans-serif; }
        
        /* Custom scrollbar for modern feel */
        .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
        
        aside .custom-scrollbar::-webkit-scrollbar-thumb { background: transparent; }
        aside:hover .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; }
        
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20;
        }

        /* Smooth Nav Item Transition */
        .nav-item {
            transition: all 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        .nav-link-active {
            background-color: #ecfdf5; /* emerald-50 */
            color: #047857 !important; /* emerald-700 */
            font-weight: 600;
        }
        
        .nav-link-active .material-symbols-outlined {
            font-variation-settings: 'FILL' 1;
            color: #059669 !important; /* emerald-600 */
            transform: scale(1.05);
        }

        /* Top Progress Bar Page Transition */
        #top-progress-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #10b981, #34d399, #059669);
            z-index: 9999;
            width: 0%;
            transition: width 0.4s cubic-bezier(0.08, 0.82, 0.17, 1);
            box-shadow: 0 0 8px #10b981;
            pointer-events: none;
        }

        /* Premium Page Entry Transition */
        @@keyframes pageFadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .page-transition-enter {
            animation: pageFadeIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-slate-50 text-slate-800 flex h-screen overflow-hidden antialiased selection:bg-primary/20 selection:text-primary">

    <!-- SIDEBAR -->
    <aside class="w-[260px] flex flex-col bg-white shrink-0 z-20 relative border-r border-slate-100 shadow-[2px_0_16px_rgba(0,0,0,0.02)]">
        <div class="h-16 flex items-center px-7 border-b border-slate-100">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-emerald-50 rounded-xl flex items-center justify-center border border-emerald-100 shrink-0">
                    <span class="material-symbols-outlined text-emerald-600 text-[18px]">@(isStaff ? "support_agent" : "admin_panel_settings")</span>
                </div>
                <span class="font-display font-extrabold text-slate-800 text-lg tracking-tight leading-none">Linked<span class="text-emerald-500">@(isStaff ? "Staff" : "Admin")</span></span>
            </div>
        </div>
        
        <nav class="flex-1 px-4 py-6 space-y-1.5 overflow-y-auto custom-scrollbar">
            <div class="px-3 mb-3 text-[10px] font-bold text-slate-400 uppercase tracking-wider leading-none">Workspace</div>
            
            <a href="/AdminApproval" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group">
                <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">how_to_reg</span> 
                Instructor Approvals
            </a>
            @if (!isStaff) {
                <a href="/AdminAccount" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group">
                    <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">manage_accounts</span> 
                    Manage Accounts
                </a>
                <a href="/AdminAiService" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group">
                    <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">smart_toy</span> 
                    Manage AI Service
                </a>
            }
            <a href="/AdminModeration/Courses" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group">
                <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">school</span> 
                Course Moderation
            </a>
            <a href="/AdminModeration/Reports" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group">
                <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">flag</span> 
                Report Center
            </a>
            <a href="/Notification/Admin" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group relative">
                <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">notifications</span> 
                Notifications
                <span class="absolute right-3.5 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-rose-500 hidden" id="admin-noti-badge"></span>
            </a>
            @if (!isStaff) {
                <a href="/Coupon/Admin" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group">
                    <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">local_activity</span> 
                    Coupons & Offers
                </a>
            }
            <a href="/Chat/Admin" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group">
                <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">forum</span> 
                Monitor Chats
            </a>
            <a href="/AdminAvatarFrame" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group">
                <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">military_tech</span> 
                Manage Avatar Frames
            </a>

            @if (!isStaff) {
                <div class="px-3 mb-3 mt-8 text-[10px] font-bold text-slate-400 uppercase tracking-wider leading-none">Finance & Transactions</div>
                
                <a href="/AdminFinance" class="nav-item flex items-center gap-3.5 px-3.5 py-2.5 rounded-xl text-[13px] font-medium text-slate-500 hover:text-slate-800 hover:bg-slate-50 group">
                    <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-emerald-500 transition-colors duration-300">monitoring</span> 
                    Revenue Dashboard
                </a>
                <a href="/AdminFinance/InstructorRevenues" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                    <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">payments</span> 
                    Instructor Revenues
                </a>
            }
            
        </nav>

    @{
        var avatarUrl = Context.Request.Cookies["AvatarUrl"];
    }
    <div class="p-4 border-t border-slate-100">
        <div onclick="window.location.href='/AdminProfile'" class="flex items-center gap-3 p-3 rounded-2xl bg-white border border-slate-100 shadow-[0_4px_12px_rgba(0,0,0,0.02)] hover:border-emerald-100 hover:shadow-[0_4px_12px_rgba(16,185,129,0.05)] transition-all duration-300 cursor-pointer">
            <div class="relative shrink-0">
                @await Html.PartialAsync("_UserAvatar", new { 
                    Url = avatarUrl, 
                    Role = isStaff ? "staff" : "admin", 
                    Name = managerName, 
                    Size = "md",
                    ShowFrame = true,
                    FrameUrl = ""
                })
                <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-emerald-500 border-2 border-white rounded-full"></span>
            </div>
            <div class="flex flex-col flex-1 overflow-hidden">
                <span class="layout-manager-name text-xs font-bold text-slate-800 truncate">@managerName</span>
                <span class="text-[10px] text-slate-400 font-medium truncate uppercase tracking-wider mt-0.5">@(isStaff ? "Support Staff" : "Super Admin")</span>
                <form method="post" action="/Account/Logout" class="m-0 mt-1.5" onclick="event.stopPropagation();">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-[11px] text-slate-400 hover:text-rose-500 font-semibold flex items-center gap-1 bg-transparent border-none p-0 cursor-pointer text-left transition-colors duration-200">
                        Logout
                    </button>
                </form>
            </div>
        </div>
    </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 flex flex-col overflow-hidden bg-[#f8fafc]">
        <!-- HEADER -->
        <header class="h-16 border-b border-slate-200 flex items-center justify-between px-8 bg-white shrink-0 shadow-sm z-10">
            <div class="flex items-center gap-4">
                <h2 class="font-display font-bold text-lg text-slate-900 tracking-tight">@ViewData["PageHeader"]</h2>
            </div>
            
            <div class="flex items-center gap-5">
                @await RenderSectionAsync("HeaderActions", required: false)
                


                <div class="flex items-center gap-3 pl-5 border-l border-slate-200">
                    <div class="flex flex-col items-end">
                        <span class="layout-manager-name text-xs font-bold text-slate-900">@managerName</span>
                        <span class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest">@(isStaff ? "Support Staff" : "Super Admin")</span>
                    </div>
                    @await Html.PartialAsync("_UserAvatar", new { 
                        Url = avatarUrl, 
                        Role = isStaff ? "staff" : "admin", 
                        Name = managerName, 
                        Size = "sm",
                        ShowFrame = true,
                        FrameUrl = ""
                    })
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <div class="flex-1 overflow-auto custom-scrollbar p-8 page-transition-enter">
            @RenderBody()
        </div>
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const currentPath = window.location.pathname.toLowerCase();
            document.querySelectorAll('.nav-item').forEach(link => {
                const href = link.getAttribute('href').toLowerCase();
                // Matching logic for active route
                if (href === currentPath || 
                   (currentPath.includes('/adminapproval') && href.includes('/adminapproval')) ||
                   (currentPath.includes('/adminaccount') && href.includes('/adminaccount')) ||
                   (currentPath.includes('/instructorrevenues') && href.includes('/instructorrevenues'))) {
                    link.classList.add('nav-link-active');
                }
            });

            // Create beautiful top progress bar element
            const progressBar = document.createElement('div');
            progressBar.id = 'top-progress-bar';
            document.body.appendChild(progressBar);

            // Intercept internal sidebar & system navigation clicks for high-end loading feedback
            document.querySelectorAll('a').forEach(link => {
                const href = link.getAttribute('href');
                if (href && href.startsWith('/') && !href.startsWith('#') && !link.getAttribute('target')) {
                    link.addEventListener('click', (e) => {
                        if (e.metaKey || e.ctrlKey) return;
                        
                        // Slide progress bar to 70% instantly
                        progressBar.style.width = '70%';
                        
                        // Gently dim and scale-out the active content area
                        const mainContent = document.querySelector('main');
                        if (mainContent) {
                            mainContent.style.transition = 'opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';
                            mainContent.style.opacity = '0.5';
                            mainContent.style.transform = 'scale(0.995)';
                        }
                    });
                }
            });
        });
    </script>
    <!-- SweetAlert2 for general use -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Prevent SweetAlert from altering the body height/padding, which breaks the fixed layout
        window.Swal = window.Swal.mixin({
            heightAuto: false,
            scrollbarPadding: false
        });

        document.addEventListener("DOMContentLoaded", () => {
            const ADMIN_LAYOUT_TOKEN = `@Html.Raw(token)`;
            window.ADMIN_LAYOUT_TOKEN = ADMIN_LAYOUT_TOKEN;
            
            if (ADMIN_LAYOUT_TOKEN) {
                // Initialize unread badge and top notifications on load
                loadAdminTopNotifications();

                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/notificationHub", {
                        accessTokenFactory: () => ADMIN_LAYOUT_TOKEN
                    })
                    .withAutomaticReconnect()
                    .build();

                connection.on("ReceiveNotification", function (noti) {
                    // 1. Show red dot at sidebar and header notification menu
                    const adminBadge = document.getElementById('admin-noti-badge');
                    if (adminBadge) adminBadge.classList.remove('hidden');
                    const headerBadge = document.getElementById('header-admin-noti-badge');
                    if (headerBadge) headerBadge.classList.remove('hidden');

                    // Reload dropdown list
                    if (typeof loadAdminTopNotifications === 'function') loadAdminTopNotifications();

                    // Dispatch event for child views (like Notification/Admin page to reload list)
                    document.dispatchEvent(new CustomEvent("ReceiveNotificationEvent"));

                    // Show a premium real-time toast alert
                    if (noti && noti.title) {
                        const truncateText = (text, maxLength = 20) => {
                            if (!text) return "";
                            return text.length > maxLength ? text.substring(0, maxLength) + "..." : text;
                        };

                        const displayTitle = truncateText(noti.title, 20);
                        const displayContent = truncateText(noti.content, 20);

                         const Toast = Swal.mixin({
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 6000,
                            timerProgressBar: true,
                            didOpen: (toast) => {
                                toast.addEventListener('mouseenter', Swal.stopTimer);
                                toast.addEventListener('mouseleave', Swal.resumeTimer);
                                
                                // Make entire toast clickable
                                toast.style.cursor = 'pointer';
                                toast.addEventListener('click', (e) => {
                                    if (e.target.tagName !== 'A' && e.target.tagName !== 'BUTTON') {
                                        const targetUrl = noti.linkAction || '/Notification/Admin';
                                        window.location.href = targetUrl;
                                    }
                                });
                            }
                        });

                        Toast.fire({
                            icon: 'info',
                            title: displayTitle,
                            html: `
                                <div class="text-left font-body">
                                    <p class="text-[12px] text-slate-600 mt-1 leading-relaxed">${displayContent}</p>
                                    ${noti.linkAction ? `<a href="${noti.linkAction}" class="inline-block mt-2 text-[12px] font-bold text-emerald-600 hover:text-emerald-700 transition-colors">View Detail &rarr;</a>` : ''}
                                </div>
                            `
                        });
                    }
                });

                connection.start().catch(err => console.error("Admin Notification Hub connection error: ", err));
            }
        });



        function timeSince(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            let interval = seconds / 31536000;
            if (interval > 1) return Math.floor(interval) + " years ago";
            interval = seconds / 2592000;
            if (interval > 1) return Math.floor(interval) + " months ago";
            interval = seconds / 86400;
            if (interval > 1) return Math.floor(interval) + " days ago";
            interval = seconds / 3600;
            if (interval > 1) return Math.floor(interval) + " hours ago";
            interval = seconds / 60;
            if (interval > 1) return Math.floor(interval) + " mins ago";
            return Math.floor(seconds) + " seconds ago";
        }

        async function loadAdminTopNotifications() {
            const sidebarBadge = document.getElementById('admin-noti-badge');
            if (!window.ADMIN_LAYOUT_TOKEN) return;

            try {
                const response = await fetch("/Notification/GetAllAdmin");
                if (response.ok) {
                    const result = await response.json();
                    const notifications = result.data?.items || [];
                    const hasUnread = notifications.some(n => n.isRead === false);
                    if (sidebarBadge) hasUnread ? sidebarBadge.classList.remove('hidden') : sidebarBadge.classList.add('hidden');
                }
            } catch (err) {
                console.error("Fetch error:", err);
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>