@using System.Net
@{
    var managerName = Context.Request.Cookies["UserName"] ?? "Admin";
    var token = Context.Request.Cookies["AccessToken"] ?? "";
    var userRole = (Context.Request.Cookies["UserRole"] ?? "admin").ToLower();
    var isStaff = userRole == "staff";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LinkedLearn Admin</title>
    <link rel="icon" type="image/png" href="~/img/default-avatar.png" />

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Fonts: Inter for UI, Manrope for display -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#10b981', // Emerald 500
                        secondary: '#059669', // Emerald 600
                        accent: '#064e3b', // Emerald 900 (Deep)
                    },
                    fontFamily: { 
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        display: ['Manrope', 'system-ui', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; }
        h1, h2, h3, h4, h5, h6, .font-display { font-family: 'Manrope', system-ui, sans-serif; }
        
        /* Custom scrollbar for modern feel */
        .custom-scrollbar::-webkit-scrollbar { width: 5px; height: 5px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        /* Dark scrollbar for Sidebar */
        aside .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.12); }
        aside .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.22); }
        
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20;
        }

        /* Smooth Nav Item Transition */
        .nav-item {
            border-left: 3px solid transparent;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-link-active {
            background: linear-gradient(90deg, rgba(16, 185, 129, 0.12) 0%, rgba(16, 185, 129, 0.01) 100%);
            color: #34d399 !important; /* emerald-400 */
            font-weight: 600;
            border-left: 3px solid #10b981 !important;
            box-shadow: inset 1px 0 0 0 rgba(16, 185, 129, 0.15);
        }
        
        .nav-link-active .material-symbols-outlined {
            font-variation-settings: 'FILL' 1;
            color: #34d399 !important;
            transform: scale(1.05);
        }

        /* Top Progress Bar Page Transition */
        #top-progress-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #10b981, #34d399, #059669);
            z-index: 9999;
            width: 0%;
            transition: width 0.4s cubic-bezier(0.08, 0.82, 0.17, 1);
            box-shadow: 0 0 8px #10b981;
            pointer-events: none;
        }

        /* Premium Page Entry Transition */
        @@keyframes pageFadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .page-transition-enter {
            animation: pageFadeIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-slate-50 text-slate-800 flex h-screen overflow-hidden antialiased selection:bg-primary/20 selection:text-primary">

    <!-- SIDEBAR -->
    <aside class="w-64 flex flex-col bg-[#0b0f19] shrink-0 z-20 relative border-r border-slate-800/60 shadow-[4px_0_24px_rgba(0,0,0,0.2)]">
        <div class="h-16 flex items-center px-6 border-b border-slate-800/40 bg-slate-950/20">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 bg-gradient-to-br from-emerald-400 to-emerald-600 rounded-lg flex items-center justify-center shadow-[0_0_12px_rgba(16,185,129,0.35)] shrink-0">
                    <span class="material-symbols-outlined text-white text-[18px]">@(isStaff ? "support_agent" : "admin_panel_settings")</span>
                </div>
                <span class="font-display font-extrabold text-white text-base tracking-tight leading-none">Linked<span class="text-[#34d399]">@(isStaff ? "Staff" : "Admin")</span></span>
            </div>
        </div>
        
        <nav class="flex-1 px-4 py-6 space-y-1.5 overflow-y-auto custom-scrollbar bg-gradient-to-b from-[#0b0f19] to-[#0d1222]">
            <div class="px-3.5 mb-2 text-[9px] font-bold text-slate-500 uppercase tracking-widest leading-none">Workspace</div>
            
            <a href="/AdminApproval" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">how_to_reg</span> 
                Instructor Approvals
            </a>
            @if (!isStaff) {
                <a href="/AdminAccount" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                    <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">manage_accounts</span> 
                    Manage Accounts
                </a>
            }
            <a href="/AdminModeration/Courses" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">school</span> 
                Course Moderation
            </a>
            <a href="/AdminModeration/Reports" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">flag</span> 
                Report Center
            </a>
            <a href="/Notification/Admin" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group relative">
                <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">notifications</span> 
                Notifications
                <span class="absolute right-3.5 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-red-500 hidden" id="admin-noti-badge"></span>
            </a>
            @if (!isStaff) {
                <a href="/Coupon/Admin" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                    <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">local_activity</span> 
                    Coupons & Offers
                </a>
            }
            <a href="/Chat/Admin" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">forum</span> 
                Monitor Chats
            </a>
            <a href="/AdminAvatarFrame" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">military_tech</span> 
                Manage Avatar Frames
            </a>

            @if (!isStaff) {
                <div class="px-3.5 mb-2 mt-6 text-[9px] font-bold text-slate-500 uppercase tracking-widest leading-none">Finance & Transactions</div>
                
                <a href="/AdminFinance" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                    <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">monitoring</span> 
                    Revenue Dashboard
                </a>
                <a href="/Transaction/Admin" class="nav-item flex items-center gap-3 px-3.5 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-100 hover:bg-slate-800/40 transition-all group">
                    <span class="material-symbols-outlined text-[20px] text-slate-500 group-hover:text-emerald-400 transition-all duration-300">receipt_long</span> 
                    Transaction Logs
                </a>
            }
            
        </nav>

    @{
        var avatarUrl = Context.Request.Cookies["AvatarUrl"];
    }
    <div class="p-3 border-t border-slate-800/40 bg-[#0d1222] shrink-0">
        <div class="flex items-center gap-3 p-3 rounded-2xl bg-slate-900/60 border border-slate-800/80 shadow-md backdrop-blur-md hover:border-slate-700/80 transition-all duration-300">
            <div class="relative shrink-0">
                @await Html.PartialAsync("_UserAvatar", new { 
                    Url = avatarUrl, 
                    Role = isStaff ? "staff" : "admin", 
                    Name = managerName, 
                    Size = "md",
                    ShowFrame = true,
                    FrameUrl = ""
                })
                <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-emerald-500 border-2 border-[#0d1222] rounded-full shadow-[0_0_8px_#10b981]"></span>
            </div>
            <div class="flex flex-col flex-1 overflow-hidden">
                <span class="text-xs font-bold text-slate-200 truncate">@managerName</span>
                <span class="text-[9px] text-slate-500 font-medium truncate uppercase tracking-wider">@(isStaff ? "Support Staff" : "Super Admin")</span>
                <form method="post" action="/Account/Logout" class="m-0 mt-1">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-[10px] text-red-400 hover:text-red-300 font-semibold flex items-center gap-1 bg-transparent border-none p-0 cursor-pointer text-left transition-colors duration-200">
                        <span class="material-symbols-outlined text-[12px] font-normal leading-none">logout</span>
                        Logout
                    </button>
                </form>
            </div>
        </div>
    </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 flex flex-col overflow-hidden bg-[#f8fafc]">
        <!-- HEADER -->
        <header class="h-16 border-b border-slate-200 flex items-center justify-between px-8 bg-white shrink-0 shadow-sm z-10">
            <div class="flex items-center gap-4">
                <h2 class="font-display font-bold text-lg text-slate-900 tracking-tight">@ViewData["PageHeader"]</h2>
            </div>
            
            <div class="flex items-center gap-5">
                @await RenderSectionAsync("HeaderActions", required: false)
                
                <div class="flex items-center gap-3 pl-5 border-l border-slate-200">
                    <div class="flex flex-col items-end">
                        <span class="text-xs font-bold text-slate-900">@managerName</span>
                        <span class="text-[10px] font-semibold text-slate-400 uppercase tracking-widest">@(isStaff ? "Support Staff" : "Super Admin")</span>
                    </div>
                    @await Html.PartialAsync("_UserAvatar", new { 
                        Url = avatarUrl, 
                        Role = isStaff ? "staff" : "admin", 
                        Name = managerName, 
                        Size = "sm",
                        ShowFrame = true,
                        FrameUrl = ""
                    })
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <div class="flex-1 overflow-auto custom-scrollbar p-8 page-transition-enter">
            @RenderBody()
        </div>
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const currentPath = window.location.pathname.toLowerCase();
            document.querySelectorAll('.nav-item').forEach(link => {
                const href = link.getAttribute('href').toLowerCase();
                // Matching logic for active route
                if (href === currentPath || 
                   (currentPath.includes('/adminapproval') && href.includes('/adminapproval')) ||
                   (currentPath.includes('/adminaccount') && href.includes('/adminaccount')) ||
                   (currentPath.includes('/transaction') && href.includes('/transaction/admin'))) {
                    link.classList.add('nav-link-active');
                }
            });

            // Create beautiful top progress bar element
            const progressBar = document.createElement('div');
            progressBar.id = 'top-progress-bar';
            document.body.appendChild(progressBar);

            // Intercept internal sidebar & system navigation clicks for high-end loading feedback
            document.querySelectorAll('a').forEach(link => {
                const href = link.getAttribute('href');
                if (href && href.startsWith('/') && !href.startsWith('#') && !link.getAttribute('target')) {
                    link.addEventListener('click', (e) => {
                        if (e.metaKey || e.ctrlKey) return;
                        
                        // Slide progress bar to 70% instantly
                        progressBar.style.width = '70%';
                        
                        // Gently dim and scale-out the active content area
                        const mainContent = document.querySelector('main');
                        if (mainContent) {
                            mainContent.style.transition = 'opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';
                            mainContent.style.opacity = '0.5';
                            mainContent.style.transform = 'scale(0.995)';
                        }
                    });
                }
            });
        });
    </script>
    <!-- SweetAlert2 for general use -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>