@model CourseMarketplaceFE.Models.CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="min-h-screen pt-8 pb-16 bg-surface">
    <div class="max-w-6xl mx-auto px-4">

        @* ── HEADER ──────────────────────────────────────────────────────── *@
        <div class="mb-8">
            <h1 class="text-3xl font-headline font-extrabold text-on-surface flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-4xl" style='font-variation-settings:"FILL" 1;'>shopping_cart</span>
                My Shopping Cart
            </h1>
            <p class="text-slate-500 mt-1 text-sm">@Model.Items.Count courses waiting for you</p>
        </div>

        @* ── TOAST MESSAGES ───────────────────────────────────────────────── *@
        <div id="cart-toasts-container">
            @if (TempData["CartSuccess"] != null)
            {
                <div class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3">
                    <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                    <span class="text-sm font-medium text-emerald-700">@TempData["CartSuccess"]</span>
                </div>
            }
            @if (TempData["CartError"] != null)
            {
                <div class="mb-6 flex items-center gap-3 bg-red-50 border border-red-200 rounded-xl px-4 py-3">
                    <span class="material-symbols-outlined text-red-500">error</span>
                    <span class="text-sm font-medium text-red-700">@TempData["CartError"]</span>
                </div>
            }
        </div>

        <div id="cart-main-container">
            @if (!Model.Items.Any())
            {
                @* ── GIỎ HÀNG RỖNG ──────────────────────────────────────────── *@
                <div class="flex flex-col items-center justify-center py-24 text-center">
                    <div class="w-28 h-28 bg-slate-100 rounded-full flex items-center justify-center mb-6">
                        <span class="material-symbols-outlined text-slate-300 text-6xl">shopping_cart</span>
                    </div>
                    <h2 class="text-xl font-bold text-slate-700 mb-2">Your cart is empty</h2>
                    <p class="text-slate-400 text-sm mb-6">Explore interesting courses and add them to your cart!</p>
                    <a href="/"
                       class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all text-sm">
                        <span class="material-symbols-outlined text-lg">explore</span>
                        Explore Courses
                    </a>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
                    @* ════ CỘT TRÁI — DANH SÁCH KHÓA HỌC ════ *@
                    <div class="lg:col-span-2 space-y-4">
                        @foreach (var item in Model.Items)
                        {
                            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 flex gap-4 hover:shadow-md transition-shadow group">
    
                                @* Thumbnail *@
                                <a href="/Course/Details/@item.CourseId" class="shrink-0">
                                    @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                    {
                                        <img src="@item.ThumbnailUrl" alt="@item.Title"
                                             class="w-32 h-20 object-cover rounded-xl bg-slate-100" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="w-32 h-20 rounded-xl bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
                                            <span class="material-symbols-outlined text-primary text-3xl">school</span>
                                        </div>
                                    }
                                </a>
    
                                @* Thông tin khóa học *@
                                <div class="flex-1 min-w-0">
                                    <a href="/Course/Details/@item.CourseId"
                                       class="font-bold text-slate-800 text-sm leading-snug line-clamp-2 hover:text-primary transition-colors">
                                        @item.Title
                                    </a>
                                    @if (!string.IsNullOrEmpty(item.InstructorName))
                                    {
                                        <p class="text-xs text-slate-400 mt-1 flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">person</span>
                                            @item.InstructorName
                                        </p>
                                    }
                                
                                <div class="mt-2 flex items-baseline gap-2">
                                    @if (!string.IsNullOrEmpty(item.AppliedCouponCode))
                                    {
                                        <span class="text-xs font-semibold text-slate-400 line-through">$@item.OriginalPrice.ToString("N2")</span>
                                        <span class="text-base font-extrabold text-emerald-600">$@item.DiscountedPrice.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-base font-extrabold text-primary">$@item.Price.ToString("N2")</span>
                                    }
                                </div>

                                @* Coupon / Voucher area per item *@
                                @if (!string.IsNullOrEmpty(item.AppliedCouponCode))
                                {
                                    <div class="mt-2 flex items-center gap-2 bg-emerald-50 border border-emerald-100 rounded-xl px-3 py-1.5 w-fit">
                                        <span class="material-symbols-outlined text-emerald-500 text-xs">local_offer</span>
                                        <span class="text-[11px] font-bold text-emerald-700">@item.AppliedCouponCode</span>
                                        <form asp-action="RemoveCoupon" asp-controller="Cart" method="post" class="m-0 inline-flex items-center" onsubmit="handleRemoveCoupon(event)">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="courseId" value="@item.CourseId" />
                                            <button type="submit" class="text-[10px] text-red-500 hover:text-red-700 font-extrabold ml-1.5 transition-colors uppercase">
                                                Remove
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <div class="mt-2">
                                        <form asp-action="ApplyCoupon" asp-controller="Cart" method="post" class="flex items-center gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="courseId" value="@item.CourseId" />
                                            <div class="relative flex-1 max-w-[200px]">
                                                <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-slate-400 text-[16px]">local_offer</span>
                                                <input type="text" name="couponCode" placeholder="Enter coupon code" class="w-full pl-8 pr-3 py-1.5 text-xs font-semibold text-slate-700 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all uppercase placeholder:normal-case placeholder:font-normal" required />
                                            </div>
                                            <button type="submit" class="px-3 py-1.5 bg-primary/10 hover:bg-primary/20 text-primary text-xs font-bold rounded-lg transition-colors">Apply</button>
                                        </form>
                                    </div>
                                }
                            </div>

                            @* Nút xóa *@
                            <div class="shrink-0 flex items-start">
                                <form asp-action="RemoveFromCart" asp-controller="Cart" method="post" onsubmit="handleRemoveFromCart(event)">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="courseId" value="@item.CourseId" />
                                    <button type="submit"
                                            title="Remove from cart"
                                            class="w-9 h-9 rounded-xl flex items-center justify-center text-slate-400 hover:bg-red-50 hover:text-red-500 transition-all">
                                        <span class="material-symbols-outlined text-xl">delete</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                @* ════ CỘT PHẢI — ORDER SUMMARY ════ *@
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 sticky top-24">

                        <h2 class="text-lg font-bold text-slate-800 mb-5 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">receipt_long</span>
                            Order Summary
                        </h2>

                        @* ── PHÂN TÁCH ────────────────────────────────────── *@
                        <div class="border-t border-slate-100 pt-5 space-y-3">

                            @* Tạm tính *@
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-slate-500">Subtotal</span>
                                <span class="font-semibold text-slate-700">$@Model.SubTotal.ToString("N2")</span>
                            </div>

                            @* Giảm giá (chỉ hiện khi > 0) *@
                            @if (Model.HasDiscount)
                            {
                                <div class="flex justify-between items-center text-sm">
                                    <span class="text-emerald-600 flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">local_offer</span>
                                        Discount
                                    </span>
                                    <span class="font-bold text-emerald-600">-$@Model.DiscountAmount.ToString("N2")</span>
                                </div>
                            }

                            @* Tổng thanh toán *@
                            <div class="border-t border-slate-100 pt-3 flex justify-between items-center">
                                <span class="font-bold text-slate-800">Total Price</span>
                                <div class="text-right">
                                    <span class="text-2xl font-extrabold text-primary block">
                                        $@Model.Total.ToString("N2")
                                    </span>
                                </div>
                            </div>
                        </div>

                        @* ── NÚT CHECKOUT ─────────────────────────────────── *@
                        <a href="/Cart/Checkout" id="checkout-btn"
                           class="mt-6 w-full flex items-center justify-center gap-2 py-4 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-xl hover:scale-[1.01] active:scale-[0.99] transition-all duration-300 text-sm uppercase tracking-wider">
                            <span class="material-symbols-outlined text-lg">payment</span>
                            Proceed to Checkout
                        </a>

                        <a href="/"
                           class="mt-3 w-full flex items-center justify-center gap-1.5 py-2.5 text-sm text-slate-500 hover:text-primary font-medium transition-colors">
                            <span class="material-symbols-outlined text-base">arrow_back</span>
                            Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        }
        </div>
    </div>
</div>



<script>
    async function handleRemoveFromCart(event) {
        if (event.currentTarget.dataset.confirmed) {
            return;
        }
        event.preventDefault();
        event.stopPropagation();
        const form = event.currentTarget;

        const confirmResult = await Swal.fire({
            title: 'Remove from cart?',
            text: "Are you sure you want to remove this course from your cart?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Remove',
            cancelButtonText: 'Cancel',
            background: '#ffffff',
            customClass: { popup: 'rounded-2xl shadow-xl' }
        });

        if (confirmResult.isConfirmed) {
            form.dataset.confirmed = "true";
            form.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
        }
    }

    async function handleRemoveCoupon(event) {
        if (event.currentTarget.dataset.confirmed) {
            return;
        }
        event.preventDefault();
        event.stopPropagation();
        const form = event.currentTarget;

        const confirmResult = await Swal.fire({
            title: 'Remove coupon?',
            text: "Are you sure you want to remove this coupon?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Remove',
            cancelButtonText: 'Cancel',
            background: '#ffffff',
            customClass: { popup: 'rounded-2xl shadow-xl' }
        });

        if (confirmResult.isConfirmed) {
            form.dataset.confirmed = "true";
            form.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
        }
    }



    // Intercept form submissions inside cart-main-container for AJAX updates
    document.addEventListener('submit', async function(e) {
        const form = e.target;
        if (form.closest('#cart-main-container') || form.id === 'manual-coupon-form') {
            if (form.id === 'checkout-form') return;
            
            e.preventDefault();
            
            const submitBtn = form.querySelector('button[type="submit"]');
            let originalContent = '';
            if (submitBtn) {
                originalContent = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[16px] mr-1">sync</span>';
            }
            
            try {
                const formData = new FormData(form);
                const action = form.getAttribute('action') || form.action;
                const method = form.getAttribute('method') || form.method || 'POST';
                
                const response = await fetch(action, {
                    method: method,
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });
                
                if (response.ok) {
                    const htmlText = await response.text();
                    await refreshCartDOM(htmlText);
                } else {
                    console.error("Cart AJAX failed.");
                }
            } catch(err) {
                console.error("Error submitting cart action:", err);
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalContent;
                }
            }
        }
    });

    async function refreshCartDOM(htmlText = null) {
        const mainContainer = document.getElementById('cart-main-container');
        const toastsContainer = document.getElementById('cart-toasts-container');
        
        if (mainContainer) {
            mainContainer.style.opacity = '0.5';
            mainContainer.style.transition = 'opacity 0.15s ease';
        }
        
        try {
            const text = htmlText || await (await fetch('/Cart')).text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(text, 'text/html');
            
            const newMain = doc.getElementById('cart-main-container');
            if (newMain && mainContainer) {
                mainContainer.innerHTML = newMain.innerHTML;
            }
            
            const newToasts = doc.getElementById('cart-toasts-container');
            if (newToasts && toastsContainer) {
                toastsContainer.innerHTML = newToasts.innerHTML;

                // Show dynamic Swal toast when fetched via AJAX
                const successText = newToasts.querySelector('.bg-emerald-50 .text-emerald-700')?.textContent?.trim();
                const errorText = newToasts.querySelector('.bg-red-50 .text-red-700')?.textContent?.trim();
                
                if (successText) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: successText,
                        confirmButtonColor: '#006a62',
                        customClass: { popup: 'rounded-2xl shadow-xl' }
                    });
                } else if (errorText) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Notification',
                        text: errorText,
                        confirmButtonColor: '#ef4444',
                        customClass: { popup: 'rounded-2xl shadow-xl' }
                    });
                }
            }
            

            
            // Dispatch global event so the header badge and header mini-dropdown updates too!
            document.dispatchEvent(new CustomEvent('cartUpdated'));
        } catch(err) {
            console.error("Error refreshing cart DOM:", err);
        } finally {
            if (mainContainer) {
                mainContainer.style.opacity = '1';
            }
        }
    }
</script>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            @if (TempData["CartSuccess"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: '@Html.Raw(TempData["CartSuccess"].ToString().Replace("'", "\\'"))',
                    confirmButtonColor: '#006a62'
                });
                </text>
            }

            @if (TempData["CartError"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Notification',
                    text: '@Html.Raw(TempData["CartError"].ToString().Replace("'", "\\'"))',
                    confirmButtonColor: '#ef4444'
                });
                </text>
            }
        });
    </script>
}
