@model CourseMarketplaceFE.Models.CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="min-h-screen pt-8 pb-16 bg-surface">
    <div class="max-w-6xl mx-auto px-4">

        @* ── HEADER ──────────────────────────────────────────────────────── *@
        <div class="mb-8">
            <h1 class="text-3xl font-headline font-extrabold text-on-surface flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-4xl" style='font-variation-settings:"FILL" 1;'>shopping_cart</span>
                Giỏ hàng của tôi
            </h1>
            <p class="text-slate-500 mt-1 text-sm">@Model.Items.Count khóa học đang chờ bạn</p>
        </div>

        @* ── TOAST MESSAGES (Now handled via SweetAlert2 popup) ── *@

        @if (!Model.Items.Any())
        {
            @* ── GIỎ HÀNG RỖNG ──────────────────────────────────────────── *@
            <div class="flex flex-col items-center justify-center py-24 text-center">
                <div class="w-28 h-28 bg-slate-100 rounded-full flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-slate-300 text-6xl">shopping_cart</span>
                </div>
                <h2 class="text-xl font-bold text-slate-700 mb-2">Giỏ hàng đang trống</h2>
                <p class="text-slate-400 text-sm mb-6">Hãy khám phá các khóa học thú vị và thêm vào giỏ hàng!</p>
                <a href="/"
                   class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all text-sm">
                    <span class="material-symbols-outlined text-lg">explore</span>
                    Khám phá khóa học
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

                @* ════ CỘT TRÁI — DANH SÁCH KHÓA HỌC ════ *@
                <div class="lg:col-span-2 space-y-4">
                    @foreach (var item in Model.Items)
                    {
                        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 flex gap-4 hover:shadow-md transition-shadow group">

                            @* Thumbnail *@
                            <a href="/Course/Details/@item.CourseId" class="shrink-0">
                                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                {
                                    <img src="@item.ThumbnailUrl" alt="@item.Title"
                                         class="w-32 h-20 object-cover rounded-xl bg-slate-100" loading="lazy" />
                                }
                                else
                                {
                                    <div class="w-32 h-20 rounded-xl bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-primary text-3xl">school</span>
                                    </div>
                                }
                            </a>

                            @* Thông tin khóa học *@
                            <div class="flex-1 min-w-0">
                                <a href="/Course/Details/@item.CourseId"
                                   class="font-bold text-slate-800 text-sm leading-snug line-clamp-2 hover:text-primary transition-colors">
                                    @item.Title
                                </a>
                                @if (!string.IsNullOrEmpty(item.InstructorName))
                                {
                                    <p class="text-xs text-slate-400 mt-1 flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">person</span>
                                        @item.InstructorName
                                    </p>
                                }
                                
                                <div class="mt-2 flex items-baseline gap-2">
                                    @if (!string.IsNullOrEmpty(item.AppliedCouponCode))
                                    {
                                        <span class="text-xs font-semibold text-slate-400 line-through">$@item.OriginalPrice.ToString("N2")</span>
                                        <span class="text-base font-extrabold text-emerald-600">$@item.DiscountedPrice.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-base font-extrabold text-primary">$@item.Price.ToString("N2")</span>
                                    }
                                </div>

                                @* Coupon / Voucher area per item *@
                                @if (!string.IsNullOrEmpty(item.AppliedCouponCode))
                                {
                                    <div class="mt-2 flex items-center gap-2 bg-emerald-50 border border-emerald-100 rounded-xl px-3 py-1.5 w-fit">
                                        <span class="material-symbols-outlined text-emerald-500 text-xs">local_offer</span>
                                        <span class="text-[11px] font-bold text-emerald-700">@item.AppliedCouponCode</span>
                                        <form asp-action="RemoveCoupon" asp-controller="Cart" method="post" class="m-0 inline-flex items-center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="courseId" value="@item.CourseId" />
                                            <button type="submit" class="text-[10px] text-red-500 hover:text-red-700 font-extrabold ml-1.5 transition-colors uppercase">
                                                Gỡ mã
                                            </button>
                                        </form>
                                    </div>
                                }
                                else if (Model.AvailableCoupons.Any(c => c.CourseId == item.CourseId))
                                {
                                    <div class="mt-2">
                                        <button type="button" onclick="openVoucherModalForItem(@item.CourseId, '@Html.Raw(item.Title.Replace("'", "\\'"))')"
                                                class="flex items-center gap-1.5 px-3 py-1.5 border border-dashed border-primary/40 hover:border-primary hover:bg-emerald-50/20 rounded-xl transition-all group/btn text-left">
                                            <span class="text-xs">🎫</span>
                                            <span class="text-xs font-bold text-primary group-hover/btn:text-secondary transition-colors">
                                                Áp dụng Voucher
                                            </span>
                                            @if (Model.AvailableCoupons.Any(c => c.CourseId == item.CourseId && c.IsEligible))
                                            {
                                                <span class="text-[9px] font-extrabold text-emerald-600 bg-emerald-100 px-1.5 py-0.5 rounded-full ml-1 uppercase">
                                                    Có thể dùng
                                                </span>
                                            }
                                        </button>
                                    </div>
                                }
                            </div>

                            @* Nút xóa *@
                            <div class="shrink-0 flex items-start">
                                <form asp-action="RemoveFromCart" asp-controller="Cart" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="courseId" value="@item.CourseId" />
                                    <button type="submit"
                                            title="Xóa khỏi giỏ hàng"
                                            class="w-9 h-9 rounded-xl flex items-center justify-center text-slate-400 hover:bg-red-50 hover:text-red-500 transition-all"
                                            onclick="return confirm('Xóa khóa học này khỏi giỏ hàng?')">
                                        <span class="material-symbols-outlined text-xl">delete</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                @* ════ CỘT PHẢI — ORDER SUMMARY ════ *@
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 sticky top-24">

                        <h2 class="text-lg font-bold text-slate-800 mb-5 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">receipt_long</span>
                            Tóm tắt đơn hàng
                        </h2>

                        @* ── PHÂN TÁCH ────────────────────────────────────── *@
                        <div class="border-t border-slate-100 pt-5 space-y-3">

                            @* Tạm tính *@
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-slate-500">Tạm tính</span>
                                <span class="font-semibold text-slate-700">$@Model.SubTotal.ToString("N2")</span>
                            </div>

                            @* Giảm giá (chỉ hiện khi > 0) *@
                            @if (Model.HasDiscount)
                            {
                                <div class="flex justify-between items-center text-sm">
                                    <span class="text-emerald-600 flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">local_offer</span>
                                        Giảm giá
                                    </span>
                                    <span class="font-bold text-emerald-600">-$@Model.DiscountAmount.ToString("N2")</span>
                                </div>
                            }

                            @* Tổng thanh toán *@
                            <div class="border-t border-slate-100 pt-3 flex justify-between items-center">
                                <span class="font-bold text-slate-800">Tổng thanh toán</span>
                                <div class="text-right">
                                    <span class="text-2xl font-extrabold text-primary block">
                                        $@Model.Total.ToString("N2")
                                    </span>
                                </div>
                            </div>
                        </div>

                        @* ── NÚT CHECKOUT ─────────────────────────────────── *@
                        <form asp-action="Checkout" asp-controller="Cart" method="post" id="checkout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" id="checkout-btn"
                               class="mt-6 w-full flex items-center justify-center gap-2 py-4 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-xl hover:scale-[1.01] active:scale-[0.99] transition-all duration-300 text-sm uppercase tracking-wider">
                                <span class="material-symbols-outlined text-lg">payment</span>
                                Tiến hành thanh toán
                            </button>
                        </form>

                        <a href="/"
                           class="mt-3 w-full flex items-center justify-center gap-1.5 py-2.5 text-sm text-slate-500 hover:text-primary font-medium transition-colors">
                            <span class="material-symbols-outlined text-base">arrow_back</span>
                            Tiếp tục mua sắm
                        </a>
                    </div>
                </div>

            </div>
        }
    </div>
</div>

@* ════ VOUCHER WALLET MODAL ════ *@
<div id="voucher-modal" class="fixed inset-0 z-50 hidden" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeVoucherModal()"></div>

    <div class="absolute right-0 top-0 bottom-0 w-full max-w-md bg-white shadow-2xl flex flex-col">
        @* Modal Header *@
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
            <div>
                <h3 class="text-base font-bold text-slate-900">🎫 Áp dụng Voucher</h3>
                <p class="text-xs text-slate-500 mt-1 font-semibold text-primary" id="modal-course-title"></p>
            </div>
            <button type="button" onclick="closeVoucherModal()"
                    class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-slate-100 transition-colors">
                <span class="material-symbols-outlined text-slate-500 text-xl">close</span>
            </button>
        </div>

        @* Manual Code Input *@
        <div class="px-5 py-3 border-b border-slate-100 bg-slate-50">
            <form asp-action="ApplyCoupon" asp-controller="Cart" method="post" class="flex gap-2" id="manual-coupon-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseId" id="manual-coupon-course-id" />
                <input type="text" name="couponCode" id="manual-coupon-input"
                       placeholder="Nhập mã thủ công..."
                       class="flex-1 px-3 py-2 text-sm border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all uppercase bg-white"
                       style="text-transform:uppercase" />
                <button type="submit"
                        class="px-4 py-2 bg-primary text-white text-sm font-bold rounded-lg hover:bg-secondary transition-colors whitespace-nowrap">
                    Áp dụng
                </button>
            </form>
        </div>

        @* Voucher List *@
        <div class="flex-1 overflow-y-auto px-4 py-4 space-y-3">
            <div id="no-vouchers-message" class="hidden flex flex-col items-center justify-center py-16 text-center">
                <span class="text-5xl mb-3">🎟️</span>
                <p class="text-slate-500 font-medium">Không có voucher khả dụng</p>
                <p class="text-xs text-slate-400 mt-1">Khóa học này hiện không tham gia chương trình ưu đãi.</p>
            </div>

            @if (Model.AvailableCoupons.Any())
            {
                @foreach (var voucher in Model.AvailableCoupons.Where(c => c.IsEligible))
                {
                    <div class="voucher-item-card flex rounded-xl border border-emerald-200 bg-white overflow-hidden shadow-sm hover:shadow-md transition-shadow" data-course-id="@voucher.CourseId">
                        @* Left accent bar *@
                        <div class="w-1.5 bg-primary shrink-0"></div>

                        @* Coupon icon + cut circle *@
                        <div class="flex items-center px-3 border-r border-dashed border-emerald-200 bg-emerald-50/50 shrink-0">
                            <div class="w-10 h-10 flex items-center justify-center">
                                <span class="text-2xl">
                                    @(voucher.CouponType == "percentage" ? "%" : "đ")
                                </span>
                            </div>
                        </div>

                        @* Voucher info *@
                        <div class="flex-1 px-3 py-3 min-w-0">
                            <div class="flex items-center gap-2 mb-0.5">
                                <span class="font-mono font-bold text-slate-900 text-sm">@voucher.CouponCode</span>
                                <span class="text-[10px] font-bold text-emerald-600 bg-emerald-100 px-1.5 py-0.5 rounded uppercase">
                                    @(voucher.CouponType == "percentage" ? "%" : "Cố định")
                                </span>
                            </div>
                            <p class="text-sm font-semibold text-primary">@voucher.ConditionMessage</p>
                            @if (voucher.MinOrderValue > 0)
                            {
                                <p class="text-[11px] text-slate-500 mt-0.5">Đơn tối thiểu $@voucher.MinOrderValue.ToString("N2")</p>
                            }
                            @if (voucher.EndDate.HasValue)
                            {
                                <p class="text-[10px] text-slate-400 mt-0.5">HSD: @voucher.EndDate.Value.ToString("dd/MM/yyyy")</p>
                            }
                        </div>

                        @* Apply button *@
                        <div class="flex items-center px-3 shrink-0">
                            <form asp-action="ApplyCoupon" asp-controller="Cart" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="couponCode" value="@voucher.CouponCode" />
                                <input type="hidden" name="courseId" class="voucher-apply-course-id" value="" />
                                <button type="submit"
                                        class="px-3 py-2 bg-primary text-white text-xs font-bold rounded-lg hover:bg-secondary transition-colors whitespace-nowrap shadow-sm shadow-primary/30">
                                    Dùng
                                </button>
                            </form>
                        </div>
                    </div>
                }

                @foreach (var voucher in Model.AvailableCoupons.Where(c => !c.IsEligible))
                {
                    <div class="voucher-item-card flex rounded-xl border border-slate-200 bg-slate-50 overflow-hidden opacity-75" data-course-id="@voucher.CourseId">
                        <div class="w-1.5 bg-slate-300 shrink-0"></div>

                        <div class="flex items-center px-3 border-r border-dashed border-slate-200 bg-slate-100 shrink-0">
                            <div class="w-10 h-10 flex items-center justify-center">
                                <span class="text-2xl opacity-50">
                                    @(voucher.CouponType == "percentage" ? "%" : "đ")
                                </span>
                            </div>
                        </div>

                        <div class="flex-1 px-3 py-3 min-w-0">
                            <div class="flex items-center gap-2 mb-0.5">
                                <span class="font-mono font-bold text-slate-500 text-sm">@voucher.CouponCode</span>
                                <span class="text-[10px] font-bold text-slate-400 bg-slate-200 px-1.5 py-0.5 rounded uppercase">
                                    @(voucher.CouponType == "percentage" ? "%" : "Cố định")
                                </span>
                            </div>
                            <p class="text-sm font-semibold text-slate-600">@voucher.ConditionMessage</p>
                            <p class="text-[11px] text-slate-500 mt-0.5">Đơn tối thiểu $@voucher.MinOrderValue.ToString("N2")</p>
                            @if (voucher.EndDate.HasValue)
                            {
                                <p class="text-[10px] text-slate-400 mt-0.5">HSD: @voucher.EndDate.Value.ToString("dd/MM/yyyy")</p>
                            }
                        </div>

                        <div class="flex items-center px-3 shrink-0">
                            <button type="button" disabled
                                    class="px-3 py-2 bg-slate-200 text-slate-400 text-xs font-bold rounded-lg cursor-not-allowed whitespace-nowrap">
                                Dùng
                            </button>
                        </div>
                    </div>
                }
            }
        </div>

        @* Modal Footer *@
        <div class="px-5 py-3 border-t border-slate-100 bg-slate-50">
            <p class="text-xs text-slate-400 text-center">
                Mỗi đơn hàng chỉ áp dụng được tối đa 1 mã giảm giá
            </p>
        </div>
    </div>
</div>

<script>
    function openVoucherModalForItem(courseId, courseTitle) {
        // Cập nhật tiêu đề modal với tên khóa học
        document.getElementById('modal-course-title').innerText = courseTitle;
        
        // Cập nhật courseId cho input nhập thủ công
        document.getElementById('manual-coupon-course-id').value = courseId;
        
        // ★ Cập nhật courseId cho TẤT CẢ các form "Dùng" trong modal
        document.querySelectorAll('.voucher-apply-course-id').forEach(input => {
            input.value = courseId;
        });
        
        // Lọc hiển thị voucher theo CourseId của item
        const cards = document.querySelectorAll('.voucher-item-card');
        let visibleCount = 0;
        
        cards.forEach(card => {
            const cid = card.getAttribute('data-course-id');
            if (cid == courseId) {
                card.classList.remove('hidden');
                visibleCount++;
            } else {
                card.classList.add('hidden');
            }
        });
        
        // Hiển thị hoặc ẩn thông báo "Không có voucher"
        const noMsg = document.getElementById('no-vouchers-message');
        if (visibleCount === 0) {
            noMsg.classList.remove('hidden');
        } else {
            noMsg.classList.add('hidden');
        }
        
        const modal = document.getElementById('voucher-modal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeVoucherModal() {
        const modal = document.getElementById('voucher-modal');
        modal.classList.add('hidden');
        document.body.style.overflow = '';
    }

    // Đóng modal khi bấm Escape
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeVoucherModal();
    });
</script>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            @if (TempData["CartSuccess"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: '@Html.Raw(TempData["CartSuccess"].ToString().Replace("'", "\\'"))',
                    confirmButtonColor: '#059669'
                });
                </text>
            }

            @if (TempData["CartError"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Thông báo',
                    text: '@Html.Raw(TempData["CartError"].ToString().Replace("'", "\\'"))',
                    confirmButtonColor: '#ef4444'
                });
                </text>
            }
        });
    </script>
}
