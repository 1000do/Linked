@using CourseMarketplaceFE.Controllers
@model TransactionController.TransactionPagedVM
@{
    ViewData["Title"] = "Purchase History";
    Layout = "_Layout";
}

<div class="min-h-screen bg-[#f8fafc] relative overflow-hidden pb-16">
    @* Decorative background elements *@
    <div class="absolute top-0 left-0 w-full h-64 bg-gradient-to-br from-primary/5 to-transparent -z-10"></div>
    <div class="absolute top-40 -right-20 w-80 h-80 bg-primary/5 rounded-full blur-3xl -z-10"></div>
    
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 relative">
        <div class="flex flex-col lg:flex-row gap-10">
            @* Sidebar *@
            @await Html.PartialAsync("_AccountSidebar", "History")

            @* Main Content *@
            <div class="flex-grow space-y-8">
                <!-- Header Section -->
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
                    <div>
                        <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-2">Purchase History</h1>
                        <p class="text-slate-500 font-medium">Track your course purchases, payments, and refund statuses.</p>
                    </div>
                    <div class="flex items-center gap-3 shrink-0">
                        <div class="bg-indigo-50 px-4 py-2 rounded-2xl border border-indigo-100 flex items-center gap-3">
                            <span class="material-symbols-outlined text-indigo-600">receipt_long</span>
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-wider text-indigo-400 leading-none mb-1">Total Purchases</p>
                                <p class="text-lg font-black text-indigo-900 leading-none">@Model.TotalCount</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Search, Sort, Filter Bar ───────────────────── -->
                <div class="bg-white p-4 rounded-3xl border border-slate-100 shadow-xl shadow-slate-200/40">
                    <form method="get" action="/Transaction/History" class="flex flex-col md:flex-row items-center gap-4">
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@Model.PageSize" />

                        <div class="relative w-full md:w-1/3">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                            <input type="text" name="keyword" value="@ViewBag.Keyword" placeholder="Search by course title..." 
                                   class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-800 placeholder:text-slate-400 bg-slate-50 focus:bg-white" />
                        </div>
                        
                        <div class="flex flex-wrap items-center gap-4 w-full md:w-auto md:ml-auto">
                            <div class="relative w-full sm:w-auto">
                                <select name="status" class="w-full sm:w-auto appearance-none border border-slate-200 rounded-xl pl-4 pr-10 py-2.5 text-sm font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-700 cursor-pointer">
                                    <option value="">All Statuses</option>
                                    <option value="succeeded" selected="@(ViewBag.Status == "succeeded")">Success</option>
                                    <option value="refund_pending" selected="@(ViewBag.Status == "refund_pending")">Refund Pending</option>
                                    <option value="refunded" selected="@(ViewBag.Status == "refunded")">Refunded</option>
                                    <option value="failed" selected="@(ViewBag.Status == "failed")">Failed</option>
                                </select>
                                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
                            </div>

                            <div class="relative w-full sm:w-auto">
                                <select name="sortBy" class="w-full sm:w-auto appearance-none border border-slate-200 rounded-xl pl-4 pr-10 py-2.5 text-sm font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-slate-700 cursor-pointer">
                                    <option value="date_desc" selected="@(ViewBag.SortBy == "date_desc")">Newest</option>
                                    <option value="date_asc" selected="@(ViewBag.SortBy == "date_asc")">Oldest</option>
                                    <option value="amount_desc" selected="@(ViewBag.SortBy == "amount_desc")">Price: High to Low</option>
                                    <option value="amount_asc" selected="@(ViewBag.SortBy == "amount_asc")">Price: Low to High</option>
                                </select>
                                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
                            </div>

                            <button type="submit" class="w-full sm:w-auto px-6 py-2.5 bg-slate-900 text-white font-bold rounded-xl shadow-lg hover:bg-primary transition-all duration-300">
                                Apply
                            </button>

                            @if (!string.IsNullOrEmpty(ViewBag.Keyword) || !string.IsNullOrEmpty(ViewBag.Status) || ViewBag.SortBy != "date_desc")
                            {
                                <a href="/Transaction/History" class="w-full sm:w-auto px-4 py-2.5 text-sm font-bold bg-slate-100 hover:bg-slate-200 text-slate-600 text-center rounded-xl transition-all">
                                    Reset
                                </a>
                            }
                        </div>
                    </form>
                </div>

                @* 14-Day Guarantee & Stripe Billing Help Desk (Horizontal banner) *@
                <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-3xl p-6 text-white shadow-xl shadow-slate-200/50 border border-slate-700/50 flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-indigo-500/20 flex items-center justify-center border border-indigo-400/20 flex-shrink-0">
                            <span class="material-symbols-outlined text-indigo-300">verified_user</span>
                        </div>
                        <div>
                            <h4 class="font-black text-sm tracking-tight flex items-center gap-2">
                                14-Day Escrow Policy
                                <span class="bg-indigo-500/20 text-indigo-300 text-[9px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full border border-indigo-400/20">Stripe Secure Hold</span>
                            </h4>
                            <p class="text-xs text-indigo-200/80 leading-relaxed font-medium mt-1">
                                All payments are held securely in escrow for 14 days under our buyer protection policy. 
                                Instructors are credited only after the refund window expires.
                            </p>
                        </div>
                    </div>
                    <div class="flex-shrink-0 w-full md:w-auto">
                        <button type="button" onclick="showHelpDeskModal()" 
                                class="w-full md:w-auto px-6 py-3.5 bg-indigo-600 hover:bg-indigo-500 text-white font-bold text-xs rounded-xl shadow-lg shadow-indigo-600/20 hover:shadow-indigo-600/40 transition-all active:scale-95 flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-[16px]">contact_support</span>
                            Stripe Billing Help Desk
                        </button>
                    </div>
                </div>

                @* Main List *@
                <div class="space-y-4">
                @if (Model.Items != null && Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <div class="group bg-white rounded-[2rem] p-6 border border-slate-100 hover:border-indigo-200 hover:shadow-2xl hover:shadow-indigo-500/10 transition-all duration-500 flex flex-col md:flex-row items-center gap-6">
                            @* Transaction Info *@
                            <div class="w-16 h-16 rounded-3xl bg-slate-50 flex items-center justify-center flex-shrink-0 group-hover:bg-indigo-50 transition-colors">
                                <span class="material-symbols-outlined text-slate-400 group-hover:text-indigo-500 transition-colors">shopping_bag</span>
                            </div>

                            <div class="flex-grow text-center md:text-left">
                                <div class="flex flex-wrap items-center justify-center md:justify-start gap-2 mb-1">
                                    <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">#@item.TransactionId</span>
                                    <span class="text-slate-300">•</span>
                                    <span class="text-[10px] font-bold text-slate-500">@(item.Date.HasValue ? item.Date.Value.ToString("dd MMM, yyyy HH:mm") : "—")</span>
                                </div>
                                <h3 class="text-lg font-black text-slate-900 group-hover:text-indigo-600 transition-colors line-clamp-1">@item.CourseTitle</h3>
                                <p class="text-sm text-slate-500 font-medium mt-0.5">Instructor: <span class="text-slate-700 font-bold">@item.InstructorName</span></p>
                            </div>

                            <div class="flex flex-col items-center md:items-end gap-3 flex-shrink-0">
                                <div class="text-xl font-black text-slate-900">
                                    @if (item.Status == "refunded")
                                    {
                                        <span class="text-rose-600 font-bold">- @((item.Currency ?? "USD").ToUpper()) @Math.Abs(item.Amount).ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span>@((item.Currency ?? "USD").ToUpper()) @item.Amount.ToString("N2")</span>
                                    }
                                </div>
                                
                                @{
                                    var (bgClass, textClass, dotClass, label) = item.Status switch
                                    {
                                        "succeeded"      => ("bg-emerald-50", "text-emerald-600", "bg-emerald-500", "Success"),
                                        "failed"         => ("bg-rose-50",    "text-rose-600",    "bg-rose-500",    "Failed"),
                                        "pending"        => ("bg-amber-50",   "text-amber-600",   "bg-amber-400",   "Pending"),
                                        "refund_pending" => ("bg-orange-50",  "text-orange-600",  "bg-orange-500",  "Refund Pending"),
                                        "refunded"       => ("bg-violet-50",  "text-violet-600",  "bg-violet-500",  "Refunded"),
                                        _                => ("bg-slate-50",   "text-slate-500",   "bg-slate-400",   item.Status ?? "—")
                                    };
                                }
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider @bgClass @textClass">
                                    <span class="w-1.5 h-1.5 rounded-full @dotClass"></span>
                                    @label
                                </span>
                            </div>

                            <div class="flex-shrink-0 flex items-center gap-3">
                                @{
                                    var isRefundable = item.Status == "succeeded" && item.Date.HasValue && item.Date.Value >= DateTime.UtcNow.AddDays(-14);
                                }
                                @if (isRefundable)
                                {
                                    <button type="button" 
                                            onclick="requestRefund(@item.TransactionId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(item.CourseTitle))')"
                                            class="flex items-center gap-1.5 px-4 py-2.5 bg-rose-50 hover:bg-rose-100 text-rose-600 hover:text-rose-700 font-bold text-xs rounded-xl border border-rose-100 hover:border-rose-200 transition-all shadow-sm active:scale-95">
                                        <span class="material-symbols-outlined text-[16px]">restart_alt</span>
                                        Refund Request
                                    </button>
                                }
                                <a href="@Url.Action("HistoryDetail", "Transaction", new { id = item.TransactionId })" 
                                   class="w-12 h-12 rounded-2xl bg-slate-50 text-slate-400 flex items-center justify-center hover:bg-slate-900 hover:text-white transition-all active:scale-90"
                                   title="View Details">
                                    <span class="material-symbols-outlined">chevron_right</span>
                                </a>
                            </div>
                        </div>
                    }

                    @* Pagination *@
                    @if (Model.TotalPages > 1)
                    {
                        <div class="mt-12 flex items-center justify-center gap-2">
                            @if (Model.Page > 1)
                            {
                                <a href="@Url.Action("History", new { page = Model.Page - 1, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status })" 
                                   class="w-12 h-12 rounded-2xl border border-slate-200 flex items-center justify-center text-slate-500 hover:bg-white hover:border-indigo-500 hover:text-indigo-500 transition-all">
                                    <span class="material-symbols-outlined">chevron_left</span>
                                </a>
                            }

                            @for (int p = 1; p <= Model.TotalPages; p++)
                            {
                                if (p == Model.Page)
                                {
                                    <span class="w-12 h-12 rounded-2xl bg-slate-900 text-white flex items-center justify-center font-black shadow-lg shadow-slate-900/20">@p</span>
                                }
                                else if (p <= 3 || p > Model.TotalPages - 2 || (p >= Model.Page - 1 && p <= Model.Page + 1))
                                {
                                    <a href="@Url.Action("History", new { page = p, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status })" 
                                       class="w-12 h-12 rounded-2xl border border-slate-200 bg-white flex items-center justify-center font-bold text-slate-600 hover:border-indigo-500 hover:text-indigo-500 transition-all">@p</a>
                                }
                            }

                            @if (Model.Page < Model.TotalPages)
                            {
                                <a href="@Url.Action("History", new { page = Model.Page + 1, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status })" 
                                   class="w-12 h-12 rounded-2xl border border-slate-200 flex items-center justify-center text-slate-500 hover:bg-white hover:border-indigo-500 hover:text-indigo-500 transition-all">
                                    <span class="material-symbols-outlined">chevron_right</span>
                                </a>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="bg-white rounded-[3rem] p-20 text-center border border-slate-100 shadow-xl shadow-slate-200/40">
                        <div class="w-24 h-24 rounded-full bg-slate-50 flex items-center justify-center mx-auto mb-6">
                            <span class="material-symbols-outlined text-5xl text-slate-200">receipt_long</span>
                        </div>
                        <h2 class="text-2xl font-black text-slate-900 mb-2">No transactions found</h2>
                        <p class="text-slate-500 font-medium max-w-sm mx-auto">You have not made any purchases yet, or no transactions match your criteria.</p>
                        <a href="/Home" class="inline-flex items-center gap-2 mt-8 px-8 py-4 bg-primary text-white font-bold rounded-2xl hover:shadow-lg hover:shadow-primary/30 transition-all active:scale-95">
                            Explore Courses
                            <span class="material-symbols-outlined text-[20px]">explore</span>
                        </a>
                    </div>
                }
            </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function requestRefund(transactionId, courseTitle) {
            Swal.fire({
                title: 'Request Refund',
                html: `<div class="text-left font-sans">
                        <p class="text-sm text-slate-500 mb-4">You are requesting a refund for the course <strong>${courseTitle}</strong>. 
                        Please enter a specific reason for Admin approval.</p>
                       </div>`,
                input: 'textarea',
                inputPlaceholder: 'Enter refund reason here...',
                inputAttributes: {
                    'aria-label': 'Enter refund reason here'
                },
                showCancelButton: true,
                confirmButtonText: 'Submit Request',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#e11d48',
                cancelButtonColor: '#64748b',
                buttonsStyling: true,
                customClass: {
                    popup: 'rounded-3xl border border-slate-100 p-8 shadow-2xl',
                    title: 'text-xl font-black text-slate-900 tracking-tight',
                    confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all',
                    cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                },
                inputValidator: (value) => {
                    if (!value || value.trim() === '') {
                        return 'You must enter a refund reason!';
                    }
                },
                showLoaderOnConfirm: true,
                preConfirm: (reason) => {
                    // Lấy token anti-forgery từ input ẩn
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const params = new URLSearchParams();
                    params.append('transactionId', transactionId);
                    params.append('reason', reason);

                    return fetch('/Transaction/RequestRefund', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: params
                    })
                    .then(response => {
                        return response.json().then(data => {
                            if (!response.ok || !data.success) {
                                throw new Error(data.message || response.statusText);
                            }
                            return data;
                        });
                    })
                    .catch(error => {
                        Swal.showValidationMessage(`Request failed: ${error.message}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Request Submitted!',
                        text: result.value.message,
                        icon: 'success',
                        confirmButtonText: 'Close',
                        confirmButtonColor: '#10b981',
                        customClass: {
                            popup: 'rounded-3xl',
                            title: 'text-xl font-black text-slate-900',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm'
                        }
                    }).then(() => {
                        location.reload();
                    });
                }
            });
        }

        function showHelpDeskModal() {
            Swal.fire({
                title: 'Stripe Billing Help Desk',
                html: `
                    <div class="text-left font-sans space-y-4">
                        <p class="text-xs text-slate-500">
                            Encountered an issue with your payment, billing invoice, or refund status? 
                            Submit a priority ticket directly to our Stripe Integration Support Team.
                        </p>
                        <div>
                            <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-2">Issue Category</label>
                            <select id="supportCategory" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:bg-white focus:border-indigo-500 outline-none transition-all font-medium appearance-none cursor-pointer">
                                <option value="payment_failure">Payment Failed / Stripe Card Declined</option>
                                <option value="refund_dispute">Refund Request Pending > 14 Days</option>
                                <option value="double_charge">Double Charge / Unauthorized Invoice</option>
                                <option value="other">Other Account & Billing Issues</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-2">Detailed Description</label>
                            <textarea id="supportDescription" placeholder="Please describe what happened, including dates or error messages if possible..." class="w-full h-24 px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:bg-white focus:border-indigo-500 outline-none transition-all font-medium resize-none"></textarea>
                        </div>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'Submit Ticket',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#4f46e5',
                cancelButtonColor: '#64748b',
                customClass: {
                    popup: 'rounded-3xl border border-slate-100 p-8 shadow-2xl max-w-md w-full',
                    title: 'text-xl font-black text-slate-900 tracking-tight text-left',
                    confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all',
                    cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                },
                preConfirm: () => {
                    const category = document.getElementById('supportCategory').value;
                    const description = document.getElementById('supportDescription').value;
                    if (!description || description.trim() === '') {
                        Swal.showValidationMessage('Please write a detailed description of your issue.');
                        return false;
                    }
                    return { category, description };
                },
                showLoaderOnConfirm: true,
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    var ticketRef = 'TK-STRIPE-' + Math.floor(100000 + Math.random() * 900000);
                    Swal.fire({
                        title: 'Ticket Submitted Successfully!',
                        html: `
                            <div class="text-left font-sans space-y-3">
                                <p class="text-sm text-slate-500">
                                    Our support agents are investigating your Stripe billing transaction logs.
                                </p>
                                <div class="bg-indigo-50 border border-indigo-100 rounded-2xl p-4 flex flex-col gap-2">
                                    <div class="flex justify-between items-center">
                                        <span class="text-[10px] uppercase font-black tracking-wider text-indigo-400">Ticket Reference</span>
                                        <span class="text-xs font-black text-indigo-900">` + ticketRef + `</span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-[10px] uppercase font-black tracking-wider text-indigo-400">Response Time</span>
                                        <span class="text-xs font-bold text-emerald-600">Within 24 Hours</span>
                                    </div>
                                </div>
                            </div>
                        `,
                        icon: 'success',
                        confirmButtonText: 'Got it',
                        confirmButtonColor: '#10b981',
                        customClass: {
                            popup: 'rounded-3xl border border-slate-100 p-8 shadow-2xl',
                            title: 'text-xl font-black text-slate-900 tracking-tight',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                        }
                    });
                }
            });
        }
    </script>
}
