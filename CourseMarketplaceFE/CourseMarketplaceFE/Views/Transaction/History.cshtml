@using CourseMarketplaceFE.Controllers
@model CourseMarketplaceFE.Models.TransactionPagedVM
@{
    ViewData["Title"] = "Purchase History";
    Layout = "_Layout";
}

<div class="min-h-screen bg-[#f8fafc] relative overflow-hidden pb-16">
    @* Decorative background elements *@
    <div class="absolute top-0 left-0 w-full h-64 bg-gradient-to-br from-primary/5 to-transparent -z-10"></div>
    <div class="absolute top-40 -right-20 w-80 h-80 bg-primary/5 rounded-full blur-3xl -z-10"></div>
    
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 relative">
        <div class="flex flex-col lg:flex-row gap-10">
            @* Sidebar *@
            @await Html.PartialAsync("_AccountSidebar", "History")

            @* Main Content *@
            <div class="flex-grow space-y-8">
                <!-- Header Section -->
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8">
                    <div>
                        <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-2">Purchase History</h1>
                        <p class="text-slate-500 font-medium">Track your course purchases, payments, and refund statuses.</p>
                    </div>
                    <div class="flex items-center gap-3 shrink-0">
                        <div class="bg-indigo-50 px-4 py-2 rounded-2xl border border-indigo-100 flex items-center gap-3">
                            <span class="material-symbols-outlined text-indigo-600">receipt_long</span>
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-wider text-indigo-400 leading-none mb-1">Total Purchases</p>
                                <p class="text-lg font-black text-indigo-900 leading-none">@Model.TotalCount</p>
                            </div>
                        </div>
                    </div>
                </div>

                                <!-- ── Search, Sort, Filter Bar ───────────────────── -->
                <div class="bg-white p-5 rounded-3xl border border-slate-100 shadow-xl shadow-slate-100/40">
                    <form method="get" action="/Transaction/History" class="flex flex-col lg:flex-row items-center gap-4">
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@Model.PageSize" />

                        <div class="relative w-full lg:w-1/3">
                            <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                            <input type="text" name="keyword" value="@ViewBag.Keyword" placeholder="Search by course title..." 
                                   class="w-full pl-11 pr-4 py-3 text-xs font-semibold border border-slate-200/80 rounded-2xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-800 placeholder:text-slate-400 bg-slate-50 focus:bg-white" />
                        </div>
                        
                        <div class="flex flex-col sm:flex-row flex-wrap items-center gap-3 w-full lg:w-auto lg:ml-auto">
                            <div class="relative w-full sm:w-auto">
                                <select name="status" class="w-full sm:w-auto appearance-none border border-slate-200/80 rounded-2xl pl-4 pr-10 py-3 text-xs font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-600 cursor-pointer">
                                    <option value="">All Statuses</option>
                                    <option value="succeeded" selected="@(ViewBag.Status == "succeeded")">Success</option>
                                    <option value="refund_pending" selected="@(ViewBag.Status == "refund_pending")">Refund Pending</option>
                                    <option value="refunded" selected="@(ViewBag.Status == "refunded")">Refunded</option>
                                    <option value="failed" selected="@(ViewBag.Status == "failed")">Failed</option>
                                </select>
                                <span class="material-symbols-outlined absolute right-3.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
                            </div>

                            <div class="relative w-full sm:w-auto">
                                <select name="sortBy" class="w-full sm:w-auto appearance-none border border-slate-200/80 rounded-2xl pl-4 pr-10 py-3 text-xs font-semibold bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all text-slate-600 cursor-pointer">
                                    <option value="date_desc" selected="@(ViewBag.SortBy == "date_desc")">Newest</option>
                                    <option value="date_asc" selected="@(ViewBag.SortBy == "date_asc")">Oldest</option>
                                    <option value="amount_desc" selected="@(ViewBag.SortBy == "amount_desc")">Price: High to Low</option>
                                    <option value="amount_asc" selected="@(ViewBag.SortBy == "amount_asc")">Price: Low to High</option>
                                </select>
                                <span class="material-symbols-outlined absolute right-3.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-[20px]">arrow_drop_down</span>
                            </div>

                            <button type="submit" class="w-full sm:w-auto px-6 py-3 bg-slate-900 hover:bg-indigo-600 text-white font-black text-xs rounded-2xl shadow-md shadow-slate-900/10 hover:shadow-indigo-600/20 transition-all active:scale-95 duration-200">
                                Apply
                            </button>

                            @if (!string.IsNullOrEmpty(ViewBag.Keyword) || !string.IsNullOrEmpty(ViewBag.Status) || ViewBag.SortBy != "date_desc")
                            {
                                <a href="/Transaction/History" class="w-full sm:w-auto px-4 py-3 text-xs font-black bg-slate-100 hover:bg-slate-200 text-slate-600 text-center rounded-2xl transition-all">
                                    Reset
                                </a>
                            }
                        </div>
                    </form>
                </div>

                @* 14-Day Guarantee (Horizontal banner) *@
                <div class="bg-gradient-to-r from-indigo-50/70 to-purple-50/50 backdrop-blur-md rounded-3xl p-6 border border-indigo-100/60 shadow-md shadow-indigo-100/10 flex items-start gap-4 hover:shadow-lg transition-all duration-300">
                    <div class="w-12 h-12 rounded-2xl bg-indigo-600 flex items-center justify-center shadow-lg shadow-indigo-200 flex-shrink-0">
                        <span class="material-symbols-outlined text-white text-[22px]">verified_user</span>
                    </div>
                    <div class="space-y-1">
                        <h4 class="font-black text-slate-800 text-sm tracking-tight flex items-center gap-2 flex-wrap">
                            14-Day Escrow Policy
                            <span class="bg-indigo-100 text-indigo-700 text-[9px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full border border-indigo-200/50">Stripe Secure Hold</span>
                        </h4>
                        <p class="text-xs text-slate-500/90 leading-relaxed font-medium">
                            All payments are held securely in escrow for 14 days under our buyer protection policy. 
                            Instructors are credited only after the refund window expires.
                        </p>
                    </div>
                </div>

                @* Main List *@
                <div class="space-y-4">
                @if (Model.Items != null && Model.Items.Any())
                {
                    <div class="hidden lg:grid grid-cols-12 px-6 py-2 text-[10px] font-black uppercase tracking-widest text-slate-400">
                        <div class="col-span-4">Course Details</div>
                        <div class="col-span-3">Date & ID</div>
                        <div class="col-span-3 text-right">Amount & Status</div>
                        <div class="col-span-2 text-right">Actions</div>
                    </div>

                    @foreach (var item in Model.Items)
                    {
                        var (bgClass, textClass, dotClass, label) = item.Status switch
                        {
                            "succeeded"      => item.IsGift && item.IsGiftClaimed
                                                ? ("bg-blue-50/80 border-blue-100/50", "text-blue-700", "bg-blue-500", "Claimed")
                                                : ("bg-emerald-50/80 border-emerald-100/50", "text-emerald-700", "bg-emerald-500", "Success"),
                            "failed"         => ("bg-rose-50/80 border-rose-100/50", "text-rose-700", "bg-rose-500", "Failed"),
                            "pending"        => ("bg-amber-50/80 border-amber-100/50", "text-amber-700", "bg-amber-400", "Pending"),
                            "refund_pending" => ("bg-orange-50/80 border-orange-100/50", "text-orange-700", "bg-orange-500", "Refund Pending"),
                            "refunded"       => ("bg-violet-50/80 border-violet-100/50", "text-violet-700", "bg-violet-500", "Refunded"),
                            _                => ("bg-slate-50/80 border-slate-100/50", "text-slate-600", "bg-slate-400", item.Status ?? "—")
                        };

                        var (iconName, iconBgClass, iconTextClass) = item.Status switch
                        {
                            "succeeded"      => ("school", "from-emerald-50 to-teal-50/50 group-hover:from-emerald-100 group-hover:to-teal-100/60", "text-emerald-600"),
                            "refund_pending" => ("assignment_return", "from-amber-50 to-orange-50/50 group-hover:from-amber-100 group-hover:to-orange-100/60", "text-amber-600"),
                            "refunded"       => ("history", "from-violet-50 to-purple-50/50 group-hover:from-violet-100 group-hover:to-purple-100/60", "text-violet-600"),
                            "failed"         => ("sms_failed", "from-rose-50 to-red-50/50 group-hover:from-rose-100 group-hover:to-red-100/60", "text-rose-600"),
                            _                => ("shopping_bag", "from-slate-50 to-slate-100/50 group-hover:from-slate-100 group-hover:to-slate-200/60", "text-slate-500")
                        };

                        <div class="group bg-white rounded-3xl p-5 border border-slate-100 hover:border-indigo-100/80 hover:shadow-xl hover:shadow-indigo-500/5 hover:-translate-y-0.5 transition-all duration-300 grid grid-cols-1 lg:grid-cols-12 items-center gap-4 lg:gap-6">
                            <!-- Col 1: Course Info -->
                            <div class="col-span-1 lg:col-span-4 flex items-center gap-4 min-w-0">
                                <div class="w-12 h-12 rounded-2xl bg-gradient-to-br @iconBgClass flex items-center justify-center flex-shrink-0 transition-all duration-300">
                                    <span class="material-symbols-outlined @iconTextClass group-hover:scale-110 transition-transform duration-300">@iconName</span>
                                </div>
                                <div class="min-w-0 space-y-1">
                                    <h3 class="text-sm font-black text-slate-800 group-hover:text-indigo-600 transition-colors truncate flex items-center gap-2">
                                        @item.CourseTitle
                                        @if (item.IsGift)
                                        {
                                            <span class="bg-emerald-50 text-emerald-700 text-[9px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full border border-emerald-200/80 flex items-center gap-1 shrink-0">
                                                <span class="material-symbols-outlined text-[10px]">redeem</span>
                                                Gift
                                            </span>
                                        }
                                    </h3>
                                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                                        <div class="flex items-center gap-1.5">
                                            <span class="material-symbols-outlined text-[13px] text-slate-400">person</span>
                                            <span class="text-[11px] text-slate-500 font-semibold">@item.InstructorName</span>
                                        </div>
                                        @if (item.IsGift && !string.IsNullOrEmpty(item.RecipientEmail))
                                        {
                                            <div class="flex items-center gap-1.5 text-slate-400">
                                                <span class="text-xs">•</span>
                                                <span class="material-symbols-outlined text-[13px] text-slate-400">mail</span>
                                                <span class="text-[11px] text-slate-500 font-semibold">Gift to: @item.RecipientEmail</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Col 2: Date & ID -->
                            <div class="col-span-1 lg:col-span-3 flex flex-row lg:flex-col items-center lg:items-start justify-between lg:justify-center gap-2 lg:gap-1 pt-3 lg:pt-0 border-t lg:border-t-0 border-slate-100">
                                <div class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[13px] text-slate-400">fingerprint</span>
                                    <span class="text-[11px] lg:text-xs font-bold font-mono text-slate-600">#@item.TransactionId</span>
                                </div>
                                <div class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[13px] text-slate-400">calendar_today</span>
                                    <span class="text-[11px] lg:text-xs text-slate-500 font-medium">@(item.Date.HasValue ? item.Date.Value.ToString("dd MMM, yyyy HH:mm") : "—")</span>
                                </div>
                            </div>

                            <!-- Col 3: Amount & Status -->
                            <div class="col-span-1 lg:col-span-3 flex flex-row lg:flex-col items-center lg:items-end justify-between lg:justify-center gap-2 lg:gap-1.5 pt-3 lg:pt-0 border-t lg:border-t-0 border-slate-100">
                                <div class="text-sm lg:text-base font-black font-mono text-slate-900">
                                    @if (item.Status == "refunded")
                                    {
                                        <span class="text-rose-600 font-black">- @((item.Currency ?? "USD").ToUpper()) @Math.Abs(item.Amount).ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span>@((item.Currency ?? "USD").ToUpper()) @item.Amount.ToString("N2")</span>
                                    }
                                </div>
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[9px] font-black uppercase tracking-wider border @bgClass @textClass">
                                    <span class="w-1.5 h-1.5 rounded-full @dotClass"></span>
                                    @label
                                </span>
                            </div>

                            <!-- Col 4: Actions -->
                            <div class="col-span-1 lg:col-span-2 flex items-center justify-end gap-2.5 mt-2 lg:mt-0 pt-3 lg:pt-0 border-t lg:border-t-0 border-slate-100 w-full">
                                @{
                                    var isRefundable = item.Status == "succeeded" 
                                        && item.Date.HasValue 
                                        && item.Date.Value >= DateTime.UtcNow.AddDays(-14)
                                        && !(item.IsGift && item.IsGiftClaimed);
                                }
                                @if (isRefundable)
                                {
                                    <button type="button" 
                                            onclick="requestRefund(@item.TransactionId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(item.CourseTitle))')"
                                            class="flex items-center justify-center gap-1.5 px-3 py-1.5 bg-rose-50 hover:bg-rose-100 text-rose-600 hover:text-rose-700 font-bold text-[11px] rounded-xl border border-rose-100/80 hover:border-rose-200 transition-all shadow-sm active:scale-95 duration-200">
                                        <span class="material-symbols-outlined text-[14px]">restart_alt</span>
                                        Refund
                                    </button>
                                }
                                <a href="@Url.Action("HistoryDetail", "Transaction", new { id = item.TransactionId })" 
                                   class="w-9 h-9 rounded-xl bg-slate-50 text-slate-500 border border-slate-200/50 hover:bg-slate-900 hover:text-white flex items-center justify-center transition-all duration-200 active:scale-90"
                                   title="View Details">
                                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                                </a>
                            </div>
                        </div>
                    }

                    @* Pagination *@
                    @if (Model.TotalPages > 1)
                    {
                        <div class="mt-12 flex items-center justify-center gap-2">
                            @if (Model.Page > 1)
                            {
                                <a href="@Url.Action("History", new { page = Model.Page - 1, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status })" 
                                   class="w-12 h-12 rounded-2xl border border-slate-200 flex items-center justify-center text-slate-500 hover:bg-white hover:border-indigo-500 hover:text-indigo-500 transition-all">
                                    <span class="material-symbols-outlined">chevron_left</span>
                                </a>
                            }

                            @for (int p = 1; p <= Model.TotalPages; p++)
                            {
                                if (p == Model.Page)
                                {
                                    <span class="w-12 h-12 rounded-2xl bg-slate-900 text-white flex items-center justify-center font-black shadow-lg shadow-slate-900/20">@p</span>
                                }
                                else if (p <= 3 || p > Model.TotalPages - 2 || (p >= Model.Page - 1 && p <= Model.Page + 1))
                                {
                                    <a href="@Url.Action("History", new { page = p, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status })" 
                                       class="w-12 h-12 rounded-2xl border border-slate-200 bg-white flex items-center justify-center font-bold text-slate-600 hover:border-indigo-500 hover:text-indigo-500 transition-all">@p</a>
                                }
                            }

                            @if (Model.Page < Model.TotalPages)
                            {
                                <a href="@Url.Action("History", new { page = Model.Page + 1, keyword = ViewBag.Keyword, sortBy = ViewBag.SortBy, status = ViewBag.Status })" 
                                   class="w-12 h-12 rounded-2xl border border-slate-200 flex items-center justify-center text-slate-500 hover:bg-white hover:border-indigo-500 hover:text-indigo-500 transition-all">
                                    <span class="material-symbols-outlined">chevron_right</span>
                                </a>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="bg-white rounded-[3rem] p-20 text-center border border-slate-100 shadow-xl shadow-slate-200/40">
                        <div class="w-24 h-24 rounded-full bg-slate-50 flex items-center justify-center mx-auto mb-6">
                            <span class="material-symbols-outlined text-5xl text-slate-200">receipt_long</span>
                        </div>
                        <h2 class="text-2xl font-black text-slate-900 mb-2">No transactions found</h2>
                        <p class="text-slate-500 font-medium max-w-sm mx-auto">You have not made any purchases yet, or no transactions match your criteria.</p>
                        <a href="/Home" class="inline-flex items-center gap-2 mt-8 px-8 py-4 bg-primary text-white font-bold rounded-2xl hover:shadow-lg hover:shadow-primary/30 transition-all active:scale-95">
                            Explore Courses
                            <span class="material-symbols-outlined text-[20px]">explore</span>
                        </a>
                    </div>
                }
            </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function requestRefund(transactionId, courseTitle) {
            Swal.fire({
                title: 'Request Refund',
                html: `<div class="text-left font-sans">
                        <p class="text-sm text-slate-500 mb-4">You are requesting a refund for the course <strong>${courseTitle}</strong>. 
                        Please enter a specific reason for Admin approval.</p>
                       </div>`,
                input: 'textarea',
                inputPlaceholder: 'Enter refund reason here...',
                inputAttributes: {
                    'aria-label': 'Enter refund reason here'
                },
                showCancelButton: true,
                confirmButtonText: 'Submit Request',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#e11d48',
                cancelButtonColor: '#64748b',
                buttonsStyling: true,
                customClass: {
                    popup: 'rounded-3xl border border-slate-100 p-8 shadow-2xl',
                    title: 'text-xl font-black text-slate-900 tracking-tight',
                    confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all',
                    cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                },
                inputValidator: (value) => {
                    if (!value || value.trim() === '') {
                        return 'You must enter a refund reason!';
                    }
                },
                showLoaderOnConfirm: true,
                preConfirm: (reason) => {
                    // Lấy token anti-forgery từ input ẩn
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const params = new URLSearchParams();
                    params.append('transactionId', transactionId);
                    params.append('reason', reason);

                    return fetch('/Transaction/RequestRefund', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: params
                    })
                    .then(response => {
                        return response.json().then(data => {
                            if (!response.ok || !data.success) {
                                throw new Error(data.message || response.statusText);
                            }
                            return data;
                        });
                    })
                    .catch(error => {
                        Swal.showValidationMessage(`Request failed: ${error.message}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    const isRejected = result.value.autoRejected;
                    Swal.fire({
                        title: isRejected ? 'Refund Rejected' : 'Request Submitted!',
                        text: result.value.message,
                        icon: isRejected ? 'error' : 'success',
                        confirmButtonText: 'Close',
                        confirmButtonColor: isRejected ? '#e11d48' : '#10b981',
                        customClass: {
                            popup: 'rounded-3xl',
                            title: 'text-xl font-black text-slate-900',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm'
                        }
                    }).then(() => {
                        location.reload();
                    });
                }
            });
        }


    </script>
}
