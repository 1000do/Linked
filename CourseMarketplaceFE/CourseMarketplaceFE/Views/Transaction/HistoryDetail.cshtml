@using CourseMarketplaceFE.Controllers
@model CourseMarketplaceFE.Models.TransactionDetailVM
@{
    ViewData["Title"] = "Invoice Details";
    Layout = "_Layout";

    var statusBg = Model.Status == "succeeded" ? "bg-emerald-50 text-emerald-600"
                 : Model.Status == "failed" ? "bg-rose-50 text-rose-600"
                 : Model.Status == "refund_pending" ? "bg-orange-50 text-orange-600"
                 : Model.Status == "refunded" ? "bg-violet-50 text-violet-600"
                 : "bg-amber-50 text-amber-600";
    
    var statusLabel = Model.Status == "succeeded" ? "Success"
                    : Model.Status == "failed" ? "Failed"
                    : Model.Status == "pending" ? "Pending"
                    : Model.Status == "refund_pending" ? "Refund Pending"
                    : Model.Status == "refunded" ? "Refunded"
                    : Model.Status ?? "—";

    var dotColor = Model.Status == "succeeded" ? "bg-emerald-500"
                 : Model.Status == "failed" ? "bg-rose-500"
                 : Model.Status == "refund_pending" ? "bg-orange-500"
                 : Model.Status == "refunded" ? "bg-violet-500"
                 : "bg-amber-400";
}

<div class="min-h-screen bg-[#f8fafc] pb-20">
    <div class="max-w-4xl mx-auto px-6 pt-10">
        @* Back button *@
        <a href="/Transaction/History" class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-900 font-bold transition-colors mb-8 group">
            <span class="material-symbols-outlined text-[20px] group-hover:-translate-x-1 transition-transform">arrow_back</span>
            Back to history
        </a>
        @if (Model.Status == "refund_pending") {
            <div class="mb-8 p-6 bg-gradient-to-r from-orange-50 to-amber-50 border border-orange-200 rounded-3xl shadow-sm flex items-start gap-4">
                <div class="w-12 h-12 rounded-2xl bg-orange-100 flex items-center justify-center border border-orange-200 shadow-inner shrink-0">
                    <span class="material-symbols-outlined text-orange-600 text-[24px]">restart_alt</span>
                </div>
                <div>
                    <h3 class="text-base font-black text-slate-900 mb-1">Refund request pending approval</h3>
                    <p class="text-sm text-slate-600">
                        Your refund request was successfully submitted on <span class="font-bold text-slate-800">@(Model.RefundRequestedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span> and is currently under review by Admin.
                    </p>
                    <div class="mt-3 p-3 bg-white border border-orange-100 rounded-2xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Your refund reason</p>
                        <p class="text-sm text-slate-800 italic">"@Model.RefundReason"</p>
                    </div>
                </div>
            </div>
        } else if (Model.Status == "refunded") {
            <div class="mb-8 p-6 bg-gradient-to-r from-rose-50 to-red-50 border border-rose-200 rounded-3xl shadow-sm flex items-start gap-4">
                <div class="w-12 h-12 rounded-2xl bg-rose-100 flex items-center justify-center border border-rose-200 shadow-inner shrink-0">
                    <span class="material-symbols-outlined text-rose-600 text-[24px]">verified_user</span>
                </div>
                <div class="flex-1">
                    <h3 class="text-base font-black text-slate-900 mb-1">Transaction successfully refunded</h3>
                    <p class="text-sm text-slate-600">
                        The system has approved the refund request for this transaction. Access to the course learning materials has been revoked.
                    </p>
                    <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="p-3 bg-white border border-rose-100 rounded-2xl">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Your refund reason</p>
                            <p class="text-sm text-slate-800 italic">"@Model.RefundReason"</p>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.RefundAdminNote)) {
                            <div class="p-3 bg-white border border-rose-100 rounded-2xl">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Admin Response</p>
                                <p class="text-sm text-slate-800 font-bold">"@Model.RefundAdminNote"</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        } else if (Model.Status == "succeeded" && !string.IsNullOrEmpty(Model.RefundAdminNote)) {
            <div class="mb-8 p-6 bg-gradient-to-r from-slate-50 to-slate-100 border border-slate-200 rounded-3xl shadow-sm flex items-start gap-4">
                <div class="w-12 h-12 rounded-2xl bg-slate-200 flex items-center justify-center border border-slate-300 shrink-0 shadow-inner">
                    <span class="material-symbols-outlined text-slate-600 text-[24px]">cancel</span>
                </div>
                <div class="flex-1">
                    <h3 class="text-base font-black text-slate-900 mb-1">Previous refund request was rejected</h3>
                    <p class="text-sm text-slate-600">
                        The refund request you submitted on <span class="font-bold text-slate-800">@(Model.RefundRequestedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span> has been rejected by Admin.
                    </p>
                    <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="p-3 bg-white border border-slate-200 rounded-2xl">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Your original refund reason</p>
                            <p class="text-sm text-slate-800 italic">"@Model.RefundReason"</p>
                        </div>
                        <div class="p-3 bg-white border border-slate-200 rounded-2xl">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Admin Response</p>
                            <p class="text-sm text-slate-800 font-bold">"@Model.RefundAdminNote"</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="bg-white rounded-[3rem] shadow-2xl shadow-slate-200/50 border border-slate-100 overflow-hidden relative">
            @* Top Decoration *@
            <div class="h-2 w-full bg-gradient-to-r from-primary to-secondary"></div>

            <div class="p-8 md:p-12">
                @* Invoice Header *@
                <div class="flex flex-col md:flex-row justify-between items-start gap-8 mb-12">
                    <div>
                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest @statusBg mb-4">
                            <span class="w-1.5 h-1.5 rounded-full @dotColor"></span>
                            @statusLabel
                        </div>
                        <h1 class="text-4xl font-black text-slate-900 tracking-tight">Electronic Invoice</h1>
                        <p class="text-slate-400 font-bold mt-1 uppercase tracking-widest text-xs">Transaction ID: #@Model.TransactionId</p>
                    </div>

                    <div class="text-left md:text-right">
                        <p class="text-slate-400 font-bold uppercase tracking-widest text-[10px] mb-1">Payment Date</p>
                        <p class="text-lg font-black text-slate-800">@(Model.Date.HasValue ? Model.Date.Value.ToString("dd MMMM, yyyy") : "—")</p>
                        <p class="text-sm text-slate-500 font-medium">@(Model.Date.HasValue ? Model.Date.Value.ToString("HH:mm") : "")</p>
                    </div>
                </div>

                @* Invoice Body *@
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
                    <div>
                        <h3 class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Customer Details</h3>
                        <div class="bg-slate-50 rounded-3xl p-6 border border-slate-100">
                            <p class="font-black text-slate-900 text-lg">@Model.BuyerName</p>
                            <p class="text-slate-500 font-medium mt-1">@Model.BuyerEmail</p>
                        </div>
                    </div>

                    <div>
                        <h3 class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Payment Method</h3>
                        <div class="bg-slate-50 rounded-3xl p-6 border border-slate-100 flex items-center gap-4">
                            <div class="w-12 h-12 rounded-2xl bg-white border border-slate-200 flex items-center justify-center shadow-sm">
                                <span class="material-symbols-outlined text-primary">payments</span>
                            </div>
                            <div>
                                <p class="font-black text-slate-900">Paid via Stripe</p>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mt-0.5">Secure Online Payment</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* Item Detail *@
                <div class="mb-12">
                    <h3 class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Course Details</h3>
                    <div class="border border-slate-100 rounded-[2.5rem] overflow-hidden">
                        <table class="w-full text-left">
                            <thead class="bg-slate-50/80">
                                <tr>
                                    <th class="px-8 py-5 text-[11px] font-black text-slate-400 uppercase tracking-wider">Course Description</th>
                                    <th class="px-8 py-5 text-[11px] font-black text-slate-400 uppercase tracking-wider text-right">Total</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-50">
                                <tr>
                                    <td class="px-8 py-8">
                                        <div class="flex items-center gap-5">
                                            <div class="w-24 h-16 rounded-2xl bg-slate-100 overflow-hidden shrink-0 border border-slate-200">
                                                @if (!string.IsNullOrEmpty(Model.CourseThumbnail)) {
                                                    <img src="@Model.CourseThumbnail" class="w-full h-full object-cover" />
                                                } else {
                                                    <div class="w-full h-full flex items-center justify-center">
                                                        <span class="material-symbols-outlined text-slate-300">school</span>
                                                    </div>
                                                }
                                            </div>
                                            <div>
                                                <p class="font-black text-slate-900 text-lg leading-tight mb-1">@Model.CourseTitle</p>
                                                <p class="text-sm text-slate-500 font-medium">Instructor: <span class="text-slate-800 font-bold">@Model.InstructorName</span></p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-8 py-8 text-right font-black text-slate-900 text-xl">
                                        @if (Model.Status == "refunded")
                                        {
                                            <span class="text-rose-600 font-bold">- @((Model.Currency ?? "VND").ToUpper()) @Math.Abs(Model.GrossAmount).ToString("N2")</span>
                                        }
                                        else
                                        {
                                            <span>@((Model.Currency ?? "VND").ToUpper()) @Model.GrossAmount.ToString("N2")</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                @* Total Summary *@
                <div class="flex flex-col items-end gap-4 border-t border-slate-100 pt-10">
                    <div class="w-full md:w-80 space-y-3">
                        <div class="flex justify-between items-center text-slate-500 font-medium">
                            <span>Subtotal</span>
                            <span>@((Model.Currency ?? "VND").ToUpper()) @Model.OriginalPrice.ToString("N2")</span>
                        </div>
                        @if (Model.CouponUsed) {
                            <div class="flex justify-between items-center text-slate-500 font-medium">
                                <div class="flex items-center gap-2">
                                    <span>Discount</span>
                                    @if (!string.IsNullOrEmpty(Model.CouponCode)) {
                                        <span class="text-[10px] font-bold text-emerald-700 bg-emerald-100 px-2 py-0.5 rounded border border-emerald-200 uppercase">
                                            @Model.CouponCode
                                        </span>
                                    }
                                </div>
                                <span class="text-emerald-500 font-bold">- @((Model.Currency ?? "VND").ToUpper()) @Model.DiscountAmount.ToString("N2")</span>
                            </div>
                        } else {
                            <div class="flex justify-between items-center text-slate-500 font-medium">
                                <span>Discount</span>
                                <span class="text-slate-400 font-bold">- 0 USD</span>
                            </div>
                        }
                        
                        <div class="flex justify-between items-center pt-4 border-t border-slate-100">
                            <span class="text-lg font-black text-slate-900 uppercase tracking-wider">Total</span>
                            <div class="text-right">
                                @if (Model.CouponUsed) {
                                    <div class="text-sm text-slate-400 line-through mb-1">
                                        @((Model.Currency ?? "VND").ToUpper()) @Model.OriginalPrice.ToString("N2")
                                    </div>
                                }
                                <span class="text-3xl font-black @(Model.Status == "refunded" ? "text-rose-600" : "text-primary")">
                                    @if (Model.Status == "refunded")
                                    {
                                        <span>- @((Model.Currency ?? "VND").ToUpper()) @Math.Abs(Model.GrossAmount).ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span>@((Model.Currency ?? "VND").ToUpper()) @Model.GrossAmount.ToString("N2")</span>
                                    }
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                @* Footer Actions *@
                <div class="mt-16 flex flex-col md:flex-row items-center justify-between gap-6 pt-10 border-t border-dashed border-slate-200">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center">
                            <span class="material-symbols-outlined text-slate-400 text-[20px]">help_center</span>
                        </div>
                        <p class="text-xs text-slate-500 font-medium max-w-xs leading-relaxed">
                            If you have any questions regarding this invoice, please contact <a href="mailto:support@linkedlearn.com" class="text-primary font-bold hover:underline">Support</a>.
                        </p>
                    </div>
                </div>
            </div>

            @* Bottom Decoration *@
            <div class="bg-slate-50 px-8 py-6 text-center border-t border-slate-100">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Thank you for trusting and learning with LinkedLearn</p>
            </div>
        </div>
        
        <p class="text-center text-slate-400 text-xs mt-10 font-medium">
            This is an electronic invoice automatically generated by the LinkedLearn system.
        </p>
    </div>
</div>

<style>
    @@media print {
        body { background: white !important; }
        .min-h-screen { padding-bottom: 0 !important; }
        .max-w-4xl { max-width: 100% !important; margin: 0 !important; padding: 0 !important; }
        nav, aside, footer, button, .group { display: none !important; }
        .shadow-2xl, .shadow-xl, .shadow-sm { box-shadow: none !important; }
        .bg-[#f8fafc] { background: white !important; }
        .border { border-color: #f1f5f9 !important; }
        .rounded-[3rem] { border-radius: 0 !important; }
    }
</style>
