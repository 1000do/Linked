@using CourseMarketplaceFE.Controllers
@model TransactionController.TransactionDetailVM
@{
    ViewData["Title"] = $"Transaction #{Model.TransactionId}";
    ViewData["PageHeader"] = "Transaction Details";
    Layout = "_AdminLayout";

    var statusBg   = Model.Status == "succeeded" ? "bg-emerald-50 text-emerald-700 border-emerald-200"
                   : Model.Status == "failed"    ? "bg-red-50 text-red-700 border-red-200"
                   : Model.Status == "refund_pending" ? "bg-orange-50 text-orange-700 border-orange-200"
                   : Model.Status == "refunded"  ? "bg-rose-50 text-rose-700 border-rose-200"
                   : "bg-amber-50 text-amber-700 border-amber-200";
    var statusLabel = Model.Status == "succeeded" ? "Completed"
                    : Model.Status == "failed"    ? "Failed"
                    : Model.Status == "pending"   ? "Pending"
                    : Model.Status == "refund_pending" ? "Refund Pending"
                    : Model.Status == "refunded"  ? "Refunded"
                    : Model.Status ?? "—";
    var dotColor    = Model.Status == "succeeded" ? "bg-emerald-500"
                    : Model.Status == "failed"    ? "bg-red-500"
                    : Model.Status == "refund_pending" ? "bg-orange-500"
                    : Model.Status == "refunded"  ? "bg-rose-500"
                    : "bg-amber-400";
}

@section HeaderActions {
    <div class="flex items-center gap-3">
        <button type="button" onclick="window.print()" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-bold text-slate-600 hover:bg-slate-50 transition-all shadow-sm">
            <span class="material-symbols-outlined text-[18px]">print</span>
            Print Receipt
        </button>
        @if (Model.Status == "succeeded") {
            <button type="button" onclick="confirmRefund()" class="inline-flex items-center gap-2 px-4 py-2 bg-red-50 border border-red-100 rounded-lg text-sm font-bold text-red-600 hover:bg-red-100 transition-all shadow-sm">
                <span class="material-symbols-outlined text-[18px]">currency_exchange</span>
                Refund
            </button>
        } else if (Model.Status == "refunded") {
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-rose-50 border border-rose-200 rounded-lg text-sm font-bold text-rose-600 cursor-not-allowed">
                <span class="material-symbols-outlined text-[18px]">check_circle</span>
                Refunded
            </span>
        } else if (Model.Status == "refund_pending") {
            <button type="button" onclick="approveRefundDetail(@Model.TransactionId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(Model.CourseTitle))')" class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 border border-emerald-100 rounded-lg text-sm font-bold text-emerald-600 hover:bg-emerald-100 transition-all shadow-sm">
                <span class="material-symbols-outlined text-[18px]">check_circle</span>
                Duyệt hoàn tiền
            </button>
            <button type="button" onclick="rejectRefundDetail(@Model.TransactionId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(Model.CourseTitle))')" class="inline-flex items-center gap-2 px-4 py-2 bg-rose-50 border border-rose-100 rounded-lg text-sm font-bold text-rose-600 hover:bg-rose-100 transition-all shadow-sm">
                <span class="material-symbols-outlined text-[18px]">cancel</span>
                Từ chối
            </button>
        }
    </div>
    <form id="refundForm" method="post" asp-controller="AdminFinance" asp-action="Refund" asp-route-transactionId="@Model.TransactionId" class="hidden">
        @Html.AntiForgeryToken()
        <input type="hidden" name="reason" id="refundReason" />
    </form>
}

<div class="mb-6 flex items-center gap-3">
    <a href="@Url.Action("Index", "Transaction")"
       class="inline-flex items-center gap-1.5 text-sm font-bold text-slate-400 hover:text-slate-900 transition-colors">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
        Transaction List
    </a>
    <span class="text-slate-300">/</span>
    <span class="text-sm font-bold text-slate-900">Transaction Details #@Model.TransactionId</span>
</div>

@* TempData Toast Notifications *@
@if (TempData["FinanceSuccess"] != null) {
    <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-medium flex items-center gap-3">
        <span class="material-symbols-outlined text-emerald-600 text-[20px]">check_circle</span>
        @TempData["FinanceSuccess"]
    </div>
}
@if (TempData["FinanceError"] != null) {
    <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 text-sm font-medium flex items-center gap-3">
        <span class="material-symbols-outlined text-red-600 text-[20px]">error</span>
        @TempData["FinanceError"]
    </div>
}

@if (Model.Status == "refund_pending") {
    <div class="mb-8 p-6 bg-gradient-to-r from-orange-50 to-amber-50 border border-orange-200 rounded-2xl shadow-sm flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-2xl bg-orange-100 flex items-center justify-center border border-orange-200 shadow-inner shrink-0">
                <span class="material-symbols-outlined text-orange-600 text-[24px]">restart_alt</span>
            </div>
            <div>
                <h3 class="text-base font-black text-slate-900 mb-1">Yêu cầu hoàn tiền đang chờ duyệt (Refund Request Pending)</h3>
                <p class="text-sm text-slate-600">
                    Học viên đã gửi yêu cầu hoàn tiền cho khóa học này vào lúc <span class="font-bold text-slate-800">@(Model.RefundRequestedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span>.
                </p>
                <div class="mt-3 p-3 bg-white border border-orange-100 rounded-xl">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Lý do hoàn tiền của học viên</p>
                    <p class="text-sm text-slate-800 italic">"@Model.RefundReason"</p>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-2 shrink-0 w-full md:w-auto justify-end">
            <button type="button" onclick="approveRefundDetail(@Model.TransactionId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(Model.CourseTitle))')" class="px-4 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-xs rounded-xl shadow-sm transition-all active:scale-95 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-[16px]">check_circle</span>
                Duyệt
            </button>
            <button type="button" onclick="rejectRefundDetail(@Model.TransactionId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(Model.CourseTitle))')" class="px-4 py-2.5 bg-rose-600 hover:bg-rose-700 text-white font-bold text-xs rounded-xl shadow-sm transition-all active:scale-95 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-[16px]">cancel</span>
                Từ chối
            </button>
        </div>
    </div>
} else if (Model.Status == "refunded") {
    <div class="mb-8 p-6 bg-gradient-to-r from-rose-50 to-red-50 border border-rose-200 rounded-2xl shadow-sm flex items-start gap-4">
        <div class="w-12 h-12 rounded-2xl bg-rose-100 flex items-center justify-center border border-rose-200 shadow-inner shrink-0">
            <span class="material-symbols-outlined text-rose-600 text-[24px]">verified_user</span>
        </div>
        <div class="flex-1">
            <h3 class="text-base font-black text-slate-900 mb-1">Giao dịch đã được hoàn tiền thành công (Refunded)</h3>
            <p class="text-sm text-slate-600">
                Giao dịch đã hoàn tất thủ tục hoàn trả tiền qua Stripe Connect và thu hồi quyền học tập của học viên.
            </p>
            <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="p-3 bg-white border border-rose-100 rounded-xl">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Lý do hoàn tiền của học viên</p>
                    <p class="text-sm text-slate-800 italic">"@Model.RefundReason"</p>
                </div>
                @if (!string.IsNullOrEmpty(Model.RefundAdminNote)) {
                    <div class="p-3 bg-white border border-rose-100 rounded-xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Ghi chú phê duyệt của Admin</p>
                        <p class="text-sm text-slate-800">"@Model.RefundAdminNote"</p>
                    </div>
                }
            </div>
        </div>
    </div>
} else if (Model.Status == "succeeded" && !string.IsNullOrEmpty(Model.RefundAdminNote)) {
    <div class="mb-8 p-6 bg-gradient-to-r from-slate-50 to-slate-100 border border-slate-200 rounded-2xl shadow-sm flex items-start gap-4">
        <div class="w-12 h-12 rounded-2xl bg-slate-200 flex items-center justify-center border border-slate-300 shrink-0 shadow-inner">
            <span class="material-symbols-outlined text-slate-600 text-[24px]">cancel</span>
        </div>
        <div class="flex-1">
            <h3 class="text-base font-black text-slate-900 mb-1">Yêu cầu hoàn tiền trước đó đã bị từ chối</h3>
            <p class="text-sm text-slate-600">
                Giao dịch này từng có yêu cầu hoàn tiền gửi vào lúc <span class="font-bold text-slate-800">@(Model.RefundRequestedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span> nhưng đã bị Admin từ chối.
            </p>
            <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="p-3 bg-white border border-slate-200 rounded-xl">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Lý do hoàn tiền ban đầu của học viên</p>
                    <p class="text-sm text-slate-800 italic">"@Model.RefundReason"</p>
                </div>
                <div class="p-3 bg-white border border-slate-200 rounded-xl">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Lý do từ chối của Admin</p>
                    <p class="text-sm text-slate-800 font-bold">"@Model.RefundAdminNote"</p>
                </div>
            </div>
        </div>
    </div>
}

@* Banner Overview *@
<div class="bg-gradient-to-r from-slate-900 to-slate-800 rounded-2xl shadow-xl p-8 mb-8 text-white relative overflow-hidden">
    <div class="absolute right-0 top-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl -mr-32 -mt-32"></div>
    <div class="absolute left-0 bottom-0 w-48 h-48 bg-indigo-500/10 rounded-full blur-3xl -ml-24 -mb-24"></div>
    
    <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-5">
            <div class="w-16 h-16 rounded-2xl bg-white/10 backdrop-blur-md flex items-center justify-center border border-white/20">
                <span class="material-symbols-outlined text-white text-[32px]">receipt_long</span>
            </div>
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <h1 class="text-2xl font-display font-black tracking-tight">Transaction #@Model.TransactionId</h1>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white/20 backdrop-blur-md border border-white/10">
                        <span class="w-1.5 h-1.5 rounded-full @dotColor"></span>
                        @statusLabel
                    </span>
                </div>
                <p class="text-slate-400 text-sm font-medium">
                    @(Model.Date.HasValue ? Model.Date.Value.ToString("dd MMMM, yyyy 'at' HH:mm") : "Unknown date")
                </p>
            </div>
        </div>
        
        <div class="flex items-center gap-8 md:border-l md:border-white/10 md:pl-8">
            <div class="text-right">
                <p class="text-slate-400 text-[11px] font-bold uppercase tracking-wider mb-1">Payment Amount</p>
                <p class="text-3xl font-display font-black">
                    <span class="text-primary text-xl mr-1">@Model.Currency?.ToUpper()</span>@Model.GrossAmount.ToString("N2")
                </p>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    @* LEFT COLUMN - 2/3 width *@
    <div class="lg:col-span-2 space-y-8">
        
        @* Course Info *@
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[20px]">school</span>
                    Product & Details
                </h3>
            </div>
            <div class="p-6">
                <div class="flex items-center gap-5 p-4 rounded-xl bg-slate-50 border border-slate-100">
                    <div class="w-24 h-16 rounded-lg bg-slate-200 overflow-hidden shrink-0 border border-slate-200">
                        @if (!string.IsNullOrEmpty(Model.CourseThumbnail)) {
                            <img src="@Model.CourseThumbnail" class="w-full h-full object-cover" />
                        } else {
                            <div class="w-full h-full flex items-center justify-center">
                                <span class="material-symbols-outlined text-slate-400 text-[24px]">image</span>
                            </div>
                        }
                    </div>
                    <div class="flex-1 min-w-0">
                        <h4 class="font-bold text-slate-900 text-lg leading-snug truncate">@Model.CourseTitle</h4>
                        <div class="flex items-center gap-3 mt-1.5">
                            <span class="inline-flex items-center gap-1 text-xs font-bold text-slate-500">
                                <span class="material-symbols-outlined text-[14px]">id_card</span>
                                Ref: #CRS-@Model.TransactionId
                            </span>
                            <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                            <span class="inline-flex items-center gap-1 text-xs font-bold text-slate-500">
                                <span class="material-symbols-outlined text-[14px]">sell</span>
                                Type: Digital Content
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* User Partners *@
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            @* Buyer *@
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2">
                        <span class="material-symbols-outlined text-indigo-500 text-[20px]">person</span>
                        Purchaser Details
                    </h3>
                </div>
                <div class="p-6 space-y-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-indigo-100 flex items-center justify-center font-bold text-indigo-700 text-lg border border-indigo-200 shadow-inner">
                            @Model.BuyerName[..1].ToUpper()
                        </div>
                        <div class="min-w-0">
                            <p class="font-bold text-slate-900 truncate">@Model.BuyerName</p>
                            <p class="text-xs text-slate-500 truncate">@Model.BuyerEmail</p>
                        </div>
                    </div>
                    <div class="pt-4 border-t border-slate-50 flex items-center justify-between text-xs font-bold">
                        <span class="text-slate-400 uppercase tracking-wider">Role</span>
                        <span class="text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded">STUDENT</span>
                    </div>
                </div>
            </div>

            @* Instructor *@
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2">
                        <span class="material-symbols-outlined text-emerald-500 text-[20px]">co_present</span>
                        Instructor Details
                    </h3>
                </div>
                <div class="p-6 space-y-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-emerald-100 flex items-center justify-center font-bold text-emerald-700 text-lg border border-emerald-200 shadow-inner">
                            @Model.InstructorName[..1].ToUpper()
                        </div>
                        <div class="min-w-0">
                            <p class="font-bold text-slate-900 truncate">@Model.InstructorName</p>
                            <p class="text-xs text-slate-500 truncate">@Model.InstructorEmail</p>
                        </div>
                    </div>
                    <div class="pt-4 border-t border-slate-50 flex items-center justify-between text-xs font-bold">
                        <span class="text-slate-400 uppercase tracking-wider">Payout Status</span>
                        @if (Model.IsPaid) {
                            <span class="text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded flex items-center gap-1">
                                <span class="material-symbols-outlined text-[12px]">check_circle</span>
                                PAID
                            </span>
                        } else {
                            <span class="text-amber-600 bg-amber-50 px-2 py-0.5 rounded flex items-center gap-1">
                                <span class="material-symbols-outlined text-[12px]">schedule</span>
                                PENDING
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Stripe Metadata *@
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
                <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2">
                    <span class="material-symbols-outlined text-indigo-600 text-[20px]">payments</span>
                    Stripe Payment Gateway References
                </h3>
                @if (!string.IsNullOrEmpty(Model.StripeSessionId)) {
                    <a href="https://dashboard.stripe.com/payments/@Model.StripePaymentIntentId" target="_blank" 
                       class="text-[10px] font-black bg-indigo-600 text-white px-2 py-1 rounded hover:bg-indigo-700 transition-colors uppercase tracking-widest">
                        View on Stripe
                    </a>
                }
            </div>
            <div class="p-6 space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Checkout Session ID</p>
                        <div class="flex items-center gap-2">
                            <code class="text-[11px] font-mono text-slate-500 bg-slate-50 border border-slate-200 px-3 py-2 rounded-lg truncate flex-1 shadow-inner">
                                @(Model.StripeSessionId ?? "N/A")
                            </code>
                            <button onclick="copyText('@Model.StripeSessionId')" class="p-2 text-slate-400 hover:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[18px]">content_copy</span>
                            </button>
                        </div>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Payment Intent ID</p>
                        <div class="flex items-center gap-2">
                            <code class="text-[11px] font-mono text-slate-500 bg-slate-50 border border-slate-200 px-3 py-2 rounded-lg truncate flex-1 shadow-inner">
                                @(Model.StripePaymentIntentId ?? "N/A")
                            </code>
                            <button onclick="copyText('@Model.StripePaymentIntentId')" class="p-2 text-slate-400 hover:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[18px]">content_copy</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* RIGHT COLUMN - 1/3 width *@
    <div class="lg:col-span-1 space-y-8">
        
        @* Split Breakdown *@
        <div class="bg-white rounded-3xl border border-slate-200 shadow-lg overflow-hidden relative">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-primary"></div>
            <div class="p-8">
                <h3 class="text-lg font-black text-slate-900 mb-6 font-display">Split Summary</h3>
                
                <div class="space-y-4">
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-slate-500 font-medium">Course Original Price</span>
                        <span class="text-slate-900 font-bold">@Model.Currency?.ToUpper() @Model.OriginalPrice.ToString("N2")</span>
                    </div>
                    @if (Model.CouponUsed) {
                        <div class="flex items-center justify-between text-sm">
                            <div class="flex items-center gap-2">
                                <span class="text-slate-500 font-medium">Discount / Coupon</span>
                                @if (!string.IsNullOrEmpty(Model.CouponCode)) {
                                    <span class="text-[10px] font-bold text-emerald-700 bg-emerald-100 px-2 py-0.5 rounded border border-emerald-200">
                                        @Model.CouponCode
                                    </span>
                                }
                            </div>
                            <span class="text-emerald-600 font-bold">- @Model.Currency?.ToUpper() @Model.DiscountAmount.ToString("N2")</span>
                        </div>
                    } else {
                         <div class="flex items-center justify-between text-sm">
                            <span class="text-slate-500 font-medium">Discount / Coupon</span>
                            <span class="text-slate-400 font-bold">@Model.Currency?.ToUpper() 0.00</span>
                        </div>
                    }
                    <div class="pt-4 border-t border-slate-100 flex items-center justify-between">
                        <span class="text-base font-black text-slate-900 uppercase">Total Gross Revenue</span>
                        <div class="text-right">
                            @if (Model.CouponUsed) {
                                <div class="text-sm text-slate-400 line-through mb-1">
                                    @Model.Currency?.ToUpper() @Model.OriginalPrice.ToString("N2")
                                </div>
                            }
                            <span class="text-2xl font-display font-black text-slate-900">@Model.Currency?.ToUpper() @Model.GrossAmount.ToString("N2")</span>
                        </div>
                    </div>
                </div>

                <div class="mt-8 space-y-3">
                    <div class="bg-indigo-50/50 rounded-2xl p-4 border border-indigo-100/50">
                        <div class="flex items-center justify-between mb-1">
                            <p class="text-[11px] font-black text-indigo-400 uppercase tracking-widest">Platform Profit Fee</p>
                            <span class="text-[10px] font-bold text-indigo-600 bg-indigo-100 px-1.5 py-0.5 rounded">@(100 - Model.TransferRate)%</span>
                        </div>
                        <p class="text-xl font-display font-black text-indigo-700">@Model.Currency?.ToUpper() @Model.PlatformProfit.ToString("N2")</p>
                    </div>

                    <div class="@(Model.IsPaid ? "bg-emerald-50/50 border-emerald-100/50" : "bg-amber-50/50 border-amber-100/50") rounded-2xl p-4 border transition-all">
                        <div class="flex items-center justify-between mb-1">
                            <p class="text-[11px] font-black @(Model.IsPaid ? "text-emerald-400" : "text-amber-400") uppercase tracking-widest">Instructor Net Income</p>
                            <span class="text-[10px] font-bold @(Model.IsPaid ? "text-emerald-600 bg-emerald-100" : "text-amber-600 bg-amber-100") px-1.5 py-0.5 rounded">@Model.TransferRate%</span>
                        </div>
                        <p class="text-xl font-display font-black @(Model.IsPaid ? "text-emerald-700" : "text-amber-700")">@Model.Currency?.ToUpper() @Model.InstructorPayout.ToString("N2")</p>
                    </div>
                </div>

                <div class="mt-8 p-4 rounded-xl bg-slate-900 text-white shadow-xl shadow-slate-200">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center border border-primary/30">
                            <span class="material-symbols-outlined text-primary text-[20px]">verified</span>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Settlement Status</p>
                            <p class="text-sm font-bold">@statusLabel</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Quick Actions Card *@
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4">Notes & Action Plan</h3>
            <p class="text-xs text-slate-500 leading-relaxed italic">
                * The transfer rate is locked at the exact checkout time to guarantee absolute transparency between the platform and the instructor.
            </p>
            <div class="mt-6 flex flex-col gap-2">
                <button class="w-full py-2.5 rounded-xl text-xs font-bold bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">contact_support</span>
                    Contact Support
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyText(text) {
            if (!text || text === 'N/A') return;
            navigator.clipboard.writeText(text).then(() => {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Copied to clipboard',
                    showConfirmButton: false,
                    timer: 2000,
                    timerProgressBar: true
                });
            });
        }

        function confirmRefund() {
            Swal.fire({
                title: 'Refund Transaction #@Model.TransactionId',
                html: `
                    <p class="text-sm text-gray-600 mb-4">
                        This action will:<br>
                        • Refund <strong>@Model.Currency?.ToUpper() @Model.GrossAmount.ToString("N2")</strong> back to the customer<br>
                        • Revoke payouts processed for the instructor (if applicable)<br>
                        • Revoke course enrollment access
                    </p>
                    <label class="block text-left text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Refund Reason</label>
                    <select id="swal-reason" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-red-300 focus:border-red-400">
                        <option value="requested_by_customer">Requested by Customer</option>
                        <option value="duplicate">Duplicate Transaction</option>
                        <option value="fraudulent">Fraudulent Activity</option>
                    </select>
                `,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: '<i class="material-symbols-outlined text-[16px] align-middle mr-1">currency_exchange</i> Confirm Refund',
                cancelButtonText: 'Cancel',
                showLoaderOnConfirm: true,
                preConfirm: () => {
                    const reason = document.getElementById('swal-reason').value;
                    document.getElementById('refundReason').value = reason;
                    document.getElementById('refundForm').submit();
                    return false; // Keep the loading state
                },
                allowOutsideClick: () => !Swal.isLoading()
            });
        }

        function approveRefundDetail(transactionId, courseTitle) {
            Swal.fire({
                title: 'Phê duyệt hoàn tiền',
                html: `<div class="text-left font-sans">
                        <p class="text-sm text-slate-500 mb-4">Bạn có chắc chắn muốn phê duyệt hoàn tiền cho giao dịch khóa học <strong>${courseTitle}</strong>? 
                        Hệ thống sẽ thực hiện hoàn trả tiền về ví/thẻ của học viên thông qua Stripe Connect và thu hồi quyền truy cập học tập của học viên đối với khóa học này.</p>
                       </div>`,
                input: 'textarea',
                inputPlaceholder: 'Nhập ghi chú phản hồi học viên (không bắt buộc)...',
                showCancelButton: true,
                confirmButtonText: 'Đồng ý & Hoàn tiền',
                cancelButtonText: 'Hủy',
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#64748b',
                buttonsStyling: true,
                customClass: {
                    popup: 'rounded-3xl border border-slate-100 p-8 shadow-2xl',
                    title: 'text-xl font-black text-slate-900 tracking-tight',
                    confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all',
                    cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                },
                showLoaderOnConfirm: true,
                preConfirm: (adminNote) => {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const params = new URLSearchParams();
                    params.append('transactionId', transactionId);
                    params.append('adminNote', adminNote || '');

                    return fetch('/AdminFinance/ApproveRefundDecision', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: params
                    })
                    .then(response => {
                        return response.json().then(data => {
                            if (!response.ok || !data.success) {
                                throw new Error(data.message || response.statusText);
                            }
                            return data;
                        });
                    })
                    .catch(error => {
                        Swal.showValidationMessage(`Thao tác thất bại: ${error.message}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Thành công!',
                        text: result.value.message,
                        icon: 'success',
                        confirmButtonText: 'Đóng',
                        confirmButtonColor: '#10b981',
                        customClass: {
                            popup: 'rounded-3xl',
                            title: 'text-xl font-black text-slate-900',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm'
                        }
                    }).then(() => {
                        window.location.reload();
                    });
                }
            });
        }

        function rejectRefundDetail(transactionId, courseTitle) {
            Swal.fire({
                title: 'Từ chối hoàn tiền',
                html: `<div class="text-left font-sans">
                        <p class="text-sm text-slate-500 mb-4">Bạn đang từ chối yêu cầu hoàn tiền cho giao dịch khóa học <strong>${courseTitle}</strong>. 
                        Bạn phải nhập lý do từ chối cụ thể để phản hồi lại cho học viên.</p>
                       </div>`,
                input: 'textarea',
                inputPlaceholder: 'Nhập lý do từ chối hoàn tiền ở đây...',
                showCancelButton: true,
                confirmButtonText: 'Từ chối yêu cầu',
                cancelButtonText: 'Hủy',
                confirmButtonColor: '#e11d48',
                cancelButtonColor: '#64748b',
                buttonsStyling: true,
                customClass: {
                    popup: 'rounded-3xl border border-slate-100 p-8 shadow-2xl',
                    title: 'text-xl font-black text-slate-900 tracking-tight',
                    confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all',
                    cancelButton: 'px-6 py-3 font-bold rounded-2xl text-sm transition-all'
                },
                inputValidator: (value) => {
                    if (!value || value.trim() === '') {
                        return 'Bạn phải nhập lý do từ chối hoàn tiền!';
                    }
                },
                showLoaderOnConfirm: true,
                preConfirm: (adminNote) => {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const params = new URLSearchParams();
                    params.append('transactionId', transactionId);
                    params.append('adminNote', adminNote);

                    return fetch('/AdminFinance/RejectRefundDecision', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: params
                    })
                    .then(response => {
                        return response.json().then(data => {
                            if (!response.ok || !data.success) {
                                throw new Error(data.message || response.statusText);
                            }
                            return data;
                        });
                    })
                    .catch(error => {
                        Swal.showValidationMessage(`Thao tác thất bại: ${error.message}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Đã từ chối!',
                        text: result.value.message,
                        icon: 'warning',
                        confirmButtonText: 'Đóng',
                        confirmButtonColor: '#64748b',
                        customClass: {
                            popup: 'rounded-3xl',
                            title: 'text-xl font-black text-slate-900',
                            confirmButton: 'px-6 py-3 font-bold rounded-2xl text-sm'
                        }
                    }).then(() => {
                        window.location.reload();
                    });
                }
            });
        }
    </script>
}
