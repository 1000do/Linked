@using CourseMarketplaceFE.Controllers
@model CourseMarketplaceFE.Models.TransactionDetailVM
@{
    ViewData["Title"] = $"Transaction #{Model.TransactionId}";
    Layout = "_InstructorLayout";

    var statusBg   = Model.Status == "succeeded" ? "bg-emerald-50 text-emerald-700 border-emerald-200"
                   : Model.Status == "failed"    ? "bg-red-50 text-red-700 border-red-200"
                   : Model.Status == "refund_pending" ? "bg-orange-50 text-orange-700 border-orange-200"
                   : Model.Status == "refunded"  ? "bg-rose-50 text-rose-700 border-rose-200"
                   : "bg-amber-50 text-amber-700 border-amber-200";
    var statusLabel = Model.Status == "succeeded" ? "Completed"
                    : Model.Status == "failed"    ? "Failed"
                    : Model.Status == "pending"   ? "Pending"
                    : Model.Status == "refund_pending" ? "Refund Pending"
                    : Model.Status == "refunded"  ? "Refunded"
                    : Model.Status ?? "—";
    var dotColor    = Model.Status == "succeeded" ? "bg-emerald-500"
                    : Model.Status == "failed"    ? "bg-red-500"
                    : Model.Status == "refund_pending" ? "bg-orange-500"
                    : Model.Status == "refunded"  ? "bg-rose-500"
                    : "bg-amber-400";
}

<div class="min-h-screen pt-28 pb-16 max-w-7xl mx-auto px-4">
    <!-- Breadcrumbs / Back button -->
    <div class="mb-6 flex items-center gap-3">
        <a href="/Transaction/Instructor"
           class="inline-flex items-center gap-1.5 text-sm font-bold text-slate-400 hover:text-slate-900 transition-colors">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            Earnings Dashboard
        </a>
        <span class="text-slate-300">/</span>
        <span class="text-sm font-bold text-slate-900 font-headline">Transaction Details #@Model.TransactionId</span>
    </div>

    @* TempData Notifications *@
    @if (TempData["Success"] != null) {
        <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-medium flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-600 text-[20px]">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null) {
        <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 text-sm font-medium flex items-center gap-3">
            <span class="material-symbols-outlined text-red-600 text-[20px]">error</span>
            @TempData["Error"]
        </div>
    }

    @* Status Banners - Informational only for Instructors *@
    @if (Model.Status == "refund_pending") {
        <div class="mb-8 p-6 bg-gradient-to-r from-orange-50 to-amber-50 border border-orange-200 rounded-2xl shadow-sm flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-2xl bg-orange-100 flex items-center justify-center border border-orange-200 shadow-inner shrink-0">
                    <span class="material-symbols-outlined text-orange-600 text-[24px]">restart_alt</span>
                </div>
                <div>
                    <h3 class="text-base font-headline font-black text-slate-900 mb-1">Refund Request Pending Admin Approval</h3>
                    <p class="text-sm text-slate-600">
                        The student has submitted a refund request for this purchase on <span class="font-bold text-slate-800">@(Model.RefundRequestedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span>.
                    </p>
                    <div class="mt-3 p-3 bg-white border border-orange-100 rounded-xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Student's Stated Reason</p>
                        <p class="text-sm text-slate-800 italic">"@Model.RefundReason"</p>
                    </div>
                </div>
            </div>
        </div>
    } else if (Model.Status == "refunded") {
        <div class="mb-8 p-6 bg-gradient-to-r from-rose-50 to-red-50 border border-rose-200 rounded-2xl shadow-sm flex items-start gap-4">
            <div class="w-12 h-12 rounded-2xl bg-rose-100 flex items-center justify-center border border-rose-200 shadow-inner shrink-0">
                <span class="material-symbols-outlined text-rose-600 text-[24px]">verified_user</span>
            </div>
            <div class="flex-1">
                <h3 class="text-base font-headline font-black text-slate-900 mb-1">Transaction Refunded</h3>
                <p class="text-sm text-slate-600">
                    This transaction has been successfully refunded by the platform administrator via Stripe Connect. The student's access has been revoked.
                </p>
                <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="p-3 bg-white border border-rose-100 rounded-xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Student's Refund Reason</p>
                        <p class="text-sm text-slate-800 italic">"@Model.RefundReason"</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.RefundAdminNote)) {
                        <div class="p-3 bg-white border border-rose-100 rounded-xl">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Administrator's Settlement Note</p>
                            <p class="text-sm text-slate-800">"@Model.RefundAdminNote"</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    } else if (Model.Status == "succeeded" && !string.IsNullOrEmpty(Model.RefundAdminNote)) {
        <div class="mb-8 p-6 bg-gradient-to-r from-slate-50 to-slate-100 border border-slate-200 rounded-2xl shadow-sm flex items-start gap-4">
            <div class="w-12 h-12 rounded-2xl bg-slate-200 flex items-center justify-center border border-slate-300 shrink-0 shadow-inner">
                <span class="material-symbols-outlined text-slate-600 text-[24px]">cancel</span>
            </div>
            <div class="flex-1">
                <h3 class="text-base font-headline font-black text-slate-900 mb-1">Refund Request Rejected</h3>
                <p class="text-sm text-slate-600">
                    A refund request was previously submitted on <span class="font-bold text-slate-800">@(Model.RefundRequestedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</span> but has been rejected by the administrator.
                </p>
                <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="p-3 bg-white border border-slate-200 rounded-xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Student's original reason</p>
                        <p class="text-sm text-slate-800 italic">"@Model.RefundReason"</p>
                    </div>
                    <div class="p-3 bg-white border border-slate-200 rounded-xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Rejection Decision Note</p>
                        <p class="text-sm text-slate-800 font-bold">"@Model.RefundAdminNote"</p>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Banner Overview *@
    <div class="bg-gradient-to-r from-slate-900 to-slate-800 rounded-2xl shadow-xl p-8 mb-8 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl -mr-32 -mt-32"></div>
        <div class="absolute left-0 bottom-0 w-48 h-48 bg-indigo-500/10 rounded-full blur-3xl -ml-24 -mb-24"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex items-center gap-5">
                <div class="w-16 h-16 rounded-2xl bg-white/10 backdrop-blur-md flex items-center justify-center border border-white/20">
                    <span class="material-symbols-outlined text-white text-[32px]">receipt_long</span>
                </div>
                <div>
                    <div class="flex items-center gap-3 mb-1">
                        <h1 class="text-2xl font-headline font-extrabold tracking-tight">Transaction #@Model.TransactionId</h1>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-white/20 backdrop-blur-md border border-white/10">
                            <span class="w-1.5 h-1.5 rounded-full @dotColor"></span>
                            @statusLabel
                        </span>
                    </div>
                    <p class="text-slate-400 text-sm font-medium">
                        @(Model.Date.HasValue ? Model.Date.Value.ToString("dd MMMM, yyyy 'at' HH:mm") : "Unknown date")
                    </p>
                </div>
            </div>
            
            <div class="flex items-center gap-8 md:border-l md:border-white/10 md:pl-8">
                <div class="text-right">
                    <p class="text-slate-400 text-[11px] font-bold uppercase tracking-wider mb-1">Student Paid</p>
                    <p class="text-3xl font-headline font-black @(Model.Status == "refunded" ? "text-rose-400" : "")">
                        @if (Model.Status == "refunded")
                        {
                            <span class="text-rose-400 text-xl mr-1">- $</span>@Math.Abs(Model.GrossAmount).ToString("N2")
                        }
                        else
                        {
                            <span class="text-primary text-xl mr-1">$</span>@Model.GrossAmount.ToString("N2")
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        @* LEFT COLUMN - 2/3 width *@
        <div class="lg:col-span-2 space-y-8">
            
            @* Course Info *@
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2 font-headline">
                        <span class="material-symbols-outlined text-primary text-[20px]">school</span>
                        Product Details
                    </h3>
                </div>
                <div class="p-6">
                    <div class="flex items-center gap-5 p-4 rounded-xl bg-slate-50 border border-slate-100">
                        <div class="w-24 h-16 rounded-lg bg-slate-200 overflow-hidden shrink-0 border border-slate-200">
                            @if (!string.IsNullOrEmpty(Model.CourseThumbnail)) {
                                <img src="@Model.CourseThumbnail" class="w-full h-full object-cover" />
                            } else {
                                <div class="w-full h-full flex items-center justify-center">
                                    <span class="material-symbols-outlined text-slate-400 text-[24px]">image</span>
                                </div>
                            }
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="font-bold text-slate-900 text-lg leading-snug truncate">@Model.CourseTitle</h4>
                            <div class="flex items-center gap-3 mt-1.5">
                                <span class="inline-flex items-center gap-1 text-xs font-bold text-slate-500">
                                    <span class="material-symbols-outlined text-[14px]">id_card</span>
                                    Ref: #CRS-@Model.TransactionId
                                </span>
                                <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                                <span class="inline-flex items-center gap-1 text-xs font-bold text-slate-500">
                                    <span class="material-symbols-outlined text-[14px]">sell</span>
                                    Type: Digital Content
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Buyer details (Instructor only sees relevant details of their buyer) *@
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2 font-headline">
                        <span class="material-symbols-outlined text-indigo-500 text-[20px]">person</span>
                        Purchaser Details
                    </h3>
                </div>
                <div class="p-6 space-y-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-indigo-100 flex items-center justify-center font-black text-indigo-700 text-lg border border-indigo-200 shadow-inner font-headline">
                            @Model.BuyerName[..1].ToUpper()
                        </div>
                        <div class="min-w-0">
                            <p class="font-bold text-slate-900 truncate">@Model.BuyerName</p>
                            <p class="text-xs text-slate-500 truncate">@Model.BuyerEmail</p>
                        </div>
                    </div>
                    <div class="pt-4 border-t border-slate-100 flex items-center justify-between text-xs font-bold">
                        <span class="text-slate-400 uppercase tracking-wider">Role</span>
                        <span class="text-indigo-600 bg-indigo-50 px-2.5 py-0.5 rounded font-extrabold">STUDENT</span>
                    </div>
                </div>
            </div>

            @* Stripe Payment Secure References *@
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
                    <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2 font-headline">
                        <span class="material-symbols-outlined text-indigo-600 text-[20px]">payments</span>
                        Stripe Payment Gateway References
                    </h3>
                </div>
                <div class="p-6 space-y-5">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Checkout Session ID</p>
                            <div class="flex items-center gap-2">
                                <code class="text-[11px] font-mono text-slate-500 bg-slate-50 border border-slate-200 px-3 py-2 rounded-lg truncate flex-1 shadow-inner">
                                    @(Model.StripeSessionId ?? "N/A")
                                </code>
                                <button onclick="copyText('@Model.StripeSessionId')" class="p-2 text-slate-400 hover:text-primary transition-colors flex items-center justify-center bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-lg shadow-sm">
                                    <span class="material-symbols-outlined text-[16px]">content_copy</span>
                                </button>
                            </div>
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Payment Intent ID</p>
                            <div class="flex items-center gap-2">
                                <code class="text-[11px] font-mono text-slate-500 bg-slate-50 border border-slate-200 px-3 py-2 rounded-lg truncate flex-1 shadow-inner">
                                    @(Model.StripePaymentIntentId ?? "N/A")
                                </code>
                                <button onclick="copyText('@Model.StripePaymentIntentId')" class="p-2 text-slate-400 hover:text-primary transition-colors flex items-center justify-center bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-lg shadow-sm">
                                    <span class="material-symbols-outlined text-[16px]">content_copy</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* RIGHT COLUMN - 1/3 width *@
        <div class="lg:col-span-1 space-y-8">
            
            @* Split Summary *@
            <div class="bg-white rounded-3xl border border-slate-200 shadow-lg overflow-hidden relative">
                <div class="absolute top-0 left-0 w-full h-1.5 bg-primary"></div>
                <div class="p-8">
                    <h3 class="text-lg font-headline font-black text-slate-900 mb-6">Split Summary</h3>
                    
                    @{
                        var stripeFee = Math.Round(Model.GrossAmount * 0.029m + 0.30m, 2);
                        stripeFee = Math.Min(stripeFee, Model.GrossAmount);
                        var netPrice = Model.GrossAmount - stripeFee;
                        var netPlatformProfit = Model.PlatformProfit - stripeFee;
                    }

                    <div class="space-y-4">
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-slate-500 font-medium">Original Course Price</span>
                            <span class="text-slate-900 font-bold">$@Model.OriginalPrice.ToString("N2")</span>
                        </div>
                        @if (Model.CouponUsed) {
                            <div class="flex items-center justify-between text-sm">
                                <div class="flex items-center gap-2">
                                    <span class="text-slate-500 font-medium">Coupon Discount</span>
                                    @if (!string.IsNullOrEmpty(Model.CouponCode)) {
                                        <span class="text-[10px] font-bold text-emerald-700 bg-emerald-100 px-2 py-0.5 rounded border border-emerald-200">
                                            @Model.CouponCode
                                        </span>
                                    }
                                </div>
                                <span class="text-emerald-600 font-bold">- $@Model.DiscountAmount.ToString("N2")</span>
                            </div>
                        } else {
                            <div class="flex items-center justify-between text-sm">
                                <span class="text-slate-500 font-medium">Coupon Discount</span>
                                <span class="text-slate-400 font-bold">$0.00</span>
                            </div>
                        }
                        <div class="pt-4 border-t border-slate-100 flex items-center justify-between">
                            <span class="text-base font-bold text-slate-955 uppercase font-headline">Gross Amount</span>
                            <div class="text-right">
                                @if (Model.CouponUsed) {
                                    <div class="text-xs text-slate-400 line-through mb-1">
                                        $@Model.OriginalPrice.ToString("N2")
                                    </div>
                                }
                                @if (Model.Status == "refunded") {
                                    <span class="text-2xl font-headline font-black text-rose-600">- $@Math.Abs(Model.GrossAmount).ToString("N2")</span>
                                } else {
                                    <span class="text-2xl font-headline font-black text-slate-955">$@Model.GrossAmount.ToString("N2")</span>
                                }
                            </div>
                        </div>
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-slate-500 font-medium flex items-center gap-1">
                                Stripe Processing Fee
                                <span class="text-[9px] font-bold text-slate-400 bg-slate-100 px-1 py-0.2 rounded border border-slate-200/50">2.9% + $0.30</span>
                            </span>
                            <span class="text-rose-600 font-bold">- $@stripeFee.ToString("N2")</span>
                        </div>
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-slate-500 font-medium">Net Course Revenue to Split</span>
                            <span class="text-slate-900 font-black">$@netPrice.ToString("N2")</span>
                        </div>
                    </div>

                    <div class="mt-8 space-y-3">
                        <div class="@(Model.Status == "refunded" ? "bg-rose-50/30 border-rose-100/50" : "bg-indigo-50/50 rounded-2xl p-4 border border-indigo-100/50") rounded-2xl p-4 border transition-all">
                            <div class="flex items-center justify-between mb-1">
                                <p class="text-[11px] font-black @(Model.Status == "refunded" ? "text-rose-400" : "text-indigo-400") uppercase tracking-widest">Platform Net Profit</p>
                                <span class="text-[10px] font-bold @(Model.Status == "refunded" ? "text-rose-600 bg-rose-100" : "text-indigo-600 bg-indigo-100") px-1.5 py-0.5 rounded">@(100 - Model.TransferRate)%</span>
                            </div>
                            @if (Model.Status == "refunded") {
                                <p class="text-xl font-headline font-black text-rose-600">- $@Math.Abs(netPlatformProfit).ToString("N2")</p>
                            } else {
                                <p class="text-xl font-headline font-black text-indigo-700">$@netPlatformProfit.ToString("N2")</p>
                            }
                        </div>

                        <div class="@(Model.Status == "refunded" ? "bg-rose-50/50 border-rose-200" : Model.IsPaid ? "bg-emerald-50/50 border-emerald-100/50" : "bg-amber-50/50 border-amber-100/50") rounded-2xl p-4 border transition-all">
                            <div class="flex items-center justify-between mb-1">
                                <p class="text-[11px] font-black @(Model.Status == "refunded" ? "text-rose-500" : Model.IsPaid ? "text-emerald-500" : "text-amber-500") uppercase tracking-widest">Instructor Net Income</p>
                                <span class="text-[10px] font-bold @(Model.Status == "refunded" ? "text-rose-600 bg-rose-100" : Model.IsPaid ? "text-emerald-600 bg-emerald-100" : "text-amber-600 bg-amber-100") px-1.5 py-0.5 rounded">@Model.TransferRate%</span>
                            </div>
                            @if (Model.Status == "refunded") {
                                <p class="text-xl font-headline font-black text-rose-700">- $@Math.Abs(Model.InstructorPayout).ToString("N2")</p>
                            } else {
                                <p class="text-xl font-headline font-black @(Model.IsPaid ? "text-emerald-700" : "text-amber-700")">$@Model.InstructorPayout.ToString("N2")</p>
                            }
                        </div>
                    </div>

                    <div class="mt-8 p-4 rounded-xl bg-slate-900 text-white shadow-xl shadow-slate-200">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center border border-primary/30 shrink-0">
                                <span class="material-symbols-outlined text-primary text-[20px]">verified</span>
                            </div>
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Settlement Status</p>
                                <p class="text-sm font-bold">@statusLabel</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Notes & Actions Card *@
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
                <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Notes & Settlement Policy</h3>
                <p class="text-xs text-slate-500 leading-relaxed italic">
                    * Split rates and payout currencies are locked at the time of purchase to ensure stable cash flows for both parties and avoid exchange rate fluctuations.
                </p>
                <div class="mt-6 flex flex-col gap-2">
                    <button type="button" class="w-full py-2.5 rounded-xl text-xs font-bold bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all flex items-center justify-center gap-2 border border-slate-200">
                        <span class="material-symbols-outlined text-[18px]">contact_support</span>
                        Contact Partner Support
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyText(text) {
            if (!text || text === 'N/A') return;
            navigator.clipboard.writeText(text).then(() => {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Copied Reference Code!',
                    showConfirmButton: false,
                    timer: 2000,
                    timerProgressBar: true
                });
            });
        }
    </script>
}
