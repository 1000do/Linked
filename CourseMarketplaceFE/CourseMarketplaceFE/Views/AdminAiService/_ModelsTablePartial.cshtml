@model CourseMarketplaceFE.Models.AdminAiServicePageViewModel

<table class="w-full text-left border-collapse">
    <thead>
        <tr class="border-b border-slate-200 bg-slate-50/50">
            <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Model</th>
            <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Type / Process</th>
            <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Last Modified</th>
            <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider text-center">Actions</th>
        </tr>
    </thead>
    <tbody class="divide-y divide-slate-100 text-sm">
        @if(Model.AiModels.Any()) {
            @foreach(var item in Model.AiModels) {
                <tr class="hover:bg-slate-50/30 transition-colors">
                    <td class="px-6 py-4">
                        <div class="flex flex-col">
                            <span class="font-semibold text-slate-900">@item.ModelName <span class="text-xs text-slate-400 font-normal ml-1">v@(item.ModelVersion)</span></span>
                            <span class="text-[11px] text-slate-500 font-mono mt-0.5">@item.ModelPath</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 align-middle">
                        <div class="flex flex-col gap-0.5">
                            <span class="text-slate-700 capitalize">@item.ModelType.Replace("_", " ")</span>
                            <span class="text-xs text-slate-400 capitalize">@item.ProcessType</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 align-middle">
                        <div class="flex items-center gap-2">
                            @if(item.ModelStatus == "active") {
                                <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
                                <span class="font-medium text-emerald-600 text-xs">Active</span>
                            } else {
                                <span class="w-2.5 h-2.5 rounded-full bg-slate-300"></span>
                                <span class="font-medium text-slate-500 text-xs">Inactive</span>
                            }
                        </div>
                    </td>
                    <td class="px-6 py-4 align-middle text-slate-500 text-xs">
                        @item.ModelUpdatedAt?.ToString("MMM dd yyyy HH:mm:ss")
                    </td>
                    <td class="px-6 py-4 align-middle text-center">
                        <div class="flex items-center justify-center gap-2">
                            <button type="button" onclick="openDetailsModal(this)"
                                    data-id="@item.ModelId"
                                    data-name="@item.ModelName"
                                    data-version="@item.ModelVersion"
                                    data-provider="@item.ModelProvider"
                                    data-type="@item.ModelType"
                                    data-process="@item.ProcessType"
                                    data-path="@item.ModelPath"
                                    data-desc="@item.Description"
                                    data-updated="@item.ModelUpdatedAt?.ToString("MMM dd yyyy HH:mm:ss")"
                                    class="p-1.5 text-slate-400 hover:text-indigo-600 transition-colors" title="View Details">
                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                            </button>
                            <button type="button" onclick="openEditAiModelModal(this)"
                                    data-id="@item.ModelId"
                                    data-provider="@item.ModelProvider"
                                    data-version="@item.ModelVersion"
                                    data-path="@item.ModelPath"
                                    data-desc="@item.Description"
                                    class="p-1.5 text-slate-400 hover:text-slate-900 transition-colors" title="Edit Model">
                                <span class="material-symbols-outlined text-[18px]">edit</span>
                            </button>
                            <button onclick="toggleModelStatus(@item.ModelId)" class="relative inline-flex h-5 w-9 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-300 ease-out focus:outline-none @(item.ModelStatus == "active" ? "bg-emerald-500" : "bg-slate-200")" title="Toggle Status">
                                <span class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow-sm transition duration-300 ease-out @(item.ModelStatus == "active" ? "translate-x-4" : "translate-x-0")"></span>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        } else {
            <tr>
                <td colspan="5" class="px-6 py-8 text-center text-slate-500">No AI Models found.</td>
            </tr>
        }
    </tbody>
</table>

@if(ViewBag.ModelTotalPages > 1) {
    <div class="px-6 py-4 border-t border-slate-200 flex justify-between items-center bg-slate-50">
        <button onclick="fetchPage('models', @(ViewBag.ModelPage - 1))" class="px-3 py-1.5 text-sm font-semibold rounded bg-white border border-slate-300 text-slate-700 hover:bg-slate-50 @(ViewBag.ModelPage <= 1 ? "pointer-events-none opacity-50" : "")">Previous</button>
        <span class="text-sm text-slate-500">Page @ViewBag.ModelPage of @ViewBag.ModelTotalPages</span>
        <button onclick="fetchPage('models', @(ViewBag.ModelPage + 1))" class="px-3 py-1.5 text-sm font-semibold rounded bg-white border border-slate-300 text-slate-700 hover:bg-slate-50 @(ViewBag.ModelPage >= ViewBag.ModelTotalPages ? "pointer-events-none opacity-50" : "")">Next</button>
    </div>
}
