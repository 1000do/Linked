@model CourseMarketplaceFE.Models.ReviewModerationLogViewModel
@using System.Text.Json
@{
    var type = ViewBag.ReviewType as string ?? "course";
    var titleText = type == "course" ? "Course Review" : "Lesson Review";
    ViewData["Title"] = "AI Moderation Details";
    ViewData["PageHeader"] = $"{titleText} Evaluation Record";
    Layout = "_AdminLayout";

    JsonElement? inputData = null;
    JsonElement? outputData = null;
    try {
        if (!string.IsNullOrEmpty(Model.InputJson)) {
            inputData = JsonDocument.Parse(Model.InputJson).RootElement;
        }
        if (!string.IsNullOrEmpty(Model.OutputJson)) {
            outputData = JsonDocument.Parse(Model.OutputJson).RootElement;
        }
    } catch { }
}

<div class="flex flex-col gap-6 max-w-7xl mx-auto">
    <!-- Breadcrumb back link -->
    <div class="flex items-center gap-2">
        @{
            var q = Context.Request.QueryString.Value;
            var defaultTab = type == "course" ? "course_review" : "lesson_review";
            var backUrl = Url.Action("Index", "AdminAiService") + (string.IsNullOrEmpty(q) ? $"?tab=logs&subtab={defaultTab}" : q);
        }
        <a href="@backUrl" class="inline-flex items-center gap-1.5 text-xs font-semibold text-slate-500 hover:text-slate-900 transition-colors">
            <span class="material-symbols-outlined text-[16px]">arrow_back</span>
            Back to Activity Logs
        </a>
    </div>

    <!-- Header Card -->
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 flex flex-col gap-6 relative overflow-hidden">
        <div class="flex flex-col gap-3 relative z-10">
            <div class="flex items-center justify-between flex-wrap gap-4">
                <div class="flex items-center gap-2.5">
                    <span class="font-mono text-xs font-bold text-slate-400">LOG-@Model.LogId</span>
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-slate-50 border border-slate-200 rounded-lg text-xs font-semibold text-slate-700">
                        <span class="material-symbols-outlined text-[16px]">comment</span>
                        Review ID: @Model.ReviewId
                    </span>
                    
                    @if(Model.ResultStatus == "Flagged") {
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-rose-50 text-rose-700 border border-rose-200">Flagged</span>
                    } else if (Model.ResultStatus == "ERROR" || !string.IsNullOrEmpty(Model.ErrorMessage)) {
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-red-50 text-red-700 border border-red-200">Error</span>
                    } else {
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200">@Model.ResultStatus</span>
                    }
                </div>
            </div>
            
            <div class="bg-slate-50/50 border border-slate-100 rounded-xl p-4">
                <p class="text-sm font-medium text-slate-800 italic">"@Model.Comment"</p>
            </div>
            
            <div class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-2 text-sm mt-2">
                <div class="flex flex-col">
                    <span class="text-[10px] uppercase font-bold text-slate-400">Model Used</span>
                    <span class="font-medium text-slate-700">@Model.ModelName <span class="text-slate-400 text-xs">(ID: @Model.ModelId)</span></span>
                </div>
                <div class="flex flex-col">
                    <span class="text-[10px] uppercase font-bold text-slate-400">Performance</span>
                    <span class="font-medium text-slate-700">@Model.LatencyMs ms</span>
                </div>
                <div class="flex flex-col">
                    <span class="text-[10px] uppercase font-bold text-slate-400">Logged At</span>
                    <span class="font-medium text-slate-700">@Model.LogCreatedAt.ToString("MMM dd yyyy HH:mm:ss")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Error Banner -->
    @if(!string.IsNullOrEmpty(Model.ErrorMessage)) {
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 flex items-start gap-3">
            <span class="material-symbols-outlined text-red-600 mt-0.5">error</span>
            <div class="flex flex-col">
                <h4 class="text-sm font-bold text-red-800">Execution Error</h4>
                <p class="text-sm text-red-600 mt-1">@Model.ErrorMessage</p>
            </div>
        </div>
    }

    <!-- Output Data Table -->
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm flex flex-col overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
            <h3 class="text-sm font-bold text-slate-900">Moderation I/O Details</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-100 bg-white">
                        <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Thresholds</th>
                        <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Result / Score</th>
                        <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Reason</th>
                        <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Timestamp</th>
                        <th class="px-6 py-3.5 text-[11px] font-semibold text-slate-500 uppercase tracking-wider text-center">Output Details</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm bg-white">
                    <tr class="hover:bg-slate-50/30 transition-colors">
                        <td class="px-6 py-4 align-top">
                            @if(inputData.HasValue) {
                                <div class="flex flex-col gap-1 text-[11px]">
                                    @if(inputData.Value.TryGetProperty("spam_score_threshold", out var spam)) {
                                        <span class="text-slate-600">Spam: <span class="font-medium text-slate-900">@spam</span></span>
                                    }
                                    @if(inputData.Value.TryGetProperty("toxic_score_threshold", out var toxic)) {
                                        <span class="text-slate-600">Toxic: <span class="font-medium text-slate-900">@toxic</span></span>
                                    }
                                </div>
                            } else {
                                <span class="text-xs text-slate-400 italic">No input data</span>
                            }
                        </td>
                        <td class="px-6 py-4 align-top">
                            @if(outputData.HasValue) {
                                <div class="flex flex-col">
                                    @{
                                        string res = outputData.Value.TryGetProperty("result", out var r) ? r.ToString() ?? "" : "";
                                        string resClass = res == "Flagged" ? "text-rose-600" : "text-emerald-600";
                                    }
                                    <span class="font-bold @resClass">@res</span>
                                    <span class="text-xs font-mono text-slate-500">@(outputData.Value.TryGetProperty("confidence_score", out var conf) ? conf.GetRawText() : "N/A")</span>
                                </div>
                            }
                        </td>
                        <td class="px-6 py-4 align-top text-xs text-slate-700 max-w-sm truncate" title="@(outputData.HasValue && outputData.Value.TryGetProperty("reason", out var rs) ? rs.ToString() : "")">
                            @(outputData.HasValue && outputData.Value.TryGetProperty("reason", out var rea) ? rea.ToString() : "-")
                        </td>
                        <td class="px-6 py-4 align-top text-xs text-slate-500 whitespace-nowrap">
                            @(outputData.HasValue && outputData.Value.TryGetProperty("timestamp", out var ts) ? ts.ToString() : "-")
                        </td>
                        <td class="px-6 py-4 align-top text-center">
                            @if(outputData.HasValue && outputData.Value.TryGetProperty("details", out var details)) {
                                <button onclick="openRawDetailsModal(this.getAttribute('data-json'))" data-json="@details.GetRawText()" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded transition-colors" title="View Raw JSON">
                                    <span class="material-symbols-outlined text-[18px]">data_object</span>
                                </button>
                            } else {
                                <span class="text-xs text-slate-300">-</span>
                            }
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ========================================================================= -->
<!-- MODAL: RAW JSON DETAILS -->
<!-- ========================================================================= -->
<div id="rawDetailsModal" class="fixed inset-0 z-50 hidden bg-slate-950/40 backdrop-blur-sm flex items-center justify-center p-4 transition-all duration-300 ease-out opacity-0">
    <div class="bg-white border border-slate-200 rounded-2xl shadow-2xl w-full max-w-2xl overflow-hidden transform scale-95 transition-all duration-300 ease-out flex flex-col max-h-[85vh]">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between shrink-0 bg-slate-50/50">
            <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-600 text-[20px]">data_object</span>
                Raw Output Details
            </h3>
            <button onclick="closeRawDetailsModal()" class="text-slate-400 hover:text-slate-600">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
        <div class="p-6 overflow-y-auto custom-scrollbar flex-1 bg-slate-900">
            <pre><code id="rawDetailsContent" class="text-sm font-mono text-emerald-400 whitespace-pre-wrap break-all"></code></pre>
        </div>
        <div class="p-4 border-t border-slate-100 flex justify-end shrink-0 bg-white">
            <button onclick="closeRawDetailsModal()" class="px-4 py-2 text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 rounded-lg transition-colors">Close</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openRawDetailsModal(jsonString) {
            try {
                const jsonObj = JSON.parse(jsonString);
                const formattedJson = JSON.stringify(jsonObj, null, 4);
                document.getElementById('rawDetailsContent').textContent = formattedJson;
            } catch (e) {
                document.getElementById('rawDetailsContent').textContent = jsonString;
            }

            const modal = document.getElementById('rawDetailsModal');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.firstElementChild.classList.remove('scale-95');
            }, 10);
        }

        function closeRawDetailsModal() {
            const modal = document.getElementById('rawDetailsModal');
            modal.classList.add('opacity-0');
            modal.firstElementChild.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }
    </script>
}
