        async function submitThresholds(e) {
            e.preventDefault();
            
            const origSpam = '@Model.Config.SpamConfidenceThreshold';
            const origTox = '@Model.Config.ToxicityConfidenceThreshold';
            const origSim = '@Model.Config.SimilarityScoreThreshold';
            
            let spamInput = document.getElementById('spamThreshold');
            let toxInput = document.getElementById('toxicityThreshold');
            let simInput = document.getElementById('similarityThreshold');
            
            if (!spamInput.value) {
                if (origSpam) spamInput.value = origSpam;
                else return Swal.fire('Error', 'Spam threshold is required.', 'error');
            }
            if (!toxInput.value) {
                if (origTox) toxInput.value = origTox;
                else return Swal.fire('Error', 'Toxicity threshold is required.', 'error');
            }
            if (!simInput.value) {
                if (origSim) simInput.value = origSim;
                else return Swal.fire('Error', 'Similarity threshold is required.', 'error');
            }

            const body = {
                SpamConfidenceThreshold: parseFloat(spamInput.value),
                ToxicityConfidenceThreshold: parseFloat(toxInput.value),
                SimilarityScoreThreshold: parseFloat(simInput.value)
            };

            const confirm = await Swal.fire({
                title: 'Update Thresholds?',
                text: "This will affect how strict the AI moderation is.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0f172a',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Yes, update',
                customClass: { popup: 'rounded-2xl border border-slate-100 shadow-xl' }
            });

            if (!confirm.isConfirmed) return;

            const res = await fetch('/AdminAiService/UpdateThresholds', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });

            if(res.ok) {
                Swal.fire({ 
                    title: 'Success', 
                    text: 'Thresholds updated successfully', 
                    icon: 'success', 
                    customClass: { 
                        popup: 'rounded-2xl border border-slate-100 shadow-xl' } });
            } else {
                const err = await res.json();
                Swal.fire('Error', err.Message || 'Failed to update', 'error');
            }
        }

        async function submitIntegration(e) {
            e.preventDefault();
            
            const selectIds = ['courseHarmfulText', 'courseTextEmbed', 'courseMediaEmbed', 'reviewHarmfulText'];
            const keyMapping = {
                'courseHarmfulText': 'course_harmful_text_classifier',
                'courseTextEmbed': 'course_text_embedding_generator',
                'courseMediaEmbed': 'course_media_embedding_generator',
                'reviewHarmfulText': 'review_harmful_text_classifier'
            };
            
            for (let id of selectIds) {
                const el = document.getElementById(id);
                if (!el.value) {
                    return Swal.fire('Error', 'All integration configurations are required.', 'error');
                }
            }
            
            const confirm = await Swal.fire({
                title: 'Update Integrations?',
                text: "This will change which models handle specific features.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0f172a',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Yes, update mappings',
                customClass: { popup: 'rounded-2xl border border-slate-100 shadow-xl' }
            });

            if (!confirm.isConfirmed) return;

            let success = true;
            for (let id of selectIds) {
                const el = document.getElementById(id);
                const res = await fetch('/AdminAiService/UpdateIntegration', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ConfigKey: keyMapping[id], ConfigValue: el.value })
                });
                if(!res.ok) success = false;
            }

            if (success) {
                Swal.fire({ 
                    title: 'Success', 
                    text: 'Integration configs saved', 
                    icon: 'success', 
                    customClass: { 
                        popup: 'rounded-2xl border border-slate-100 shadow-xl' } });
            } else {
                Swal.fire('Error', 'Failed to update some configurations', 'error');
            }
        }

