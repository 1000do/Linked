@model CourseMarketplaceFE.Models.AdminAiServicePageViewModel
@{
    ViewData["Title"] = "AI Service Management";
    ViewData["PageHeader"] = "AI Models & Integrations";
    Layout = "_AdminLayout";
    var activeTab = ViewBag.ActiveTab as string ?? "models";
    var activeSubtab = ViewBag.ActiveSubtab as string ?? "course";
}

<div class="flex flex-col gap-6">
    <!-- Header with Stats & Actions -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">AI Service Configuration</h1>
            <p class="text-sm text-slate-500">Manage AI models, configure thresholds, and monitor moderation logs.</p>
        </div>
        <div class="flex items-center gap-2">
            <button onclick="openAddAiModelModal()" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-slate-900 hover:bg-slate-800 rounded-lg shadow-sm transition-all">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Add AI Model
            </button>
        </div>
    </div>

    <!-- Quick Settings / Config Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <!-- Confidence Thresholds -->
        <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-5 flex flex-col gap-4">
            <h3 class="text-sm font-bold text-slate-900 flex items-center gap-2">
                <span class="material-symbols-outlined text-indigo-600 text-[18px]">tune</span>
                AI Moderation Thresholds
            </h3>
            <form id="thresholdsForm" onsubmit="submitThresholds(event)" class="flex flex-col gap-3 flex-1">
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-700">Spam Confidence</label>
                        <input type="number" step="0.01" min="0.01" max="1" id="spamThreshold" value="@Model.Config.SpamConfidenceThreshold" 
                               class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-700">Toxicity Confidence</label>
                        <input type="number" step="0.01" min="0.01" max="1" id="toxicityThreshold" value="@Model.Config.ToxicityConfidenceThreshold" 
                               class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-700">Similarity Score</label>
                        <input type="number" step="0.01" min="0.01" max="1" id="similarityThreshold" value="@Model.Config.SimilarityScoreThreshold" 
                               class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
                    </div>
                </div>
                <div class="flex justify-end mt-4 lg:mt-auto">
                    <button type="submit" class="px-4 py-2 text-xs font-semibold bg-slate-900 hover:bg-slate-800 text-white rounded-lg transition-colors shadow-sm">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>

        <!-- AI Integration Setup -->
        <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-5 flex flex-col gap-4">
            <h3 class="text-sm font-bold text-slate-900 flex items-center gap-2">
                <span class="material-symbols-outlined text-emerald-600 text-[18px]">integration_instructions</span>
                AI Integration Mapping
            </h3>
            <form id="integrationForm" onsubmit="submitIntegration(event)" class="flex flex-col gap-3 flex-1">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-3">
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-700">Course Harmful Text Classifier</label>
                        <select id="courseHarmfulText" class="px-3.5 py-2 text-[13px] border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors">
                            @foreach (var m in Model.AllActiveModels.Where(x => x.ModelType == "classifier" && x.ProcessType == "text")) {
                                <option value="@m.ModelPath" selected="@(m.ModelPath == Model.Config.CourseHarmfulTextClassifierPath)">@m.ModelName (@m.ModelPath)</option>
                            }
                        </select>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-700">Course Text Embedding</label>
                        <select id="courseTextEmbed" class="px-3.5 py-2 text-[13px] border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors">
                            @foreach (var m in Model.AllActiveModels.Where(x => x.ModelType == "embedding_generator" && x.ProcessType == "text")) {
                                <option value="@m.ModelPath" selected="@(m.ModelPath == Model.Config.CourseTextEmbeddingGeneratorPath)">@m.ModelName (@m.ModelPath)</option>
                            }
                        </select>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-700">Course Media Embedding</label>
                        <select id="courseMediaEmbed" class="px-3.5 py-2 text-[13px] border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors">
                            @foreach (var m in Model.AllActiveModels.Where(x => x.ModelType == "embedding_generator" && x.ProcessType == "media")) {
                                <option value="@m.ModelPath" selected="@(m.ModelPath == Model.Config.CourseMediaEmbeddingGeneratorPath)">@m.ModelName (@m.ModelPath)</option>
                            }
                        </select>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs font-bold text-slate-700">Review Harmful Text Classifier</label>
                        <select id="reviewHarmfulText" class="px-3.5 py-2 text-[13px] border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors">
                            @foreach (var m in Model.AllActiveModels.Where(x => x.ModelType == "classifier" && x.ProcessType == "text")) {
                                <option value="@m.ModelPath" selected="@(m.ModelPath == Model.Config.ReviewHarmfulTextClassifierPath)">@m.ModelName (@m.ModelPath)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="flex justify-end mt-4 lg:mt-auto">
                    <button type="submit" class="px-4 py-2 text-xs font-semibold bg-slate-900 hover:bg-slate-800 text-white rounded-lg transition-colors shadow-sm">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Main Content Tabs -->
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden flex flex-col">
        <div class="px-6 border-b border-slate-200 bg-slate-50/50 flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div class="flex overflow-x-auto gap-4 py-3">
                <button onclick="switchMainTab('models')" id="main-tab-models" 
                        class="px-3 py-2 text-sm font-semibold transition-colors whitespace-nowrap focus:outline-none @(activeTab == "models" ? "border-b-2 border-slate-900 text-slate-900" : "border-b-2 border-transparent text-slate-500 hover:text-slate-900")">
                    All AI Models
                </button>
                <button onclick="switchMainTab('logs')" id="main-tab-logs" 
                        class="px-3 py-2 text-sm font-semibold transition-colors whitespace-nowrap focus:outline-none @(activeTab == "logs" ? "border-b-2 border-slate-900 text-slate-900" : "border-b-2 border-transparent text-slate-500 hover:text-slate-900")">
                    AI Activity Logs
                </button>
            </div>
        </div>

        <!-- ───────────────── TAB: ALL AI MODELS ───────────────── -->
        <div id="content-models" class="tab-content overflow-x-auto @(activeTab == "models" ? "" : "hidden")">
            <div id="modelsTableContainer">
                <partial name="_ModelsTablePartial" model="Model" />
            </div>
        </div>

        <!-- ───────────────── TAB: AI ACTIVITY LOGS ───────────────── -->
        <div id="content-logs" class="tab-content @(activeTab == "logs" ? "" : "hidden")">
            <!-- Subtabs -->
            <div class="px-6 border-b border-slate-100 bg-white flex overflow-x-auto gap-4">
                <button onclick="switchSubTab('course')" id="sub-tab-course" 
                        class="px-2 py-2.5 text-xs font-semibold transition-colors whitespace-nowrap focus:outline-none @(activeSubtab == "course" ? "border-b-2 border-indigo-600 text-indigo-600" : "border-b-2 border-transparent text-slate-500 hover:text-slate-800")">
                    Course Moderation
                </button>
                <button onclick="switchSubTab('course_review')" id="sub-tab-course_review" 
                        class="px-2 py-2.5 text-xs font-semibold transition-colors whitespace-nowrap focus:outline-none @(activeSubtab == "course_review" ? "border-b-2 border-indigo-600 text-indigo-600" : "border-b-2 border-transparent text-slate-500 hover:text-slate-800")">
                    Course Review Moderation
                </button>
                <button onclick="switchSubTab('lesson_review')" id="sub-tab-lesson_review" 
                        class="px-2 py-2.5 text-xs font-semibold transition-colors whitespace-nowrap focus:outline-none @(activeSubtab == "lesson_review" ? "border-b-2 border-indigo-600 text-indigo-600" : "border-b-2 border-transparent text-slate-500 hover:text-slate-800")">
                    Lesson Review Moderation
                </button>
            </div>

            <!-- Subtab Content: Course Moderation -->
            <div id="sub-content-course" class="subtab-content overflow-x-auto @(activeSubtab == "course" ? "" : "hidden")">
                <div id="course_logsTableContainer">
                    <partial name="_CourseLogsTablePartial" model="Model" />
                </div>
            </div>

            <!-- Subtab Content: Course Review Moderation -->
            <div id="sub-content-course_review" class="subtab-content overflow-x-auto @(activeSubtab == "course_review" ? "" : "hidden")">
                <div id="course_review_logsTableContainer">
                    <partial name="_CourseReviewLogsTablePartial" model="Model" />
                </div>
            </div>

            <!-- Subtab Content: Lesson Review Moderation -->
            <div id="sub-content-lesson_review" class="subtab-content overflow-x-auto @(activeSubtab == "lesson_review" ? "" : "hidden")">
                <div id="lesson_review_logsTableContainer">
                    <partial name="_LessonReviewLogsTablePartial" model="Model" />
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ========================================================================= -->
<!-- MODAL: ADD AI MODEL -->
<!-- ========================================================================= -->
<div id="addAiModelModal" class="fixed inset-0 z-50 hidden bg-slate-950/40 backdrop-blur-sm flex items-center justify-center p-4 transition-all duration-300 ease-out opacity-0">
    <div class="bg-white border border-slate-200 rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden transform scale-95 transition-all duration-300 ease-out">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h3 class="text-base font-bold text-slate-900">Register New AI Model</h3>
            <button onclick="closeAddAiModelModal()" class="text-slate-400 hover:text-slate-600">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
        <form id="addAiModelForm" onsubmit="submitAddAiModel(event)" class="p-6 flex flex-col gap-4 max-h-[80vh] overflow-y-auto custom-scrollbar">
            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5 col-span-2 sm:col-span-1">
                    <label class="text-xs font-bold text-slate-700">Model Name <span class="text-rose-500">*</span></label>
                    <input type="text" id="addModelName" required minlength="3" maxlength="255" class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
                </div>
                <div class="flex flex-col gap-1.5 col-span-2 sm:col-span-1">
                    <label class="text-xs font-bold text-slate-700">Model Version <span class="text-rose-500">*</span></label>
                    <input type="text" id="addModelVersion" required pattern="^\d+\.\d+\.\d+$" maxlength="50" placeholder="e.g. 1.0.0" class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
                </div>
                <div class="flex flex-col gap-1.5 col-span-2">
                    <label class="text-xs font-bold text-slate-700">Model Path <span class="text-rose-500">*</span></label>
                    <input type="text" id="addModelPath" required maxlength="255" class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
                </div>
                <div class="flex flex-col gap-1.5 col-span-2 sm:col-span-1">
                    <label class="text-xs font-bold text-slate-700">Provider <span class="text-rose-500">*</span></label>
                    <select id="addModelProvider" required class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors">
                        <option value="meta">Meta</option>
                        <option value="openai">OpenAI</option>
                        <option value="google">Google</option>
                        <option value="hugging_face">Hugging Face</option>
                        <option value="local">Local</option>
                    </select>
                </div>
                <div class="flex flex-col gap-1.5 col-span-2 sm:col-span-1">
                    <label class="text-xs font-bold text-slate-700">Model Type <span class="text-rose-500">*</span></label>
                    <select id="addModelType" class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors">
                        <option value="classifier">Classifier</option>
                        <option value="embedding_generator">Embedding Generator</option>
                    </select>
                </div>
                <div class="flex flex-col gap-1.5 col-span-2 sm:col-span-1">
                    <label class="text-xs font-bold text-slate-700">Process Type <span class="text-rose-500">*</span></label>
                    <select id="addProcessType" class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors">
                        <option value="text">Text</option>
                        <option value="media">Media</option>
                    </select>
                </div>
                <div class="flex items-center gap-3 col-span-2 sm:col-span-1 mt-6">
                    <span class="text-xs font-bold text-slate-700">Status Active</span>
                    <button type="button" onclick="toggleAddStatus()" id="addModelStatusBtn" class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent bg-emerald-500 transition-colors duration-300 ease-out focus:outline-none">
                        <span id="addModelStatusDot" class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow-sm transition duration-300 ease-out translate-x-5"></span>
                    </button>
                    <input type="hidden" id="addModelStatus" value="active" />
                </div>
                <div class="flex flex-col gap-1.5 col-span-2">
                    <label class="text-xs font-bold text-slate-700">Description <span class="text-rose-500">*</span></label>
                    <textarea id="addDescription" required minlength="20" rows="3" placeholder="At least 20 characters..." class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors"></textarea>
                </div>
            </div>
            <div class="flex items-center gap-3 mt-4">
                <button type="button" onclick="closeAddAiModelModal()" class="w-full py-2 text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 rounded-lg transition-colors">Cancel</button>
                <button type="submit" class="w-full py-2 text-sm font-semibold bg-slate-900 hover:bg-slate-800 text-white rounded-lg transition-colors shadow-sm">Add Model</button>
            </div>
        </form>
    </div>
</div>

<!-- ========================================================================= -->
<!-- MODAL: EDIT AI MODEL -->
<!-- ========================================================================= -->
<div id="editAiModelModal" class="fixed inset-0 z-50 hidden bg-slate-950/40 backdrop-blur-sm flex items-center justify-center p-4 transition-all duration-300 ease-out opacity-0">
    <div class="bg-white border border-slate-200 rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden transform scale-95 transition-all duration-300 ease-out">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h3 class="text-base font-bold text-slate-900">Edit AI Model</h3>
            <button onclick="closeEditAiModelModal()" class="text-slate-400 hover:text-slate-600">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
        <form id="editAiModelForm" onsubmit="submitEditAiModel(event)" class="p-6 flex flex-col gap-4">
            <input type="hidden" id="editModelId" />
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-slate-700">Provider <span class="text-rose-500">*</span></label>
                <select id="editModelProvider" required class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors">
                    <option value="meta">Meta</option>
                    <option value="openai">OpenAI</option>
                    <option value="google">Google</option>
                    <option value="hugging_face">Hugging Face</option>
                    <option value="local">Local</option>
                </select>
            </div>
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-slate-700">Model Version <span class="text-rose-500">*</span></label>
                <input type="text" id="editModelVersion" required pattern="^\d+\.\d+\.\d+$" maxlength="50" placeholder="e.g. 1.0.0" class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
            </div>
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-slate-700">Model Path <span class="text-rose-500">*</span></label>
                <input type="text" id="editModelPath" required maxlength="255" class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
            </div>
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-slate-700">Description <span class="text-rose-500">*</span></label>
                <textarea id="editDescription" required minlength="20" rows="3" class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors"></textarea>
            </div>
            <div class="flex items-center gap-3 mt-4">
                <button type="button" onclick="closeEditAiModelModal()" class="w-full py-2 text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 rounded-lg transition-colors">Cancel</button>
                <button type="submit" class="w-full py-2 text-sm font-semibold bg-slate-900 hover:bg-slate-800 text-white rounded-lg transition-colors shadow-sm">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            @if(TempData["Error"] != null)
            {
                <text>
                Swal.fire({ title: 'Error', text: '@TempData["Error"]', icon: 'error', customClass: { popup: 'rounded-2xl border border-slate-100 shadow-xl' } });
                </text>
            }
        });

        function switchMainTab(tab) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('[id^="main-tab-"]').forEach(btn => {
                btn.classList.remove('border-slate-900', 'text-slate-900');
                btn.classList.add('border-transparent', 'text-slate-500');
            });
            document.getElementById(`content-${tab}`).classList.remove('hidden');
            const btn = document.getElementById(`main-tab-${tab}`);
            btn.classList.remove('border-transparent', 'text-slate-500');
            btn.classList.add('border-slate-900', 'text-slate-900');
            
            // Update URL without reload
            const url = new URL(window.location);
            url.searchParams.set('tab', tab);
            window.history.pushState({}, '', url);
        }

        function switchSubTab(subtab) {
            document.querySelectorAll('.subtab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('[id^="sub-tab-"]').forEach(btn => {
                btn.classList.remove('border-indigo-600', 'text-indigo-600');
                btn.classList.add('border-transparent', 'text-slate-500');
            });
            document.getElementById(`sub-content-${subtab}`).classList.remove('hidden');
            const btn = document.getElementById(`sub-tab-${subtab}`);
            btn.classList.remove('border-transparent', 'text-slate-500');
            btn.classList.add('border-indigo-600', 'text-indigo-600');
            
            const url = new URL(window.location);
            url.searchParams.set('subtab', subtab);
            window.history.pushState({}, '', url);
        }

        function openAddAiModelModal() {
            const modal = document.getElementById('addAiModelModal');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.firstElementChild.classList.remove('scale-95');
            }, 10);
        }

        function closeAddAiModelModal() {
            const modal = document.getElementById('addAiModelModal');
            modal.classList.add('opacity-0');
            modal.firstElementChild.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                document.getElementById('addAiModelForm').reset();
            }, 300);
        }

        function toggleAddStatus() {
            const statusInput = document.getElementById('addModelStatus');
            const btn = document.getElementById('addModelStatusBtn');
            const dot = document.getElementById('addModelStatusDot');
            
            if(statusInput.value === 'active') {
                statusInput.value = 'inactive';
                btn.classList.replace('bg-emerald-500', 'bg-slate-200');
                dot.classList.replace('translate-x-5', 'translate-x-0');
            } else {
                statusInput.value = 'active';
                btn.classList.replace('bg-slate-200', 'bg-emerald-500');
                dot.classList.replace('translate-x-0', 'translate-x-5');
            }
        }

        function openEditAiModelModal(btn) {
            const id = btn.getAttribute('data-id');
            const provider = btn.getAttribute('data-provider');
            const version = btn.getAttribute('data-version');
            const path = btn.getAttribute('data-path');
            const desc = btn.getAttribute('data-desc');

            document.getElementById('editModelId').value = id;
            document.getElementById('editModelProvider').value = provider;
            document.getElementById('editModelVersion').value = version;
            document.getElementById('editModelPath').value = path;
            document.getElementById('editDescription').value = desc;

            const modal = document.getElementById('editAiModelModal');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modal.firstElementChild.classList.remove('scale-95');
            }, 10);
        }

        function closeEditAiModelModal() {
            const modal = document.getElementById('editAiModelModal');
            modal.classList.add('opacity-0');
            modal.firstElementChild.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                document.getElementById('editAiModelForm').reset();
            }, 300);
        }

        function navigateToLogDetail(basePath) {
            let url = basePath;
            const search = window.location.search;
            if (search) {
                if (url.includes('?')) {
                    url += '&' + search.substring(1);
                } else {
                    url += search;
                }
            }
            window.location.href = url;
        }

        async function submitAddAiModel(e) {
            e.preventDefault();
            
            const body = {
                ModelName: document.getElementById('addModelName').value,
                ModelVersion: document.getElementById('addModelVersion').value,
                ModelPath: document.getElementById('addModelPath').value,
                ModelProvider: document.getElementById('addModelProvider').value,
                ModelType: document.getElementById('addModelType').value,
                ProcessType: document.getElementById('addProcessType').value,
                Description: document.getElementById('addDescription').value,
                ModelStatus: document.getElementById('addModelStatus').value
            };

            const confirm = await Swal.fire({
                title: 'Are you sure?',
                text: "Do you want to register this AI model?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0f172a',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Yes, add it',
                customClass: { popup: 'rounded-2xl border border-slate-100 shadow-xl' }
            });

            if (!confirm.isConfirmed) return;

            const res = await fetch('/AdminAiService/AddModel', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });

            if (res.ok) {
                Swal.fire({
                    title: 'Success',
                    text: 'Model added successfully', 
                    icon: 'success', 
                    customClass: { 
                        popup: 'rounded-2xl border border-slate-100 shadow-xl' 
                        } });
                closeAddAiModelModal();
                fetchPage('models', 1);
            } else {
                const err = await res.json();
                Swal.fire('Error', err.Message || 'Failed to add model', 'error');
            }
        }

