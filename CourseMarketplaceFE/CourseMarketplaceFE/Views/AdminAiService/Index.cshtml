        }

        function openDetailsModal(btn) {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const version = btn.getAttribute('data-version');
            const provider = btn.getAttribute('data-provider');
            const type = btn.getAttribute('data-type');
            const process = btn.getAttribute('data-process');
            const path = btn.getAttribute('data-path');
            const desc = btn.getAttribute('data-desc');
            const updated = btn.getAttribute('data-updated');

            const html = `
                <div class="text-left text-sm flex flex-col gap-3 text-slate-600">
                    <div><span class="font-semibold text-slate-800">ID:</span> ${id}</div>
                    <div><span class="font-semibold text-slate-800">Name:</span> ${name} v${version}</div>
                    <div><span class="font-semibold text-slate-800">Provider:</span> <span class="capitalize">${provider}</span></div>
                    <div><span class="font-semibold text-slate-800">Type:</span> <span class="capitalize">${type.replace('_', ' ')} / ${process}</span></div>
                    <div><span class="font-semibold text-slate-800">Path:</span> <span class="font-mono text-xs bg-slate-50 px-1 py-0.5 rounded border border-slate-100 break-all">${path}</span></div>
                    <div><span class="font-semibold text-slate-800">Description:</span><br/><p class="mt-1 p-2 bg-slate-50 rounded border border-slate-100 text-xs">${desc}</p></div>
                    <div class="mt-2 pt-2 border-t border-slate-100 text-xs">
                        <div><span class="font-semibold text-slate-800">Last Updated:</span> ${updated || '-'}</div>
                    </div>
                </div>
            `;

            Swal.fire({
                title: 'Model Details',
                html: html,
                icon: 'info',
                confirmButtonText: 'Close',
                customClass: { popup: 'rounded-2xl border border-slate-100 shadow-xl' }
            });
        }

        async function fetchPage(type, page) {
            let url = '';
            let stateKey = '';
            
            if (type === 'models') {
                url = `/AdminAiService/GetModelsPartial?page=${page}`;
                stateKey = 'modelPage';
            } else if (type === 'course_logs') {
                url = `/AdminAiService/GetCourseLogsPartial?page=${page}`;
                stateKey = 'coursePage';
            } else if (type === 'course_review_logs') {
                url = `/AdminAiService/GetCourseReviewLogsPartial?page=${page}`;
                stateKey = 'cReviewPage';
            } else if (type === 'lesson_review_logs') {
                url = `/AdminAiService/GetLessonReviewLogsPartial?page=${page}`;
                stateKey = 'lReviewPage';
            }

            const res = await fetch(url);
            if (res.redirected) {
                window.location.href = res.url;
                return;
            }

            if (res.ok) {
                const html = await res.text();
                document.getElementById(`${type}TableContainer`).innerHTML = html;
                
                const currentUrl = new URL(window.location);
                currentUrl.searchParams.set(stateKey, page);
                window.history.pushState({}, '', currentUrl);
            } else {
                Swal.fire('Error', 'Failed to load page.', 'error');
            }
        }
    </script>
}
