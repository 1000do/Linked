@model List<CourseMarketplaceFE.Models.NotificationViewModel>
@{
    Layout = "_InstructorLayout";
    ViewData["Title"] = "Notifications";
}

<div class="p-6 bg-white min-h-screen">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
            <span class="material-symbols-outlined">notifications</span>
            My Notifications
        </h2>
    </div>

    <div id="notification-container" class="space-y-1">
        @if (Model == null || !Model.Any())
        {
            <div id="empty-message" class="py-20 text-center text-slate-400 border border-dashed border-slate-200 rounded-lg">
                No notifications yet.
            </div>
        }
        else
        {
            @foreach (var noti in Model.OrderByDescending(x => x.CreatedAt))
            {
                <div id="noti-@noti.NotificationId"
                     class="flex items-center justify-between p-4 transition-all @(noti.IsRead ? "bg-white opacity-60" : "bg-slate-50") border-b border-slate-100 last:border-0 hover:bg-slate-100 cursor-pointer"
                     onclick="window.location.href='@(string.IsNullOrEmpty(noti.LinkAction) ? "#" : noti.LinkAction)'">

                    <div class="flex items-center gap-4 flex-1">
                        <div class="w-2 flex-shrink-0">
                            @if (!noti.IsRead)
                            {
                                <div class="w-2 h-2 bg-teal-500 rounded-full"></div>
                            }
                        </div>

                        <div class="flex-1 grid grid-cols-12 gap-4 items-center">
                            <div class="col-span-3 font-bold text-slate-700 truncate">@noti.Title</div>
                            <div class="col-span-6 text-slate-500 text-sm truncate">@noti.Content</div>
                            <div class="col-span-3 text-right text-[11px] text-slate-400 font-medium">
                                @(noti.CreatedAt?.ToString("HH:mm dd/MM/yyyy"))
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 ml-6" onclick="event.stopPropagation()">
                        @if (!noti.IsRead)
                        {
                            <button onclick="handleAction(@noti.NotificationId, 'MarkAsRead')"
                                    class="p-2 hover:bg-teal-100 text-teal-600 rounded-lg transition-colors">
                                <span class="material-symbols-outlined text-lg">done_all</span>
                            </button>
                        }
                        <button onclick="handleAction(@noti.NotificationId, 'DeleteNotification')"
                                class="p-2 hover:bg-red-100 text-red-500 rounded-lg transition-colors">
                            <span class="material-symbols-outlined text-lg">delete</span>
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

<script>
    // 2. Dùng biến toàn cục window để tránh lỗi "already declared"
    (function () {
        if (!window.isNotiInitialized) {
            window.isNotiInitialized = true;

            // Chuyển sang dùng http nếu local bị lỗi SSL (https)
            const hubUrl = "http://localhost:5207/notificationHub"; 

            window.notiConn = new signalR.HubConnectionBuilder()
                .withUrl(hubUrl, {
                    accessTokenFactory: () => {
                        const name = "AccessToken=";
                        const ca = document.cookie.split(';');
                        for(let i = 0; i < ca.length; i++) {
                            let c = ca[i].trim();
                            if (c.indexOf(name) == 0) return c.substring(name.length, c.length);
                        }
                        return "";
                    }
                })
                .withAutomaticReconnect()
                .build();

            window.notiConn.on("ReceiveNotification", function (noti) {
                console.log("🔔 Received notification:", noti);
                
                const container = document.getElementById('notification-container');
                const emptyMsg = document.getElementById('empty-message');
                if (emptyMsg) emptyMsg.remove();
                
                if (container) {
                    const temp = document.createElement('div');
                    temp.id = `noti-${noti.notificationId}`;
                    temp.className = "flex items-center justify-between p-4 transition-all bg-slate-50 border-b border-slate-100 last:border-0 hover:bg-slate-100 cursor-pointer opacity-0 -translate-y-4";
                    temp.onclick = () => {
                        window.location.href = noti.linkAction || '#';
                    };
                    temp.style.transition = 'all 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
                    
                    temp.innerHTML = `
                        <div class="flex items-center gap-4 flex-1">
                            <div class="w-2 flex-shrink-0">
                                <div class="w-2 h-2 bg-teal-500 rounded-full"></div>
                            </div>
    
                            <div class="flex-1 grid grid-cols-12 gap-4 items-center">
                                <div class="col-span-3 font-bold text-slate-700 truncate">${noti.title}</div>
                                <div class="col-span-6 text-slate-500 text-sm truncate">${noti.content}</div>
                                <div class="col-span-3 text-right text-[11px] text-slate-400 font-medium">
                                    ${new Date(noti.createdAt || Date.now()).toLocaleTimeString('en-US')} ${new Date(noti.createdAt || Date.now()).toLocaleDateString('en-US')}
                                </div>
                            </div>
                        </div>
    
                        <div class="flex items-center gap-2 ml-6" onclick="event.stopPropagation()">
                            <button onclick="handleAction(${noti.notificationId}, 'MarkAsRead')"
                                    class="p-2 hover:bg-teal-100 text-teal-600 rounded-lg transition-colors">
                                <span class="material-symbols-outlined text-lg">done_all</span>
                            </button>
                            <button onclick="handleAction(${noti.notificationId}, 'DeleteNotification')"
                                    class="p-2 hover:bg-red-100 text-red-500 rounded-lg transition-colors">
                                <span class="material-symbols-outlined text-lg">delete</span>
                            </button>
                        </div>
                    `;
                    
                    container.prepend(temp);
                    setTimeout(() => {
                        temp.classList.remove('opacity-0', '-translate-y-4');
                    }, 50);
                }
            });

            window.notiConn.start()
                .then(() => console.log("✅ SignalR connection established!"))
                .catch(err => {
                    console.error("❌ Connection error:", err);
                });
        }
    })();

    function markNotificationAsReadInDOM(id) {
        const element = document.getElementById(`noti-${id}`);
        if (element) {
            element.classList.remove('bg-slate-50');
            element.classList.add('bg-white', 'opacity-60');
            
            const dotContainer = element.querySelector('.w-2.flex-shrink-0');
            if (dotContainer) dotContainer.innerHTML = '';
            
            const markAsReadBtn = element.querySelector('button[onclick*="MarkAsRead"]');
            if (markAsReadBtn) markAsReadBtn.remove();
        }
    }

    // 3. Hàm xử lý nút bấm
    async function handleAction(id, action) {
        if (!id || id === 0) { location.reload(); return; }
        
        if (action === 'DeleteNotification') {
            const confirmResult = await Swal.fire({
                title: 'Confirm Deletion',
                text: "Are you sure you want to delete this notification?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Delete',
                cancelButtonText: 'Cancel',
                background: '#ffffff',
                customClass: { popup: 'rounded-2xl shadow-xl' }
            });
            if (!confirmResult.isConfirmed) return;
        }

        try {
            const response = await fetch(`/Instructor/${action}?id=${id}`, {
                method: 'POST'
            });

            if (response.ok) {
                if (action === 'DeleteNotification') {
                    const element = document.getElementById(`noti-${id}`);
                    if (element) {
                        element.style.transition = 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
                        element.style.opacity = '0';
                        element.style.transform = 'translateX(20px)';
                        setTimeout(() => {
                            element.remove();
                            const container = document.getElementById('notification-container');
                            if (container && container.querySelectorAll('div[id^="noti-"]').length === 0) {
                                container.innerHTML = `<div id="empty-message" class="py-20 text-center text-slate-400 border border-dashed border-slate-200 rounded-lg">No notifications yet.</div>`;
                            }
                        }, 300);
                    }
                    Swal.fire({
                        title: 'Deleted!',
                        text: 'The notification has been successfully deleted.',
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false,
                        background: '#ffffff',
                        customClass: { popup: 'rounded-2xl shadow-xl' }
                    });
                } else {
                    markNotificationAsReadInDOM(id);
                }
            }
        } catch (e) { console.error(e); }
    }
</script>