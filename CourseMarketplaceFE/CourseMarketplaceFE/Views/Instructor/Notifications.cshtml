@model List<CourseMarketplaceFE.Models.NotificationViewModel>
@{
    Layout = "_InstructorLayout";
    ViewData["Title"] = "Thông báo";
}

<div class="p-6 bg-white min-h-screen">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
            <span class="material-symbols-outlined">notifications</span>
            Thông báo của tôi
        </h2>
    </div>

    <div id="notification-container" class="space-y-1">
        @if (Model == null || !Model.Any())
        {
            <div id="empty-message" class="py-20 text-center text-slate-400 border border-dashed border-slate-200 rounded-lg">
                Không có thông báo nào.
            </div>
        }
        else
        {
            @foreach (var noti in Model.OrderByDescending(x => x.CreatedAt))
            {
                <div id="noti-@noti.NotificationId"
                     class="flex items-center justify-between p-4 transition-all @(noti.IsRead ? "bg-white opacity-60" : "bg-slate-50") border-b border-slate-100 last:border-0">

                    <div class="flex items-center gap-4 flex-1">
                        <div class="w-2 flex-shrink-0">
                            @if (!noti.IsRead)
                            {
                                <div class="w-2 h-2 bg-teal-500 rounded-full"></div>
                            }
                        </div>

                        <div class="flex-1 grid grid-cols-12 gap-4 items-center">
                            <div class="col-span-3 font-bold text-slate-700 truncate">@noti.Title</div>
                            <div class="col-span-6 text-slate-500 text-sm truncate">@noti.Content</div>
                            <div class="col-span-3 text-right text-[11px] text-slate-400 font-medium">
                                @(noti.CreatedAt?.ToString("HH:mm dd/MM/yyyy"))
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 ml-6">
                        @if (!noti.IsRead)
                        {
                            <button onclick="handleAction(@noti.NotificationId, 'MarkAsRead')"
                                    class="p-2 hover:bg-teal-100 text-teal-600 rounded-lg transition-colors">
                                <span class="material-symbols-outlined text-lg">done_all</span>
                            </button>
                        }
                        <button onclick="handleAction(@noti.NotificationId, 'DeleteNotification')"
                                class="p-2 hover:bg-red-100 text-red-500 rounded-lg transition-colors">
                            <span class="material-symbols-outlined text-lg">delete</span>
                        </div>
                    </div>
                
            }
        }
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

<script>
    // 2. Dùng biến toàn cục window để tránh lỗi "already declared"
    (function () {
        if (!window.isNotiInitialized) {
            window.isNotiInitialized = true;

            // Chuyển sang dùng http nếu local bị lỗi SSL (https)
            const hubUrl = "http://localhost:5207/notificationHub"; 

            window.notiConn = new signalR.HubConnectionBuilder()
                .withUrl(hubUrl, {
                    accessTokenFactory: () => {
                        const name = "AccessToken=";
                        const ca = document.cookie.split(';');
                        for(let i = 0; i < ca.length; i++) {
                            let c = ca[i].trim();
                            if (c.indexOf(name) == 0) return c.substring(name.length, c.length);
                        }
                        return "";
                    }
                })
                .withAutomaticReconnect()
                .build();

            window.notiConn.on("ReceiveNotification", function (noti) {
                console.log("🔔 Nhận thông báo:", noti);
                
                // CÁCH MẠNH NHẤT: Bất kể thông báo gì, tự động load lại trang
                // Không cần F5 tay nữa
                setTimeout(() => {
                    window.location.reload();
                }, 500); 
            });

            window.notiConn.start()
                .then(() => console.log("✅ SignalR đã sẵn sàng!"))
                .catch(err => {
                    console.error("❌ Lỗi kết nối:", err);
                    // Nếu lỗi SSL ở trên, thử fallback sang https nếu cần
                });
        }
    })();

    // 3. Hàm xử lý nút bấm
    async function handleAction(id, action) {
        if (!id || id === 0) { location.reload(); return; }
        if (action === 'DeleteNotification' && !confirm("Bạn muốn xóa thông báo này?")) return;

        try {
            const response = await fetch(`/Instructor/${action}?id=${id}`, {
                method: 'POST'
            });

            if (response.ok) {
                const element = document.getElementById(`noti-${id}`);
                if (element) {
                    if (action === 'DeleteNotification') {
                        element.remove();
                    } else {
                        location.reload(); // Đọc xong reload cho sạch
                    }
                }
            }
        } catch (e) { console.error(e); }
    }
</script>