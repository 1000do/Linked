@model CourseMarketplaceFE.Models.InstructorApplyViewModel
@{
    ViewData["Title"] = "Register as Instructor";
    bool isVerified = ViewBag.IsEmailVerified ?? false;
}

<div class="min-h-screen pt-28 pb-16">
    <div class="max-w-2xl mx-auto px-4">

        @* ── HEADER ──────────────────────────────────────────── *@
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-primary to-secondary rounded-2xl shadow-lg mb-4">
                <span class="material-symbols-outlined text-white text-3xl">school</span>
            </div>
            <h1 class="text-3xl font-headline font-extrabold text-slate-800">Become an Instructor</h1>
            <p class="text-slate-500 mt-2">Fill out the details below to submit your application. Admins will review it within 24 hours.</p>
        </div>

        @* ── EMAIL CHƯA XÁC THỰC → CHẶN ────────────────────── *@
        @if (!isVerified)
        {
            <div class="bg-white rounded-2xl shadow-lg border border-slate-100 p-8">
                <div class="text-center py-8">
                    <div class="inline-flex items-center justify-center w-20 h-20 bg-amber-50 rounded-full mb-6">
                        <span class="material-symbols-outlined text-amber-500 text-4xl">mail_lock</span>
                    </div>
                    <h2 class="text-xl font-bold text-slate-800 mb-3">Email Not Verified</h2>
                    <p class="text-slate-500 mb-6 max-w-md mx-auto">
                        To ensure security and verify your identity, you must <strong>verify your email</strong> before applying to become an Instructor.
                    </p>
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                        <a href="/Account/SendVerifyOtp"
                           class="inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-xl hover:scale-[1.01] active:scale-[0.99] transition-all duration-300 text-sm">
                            <span class="material-symbols-outlined text-lg">verified</span>
                            Verify Email Now
                        </a>
                        <a href="/Account/Profile"
                           class="inline-flex items-center gap-2 px-6 py-3.5 bg-slate-100 text-slate-600 font-semibold rounded-xl hover:bg-slate-200 transition-all text-sm">
                            <span class="material-symbols-outlined text-lg">arrow_back</span>
                            Go to Profile
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            @* ── RESUBMIT BANNER ───────────────────────────────────── *@
            @if (Model.IsResubmit)
            {
                <div class="bg-amber-50 border border-amber-300 rounded-xl p-4 mb-6 flex items-start gap-3">
                    <span class="material-symbols-outlined text-amber-500 text-2xl mt-0.5">warning</span>
                    <div>
                        <p class="text-sm font-bold text-amber-800 mb-1">Previous Application Rejected</p>
                        <p class="text-sm text-amber-700">
                            Please check the details below, edit if necessary, and click <strong>Resubmit Application</strong>.
                            Your new application will be processed under the same ID.
                        </p>
                    </div>
                </div>
            }


            @* ── FORM ─────────────────────────────────────────────── *@
            <div class="bg-white rounded-2xl shadow-lg border border-slate-100 p-8">

                @* Progress indicator *@
                <div class="flex items-center justify-center gap-4 mb-8">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center text-xs font-bold">1</div>
                        <span class="text-xs font-bold text-primary uppercase tracking-wider">Apply</span>
                    </div>
                    <div class="w-12 h-px bg-slate-200"></div>
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-slate-200 text-slate-400 flex items-center justify-center text-xs font-bold">2</div>
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Review</span>
                    </div>
                    <div class="w-12 h-px bg-slate-200"></div>
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-slate-200 text-slate-400 flex items-center justify-center text-xs font-bold">3</div>
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Stripe</span>
                    </div>
                </div>

                <form asp-action="Apply" asp-controller="Instructor" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="IsResubmit" />
                    <input type="hidden" asp-for="ExistingDocumentUrl" />

                    @* Professional Title *@
                    <div class="mb-5">
                        <label class="flex items-center gap-2 text-sm font-semibold text-slate-700 mb-2">
                            <span class="material-symbols-outlined text-lg text-primary">badge</span>
                            Professional Title <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="ProfessionalTitle" type="text" placeholder="e.g., Senior .NET Developer, Data Scientist..."
                               class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm" />
                        <span asp-validation-for="ProfessionalTitle" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    @* Expertise Categories *@
                    <div class="mb-5">
                        <label class="flex items-center gap-2 text-sm font-semibold text-slate-700 mb-2">
                            <span class="material-symbols-outlined text-lg text-primary">category</span>
                            Areas of Expertise <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="ExpertiseCategories" type="text" placeholder="e.g., C#, Cloud Computing, Machine Learning..."
                               class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm" />
                        <span asp-validation-for="ExpertiseCategories" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    @* LinkedIn URL *@
                    <div class="mb-5">
                        <label class="flex items-center gap-2 text-sm font-semibold text-slate-700 mb-2">
                            <span class="material-symbols-outlined text-lg text-primary">link</span>
                            LinkedIn Profile
                        </label>
                        <input asp-for="LinkedinUrl" type="url" placeholder="https://linkedin.com/in/yourname"
                               class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm" />
                        <span asp-validation-for="LinkedinUrl" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
                        @* Youtube URL *@
                        <div>
                            <label class="flex items-center gap-2 text-sm font-semibold text-slate-700 mb-2">
                                <span class="material-symbols-outlined text-lg text-primary">video_library</span>
                                YouTube Channel
                            </label>
                            <input asp-for="YoutubeUrl" type="url" placeholder="https://youtube.com/@@yourchannel"
                                   class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm" />
                        </div>

                        @* Facebook URL *@
                        <div>
                            <label class="flex items-center gap-2 text-sm font-semibold text-slate-700 mb-2">
                                <span class="material-symbols-outlined text-lg text-primary">group</span>
                                Facebook Profile
                            </label>
                            <input asp-for="FacebookUrl" type="url" placeholder="https://facebook.com/yourprofile"
                                   class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm" />
                        </div>
                    </div>

                    @* Stripe Country Selection *@
                    <div class="mb-5">
                        <label class="flex items-center gap-2 text-sm font-semibold text-slate-700 mb-2">
                            <span class="material-symbols-outlined text-lg text-primary">public</span>
                            Stripe Connect Country <span class="text-red-500">*</span>
                        </label>
                        <p class="text-xs text-slate-500 mb-2">Select the country where your bank account is located to receive payouts from LinkedLearn.</p>
                        <select asp-for="StripeCountry" asp-items="Model.AvailableCountries"
                                class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all text-sm bg-white cursor-pointer">
                            <option value="">-- Select Country --</option>
                        </select>
                        <span asp-validation-for="StripeCountry" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    @* Document Upload *@
                    <div class="mb-8">
                        <label class="flex items-center gap-2 text-sm font-semibold text-slate-700 mb-2">
                            <span class="material-symbols-outlined text-lg text-primary">upload_file</span>
                            Upload CV / Certificates / ID Documents (Max 3) <span class="text-red-500">*</span>
                        </label>

                        @* Hiển link các tài liệu cũ khi resubmit *@
                        @if (Model.IsResubmit && Model.ExistingDocumentUrls != null && Model.ExistingDocumentUrls.Any())
                        {
                            <div class="mb-4 space-y-2">
                                <p class="text-xs font-bold text-slate-500">Current Documents:</p>
                                <div class="grid grid-cols-1 gap-2" id="retained-documents-list">
                                    @for (int i = 0; i < Model.ExistingDocumentUrls.Count; i++)
                                    {
                                        var url = Model.ExistingDocumentUrls[i];
                                        var ext = System.IO.Path.GetExtension(url).ToLower();
                                        var iconName = (ext == ".pdf") ? "picture_as_pdf" : "image";
                                        <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-200 shadow-sm transition-all hover:bg-slate-100/70" id="retained-doc-@i">
                                            <input type="hidden" name="RetainedDocumentUrls" value="@url" id="retained-input-@i" />
                                            <div class="flex items-center gap-2 truncate">
                                                <span class="material-symbols-outlined text-primary text-lg flex-shrink-0">@iconName</span>
                                                <a href="@url" target="_blank" class="text-xs text-primary font-bold hover:underline truncate max-w-sm">
                                                    Document #@(i + 1) @ext
                                                </a>
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <span class="text-[10px] text-slate-400 bg-slate-200/50 px-2.5 py-0.5 rounded-full font-black uppercase">Stored</span>
                                                <button type="button" class="w-7 h-7 rounded-full bg-rose-50 text-rose-600 border border-rose-100 hover:bg-rose-100 hover:text-rose-700 transition-all flex items-center justify-center active:scale-90" onclick="removeRetainedDocument(@i)">
                                                    <span class="material-symbols-outlined text-[16px]">remove</span>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        <!-- Dynamic Document Slots Container -->
                        <div id="document-slots-container" class="space-y-3">
                            <!-- Slots will be injected here dynamically by JavaScript -->
                        </div>

                        <!-- Add Slot Button -->
                        <div class="mt-3 flex justify-between items-center">
                            <span class="text-xs text-slate-400 font-semibold">Selected: <span id="files-uploaded-count" class="font-extrabold text-primary">0</span>/3 files</span>
                            <button type="button" id="add-slot-btn" class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-xs rounded-xl border border-slate-200 transition-all shadow-sm active:scale-95">
                                <span class="material-symbols-outlined text-sm font-bold">add</span>
                                Add Document
                            </button>
                        </div>
                        <span asp-validation-for="DocumentFiles" class="text-xs text-red-500 mt-2 block"></span>
                    </div>

                    @* Submit Button *@
                    <button type="submit"
                            class="w-full py-4 bg-gradient-to-r from-primary to-secondary text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-xl hover:scale-[1.01] active:scale-[0.99] transition-all duration-300 text-sm uppercase tracking-wider">
                        <span class="material-symbols-outlined text-lg align-middle mr-1">send</span>
                        @(Model.IsResubmit ? "Resubmit Application" : "Submit Application")
                    </button>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (ViewBag.ApiError != null)
    {
        <script>
            Swal.fire({
                title: 'Submission Error',
                text: '@Html.Raw(ViewBag.ApiError)',
                icon: 'error',
                confirmButtonColor: '#006a62'
            });
        </script>
    }

    <script>
        let slots = [];
        let nextSlotId = 1;
        let retainedCount = @(Model.IsResubmit && Model.ExistingDocumentUrls != null ? Model.ExistingDocumentUrls.Count : 0);

        document.addEventListener('DOMContentLoaded', () => {
            const addBtn = document.getElementById('add-slot-btn');
            if (addBtn) {
                addBtn.addEventListener('click', addSlot);
            }
            // Add initial slot only if there are no existing documents
            if (retainedCount === 0) {
                addSlot();
            } else {
                updateTotalCount();
            }
        });

        function getSlotHtml(slotId) {
            return `
                <div class="document-slot bg-slate-50/50 rounded-2xl border border-slate-200 p-4 transition-all hover:bg-slate-50 relative group" id="slot-${slotId}" data-slot-id="${slotId}">
                    <input type="file" name="DocumentFiles" accept=".pdf,.jpg,.jpeg,.png" class="hidden slot-file-input" id="file-input-${slotId}" onchange="onFileInputChange(${slotId}, event)" />
                    
                    <div class="flex items-center justify-between gap-4">
                        <!-- Left: file details or empty state -->
                        <div class="flex-1 min-w-0">
                            <!-- Empty State (No file selected) -->
                            <div class="empty-state cursor-pointer hover:text-primary transition-colors flex items-center gap-3" id="empty-state-${slotId}" onclick="triggerFileInput(${slotId})">
                                <div class="w-10 h-10 bg-primary/10 text-primary rounded-xl flex items-center justify-center shrink-0 group-hover:scale-105 group-hover:bg-primary/20 transition-all duration-300">
                                    <span class="material-symbols-outlined text-[20px]">cloud_upload</span>
                                </div>
                                <div class="truncate">
                                    <p class="text-xs font-bold text-slate-700">Choose Certificate, CV, or ID document</p>
                                    <p class="text-[10px] text-slate-400 mt-0.5 font-medium">Accepted: PDF, JPG, PNG (Max 5MB)</p>
                                </div>
                            </div>
                            
                            <!-- Chosen State (File details) -->
                            <div class="chosen-state hidden flex items-center gap-3" id="chosen-state-${slotId}">
                                <div class="w-10 h-10 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center shrink-0 border border-emerald-100 slot-file-icon-container">
                                    <span class="material-symbols-outlined slot-file-icon text-[20px]">picture_as_pdf</span>
                                </div>
                                <div class="truncate">
                                    <p class="text-xs font-bold text-slate-800 truncate slot-file-name" id="file-name-${slotId}"></p>
                                    <p class="text-[10px] text-slate-400 mt-0.5 slot-file-size" id="file-size-${slotId}"></p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Right: Actions -->
                        <div class="flex items-center gap-2">
                            <!-- Minus button to remove slot or clear file -->
                            <button type="button" class="w-8 h-8 rounded-full bg-rose-50 text-rose-600 border border-rose-100 hover:bg-rose-100 hover:text-rose-700 transition-all flex items-center justify-center active:scale-90" onclick="removeSlot(${slotId})">
                                <span class="material-symbols-outlined text-[18px]">remove</span>
                            </button>
                        </div>
                    </div>
                </div>
            `;
        }

        function triggerFileInput(slotId) {
            const input = document.getElementById(`file-input-${slotId}`);
            if (input) {
                input.click();
            }
        }

        function addSlot() {
            if (retainedCount + slots.length >= 3) return;

            const slotId = nextSlotId++;
            slots.push(slotId);

            const container = document.getElementById('document-slots-container');
            if (container) {
                container.insertAdjacentHTML('beforeend', getSlotHtml(slotId));
                initSlotDragAndDrop(slotId);
            }
            updateTotalCount();
        }

        function removeSlot(slotId) {
            const fileInput = document.getElementById(`file-input-${slotId}`);
            
            if (retainedCount + slots.length <= 1) {
                // If it's the only slot overall, clear the input and show empty state
                if (fileInput) {
                    fileInput.value = '';
                }
                const emptyDiv = document.getElementById(`empty-state-${slotId}`);
                const chosenDiv = document.getElementById(`chosen-state-${slotId}`);
                if (emptyDiv && chosenDiv) {
                    emptyDiv.classList.remove('hidden');
                    chosenDiv.classList.add('hidden');
                }
            } else {
                // If multiple slots, remove it from DOM and list
                const slotEl = document.getElementById(`slot-${slotId}`);
                if (slotEl) {
                    slotEl.remove();
                }
                slots = slots.filter(id => id !== slotId);
            }
            updateTotalCount();
        }

        function removeRetainedDocument(index) {
            const docEl = document.getElementById(`retained-doc-${index}`);
            const inputEl = document.getElementById(`retained-input-${index}`);
            if (docEl) docEl.remove();
            if (inputEl) inputEl.remove();

            retainedCount--;
            
            // If all documents are removed, automatically add a slot so there is always at least one
            if (retainedCount + slots.length === 0) {
                addSlot();
            } else {
                updateTotalCount();
            }
        }

        function onFileInputChange(slotId, event) {
            const files = event.target.files;
            if (files && files.length > 0) {
                const file = files[0];
                if (validateFile(file)) {
                    updateSlotUI(slotId, file);
                } else {
                    event.target.value = '';
                    const emptyDiv = document.getElementById(`empty-state-${slotId}`);
                    const chosenDiv = document.getElementById(`chosen-state-${slotId}`);
                    if (emptyDiv && chosenDiv) {
                        emptyDiv.classList.remove('hidden');
                        chosenDiv.classList.add('hidden');
                    }
                }
            }
            updateTotalCount();
        }

        function validateFile(file) {
            const allowedExtensions = ['.pdf', '.jpg', '.jpeg', '.png'];
            const maxBytes = 5 * 1024 * 1024;
            const ext = '.' + file.name.split('.').pop().toLowerCase();

            if (!allowedExtensions.includes(ext)) {
                Swal.fire({
                    title: 'Invalid Format',
                    text: `File "${file.name}" is not supported. Please upload PDF, JPG, or PNG only.`,
                    icon: 'error',
                    confirmButtonColor: '#006a62'
                });
                return false;
            }

            if (file.size > maxBytes) {
                Swal.fire({
                    title: 'File Too Large',
                    text: `File "${file.name}" exceeds the 5MB size limit.`,
                    icon: 'error',
                    confirmButtonColor: '#006a62'
                });
                return false;
            }

            return true;
        }

        function updateSlotUI(slotId, file) {
            const emptyDiv = document.getElementById(`empty-state-${slotId}`);
            const chosenDiv = document.getElementById(`chosen-state-${slotId}`);
            const nameEl = document.getElementById(`file-name-${slotId}`);
            const sizeEl = document.getElementById(`file-size-${slotId}`);
            const iconEl = document.querySelector(`#slot-${slotId} .slot-file-icon`);
            const iconContainer = document.querySelector(`#slot-${slotId} .slot-file-icon-container`);

            if (emptyDiv && chosenDiv && nameEl && sizeEl) {
                emptyDiv.classList.add('hidden');
                chosenDiv.classList.remove('hidden');
                
                nameEl.textContent = file.name;
                const sizeMb = (file.size / (1024 * 1024)).toFixed(2);
                sizeEl.textContent = `${sizeMb} MB`;

                const ext = '.' + file.name.split('.').pop().toLowerCase();
                if (iconEl && iconContainer) {
                    if (ext === '.pdf') {
                        iconEl.textContent = 'picture_as_pdf';
                        iconContainer.className = 'w-10 h-10 bg-rose-50 text-rose-600 rounded-xl flex items-center justify-center shrink-0 border border-rose-100 slot-file-icon-container';
                    } else {
                        iconEl.textContent = 'image';
                        iconContainer.className = 'w-10 h-10 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center shrink-0 border border-emerald-100 slot-file-icon-container';
                    }
                }
            }
        }

        function initSlotDragAndDrop(slotId) {
            const slotEl = document.getElementById(`slot-${slotId}`);
            if (!slotEl) return;

            ['dragenter', 'dragover'].forEach(eventName => {
                slotEl.addEventListener(eventName, (e) => {
                    e.preventDefault();
                    if (!slotEl.classList.contains('bg-primary/5')) {
                        slotEl.classList.add('border-primary/60', 'bg-primary/5');
                    }
                }, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                slotEl.addEventListener(eventName, (e) => {
                    e.preventDefault();
                    slotEl.classList.remove('border-primary/60', 'bg-primary/5');
                }, false);
            });

            slotEl.addEventListener('drop', (e) => {
                const dt = e.dataTransfer;
                const files = dt.files;
                if (files && files.length > 0) {
                    const fileInput = document.getElementById(`file-input-${slotId}`);
                    if (fileInput) {
                        const file = files[0];
                        if (validateFile(file)) {
                            const dt2 = new DataTransfer();
                            dt2.items.add(file);
                            fileInput.files = dt2.files;
                            updateSlotUI(slotId, file);
                            updateTotalCount();
                        }
                    }
                }
            });
        }

        function updateTotalCount() {
            let filledCount = 0;
            slots.forEach(slotId => {
                const fileInput = document.getElementById(`file-input-${slotId}`);
                if (fileInput && fileInput.files && fileInput.files.length > 0) {
                    filledCount++;
                }
            });

            const totalFiles = retainedCount + filledCount;
            const countEl = document.getElementById('files-uploaded-count');
            if (countEl) {
                countEl.textContent = totalFiles;
            }

            const totalSlots = retainedCount + slots.length;
            const addBtn = document.getElementById('add-slot-btn');
            if (addBtn) {
                if (totalSlots >= 3) {
                    addBtn.classList.add('hidden');
                } else {
                    addBtn.classList.remove('hidden');
                }
            }
        }
    </script>
}
