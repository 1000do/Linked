@model List<CourseMarketplaceFE.Controllers.InstructorController.InstructorPayoutViewModel>
@{
    ViewData["Title"] = "Lịch sử thanh toán";
    Layout = "_InstructorLayout";
}

<div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h1 class="text-3xl font-black text-slate-900 tracking-tight mb-2">Doanh thu & Thanh toán</h1>
        <p class="text-slate-500 font-medium">Theo dõi lịch sử bán khóa học và trạng thái nhận tiền từ hệ thống.</p>
    </div>
    
    <div class="flex items-center gap-3 bg-emerald-50 px-4 py-3 rounded-2xl border border-emerald-100">
        <div class="w-10 h-10 bg-emerald-500 rounded-full flex items-center justify-center text-white">
            <span class="material-symbols-outlined">payments</span>
        </div>
        <div>
            <p class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest">Tổng thu nhập</p>
            <p class="text-xl font-black text-slate-900">@Model.Sum(x => x.Amount).ToString("C")</p>
        </div>
    </div>
</div>

<div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
        <h2 class="text-lg font-bold text-slate-900">Chi tiết giao dịch</h2>
        <div class="flex gap-2">
             <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-bold bg-white border border-slate-200 text-slate-600">
                <span class="w-2 h-2 rounded-full bg-emerald-500"></span> Đã trả: @Model.Count(x => x.IsPaid)
            </span>
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-bold bg-white border border-slate-200 text-slate-600">
                <span class="w-2 h-2 rounded-full bg-amber-500"></span> Chờ: @Model.Count(x => !x.IsPaid)
            </span>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="text-[11px] font-black text-slate-400 uppercase tracking-widest bg-slate-50/30">
                    <th class="px-6 py-4">Ngày giao dịch</th>
                    <th class="px-6 py-4">Khóa học</th>
                    <th class="px-6 py-4">Giá bán</th>
                    <th class="px-6 py-4">Bạn nhận (70%)</th>
                    <th class="px-6 py-4">Trạng thái</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center gap-3">
                                <span class="material-symbols-outlined text-4xl text-slate-200">history_edu</span>
                                <p class="text-slate-400 font-medium">Bạn chưa có giao dịch nào.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="px-6 py-5">
                                <p class="text-sm font-bold text-slate-900">@item.PayoutDate.ToString("dd/MM/yyyy")</p>
                                <p class="text-[10px] text-slate-400 font-medium">@item.PayoutDate.ToString("HH:mm")</p>
                            </td>
                            <td class="px-6 py-5">
                                <p class="text-sm font-bold text-slate-700 group-hover:text-primary transition-colors">@item.CourseTitle</p>
                            </td>
                            <td class="px-6 py-5">
                                <p class="text-sm font-bold text-slate-400 line-through decoration-slate-200">@item.TotalAmount.ToString("C")</p>
                            </td>
                            <td class="px-6 py-5">
                                <p class="text-base font-black text-slate-900">@item.Amount.ToString("C")</p>
                            </td>
                            <td class="px-6 py-5">
                                @if (item.IsPaid)
                                {
                                    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-50 text-emerald-600 border border-emerald-100">
                                        <span class="material-symbols-outlined text-sm">check_circle</span>
                                        <span class="text-[11px] font-bold uppercase tracking-wider">Đã thanh toán</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-600 border border-amber-100">
                                        <span class="material-symbols-outlined text-sm">schedule</span>
                                        <span class="text-[11px] font-bold uppercase tracking-wider">Đang chờ (Escrow)</span>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-slate-900 p-8 rounded-3xl text-white relative overflow-hidden shadow-xl">
        <div class="absolute right-0 bottom-0 opacity-10">
            <span class="material-symbols-outlined text-[120px]">help</span>
        </div>
        <h3 class="text-xl font-bold mb-4 relative z-10">Làm sao để rút tiền?</h3>
        <p class="text-slate-400 text-sm leading-relaxed mb-6 relative z-10">
            Hệ thống áp dụng chính sách <b>Merchant of Record</b>. Toàn bộ tiền bán khóa học sẽ được Sàn giữ hộ để đảm bảo quyền lợi hoàn tiền của học viên.
        </p>
        <div class="space-y-4 relative z-10">
            <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center shrink-0">
                    <span class="text-[12px] font-black">1</span>
                </div>
                <p class="text-xs text-slate-300">Tiền được cộng vào số dư "Đang chờ" ngay khi khách mua.</p>
            </div>
            <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center shrink-0">
                    <span class="text-[12px] font-black">2</span>
                </div>
                <p class="text-xs text-slate-300">Sau 14-30 ngày (chu kỳ đối soát), Admin sẽ thực hiện chuyển tiền thủ công cho bạn.</p>
            </div>
            <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center shrink-0">
                    <span class="text-[12px] font-black">3</span>
                </div>
                <p class="text-xs text-slate-300">Khi trạng thái đổi sang "Đã thanh toán", tiền đã được gửi tới tài khoản ngân hàng của bạn.</p>
            </div>
        </div>
    </div>
    
    <div class="bg-primary p-8 rounded-3xl text-white relative overflow-hidden shadow-xl">
        <div class="absolute right-0 bottom-0 opacity-20">
            <span class="material-symbols-outlined text-[120px]">support_agent</span>
        </div>
        <h3 class="text-xl font-bold mb-4 relative z-10">Cần hỗ trợ thanh toán?</h3>
        <p class="text-white/80 text-sm leading-relaxed mb-8 relative z-10">
            Nếu bạn đã quá chu kỳ đối soát mà chưa nhận được tiền, hoặc muốn thay đổi thông tin nhận tiền (STK Ngân hàng, PayPal), vui lòng liên hệ đội ngũ hỗ trợ.
        </p>
        <a href="mailto:support@linked.com" class="inline-flex items-center gap-2 bg-white text-primary px-6 py-3 rounded-2xl font-bold hover:bg-slate-50 transition-all relative z-10">
            <span class="material-symbols-outlined">mail</span>
            Gửi yêu cầu hỗ trợ
        </a>
    </div>
</div>
