@model CourseMarketplaceFE.Models.UpdateAdminProfileViewModel
@{
    ViewData["Title"] = "Edit Administrative Profile";
    ViewData["PageHeader"] = "Account Settings";
    Layout = "_AdminLayout";
}

<div class="max-w-xl mx-auto">
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <!-- Header -->
        <div class="px-6 py-5 border-b border-slate-200 bg-slate-50/50 flex items-center justify-between">
            <h3 class="text-base font-bold text-slate-900 tracking-tight">Edit Profile Info</h3>
            <a href="@Url.Action("Index", "AdminProfile")" class="text-xs font-semibold text-slate-500 hover:text-slate-900 transition-colors flex items-center gap-1">
                <span class="material-symbols-outlined text-[16px]">arrow_back</span>
                Cancel
            </a>
        </div>

        <!-- Form -->
        <form action="@Url.Action("Edit", "AdminProfile")" method="post" enctype="multipart/form-data" class="p-6 flex flex-col gap-5">
            <!-- Avatar Section -->
            <div class="flex items-center gap-4.5 bg-slate-50/50 p-4 rounded-xl border border-slate-100">
                <div class="relative shrink-0">
                    <img id="avatarPreview" src="@(string.IsNullOrEmpty(ViewBag.AvatarUrl) ? "/img/default-avatar.png" : ViewBag.AvatarUrl)"
                         class="w-16 h-16 rounded-full object-cover border border-slate-200 bg-white"
                         onerror="this.src='/img/default-avatar.png'" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-bold text-slate-700">Profile Picture</label>
                    <input type="file" name="AvatarFile" id="avatarInput" accept="image/*"
                           class="text-xs text-slate-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-900 file:text-white file:cursor-pointer hover:file:bg-slate-800 transition-all" />
                </div>
            </div>

            <!-- Display Name -->
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-slate-700">Display Name <span class="text-rose-500">*</span></label>
                <input type="text" name="DisplayName" value="@Model.DisplayName" required placeholder="Manager nickname"
                       class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
                <span asp-validation-for="DisplayName" class="text-xs text-rose-500"></span>
            </div>

            <!-- Full Name -->
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-slate-700">Full Name</label>
                <input type="text" name="FullName" value="@Model.FullName" placeholder="Họ và tên"
                       class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
            </div>

            <!-- Contact Number -->
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-slate-700">Contact Number</label>
                <input type="text" name="PhoneNumber" value="@Model.PhoneNumber" placeholder="e.g. +84912345678"
                       class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors" />
            </div>

            <!-- Bio -->
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-bold text-slate-700">Biography / About Me</label>
                <textarea name="Bio" rows="4" placeholder="Brief description about your administrative role..."
                          class="px-3.5 py-2 text-sm border border-slate-200 focus:border-slate-300 focus:outline-none rounded-lg bg-slate-50/50 focus:bg-white transition-colors resize-none">@Model.Bio</textarea>
            </div>

            <!-- Buttons -->
            <div class="flex items-center gap-3.5 border-t border-slate-100 pt-5 mt-2">
                <a href="@Url.Action("Index", "AdminProfile")" class="w-full py-2.5 text-center text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 rounded-lg transition-colors">
                    Cancel
                </a>
                <button type="submit" class="w-full py-2.5 text-sm font-semibold bg-slate-900 hover:bg-slate-800 text-white rounded-lg transition-colors shadow-sm active:scale-[0.98]">
                    Save Profile
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Live image preview
        document.getElementById('avatarInput').addEventListener('change', function(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
