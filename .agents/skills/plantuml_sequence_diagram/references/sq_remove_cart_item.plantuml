@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Delete Cart Items

actor User as act
participant "CartPage" as view
participant "LoginPage" as login_view
participant "CartController" as fe_ctrl <<frontend controller>>
participant "CartController" as be_ctrl <<backend controller>>
participant ":CartService" as sv
participant ":CartRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act -> view++: Click "Remove" button on a course in cart
view -> view++: Prompt confirmation dialog
view--
opt Cancel removal
    act -> view: Cancel removal
    view -->> act: Close dialog
end
act -> view: Confirm removal
view -> fe_ctrl++: Send POST request to /Cart/RemoveFromCart

fe_ctrl -> fe_ctrl++: Validate login session
fe_ctrl--

alt Unauthenticated Access
    fe_ctrl -> login_view++: Redirect to Login page
    login_view -->> act--: Display Login page
else Valid Session
    fe_ctrl -> be_ctrl++: Send DELETE request to /api/cart/remove/{courseId}
    
    be_ctrl -> be_ctrl++: Validate JWT Token
    be_ctrl--
    
    alt Invalid Token
        be_ctrl -->> fe_ctrl: Return statusCode 401
        fe_ctrl -> login_view++: Redirect to Login page
        login_view -->> act--: Display Login page
    else Valid Token
        be_ctrl -> sv++: Call RemoveFromCartAsync(userId, courseId)
        
        sv -> repo++: Call GetCartItemAsync(userId, courseId)
        repo -> ctx++: Query cart item
        ctx -> db++: Execute query
        db -->> ctx--: Return data
        ctx -->> repo--: Return entity
        repo -->> sv--: Return CartItem object
        
        alt Cart Item Not Found
            sv -->> be_ctrl: throw InvalidOperationException
            be_ctrl -->> fe_ctrl: Return statusCode 400
            fe_ctrl -->> view: Return statusCode 302
            view -->> act: Display error message
        else Cart Item Found
            sv -> repo++: Call RemoveCartItem(item)
            repo -> ctx++: Delete entity state
            ctx -->> repo--: Return void
            repo -->> sv--: Return result
            
            sv -> repo++: Call SaveChangesAsync()
            repo -> ctx++: Save changes
            ctx -> db++: Save changes to database
            db -->> ctx--: Return affected rows
            ctx -->> repo--: Return affected rows
            repo -->> sv--: Return numberOfRowsAffected
            
            sv -> sv++: Check numberOfRowsAffected
            sv--
            
            alt numberOfRowsAffected = 0
                sv -->> be_ctrl: throw InvalidOperationException
                be_ctrl -->> fe_ctrl: Return statusCode 400
                fe_ctrl -->> view: Return statusCode 302
                view -->> act: Display error message
            else numberOfRowsAffected > 0
                sv -->> be_ctrl--: Return result
                be_ctrl -->> fe_ctrl--: Return statusCode 200
                fe_ctrl -->> view--: Return statusCode 302
                view -->> act--: Display success message and updated cart
            end
        end
    end
end
@enduml
