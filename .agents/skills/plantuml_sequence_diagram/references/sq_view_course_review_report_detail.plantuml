@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Course Review Report Detail

actor "Staff / Admin" as act
participant "ReportCenterPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "HomePage" as home_view
participant "AdminModerationController" as fe_ctrl <<frontend controller>>
participant ":PagedResult<ReviewReportDetailViewModel>" as view_model <<view model>>
participant "AdminModerationController" as be_ctrl <<backend controller>>
participant ":IReportModerationService" as sv
participant ":PagedResult<ReviewReportDetailResponse>" as res <<dto>>
participant ":IReportRepository" as repo
database Database as db

act ++
act -> view++: Select "Course Review Reports" tab

view -> fe_ctrl++: GET /AdminModeration/GetCourseReviewReports

fe_ctrl -> fe_ctrl++: Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view: Redirect to LoginPage
    activate login_view
    login_view -->> act--: Display login form
else Unauthorized Access
    fe_ctrl -->> error_view: Redirect to ErrorPage
    activate error_view
    error_view -->> act--: Display error message
else Valid actor's authentication and authorization
    fe_ctrl -> be_ctrl++: GET /api/admin/moderation/reports/course-reviews
    be_ctrl -> sv++: Call GetAllCourseReviewReportsAsync(request)
    
    sv -> repo++: GetAllCourseReviewReportsAsync(status, page, pageSize)
    repo -> db++: Query course review reports from database
    
    alt Empty Course Review Report List
        db -->> repo: Return empty list, totalCount = 0
        repo -->> sv: Return empty list, totalCount = 0
        sv -->> be_ctrl: throw KeyNotFoundException
        be_ctrl -->> fe_ctrl: Return statusCode 404
        fe_ctrl -->> view: Return empty PartialView
        view -->> act: Display empty state message
    else Database Query Success
        db -->> repo: Return (reports, totalCount)
        db--
        repo -->> sv: Return (reports, totalCount)
        repo--
        
        sv -> sv++: Call Mapper to map entities to DTOs
        sv--
        
        sv -> res++: Create PagedResult
        res -->> sv--: Return object
        
        sv -->> be_ctrl--: Return PagedResult<ReviewReportDetailResponse>
        
        be_ctrl -->> fe_ctrl--: Return statusCode 200 with PagedResult
        
        fe_ctrl -> view_model++: Deserialize JSON to populate ViewModel
        view_model -->> fe_ctrl--: Return populated ViewModel
        
        fe_ctrl -->> view--: Return PartialView with ViewModel
        
        view -->> act: Display course review reports
        
        act -> view: Click on a course review report row
        
        view -> view++: Retrieve selected course review report details from local state
        view--
        
        opt Report contains resolution details (Resolved/Rejected)
            view -> view++: Append Resolution Details (Moderator, Resolved At, Note)
            view--
        end
        
        view -->> act--: Display popup containing course review report details
    end
end
@enduml
