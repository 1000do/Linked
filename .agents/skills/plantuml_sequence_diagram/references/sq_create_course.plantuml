@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Create Course
actor Instructor as act

participant "CourseCreationForm" as view
participant "CloudStorageService" as cloud
participant "InstructorCourseController" as fe_ctrl
participant "CourseController" as be_ctrl

participant ":CourseCommandService" as sv
participant ":CourseResponse" as res
participant ":Course" as ett

participant ":CourseRepository" as repo
participant ":CourseExtRepository" as ext_repo
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++:Access course creation form
act->view:Enter required course details
act->view:Upload a thumbnail image
view->cloud++:Send image file
cloud-->>view--:Return image URL
act->view:Set the course price
act->view:Click the "Create Course" button
view->view++:Validate input
view--
group opt [Invalid input]
    view-->>act:Display error message
end

view->fe_ctrl++:Send POST request to InstructorCourse/Create
fe_ctrl->fe_ctrl++: Validate ModelState
fe_ctrl--
group opt [Invalid ModelState]
    fe_ctrl-->>view: Return status code 400 
    view-->>act:Display error message
end
fe_ctrl->be_ctrl++: Send POST request to /courses
be_ctrl -> sv++: Call CreateCourseAsync()
sv -> sv++: CheckInstructorRights()
sv--
alt Invalid Instructor Rights
    sv -->> be_ctrl: throw BadRequestException
    be_ctrl -->> fe_ctrl: Return statusCode 400
    fe_ctrl -->> view: Return statusCode 400
    view -->> act: Display error message
' Be it Flat or Nested, the final branch of the alt fragment must be semantically sensible with its Conditional Trigger
' In this case, since we pretty much have 2 branches, I decide to use the original condition
' In other cases, like for Remove Course, we might rename the Conditional Trigger to make the flat alt sensible
else Valid Instructor Rights
    sv -> ett++: Call Course()
    ett -->>sv--: Return Course object

    sv -> sv++: Call AddCourseFingerprintAsync()
    sv--

    sv -> repo++: Call Add()
    repo->ctx++: Call Add()
    ctx-->>repo--: Return result
    repo -->> sv--: Return result

    sv -> sv++: Call SaveChangesWithFingerprintAsync()
    sv -> ext_repo++: Call SaveChangesAsync()
    ext_repo->ctx++: Call SaveChangesAsync()
    ctx->db++: Save changes to Database
    
    alt Duplicate Content Detected
        db-->>ctx: throw DbUpdateException
        ctx-->>ext_repo: throw DbUpdateException
        ext_repo -->> sv: throw CourseExtException
        sv -->> be_ctrl: throw BadRequestException
        be_ctrl -->> fe_ctrl: Return statusCode 400
        fe_ctrl -->> view: Return statusCode 400
        view -->> act: Display error message
    else No Duplicate Content Detected
        db-->>ctx--: Return numberOfRowsAffected
        ctx-->>ext_repo--: Return numberOfRowsAffected
        ext_repo -->> sv--: Return numberOfRowsAffected
        ' SaveChangesWithFingerprintAsync activation bar should end here since it either throws BadRequestException or Return numRows to its references
        sv--
        ' From now on, for the Conditional Trigger of numberOfRowsAffected check should always be like this
        sv->sv++:Check numberOfRowsAffected
        sv--
        alt numberOfRowsAffected > 0
            sv -> res++: Call CourseResponse()
            res -->> sv--: Return CourseResponse object
            sv -->> be_ctrl: Return CourseResponse object
            be_ctrl -->> fe_ctrl:Return statusCode 201
            fe_ctrl -->> view: Return statusCode 201
            view -->> act: Display course creation success message
        else numberOfRowsAffected = 0
            sv-->>be_ctrl--:throw InvalidOperationException
            be_ctrl -->> fe_ctrl--:Return statusCode 400
            fe_ctrl -->> view--: Return statusCode 400
            view -->> act--: Display error message
        end
    end
end

@enduml