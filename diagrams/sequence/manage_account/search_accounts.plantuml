@startuml search_accounts
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Search Accounts
actor Admin as act

participant "AccountListView" as view
participant "AdminAccountController" as be_ctrl
participant ":AdminAccountService" as sv
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++: Enter search keyword in search input\n(Email, Name, or Phone)
view->be_ctrl++: GET /api/admin/accounts?keyword={kw}&role={role}&page=1&pageSize=10
be_ctrl->sv++: GetAccountsPagedAsync(keyword, role, page, pageSize)
sv->ctx++: Query Accounts matching keyword\n(a.Email, a.PhoneNumber, Manager.DisplayName, User.FullName)
ctx->db++: Execute SQL query
db-->>ctx--: Return matched results
ctx-->>sv--: Return matched items and count
sv-->>be_ctrl--: Return PagedResult<AdminAccountListDto>
be_ctrl-->>view--: Return status 200 with JSON payload (search results)
view-->>act--: Render and display searched Account List
@enduml
