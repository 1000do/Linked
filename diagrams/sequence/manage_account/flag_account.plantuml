@startuml flag_account
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Flag Account for Violation
actor Admin as act

participant "AccountListView" as view
participant "AdminAccountController" as be_ctrl
participant ":AdminAccountService" as sv
participant ":AppDbContext" as ctx
participant ":NotificationService" as noti

database Database as db

act++
act->view++: Click "Flag Account" button & enter Reason
view->be_ctrl++: POST /api/admin/accounts/{id}/flag\n(FlagAccountRequest: { Reason })
be_ctrl->sv++: FlagAccountAsync(id, reason)
sv->ctx++: FindAsync<Account>(id)
ctx->db++: SELECT Account where AccountId = id
db-->>ctx--: Return Account entity
ctx-->>sv--: Return Account entity

alt Account is null
    sv-->>be_ctrl: Return Success=false, ErrorMessage="Account not found."
    be_ctrl-->>view: Return 404 NotFound
    view-->>act: Display "Account not found" message
else Account is already banned or flags >= 3
    sv-->>be_ctrl: Return Success=false, ErrorMessage="Already banned or max flags reached."
    be_ctrl-->>view: Return 400 BadRequest
    view-->>act: Display warning message
else Account eligible for flagging
    sv->sv: Increment flags, update AccountStatus\n(flagged_1, flagged_2, or banned)
    sv->ctx: Update Account Entity
    sv->ctx++: SaveChangesAsync()
    ctx->db++: UPDATE Accounts
    db-->>ctx--: Return rows affected
    ctx-->>sv--: Return rows affected
    
    alt rowsAffected <= 0
        sv-->>be_ctrl: Throw InvalidOperationException
        be_ctrl-->>view: Return 400 BadRequest ("Failed to flag account")
    else rowsAffected > 0
        opt Send Notification (Try-Catch)
            sv->noti++: SendNotificationAsync(accountId, title, content, "/profile")
            noti-->>sv--: Completed
        end
        sv-->>be_ctrl--: Return Success=true, currentFlags, newStatus
        be_ctrl-->>view--: Return status 200 with result payload
        view-->>act--: Render updated account status & flag count
    end
end
@enduml
