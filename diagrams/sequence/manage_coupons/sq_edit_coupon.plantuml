@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Edit Coupon

actor Admin as act
participant "CouponListView" as view
participant "CouponController" as be_ctrl <<backend controller>>
participant ":UpdateCouponRequestDTO" as be_req
participant ":ICouponService" as sv
participant ":ICouponRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Click "Edit" and submit form
view->be_ctrl++: PUT /api/coupon/{id}

be_ctrl->be_req++: Call UpdateCouponRequestDTO()
be_req-->>be_ctrl--: Return UpdateCouponRequestDTO object

be_ctrl->sv++: Update(id, req, GetUserId(), isAdmin)

sv->repo++: GetByIdAsync(id, filterId)
repo->ctx++: Query coupon
ctx->db++: Execute query
db-->>ctx--: Return result
ctx-->>repo--: Return Coupon entity
repo-->>sv--: Return Coupon entity

sv->sv++: Validate coupon update request
sv--

alt Coupon not found
    sv-->>be_ctrl: throw KeyNotFoundException
    be_ctrl-->>view: Return statusCode 404
    view-->>act: Display error message
else Invalid EndDate or UsageLimit
    sv-->>be_ctrl: throw ArgumentException
    be_ctrl-->>view: Return statusCode 400
    view-->>act: Display error message
else Valid coupon update request
    sv->sv++: Update EndDate, UsageLimit, IsActive
    sv--
    
    sv->repo++: Update(coupon)
    repo->ctx++: Mark entity as modified
    ctx-->>repo--: Return result
    repo-->>sv--: Return result
    
    sv->repo++: SaveChangesAsync()
    repo->ctx++: Commit tracked changes
    ctx->db++: Save changes to database
    db-->>ctx--: Return result
    ctx-->>repo--: Return numberOfRowsAffected
    repo-->>sv--: Return success
    
    sv-->>be_ctrl--: Return result
    be_ctrl-->>view--: Return statusCode 200
    view-->>act--: Display success message
end
@enduml
