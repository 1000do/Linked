@startuml add_coupon
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Add Coupons
actor Admin as act

participant "CouponListView" as view
participant "CouponController" as be_ctrl
participant ":CouponService" as sv
participant ":CouponRepository" as repo
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++: Click "Add Coupon" & enter Coupon details\n(Code, Type, Value, Start/End Date, Limit)
view->be_ctrl++: POST /api/coupon\n(CreateCouponRequest payload)
be_ctrl->sv++: Create(req, managerId)
sv->sv: NormalizeType() & ValidateCreate()

sv->repo++: GetByCodeAsync(couponCode)
repo->ctx++: Query Coupon where CouponCode = code
ctx->db++: Execute SELECT Query
db-->>ctx--: Return Coupon (if exists)
ctx-->>repo--: Return Coupon
repo-->>sv--: Return Coupon

alt Coupon Code Already Exists
    sv-->>be_ctrl: Throw InvalidOperationException("Coupon code ... already exists")
    be_ctrl-->>view: Return 400 BadRequest (ApiResponse with Error message)
    view-->>act: Display error "Coupon code already exists"
else Coupon Code is Unique
    sv->sv: Instantiate new Coupon entity
    sv->repo++: AddAsync(coupon)
    repo->ctx++: Add Coupon entity to ChangeTracker
    ctx-->>repo--: Completed
    repo-->>sv--: Completed
    
    sv->repo++: SaveChangesAsync()
    repo->ctx++: SaveChangesAsync()
    ctx->db++: INSERT INTO Coupons
    db-->>ctx--: Return rows affected
    ctx-->>repo--: Return rows affected
    repo-->>sv--: Return rows affected
    
    alt rowsAffected <= 0
        sv-->>be_ctrl: Throw InvalidOperationException("Failed to save changes")
        be_ctrl-->>view: Return 400 BadRequest (ApiResponse)
    else rowsAffected > 0
        sv-->>be_ctrl--: Completed successfully
        be_ctrl-->>view--: Return status 200 with Success payload
        view-->>act--: Render updated Coupon List / Success message
    end
end
@enduml
