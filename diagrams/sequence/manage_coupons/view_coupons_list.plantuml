@startuml view_coupons_list
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Coupons List
actor Admin as act

participant "CouponListView" as view
participant "CouponController" as be_ctrl
participant ":CouponService" as sv
participant ":CouponRepository" as repo
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++: Access "Voucher Center" page / Search & Filter Coupons
view->be_ctrl++: GET /api/coupon?isActive={isActive}&type={type}&search={search}
be_ctrl->sv++: GetAll(managerId, isActive, type, search, isAdmin=true)
sv->repo++: GetAllAsync(managerId=null, isActive, type, search)
repo->ctx++: Query Coupons entities with filters\n(isActive, type, search, sorted by CouponId desc)
ctx->db++: Execute SELECT query
db-->>ctx--: Return matched Coupon entities
ctx-->>repo--: Return list of Coupon entities
repo-->>sv--: Return list of Coupon entities
sv->sv: Map list to List<CouponResponse>
sv-->>be_ctrl--: Return List<CouponResponse>
be_ctrl-->>view--: Return status 200 with ApiResponse<List<CouponResponse>>
view-->>act--: Render and display Coupon List table
@enduml
