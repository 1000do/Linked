@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Edit Profile (For Manager)


actor Staff as act

participant "EditProfilePage" as view
participant "AdminProfileController" as fe_ctrl <<frontend controller>>
participant "AdminProfileController" as be_ctrl <<backend controller>>
participant ":IManagerProfileService" as sv
participant ":IFileUploadService" as upload_sv
participant ":ManagerProfileResponse" as res
participant ":IManagerRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++

act -> view++: Enter personal information (DisplayName, PhoneNumber, Bio, AvatarFile)
act -> view: Click "Save Changes" button
view -> fe_ctrl++: POST /AdminProfile/Edit (FormData)

fe_ctrl -> fe_ctrl++: Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> view: Return JSON (success=false)
    view -->> act: Display error message
else Unauthorized Access
    fe_ctrl -->> view: Return JSON (success=false)
    view -->> act: Display error message
else Valid actor's authentication and authorization
    fe_ctrl -> fe_ctrl++: Validate model inputs
    fe_ctrl--
    
    alt Invalid Form Data
        fe_ctrl -->> view: Return JSON (success=false)
        view -->> act: Display error message
    else Valid Form Data
        fe_ctrl -> be_ctrl++: PUT /api/admin/profile/update (MultipartFormData)
        
        be_ctrl -> be_ctrl++: Validate ModelState & Login Session
        be_ctrl--
        
        alt Invalid ModelState or Session
            be_ctrl -->> fe_ctrl: Return statusCode 400 or 401
            fe_ctrl -->> view: Return JSON (success=false)
            view -->> act: Display error message
        else Valid Request
            be_ctrl -> sv++: UpdateProfileAsync(userId, request)
            
            sv -> sv++: Validate PhoneNumber & Upload Avatar
            sv--
            
            alt Invalid PhoneNumber or Avatar Upload Failed
                sv -->> be_ctrl: Throw Exception / Return false
                be_ctrl -->> fe_ctrl: Return Error statusCode
                fe_ctrl -->> view: Return JSON (success=false)
                view -->> act: Display error message
            else Valid Data and Upload Success (or No Avatar)
                opt AvatarFile != null
                    sv -> upload_sv++: UploadImageAsync(AvatarFile)
                    upload_sv -->> sv--: Return avatarUrl
                end
                
                sv -> repo++: UpdateManagerProfileAsync(userId, displayName, fullName, phoneNumber, avatarUrl, bio)
                    
                    repo -> ctx++: Save changes to database
                    ctx -> db++: Execute UPDATE
                    db -->> ctx--: Return numberOfRowsAffected
                    ctx -->> repo--: Return numberOfRowsAffected
                    repo -->> sv--: Return result
                    
                    alt Database Save Failure (result = false)
                        sv -->> be_ctrl: Return false
                        be_ctrl -->> fe_ctrl: Return statusCode 400
                        fe_ctrl -->> view: Return JSON (success=false)
                        view -->> act: Display error message
                    else Database Save Success (result = true)
                        sv -->> be_ctrl--: Return true
                        be_ctrl -->> fe_ctrl--: Return statusCode 200 (Success)
                        
                        fe_ctrl -> be_ctrl++: GET /api/admin/profile
                        be_ctrl -> sv++: GetProfileAsync(userId)
                        sv -> repo++: GetManagerByIdAsync(userId)
                        repo -> ctx++: Fetch Manager with Account details
                        ctx -> db++: Execute Query
                        db -->> ctx--: Return database record
                        ctx -->> repo--: Return Manager entity
                        repo -->> sv--: Return Manager entity
                        
                        sv -> res++: Call ManagerProfileResponse()
                        res -->> sv--: Return ManagerProfileResponse object
                        sv -->> be_ctrl--: Return ManagerProfileResponse DTO
                        be_ctrl -->> fe_ctrl--: Return statusCode 200 (parsed and sync display cookies)
                        
                        fe_ctrl -->> view: Return JSON (success=true, message, avatarUrl)
                        deactivate fe_ctrl
                        view -->> act--: Display success message and update UI
                    end
                end
            end
        end
    end

@enduml
