@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Chat History

actor User as act
participant "ChatIndexPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_page
participant "ChatController" as fe_ctrl <<frontend controller>>
participant "ChatController" as be_ctrl <<backend controller>>
participant "ChatHub" as hub
participant ":ChatService" as sv
participant ":IChatRepository" as repo
participant ":MessageDto" as msg_dto
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Click on partner in Chat List
view->view++: Select chat (chatId)
view--

view->fe_ctrl++: GET /Chat/GetHistory?roomId={chatId}

fe_ctrl -> fe_ctrl++: Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view: Redirect to LoginPage
    activate login_view
    login_view -->> act--: Display login form
else Unauthorized Access
    fe_ctrl -->> error_page: Redirect to ErrorPage
    activate error_page
    error_page -->> act--: Display error message
else Valid actor's authentication and authorization
    fe_ctrl->be_ctrl++: GET /api/chat/history?roomId={chatId}
    
    be_ctrl->sv++: Call GetChatHistoryAsync(chatId, accountId)

sv->sv++: Call HasAccessToChatAsync(accountId, chatId)
sv->repo++: Call IsParticipantAsync(chatId, accountId)
repo->ctx++: Call IsParticipantAsync(chatId, accountId)
ctx->db++: Execute SELECT query

db-->>ctx--: Return isParticipant
ctx-->>repo--: Return isParticipant
repo-->>sv--: Return isParticipant
sv-->>sv--: Return hasAccess

alt hasAccess == false
    sv-->>be_ctrl: throw UnauthorizedAccessException
    be_ctrl-->>fe_ctrl: Return statusCode 403 (Forbidden)
    fe_ctrl-->>view: Return Forbidden
    view-->>act: Display unauthorized error message
else [hasAccess == true]
    sv->sv++: Call MarkChatAsReadAsync(chatId, accountId)
    
    sv->repo++: Call MarkAsReadAsync(chatId, accountId)
    repo->ctx++: Call MarkAsReadAsync(chatId, accountId)
    ctx-->>repo--: Return success
    repo-->>sv--: Return success
    
    sv->repo++: Call SaveChangesAsync()
    repo->ctx++: Call SaveChangesAsync()
    ctx->db++: Save changes (Execute UPDATE statement)
    
    alt Database Save Failure
        db-->>ctx: Throw DbUpdateException
        ctx-->>repo: Throw DbUpdateException
        repo-->>sv: Throw DbUpdateException
        sv-->>be_ctrl: Throw DbUpdateException
        be_ctrl-->>fe_ctrl: Return statusCode 500 (InternalServerError)
        fe_ctrl-->>view: Return JSON error
        view-->>act: Display database error message
    else Database Save Success
        db-->>ctx--: Return result
        ctx-->>repo--: Return result
        repo-->>sv--: Return result
        sv-->>sv--: Return success
        
        sv->repo++: Call GetParticipantAsync(chatId, accountId)
        repo->ctx++: Call GetParticipantAsync(chatId, accountId)
        ctx->db++: Execute SELECT query
        db-->>ctx--: Return ChatParticipant
        ctx-->>repo--: Return ChatParticipant
        repo-->>sv--: Return ChatParticipant
        
        sv->repo++: Call GetMessagesByChatIdAsync(chatId)
        repo->ctx++: Call GetMessagesByChatIdAsync(chatId)
        ctx->db++: Execute SELECT query
        db-->>ctx--: Return Messages list
        ctx-->>repo--: Return List<Message>
        repo-->>sv--: Return List<Message>
        
        sv->sv++: Filter messages where SentAt > ClearedAt
        sv--
        sv->msg_dto++: Call MessageDto()
        msg_dto-->>sv--: Return MessageDto list
        
        sv-->>be_ctrl--: Return List<MessageDto>
        be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with message list
        fe_ctrl-->>view--: Return JSON message list
        
        view->view++: renderChatHistory(messages)
        view--
        view->view++: scrollToBottom()
        view--
        
        view->hub++: Invoke MarkAsRead(chatId) via SignalR
        hub->hub++: Broadcast ReadReceipt to Group ("Chat_{chatId}")
        hub--
        hub-->>view--: Broadcast read status update
        
        view-->>act--: Display chat messages and history
    end
end
end

@enduml
