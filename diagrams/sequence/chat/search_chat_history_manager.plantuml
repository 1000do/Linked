@startuml SearchChatHistoryManager
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Search Chat History (For Manager)
actor Staff as act

participant "ChatIndexView" as view

act++
act -> view++: Type search query in "search-chats" input field

view -> view++: EventListener: input
view -> view++: applyChatFilters()

view -> view++: Filter allChats locally (partnerName or lastMessage contains query)
view--

view -> view++: renderChatList(filteredChats)
view--

deactivate view
deactivate view

view -->> act--: Display filtered conversations in sidebar list
deactivate view
@enduml
