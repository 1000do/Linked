@startuml ViewInstructorApplicationsDetail
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Instructor Applications Detail
actor Staff as act

participant "AdminApprovalIndexView" as view
participant "DocumentViewer" as doc_view
participant "FileStorage" as fs

act++
act -> view++: Click on a submitted document link (e.g., "Document #1 (.pdf)")
view -> doc_view++: Open document URL in a new browser tab (target="_blank")
view--

doc_view -> fs++: Send GET request to retrieve the document file
fs -> fs++: Fetch document file content (PDF/Image)
fs--
fs -->> doc_view--: Return document file stream / content

doc_view -->> act--: Display instructor application document (CV / Certificate) in browser
deactivate act

@enduml
