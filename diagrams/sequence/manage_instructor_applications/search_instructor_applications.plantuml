@startuml SearchInstructorApplications
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Search Instructor Applications
actor Staff as act

participant "AdminApprovalIndexView" as view
participant "AdminApprovalController" as be_ctrl
participant ":InstructorApprovalService" as sv
participant ":InstructorRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act -> view++: Enter keyword in search input (e.g. name, email, professional title)
view -> view++: EventListener: input / change
view -> view++: triggerAjaxFetch() with 300ms debounce
view--

view -> view++: fetchInstructors(search, page, pageSize)
view -> view++: Set table-container opacity to 0.5
view--

view -> be_ctrl++: Send GET request to /AdminApproval/Index?search=...&page=...&pageSize=...
be_ctrl -> sv++: Call GetPendingListAsync(search, page, pageSize)
sv -> repo++: Call GetPendingInstructorsAsync(search, page, pageSize)
repo -> ctx++: Call GetPendingInstructorsAsync(search, page, pageSize)

ctx -> ctx++: Apply filter: Status = "Pending"
ctx--
ctx -> ctx++: Apply search: FullName, Email or ProfessionalTitle contains keyword (if specified)
ctx--

ctx -> db++: Query filtered pending instructors & total count
db -->> ctx--: Return instructors list & total count
ctx -->> repo--: Return instructors list & total count
repo -->> sv--: Return instructors list & total count

sv -> sv++: Map to InstructorApprovalDto items
sv--

sv -->> be_ctrl--: Return PagedResult<InstructorApprovalDto>
be_ctrl -->> view: Return Index view / HTML with filtered applications data
deactivate be_ctrl

view -> view++: Parse HTML response with DOMParser
view -> view++: Replace table-container innerHTML with new content
view--
view -> view++: Restore table-container opacity to 1.0
view--
deactivate view

view -->> act--: Display filtered list of pending instructor applications
deactivate view

@enduml
