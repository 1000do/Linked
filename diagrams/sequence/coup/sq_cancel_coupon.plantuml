@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Cancel Coupon
actor User as act

participant "CartView" as view
participant "CartController" as fe_ctrl <<frontend controller>>
participant "CartController" as be_ctrl <<backend controller>>
participant ":CartSummaryResponseDTO" as res
participant ":CartViewModel" as vm
participant ":ICartService" as sv
participant ":ICartRepository" as cart_repo
participant ":ICouponRepository" as coupon_repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Click "Cancel" / "Remove Coupon" button
view->fe_ctrl++: POST /Cart/RemoveCoupon

fe_ctrl->fe_ctrl++: Retrieve applied coupon map from cookies
fe_ctrl--
fe_ctrl->fe_ctrl++: Remove coupon entry from cookie map
fe_ctrl--
fe_ctrl->fe_ctrl++: Set success message
fe_ctrl--

fe_ctrl-->>view--: Return statusCode 302
view->fe_ctrl++: GET /Cart

fe_ctrl->be_ctrl++: GET /api/cart/summary

be_ctrl->sv++: Call GetCartSummaryAsync(userId, couponCode)

sv->cart_repo++: Call GetCartItemsWithDetailsAsync(userId)
cart_repo->ctx++: Query CartItems and Course details
ctx->db++: Execute query
db-->>ctx--: Return result
ctx-->>cart_repo--: Return list
cart_repo-->>sv--: Return list

sv->sv++: Re-calculate totals based on remaining coupons
sv--

sv->coupon_repo++: Call GetActiveAvailableCouponsAsync(now)
coupon_repo->ctx++: Query active coupons
ctx->db++: Execute query
db-->>ctx--: Return result
ctx-->>coupon_repo--: Return list
coupon_repo-->>sv--: Return list

sv->res++: Call CartSummaryResponseDTO()
res-->>sv--: Return CartSummaryResponseDTO object

sv-->>be_ctrl--: Return CartSummaryResponseDTO object
be_ctrl-->>fe_ctrl--: Return statusCode 200

fe_ctrl->vm++: Call CartViewModel()
vm-->>fe_ctrl--: Return CartViewModel object

fe_ctrl->fe_ctrl++: Map to CartViewModel
fe_ctrl--

fe_ctrl-->>view--: Return statusCode 200
view-->>act--: Display cart items with original prices and cleared coupon input
@enduml
