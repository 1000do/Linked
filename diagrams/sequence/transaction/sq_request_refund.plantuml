    @startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Request Refund

actor User as act
participant "PurchaseHistoryPage" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "TransactionController" as be_ctrl <<backend controller>>
participant ":AdminFinanceService" as sv
participant ":FinanceRepository" as repo
participant ":NotificationService" as noti
participant ":AppDbContext" as ctx
database Database as db

act ++
view ++

act -> view: Click "Refund Request" button next to eligible transaction
view -->> act: Display confirmation modal for refund reason

act -> view: Enter reason and click "Submit Request" button

view -> fe_ctrl++: POST /Transaction/RequestRefund(transactionId, reason)

fe_ctrl -> fe_ctrl++: Validate reason
fe_ctrl--

alt Missing Refund Reason
    fe_ctrl -->> view--: Return JSON (success=false, message="Refund reason cannot be empty")
    view -->> act: Display validation alert "You must enter a refund reason!"
else Reason Valid
    fe_ctrl -> be_ctrl++: POST /api/transactions/{id}/request-refund
    
    be_ctrl -> be_ctrl++: Check user session
    be_ctrl--
    
    opt Session Invalid
        be_ctrl -->> fe_ctrl: Return 401 Unauthorized
        fe_ctrl -->> view: Redirect to Login
        view -->> act: Display Login page
    end
    
    be_ctrl -> sv++: RequestRefundAsync(transactionId, studentId, reason)
    
    sv -> repo++: GetTransactionWithFullGraphAsync(transactionId)
    repo -> ctx++: Query transaction
    ctx -> db++: Execute SELECT
    db -->> ctx--: Return record
    ctx -->> repo--: Return Transaction entity
    repo -->> sv--: Return Transaction entity
    
    sv -> sv++: Validate ownership, status, 14-day window, gift claimed status
    sv--
    
    sv -> repo++: GetRefundEligibilityMetricsAsync(transactionId, studentId, courseId)
    repo -> ctx++: Calculate eligibility metrics
    ctx -> db++: Execute aggregation queries
    db -->> ctx--: Return metrics data
    ctx -->> repo--: Return RefundEligibilityMetrics
    repo -->> sv--: Return RefundEligibilityMetrics
    
    sv -> sv++: Evaluate metrics against auto-rejection rules
    sv--
    
    alt Auto-Rejection Triggered
        sv -> sv++: Update TransactionExt with abstract reject reason
        sv--
        
        sv -> repo++: SaveChangesAsync()
        repo -> ctx++: SaveChangesAsync()
        ctx -> db++: UPDATE
        db -->> ctx--: 1 row affected
        ctx -->> repo--: Return
        repo -->> sv--: Return
        
        sv -->> be_ctrl: Return RefundResultDto (IsAutoRejected=true, RejectReason)
    else Validation Passed (Normal Flow)
        sv -> sv++: Update TransactionsStatus to "refund_pending" & save TransactionExt
        sv--
        
        sv -> repo++: SaveChangesAsync()
        repo -> ctx++: SaveChangesAsync()
        ctx -> db++: UPDATE
        db -->> ctx--: 1 row affected
        ctx -->> repo--: Return
        repo -->> sv--: Return
        
        sv -> noti++: SendNotificationAsync(AdminId, "New Refund Request")
        noti -->> sv--: Notification queued
        
        sv -->> be_ctrl: Return RefundResultDto (IsAutoRejected=false)
    end
    deactivate sv
    
    be_ctrl -->> fe_ctrl--: Return statusCode 200 (ApiResponse)
    
    fe_ctrl -->> view--: Return JSON (RefundResultDto data)
    
    view -> view++: Check autoRejected flag
    view--
    
    alt Auto-Rejection Triggered
        view -->> act: Display rejection message with abstract reason
    else Validation Passed (Normal Flow)
        view -->> act: Display success message
        view -> view++: Reload page to display updated transaction status
        view--
        view -->> act: Reloaded Purchase History Page
    end
end

deactivate view
deactivate act

@enduml
