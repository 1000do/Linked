@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Request Refund
actor User as act

participant "Transaction/History.cshtml" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "TransactionController" as be_ctrl <<backend controller>>
participant ":AdminFinanceService" as sv
participant ":AdminFinanceRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Click "Refund Request" button
view->view++: Open SweetAlert2 modal
view--

act->view: Enter reason and click "Submit Request"
view->fe_ctrl++: Send POST /Transaction/RequestRefund (transactionId, reason)

alt [Reason is empty]
    fe_ctrl-->>view: Return JSON (success = false)
    view-->>act: Display warning alert
else [Reason is valid]
    fe_ctrl->be_ctrl++: Send POST /api/transactions/{id}/request-refund (with Bearer Token & Reason DTO)
    
    be_ctrl->be_ctrl++: Retrieve studentId from Token Claims
    be_ctrl--
    
    be_ctrl->sv++: Call RequestRefundAsync(transactionId, studentId, reason)
    sv->repo++: Call GetTransactionWithFullGraphAsync(transactionId)
    repo->ctx++: Query transaction with details
    ctx->db++: Execute SELECT query
    db-->>ctx--: Return transaction record
    ctx-->>repo--: Return transaction entity
    repo-->>sv--: Return transaction entity
    
    alt [Transaction not found / invalid owner / not succeeded / purchased > 14 days]
        sv-->>be_ctrl: throw InvalidOperationException
        be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    else [Transaction is eligible for request validation]
        sv->repo++: Call GetRefundEligibilityMetricsAsync(transactionId, studentId, courseId)
        repo->ctx++: Query student metrics
        ctx->db++: Execute query
        db-->>ctx--: Return metrics
        ctx-->>repo--: Return metrics DTO
        repo-->>sv--: Return RefundEligibilityMetrics
        
        sv->sv++: Evaluate eligibility metrics (Auto-Reject Rule Check)
        sv--
        
        alt [Auto-reject criteria met]
            sv->repo++: Update TransactionExt with Rejected status & reason
            repo->ctx++: Mark entity as modified/added
            ctx-->>repo--: Return
            repo-->>sv--: Return
        else [Eligible for review]
            sv->repo++: Create TransactionExt with Pending status & reason
            repo->ctx++: Mark entity as added
            ctx-->>repo--: Return
            repo-->>sv--: Return
        end
        
        sv->repo++: Call SaveChangesAsync()
        repo->ctx++: Call SaveChangesAsync()
        ctx->db++: Execute UPDATE/INSERT statements
        db-->>ctx--: Return result
        ctx-->>repo--: Return numberOfRowsAffected
        repo-->>sv--: Return numberOfRowsAffected
        
        repo->repo++: Check numberOfRowsAffected
        repo--
        
        alt [numberOfRowsAffected > 0]
            repo-->>sv: Return true
            sv-->>be_ctrl: Return RefundResultDto
            be_ctrl-->>fe_ctrl: Return statusCode 200 (Ok) with RefundResultDto JSON
            fe_ctrl->fe_ctrl++: Deserialize response
            fe_ctrl--
            fe_ctrl-->>view: Return JSON (success = true)
            
            alt [Request was auto-rejected]
                view-->>act: Display "Refund Rejected" error alert
            else [Request is pending review]
                view-->>act: Display "Request Submitted!" success alert
            end
        else [numberOfRowsAffected = 0]
            repo-->>sv--: Return false
            sv->sv++: throw InvalidOperationException
            sv--
            sv-->>be_ctrl--: throw InvalidOperationException
            be_ctrl-->>fe_ctrl--: Return statusCode 400 (BadRequest)
            fe_ctrl-->>view--: Return statusCode 400
            view-->>act--: Display error message
        end
    end
end
@enduml
