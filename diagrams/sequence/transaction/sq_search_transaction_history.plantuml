@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Search Transaction History

actor User as act
participant "PurchaseHistoryPage" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "TransactionController" as be_ctrl <<backend controller>>
participant ":TransactionService" as sv
participant ":TransactionRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
view ++

act -> view: Enter search keyword in "Search by course title..." input field
act -> view: Click "Apply" button or press "Enter"

view -> fe_ctrl++: GET /Transaction/History?keyword=searchTerm

fe_ctrl -> fe_ctrl++: Initialize TransactionPagedVM
fe_ctrl--

fe_ctrl -> be_ctrl++: GET /api/transactions/my?keyword=searchTerm
be_ctrl -> sv++: GetUserTransactionsAsync(userId, page, pageSize, keyword, sortBy, status)

sv -> sv++: Validate pagination parameters
sv--

sv -> repo++: GetUserTransactionsAsync(userId, page, pageSize, keyword, sortBy, status)

repo -> ctx++: Calculate totalCount and query items with keyword filter
ctx -> db++: Execute query
db -->> ctx--: Return data
ctx -->> repo--: Return items and totalCount

repo -->> sv--: Return items and totalCount

sv -> sv++: Create PagedResult
sv--

sv -->> be_ctrl--: Return PagedResult object
be_ctrl -->> fe_ctrl--: Return statusCode 200

fe_ctrl -> fe_ctrl++: Deserialize JSON to TransactionPagedVM
fe_ctrl--

fe_ctrl -->> view--: Return View(vm)

view -> view++: Check totalCount and keyword
view--
alt Matching results found (totalCount > 0)
    view -->> act: Display filtered list of transactions

    opt Reset Search (A.2.1)
        act -> view: Click "Reset" button
        view -> fe_ctrl++: GET /Transaction/History (without keyword)
        
       
        fe_ctrl -->> view--: Return View(vm)
        
        view -->> act: Clear search input field and hide "Reset" button
        view -->> act: Display full unfiltered transaction history list
    end
    
else No matching results found (totalCount == 0)
    view -->> act: Display empty state screen with "No transactions found" message


end

@enduml
