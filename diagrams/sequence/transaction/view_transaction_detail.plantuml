@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Transaction Detail
actor User as act

participant "HistoryDetail.cshtml" as view
participant "TransactionController (FE)" as fe_ctrl
participant "TransactionController (BE)" as be_ctrl
participant ":TransactionService" as sv
participant ":TransactionRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Click chevron/details button on transaction card
view->fe_ctrl++: Send GET request to /Transaction/HistoryDetail/{id}

fe_ctrl->be_ctrl++: Send GET /api/transactions/{id} (with Bearer Token)

alt [Transaction not found (404)]
    be_ctrl-->>fe_ctrl: Return statusCode 404 (NotFound)
    fe_ctrl-->>view: Redirect to Transaction/History with Error message
    view-->>act: Redirect to Purchase History page and display Toast error
else [Transaction is found]
    be_ctrl->sv++: Call GetTransactionDetailAsync(transactionId)
    sv->repo++: Call GetTransactionDetailAsync(transactionId)
    
    repo->ctx++: Query detailed transaction data with multi-table joins\n(Buyer, Seller/Instructor, Course, Coupon, Payouts)
    ctx->db++: Execute SELECT query
    db-->>ctx--: Return transaction detail record
    ctx-->>repo--: Return TransactionDetailDto
    repo-->>sv--: Return TransactionDetailDto
    sv-->>be_ctrl--: Return TransactionDetailDto
    be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with JSON data
    
    fe_ctrl->fe_ctrl++: Deserialize to ApiResp<TransactionDetailVM>
    fe_ctrl--
    fe_ctrl-->>view--: Return View(parsed.Data)
    view-->>act--: Display electronic invoice details page
end
@enduml
