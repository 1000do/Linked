@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Transaction Detail

actor User as act
participant "PurchaseHistoryPage" as list_view
participant "HistoryDetailPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant ":TransactionDetailVM" as vm
participant "TransactionController" as be_ctrl <<backend controller>>
participant ":ITransactionService" as sv
participant ":ITransactionRepository" as repo
participant ":AppDbContext" as ctx
participant ":TransactionDetailDto" as dto
database Database as db

activate act
activate list_view

act -> list_view: Click "View Detail" button next to a transaction record
list_view -> fe_ctrl++: GET /Transaction/HistoryDetail/{id}

fe_ctrl -> fe_ctrl++: Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view++: Redirect to LoginPage
    login_view -->> act--: Display login form
else Unauthorized Access
    fe_ctrl -->> error_view++: Redirect to ErrorPage
    error_view -->> act--: Display error message
else Valid actor's authentication and authorization
    
    fe_ctrl -> be_ctrl++: GET /api/transactions/{id}
    be_ctrl -> sv++: GetTransactionDetailAsync(id)
    sv -> repo++: GetTransactionDetailAsync(id)
    repo -> ctx++: Query transaction details
    ctx -> db++: Execute SELECT with JOINs (Courses, Users, OrderItems)
    db -->> ctx--: Return query result
    
    ctx -> ctx++: Check if query result is null
    ctx--
    
    alt Database Query Failure (Not Found)
        ctx -->> repo: Return null
        repo -->> sv: Return null
        sv -->> be_ctrl: Return null
        be_ctrl -->> fe_ctrl: Return 404 NotFound
        fe_ctrl -->> list_view: Redirect to History list (TempData["Error"])
        list_view -->> act: Display "Transaction not found" message
        deactivate list_view
    else Database Query Success
        ctx -> dto++: Call TransactionDetailDto(TransactionId, Status, BuyerName, CourseTitle, GrossAmount, ...)
        dto -->> ctx--: Return TransactionDetailDto object
        
        ctx -->> repo--: Return TransactionDetailDto
        repo -->> sv--: Return TransactionDetailDto
        sv -->> be_ctrl--: Return TransactionDetailDto
        
        be_ctrl -->> fe_ctrl--: Return 200 OK (ApiResponse<TransactionDetailDto>)
        
        fe_ctrl -> vm++: Call TransactionDetailVM(TransactionId, Status, BuyerName, CourseTitle, GrossAmount, ...)
        vm -->> fe_ctrl--: Return TransactionDetailVM object
        
        fe_ctrl -->> view++: Return View(TransactionDetailVM)
        deactivate fe_ctrl
        
        view -> view++: Render transaction receipt
        view--
        
        alt Refunded Transaction
            view -->> act: Display refund notification banner (Reason, Admin Note)
        else Normal Transaction
            view -->> act--: Display detailed financial breakdown, purchaser info, and course details
        end
    end
    deactivate ctx
    deactivate repo
    deactivate sv
    deactivate be_ctrl
end

deactivate view
deactivate act

@enduml
