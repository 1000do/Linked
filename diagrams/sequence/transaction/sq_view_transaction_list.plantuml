@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Transaction List
actor User as act

participant "Transaction/History.cshtml" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "TransactionController" as be_ctrl <<backend controller>>
participant ":TransactionService" as sv
participant ":TransactionRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Access Purchase History page
view->fe_ctrl++: Send GET /Transaction/History

fe_ctrl->be_ctrl++: Send GET /api/transactions/my (with Bearer Token)

be_ctrl->be_ctrl++: Authorize Student role
be_ctrl--

alt [Unauthorized]
    be_ctrl-->>fe_ctrl: Return statusCode 401 (Unauthorized)
    fe_ctrl-->>view: Redirect to Account/Login
    view-->>act: Display Login page
else [Authorized]
    be_ctrl->sv++: Call GetUserTransactionsAsync(userId, page, pageSize, ...)
    sv->repo++: Call GetUserTransactionsAsync(userId, page, pageSize, ...)
    repo->ctx++: Query user's active transactions
    ctx->db++: Execute SELECT query
    db-->>ctx--: Return data
    ctx-->>repo--: Return data
    repo-->>sv--: Return data
    
    sv->sv++: Map to PagedResult
    sv--
    sv-->>be_ctrl--: Return DTO list
    be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with JSON data
    
    fe_ctrl->fe_ctrl++: Deserialize response
    fe_ctrl--
    fe_ctrl-->>view--: Return View
    view-->>act--: Display purchase history list
end
@enduml
