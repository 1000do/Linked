@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Set Transfer Rate

actor "Admin" as act
participant "AdminFinanceDashboard" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "AdminFinanceController" as fe_ctrl <<frontend controller>>
participant "AdminFinanceController" as be_ctrl <<backend controller>>
participant ":IAdminFinanceService" as finance_sv
participant ":ISystemConfigRepository" as config_repo
participant ":IInstructorRepository" as instructor_repo
participant ":INotificationService" as noti_sv
participant ":AppDbContext" as ctx
database Database as db

act -> view++: Enter rate and click "Save Rate" button
view -->> act: Display "Confirm Rate Change" dialog
act -> view: Click "Save Rate" confirmation button

group opt [Invalid Split Rate]
    view -->> act: Display "Invalid Split Rate" error dialog
end

view -> fe_ctrl++: POST /AdminFinance/SetTransferRate

fe_ctrl -> fe_ctrl++: Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view++: Redirect to LoginPage
    login_view -->> act--: Display login form
else Unauthorized Access
    fe_ctrl -->> error_view++: Redirect to ErrorPage
    error_view -->> act--: Display error message
else Valid actor's authentication and authorization
    fe_ctrl -> be_ctrl++: POST /api/admin/finance/transfer-rate

    be_ctrl -> finance_sv++: SetTransferRateAsync(rate)

    finance_sv -> finance_sv++: Validate rate (between 30% and 95%)
    finance_sv--

    alt Invalid Rate
        finance_sv -->> be_ctrl: throw InvalidOperationException
        be_ctrl -->> fe_ctrl: Return statusCode 400
        fe_ctrl -->> view: Return redirect to Index with TempData error
        view -->> act: Display error notification
    else Valid Rate
        finance_sv -> config_repo++: UpsertConfigAsync(TransferRateKey, rate, description)
        config_repo -> ctx++: SystemConfigs.FirstOrDefaultAsync(...) \n(or Add/Update)
        ctx -> db++: Execute query
        db -->> ctx--: Return data
        ctx -->> config_repo--: Return result
        config_repo -->> finance_sv--: Return rows affected

        finance_sv -> instructor_repo++: GetInstructorsWithStripeAsync()
        instructor_repo -> ctx++: Instructors.Where(...).ToListAsync()
        ctx -> db++: Execute query
        db -->> ctx--: Return data
        ctx -->> instructor_repo--: Return List<Instructor>
        instructor_repo -->> finance_sv--: Return List<Instructor>

        group opt [For each Instructor with Stripe]
            finance_sv -> noti_sv++: SendNotificationAsync(InstructorId, title, content, link)
            noti_sv -->> finance_sv--: Return result
        end

        finance_sv -->> be_ctrl--: Return result
        be_ctrl -->> fe_ctrl--: Return statusCode 200

        fe_ctrl -->> view--: Return redirect to Index
        view -->> act--: Refresh dashboard view displaying the newly saved rate
    end
end

@enduml
