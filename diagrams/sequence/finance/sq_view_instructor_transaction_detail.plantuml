@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Instructor's Transaction History Detail
actor Instructor as act

participant "Transaction/InstructorDetail.cshtml" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "TransactionController" as be_ctrl <<backend controller>>
participant ":TransactionService" as sv
participant ":TransactionRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Click "View Details" button on a transaction row
view->fe_ctrl++: Send GET /Transaction/InstructorDetail/{id}

fe_ctrl->be_ctrl++: Send GET /api/transactions/{id} (with Bearer Token)

be_ctrl->sv++: Call GetTransactionDetailAsync(id)
sv->repo++: Call GetTransactionDetailAsync(id)

repo->ctx++: Query Transaction details
ctx->db++: Execute SELECT query
db-->>ctx--: Return Transaction entity with related data
ctx-->>repo--: Return data

repo-->>sv--: Return TransactionDetailDto
sv-->>be_ctrl--: Return TransactionDetailDto
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with Transaction detail JSON

fe_ctrl-->>view--: Return View(model)
view->view++: Render transaction breakdown
view--
view-->>act--: Display transaction detail modal / page
@enduml
