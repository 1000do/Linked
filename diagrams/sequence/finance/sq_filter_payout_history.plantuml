@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Filter Payout History
actor Instructor as act

participant "Transaction/Instructor.cshtml" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "InstructorController" as be_ctrl <<backend controller>>
participant ":InstructorService" as sv
participant ":InstructorRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Enter payout keyword, select status, and click "Filter"
view->fe_ctrl++: Send GET /Transaction/Instructor?tab=po&payoutKeyword=Stripe&payoutStatus=succeeded&payoutPage=1

fe_ctrl->be_ctrl++: Send GET /api/instructor/payouts?page=1&pageSize=20&keyword=Stripe&status=succeeded&year=... (with Bearer Token)

be_ctrl->sv++: Call GetPayoutsAsync(..., keyword: "Stripe", status: "succeeded", ...)
sv->repo++: Call GetPayoutsAsync(..., keyword: "Stripe", status: "succeeded", ...)

repo->repo++: Construct EF Core IQueryable for InstructorPayouts
repo--

alt [keyword is not null or empty]
    repo->repo++: Apply .Where(p => p.CourseTitle.Contains(keyword) || p.StripeTransferId.Contains(keyword))
    repo--
end

alt [status is not null or empty]
    repo->repo++: Apply .Where(p => p.PayoutStatus == status)
    repo--
end

repo->ctx++: Query InstructorPayouts
ctx->db++: Execute filtered query with Skip() and Take()
db-->>ctx--: Return filtered payouts list and total count
ctx-->>repo--: Return payouts list and count

repo-->>sv--: Return PagedResult<InstructorPayoutDto>
sv-->>be_ctrl--: Return PagedResult<InstructorPayoutDto>
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with filtered Payouts JSON

fe_ctrl-->>view--: Return View(vm)
view->view++: Re-render Payout History table
view--
view-->>act--: Display payout list matching criteria
@enduml
