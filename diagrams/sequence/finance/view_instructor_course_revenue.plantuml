@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Instructor's Course Revenue
actor Instructor as act

participant "Instructor.cshtml" as view
participant "TransactionControllerFE" as fe_ctrl
participant "TransactionControllerBE" as be_ctrl
participant ":AdminFinanceService" as sv
participant ":AdminFinanceRepository" as repo
database Database as db

act++
act->view++: Click "Course Revenues" tab
view->fe_ctrl++: Send GET /Transaction/Instructor?tab=cr&courseSortBy=sales_desc

fe_ctrl->be_ctrl++: Send GET /api/transactions/instructor/course-revenues?year=...&month=... (with Bearer Token)

be_ctrl->be_ctrl++: Extract instructorId from claims
be_ctrl--

be_ctrl->sv++: Call GetInstructorCourseRevenuesByInstructorAsync(instructorId, year, month)
sv->repo++: Call GetInstructorCourseRevenuesByInstructorAsync(instructorId, year, month)

repo->db++: Query Courses and aggregate Transactions:\n- Sales count\n- Monthly, Previous Month, Yearly, and Lifetime Revenues
db-->>repo--: Return aggregated course revenues list

repo-->>sv--: Return List<InstructorCourseRevenueResponse>
sv-->>be_ctrl--: Return List<InstructorCourseRevenueResponse>
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with course revenues JSON

fe_ctrl->fe_ctrl++: Sort revenues list based on courseSortBy ("sales_desc")
fe_ctrl--

fe_ctrl-->>view--: Return View(vm) with sorted CourseRevenues list
view->view++: Render Course Revenues table:\nCourse Title, Sales Count, Monthly, Yearly, and Lifetime Revenue
view--
view-->>act--: Display course-by-course revenue analytics
@enduml
