@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Report a Course

actor User as act

participant "ReportModal" as view
participant "ReportController" as fe_ctrl
participant "ReportController" as be_ctrl
participant ":ReportService" as sv
participant ":CourseReport" as ett_r
participant ":CourseRepository" as c_repo
participant ":EnrollmentRepository" as e_repo
participant ":ReportRepository" as r_repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Select reason & input description
act->view: Click "Submit Report" button
view->view++: Validate input (reason not empty)
view--
group opt [Reason is empty]
    view-->>act: Display client validation errors
end

view->fe_ctrl++: Send POST request (AJAX) to Report/ReportCourse (JSON body)

fe_ctrl->be_ctrl++: Send POST request to /api/report/courses (with AccessToken)

be_ctrl->be_ctrl++: GetUserId() from Token Claims
be_ctrl--

group opt [userId == null]
    be_ctrl-->>fe_ctrl: Return statusCode 401 (Unauthorized)
    fe_ctrl-->>view: Return JSON { success = false, message = "Unauthorized" }
    view-->>act: Display unauthorized message
end

be_ctrl->be_ctrl++: IsInstructor() checking claims
be_ctrl--

be_ctrl->sv++: Call CreateCourseReportAsync(userId, request, isInstructor)

sv->c_repo++: Call GetByIdAsync(courseId)
c_repo->ctx++: Fetch Course by ID
ctx->db++: Query Courses table
db-->>ctx--: Return database record
ctx-->>c_repo--: Return Course entity
c_repo-->>sv--: Return Course entity

sv->sv++: Check course != null
sv--
group opt [course == null]
    sv-->>be_ctrl: Throw InvalidOperationException("Course not found.")
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return JSON { success = false }
    view-->>act: Display error message
end

sv->sv++: Check CourseStatus is "pending" or "under_review"
sv--
group opt [Course is pending / under review]
    sv-->>be_ctrl: Throw InvalidOperationException
    be_ctrl-->>fe_ctrl: Return statusCode 400
    fe_ctrl-->>view: Return JSON { success = false }
    view-->>act: Display error message
end

sv->sv++: Check if Reporter owns the course (course.InstructorId == reporterId)
sv--
group opt [Reporter owns the course]
    sv-->>be_ctrl: Throw InvalidOperationException
    be_ctrl-->>fe_ctrl: Return statusCode 400
    fe_ctrl-->>view: Return JSON { success = false }
    view-->>act: Display error message
end

alt !isInstructor
    sv->e_repo++: Call GetEnrollmentWithProgressAsync(reporterId, courseId)
    e_repo->ctx++: Fetch enrollment details
    ctx->db++: Query Enrollments table
    db-->>ctx--: Return database record
    ctx-->>e_repo--: Return Enrollment entity
    e_repo-->>sv--: Return Enrollment entity
    
    sv->sv++: Check enrollment != null
    sv--
    group opt [enrollment == null]
        sv-->>be_ctrl: Throw InvalidOperationException
        be_ctrl-->>fe_ctrl: Return statusCode 400
        fe_ctrl-->>view: Return JSON { success = false }
        view-->>act: Display error message
    end
end

sv->r_repo++: Call GetPendingCourseReportAsync(reporterId, courseId)
r_repo->ctx++: Query pending course report by reporter and course ID
ctx->db++: Query CourseReports table
db-->>ctx--: Return database record
ctx-->>r_repo--: Return CourseReport entity
r_repo-->>sv--: Return CourseReport entity

sv->sv++: Check existing != null
sv--
group opt [existing != null]
    sv-->>be_ctrl: Throw InvalidOperationException
    be_ctrl-->>fe_ctrl: Return statusCode 400
    fe_ctrl-->>view: Return JSON { success = false }
    view-->>act: Display error message
end

sv->ett_r++: Call CourseReport()
ett_r-->>sv--: Return CourseReport entity

sv->r_repo++: Call AddCourseReportAsync(report)
r_repo->ctx++: Add report to context
ctx-->>r_repo--: Done
r_repo-->>sv--: Done

sv->r_repo++: Call SaveChangesAsync()
r_repo->ctx++: Call SaveChangesAsync()
ctx->db++: Save changes to Database
db-->>ctx--: Return numberOfRowsAffected
ctx-->>r_repo--: Return numberOfRowsAffected
r_repo-->>sv--: Return numberOfRowsAffected

sv->sv++: Check numberOfRowsAffected > 0
sv--

alt numberOfRowsAffected > 0
    sv-->>be_ctrl: Return Success
    be_ctrl-->>fe_ctrl: Return statusCode 200 (Success)
    fe_ctrl-->>view: Return JSON { success = true, message = "..." }
    view-->>act: Close modal and display success alert
else numberOfRowsAffected == 0
    sv-->>be_ctrl--: Throw InvalidOperationException
    be_ctrl-->>fe_ctrl--: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view--: Return JSON { success = false }
    view-->>act--: Display error message
end

@enduml
