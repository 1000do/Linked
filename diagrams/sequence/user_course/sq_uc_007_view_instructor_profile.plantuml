@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Instructor Profile

actor Guest as act
participant "InstructorProfilePage" as view
participant "InstructorController" as fe_ctrl <<frontend controller>>
participant "InstructorController" as be_ctrl <<backend controller>>
participant ":InstructorService" as sv
participant ":InstructorPublicProfileDto" as res
participant ":IInstructorRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++: Click on instructor name
view -> fe_ctrl++: GET /Instructor/Profile/{id}
fe_ctrl -> be_ctrl++: GET /api/instructor/profile/{id}
be_ctrl -> sv++: Call GetPublicProfileAsync(id)

sv -> repo++: Call GetByIdWithNavigationAsync(id)
repo -> ctx++: Execute query
ctx -> db++: Fetch instructor data
db -->> ctx--: Return query results
ctx -->> repo--: Return instructor entity
repo -->> sv--: Return instructor entity

alt Instructor == null OR ApprovalStatus != Approved
    sv -->> be_ctrl: Return null
    be_ctrl -->> fe_ctrl: Return statusCode 404
    fe_ctrl -->> view: Redirect to HomePage / Show NotFound
    view -->> act: Display NotFound message
else Instructor Found and Approved
    sv -> repo++: Call GetStatsAsync(id)
    repo -> ctx++: Execute query
    ctx -> db++: Fetch stats
    db -->> ctx--: Return query results
    ctx -->> repo--: Return stats
    repo -->> sv--: Return instructor stats
    
    sv -> repo++: Call CountActiveCoursesAsync(id)
    repo -> ctx++: Execute query
    ctx -> db++: Count active courses
    db -->> ctx--: Return query results
    ctx -->> repo--: Return count
    repo -->> sv--: Return active courses count
    
    sv -> sv++: Select published courses
    sv--
    

    sv -> res++: Call InstructorPublicProfileDto()
    res -->> sv--: Return InstructorPublicProfileDto object
    
    sv -->> be_ctrl--: Return InstructorPublicProfileDto object
    be_ctrl -->> fe_ctrl--: Return statusCode 200
    fe_ctrl -->> view--: Return View(InstructorPublicProfileViewModel)
    view -->> act--: Display instructor profile
end