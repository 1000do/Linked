@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Add Personal Reviews

actor User as act
participant "CourseDetailPage" as view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "ReviewController" as be_ctrl <<backend controller>>
participant ":ReviewService" as sv
participant ":IUserLockoutRepository" as lockout_repo
participant ":ICourseRepository" as course_repo
participant ":IEnrollmentRepository" as enroll_repo
participant ":IReviewRepository" as repo
participant ":INotificationService" as notif_sv
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++: Click "Write a Review" and Submit
view -> fe_ctrl++: POST /Course/SubmitReview (ReviewRequest)

fe_ctrl -> fe_ctrl++: Validate actor's authentication and authorization
fe_ctrl--

alt Valid actor's authentication and authorization
    fe_ctrl -> be_ctrl++: POST /api/review/submit
    be_ctrl -> sv++: Call SubmitReviewAsync(userId, request, requireCompletion)
    
    sv -> lockout_repo++: Call GetActiveLockoutAsync(userId, "review")
    lockout_repo -> ctx++: Execute query
    ctx -> db++: Fetch lockout
    db -->> ctx--: Return query results
    ctx -->> lockout_repo--: Return lockout entity
    lockout_repo -->> sv--: Return lockout entity
    
    alt Active Lockout Exists
        sv -->> be_ctrl: throw BadRequestException
        be_ctrl -->> fe_ctrl: Return statusCode 400
        fe_ctrl -->> view: Return JSON (success=false)
        view -->> act: Display restriction message
    else No Active Lockout
        sv -> course_repo++: Call IsOwnerAsync(userId, courseId)
        course_repo -> ctx++: Execute query
        ctx -> db++: Check owner
        db -->> ctx--: Return query results
        ctx -->> course_repo--: Return IsOwner flag
        course_repo -->> sv--: Return IsOwner flag
        
        alt Is Owner
            sv -> enroll_repo++: Call GetEnrollmentWithProgressAsync(userId, courseId)
            enroll_repo -> ctx++: Execute query
            ctx -> db++: Fetch enrollment
            db -->> ctx--: Return query results
            ctx -->> enroll_repo--: Return enrollment entity
            enroll_repo -->> sv--: Return enrollment entity
            

        else Not Owner
            sv -> enroll_repo++: Call GetEnrollmentWithProgressAsync(userId, courseId)
            enroll_repo -> ctx++: Execute query
            ctx -> db++: Fetch enrollment
            db -->> ctx--: Return query results
            ctx -->> enroll_repo--: Return enrollment entity
            enroll_repo -->> sv--: Return enrollment entity
            
            alt Enrollment == null OR (requireCompletion == true AND Not Completed)
                sv -->> be_ctrl: throw InvalidOperationException
                be_ctrl -->> fe_ctrl: Return statusCode 400
                fe_ctrl -->> view: Return JSON (success=false)
                view -->> act: Display requirement error message
            else Enrollment Valid
                opt requireCompletion == false
                    sv -> enroll_repo++: Call GetCompletedMaterialCountAsync(enrollmentId)
                    enroll_repo -->> sv--: Return learnedCount
                end
            end
        end
        
        alt LessonId HasValue
            sv -> repo++: Call AddLessonReviewAsync(newLessonReview)
            repo -> ctx++: Add entity
            ctx -->> repo--: Return
            repo -->> sv--: Return result
        else CourseId Only
            sv -> repo++: Call AddCourseReviewAsync(newCourseReview)
            repo -> ctx++: Add entity
            ctx -->> repo--: Return
            repo -->> sv--: Return result
        end
        
        sv -> repo++: Call SaveChangesAsync()
        repo -> ctx++: Save changes to database
        ctx -> db++: Insert Review
        
        alt Database Save Failure
            db -->> ctx: throw DbUpdateException
            ctx -->> repo: throw DbUpdateException
            repo -->> sv: throw DbUpdateException
            sv -->> be_ctrl: throw DbUpdateException
            be_ctrl -->> fe_ctrl: Return statusCode 500
            fe_ctrl -->> view: Return JSON (success=false)
            view -->> act: Display server error message
        else Database Save Success
            db -->> ctx--: Return returnCode
            ctx -->> repo--: Return numberOfRowsAffected
            repo -->> sv--: Return numberOfRowsAffected
            
            sv -->> be_ctrl--: Return result
            be_ctrl -->> fe_ctrl--: Return statusCode 200
            fe_ctrl -->> view--: Return JSON (success=true)
            view -->> act--: Display review success message
        end
    end
end