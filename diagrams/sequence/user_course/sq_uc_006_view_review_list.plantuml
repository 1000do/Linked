@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Review List

actor Guest as act
participant "CourseDetailPage" as view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "ReviewController" as be_ctrl <<backend controller>>
participant ":ReviewService" as sv
participant ":ReviewResponse" as res
participant ":IReviewRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++: Scroll to Reviews section
view -> fe_ctrl++: GET /Course/GetReviews?id={courseId}
fe_ctrl -> be_ctrl++: GET /api/reviews/course/{courseId}
be_ctrl -> sv++: Call GetCourseReviewsAsync(courseId, page, pageSize, starFilter)

sv -> repo++: Call GetCourseReviewsWithDetailsAsync(courseId, page, pageSize, starFilter)
repo -> ctx++: Execute query
ctx -> db++: Fetch reviews
db -->> ctx--: Return query results
ctx -->> repo--: Return review entities and totalCount
repo -->> sv--: Return (reviews, totalCount)

sv -> res++: Call ReviewResponse() (mapping)
res -->> sv--: Return List<ReviewResponse>

sv -->> be_ctrl--: Return PagedResult<ReviewResponse>
be_ctrl -->> fe_ctrl--: Return statusCode 200
fe_ctrl -->> view--: Return View(PagedResult<ReviewResponse>)
view -->> act--: Display review list