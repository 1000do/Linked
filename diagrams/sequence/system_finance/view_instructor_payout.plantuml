@startuml view_instructor_payout
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Instructor Payout
actor Admin as act

participant "SystemFinanceView" as view
participant "AdminFinanceController" as be_ctrl
participant ":AdminFinanceService" as sv
participant ":AdminFinanceRepository" as repo
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++: Access "Instructor Payouts" page\n(optionally select year / month filter)
view->be_ctrl++: GET /api/admin/finance/payouts?year={y}&month={m}&page={p}&pageSize={ps}
be_ctrl->sv++: GetInstructorPayoutsAsync(year, month, page, pageSize)
sv->repo++: GetPayoutDetailsAsync(year, month, page, pageSize)
repo->ctx++: Query InstructorPayouts with Includes\n(Transaction, OrderItem, Course,\nInstructor, InstructorNavigation)\nfiltered by year/month, ordered by TransactionCreatedAt DESC
ctx->db++: Execute SELECT with JOINs
db-->>ctx--: Return payout rows
ctx-->>repo--: Return List<InstructorPayout>
repo->repo: Project to List<PayoutDetailProjection>
repo-->>sv--: Return (Items: List<PayoutDetailProjection>, TotalCount)
sv->sv: Map each projection to PayoutDetailResponse:\n- Calculate StripeFee (2.9% + $0.30)\n- Calculate PlatformReceived = Amount - Fee - InstructorReceived
sv-->>be_ctrl--: Return PagedResult<PayoutDetailResponse>
be_ctrl-->>view--: Return status 200 with ApiResponse<PagedResult<PayoutDetailResponse>>
view-->>act--: Render Instructor Payout table\n(InstructorName, CourseTitle, Amount,\nInstructorReceived, PlatformReceived,\nPayoutStatus, PayoutDate)
@enduml
