@startuml ViewCourseModerationList
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Course Moderation List
actor Staff as act

participant "AdminModerationCoursesView" as view
participant "AdminModerationController" as fe_ctrl
participant "ApiClient" as api_client
participant "CoursePublicController" as pub_ctrl
participant "AdminModerationController" as be_ctrl
participant ":CourseModerationService" as sv
participant ":CourseRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act -> fe_ctrl++: Access Course Moderation Page (/AdminModeration/Courses)

fe_ctrl -> api_client++: Send GET request to /api/public/categories
api_client -> pub_ctrl++: Send GET request to /api/public/categories
pub_ctrl -> ctx++: Call GetCategoriesAsync()
ctx -> db++: Query all Categories
db -->> ctx--: Return categories
ctx -->> pub_ctrl--: Return categories list
pub_ctrl -->> api_client--: Return HTTP 200 (Ok) with categories JSON data
api_client -->> fe_ctrl--: Return HTTP 200 (Ok) response

fe_ctrl -> api_client++: Send GET request to /api/admin/moderation/courses/pending?...
api_client -> be_ctrl++: Send GET request to /api/admin/moderation/courses/pending?...

be_ctrl -> sv++: Call GetPendingCoursesAsync(filter)
sv -> repo++: Call GetPendingCoursesModerationAsync(filter)
repo -> ctx++: Call GetPendingCoursesModerationAsync(filter)
ctx -> db++: Query pending/under-review courses
db -->> ctx--: Return courses list
ctx -->> repo--: Return courses list
repo -->> sv--: Return courses list

sv -> sv++: Calculate UrgencyLevel & UrgencyColor for each course
sv--

sv -->> be_ctrl--: Return PagedResult<CourseModerationDto>
be_ctrl -->> api_client--: Return HTTP 200 (Ok) with pending courses JSON

alt Pending Courses API Call Successful
    api_client -->> fe_ctrl: Return HTTP 200 (Ok) response
    deactivate api_client
    
    fe_ctrl -> api_client++: Send GET request to /api/admin/moderation/courses/stats
    api_client -> be_ctrl++: Send GET request to /api/admin/moderation/courses/stats
    be_ctrl -> sv++: Call GetCourseModerationStatsAsync()
    sv -> repo++: Call GetCourseModerationStatsAsync()
    repo -> ctx++: Call GetCourseModerationStatsAsync()
    ctx -> db++: Query counts (pending and resolved today)
    db -->> ctx--: Return counts
    ctx -->> repo--: Return counts
    repo -->> sv--: Return counts
    sv -->> be_ctrl--: Return CourseModerationStatsDto
    be_ctrl -->> api_client--: Return HTTP 200 (Ok) with stats JSON
    api_client -->> fe_ctrl: Return HTTP 200 (Ok) response
    deactivate api_client
    
    fe_ctrl -> view++: Render AdminModeration/Courses View with PagedResult and Stats
    deactivate fe_ctrl
    view -->> act: Display Course Moderation List and statistics
    deactivate view
else Pending Courses API Call Failed
    api_client -->> fe_ctrl: Return HTTP 400/500 Error response
    deactivate api_client
    
    fe_ctrl -> view++: Render AdminModeration/Courses View with empty PagedResult and 0 stats
    deactivate fe_ctrl
    view -->> act: Display empty moderation list
    deactivate view
end

@enduml
