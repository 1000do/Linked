@startuml FlagCourseViolation
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Flag Course for Content Violation
actor Staff as act

participant "AdminModerationCoursesView" as view
participant "AdminModerationController" as be_ctrl
participant ":CourseModerationService" as sv
participant ":CourseRepository" as repo
participant ":AppDbContext" as ctx
participant ":NotificationService" as notif_sv
participant ":RedisService" as redis_sv
database Database as db

act++
act -> view++: Click "Flag Violation" button on a course row
view -> view++: Display Swal warning dialog with text input for reason
view--

act -> view++: Enter violation reason and click "Confirm Flag" (or cancel)
alt Cancelled
    view -->> act: Close dialog without changes
else Confirmed
    view -> view++: Swal.showLoading()
    view--
    view -> be_ctrl++: Send POST request to /AdminModeration/FlagCourse with body (id, reason)
    
    be_ctrl -> sv++: Call FlagCourseAsync(id, reason)
    
    sv -> repo++: Call GetByIdAsync(id)
    repo -> ctx++: Get course by ID
    ctx -> db++: Select Course
    db -->> ctx--: Return Course
    ctx -->> repo--: Return Course
    repo -->> sv--: Return Course
    
    alt Course not found
        sv -->> be_ctrl: Return false
        be_ctrl -->> view: Return JSON { success = false }
        view -->> act: Display error notification
    else Course found
        sv -> sv++: Increment course flag count (currentFlags = flags + 1)
        sv -> sv++: Set course status to "Flagged" and format ModerationFeedback
        sv--
        sv--
        
        sv -> repo: Call Update(course)
        
        sv -> repo++: Call SaveChangesAsync()
        repo -> ctx++: Call SaveChangesAsync()
        ctx -> db++: Save changes (Status and flag count)
        db -->> ctx--: Return rows affected (rowsFlag)
        ctx -->> repo--: Return rows affected
        repo -->> sv--: Return rows affected
        
        alt rowsFlag <= 0
            sv -->> be_ctrl: Throw InvalidOperationException
            be_ctrl -->> view: Return JSON { success = false }
            view -->> act: Display error notification
        else rowsFlag > 0
            opt course.InstructorId is present
                alt currentFlags = 1
                    
                else currentFlags = 2
                    
                else currentFlags >= 3
                    
                    sv -> sv++: Set course status to "archived"
                    sv--
                    sv -> repo: Call Update(course)
                    sv -> repo++: Call SaveChangesAsync()
                    repo -> ctx++: Call SaveChangesAsync()
                    ctx -> db++: Save archived status to Database
                    db -->> ctx--: Return rows affected (rowsArchive1)
                    ctx -->> repo--: Return rows affected
                    repo -->> sv--: Return rows affected
                    
                    opt rowsArchive1 <= 0
                        sv -->> be_ctrl: Throw InvalidOperationException
                    end
                end
                
                sv -> notif_sv++: Call SendNotificationAsync(instructorId, subject, message, link)
                notif_sv--
            end
            
            sv -> redis_sv++: Call RemoveCacheAsync(courseDetailCacheKey)
            redis_sv--
            
            sv -->> be_ctrl--: Return true
            be_ctrl -->> view--: Return JSON { success = true }
            
            view -> view++: dimCourseRowInDOM(id) (make row transparent)
            view -> view++: triggerAjaxFetch() to update table & stats in background
            view--
            view--
            
            view -->> act--: Display success notification ("Course Flagged")
        end
    end
end
deactivate view

@enduml
