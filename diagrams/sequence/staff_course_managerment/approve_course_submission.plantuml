@startuml ApproveCourseSubmission
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Approve Course Submission
actor Staff as act

participant "AdminModerationCoursesView" as view
participant "AdminModerationController" as be_ctrl
participant ":CourseModerationService" as sv
participant ":CourseRepository" as repo
participant ":MaterialRepository" as mat_repo
participant ":LessonRepository" as less_repo
participant ":EnrollmentRepository" as enroll_repo
participant ":AppDbContext" as ctx
participant ":NotificationService" as notif_sv
participant ":RedisService" as redis_sv
database Database as db

act++
act -> view++: Click "Approve" button on a course row
view -> view++: Display Swal input dialog (optional feedback message)
view--

act -> view++: Enter feedback and click "Approve & Publish" (or cancel)
alt Cancelled
    view -->> act: Close dialog without changes
else Confirmed
    view -> view++: Swal.showLoading()
    view--
    view -> be_ctrl++: Send POST request to /AdminModeration/ApproveCourse/{id} with feedback
    
    be_ctrl -> sv++: Call ApproveCourseAsync(id, feedback)
    
    sv -> repo++: Call GetByIdAsync(id)
    repo -> ctx++: Get course by ID
    ctx -> db++: Select Course
    db -->> ctx--: Return Course
    ctx -->> repo--: Return Course
    repo -->> sv--: Return Course
    
    alt Course not found
        sv -->> be_ctrl: Return false
        be_ctrl -->> view: Return JSON { success = false }
        view -->> act: Display error notification
    else Course found
        sv -> sv++: Update course status to "published" and set approval timestamps
        sv--
        
        sv -> mat_repo++: Call GetByCourseIdAsync(id)
        mat_repo -> ctx++: Query materials for course
        ctx -> db++: Select materials
        db -->> ctx--: Return materials
        ctx -->> mat_repo--: Return materials
        mat_repo -->> sv--: Return materials
        
        opt Materials exist
            loop Each material
                sv -> mat_repo: Call Update(material)
            end
        end
        
        sv -> less_repo++: Call GetByCourseIdAsync(id)
        less_repo -> ctx++: Query lessons for course
        ctx -> db++: Select lessons
        db -->> ctx--: Return lessons
        ctx -->> less_repo--: Return lessons
        less_repo -->> sv--: Return lessons
        
        opt Lessons exist
            loop Each lesson
                sv -> less_repo: Call Update(lesson)
            end
        end
        
        sv -> repo: Call Update(course)
        
        sv -> repo++: Call SaveChangesAsync()
        repo -> ctx++: Call SaveChangesAsync()
        ctx -> db++: Save updates (Course, Materials, Lessons)
        db -->> ctx--: Return rows affected (rowsApprove)
        ctx -->> repo--: Return rows affected
        repo -->> sv--: Return rows affected
        
        alt rowsApprove <= 0
            sv -->> be_ctrl: Throw InvalidOperationException
            be_ctrl -->> view: Return JSON { success = false }
            view -->> act: Display error notification
        else rowsApprove > 0
            opt course.InstructorId is present
                sv -> notif_sv++: Call SendNotificationAsync(instructorId, title, content, link)
                notif_sv--
                
                sv -> enroll_repo++: Call GetEnrolledUserIdsAsync(courseId)
                enroll_repo -> ctx++: Query enrolled user IDs
                ctx -> db++: Select enrolled student IDs
                db -->> ctx--: Return student IDs
                ctx -->> enroll_repo--: Return student IDs
                enroll_repo -->> sv--: Return student IDs
                
                opt Students enrolled
                    sv -> notif_sv++: Call SendBulkNotificationsAsync(studentNotifications)
                    notif_sv--
                end
            end
            
            sv -> redis_sv++: Call RemoveCacheAsync(courseDetailCacheKey)
            redis_sv--
            
            sv -->> be_ctrl--: Return true
            be_ctrl -->> view--: Return JSON { success = true }
            
            view -> view++: dimCourseRowInDOM(id) (make row transparent)
            view -> view++: triggerAjaxFetch() to update table & stats in background
            view--
            view--
            
            view -->> act--: Display success notification ("Course Approved!")
        end
    end
end
deactivate view

@enduml
