@startuml view_course_review_reports
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View List of Course Review Reports
actor Staff as act

participant "CourseReviewReportListView" as view
participant "AdminModerationController" as be_ctrl
participant ":ReportService" as sv
participant ":ReportRepository" as repo
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++: Access "Course Review Reports" page
view->be_ctrl++: GET /admin/moderation/reports/course-reviews?page={page}&pageSize={size}
be_ctrl->sv++: GetAllCourseReviewReportsAsync(status, page, pageSize)
sv->repo++: GetAllCourseReviewReportsAsync(status, page, pageSize)
repo->ctx++: Query CourseReviewReport entities
ctx->db++: Execute SQL query
db-->>ctx: Return result set
ctx-->>repo: (reports, totalCount)
repo-->>sv: (reports, totalCount)
sv-->>be_ctrl: PagedResult<CourseReviewReportDetailResponse>
be_ctrl-->>view: JSON payload
view-->>act: Render list UI
act--
@enduml
