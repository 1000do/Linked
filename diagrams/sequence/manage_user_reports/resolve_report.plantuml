@startuml resolve_report
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Resolve Report
actor Staff as act

participant "Reports" as view
participant "AdminModerationController" as be_ctrl
participant ":ReportService" as sv
participant ":ReportRepository" as repo
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++: Click "Moderate" on a report row
view-->>act: Display moderation modal\n(status, resolutionNote, removeContent)
act->view: Fill in decision and click "Submit Decision"

group alt [Resolve Course Report]
    view->be_ctrl++: PATCH /api/admin/moderation/reports/courses/{reportId}
    be_ctrl->be_ctrl++: GetUserId() from JWT claims
    be_ctrl--
    be_ctrl->sv++: ResolveCourseReportAsync(reportId, resolverId, request)
    sv->repo++: GetCourseReportByIdAsync(reportId)
    repo->ctx++: Query CourseReport by id
    ctx->db++: Execute SQL query
    db-->>ctx: Return result
    ctx-->>repo: Return CourseReport
    repo-->>sv: Return CourseReport
    sv->sv++: Check escalation status & resolver role
    sv--
    sv->sv++: Update report fields\n(status, resolutionNote, resolverId, resolvedAt)
    sv--
    sv->sv++: GetByIdAsync(courseId) & apply flag penalty\n(reject / archive course, notify instructor)
    sv--
    sv->repo++: UpdateCourseReport(report)
    repo-->>sv--: void
    sv->repo++: SaveChangesAsync()
    repo->ctx++: SaveChangesAsync()
    ctx->db++: Save changes to Database
    db-->>ctx: Return numberOfRowsAffected
    ctx-->>repo: Return numberOfRowsAffected
    repo-->>sv: Return numberOfRowsAffected
    sv->sv++: Check numberOfRowsAffected > 0
    sv--
    alt numberOfRowsAffected > 0
        sv->sv++: SendNotificationAsync() to reporter
        sv--
        sv-->>be_ctrl--: Return true
        be_ctrl-->>view--: Return statusCode 200
        view-->>act: Display success message, reload list
    else numberOfRowsAffected = 0
        sv-->>be_ctrl--: throw InvalidOperationException
        be_ctrl-->>view--: Return statusCode 400
        view-->>act: Display error message
    end
else [Resolve Course Review Report]
    view->be_ctrl++: PATCH /api/admin/moderation/reports/course-reviews/{reportId}
    be_ctrl->be_ctrl++: GetUserId() from JWT claims
    be_ctrl--
    be_ctrl->sv++: ResolveCourseReviewReportAsync(reportId, resolverId, request)
    sv->repo++: GetCourseReviewReportByIdAsync(reportId)
    repo->ctx++: Query CourseReviewReport by id
    ctx->db++: Execute SQL query
    db-->>ctx: Return result
    ctx-->>repo: Return CourseReviewReport
    repo-->>sv: Return CourseReviewReport
    sv->sv++: Update report fields & soft-remove review if RemoveContent=true
    sv--
    sv->repo++: UpdateCourseReviewReport(report)
    repo-->>sv--: void
    sv->repo++: SaveChangesAsync()
    repo->ctx++: SaveChangesAsync()
    ctx->db++: Save changes to Database
    db-->>ctx: Return numberOfRowsAffected
    ctx-->>repo: Return numberOfRowsAffected
    repo-->>sv: Return numberOfRowsAffected
    sv->sv++: Check numberOfRowsAffected > 0
    sv--
    alt numberOfRowsAffected > 0
        sv->sv++: SendNotificationAsync() to reporter
        sv--
        sv-->>be_ctrl--: Return true
        be_ctrl-->>view--: Return statusCode 200
        view-->>act: Display success message, reload list
    else numberOfRowsAffected = 0
        sv-->>be_ctrl--: throw InvalidOperationException
        be_ctrl-->>view--: Return statusCode 400
        view-->>act: Display error message
    end
else [Resolve Lesson Review Report]
    view->be_ctrl++: PATCH /api/admin/moderation/reports/lesson-reviews/{reportId}
    be_ctrl->be_ctrl++: GetUserId() from JWT claims
    be_ctrl--
    be_ctrl->sv++: ResolveLessonReviewReportAsync(reportId, resolverId, request)
    sv->repo++: GetLessonReviewReportByIdAsync(reportId)
    repo->ctx++: Query LessonReviewReport by id
    ctx->db++: Execute SQL query
    db-->>ctx: Return result
    ctx-->>repo: Return LessonReviewReport
    repo-->>sv: Return LessonReviewReport
    sv->sv++: Update report fields & soft-remove review if RemoveContent=true
    sv--
    sv->repo++: UpdateLessonReviewReport(report)
    repo-->>sv--: void
    sv->repo++: SaveChangesAsync()
    repo->ctx++: SaveChangesAsync()
    ctx->db++: Save changes to Database
    db-->>ctx: Return numberOfRowsAffected
    ctx-->>repo: Return numberOfRowsAffected
    repo-->>sv: Return numberOfRowsAffected
    sv->sv++: Check numberOfRowsAffected > 0
    sv--
    alt numberOfRowsAffected > 0
        sv->sv++: SendNotificationAsync() to reporter
        sv--
        sv-->>be_ctrl--: Return true
        be_ctrl-->>view--: Return statusCode 200
        view-->>act: Display success message, reload list
    else numberOfRowsAffected = 0
        sv-->>be_ctrl--: throw InvalidOperationException
        be_ctrl-->>view--: Return statusCode 400
        view-->>act: Display error message
    end
end
act--
@enduml
