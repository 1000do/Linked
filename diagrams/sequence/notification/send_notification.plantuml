@startuml SendNotifications
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Send Notification
actor Admin as act

participant "SystemNotificationsView" as view
participant "NotificationController" as be_ctrl
participant ":NotificationService" as sv
participant ":UserRepository" as user_repo
participant ":NotificationRepository" as repo
participant ":AppDbContext" as ctx
participant "NotificationHub" as hub
database Database as db

act++
act->view++: Compose notification details (Target, Title, Content)
act->view: Click "Send Notification"
view->view++: Validate input form
view--
group opt [Invalid input]
    view-->>act: Display client-side warning alert
end

act->view: Confirm and submit
view->be_ctrl++: Send POST request to /api/Notification/send-advanced (JSON payload)

be_ctrl->be_ctrl++: Validate title and content length
be_ctrl--
group opt [Title or Content length > 100 characters]
    be_ctrl-->>view: Return statusCode 400 (BadRequest)
    view-->>act: Display validation error message
end

be_ctrl->sv++: Call SendAdvancedAsync(dto)

alt dto.TargetType == "ALL"
    sv->user_repo++: Call GetAllUserIdsAsync()
    user_repo->ctx++: Call GetAllUserIdsAsync()
    ctx->db++: Query all user IDs
    db-->>ctx--: Return user IDs list
    ctx-->>user_repo--: Return user IDs list
    user_repo-->>sv--: Return user IDs list
else dto.TargetType == "SINGLE" (Specific users by emails)
    loop for each email in dto.Emails
        sv->user_repo++: Call GetUserIdByEmailAsync(email)
        user_repo->ctx++: Call GetUserIdByEmailAsync(email)
        ctx->db++: Query user ID by email
        db-->>ctx--: Return userId or null
        ctx-->>user_repo--: Return userId or null
        user_repo-->>sv--: Return userId or null
    end
end

sv->sv++: Check if targetUserIds is empty
sv--
group opt [No target users found]
    sv-->>be_ctrl: Return 0
    be_ctrl-->>view: Return statusCode 200 with count = 0
    view-->>act: Display failure or warning message
end

sv->repo++: Call AddRangeAsync(notifications)
repo->ctx++: Call AddRangeAsync(notifications)
ctx-->>repo--: Return success
repo-->>sv--: Return success

sv->repo++: Call SaveChangesAsync()
repo->ctx++: Call SaveChangesAsync()
ctx->db++: Save notifications to Database
db-->>ctx--: Return numberOfRowsAffected
ctx-->>repo--: Return numberOfRowsAffected
repo-->>sv--: Return numberOfRowsAffected

sv->sv++: Check if numberOfRowsAffected > 0
sv--

alt numberOfRowsAffected > 0
    loop for each userId in targetUserIds
        sv->hub++: Call Clients.User(userId).SendAsync("ReceiveNotification", notiData)
        hub-->>sv: Broadcast notification via SignalR Hub
        hub--
    end
    sv-->>be_ctrl: Return targetUserIds.Count
    be_ctrl-->>view: Return statusCode 200 (Ok)
    view-->>act: Display "Sent successfully" notification
else numberOfRowsAffected <= 0
    sv-->>be_ctrl--: Throw InvalidOperationException("Failed to save changes")
    be_ctrl-->>view--: Return statusCode 500 (InternalServerError)
    view-->>act--: Display database error message
end

@enduml
