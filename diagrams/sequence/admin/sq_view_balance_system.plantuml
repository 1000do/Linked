@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Balance (For System)

actor "Administrator" as act
participant "AdminFinanceDashboard" as view
participant "LoginPage" as login_view
participant "AdminFinanceController" as fe_ctrl <<frontend controller>>
participant "AdminFinanceController" as be_ctrl <<backend controller>>
participant ":AdminFinanceService" as finance_sv
participant ":AdminFinanceRepository" as finance_repo
database Database as db
participant "Stripe API" as stripe
participant ":StripeConnectService" as stripe_sv

act ++
view ++

act -> view: Access Admin Finance Dashboard
view -> fe_ctrl++: GET /AdminFinance\n(default: current year/month)

fe_ctrl -> fe_ctrl: Validate active login session
alt Session Invalid
    fe_ctrl -->> login_view: Redirect to /Account/Login
    activate login_view
    login_view -->> act: Display authentication error message\nRedirect to login page
    deactivate login_view
else Valid Session
    par Fetch Dashboard Data (Task.WhenAll)
        group Summary & Payouts
            fe_ctrl -> be_ctrl++: GET /api/admin/finance/summary
            be_ctrl -> finance_sv++: GetFinancialSummaryAsync()
            finance_sv -> finance_repo++: Query Transactions & Courses
            finance_repo -> db++: Execute SELECT
            db -->> finance_repo--: Data
            finance_repo -->> finance_sv--: Data
            finance_sv -->> be_ctrl--: FinancialSummaryResponse
            be_ctrl -->> fe_ctrl--: Return statusCode 200 (Data)
        end
        
        group Stripe Gateway Balances
            fe_ctrl -> be_ctrl++: GET /api/admin/finance/balance
            be_ctrl -> finance_sv++: GetPlatformBalanceAsync()
            finance_sv -> stripe_sv++: GetPlatformBalanceAsync()
            stripe_sv -> stripe++: Request Stripe Connect Balance
            stripe -->> stripe_sv--: Balance Data
            stripe_sv -->> finance_sv--: PlatformBalanceResponse
            finance_sv -->> be_ctrl--: PlatformBalanceResponse
            be_ctrl -->> fe_ctrl--: Return statusCode 200 (Data)
        end
        
        group Config Settings
            fe_ctrl -> be_ctrl: GET /api/admin/finance/payout-days
            fe_ctrl -> be_ctrl: GET /api/admin/finance/transfer-rate
        end
    end
    
    fe_ctrl -> fe_ctrl: Map to AdminFinanceUnifiedVM
    fe_ctrl -->> view--: Return View(AdminFinanceUnifiedVM)
    
    view -->> act: Display Course Revenue, Splits,\nStripe Gateway Balances, Config statuses,\nand Monthly Financial Performance chart
end




@enduml
