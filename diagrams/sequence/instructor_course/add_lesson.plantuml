@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Add Lesson
actor Instructor as act

participant "LessonForm" as view

participant "InstructorCourseController" as fe_ctrl
participant "LessonController" as be_ctrl


participant ":LessonService" as sv
participant ":LessonResponse" as res
participant ":Lesson" as ett

participant ":LessonRepository" as repo
participant ":AppDbContext" as ctx

Database Database as db

act++
act->view++:Access add lesson form
act->view:Enter lesson title and select course
act->view:Click the "Add Lesson" button
view->view++:Validate input
view--
group opt [Invalid input]
    view-->>act:Display error message
end

view->fe_ctrl++:Send POST request with courseId and title
fe_ctrl->fe_ctrl++:Create MultipartFormDataContent
fe_ctrl--
fe_ctrl->be_ctrl++: Send POST request to /lessons
be_ctrl -> sv++: Call CreateLessonAsync()
sv -> sv++: Call ValidateCourseOwnershipAsync()
sv--

sv -> ett++: Call Lesson()
ett -->>sv--: Return Lesson object
sv -> repo++: Call AddAsync()
repo->ctx++: Call AddAsync()
ctx-->>repo--: Return result
repo -->> sv--: Return result
sv -> repo++: Call SaveChangesAsync()
repo->ctx++: Call SaveChangesAsync()
ctx->db++: Save changes to Database
db-->>ctx--: Return numberOfRowsAffected
ctx-->>repo--: Return numberOfRowsAffected
repo -->> sv--: Return numberOfRowsAffected
sv->sv++:Check numberOfRowsAffected
sv--
alt numberOfRowsAffected > 0
    sv -> res++: Call LessonResponse()
    res -->> sv--: Return LessonResponse object
    sv -->>  be_ctrl: Return LessonResponse object
    be_ctrl -->> fe_ctrl:Return statusCode 201
    fe_ctrl -->> view: Return JSON with success=true and lesson data
    view -->> act: Display lesson added successfully message
else numberOfRowsAffected = 0
    sv-->>be_ctrl--:throw InvalidOperationException
    be_ctrl -->> fe_ctrl--:Return statusCode 400
    fe_ctrl -->> view--: Return JSON with success=false and error message
    view -->> act --: Display error message
end

@enduml
