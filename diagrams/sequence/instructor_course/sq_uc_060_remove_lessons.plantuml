@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Remove Lessons

actor Instructor as act
participant "CourseEditorPage" as view
participant "InstructorCourseController" as fe_ctrl <<frontend controller>>
participant "LessonController" as be_ctrl <<backend controller>>
participant ":LessonService" as sv
participant ":ILessonRepository" as repo
participant ":ICourseRepository" as course_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++: Click Delete Lesson
view -> fe_ctrl++: DELETE /InstructorCourse/RemoveLesson/{lessonId}
fe_ctrl -> be_ctrl++: DELETE /api/lessons/{id}

be_ctrl -> sv++: Call DeleteLessonAsync(id, instructorId)

sv -> repo++: Call GetByIdAsync(id)
repo -> ctx++: Execute query
ctx -> db++: Fetch lesson
db -->> ctx--: Return query results
ctx -->> repo--: Return lesson entity
repo -->> sv--: Return lesson entity

alt Lesson Not Found
    sv -->> be_ctrl: throw Exception
    be_ctrl -->> fe_ctrl: Return statusCode 404
    fe_ctrl -->> view: Return JSON (success=false)
    view -->> act: Display lesson not found message
else Lesson Found
    sv -> sv++: Validate Instructor and Course State
    sv--
    
    alt Validation Failed
        sv -->> be_ctrl: throw BadRequestException
        be_ctrl -->> fe_ctrl: Return statusCode 400
        fe_ctrl -->> view: Return JSON (success=false)
        view -->> act: Display error message
    else Valid to Delete
        sv -> sv++: Soft delete materials and move to trash
        sv--
        
        sv -> repo++: Call Update(lesson) (Set IsRemoved=true)
        repo -> ctx++: Update entity state
        ctx -->> repo--: Return
        repo -->> sv--: Return
        
        opt Course is Published
            sv -> sv++: Set course.CourseStatus = "draft"
            sv--
        end
        
        sv -> repo++: Call SaveChangesAsync()
        repo -> ctx++: Save changes to database
        ctx -> db++: Update Lesson (Soft Delete)
        db -->> ctx--: Return returnCode
        ctx -->> repo--: Return numberOfRowsAffected
        repo -->> sv--: Return numberOfRowsAffected
        
        sv -> sv++: Check numberOfRowsAffected
        sv--
        
        alt numberOfRowsAffected > 0
            sv -> sv++: Call Cache Invalidation Logic
            sv--
            
            sv -->> be_ctrl--: Return success
            be_ctrl -->> fe_ctrl--: Return statusCode 200
            fe_ctrl -->> view--: Return JSON (success=true)
            view -->> act--: Display lesson removed successfully
        else numberOfRowsAffected = 0
            sv -->> be_ctrl--: throw InvalidOperationException
            be_ctrl -->> fe_ctrl--: Return statusCode 400
            fe_ctrl -->> view--: Return JSON (success=false)
            view -->> act--: Display error message
        end
    end
end