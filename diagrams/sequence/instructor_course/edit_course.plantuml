@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Update Course Details

actor Instructor as act
participant "CourseEditForm" as view
participant "InstructorCourseController" as fe_ctrl
participant "CourseController" as be_ctrl
participant ":CourseService" as sv
participant ":CourseResponse" as res
participant ":Course" as ett
participant ":InstructorRepository" as inst_repo
participant ":CourseRepository" as repo
participant ":CourseExtRepository" as ext_repo
participant ":ContentHashService" as hash_sv
participant ":RedisService" as redis
participant ":AppDbContext" as ctx
participant Database as db

act++
act->view++: Edit course details (Title, Description, Price, etc.)
view->view++: Debounce save action (1.5 seconds)
view--

view->view++: Validate input fields
view--
group opt [Invalid input fields]
    view-->>act: Silently cancel auto-save
end

view->fe_ctrl++: Send POST request to /InstructorCourse/UpdateDetails
fe_ctrl->be_ctrl++: Send PUT request to /api/courses/{courseId}

be_ctrl->be_ctrl++: GetInstructorId()
be_ctrl--

be_ctrl->sv++: Call UpdateCourseAsync()

sv->repo++: Call GetByIdAsync(courseId)
repo->ctx++: Call GetByIdAsync()
ctx-->>repo--: Return Course entity
repo-->>sv--: Return Course entity

sv->sv++: Check if course exists
sv--
group opt [Course is null]
    sv-->>be_ctrl: Throw Exception("Course not found.")
    be_ctrl-->>fe_ctrl: Return status code 500
    fe_ctrl-->>view: Return success = false
    view-->>act: Display error message
end

sv->sv++: Check course ownership
sv--
group opt [course.InstructorId != instructorId]
    sv-->>be_ctrl: Throw UnauthorizedAccessException
    be_ctrl-->>fe_ctrl: Return status code 403
    fe_ctrl-->>view: Return success = false
    view-->>act: Display error message
end

sv->sv++: Check course status and flag count
sv--
group opt [Course is archived and flagged >= 3]
    sv-->>be_ctrl: Throw BadRequestException
    be_ctrl-->>fe_ctrl: Return status code 400
    fe_ctrl-->>view: Return success = false
    view-->>act: Display error message
end

sv->sv++: Check if course is pending review
sv--
group opt [Course status is "pending"]
    sv-->>be_ctrl: Throw InvalidOperationException
    be_ctrl-->>fe_ctrl: Return status code 500
    fe_ctrl-->>view: Return success = false
    view-->>act: Display error message
end

sv->inst_repo++: Call GetByIdAsync(instructorId)
inst_repo->ctx++: Call GetByIdAsync()
ctx-->>inst_repo--: Return Instructor entity
inst_repo-->>sv--: Return Instructor entity

sv->sv++: Check if Stripe account is active
sv--

sv->ett++: Update Title, Description, CategoryId, Price, ThumbnailUrl, WhatYouWillLearn, Requirements, UpdatedAt
ett-->>sv--: Course fields updated

sv->sv++: Check if course status is "published"
sv--
group opt [Status is "published"]
    sv->ett++: Set CourseStatus = "draft", ModerationFeedback = null
    ett-->>sv--: Status and feedback updated
end

sv->repo++: Call Update(course)
repo->ctx++: Call Update()
ctx-->>repo--: Return result
repo-->>sv--: Return result

sv->repo++: Call SaveChangesAsync()
repo->ctx++: Call SaveChangesAsync()
ctx->db++: Update Course details in Database
db-->>ctx--: Return numberOfRowsAffected
ctx-->>repo--: Return numberOfRowsAffected
repo-->>sv--: Return numberOfRowsAffected

sv->sv++: Check numberOfRowsAffected > 0
sv--
alt numberOfRowsAffected > 0
    sv->sv++: Call UpdateCourseHashesAsync()
    
    sv->sv++: Download thumbnail bytes if CourseThumbnailUrl is present
    sv--
    
    sv->hash_sv++: Call ComputeCourseHashAsync(Title)
    hash_sv-->>sv--: Return TitleHash
    sv->hash_sv++: Call ComputeCourseHashAsync(Description)
    hash_sv-->>sv--: Return DescriptionHash
    sv->hash_sv++: Call ComputeCourseHashAsync(WhatYouWillLearn)
    hash_sv-->>sv--: Return WhatYouWillLearnHash
    sv->hash_sv++: Call ComputeCourseHashAsync(Requirements)
    hash_sv-->>sv--: Return RequirementsHash
    
    sv->sv++: Check if thumbnail is present
    sv--
    group opt [Thumbnail is present]
        sv->hash_sv++: Call ComputeFileHashAsync(ThumbnailBytes)
        hash_sv-->>sv--: Return ThumbnailHash
    end
    
    sv->sv++: Call SaveCourseHashesAsync()
    
    sv->ext_repo++: Call GetByIdAsync(courseId)
    ext_repo->ctx++: Call GetByIdAsync()
    ctx-->>ext_repo--: Return CourseExt entity
    ext_repo-->>sv--: Return CourseExt entity
    
    sv->sv++: Check if existing hashes exist
    sv--
    alt existing is not null
        sv->ext_repo++: Call Update(CourseExt)
        ext_repo-->>sv--: Return result
    else existing is null
        sv->ext_repo++: Call AddAsync(CourseExt)
        ext_repo-->>sv--: Return result
    end
    
    sv->ext_repo++: Call SaveChangesAsync()
    ext_repo->ctx++: Call SaveChangesAsync()
    ctx->db++: Save CourseExt in Database
    db-->>ctx--: Return numberOfRowsAffected
    ctx-->>ext_repo--: Return numberOfRowsAffected
    ext_repo-->>sv--: Return numberOfRowsAffected
    
    sv->sv++: Check numberOfRowsAffected > 0
    sv--
    group opt [numberOfRowsAffected = 0]
        sv-->>sv: Throw InvalidOperationException
    end
    
    sv-- 
    sv-- 
    
    sv->redis++: Call RemoveCacheAsync(courseId)
    redis-->>sv--: Return result
    
    sv->res++: Call CourseResponse()
    res-->>sv--: Return CourseResponse object
    
    sv-->>be_ctrl: Return CourseResponse object
    be_ctrl-->>fe_ctrl: Return status code 200 (OK)
    
    fe_ctrl->fe_ctrl++: Parse response JSON
    fe_ctrl--
    
    fe_ctrl-->>view: Return JSON (success = true, status)
    view->view++: Show auto-save success status ("Saved!")
    view--
    view-->>act: Update course details on editor view
else numberOfRowsAffected = 0
    sv-->>be_ctrl--: Throw InvalidOperationException("Failed to update this course")
    be_ctrl-->>fe_ctrl--: Return status code 500
    fe_ctrl-->>view--: Return success = false with error message
    view-->>act--: Display error message
end

@enduml
