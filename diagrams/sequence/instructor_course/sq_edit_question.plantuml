@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Edit Question

actor Instructor as act
participant "QuestionBankPage" as view
participant "QuestionBankController" as fe_ctrl <<frontend controller>>
participant "QuestionBankController" as be_ctrl <<backend controller>>
participant ":QuestionBankService" as sv
participant ":QuizQuestionResponse" as res
participant ":IQuestionBankRepository" as repo
participant ":ICourseRepository" as course_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++: Submit edit question form
view -> fe_ctrl++: PUT /QuestionBank/UpdateQuestion?qId={qId}

fe_ctrl -> be_ctrl++: PUT /api/QuestionBank/questions/{questionId}

be_ctrl -> sv++: Call UpdateQuestionAsync(questionId, request, instructorId)

sv -> sv++: Call ValidateQuizOptions(request.Options)
sv--

alt Invalid Options
    sv -->> be_ctrl: throw ArgumentException
    be_ctrl -->> fe_ctrl: Return statusCode 400
    fe_ctrl -->> view: Return JSON (success=false)
    view -->> act: Display validation error message
else Valid Options
    sv -> repo++: Call GetQuestionByIdAsync(questionId)
    repo -->> sv--: Return QuizQuestion entity
    
    alt Question Not Found
        sv -->> be_ctrl: throw KeyNotFoundException
        be_ctrl -->> fe_ctrl: Return statusCode 404
        fe_ctrl -->> view: Return JSON (success=false)
        view -->> act: Display not found error message
    else Question Found
        sv -> sv++: Call EnsureInstructorOwnsCourseAsync(question.CourseId, instructorId)
        sv--
        
        sv -> course_repo++: Call GetByIdAsync(courseId)
        course_repo -->> sv--: Return course entity
        
        alt Course Not Found Or Unauthorized
            sv -->> be_ctrl: throw UnauthorizedAccessException
            be_ctrl -->> fe_ctrl: Return statusCode 403
            fe_ctrl -->> view: Return JSON (success=false)
            view -->> act: Display unauthorized error message
        else Authorized
            sv -> sv++: Update QuizQuestion entity properties
            sv--
            
            sv -> repo++: Call UpdateQuestionAsync(question)
            repo -> ctx++: Save changes to database
            ctx -> db++: Update QuizQuestion and QuizOptions
            
            alt Database Save Failure
                db -->> ctx: throw DbUpdateException
                ctx -->> repo: throw DbUpdateException
                repo -->> sv: throw DbUpdateException
                sv -->> be_ctrl: throw DbUpdateException
                be_ctrl -->> fe_ctrl: Return statusCode 500
                fe_ctrl -->> view: Return JSON (success=false)
                view -->> act: Display server error message
            else Database Save Success
                db -->> ctx--: Return returnCode
                ctx -->> repo--: Return numberOfRowsAffected
                repo -->> sv--: Return updatedQuestion
                
                sv -> res++: Call QuizQuestionResponse()
                res -->> sv--: Return QuizQuestionResponse object
                
                sv -->> be_ctrl--: Return QuizQuestionResponse object
                be_ctrl -->> fe_ctrl--: Return statusCode 200
                fe_ctrl -->> view--: Return JSON (success=true)
                view -->> act--: Display question updated successfully
            end
        end
    end
end
