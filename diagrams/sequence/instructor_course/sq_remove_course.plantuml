@startuml RemoveCourse
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Remove Course
actor Instructor as act

participant "InstructorCourseListView" as view
participant "InstructorCourseController" as fe_ctrl <<frontend controller>>
participant "CourseController" as be_ctrl <<backend controller>>

participant ":CourseCommandService" as sv
participant ":LockoutRepository" as lock_repo
participant ":CourseRepository" as repo
participant ":LessonRepository" as lesson_repo
participant ":RedisService" as redis
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++: Click "Delete" button of a course
view->view++: Show deletion confirmation dialog
view--
group opt [Instructor cancels deletion]
    view-->>act: Close confirmation dialog
end

act->view: Confirm course deletion
view->fe_ctrl++: Send AJAX POST request to InstructorCourse/Delete/{id}

fe_ctrl->be_ctrl++: Send DELETE request to /api/courses/{id}
be_ctrl->be_ctrl++: Call GetInstructorId()
be_ctrl--
be_ctrl->sv++: Call DeleteCourseAsync(id, instructorId)

sv->repo++: Call GetByIdAsync(courseId)
repo->ctx++: Call FindAsync(courseId)
ctx->db++: Query Course by courseId
db-->>ctx--: Return course or null
ctx-->>repo--: Return course or null
repo-->>sv--: Return course or null

sv->lock_repo++: Call GetActiveLockoutAsync(instructorId, "instructor")
lock_repo->ctx++: Call GetActiveLockoutAsync()
ctx->db++: Query active lockout
db-->>ctx--: Return activeLockout or null
ctx-->>lock_repo--: Return activeLockout or null
lock_repo-->>sv--: Return activeLockout or null

sv->repo++: Call HasEnrollmentsAsync(courseId)
repo->ctx++: Call AnyAsync()
ctx->db++: Query course enrollments
db-->>ctx--: Return hasEnrollments (true/false)
ctx-->>repo--: Return hasEnrollments
repo-->>sv--: Return hasEnrollments

sv->sv++: Validate course removal request
sv--

alt Course Not Found
    sv-->>be_ctrl: throw Exception
    be_ctrl-->>fe_ctrl: Return statusCode 404
    fe_ctrl-->>view: Return statusCode 404
    view-->>act: Display error message
else Invalid Instructor Rights
    sv-->>be_ctrl: throw BadRequestException
    be_ctrl-->>fe_ctrl: Return statusCode 400
    fe_ctrl-->>view: Return statusCode 400
    view-->>act: Display error message
else Invalid Course Status
    sv-->>be_ctrl: throw InvalidOperationException
    be_ctrl-->>fe_ctrl: Return statusCode 400
    fe_ctrl-->>view: Return statusCode 400
    view-->>act: Display error message
else Course Has Active Enrollments
    sv-->>be_ctrl: throw BadRequestException
    be_ctrl-->>fe_ctrl: Return statusCode 400
    fe_ctrl-->>view: Return statusCode 400
    view-->>act: Display error message
else Valid course removal request
    sv->sv++: Mark course as removed (IsRemoved = true)
    sv--
    
    sv->sv++: RemoveLessonsInCourse()
    sv--
    
    
    sv->repo++: Call Update(course)
    repo-->>sv--: Return result
    
    sv->repo++: Call SaveChangesAsync()
    repo->ctx++: Call SaveChangesAsync()
    ctx->db++: Save changes to Database
    db-->>ctx--: Return numberOfRowsAffected
    ctx-->>repo--: Return numberOfRowsAffected
    repo-->>sv--: Return numberOfRowsAffected
    
    sv->sv++: Check numberOfRowsAffected
    sv--
    
    alt numberOfRowsAffected > 0
        sv->redis++: Call RemoveCacheAsync(courseKey)
        redis-->>sv--: Return result
        
        sv-->>be_ctrl: Return result
        be_ctrl-->>fe_ctrl: Return statusCode 200
        fe_ctrl-->>view: Return statusCode 200
        view-->>act: Display success message
    else numberOfRowsAffected = 0
        sv-->>be_ctrl--: throw InvalidOperationException
        be_ctrl-->>fe_ctrl--: Return statusCode 400
        fe_ctrl-->>view--: Return statusCode 400
        view-->>act--: Display error message
    end
end

@enduml
