@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Sort Instructor's Transaction History

actor "Instructor" as act
participant "EarningsDashboard" as view
participant "LoginPage" as login_view
participant "TransactionController" as fe_tx_ctrl <<frontend controller>>
participant "TransactionController" as be_tx_ctrl <<backend controller>>
participant ":TransactionService" as tx_sv
participant ":TransactionRepository" as tx_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
view ++

act -> view: Select sorting option (or "Reset") \n& click "Filter"
view -> fe_tx_ctrl++: GET /Transaction/Instructor?sortBy={sort}&keyword={k}&status={s}&year={y}&month={m}

fe_tx_ctrl -> fe_tx_ctrl++: Check Request.Cookies["InstructorApprovalStatus"]
fe_tx_ctrl--

alt Not Approved Instructor
    fe_tx_ctrl -->> view: Return statusCode 302
    view -->> act: Redirect to /Instructor/ApplicationStatus
else Approved Instructor
    fe_tx_ctrl -> be_tx_ctrl++: GET /api/transactions/instructor\n(paged, with sortBy)
    
    alt Session Invalid / Unauthorized Access
        be_tx_ctrl -->> fe_tx_ctrl: Return statusCode 401
        fe_tx_ctrl -->> login_view: Redirect to /Account/Login
        activate login_view
        login_view -->> act: Display Login page
        deactivate login_view
    else Authorized
        be_tx_ctrl -> tx_sv++: GetInstructorTransactionsAsync(..., sortBy, ...)
        tx_sv -> tx_repo++: GetInstructorTransactionsAsync(..., sortBy, ...)
        tx_repo -> ctx++: Query Transactions with OrderBy(sortBy)
        ctx -> db++: Execute SELECT
        
        alt Database query failure (EX-9)
            db -->> ctx: throw SqlException
            ctx -->> tx_repo: throw SqlException
            tx_repo -->> tx_sv: throw SqlException
            tx_sv -->> be_tx_ctrl: throw SqlException
            be_tx_ctrl -->> fe_tx_ctrl: Return statusCode 500 (ErrorResponse)
            fe_tx_ctrl -->> view: Return View with error message
            view -->> act: Display error message regarding query failure
        else Query Success
            db -->> ctx--: Sorted Data
            ctx -->> tx_repo--: Transactions List
            tx_repo -->> tx_sv--: Return PagedResult
            tx_sv -->> be_tx_ctrl--: Return PagedResult
            be_tx_ctrl -->> fe_tx_ctrl--: Return statusCode 200 (TransactionPagedVM)
            
            alt No transactions found (Empty)
                fe_tx_ctrl -->> view: Return View with InstructorFinancePageVM
                view -->> act: Display "No purchases recorded for this period."
            else Has Transactions
                fe_tx_ctrl -->> view--: Return View with InstructorFinancePageVM
                view -->> act--: Display sorted list of transactions
            end
        end
    end

@enduml
