@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Become an Instructor
actor User as act

participant "Become.cshtml" as view
participant "InstructorController (FE)" as fe_ctrl
participant "InstructorController (BE)" as be_ctrl
participant ":InstructorService" as sv
participant "Cloudinary API" as cloud
database Database as db

== Step 1: Access Application Form ==
act++
act->view++: Access "Become an Instructor" page
view->fe_ctrl++: Send GET request to /Instructor/Apply

fe_ctrl->be_ctrl++: Send GET /api/instructor/dashboard (with Bearer Token)
be_ctrl-->>fe_ctrl--: Return statusCode 404 (Not Found / No application yet)

fe_ctrl->be_ctrl++: Send GET /api/instructor/stripe-countries
be_ctrl-->>fe_ctrl--: Return supported countries list

fe_ctrl->be_ctrl++: Send GET /api/public/courses/categories
be_ctrl-->>fe_ctrl--: Return available categories list

fe_ctrl-->>view--: Return View(applyModel)
view-->>act--: Display Become an Instructor form

== Step 2: Submit Application ==
act++
act->view++: Enter bio, professional title, select Stripe country,\nupload cv/certificate document file, and click "Submit"
view->fe_ctrl++: Send POST /Instructor/Apply (with Form Data)

fe_ctrl->be_ctrl++: Send POST /api/instructor/apply (with MultipartFormDataContent)

be_ctrl->sv++: Call SubmitApplicationAsync(userId, request)
sv->db++: Query existing application status for user
db-->>sv--: Return entity (null or Rejected)

alt [CV Document File provided]
    sv->cloud++: Upload certificate/CV file
    cloud-->>sv--: Return Cloudinary file URL
end

alt [Previous application was Rejected]
    sv->db++: Update existing Application details (Title, Bio, DocumentUrls, Status = Pending)
else [New application]
    sv->db++: Create new Application entity (Status = Pending)
end
db-->>sv--: Return success

sv->db++: Commit changes to Database
db-->>sv--: Return rows affected
sv-->>be_ctrl--: Return success message
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)

fe_ctrl-->>view--: Redirect to /Instructor/ApplicationStatus

view->fe_ctrl++: Send GET request to /Instructor/ApplicationStatus
fe_ctrl->be_ctrl++: Send GET /api/instructor/dashboard (with Bearer Token)
be_ctrl->sv++: Call GetInstructorDashboardAsync(userId)
sv->db++: Query instructor dashboard details
db-->>sv--: Return dashboard details
sv-->>be_ctrl--: Return details
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with dashboard JSON

fe_ctrl->fe_ctrl++: Save Cookie "InstructorApprovalStatus" = "Pending"
fe_ctrl--
fe_ctrl-->>view--: Return View(model)
view-->>act--: Display application status page showing "Pending Admin Review"
@enduml
