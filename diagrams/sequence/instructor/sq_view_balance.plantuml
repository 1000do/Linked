@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Balance

actor Instructor as act
participant "EarningsInstructorPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "ApplicationStatusPage" as app_view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "TransactionController" as be_tx_ctrl <<backend controller>>
participant "InstructorController" as be_inst_ctrl <<backend controller>>
participant ":ITransactionService" as tx_sv
participant ":ITransactionRepository" as tx_repo
participant ":TransactionListDto" as tx_dto
participant ":IInstructorService" as inst_sv
participant ":IInstructorRepository" as inst_repo
participant ":InstructorPayoutDto" as po_dto
participant ":InstructorFinancePageVM" as vm
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view ++: View Earnings Dashboard (Balance metrics)
view -> fe_ctrl ++: GET /Transaction/Instructor

fe_ctrl -> fe_ctrl ++: Validate actor's authentication and authorization
fe_ctrl --

alt Session Invalid
    fe_ctrl -->> login_view: Redirect to LoginPage
    activate login_view
    login_view -->> act --: Display login form
else Unauthorized Access
    fe_ctrl -->> error_view: Redirect to ErrorPage
    activate error_view
    error_view -->> act --: Display error message
else Valid actor's authentication and authorization
    
    fe_ctrl -> fe_ctrl ++: Check Cookies["InstructorApprovalStatus"]
    fe_ctrl --
    
    alt Status != "Approved"
        fe_ctrl -->> app_view: Redirect to ApplicationStatusPage
        activate app_view
        app_view -->> act --: Display application status
    else Status == "Approved"
        
        par Fetch Balance Data Concurrently
            fe_ctrl -> be_tx_ctrl ++: GET /api/transactions/instructor?page=1&pageSize=100000
            be_tx_ctrl -> tx_sv ++: Call GetInstructorTransactionsAsync(...)
            tx_sv -> tx_repo ++: Call GetInstructorTransactionsAsync(...)
            tx_repo -> ctx ++: Query all Transactions
            ctx -> db ++: Execute query
            db -->> ctx --: Return database records
            ctx -->> tx_repo --: Return data
            
            tx_repo -> tx_dto ++: Call TransactionListDto()
            tx_dto -->> tx_repo --: Return TransactionListDto object
            
            tx_repo -->> tx_sv --: Return list
            tx_sv -->> be_tx_ctrl --: Return PagedResult<TransactionListDto>
            be_tx_ctrl -->> fe_ctrl --: Return statusCode 200 (All Transactions)
            
            fe_ctrl -> be_inst_ctrl ++: GET /api/instructor/payouts?page=1&pageSize=100000
            be_inst_ctrl -> inst_sv ++: Call GetPayoutsAsync(...)
            inst_sv -> inst_repo ++: Call GetPayoutsAsync(...)
            inst_repo -> ctx ++: Query all InstructorPayouts
            ctx -> db ++: Execute query
            db -->> ctx --: Return database records
            ctx -->> inst_repo --: Return data
            
            inst_repo -> po_dto ++: Call InstructorPayoutDto()
            po_dto -->> inst_repo --: Return InstructorPayoutDto object
            
            inst_repo -->> inst_sv --: Return list
            inst_sv -->> be_inst_ctrl --: Return PagedResult<InstructorPayoutDto>
            be_inst_ctrl -->> fe_ctrl --: Return statusCode 200 (All Payouts)
            
            fe_ctrl -> be_inst_ctrl ++: GET /api/instructor/payout-days
            be_inst_ctrl -> inst_sv ++: Call GetPayoutDaysDelay()
            inst_sv -->> be_inst_ctrl --: Return days config (e.g. 14)
            be_inst_ctrl -->> fe_ctrl --: Return statusCode 200 (Days delay)
        end
        
        fe_ctrl -> fe_ctrl ++: Compute Financial Metrics (Gross, Refunded, Net Earnings, Pending, Withdrawn)
        fe_ctrl --
        
        fe_ctrl -> vm ++: Call InstructorFinancePageVM()
        vm -->> fe_ctrl --: Return InstructorFinancePageVM object
        
        fe_ctrl -->> view --: Return View(vm)
        view -->> act --: Display Balance Summary Cards
    end
end
@enduml
