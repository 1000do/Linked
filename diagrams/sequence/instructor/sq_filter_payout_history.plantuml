@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Filter Payout History

actor Instructor as act
participant "EaringInstructorPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "ApplicationStatusPage" as app_view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "InstructorController" as be_ctrl <<backend controller>>
participant ":IInstructorService" as sv
participant ":IInstructorRepository" as repo
participant ":InstructorPayoutDto" as dto
participant ":InstructorPayoutPagedViewModel" as vm
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view ++: Enter keyword, select status and click "Filter"
view -> fe_ctrl ++: GET /Transaction/Instructor?tab=po&payoutKeyword=...&payoutStatus=...

fe_ctrl -> fe_ctrl ++: Validate actor's authentication and authorization
fe_ctrl --

alt Session Invalid
    fe_ctrl -->> login_view: Redirect to LoginPage
    activate login_view
    login_view -->> act --: Display login form
else Unauthorized Access
    fe_ctrl -->> error_view: Redirect to ErrorPage
    activate error_view
    error_view -->> act --: Display error message
else Valid actor's authentication and authorization
    
    fe_ctrl -> be_ctrl ++: GET /api/instructor/application-status
    be_ctrl -->> fe_ctrl --: Return statusCode 200
    
    fe_ctrl -> fe_ctrl ++: Check if status is Approved
    fe_ctrl --
    
    alt Status != "Approved"
        fe_ctrl -->> app_view: Redirect to ApplicationStatusPage
        activate app_view
        app_view -->> act --: Display application status
    else Status == "Approved"
        
        fe_ctrl -> be_ctrl ++: GET /api/instructor/payouts?page=1&pageSize=20&keyword=...&status=...
        be_ctrl -> sv ++: Call GetPayoutsAsync(...)
        sv -> repo ++: Call GetPayoutsAsync(...)
        
        repo -> repo ++: Apply filtering conditions (.Where) based on keyword and status
        repo --
        
        repo -> ctx ++: Query InstructorPayouts
        ctx -> db ++: Execute filtered query with Skip() and Take()
        db -->> ctx --: Return filtered payouts list and total count
        ctx -->> repo --: Return payouts list and count
        
        repo -> dto ++: Call InstructorPayoutDto()
        dto -->> repo --: Return InstructorPayoutDto object
        
        repo -->> sv --: Return PagedResult<InstructorPayoutDto>
        sv -->> be_ctrl --: Return PagedResult<InstructorPayoutDto>
        be_ctrl -->> fe_ctrl --: Return statusCode 200
        
        fe_ctrl -> vm ++: Call InstructorPayoutPagedViewModel()
        vm -->> fe_ctrl --: Return InstructorPayoutPagedViewModel object
        
        fe_ctrl -->> view --: Return View(vm)
        
        view -> view ++: Check vm.Items.Count
        view --
        
        alt vm.Items.Count == 0
            view -->> act: Display empty message "No payouts found"
        else vm.Items.Count > 0
            view -->> act --: Display filtered payout list
        end
    end
end
@enduml
