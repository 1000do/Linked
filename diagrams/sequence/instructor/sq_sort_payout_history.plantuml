@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Sort Payout History

actor Instructor as act
participant "EaringInstructorPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "ApplicationStatusPage" as app_view
participant "TransactionController" as fe_tx_ctrl <<frontend controller>>
participant "InstructorController" as be_inst_ctrl <<backend controller>>
participant ":IInstructorService" as inst_sv
participant ":IInstructorRepository" as inst_repo
participant ":InstructorPayoutDto" as dto
participant ":InstructorPayoutPagedViewModel" as view_model
participant ":AppDbContext" as ctx
database Database as db

act ++

act -> view++: Select sorting option & click "Filter"
view -> fe_tx_ctrl++: GET /Transaction/Instructor?payoutSortBy={sort}
view--

fe_tx_ctrl -> fe_tx_ctrl++: Validate actor's authentication and authorization
fe_tx_ctrl--

alt Session Invalid
    fe_tx_ctrl -->> login_view: Redirect to LoginPage
    activate login_view
    login_view -->> act--: Display login form
else Unauthorized Access
    fe_tx_ctrl -->> error_view: Redirect to ErrorPage
    activate error_view
    error_view -->> act--: Display error message
else Valid actor's authentication and authorization
    fe_tx_ctrl -> fe_tx_ctrl++: Validate Cookies["InstructorApprovalStatus"] == "Approved"
    fe_tx_ctrl--
    
    alt Not Approved Instructor
        fe_tx_ctrl -->> app_view: Redirect to ApplicationStatusPage
        activate app_view
        app_view -->> act: Display application status
        deactivate app_view
    else Approved Instructor
        fe_tx_ctrl -> be_inst_ctrl++: GET /api/instructor/payouts
        be_inst_ctrl -> inst_sv++: GetPayoutsAsync(userId, sortBy, ...)
        inst_sv -> inst_repo++: GetPayoutsAsync(userId, sortBy, ...)
        
        inst_repo -> ctx++: Query InstructorPayouts
        ctx -> db++: Execute SELECT
        db -->> ctx--: Return data
        ctx -->> inst_repo--: Return mapped data
        
        inst_repo -> dto++: Call InstructorPayoutDto()
        dto -->> inst_repo--: Return InstructorPayoutDto object
        
        inst_repo -->> inst_sv--: Return PagedResult<InstructorPayoutDto>
        inst_sv -->> be_inst_ctrl--: Return PagedResult<InstructorPayoutDto>
        
        be_inst_ctrl -->> fe_tx_ctrl--: Return statusCode 200
        
        fe_tx_ctrl -> fe_tx_ctrl++: Deserialize JSON to InstructorPayoutPagedViewModel
        fe_tx_ctrl--
        
        fe_tx_ctrl -> view_model++: Call InstructorPayoutPagedViewModel()
        view_model -->> fe_tx_ctrl--: Return InstructorPayoutPagedViewModel object
        
        fe_tx_ctrl -->> view --: Return View(vm)
        
        alt vm.Items.Count == 0
            view -->> act: Display empty message "No payouts found"
        else vm.Items.Count > 0
            view -->> act --: Display sorted list of payouts
        end
    end
end

@enduml
