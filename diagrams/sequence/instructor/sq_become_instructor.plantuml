@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Become an Instructor

actor "Learner" as act
participant "InstructorPortal" as portal
participant "ApplyPage" as view
participant "InstructorController" as fe_ctrl <<frontend controller>>
participant "InstructorController" as be_ctrl <<backend controller>>
participant ":InstructorService" as sv
participant ":FileUploadService" as upload
participant ":InstructorRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
portal ++

act -> portal: Click "Become an Instructor"
portal -> fe_ctrl++: GET /Instructor/Apply

fe_ctrl -> fe_ctrl++: Check user session
fe_ctrl--

opt Session Invalid
    fe_ctrl -->> portal: Return Redirect to Login
    portal -->> act: Display Login page
end

fe_ctrl -> be_ctrl++: GET /api/instructor/dashboard
be_ctrl -->> fe_ctrl--: Return ApprovalStatus (if any)

opt ApprovalStatus == "Pending" or "Approved"
    fe_ctrl -->> portal: Redirect to ApplicationStatus page
    portal -->> act: Display Application Status
end

fe_ctrl -> be_ctrl++: GET /api/Profile
be_ctrl -->> fe_ctrl--: Return IsVerified status

opt Email Not Verified
    fe_ctrl -->> view++: Render View with ViewBag.IsEmailVerified = false
    view -> view++: Block form, show warning banner
    view--
    view -->> act: Display "Email Not Verified" banner & "Verify Email Now" button
    act -> view: Click "Verify Email Now"
    view -->> act: Redirect to Email Verification page
end

opt Resubmitting a Rejected Application
    fe_ctrl -> be_ctrl++: GET /api/instructor/apply-info
    be_ctrl -->> fe_ctrl--: Return previous application info (Rejected)
    fe_ctrl -> fe_ctrl++: Pre-fill ViewModel (IsResubmit = true)
    fe_ctrl--
end

fe_ctrl -->> view: Return View(ViewModel)
view -->> act: Display instructor application form

act -> view: Fill professional details, Stripe country, and upload document(s)
act -> view: Click "Submit Application"
view -> fe_ctrl++: POST /Instructor/Apply (FormData)

fe_ctrl -> fe_ctrl++: Validate form & file constraints (Max 3 files, 5MB, format)
fe_ctrl--

alt Form Validation Failed
    fe_ctrl -->> view: Return View with ModelState errors
    view -->> act: Display validation errors inline
else Validation Passed (Normal Flow)
    fe_ctrl -> be_ctrl++: POST /api/instructor/apply (FormData)
    
    be_ctrl -> sv++: SubmitApplicationAsync(userId, request)
    
    sv -> repo++: GetByIdAsync(userId)
    repo -> ctx++: Query instructor
    ctx -> db++: Execute SELECT
    db -->> ctx--: Return record
    ctx -->> repo--: Return Instructor entity
    repo -->> sv--: Return Instructor entity
    
    sv -> upload++: UploadImageAsync(file)
    upload -->> sv--: Return document URLs
    
    alt Resubmitting a Rejected Application
        sv -> sv++: Update existing application properties (ApprovalStatus = Pending)
        sv--
    else New Application
        sv -> sv++: Create new Instructor entity (ApprovalStatus = Pending)
        sv--
        sv -> repo++: AddAsync(instructor)
        repo -> ctx++: Add entity
        ctx -->> repo--: Success
        repo -->> sv--: Success
    end
    
    sv -> repo++: SaveChangesAsync()
    repo -> ctx++: Save changes
    ctx -> db++: Execute INSERT / UPDATE
    db -->> ctx--: Success
    ctx -->> repo--: Return rows affected
    repo -->> sv--: Return rows affected
    
    sv -->> be_ctrl--: Return success message
    be_ctrl -->> fe_ctrl--: Return 200 OK
    
    fe_ctrl -->> portal--: Redirect to ApplicationStatus (TempData["SuccessMessage"])
    portal -->> act: Display "Your application has been submitted successfully!"
end

deactivate view
deactivate portal
deactivate act

@enduml
