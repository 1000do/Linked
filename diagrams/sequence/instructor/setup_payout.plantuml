@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Setup Payout (Stripe Onboarding)
actor Instructor as act

participant "ApplicationStatus.cshtml" as view
participant "InstructorController (FE)" as fe_ctrl
participant "InstructorController (BE)" as be_ctrl
participant ":InstructorService" as sv
participant "Stripe API" as stripe
database Database as db

== Phase 1: Request Setup and Redirect ==
act++
act->view++: Click "Setup Stripe Payout" button
view->fe_ctrl++: Send POST request to /Instructor/SetupPayout

fe_ctrl->be_ctrl++: Send POST /api/instructor/setup-payout (with Bearer Token)

be_ctrl->sv++: Call SetupStripePayoutAsync(userId)
sv->db++: Query Instructor details
db-->>sv--: Return Instructor entity

alt [Instructor StripeAccountId is empty]
    sv->stripe++: Create Stripe Custom Express Account
    stripe-->>sv--: Return Stripe Account ID
    sv->db++: Update Instructor entity with StripeAccountId
    db-->>sv--: Return success
end

sv->stripe++: Create Stripe Account Link (Onboarding URL)\n(with Success & Cancel return URLs pointing to FE)
stripe-->>sv--: Return Stripe Account Link Object (containing Onboarding Url)

sv->db++: Commit changes to Database
db-->>sv--: Return success
sv-->>be_ctrl--: Return onboarding link & account details
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with url JSON
fe_ctrl-->>view--: Redirect User to Stripe Onboarding Url
view-->>act--: Redirected to Stripe setup page

== Phase 2: Setup Callback (Return) ==
stripe->act: Fills details and submits Stripe form
act->fe_ctrl++: Redirected to GET /Instructor/StripeReturn?instructorId=...

fe_ctrl->be_ctrl++: Send GET /api/instructor/stripe-return?instructorId=... (with Bearer Token)

be_ctrl->sv++: Call VerifyStripeOnboardingAsync(instructorId)
sv->stripe++: Retrieve Stripe Account details
stripe-->>sv--: Return Account object (payouts_enabled, charges_enabled)

sv->sv++: Check if payouts_enabled && charges_enabled
sv--

alt [Onboarding Complete]
    sv->db++: Update Instructor (StripeOnboardingStatus = "Active", PayoutsEnabled = true)
    db-->>sv--: Return success
    sv-->>be_ctrl: Return stripeStatus = "Active"
else [Onboarding Incomplete]
    sv->db++: Update Instructor (StripeOnboardingStatus = "Pending", PayoutsEnabled = false)
    db-->>sv--: Return success
    sv-->>be_ctrl: Return stripeStatus = "Pending"
end
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with status JSON

alt [stripeStatus == "Active"]
    fe_ctrl->fe_ctrl++: Save Cookie "UserRole" = "instructor"
    fe_ctrl--
    fe_ctrl-->>view: Redirect to ApplicationStatus with Success message
else [stripeStatus == "Pending"]
    fe_ctrl-->>view: Redirect to ApplicationStatus with Error message
end

view-->>act--: Display updated payout status on Dashboard
@enduml
