@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Filter Instructor's Transaction History

actor "Instructor" as act
participant "EarningsDashboard" as view
participant "LoginPage" as login_view
participant "TransactionController" as fe_tx_ctrl <<frontend controller>>
participant "TransactionController" as be_tx_ctrl <<backend controller>>
participant ":TransactionService" as tx_sv
participant ":TransactionRepository" as tx_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
view ++

act -> view: Enter keyword, select status, month, year \n& click "Filter" (or "Reset")
view -> fe_tx_ctrl++: GET /Transaction/Instructor?keyword={k}&status={s}&year={y}&month={m}

fe_tx_ctrl -> fe_tx_ctrl++: Validate filter inputs & \nCheck Cookies["InstructorApprovalStatus"]
fe_tx_ctrl--

alt Not Approved Instructor
    fe_tx_ctrl -->> view: Return statusCode 302
    view -->> act: Redirect to /Instructor/ApplicationStatus
else Approved Instructor
    fe_tx_ctrl -> be_tx_ctrl++: GET /api/transactions/instructor\n(paged, filtered by keyword, status, year, month)
    
    alt Session Invalid / Unauthorized Access (EX-1)
        be_tx_ctrl -->> fe_tx_ctrl: Return statusCode 401
        fe_tx_ctrl -->> login_view: Redirect to /Account/Login
        activate login_view
        login_view -->> act: Display Login page
        deactivate login_view
    else Authorized
        be_tx_ctrl -> tx_sv++: GetInstructorTransactionsAsync(..., keyword, status, year, month)
        tx_sv -> tx_repo++: GetInstructorTransactionsAsync(..., keyword, status, year, month)
        tx_repo -> ctx++: Query Transactions with Where(keyword, status, year, month)
        ctx -> db++: Execute SELECT
        db -->> ctx--: Filtered Data
        ctx -->> tx_repo--: Transactions List
        tx_repo -->> tx_sv--: Return PagedResult
        tx_sv -->> be_tx_ctrl--: Return PagedResult
        be_tx_ctrl -->> fe_tx_ctrl--: Return statusCode 200 (TransactionPagedVM)
        
        alt No matching results found (A.9)
            fe_tx_ctrl -->> view: Return View with InstructorFinancePageVM
            view -->> act: Display "No purchases recorded for this period."
        else Has Matching Transactions
            fe_tx_ctrl -->> view--: Return View with InstructorFinancePageVM
            view -->> act--: Display filtered list of transactions
        end
    end

@enduml
