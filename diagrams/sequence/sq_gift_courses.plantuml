@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Gift Courses

actor User as act
participant "GiftSetupPage" as view
participant "GiftCheckoutPage" as checkout_view
participant "HomePage" as home_view
participant "GiftController" as fe_ctrl <<frontend controller>>
participant "CoursePublicController" as pub_ctrl <<backend controller>>
participant "GiftController" as be_ctrl <<backend controller>>
participant ":CourseQueryService" as pub_sv
participant ":GiftService" as gift_sv
participant ":CourseDetailResponse" as res
participant ":CourseRepository" as repo
participant ":UserRepository" as user_repo
participant ":AppDbContext" as ctx
database Database as db

act ++

act -> view++: Access Gift Setup page
view -> fe_ctrl++: GET /Gift/Setup?courseId={courseId}
fe_ctrl -> pub_ctrl++: GET /api/public/courses/{courseId}
pub_ctrl -> pub_sv++: GetCourseWithDetailsAsync(courseId, userId, role)
pub_sv -> repo++: GetCourseWithDetailsAsync(courseId)
repo -> ctx++: Courses.Include(...).FirstOrDefaultAsync(...)
ctx -> db++: Execute query
db -->> ctx--: Return data
ctx -->> repo--: Return Course entity or null
repo -->> pub_sv--: Return Course entity or null

pub_sv -> pub_sv++: Check if Course exists
pub_sv--
alt Course Not Found (EX-2)
    pub_sv -->> pub_ctrl--: throw KeyNotFoundException
    pub_ctrl -->> fe_ctrl--: Return statusCode 404
    fe_ctrl -->> home_view--: Redirect to Home page
    activate home_view
    home_view -->> act: Display Home page and error message
    deactivate home_view
else Course Found
    pub_sv -> res++: Call CourseDetailResponse(...)
    res -->> pub_sv--: Return CourseDetailResponse object
    pub_sv -->> pub_ctrl--: Return CourseDetailResponse object
    pub_ctrl -->> fe_ctrl--: Return statusCode 200
    fe_ctrl -->> view--: Return View
    view -->> act: Display Gift Setup page with course summary
end

act -> view: Fill in Gift details (Recipient Email, Name, Theme, Message)
act -> view: Click "Proceed to Payment" button

view -> view++: Validate form inputs
view--
opt Invalid form inputs (A.5)
    view -->> act: Highlight invalid fields and display inline error messages
end

view -> fe_ctrl++: POST /Gift/Setup
fe_ctrl -> be_ctrl++: GET /api/gift/check-recipient?email={recipientEmail}&courseId={courseId}
be_ctrl -> gift_sv++: IsRecipientEnrolledAsync(recipientEmail, courseId)

gift_sv -> user_repo++: GetAccountByEmailAsync(recipientEmail)
user_repo -> ctx++: Accounts.FirstOrDefaultAsync(...)
ctx -> db++: Execute query
db -->> ctx--: Return data
ctx -->> user_repo--: Return Account entity or null
user_repo -->> gift_sv--: Return Account entity or null

opt Account found
    gift_sv -> repo++: IsEnrolledAsync(accountId, courseId)
    repo -> ctx++: Enrollments.AnyAsync(...)
    ctx -> db++: Execute query
    db -->> ctx--: Return boolean
    ctx -->> repo--: Return boolean
    repo -->> gift_sv--: Return boolean
end

gift_sv -> gift_sv++: Check IsEnrolled
gift_sv--
alt Recipient Already Enrolled (A.6 / EX-6)
    gift_sv -->> be_ctrl: Return boolean (true)
    be_ctrl -->> fe_ctrl: Return statusCode 200
    fe_ctrl -->> view: Return View
    view -->> act--: Highlight recipient email field with error message\nand disable "Proceed to Payment" button
else Recipient Not Enrolled
    gift_sv -->> be_ctrl--: Return boolean (false)
    be_ctrl -->> fe_ctrl--: Return statusCode 200
    fe_ctrl -->> checkout_view--: Redirect to Gift Checkout page with gift details parameters
    activate checkout_view
    checkout_view -->> act--: Display Gift Checkout page
end

@enduml
