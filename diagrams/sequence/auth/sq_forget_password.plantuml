@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Forget Password (OTP Verification)
actor Guest as act

participant "ForgotPassword.cshtml" as view
participant "VerifyOtp.cshtml" as otp_view
participant "ResetPassword.cshtml" as reset_view
participant "Login.cshtml" as login_view
participant "AccountController" as fe_ctrl <<frontend controller>>
participant "AuthController" as be_ctrl <<backend controller>>
participant ":AuthService" as sv
participant ":EmailService" as email_sv
participant ":AppDbContext" as ctx
database Database as db

== Step 1: Request Password Reset ==
act++
act->view++: Access Forgot Password page\nand enter email address
act->view: Click "Submit" button
view->fe_ctrl++: Send POST /Account/ForgotPassword?email=...

fe_ctrl->be_ctrl++: Send POST /api/auth/forgot-password?email=...

be_ctrl->sv++: Call ForgotPasswordAsync(email)
sv->ctx++: Query Accounts table for Email
ctx->db++: Execute select query
db-->>ctx--: Return Account entity details
ctx-->>sv--: Return Account entity

alt [Email not found]
    sv-->>be_ctrl: Return null
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return statusCode 400
    view-->>act: Display "Email not found" error
else [Email exists]
    sv->sv++: Generate 6-digit OTP and set expiration (e.g. 5 mins)
    sv--
    sv->ctx++: Save OTP and expiration time to Account
    ctx->db++: Execute update query
    db-->>ctx--: Return result
    ctx-->>sv--: Return success
    sv->ctx++: SaveChangesAsync()
    ctx->db++: Commit changes
    db-->>ctx--: Return numberOfRowsAffected
    ctx-->>sv--: Return success
    sv->email_sv++: Send OTP email to User
    email_sv-->>sv--: Return send status
    sv-->>be_ctrl--: Return success message
    be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)
    fe_ctrl -> otp_view++: Redirect to Verify OTP page
    deactivate fe_ctrl
    deactivate view
    otp_view -->> act: Display OTP input form
end

== Step 2: Verify OTP ==
act->otp_view: Enter OTP and click "Verify"
otp_view->fe_ctrl++: Send POST /Account/VerifyOtp with OTP

fe_ctrl->be_ctrl++: Send POST /api/auth/verify-otp with Email and OTP DTO
be_ctrl->sv++: Call VerifyOtpForReset(email, otp)
sv->ctx++: Query Accounts table for valid OTP
ctx->db++: Execute select query
db-->>ctx--: Return OTP status (valid / expired)
ctx-->>sv--: Return OTP status

alt [OTP invalid or expired]
    sv-->>be_ctrl: Return false
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>otp_view: Return statusCode 400
    otp_view-->>act: Display "Incorrect or expired OTP" error
else [OTP is valid]
    sv-->>be_ctrl--: Return true
    be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)
    fe_ctrl -> reset_view++: Redirect to Reset Password page
    deactivate fe_ctrl
    deactivate otp_view
    reset_view -->> act: Display Reset Password form
end

== Step 3: Reset Password ==
act->reset_view: Enter new password and click "Reset"
reset_view->fe_ctrl++: Send POST /Account/ResetPassword with email, otp, and newPassword

fe_ctrl->be_ctrl++: Send POST /api/auth/reset-password with ResetPasswordRequest JSON
be_ctrl->sv++: Call ResetPasswordAsync(email, otp, newPassword)

sv->ctx++: Retrieve Account & Verify OTP one last time
ctx->db++: Execute select query
db-->>ctx--: Return Account & OTP status
ctx-->>sv--: Return Account & OTP status

sv->sv++: Hash new password
sv--
sv->ctx++: Update password hash & clear OTP record on Account
ctx->db++: Execute update query
db-->>ctx--: Return result
ctx-->>sv--: Return success

sv->ctx++: SaveChangesAsync()
ctx->db++: Commit changes
db-->>ctx--: Return numberOfRowsAffected
ctx-->>sv--: Return success

sv-->>be_ctrl--: Return true
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)
fe_ctrl -> login_view++: Redirect to Login page
deactivate fe_ctrl
deactivate reset_view
login_view -->> act--: Display Login page with "Password changed successfully" message
@enduml
