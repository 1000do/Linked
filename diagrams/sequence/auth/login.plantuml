@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Login
actor User as act

participant "Login.cshtml" as view
participant "AccountController (FE)" as fe_ctrl
participant "AuthController (BE)" as be_ctrl
participant ":AuthService" as auth_sv
database Database as db

act++
act->view++: Enter Username/Email and Password\nand click "Sign In" button
view->fe_ctrl++: Send POST /Account/Login with form body

fe_ctrl->be_ctrl++: Send POST /api/auth/login with LoginRequest JSON

be_ctrl->auth_sv++: Call LoginAsync(request)
auth_sv->db++: Query Account by Username or Email
db-->>auth_sv--: Return Account entity with password hash and role

auth_sv->auth_sv++: Verify password hash match
auth_sv--

alt [Invalid credentials]
    auth_sv-->>be_ctrl: Return null
    be_ctrl-->>fe_ctrl: Return statusCode 401 (Unauthorized)
    fe_ctrl->fe_ctrl++: Parse error message to display
    fe_ctrl--
    fe_ctrl-->>view: Return View(model) with error
    view-->>act: Display "Incorrect username/email or password" error
else [Valid credentials]
    auth_sv->auth_sv++: Generate JWT AccessToken (24h) and RefreshToken (7d)
    auth_sv--
    auth_sv-->>be_ctrl--: Return LoginResponse DTO
    
    be_ctrl->be_ctrl++: Append HttpOnly cookies to response (API path)
    be_ctrl--
    be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with LoginResponse JSON
    
    fe_ctrl->fe_ctrl++: Append HttpOnly cookies (AccessToken, RefreshToken)\nand client-readable cookies (UserRole, UserName, AvatarUrl, UserId, IsVerified)
    fe_ctrl--
    
    alt [UserRole is Admin or Staff]
        fe_ctrl-->>view: Redirect to /Notification/Admin
    else [UserRole is Learner (User) or Instructor]
        fe_ctrl-->>view: Redirect to /Home/Index
    end
    view-->>act--: Display appropriate home / dashboard page
end
@enduml
