@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Forget Password (OTP Verification)
actor Guest as act

participant "ForgotPassword.cshtml" as view
participant "VerifyOtp.cshtml" as otp_view
participant "ResetPassword.cshtml" as reset_view
participant "AccountController (FE)" as fe_ctrl
participant "AuthController (BE)" as be_ctrl
participant ":AuthService" as auth_sv
participant ":EmailService" as email_sv
database Database as db

== Step 1: Request Password Reset ==
act++
act->view++: Access Forgot Password page\nand enter email address
act->view: Click "Submit" button
view->fe_ctrl++: Send POST /Account/ForgotPassword?email=...

fe_ctrl->be_ctrl++: Send POST /api/auth/forgot-password?email=...

be_ctrl->auth_sv++: Call ForgotPasswordAsync(email)
auth_sv->db++: Query Account by email
db-->>auth_sv--: Return Account entity

alt [Email not found]
    auth_sv-->>be_ctrl: Return error ("Email not found")
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return View with ErrorMessage
    view-->>act: Display "Email not found" warning
else [Email exists]
    auth_sv->auth_sv++: Generate 6-digit OTP and set expiration (e.g. 5 mins)
    auth_sv--
    auth_sv->db++: Save OTP and expiration time
    db-->>auth_sv--: Return success
    auth_sv->email_sv++: Send OTP email to User
    email_sv-->>auth_sv--: Return send status
    auth_sv-->>be_ctrl--: Return "OTP sent" success message
    be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)
    fe_ctrl-->>view--: Redirect to /Account/VerifyOtp
end

== Step 2: Verify OTP ==
view->otp_view++: Display OTP input form
act->otp_view: Enter OTP and click "Verify"
otp_view->fe_ctrl++: Send POST /Account/VerifyOtp with OTP

fe_ctrl->be_ctrl++: Send POST /api/auth/verify-otp with Email and OTP DTO
be_ctrl->auth_sv++: Call VerifyOtpForReset(email, otp)
auth_sv->db++: Query valid OTP entry
db-->>auth_sv--: Return OTP status (valid / expired)

alt [OTP invalid or expired]
    auth_sv-->>be_ctrl: Return false
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>otp_view: Return View with ErrorMessage
    otp_view-->>act: Display "Incorrect or expired OTP" error
else [OTP is valid]
    auth_sv-->>be_ctrl--: Return true
    be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)
    fe_ctrl-->>otp_view--: Redirect to /Account/ResetPassword
end

== Step 3: Reset Password ==
otp_view->reset_view++: Display Reset Password form
act->reset_view: Enter new password and click "Reset"
reset_view->fe_ctrl++: Send POST /Account/ResetPassword with email, otp, and newPassword

fe_ctrl->be_ctrl++: Send POST /api/auth/reset-password with ResetPasswordRequest JSON
be_ctrl->auth_sv++: Call ResetPasswordAsync(email, otp, newPassword)

auth_sv->db++: Retrieve Account & Verify OTP one last time
db-->>auth_sv--: Return success

auth_sv->auth_sv++: Hash new password
auth_sv--
auth_sv->db++: Update password hash & delete OTP record
db-->>auth_sv--: Return success
auth_sv->db++: Commit changes
db-->>auth_sv--: Return success

auth_sv-->>be_ctrl--: Return true
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)
fe_ctrl-->>reset_view--: Redirect to /Account/Login with success message
reset_view-->>act--: Display Login page with "Password changed successfully" Toast
@enduml
