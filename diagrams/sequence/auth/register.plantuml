@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Register
actor Guest as act

participant "Register.cshtml" as view
participant "AccountControllerFE" as fe_ctrl
participant "AuthControllerBE" as be_ctrl
participant ":AuthService" as sv
participant ":UserRepository" as repo
database Database as db

act++
act->view++: Access registration page,\nenter details, and click "Register"
view->fe_ctrl++: Send POST /Account/Register (with RegisterViewModel)

fe_ctrl->be_ctrl++: Send POST /api/auth/register (with RegisterRequest JSON)

be_ctrl->sv++: Call RegisterAsync(request)

sv->repo++: Call IsEmailExistsAsync(email)
repo->db++: Query Accounts where Email = email
db-->>repo--: Return boolean
repo-->>sv--: Return true/false
alt [Email already exists]
    sv-->>be_ctrl: Return "Email is already in use."
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest) with message
    fe_ctrl-->>view: Return View with ErrorMessage
    view-->>act: Display "Email is already in use" warning
end

sv->repo++: Call IsUsernameExistsAsync(username)
repo->db++: Query Accounts where Username = username
db-->>repo--: Return boolean
repo-->>sv--: Return true/false
alt [Username already exists]
    sv-->>be_ctrl: Return "Username is already in use."
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest) with message
    fe_ctrl-->>view: Return View with ErrorMessage
    view-->>act: Display "Username is already in use" warning
end

sv->sv++: Hash password using BCrypt / Identity hasher
sv--

sv->sv++: Instantiate new Account & User entities\n(AccountStatus = "Active", IsVerified = false)
sv--

sv->repo++: Call RegisterUserAsync(account, user)
repo->db++: Add Account & User to DbSets and call SaveChangesAsync()
db-->>repo--: Return rows affected / success
repo-->>sv--: Return true
sv-->>be_ctrl--: Return "Success"

be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)
fe_ctrl-->>view--: Redirect to GET /Account/Login with success message
view-->>act--: Display Login page with "Account registered successfully" toast
@enduml
