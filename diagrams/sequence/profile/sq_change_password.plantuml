@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Change Password
actor User as act

participant "ChangePasswordView" as view
participant "LoginView" as r_view
participant "AccountController" as fe_ctrl <<frontend controller>>
participant "ProfileController" as be_ctrl <<backend controller>>
participant ":UserProfileService" as sv
participant ":UserRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Enter current, new, and confirm passwords
act->view: Click "Change Password"
view->view++: Validate input
view--
group opt [Invalid input]
    view-->>act: Display validation errors
end

view->fe_ctrl++: Send POST /Account/ChangePassword

fe_ctrl->fe_ctrl++: Check AccessToken cookie
fe_ctrl--
group opt [No AccessToken]
    fe_ctrl-->>view: Return statusCode 302
    view->r_view++: Redirect to Login page
    r_view-->>act: Display Login page
    deactivate r_view
end

fe_ctrl->fe_ctrl++: Validate passwords match
fe_ctrl--
group opt [Passwords do not match]
    fe_ctrl-->>view: Return statusCode 200 (with ErrorMessage)
    view-->>act: Display mismatch error message
end

fe_ctrl->be_ctrl++: Send POST /api/Profile/change-password (with AccessToken)

be_ctrl->be_ctrl++: Validate ModelState
be_ctrl--
group opt [Invalid ModelState]
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return statusCode 200 (with ErrorMessage)
    view-->>act: Display error message
end

be_ctrl->be_ctrl++: Validate login session & Parse userId
be_ctrl--
group opt [Invalid login session]
    be_ctrl-->>fe_ctrl: Return statusCode 401 (Unauthorized)
    fe_ctrl-->>view: Return statusCode 200 (with ErrorMessage)
    view-->>act: Display error message
end

be_ctrl->sv++: Call ChangePasswordAsync(userId, currentPassword, newPassword)

sv->repo++: Call GetUserByIdAsync(userId)
repo->ctx++: Query User joined with navigation details
ctx->db++: Execute SELECT query
db-->>ctx--: Return user record
ctx-->>repo--: Return User entity
repo-->>sv--: Return User entity

group opt [User or Account not found]
    sv-->>be_ctrl: Return (false, "User profile not found.")
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return statusCode 200 (with ErrorMessage)
    view-->>act: Display error message
end

group opt [PasswordHash is empty (OAuth Account)]
    sv-->>be_ctrl: Return (false, "Your account is linked...")
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return statusCode 200 (with ErrorMessage)
    view-->>act: Display error message
end

sv->sv++: Verify currentPassword using BCrypt
sv--
group opt [Current password invalid]
    sv-->>be_ctrl: Return (false, "Current password is incorrect.")
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return statusCode 200 (with ErrorMessage)
    view-->>act: Display error message
end

sv->sv++: Hash newPassword and update Account properties
sv--

sv->repo++: Call UpdateAccountAsync(account)
repo->ctx++: Mark Account as modified
ctx-->>repo--: Return

repo->ctx++: Call SaveChangesAsync()
ctx->db++: Execute UPDATE statement
db-->>ctx--: Return result
ctx-->>repo--: Return numberOfRowsAffected
repo->repo++: Check numberOfRowsAffected
repo--

alt [numberOfRowsAffected > 0]
    repo-->>sv: Return true
    sv-->>be_ctrl--: Return (true, "Password changed successfully.")
    be_ctrl-->>fe_ctrl--: Return statusCode 200 (Success)
    
    fe_ctrl->be_ctrl++: Send POST /api/Auth/logout
    be_ctrl-->>fe_ctrl--: Return statusCode 200
    
    fe_ctrl->fe_ctrl++: Delete authentication cookies
    fe_ctrl--
    
    fe_ctrl->r_view++: Redirect to Login page
    deactivate fe_ctrl
    deactivate view
    r_view-->>act--: Display login page with success message
else [numberOfRowsAffected = 0 or Exception]
    repo-->>sv: Return false
    sv-->>be_ctrl--: Return (false, "An error occurred while changing password.")
    be_ctrl-->>fe_ctrl--: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view--: Return statusCode 200 (with ErrorMessage)
    view-->>act--: Display error message
end
@enduml
