@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Profile
actor User as act

participant "Account/Profile.cshtml" as view
participant "AccountController" as fe_ctrl <<frontend controller>>
participant "ProfileController" as be_ctrl <<backend controller>>
participant ":UserProfileService" as sv
participant ":UserRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Access profile page
view->fe_ctrl++: Send GET /Account/Profile

fe_ctrl->fe_ctrl++: Check AccessToken cookie
fe_ctrl--
group opt [No AccessToken]
    fe_ctrl-->>view: Redirect to /Account/Login
    view-->>act: Display login page
end

fe_ctrl->be_ctrl++: Send GET /api/Profile (with AccessToken)

be_ctrl->be_ctrl++: Validate login session & Parse userId
be_ctrl--
group opt [Invalid login session]
    be_ctrl-->>fe_ctrl: Return statusCode 401 (Unauthorized)
    fe_ctrl-->>view: Redirect to /Account/Login
    view-->>act: Display login page
end

be_ctrl->sv++: Call GetUserProfileAsync(userId)

sv->repo++: Call GetUserByIdAsync(userId)
repo->ctx++: Query User joined with navigation details
ctx->db++: Execute SELECT query
db-->>ctx--: Return user record
ctx-->>repo--: Return User entity
repo-->>sv--: Return User entity

sv->sv++: Check user != null
sv--

alt [user == null]
    sv-->>be_ctrl: Return null
    be_ctrl-->>fe_ctrl: Return statusCode 404 (NotFound)
    fe_ctrl-->>view: Redirect to /Account/Login
    view-->>act: Display login page
else [user != null]
    sv-->>be_ctrl--: Return UserProfileResponse DTO
    be_ctrl-->>fe_ctrl--: Return statusCode 200 with user profile data
    
    fe_ctrl->fe_ctrl++: Read response and check IsVerified
    fe_ctrl--
    fe_ctrl->fe_ctrl++: Append IsVerified cookie
    fe_ctrl--
    fe_ctrl->view--: Return View with profile data
    view-->>act--: Display user profile information
end
@enduml
