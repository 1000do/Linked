@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Change Password

actor User as act

participant "ChangePasswordForm" as view
participant "LoginForm" as r_view
participant "AccountController" as fe_ctrl
participant "ProfileController" as be_ctrl
participant ":UserProfileService" as sv
participant ":Account" as ett_a
participant ":UserRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Enter current password, new password, confirm new password
act->view: Click "Change Password" button
view->view++: Validate input
view--
group opt [Invalid input]
    view-->>act: Display validation errors
end

view->fe_ctrl++: Send POST request to Account/ChangePassword

fe_ctrl->fe_ctrl++: Check AccessToken cookie
fe_ctrl--
group opt [No AccessToken]
    fe_ctrl-->>view: Redirect to /Account/Login
    view-->>act: Display login page
end

fe_ctrl->fe_ctrl++: Validate newPassword matches confirmNewPassword
fe_ctrl--
group opt [Passwords do not match]
    fe_ctrl-->>view: Return View with ErrorMessage
    view-->>act: Display "Password confirmation does not match" error
end

fe_ctrl->be_ctrl++: Send POST request to /api/Profile/change-password (with AccessToken)

be_ctrl->be_ctrl++: Validate ModelState
be_ctrl--
group opt [Invalid ModelState]
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return statusCode 400 with error
    view-->>act: Display error message
end

be_ctrl->be_ctrl++: Validate login session & Parse userId
be_ctrl--
group opt [Invalid login session]
    be_ctrl-->>fe_ctrl: Return statusCode 401 (Unauthorized)
    fe_ctrl-->>view: Redirect to /Account/Login
    view-->>act: Display login page
end

be_ctrl->sv++: Call ChangePasswordAsync(userId, currentPassword, newPassword)

sv->repo++: Call GetUserByIdAsync(userId)
repo->ctx++: Fetch user with navigation & instructor details
ctx->db++: Query user, account, and instructor tables
db-->>ctx--: Return database record
ctx-->>repo--: Return User entity
repo-->>sv--: Return User entity

sv->sv++: Check user != null
sv--
group opt [User not found]
    sv-->>be_ctrl: Return (false, "User profile not found.")
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return statusCode 400
    view-->>act: Display error message
end

sv->sv++: Check if PasswordHash is empty (OAuth Account)
sv--
group opt [PasswordHash is empty]
    sv-->>be_ctrl: Return (false, "Your account is linked...")
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return statusCode 400
    view-->>act: Display error message
end

sv->sv++: Verify currentPassword using BCrypt
sv--
group opt [Current password invalid]
    sv-->>be_ctrl: Return (false, "Current password is incorrect.")
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view: Return statusCode 400
    view-->>act: Display error message
end

sv->sv++: Hash newPassword and update Account properties
sv--

sv->repo++: Call UpdateAccountAsync(account)
repo->ctx++: Update Account entity
ctx-->>repo--: Done
repo->ctx++: Call SaveChangesAsync()
ctx->db++: Save changes to Database
db-->>ctx--: Return numberOfRowsAffected
ctx-->>repo--: Return numberOfRowsAffected
repo-->>sv--: Return success (boolean)

alt updated == true
    sv-->>be_ctrl: Return (true, "Password changed successfully.")
    be_ctrl-->>fe_ctrl: Return statusCode 200 (Success)
    
    fe_ctrl->be_ctrl++: Send POST request to /api/Auth/logout
    be_ctrl-->>fe_ctrl--: Return status code 200
    
    fe_ctrl->fe_ctrl++: Delete AccessToken, RefreshToken, and user display cookies
    fe_ctrl--
    
    fe_ctrl->r_view++: Redirect to Login view with success message
    r_view-->>act--: Display "Password changed successfully! Please login again."
else updated == false
    sv-->>be_ctrl--: Return (false, "An error occurred while changing password.")
    be_ctrl-->>fe_ctrl--: Return statusCode 400 (BadRequest)
    fe_ctrl-->>view--: Return statusCode 400 with error
    view-->>act--: Display change password error message
end

@enduml
