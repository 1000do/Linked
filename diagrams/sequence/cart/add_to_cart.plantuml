@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Add to Cart
actor User as act

participant "CourseDetail.cshtml" as view
participant "CartController (FE)" as fe_ctrl
participant "CartController (BE)" as be_ctrl
participant ":AuthService" as auth_sv
participant ":CartService" as sv
participant ":CourseRepository" as courseRepo
participant ":CartRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Click "Add to Cart" button
view->fe_ctrl++: Send POST AJAX request to /Cart/AddToCartAjax/{courseId}

fe_ctrl->be_ctrl++: Send POST /api/cart/add (with Bearer Token & courseId)

be_ctrl->auth_sv++: Call IsEmailVerifiedAsync(userId)
auth_sv->ctx++: Check EmailVerification status
ctx->db++: Execute SELECT query
db-->>ctx--: Return verification status
ctx-->>auth_sv--: Return verification status
auth_sv-->>be_ctrl--: Return isVerified

alt [Email is not verified]
    be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest) with verification error
    fe_ctrl-->>view: Return JSON { success = false, message = "Email verification required" }
    view-->>act: Display verification warning message
else [Email is verified]
    be_ctrl->sv++: Call AddToCartAsync(userId, courseId)
    
    sv->courseRepo++: Call IsEnrolledAsync(userId, courseId)
    courseRepo->ctx++: Query student enrollments for course
    ctx->db++: Execute SELECT query
    db-->>ctx--: Return enrollment status
    ctx-->>courseRepo--: Return status
    courseRepo-->>sv--: Return status
    
    alt [User already enrolled in course]
        sv-->>be_ctrl: Throw InvalidOperationException / AlreadyEnrolledException
    else [User not enrolled]
        sv->repo++: Call IsCourseInCartAsync(userId, courseId)
        repo->ctx++: Query CartItems
        ctx->db++: Execute SELECT query
        db-->>ctx--: Return boolean in-cart status
        ctx-->>repo--: Return status
        repo-->>sv--: Return status
        
        alt [Course is already in cart]
            sv-->>be_ctrl: Throw InvalidOperationException / AlreadyInCartException
        else [Course is not in cart]
            sv->courseRepo++: Call GetByIdAsync(courseId)
            courseRepo->ctx++: Query Course details
            ctx->db++: Execute SELECT query
            db-->>ctx--: Return Course entity
            ctx-->>courseRepo--: Return entity
            courseRepo-->>sv--: Return entity
            
            sv->repo++: Call AddCartItemAsync(item)
            repo->ctx++: Add CartItem entity to context
            ctx-->>repo--: Return
            repo-->>sv--: Return
            
            sv->repo++: Call SaveChangesAsync()
            repo->ctx++: Call SaveChangesAsync()
            ctx->db++: Execute INSERT into Database
            db-->>ctx--: Return rows affected
            ctx-->>repo--: Return result
            repo-->>sv--: Return result
            
            sv-->>be_ctrl--: Return completion Task
        end
    end
    
    alt [Add to Cart fails (already enrolled / already in cart)]
        be_ctrl-->>fe_ctrl: Return statusCode 400 (BadRequest) with error message
        fe_ctrl-->>view: Return JSON { success = false, message = "..." }
        view-->>act: Display error Toast message
    else [Add to Cart succeeds]
        be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)
        fe_ctrl-->>view--: Return JSON { success = true }
        view-->>act--: Display success Toast message and increment cart badge count
    end
end
@enduml
