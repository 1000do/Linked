@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Delete Cart Items
actor User as act

participant "Cart/Index.cshtml" as view
participant "CartController (FE)" as fe_ctrl
participant "CartController (BE)" as be_ctrl
participant ":CartService" as sv
participant ":CartRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Click "Remove" button next to cart item
view->fe_ctrl++: Send POST AJAX request to /Cart/RemoveFromCart?courseId=...

fe_ctrl->be_ctrl++: Send DELETE /api/cart/remove?courseId=... (with Bearer Token)

be_ctrl->sv++: Call RemoveFromCartAsync(userId, courseId)
sv->repo++: Call GetCartItemAsync(userId, courseId)
repo->ctx++: Query CartItem matching userId and courseId
ctx->db++: Execute SELECT query
db-->>ctx--: Return CartItem entity
ctx-->>repo--: Return CartItem entity
repo-->>sv--: Return CartItem entity

alt [CartItem not found]
    sv-->>be_ctrl: Throw KeyNotFoundException / InvalidOperationException
    be_ctrl-->>fe_ctrl: Return statusCode 404 (NotFound)
    fe_ctrl-->>view: Return JSON { success = false, message = "Item not found in cart" }
    view-->>act: Display item removal error Toast
else [CartItem found]
    sv->repo++: Call RemoveCartItem(item)
    repo->ctx++: Remove entity from DB context
    ctx-->>repo--: Return
    repo-->>sv--: Return
    
    sv->repo++: Call SaveChangesAsync()
    repo->ctx++: Call SaveChangesAsync()
    ctx->db++: Execute DELETE from Database
    db-->>ctx--: Return rows affected
    ctx-->>repo--: Return result
    repo-->>sv--: Return result
    
    sv-->>be_ctrl--: Return completion Task
    be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok)
    fe_ctrl-->>view--: Return JSON { success = true }
    view->view++: Remove item DOM element and update subtotal/total calculations
    view--
    view-->>act--: Display success Toast and update cart badge count
end
@enduml
