@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Cancel Coupons
actor User as act

participant "Cart/Index.cshtml" as view
participant "CartController (FE)" as fe_ctrl
participant "CartController (BE)" as be_ctrl
participant ":CartService" as sv
participant ":CartRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++: Click "Cancel" / "Remove Coupon" button next to applied coupon
view->fe_ctrl++: Send POST request to /Cart/RemoveCoupon?courseId=...

fe_ctrl->fe_ctrl++: Retrieve applied coupon map from cookies
fe_ctrl--
fe_ctrl->fe_ctrl++: Remove coupon entry from cookie map
fe_ctrl--
fe_ctrl-->>view: Redirect to GET /Cart

view->fe_ctrl: Send GET request to /Cart
fe_ctrl->be_ctrl++: Send GET /api/cart/summary (without couponCode query)

be_ctrl->sv++: Call GetCartSummaryAsync(userId, null)
sv->repo++: Call GetCartItemsWithDetailsAsync(userId)
repo->ctx++: Query CartItems with Course details
ctx->db++: Execute SELECT query
db-->>ctx--: Return CartItems list
ctx-->>repo--: Return CartItems list
repo-->>sv--: Return CartItems list

sv->sv++: Calculate original prices (no discounts applied)
sv--

sv-->>be_ctrl--: Return CartSummaryResponse
be_ctrl-->>fe_ctrl--: Return statusCode 200 (Ok) with JSON data

fe_ctrl->fe_ctrl++: Map to CartViewModel
fe_ctrl--
fe_ctrl-->>view--: Return View(vm)
view-->>act--: Display cart items with original prices and cleared coupon input
@enduml
