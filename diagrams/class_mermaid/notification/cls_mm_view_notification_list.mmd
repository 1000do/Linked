%% ==================== FRONTEND ====================

class FrontendController["NotificationController"] {
    <<frontend controller>>
    + Index() Task~IActionResult~
    + GetListTiny() Task~IActionResult~
    + GetMyNotifications() Task~IActionResult~
    + GetUnreadSummary() Task~IActionResult~
}

class NotificationViewModel {
    <<view model>>
    + NotificationId : int
    + ReceiverId : int
    + ReceiverFullName : string?
    + ReceiverEmail : string?
    + Title : string
    + Content : string
    + LinkAction : string?
    + IsRead : bool
    + CreatedAt : DateTime?
    + ReceiverRole : string?
    + SenderId : int?
    + SenderRole : string?
}

%% ==================== BACKEND - CONTROLLER ====================

class BackendController["NotificationController"] {
    <<backend controller>>
    - _notiService : INotificationService
    - _chatService : IChatService
    
    + GetMyNotifications(page: int, pageSize: int) Task~IActionResult~
    + GetUnreadSummary() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class NotificationResponseDto {
    <<dto>>
    + NotificationId : int
    + SenderId : int
    + ReceiverId : int
    + Title : string
    + Content : string
    + LinkAction : string?
    + IsRead : bool?
    + CreatedAt : DateTime
}

class PagedResultNotificationResponseDto["PagedResult~NotificationResponseDto~"] {
    <<dto>>
    + Items : List~NotificationResponseDto~?
    + TotalCount : int
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Notification {
    + NotificationId : int
    + SenderId : int?
    + ReceiverId : int?
    + Title : string?
    + Content : string?
    + LinkAction : string?
    + IsRead : bool?
    + IsRemoved : bool?
    + CreatedAt : DateTime?
    + Receiver : Account?
    + Sender : Account?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class INotificationService {
    <<interface>>
    + GetNotificationsForUserAsync(userId: int, page: int, pageSize: int) Task~PagedResult~NotificationResponseDto~~ *
    + GetUnreadCountAsync(userId: int) Task~int~ *
}

class IChatService {
    <<interface>>
    + GetTotalUnreadCountAsync(accountId: int) Task~int~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class INotificationRepository {
    <<interface>>
    + GetByReceiverIdAsync(userId: int, page: int, pageSize: int) Task~(List~Notification~ Items, int TotalCount)~ *
    + GetUnreadCountAsync(userId: int) Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class NotificationService {
    - _repo : INotificationRepository
    
    + GetNotificationsForUserAsync(userId: int, page: int, pageSize: int) Task~PagedResult~NotificationResponseDto~~
    + GetUnreadCountAsync(userId: int) Task~int~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class NotificationRepository {
    - _context : AppDbContext
    
    + GetByReceiverIdAsync(userId: int, page: int, pageSize: int) Task~(List~Notification~ Items, int TotalCount)~
    + GetUnreadCountAsync(userId: int) Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Notifications : DbSet~Notification~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

