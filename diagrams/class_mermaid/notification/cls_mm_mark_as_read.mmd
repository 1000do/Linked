classDiagram
direction LR

%% ==================== BACKEND - CONTROLLER ====================

class NotificationControllerBE["NotificationController"] {
    <<backend controller>>
    - _notiService : INotificationService
    + MarkAsRead(id: int) Task~IActionResult~
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Notification {
    + NotificationId : int
    + SenderId : int?
    + ReceiverId : int?
    + Title : string?
    + Content : string?
    + LinkAction : string?
    + IsRead : bool?
    + IsRemoved : bool?
    + CreatedAt : DateTime?
    + Receiver : Account?
    + Sender : Account?
}

class Account {
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
    + User : User?
}

class User {
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class INotificationService {
    <<interface>>
    + MarkAsReadAsync(notificationId: int, userId: int) Task~bool~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class INotificationRepository {
    <<interface>>
    + MarkAsReadAsync(notificationId: int, userId: int) Task~bool~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class NotificationService {
    - _repo : INotificationRepository
    + MarkAsReadAsync(notificationId: int, userId: int) Task~bool~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class NotificationRepository {
    - _context : AppDbContext
    + MarkAsReadAsync(notificationId: int, userId: int) Task~bool~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Notifications : DbSet~Notification~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION ===
Account *-- User
Account *-- Notification

%% === UNIDIRECTIONAL ASSOCIATION ===
NotificationControllerBE --> INotificationService
NotificationService --> INotificationRepository
NotificationRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
NotificationService ..|> INotificationService
NotificationRepository ..|> INotificationRepository

%% === DEPENDENCY ===
NotificationRepository ..> Notification

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
