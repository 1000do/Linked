%% ==================== FRONTEND ====================

class FrontendController["NotificationController"] {
    <<frontend controller>>
    - _client : HttpClient
    + Index() Task~IActionResult~
    + GetListTiny() Task~IActionResult~
    + Admin() IActionResult
}

class NotificationViewModel {
    <<view model>>
    + NotificationId : int
    + ReceiverId : int
    + ReceiverFullName : string?
    + ReceiverEmail : string?
    + Title : string
    + Content : string
    + LinkAction : string?
    + IsRead : bool
    + CreatedAt : DateTime?
    + ReceiverRole : string?
    + SenderId : int?
    + SenderRole : string?
}

%% ==================== BACKEND - CONTROLLER ====================

class BackendController["NotificationController"] {
    <<backend controller>>
    - _notiService : INotificationService
    - _chatService : IChatService
    + GetMyNotifications() Task~IActionResult~
    + GetAllNotifications() Task~IActionResult~
    + MarkAsRead(id: int) Task~IActionResult~
    + Delete(id: int) Task~IActionResult~
    + SearchEmails(query: string) Task~IActionResult~
    + SendTest(dto: NotificationSendDto) Task~IActionResult~
    + SendAdvanced(dto: NotificationAdvancedDto) Task~IActionResult~
    + GetUnreadSummary() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class NotificationSendDto {
    <<dto>>
    + ReceiverId : int
    + Title : string
    + Content : string
}

class NotificationAdvancedDto {
    <<dto>>
    + TargetType : string
    + Emails : List~string~?
    + Title : string
    + Content : string
}

class NotificationAdminResponseDto {
    <<dto>>
    + NotificationId : int
    + Title : string?
    + Content : string?
    + IsRead : bool?
    + CreatedAt : DateTime?
    + ReceiverEmail : string?
    + ReceiverFullName : string?
}

class NotificationBulkDto {
    <<dto>>
    + ReceiverId : int
    + Title : string
    + Content : string
    + LinkAction : string?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Notification {
    + NotificationId : int
    + SenderId : int?
    + ReceiverId : int?
    + Title : string?
    + Content : string?
    + LinkAction : string?
    + IsRead : bool?
    + IsRemoved : bool?
    + CreatedAt : DateTime?
    + Receiver : Account?
    + Sender : Account?
}

class Account {
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
    + User : User?
    + Manager : Manager?
    + NotificationReceivers : ICollection~Notification~
    + NotificationSenders : ICollection~Notification~
}

class User {
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class INotificationService {
    <<interface>>
    + GetNotificationsForUserAsync(userId: int) Task~List~Notification~~ *
    + GetAllNotificationsForAdminAsync() Task~List~NotificationAdminResponseDto~~ *
    + SendNotificationAsync(receiverId: int, title: string, content: string, linkAction: string?) Task *
    + SendBulkNotificationsAsync(dtos: IEnumerable~NotificationBulkDto~) Task *
    + DeleteNotificationAsync(notiId: int, userId: int) Task~bool~ *
    + GetAllNotificationsAsync() Task~List~Notification~~ *
    + MarkAsReadAsync(notificationId: int, userId: int) Task~bool~ *
    + SearchEmailsAsync(query: string) Task~List~string~~ *
    + GetUnreadCountAsync(userId: int) Task~int~ *
    + SendAdvancedAsync(dto: NotificationAdvancedDto) Task~int~ *
}

class IChatService {
    <<interface>>
    + GetTotalUnreadCountAsync(accountId: int) Task~int~ *
}

class INotificationRepository {
    <<interface>>
    + GetByReceiverIdAsync(userId: int) Task~List~Notification~~ *
    + GetByIdAsync(id: int) Task~Notification?~ *
    + AddAsync(notification: Notification) Task *
    + AddRangeAsync(notifications: IEnumerable~Notification~) Task *
    + Delete(notification: Notification) void *
    + SaveChangesAsync() Task~int~ *
    + GetAllAsync() Task~List~Notification~~ *
    + MarkAsReadAsync(notificationId: int, userId: int) Task~bool~ *
    + GetUnreadCountAsync(userId: int) Task~int~ *
    + AutoCleanupAdminNotificationsAsync() Task *
}

class IUserRepository {
    <<interface>>
    + GetAllUserIdsAsync() Task~List~int~~ *
    + GetUserIdByEmailAsync(email: string) Task~int?~ *
    + SearchEmailsByQueryAsync(query: string, take: int) Task~List~string~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class NotificationService {
    - _repo : INotificationRepository
    - _userRepo : IUserRepository
    - _hubContext : IHubContext~NotificationHub~
    + GetNotificationsForUserAsync(userId: int) Task~List~Notification~~
    + GetAllNotificationsAsync() Task~List~Notification~~
    + SendNotificationAsync(receiverId: int, title: string, content: string, linkAction: string?) Task
    + DeleteNotificationAsync(notiId: int, userId: int) Task~bool~
    + MarkAsReadAsync(notificationId: int, userId: int) Task~bool~
    + GetAllNotificationsForAdminAsync() Task~List~NotificationAdminResponseDto~~
    + SearchEmailsAsync(query: string) Task~List~string~~
    + GetUnreadCountAsync(userId: int) Task~int~
    + SendAdvancedAsync(dto: NotificationAdvancedDto) Task~int~
    + SendBulkNotificationsAsync(dtos: IEnumerable~NotificationBulkDto~) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class NotificationRepository {
    - _context : AppDbContext
    + GetByReceiverIdAsync(userId: int) Task~List~Notification~~
    + GetAllAsync() Task~List~Notification~~
    + GetByIdAsync(id: int) Task~Notification?~
    + Delete(notification: Notification) void
    + AddAsync(notification: Notification) Task
    + AddRangeAsync(notifications: IEnumerable~Notification~) Task
    + SaveChangesAsync() Task~int~
    + MarkAsReadAsync(notificationId: int, userId: int) Task~bool~
    + GetUnreadCountAsync(userId: int) Task~int~
    + AutoCleanupAdminNotificationsAsync() Task
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Accounts : DbSet~Account~
    + Notifications : DbSet~Notification~
    + Users : DbSet~User~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

