classDiagram
direction LR

%% ==================== FRONTEND ====================

class AdminModerationControllerFE["AdminModerationController"] {
    <<frontend controller>>
    + ApproveCourse(id: int, feedback: string?) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminModerationControllerBE["AdminModerationController"] {
    <<backend controller>>
    - _courseModerationService : ICourseModerationService
    
    + ApproveCourse(id: int, feedback: string?) Task~IActionResult~
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + CourseAiIntegrations : ICollection~CourseAiIntegration~
    + CartItems : ICollection~CartItem~
    + Category : Category?
    + Coupon : Coupon?
    + Enrollments : ICollection~Enrollment~
    + Instructor : Instructor?
    + Lessons : ICollection~Lesson~
    + OrderItems : ICollection~OrderItem~
    + WishlistItems : ICollection~WishlistItem~
    + CourseExt : CourseExt?
    + CourseQuizzes : ICollection~CourseQuiz~
    + FieldModerationFeedbacks : ICollection~CourseFieldModerationFeedback~
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

class LearningMaterial {
    <<entity>>
    + MaterialId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + LearningStatus : string?
    + ModerationFeedback : string?
    + MaterialUrl : string?
    + MaterialMetadata : MaterialMetadata?
    + CloudPublicId : string?
    + Lesson : Lesson?
    + TextEmbeddings : ICollection~TextEmbedding~
    + MediaEmbeddings : ICollection~MediaEmbedding~
    + MaterialCompletions : ICollection~MaterialCompletion~
}

class Lesson {
    <<entity>>
    + LessonId : int
    + CourseId : int?
    + Title : string
    + Description : string?
    + ThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + LessonStatus : string?
    + ModerationFeedback : string?
    + Course : Course?
    + LearningMaterials : ICollection~LearningMaterial~
    + LessonReviews : ICollection~LessonReview~
    + IsRemoved : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ICourseModerationService {
    <<service interface>>
    + ApproveCourseAsync(courseId: int, feedback: string?) Task~bool~ *
}

class ICourseRepository {
    <<repository interface>>
    + GetByIdAsync(courseId: int) Task~Course?~ *
    + Update(course: Course) void *
    + SaveChangesAsync() Task~int~ *
}

class IMaterialRepository {
    <<repository interface>>
    + GetByCourseIdAsync(courseId: int) Task~List~LearningMaterial~~ *
    + Update(material: LearningMaterial) void *
}

class ILessonRepository {
    <<repository interface>>
    + GetByCourseIdAsync(courseId: int) Task~List~Lesson~~ *
    + Update(lesson: Lesson) void *
}

class IEnrollmentRepository {
    <<repository interface>>
    + GetEnrolledUserIdsAsync(courseId: int) Task~List~int~~ *
}

class IEmbeddingService {
    <<service interface>>
    + PersistPendingMaterialEmbeddingsAsync(courseId: int, excludedMaterialIds: HashSet~int~) Task~int~ *
}

class INotificationService {
    <<service interface>>
    + SendNotificationAsync(receiverId: int, title: string, content: string, linkAction: string?) Task~bool~ *
    + SendBulkNotificationsAsync(dtos: IEnumerable~NotificationBulkDto~) Task~bool~ *
}

class IRedisService {
    <<service interface>>
    + RemoveCacheAsync(key: string) Task *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CourseModerationService {
    <<service>>
    - _courseRepository : ICourseRepository
    - _materialRepository : IMaterialRepository
    - _lessonRepository : ILessonRepository
    - _enrollmentRepository : IEnrollmentRepository
    - _embeddingService : IEmbeddingService
    - _notificationService : INotificationService
    - _redisService : IRedisService
    
    + ApproveCourseAsync(courseId: int, feedback: string?) Task~bool~
}

class EmbeddingService {
    <<service>>
    + PersistPendingMaterialEmbeddingsAsync(courseId: int, excludedMaterialIds: HashSet~int~) Task~int~
}

class NotificationService {
    <<service>>
    + SendNotificationAsync(receiverId: int, title: string, content: string, linkAction: string?) Task~bool~
    + SendBulkNotificationsAsync(dtos: IEnumerable~NotificationBulkDto~) Task~bool~
}

class RedisService {
    <<service>>
    + RemoveCacheAsync(key: string) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CourseRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByIdAsync(courseId: int) Task~Course?~
    + Update(course: Course) void
    + SaveChangesAsync() Task~int~
}

class MaterialRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByCourseIdAsync(courseId: int) Task~List~LearningMaterial~~
    + Update(material: LearningMaterial) void
}

class LessonRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByCourseIdAsync(courseId: int) Task~List~Lesson~~
    + Update(lesson: Lesson) void
}

class EnrollmentRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetEnrolledUserIdsAsync(courseId: int) Task~List~int~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Courses : DbSet~Course~
    + Materials : DbSet~LearningMaterial~
    + Lessons : DbSet~Lesson~
    + Enrollments : DbSet~Enrollment~
}

