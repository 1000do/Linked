classDiagram
direction LR

%% ==================== FRONTEND ====================

class FrontendController["ChatController"] {
    <<frontend controller>>
    + Search(q: string) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class BackendController["ChatController"] {
    <<backend controller>>
    - _chatService : IChatService
    + SearchChats(q: string) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class ChatListDto {
    <<dto>>
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + LastMessage : string?
    + LastMessageAt : DateTime?
    + PartnerName : string?
    + PartnerAvatar : string?
    + ContextType : string?
    + ContextId : int?
    + UnreadCount : int
    + IsOnline : bool
    + PartnerId : int?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Chat {
    <<entity>>
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + ContextType : string?
    + ContextId : int?
    + CreatedAt : DateTime?
    + LastMessageAt : DateTime?
}

class ChatParticipant {
    <<entity>>
    + ChatId : int
    + AccountId : int
    + Role : string
    + UnreadCount : int
    + LastReadAt : DateTime?
    + JoinedAt : DateTime?
    + ClearedAt : DateTime?
}

class Message {
    <<entity>>
    + MessageId : int
    + ChatId : int
    + SenderId : int?
    + Content : string
    + IsSeen : bool
    + MessageStatus : string
    + SentAt : DateTime?
    + ReceivedAt : DateTime?
}

class Account {
    <<entity>>
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
}

class User {
    <<entity>>
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

class Manager {
    <<entity>>
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IChatService {
    <<service interface>>
    + SearchChatsAsync(accountId: int, query: string) Task~List~ChatListDto~~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IChatRepository {
    <<repository interface>>
    + SearchParticipantsByAccountIdAsync(accountId: int, query: string) Task~List~ChatParticipant~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ChatService {
    <<service>>
    - _repo : IChatRepository
    + SearchChatsAsync(accountId: int, query: string) Task~List~ChatListDto~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ChatRepository {
    <<repository>>
    - _context : AppDbContext
    + SearchParticipantsByAccountIdAsync(accountId: int, query: string) Task~List~ChatParticipant~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Accounts : DbSet~Account~
    + Users : DbSet~User~
    + Managers : DbSet~Manager~
    + Chats : DbSet~Chat~
    + ChatParticipants : DbSet~ChatParticipant~
    + Messages : DbSet~Message~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
Account *-- User
Account *-- Manager
Chat *-- ChatParticipant
Chat *-- Message

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
ChatParticipant --> Account
Message --> Account
BackendController --> IChatService
ChatService --> IChatRepository
ChatRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
ChatService ..|> IChatService
ChatRepository ..|> IChatRepository

%% === DEPENDENCY (dashed arrows) ===
FrontendController ..> BackendController
BackendController ..> ChatListDto
ChatService ..> ChatListDto
ChatRepository ..> ChatParticipant

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
