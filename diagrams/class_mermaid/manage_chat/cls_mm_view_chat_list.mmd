classDiagram
direction LR

%% ==================== FRONTEND ====================

class FrontendController["ChatController"] {
    <<frontend controller>>
    + Admin() IActionResult
    + GetList() Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class BackendController["ChatController"] {
    <<backend controller>>
    - _chatService : IChatService
    + GetMyChats() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class ChatListDto {
    <<dto>>
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + LastMessage : string?
    + LastMessageAt : DateTime?
    + PartnerName : string?
    + PartnerAvatar : string?
    + ContextType : string?
    + ContextId : int?
    + UnreadCount : int
    + IsOnline : bool
    + PartnerId : int?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Chat {
    <<entity>>
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + ContextType : string?
    + ContextId : int?
    + CreatedAt : DateTime?
    + LastMessageAt : DateTime?
}

class ChatParticipant {
    <<entity>>
    + ChatId : int
    + AccountId : int
    + Role : string
    + UnreadCount : int
    + LastReadAt : DateTime?
    + JoinedAt : DateTime?
    + ClearedAt : DateTime?
}

class Account {
    <<entity>>
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
}

class User {
    <<entity>>
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

class Manager {
    <<entity>>
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IChatService {
    <<service interface>>
    + GetMyChatsAsync(accountId: int) Task~List~ChatListDto~~ *
}

class IRedisService {
    <<service interface>>
    + GetUnreadCountAsync(accountId: int, chatId: int) Task~int~ *
    + IsUserOnlineAsync(accountId: int) Task~bool~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IChatRepository {
    <<repository interface>>
    + GetParticipantsByAccountIdAsync(accountId: int) Task~List~ChatParticipant~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ChatService {
    <<service>>
    - _repo : IChatRepository
    - _redisService : IRedisService
    + GetMyChatsAsync(accountId: int) Task~List~ChatListDto~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ChatRepository {
    <<repository>>
    - _context : AppDbContext
    + GetParticipantsByAccountIdAsync(accountId: int) Task~List~ChatParticipant~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Accounts : DbSet~Account~
    + Users : DbSet~User~
    + Managers : DbSet~Manager~
    + Chats : DbSet~Chat~
    + ChatParticipants : DbSet~ChatParticipant~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
Account *-- User
Account *-- Manager
Chat *-- ChatParticipant

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
ChatParticipant --> Account
BackendController --> IChatService
ChatService --> IChatRepository
ChatService --> IRedisService
ChatRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
ChatService ..|> IChatService
ChatRepository ..|> IChatRepository

%% === DEPENDENCY (dashed arrows) ===
FrontendController ..> BackendController
BackendController ..> ChatListDto
ChatService ..> ChatListDto
ChatRepository ..> ChatParticipant

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
