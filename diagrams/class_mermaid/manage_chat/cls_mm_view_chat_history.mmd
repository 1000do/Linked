classDiagram
direction LR

%% ==================== FRONTEND ====================

class FrontendController["ChatController"] {
    <<frontend controller>>
    + GetHistory(roomId: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class BackendController["ChatController"] {
    <<backend controller>>
    - _chatService : IChatService
    + GetChatHistory(roomId: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class MessageDto {
    <<dto>>
    + MessageId : int
    + ChatId : int
    + SenderId : int?
    + SenderName : string
    + SenderAvatar : string?
    + Content : string
    + IsSeen : bool
    + MessageStatus : string
    + SentAt : DateTime?
    + Attachments : List~AttachmentDto~
}

class AttachmentDto {
    <<dto>>
    + AttachmentId : int
    + FileUrl : string
    + FileName : string?
    + FileType : string?
    + FileSize : long?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Chat {
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + ContextType : string?
    + ContextId : int?
    + CreatedAt : DateTime?
    + LastMessageAt : DateTime?
}

class Message {
    + MessageId : int
    + ChatId : int
    + SenderId : int?
    + Content : string
    + IsSeen : bool
    + MessageStatus : string
    + SentAt : DateTime?
    + ReceivedAt : DateTime?
}

class MessageAttachment {
    + AttachmentId : int
    + MessageId : int
    + FileUrl : string
    + FileName : string?
    + FileType : string?
    + FileSize : long?
    + CreatedAt : DateTime?
}

class Account {
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
}

class User {
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

class Manager {
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IChatService {
    <<interface>>
    + GetChatHistoryAsync(chatId: int, accountId: int) Task~List~MessageDto~~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IChatRepository {
    <<interface>>
    + GetMessagesByChatIdAsync(chatId: int) Task~List~Message~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ChatService {
    - _repo : IChatRepository
    + GetChatHistoryAsync(chatId: int, accountId: int) Task~List~MessageDto~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ChatRepository {
    - _context : AppDbContext
    + GetMessagesByChatIdAsync(chatId: int) Task~List~Message~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Accounts : DbSet~Account~
    + Users : DbSet~User~
    + Managers : DbSet~Manager~
    + Chats : DbSet~Chat~
    + Messages : DbSet~Message~
    + MessageAttachments : DbSet~MessageAttachment~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
Account *-- User
Account *-- Manager
Chat *-- Message
Message *-- MessageAttachment
MessageDto *-- AttachmentDto

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
Message --> Account
BackendController --> IChatService
ChatService --> IChatRepository
ChatRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
ChatService ..|> IChatService
ChatRepository ..|> IChatRepository

%% === DEPENDENCY (dashed arrows) ===
FrontendController ..> BackendController
BackendController ..> MessageDto
ChatService ..> MessageDto
ChatRepository ..> Message

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
