classDiagram
direction LR

%% ==================== FRONTEND ====================

class FrontendController["ChatController"] {
    <<frontend controller>>
    + GetHistory(roomId: int) Task~IActionResult~
}

%% ==================== BACKEND - HUB & CONTROLLERS ====================

class ChatHub {
    <<hub>>
    + MarkAsRead(chatId: int) Task
}

class BackendController["ChatController"] {
    <<backend controller>>
    - _chatService : IChatService
    + GetChatHistory(roomId: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class MessageDto {
    <<dto>>
    + MessageId : int
    + ChatId : int
    + SenderId : int?
    + SenderName : string
    + SenderAvatar : string?
    + Content : string
    + IsSeen : bool
    + MessageStatus : string
    + SentAt : DateTime?
    + Attachments : List~AttachmentDto~
}

class AttachmentDto {
    <<dto>>
    + AttachmentId : int
    + FileUrl : string
    + FileName : string?
    + FileType : string?
    + FileSize : long?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Chat {
    <<entity>>
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + ContextType : string?
    + ContextId : int?
    + CreatedAt : DateTime?
    + LastMessageAt : DateTime?
}

class ChatParticipant {
    <<entity>>
    + ChatId : int
    + AccountId : int
    + ClearedAt : DateTime?
    + UnreadCount : int
    + LastReadAt : DateTime?
}

class Message {
    <<entity>>
    + MessageId : int
    + ChatId : int
    + SenderId : int?
    + Content : string
    + IsSeen : bool
    + MessageStatus : string
    + SentAt : DateTime?
    + ReceivedAt : DateTime?
}

class MessageAttachment {
    <<entity>>
    + AttachmentId : int
    + MessageId : int
    + FileUrl : string
    + FileName : string?
    + FileType : string?
    + FileSize : long?
    + CreatedAt : DateTime?
}

class Account {
    <<entity>>
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
}

class User {
    <<entity>>
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

class Manager {
    <<entity>>
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IChatService {
    <<service interface>>
    + GetChatHistoryAsync(chatId: int, accountId: int) Task~List~MessageDto~~ *
}

class IRedisService {
    <<service interface>>
    + ClearUnreadCountAsync(accountId: int, chatId: int) Task *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IChatRepository {
    <<repository interface>>
    + GetMessagesByChatIdAsync(chatId: int) Task~List~Message~~ *
    + IsParticipantAsync(chatId: int, accountId: int) Task~bool~ *
    + HasActiveReportForChatAsync(chatId: int) Task~bool~ *
    + MarkAsReadAsync(chatId: int, accountId: int) Task *
    + GetParticipantAsync(chatId: int, accountId: int) Task~ChatParticipant?~ *
    + SaveChangesAsync() Task~int~ *
}

class IUserRepository {
    <<repository interface>>
    + GetRoleByAccountIdAsync(accountId: int) Task~string?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ChatService {
    <<service>>
    - _repo : IChatRepository
    - _userRepository : IUserRepository
    - _redisService : IRedisService
    + GetChatHistoryAsync(chatId: int, accountId: int) Task~List~MessageDto~~
    - HasAccessToChatAsync(accountId: int, chatId: int) Task~bool~
    - MarkChatAsReadAsync(chatId: int, accountId: int) Task~void~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ChatRepository {
    <<repository>>
    - _context : AppDbContext
    + GetMessagesByChatIdAsync(chatId: int) Task~List~Message~~
    + IsParticipantAsync(chatId: int, accountId: int) Task~bool~
    + HasActiveReportForChatAsync(chatId: int) Task~bool~
    + MarkAsReadAsync(chatId: int, accountId: int) Task
    + GetParticipantAsync(chatId: int, accountId: int) Task~ChatParticipant?~
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Accounts : DbSet~Account~
    + Users : DbSet~User~
    + Managers : DbSet~Manager~
    + Chats : DbSet~Chat~
    + Messages : DbSet~Message~
    + MessageAttachments : DbSet~MessageAttachment~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
Account *-- User
Account *-- Manager
Chat *-- Message
Message *-- MessageAttachment
MessageDto *-- AttachmentDto

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
Message --> Account
BackendController --> IChatService
ChatService --> IChatRepository
ChatService --> IUserRepository
ChatService --> IRedisService
ChatRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
ChatService ..|> IChatService
ChatRepository ..|> IChatRepository

%% === DEPENDENCY (dashed arrows) ===
FrontendController ..> BackendController
FrontendController ..> ChatHub
BackendController ..> MessageDto
ChatService ..> MessageDto
ChatService ..> ChatParticipant
ChatRepository ..> Message
ChatRepository ..> ChatParticipant

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
