%% ==================== FRONTEND ====================

class TransactionControllerFE["TransactionController"] {
    <<frontend controller>>
    + Detail(id: int) Task~IActionResult~
}

class TransactionDetailVM {
    <<view model>>
    + TransactionId : int
    + StripeSessionId : string?
    + StripePaymentIntentId : string?
    + Date : DateTime?
    + Status : string?
    + Currency : string?
    + BuyerName : string
    + BuyerEmail : string
    + CourseTitle : string
    + CourseThumbnail : string?
    + InstructorName : string
    + InstructorEmail : string
    + GrossAmount : decimal
    + OriginalPrice : decimal
    + DiscountAmount : decimal
    + CouponUsed : bool
    + CouponCode : string?
    + CouponType : string?
    + CouponDiscountValue : decimal?
    + TransferRate : decimal
    + InstructorPayout : decimal
    + PlatformProfit : decimal
    + IsPaid : bool
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
}

%% ==================== BACKEND - CONTROLLER ====================

class TransactionControllerBE["TransactionController"] {
    <<backend controller>>
    - _transactionService : ITransactionService
    + GetTransactionDetail(id: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class TransactionDetailDto {
    <<dto>>
    + TransactionId : int
    + StripeSessionId : string?
    + StripePaymentIntentId : string?
    + Date : DateTime?
    + Status : string?
    + Currency : string?
    + BuyerName : string
    + BuyerEmail : string
    + CourseTitle : string
    + CourseThumbnail : string?
    + InstructorName : string
    + InstructorEmail : string
    + GrossAmount : decimal
    + OriginalPrice : decimal
    + DiscountAmount : decimal
    + CouponUsed : bool
    + CouponCode : string?
    + CouponType : string?
    + CouponDiscountValue : decimal?
    + TransferRate : decimal
    + InstructorPayout : decimal
    + PlatformProfit : decimal
    + IsPaid : bool
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction {
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + TransferRate : decimal
    + StripeSessionId : string?
    + StripePaymentintentId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionType : string?
    + TransactionCreatedAt : DateTime?
    + TransactionExt : TransactionExt?
    + OrderItem : OrderItem?
    + AccountFromNavigation : Account?
    + AccountToNavigation : Account?
    + InstructorPayouts : ICollection~InstructorPayout~
}

class TransactionExt {
    + TransactionId : int
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
    + Transaction : Transaction
}

class OrderItem {
    + Id : int
    + OrderId : int?
    + CourseId : int?
    + PurchasePrice : decimal
    + CouponUsed : bool?
    + OriginalPrice : decimal?
    + CouponCode : string?
    + CouponType : string?
    + DiscountAmount : decimal
    + Course : Course?
    + Order : OrderInfo?
    + Transactions : ICollection~Transaction~
}

class Course {
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

class Account {
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
    + User : User?
    + TransactionFroms : ICollection~Transaction~
    + TransactionTos : ICollection~Transaction~
}

class User {
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
    + Instructor : Instructor?
    + UserNavigation : Account
}

class InstructorPayout {
    + PayoutId : int
    + TransactionId : int?
    + InstructorId : int?
    + PayoutAmount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + PayoutStatus : string
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
    + Transaction : Transaction?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ITransactionService {
    <<interface>>
    + GetTransactionDetailAsync(transactionId: int) Task~TransactionDetailDto?~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class ITransactionRepository {
    <<interface>>
    + GetTransactionDetailAsync(transactionId: int) Task~TransactionDetailDto?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class TransactionService {
    - _repo : ITransactionRepository
    + GetTransactionDetailAsync(transactionId: int) Task~TransactionDetailDto?~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class TransactionRepository {
    - _context : AppDbContext
    + GetTransactionDetailAsync(transactionId: int) Task~TransactionDetailDto?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Transactions : DbSet~Transaction~
    + TransactionExts : DbSet~TransactionExt~
    + OrderItems : DbSet~OrderItem~
    + InstructorPayouts : DbSet~InstructorPayout~
    + Accounts : DbSet~Account~
    + Users : DbSet~User~
    + Courses : DbSet~Course~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
Transaction *-- TransactionExt
OrderItem *-- Transaction
Transaction *-- InstructorPayout
Account *-- User

%% === AGGREGATION (hollow diamond) ===
Course o-- OrderItem

%% === UNIDIRECTIONAL ASSOCIATION ===
TransactionControllerBE --> ITransactionService
TransactionService --> ITransactionRepository
TransactionRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
TransactionService ..|> ITransactionService
TransactionRepository ..|> ITransactionRepository

%% === DEPENDENCY ===
TransactionControllerFE ..> TransactionControllerBE
TransactionControllerFE ..> TransactionDetailVM
TransactionControllerBE ..> TransactionDetailDto
ITransactionService ..> TransactionDetailDto
TransactionService ..> TransactionDetailDto
ITransactionRepository ..> TransactionDetailDto
TransactionRepository ..> TransactionDetailDto
TransactionRepository ..> Transaction

%% === BIDIRECTIONAL ASSOCIATION ===
Transaction -- Account
OrderItem -- Course

