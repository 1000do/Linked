classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminProfileControllerFE["AdminProfileController"] {
    <<frontend controller>>
    + Index() Task~IActionResult~
}

class AdminProfileViewModel {
    <<view model>>
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
    + AccountCreatedAt : DateTime?
    + LockoutStart : DateTime?
    + LockoutEnd : DateTime?
    + Email : string
}

%% ==================== BACKEND ====================

class AdminProfileControllerBE["AdminProfileController"] {
    <<backend controller>>
    - _profileService : IManagerProfileService
    + GetProfile() Task~IActionResult~
}

class IManagerProfileService {
    <<service interface>>
    + GetProfileAsync(managerId: int) Task~ManagerProfileResponse?~ *
}

class ManagerProfileService {
    <<service>>
    - _managerRepo : IManagerRepository
    + GetProfileAsync(managerId: int) Task~ManagerProfileResponse?~
}

class IManagerRepository {
    <<repository interface>>
    + GetManagerByIdAsync(managerId: int) Task~Manager?~ *
}

class ManagerRepository {
    <<repository>>
    - _context : AppDbContext
    + GetManagerByIdAsync(managerId: int) Task~Manager?~
}

class AppDbContext {
    <<dbcontext>>
    + Managers : DbSet~Manager~
}

class ManagerProfileResponse {
    <<dto>>
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
    + AccountCreatedAt : DateTime?
    + LockoutStart : DateTime?
    + LockoutEnd : DateTime?
    + Email : string
}

%% ==================== DOMAIN ENTITIES ====================

class Manager {
    <<entity>>
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
}

class Account {
    <<entity>>
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
}

class Lockout {
    <<entity>>
    + LockoutId : int
    + AccountId : int?
    + LockoutType : string?
    + LockoutLevel : string?
    + LockoutStart : DateTime?
    + LockoutEnd : DateTime?
}

%% ==================== RELATIONSHIPS ====================

%% === ASSOCIATION ===
AdminProfileControllerBE --> IManagerProfileService
ManagerProfileService --> IManagerRepository
ManagerRepository --> AppDbContext
Manager -- Account
Account -- Lockout

%% === REALIZATION ===
ManagerProfileService ..|> IManagerProfileService
ManagerRepository ..|> IManagerRepository

%% === DEPENDENCY ===
AdminProfileControllerFE ..> AdminProfileControllerBE
AdminProfileControllerFE ..> AdminProfileViewModel
AdminProfileControllerBE ..> ManagerProfileResponse
ManagerProfileService ..> ManagerProfileResponse
ManagerProfileService ..> Manager
ManagerRepository ..> Manager

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
