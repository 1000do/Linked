classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    + Index(year: int?, month: int?) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + PendingRefunds : PagedResult~RefundRequestVM~
}

class PagedResult_RefundRequestVM["PagedResult~RefundRequestVM~"] {
    <<view model>>
    + Items : List~RefundRequestVM~
    + TotalCount : int
    + PageCount : int
}

class RefundRequestVM {
    <<view model>>
    + TransactionId : int
    + Amount : decimal
    + Currency : string?
    + RefundReason : string?
    + RefundRequestedAt : DateTime?
    + TransactionCreatedAt : DateTime?
    + CourseTitle : string
    + BuyerName : string
}

%% ==================== BACKEND - CONTROLLERS ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetPendingRefundRequests(page: int, pageSize: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class PagedResult_Transaction["PagedResult~Transaction~"] {
    <<dto>>
    + Items : List~Transaction~
    + TotalCount : int
    + PageCount : int
}

%% ==================== BACKEND - SERVICES ====================

class IAdminFinanceService {
    <<interface>>
    + GetPendingRefundRequestsAsync(page: int, pageSize: int) Task~PagedResult~Transaction~~ *
}

class AdminFinanceService {
    - _financeRepo : IAdminFinanceRepository
    + GetPendingRefundRequestsAsync(page: int, pageSize: int) Task~PagedResult~Transaction~~
}

%% ==================== BACKEND - REPOSITORIES ====================

class IAdminFinanceRepository {
    <<interface>>
    + GetPendingRefundRequestsAsync(page: int, pageSize: int) Task~Tuple~List~Transaction~, int~~ *
}

class AdminFinanceRepository {
    - _context : AppDbContext
    + GetPendingRefundRequestsAsync(page: int, pageSize: int) Task~Tuple~List~Transaction~, int~~
}

%% ==================== BACKEND - DB CONTEXT ====================

class AppDbContext {
    + Transactions : DbSet~Transaction~
}

%% ==================== BACKEND - ENTITIES ====================

class Transaction {
    + TransactionId : int
    + Amount : decimal
    + RefundReason : string?
    + RefundRequestedAt : DateTime?
    + CreatedAt : DateTime
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
AdminFinanceUnifiedVM --> PagedResult_RefundRequestVM
PagedResult_RefundRequestVM --> RefundRequestVM

AdminFinanceControllerBE --> IAdminFinanceService
AdminFinanceService --> IAdminFinanceRepository
AdminFinanceRepository --> AppDbContext
AppDbContext --> Transaction

%% === REALIZATION ===
AdminFinanceService ..|> IAdminFinanceService
AdminFinanceRepository ..|> IAdminFinanceRepository

%% === DEPENDENCY ===
AdminFinanceControllerFE ..> AdminFinanceUnifiedVM
AdminFinanceControllerFE ..> AdminFinanceControllerBE : API calls
AdminFinanceControllerBE ..> PagedResult_Transaction
IAdminFinanceService ..> PagedResult_Transaction
IAdminFinanceRepository ..> Transaction
AdminFinanceRepository ..> Transaction

%% ==================== STYLES ====================
classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
