classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminProfileControllerFE["AdminProfileController"] {
    <<frontend controller>>
    + Edit() Task~IActionResult~
    + Edit(model: UpdateAdminProfileViewModel) Task~IActionResult~
}

class UpdateAdminProfileViewModel {
    <<view model>>
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + Bio : string?
    + AvatarFile : IFormFile?
}

%% ==================== BACKEND - CONTROLLERS ====================

class AdminProfileControllerBE["AdminProfileController"] {
    <<backend controller>>
    - _profileService : IManagerProfileService
    + UpdateProfile(request: UpdateManagerProfileRequest) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class UpdateManagerProfileRequest {
    <<dto>>
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + Bio : string?
    + AvatarFile : IFormFile?
}

%% ==================== BACKEND - SERVICES ====================

class IManagerProfileService {
    <<interface>>
    + UpdateProfileAsync(managerId: int, request: UpdateManagerProfileRequest) Task~bool~ *
}

class ManagerProfileService {
    - _managerRepo : IManagerRepository
    - _uploadService : IFileUploadService
    + UpdateProfileAsync(managerId: int, request: UpdateManagerProfileRequest) Task~bool~
}

class IFileUploadService {
    <<interface>>
    + UploadImageAsync(file: IFormFile) Task~string?~ *
}

class FileUploadService {
    + UploadImageAsync(file: IFormFile) Task~string?~
}

%% ==================== BACKEND - REPOSITORIES ====================

class IManagerRepository {
    <<interface>>
    + UpdateManagerProfileAsync(managerId: int, displayName: string, fullName: string?, phoneNumber: string?, avatarUrl: string?, bio: string?) Task~bool~ *
}

class ManagerRepository {
    - _context : AppDbContext
    + UpdateManagerProfileAsync(managerId: int, displayName: string, fullName: string?, phoneNumber: string?, avatarUrl: string?, bio: string?) Task~bool~
}

%% ==================== BACKEND - DB CONTEXT ====================

class AppDbContext {
    + Managers : DbSet~Manager~
}

%% ==================== BACKEND - ENTITIES ====================

class Manager {
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
AdminProfileControllerBE --> IManagerProfileService
ManagerProfileService --> IManagerRepository
ManagerProfileService --> IFileUploadService
ManagerRepository --> AppDbContext
AppDbContext --> Manager

%% === REALIZATION ===
ManagerProfileService ..|> IManagerProfileService
ManagerRepository ..|> IManagerRepository
FileUploadService ..|> IFileUploadService

%% === DEPENDENCY ===
AdminProfileControllerFE ..> UpdateAdminProfileViewModel
AdminProfileControllerFE ..> AdminProfileControllerBE : API
AdminProfileControllerBE ..> UpdateManagerProfileRequest
IManagerProfileService ..> UpdateManagerProfileRequest
ManagerProfileService ..> UpdateManagerProfileRequest
IManagerRepository ..> Manager
ManagerRepository ..> Manager

