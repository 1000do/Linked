```mermaid
classDiagram
direction LR

%% ==================== FRONTEND ====================

class TransactionControllerFE["TransactionController"] {
    <<frontend controller>>
    + Instructor(page: int, pageSize: int, tab: string, payoutPage: int, payoutPageSize: int, year: int?, month: int?) Task~IActionResult~
    - ComputeFinancialMetrics() void
}

class InstructorFinancePageVM {
    <<view model>>
    + Transactions : TransactionPagedVM
    + Payouts : InstructorPayoutPagedViewModel
    + CourseRevenues : List~InstructorCourseRevenueResponse~
}

class TransactionPagedVM {
    <<view model>>
    + Items : List~TransactionListItemVM~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
}

class InstructorPayoutPagedViewModel {
    <<view model>>
    + Items : List~InstructorPayoutViewModel~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
}

class TransactionListItemVM {
    <<view model>>
    + TransactionId : int
    + Amount : decimal
    + Status : string?
    + Date : DateTime?
}

class InstructorPayoutViewModel {
    <<view model>>
    + PayoutId : int
    + Amount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + PayoutStatus : string?
}

%% ==================== BACKEND - CONTROLLERS ====================

class TransactionControllerBE["TransactionController"] {
    <<backend controller>>
    - _transactionService : ITransactionService
    + GetInstructorTransactions(page: int, pageSize: int) Task~IActionResult~
}

class InstructorControllerBE["InstructorController"] {
    <<backend controller>>
    - _instructorService : IInstructorService
    + GetPayouts(page: int, pageSize: int) Task~IActionResult~
    + GetPayoutDaysDelay() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class PagedResultTransactionListDto["PagedResult~TransactionListDto~"] {
    <<dto>>
    + Items : IEnumerable~TransactionListDto~
    + TotalCount : int
}

class TransactionListDto {
    <<dto>>
    + TransactionId : int
    + Amount : decimal
    + Status : string?
    + Date : DateTime?
}

class PagedResultInstructorPayoutDto["PagedResult~InstructorPayoutDto~"] {
    <<dto>>
    + Items : IEnumerable~InstructorPayoutDto~
    + TotalCount : int
}

class InstructorPayoutDto {
    <<dto>>
    + PayoutId : int
    + Amount : decimal
    + IsPaid : bool
    + PayoutDate : DateTime
    + PayoutStatus : string?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction {
    + TransactionId : int
    + Amount : decimal
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionCreatedAt : DateTime?
}

class InstructorPayout {
    + PayoutId : int
    + PayoutAmount : decimal
    + IsPaid : bool
    + PayoutDate : DateTime
    + PayoutStatus : string
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ITransactionService {
    <<interface>>
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, ...) Task~PagedResult~TransactionListDto~~ *
}

class ITransactionRepository {
    <<interface>>
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, ...) Task~PagedResult~TransactionListDto~~ *
}

class IInstructorService {
    <<interface>>
    + GetPayoutsAsync(userId: int, page: int, pageSize: int, ...) Task~PagedResult~InstructorPayoutDto~~ *
    + GetPayoutDaysDelay() Task~int~ *
}

class IInstructorRepository {
    <<interface>>
    + GetPayoutsAsync(userId: int, page: int, pageSize: int, ...) Task~PagedResult~InstructorPayoutDto~~ *
}

%% ==================== BACKEND - IMPLEMENTATIONS ====================

class TransactionService {
    - _repo : ITransactionRepository
    + GetInstructorTransactionsAsync(...) Task~PagedResult~TransactionListDto~~
}

class TransactionRepository {
    - _context : AppDbContext
    + GetInstructorTransactionsAsync(...) Task~PagedResult~TransactionListDto~~
}

class InstructorService {
    - _repo : IInstructorRepository
    + GetPayoutsAsync(...) Task~PagedResult~InstructorPayoutDto~~
}

class InstructorRepository {
    - _context : AppDbContext
    + GetPayoutsAsync(...) Task~PagedResult~InstructorPayoutDto~~
}

class AppDbContext {
    + Transactions : DbSet~Transaction~
    + InstructorPayouts : DbSet~InstructorPayout~
}

