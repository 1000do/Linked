classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class TransactionControllerFE["TransactionController"] {
    <<frontend controller>>
    + Instructor(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, payoutPage: int, payoutPageSize: int, payoutKeyword: string?, payoutSortBy: string?, payoutStatus: string?, year: int?, month: int?, courseSortBy: string?) Task~IActionResult~
}

class InstructorFinancePageVM {
    <<view model>>
    + Transactions : TransactionPagedVM
    + Payouts : InstructorPayoutPagedViewModel
    + CourseRevenues : List~InstructorCourseRevenueResponse~
}

%% ==================== BACKEND ====================

class TransactionControllerBE["TransactionController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetInstructorCourseRevenues(year: int, month: int) Task~IActionResult~
}

class IAdminFinanceService {
    <<service interface>>
    + GetInstructorCourseRevenuesByInstructorAsync(instructorId: int, year: int, month: int) Task~List~InstructorCourseRevenueResponse~~ *
}

class AdminFinanceService {
    <<service>>
    - _repo : IAdminFinanceRepository
    + GetInstructorCourseRevenuesByInstructorAsync(instructorId: int, year: int, month: int) Task~List~InstructorCourseRevenueResponse~~
}

class IAdminFinanceRepository {
    <<repository interface>>
    + GetInstructorCourseRevenuesByInstructorAsync(instructorId: int, year: int, month: int) Task~List~InstructorCourseRevenueProjection~~ *
}

class AdminFinanceRepository {
    <<repository>>
    - _context : AppDbContext
    + GetInstructorCourseRevenuesByInstructorAsync(instructorId: int, year: int, month: int) Task~List~InstructorCourseRevenueProjection~~
}

class AppDbContext {
    <<dbcontext>>
    + Courses : DbSet~Course~
    + Transactions : DbSet~Transaction~
}

class InstructorCourseRevenueResponse {
    <<dto>>
    + CourseId : int
    + CourseTitle : string
    + InstructorId : int
    + InstructorName : string
    + SalesCount : int
    + MonthlyRevenue : decimal
    + PreviousMonthRevenue : decimal
    + YearlyRevenue : decimal
    + LifetimeRevenue : decimal
}

class InstructorCourseRevenueProjection {
    <<dto>>
    + CourseId : int
    + CourseTitle : string
    + InstructorId : int
    + InstructorName : string
    + SalesCount : int
    + MonthlyRevenue : decimal
    + PreviousMonthRevenue : decimal
    + YearlyRevenue : decimal
    + LifetimeRevenue : decimal
}

%% ==================== DOMAIN ENTITIES ====================

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

class Transaction {
    <<entity>>
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + TransferRate : decimal
    + StripeSessionId : string?
    + StripePaymentintentId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionType : string?
    + TransactionCreatedAt : DateTime?
}

class OrderItem {
    <<entity>>
    + Id : int
    + OrderId : int?
    + CourseId : int?
    + PurchasePrice : decimal
    + CouponUsed : bool?
    + OriginalPrice : decimal?
    + CouponCode : string?
    + CouponType : string?
    + DiscountAmount : decimal
}

class Instructor {
    <<entity>>
    + InstructorId : int
    + ProfessionalTitle : string?
    + ExpertiseCategories : string?
    + LinkedinUrl : string?
    + YoutubeUrl : string?
    + FacebookUrl : string?
    + DocumentUrl : string?
    + ApprovalStatus : string?
    + RejectionReason : string?
    + StripeAccountId : string?
    + StripeOnboardingStatus : string?
    + PayoutsEnabled : bool?
    + ChargesEnabled : bool?
    + StripeCountry : string?
}

class User {
    <<entity>>
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION ===
InstructorFinancePageVM *-- InstructorCourseRevenueResponse

%% === ASSOCIATION ===
TransactionControllerBE --> IAdminFinanceService
AdminFinanceService --> IAdminFinanceRepository
AdminFinanceRepository --> AppDbContext
Course -- Instructor
Instructor -- User
Transaction -- OrderItem
OrderItem -- Course

%% === REALIZATION ===
AdminFinanceService ..|> IAdminFinanceService
AdminFinanceRepository ..|> IAdminFinanceRepository

%% === DEPENDENCY ===
TransactionControllerFE ..> TransactionControllerBE
TransactionControllerFE ..> InstructorFinancePageVM
TransactionControllerBE ..> InstructorCourseRevenueResponse
AdminFinanceService ..> InstructorCourseRevenueResponse
AdminFinanceService ..> InstructorCourseRevenueProjection
AdminFinanceRepository ..> InstructorCourseRevenueProjection
AdminFinanceRepository ..> Course
AdminFinanceRepository ..> Transaction

