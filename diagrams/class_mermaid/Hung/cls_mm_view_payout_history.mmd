classDiagram-v2
direction LR

%% ==================== FRONTEND ====================
class TransactionControllerFE["TransactionController"] {
    <<frontend controller>>
    + Instructor(page: int, pageSize: int, keyword: string?, sortBy: string?, tab: string, status: string?, year: int?, month: int?) Task~IActionResult~
}

class InstructorFinancePageVM {
    <<view model>>
    + Payouts : InstructorPayoutPagedViewModel
}

class InstructorPayoutPagedViewModel {
    <<view model>>
    + Items : List~InstructorPayoutViewModel~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
}

class InstructorPayoutViewModel {
    <<view model>>
    + PayoutId : int
    + Amount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + CourseTitle : string
    + TotalAmount : decimal
    + PayoutStatus : string?
    + PaidToBankAt : DateTime?
    + StripeTransferId : string?
    + StripePayoutId : string?
}

%% ==================== BACKEND ====================
class InstructorControllerBE["InstructorController"] {
    <<backend controller>>
    - _instructorService : IInstructorService
    + GetPayouts(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~IActionResult~
}

class IInstructorService {
    <<service interface>>
    + GetPayoutsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~InstructorPayoutDto~~*
}

class InstructorService {
    <<service>>
    - _instructorRepository : IInstructorRepository
    + GetPayoutsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~InstructorPayoutDto~~
}

class IInstructorRepository {
    <<repository interface>>
    + GetPayoutsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~InstructorPayoutDto~~*
}

class InstructorRepository {
    <<repository>>
    - _context : AppDbContext
    + GetPayoutsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~InstructorPayoutDto~~
}

class InstructorPayoutDto {
    <<dto>>
    + PayoutId : int
    + Amount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + CourseTitle : string
    + TotalAmount : decimal
    + PayoutStatus : string?
    + PaidToBankAt : DateTime?
    + StripeTransferId : string?
    + StripePayoutId : string?
}

%% ==================== DATABASE ====================
class AppDbContext {
    <<dbcontext>>
    + InstructorPayouts : DbSet~InstructorPayout~
}

class InstructorPayout {
    <<entity>>
    + PayoutId : int
    + TransactionId : int?
    + InstructorId : int?
    + PayoutAmount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + PayoutStatus : string
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
}

class Transaction {
    <<entity>>
    + TransactionId : int
    + Amount : decimal
    + TransactionCreatedAt : DateTime?
    + OrderItemId : int?
}

class OrderItem {
    <<entity>>
    + Id : int
    + CourseId : int?
}

class Course {
    <<entity>>
    + CourseId : int
    + Title : string?
}

%% ==================== RELATIONSHIPS ====================
TransactionControllerFE ..> InstructorFinancePageVM
InstructorFinancePageVM *-- InstructorPayoutPagedViewModel
InstructorPayoutPagedViewModel *-- InstructorPayoutViewModel

TransactionControllerFE ..> InstructorControllerBE
InstructorControllerBE --> IInstructorService

InstructorService ..|> IInstructorService
InstructorService --> IInstructorRepository

InstructorRepository ..|> IInstructorRepository
InstructorRepository --> AppDbContext
InstructorRepository ..> InstructorPayoutDto

AppDbContext --> InstructorPayout

InstructorPayout -- Transaction
Transaction -- OrderItem
OrderItem -- Course

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
