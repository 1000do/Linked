classDiagram
direction LR

%% ==================== FRONTEND - CONTROLLER ====================

class TransactionControllerFE["TransactionController"] {
    <<frontend controller>>
    + Instructor(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, payoutPage: int, payoutPageSize: int, payoutKeyword: string?, payoutSortBy: string?, payoutStatus: string?, year: int?, month: int?, courseSortBy: string?) Task~IActionResult~
}

%% ==================== FRONTEND - VIEW MODELS ====================

class InstructorFinancePageVM {
    <<view model>>
    + Transactions : TransactionPagedVM
    + Payouts : InstructorPayoutPagedViewModel
    + CourseRevenues : List~InstructorCourseRevenueResponse~
}

%% ==================== BACKEND - CONTROLLER ====================

class TransactionControllerBE["TransactionController"] {
    <<backend controller>>
    - _transactionService : ITransactionService
    - _financeService : IAdminFinanceService
    + GetInstructorCourseRevenues(year: int, month: int) Task~IActionResult~
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminFinanceService {
    <<interface>>
    + GetInstructorCourseRevenuesByInstructorAsync(instructorId: int, year: int, month: int) Task~List~InstructorCourseRevenueResponse~~ *
}

class IAdminFinanceRepository {
    <<interface>>
    + GetInstructorCourseRevenuesByInstructorAsync(instructorId: int, year: int, month: int) Task~List~InstructorCourseRevenueProjection~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AdminFinanceService {
    - _repo : IAdminFinanceRepository
    - _paymentGateway : IPaymentGatewayService
    - _instructorRepo : IInstructorRepository
    - _notiService : INotificationService
    - _hubContext : IHubContext~FinanceHub~
    - _logger : ILogger~AdminFinanceService~
    - _configRepo : ISystemConfigRepository
    - _courseRepo : ICourseRepository
    - _stripeConnect : IStripeConnectService
    - _giftRepo : IGiftRepository
    + GetInstructorCourseRevenuesByInstructorAsync(instructorId: int, year: int, month: int) Task~List~InstructorCourseRevenueResponse~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class AdminFinanceRepository {
    - _context : AppDbContext
    + GetInstructorCourseRevenuesByInstructorAsync(instructorId: int, year: int, month: int) Task~List~InstructorCourseRevenueProjection~~
}

%% ==================== BACKEND - DB CONTEXT ====================

class AppDbContext {
    + Courses : DbSet~Course~
    + Transactions : DbSet~Transaction~
}

%% ==================== BACKEND - DTOs ====================

class InstructorCourseRevenueResponse {
    <<dto>>
    + CourseId : int
    + CourseTitle : string
    + InstructorId : int
    + InstructorName : string
    + SalesCount : int
    + MonthlyRevenue : decimal
    + PreviousMonthRevenue : decimal
    + YearlyRevenue : decimal
    + LifetimeRevenue : decimal
}

class InstructorCourseRevenueProjection {
    <<dto>>
    + CourseId : int
    + CourseTitle : string
    + InstructorId : int
    + InstructorName : string
    + SalesCount : int
    + MonthlyRevenue : decimal
    + PreviousMonthRevenue : decimal
    + YearlyRevenue : decimal
    + LifetimeRevenue : decimal
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Course {
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
    + CourseAiIntegrations : ICollection~CourseAiIntegration~
    + CartItems : ICollection~CartItem~
    + Category : Category?
    + Coupon : Coupon?
    + Enrollments : ICollection~Enrollment~
    + Instructor : Instructor?
    + Lessons : ICollection~Lesson~
    + OrderItems : ICollection~OrderItem~
    + WishlistItems : ICollection~WishlistItem~
    + CourseExt : CourseExt?
    + CourseQuizzes : ICollection~CourseQuiz~
}

class Transaction {
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + TransferRate : decimal
    + StripeSessionId : string?
    + StripePaymentintentId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionType : string?
    + TransactionCreatedAt : DateTime?
    + TransactionExt : TransactionExt?
    + OrderItem : OrderItem?
    + AccountFromNavigation : Account?
    + AccountToNavigation : Account?
    + InstructorPayouts : ICollection~InstructorPayout~
}

