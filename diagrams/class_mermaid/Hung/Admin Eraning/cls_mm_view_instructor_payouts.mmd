    %% ==================== RELATIONSHIPS ====================

    %% === ASSOCIATION ===
    AdminFinanceControllerBE --> IAdminFinanceService
    AdminFinanceService --> IAdminFinanceRepository
    AdminFinanceRepository --> AppDbContext
    InstructorPayout -- Transaction
    InstructorPayout -- Instructor
    Transaction -- OrderItem
    OrderItem -- Course
    Instructor -- User

    %% === REALIZATION ===
    AdminFinanceService ..|> IAdminFinanceService
    AdminFinanceRepository ..|> IAdminFinanceRepository

    %% === DEPENDENCY ===
    AdminFinanceControllerFE ..> AdminFinanceControllerBE
    AdminFinanceControllerFE ..> AdminFinanceUnifiedVM
    AdminFinanceControllerFE ..> PayoutDetailVM
    AdminFinanceControllerBE ..> PayoutDetailResponse
    AdminFinanceService ..> PayoutDetailResponse
    AdminFinanceService ..> PayoutDetailProjection
    AdminFinanceRepository ..> InstructorPayout
    AdminFinanceRepository ..> Transaction
    AdminFinanceRepository ..> OrderItem
    AdminFinanceRepository ..> Course
    AdminFinanceRepository ..> Instructor
    AdminFinanceRepository ..> User
    AdminFinanceRepository ..> PayoutDetailProjection

