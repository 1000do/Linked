classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    + Index(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, year: int?, month: int?, payoutPage: int, withdrawPage: int) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + Dashboard : FinanceDashboardVM
    + Withdraw : WithdrawPageVM
    + Transactions : TransactionPagedVM
    + Payouts : PagedResult~PayoutDetailVM~
    + Withdrawals : PagedResult~WithdrawalHistoryVM~
    + PendingRefunds : PagedResult~RefundRequestVM~
    + PayoutDays : string
    + CourseRevenues : List~InstructorCourseRevenueResponse~
    + YearlySummaries : Dictionary~int, FinancialSummaryVM~
}

class RefundRequestVM {
    <<view model>>
    + TransactionId : int
    + Amount : decimal
    + Currency : string?
    + RefundReason : string?
    + RefundRequestedAt : DateTime?
    + TransactionCreatedAt : DateTime?
    + OrderItem : OrderItemDto?
    + AccountFromNavigation : AccountDto?
    + TransactionExt : TransactionExtDto?
    + CourseTitle : string
    + BuyerName : string
}

class TransactionExtDto {
    <<dto>>
    + TransactionId : int
    + Description : string?
    + PaymentMethod : string?
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
}

class OrderItemDto {
    <<dto>>
    + Id : int
    + OrderId : int?
    + CourseId : int?
    + PurchasePrice : decimal
    + CouponUsed : bool?
    + DiscountAmount : decimal
    + Course : CourseDto?
}

class CourseDto {
    <<dto>>
    + CourseId : int
    + Title : string
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CourseStatus : string?
}

class AccountDto {
    <<dto>>
    + AccountId : int
    + UserId : int?
    + Balance : decimal?
    + DefaultCurrency : string?
    + IsActive : bool?
    + User : UserDto?
}

class UserDto {
    <<dto>>
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

%% ==================== BACKEND ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetPendingRefundRequests(page: int, pageSize: int) Task~IActionResult~
}

class IAdminFinanceService {
    <<service interface>>
    + GetPendingRefundRequestsAsync(page: int, pageSize: int) Task~PagedResult~TransactionListDto~~ *
}

class AdminFinanceService {
    <<service>>
    - _repo : IAdminFinanceRepository
    + GetPendingRefundRequestsAsync(page: int, pageSize: int) Task~PagedResult~TransactionListDto~~
}

class IAdminFinanceRepository {
    <<repository interface>>
    + GetPendingRefundRequestsAsync(page: int, pageSize: int) Task~Tuple~List~TransactionListDto~, int~~ *
}

class AdminFinanceRepository {
    <<repository>>
    - _context : AppDbContext
    + GetPendingRefundRequestsAsync(page: int, pageSize: int) Task~Tuple~List~TransactionListDto~, int~~
}

class AppDbContext {
    <<dbcontext>>
    + Transactions : DbSet~Transaction~
}

class TransactionListDto {
    <<dto>>
    + TransactionId : int
    + StripeSessionId : string?
    + Date : DateTime?
    + Amount : decimal
    + Status : string?
    + BuyerName : string
    + CourseTitle : string
    + InstructorName : string
    + Currency : string?
    + PayoutCurrency : string?
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
    + IsGift : bool
    + RecipientEmail : string?
    + IsGiftClaimed : bool
}

%% ==================== DOMAIN ENTITIES ====================

class Transaction {
    <<entity>>
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + TransferRate : decimal
    + StripeSessionId : string?
    + StripePaymentintentId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionType : string?
    + TransactionCreatedAt : DateTime?
    + TransactionExt : TransactionExt?
    + OrderItem : OrderItem?
    + AccountFromNavigation : Account?
    + AccountToNavigation : Account?
}

class TransactionExt {
    <<entity>>
    + TransactionId : int
    + Description : string?
    + PaymentMethod : string?
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
    + Transaction : Transaction
}

class OrderItem {
    <<entity>>
    + Id : int
    + OrderId : int?
    + CourseId : int?
    + PurchasePrice : decimal
    + CouponUsed : bool?
    + OriginalPrice : decimal?
    + CouponCode : string?
    + CouponType : string?
    + DiscountAmount : decimal
    + Course : Course?
    + Order : OrderInfo?
    + Transactions : ICollection~Transaction~
}

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
    + CourseAiIntegrations : ICollection~CourseAiIntegration~
    + FieldModerationFeedbacks : ICollection~CourseFieldModerationFeedback~
    + CartItems : ICollection~CartItem~
    + Category : Category?
    + Coupon : Coupon?
    + Enrollments : ICollection~Enrollment~
    + Instructor : Instructor?
    + Lessons : ICollection~Lesson~
    + OrderItems : ICollection~OrderItem~
    + WishlistItems : ICollection~WishlistItem~
    + CourseExt : CourseExt?
    + CourseQuizzes : ICollection~CourseQuiz~
}

class Account {
    <<entity>>
    + AccountId : int
    + UserId : int?
    + Balance : decimal?
    + DefaultCurrency : string?
    + CreatedAt : DateTime?
    + IsActive : bool?
    + InstructorPayouts : ICollection~InstructorPayout~
    + SystemConfigs : ICollection~SystemConfig~
    + TransactionAccountFromNavigations : ICollection~Transaction~
    + TransactionAccountToNavigations : ICollection~Transaction~
    + User : User?
}

class User {
    <<entity>>
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
    + CartItems : ICollection~CartItem~
    + Enrollments : ICollection~Enrollment~
    + Instructor : Instructor?
    + OrderInfos : ICollection~OrderInfo~
    + UserNavigation : Account
    + WishlistItems : ICollection~WishlistItem~
    + QuizAttempts : ICollection~QuizAttempt~
}

%% ==================== RELATIONSHIPS ====================

%% === ASSOCIATION ===
AdminFinanceControllerBE --> IAdminFinanceService
AdminFinanceService --> IAdminFinanceRepository
AdminFinanceRepository --> AppDbContext

RefundRequestVM *-- TransactionExtDto
RefundRequestVM *-- OrderItemDto
RefundRequestVM *-- AccountDto
OrderItemDto *-- CourseDto
AccountDto *-- UserDto

Transaction -- TransactionExt
Transaction -- OrderItem
Transaction -- Account
OrderItem -- Course
Account -- User

%% === REALIZATION ===
AdminFinanceService ..|> IAdminFinanceService
AdminFinanceRepository ..|> IAdminFinanceRepository

%% === DEPENDENCY ===
AdminFinanceControllerFE ..> AdminFinanceControllerBE
AdminFinanceControllerFE ..> AdminFinanceUnifiedVM
AdminFinanceControllerFE ..> RefundRequestVM

AdminFinanceControllerBE ..> TransactionListDto
AdminFinanceService ..> TransactionListDto
AdminFinanceRepository ..> TransactionListDto

AdminFinanceRepository ..> Transaction
AdminFinanceRepository ..> TransactionExt
AdminFinanceRepository ..> OrderItem
AdminFinanceRepository ..> Course
AdminFinanceRepository ..> Account
AdminFinanceRepository ..> User

