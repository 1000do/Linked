CourseDetailResponse --|> CourseResponse

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
GiftControllerBE --> IGiftService
GiftControllerBE --> ICourseQueryService

GiftService --> IUserRepository
GiftService --> ICourseRepository

CourseQueryService --> ICourseRepository

UserRepository --> AppDbContext
CourseRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
GiftService ..|> IGiftService
CourseQueryService ..|> ICourseQueryService
UserRepository ..|> IUserRepository
CourseRepository ..|> ICourseRepository

%% === DEPENDENCY (dashed arrows) ===
GiftControllerFE ..> GiftControllerBE

GiftControllerFE ..> GiftSetupViewModel
GiftControllerFE ..> PublicCourseViewModel

GiftControllerBE ..> CourseDetailResponse
ICourseQueryService ..> CourseDetailResponse
CourseQueryService ..> CourseDetailResponse

IGiftService ..> Account
GiftService ..> Account
IUserRepository ..> Account
UserRepository ..> Account

ICourseRepository ..> Course
CourseRepository ..> Course

