classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    + Index(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, year: int?, month: int?, payoutPage: int, withdrawPage: int) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + Dashboard : FinanceDashboardVM
    + Withdraw : WithdrawPageVM
    + Transactions : TransactionPagedVM
    + Payouts : PagedResult~PayoutDetailVM~
    + Withdrawals : PagedResult~WithdrawalHistoryVM~
    + PendingRefunds : PagedResult~RefundRequestVM~
    + PayoutDays : string
    + CourseRevenues : List~InstructorCourseRevenueResponse~
    + YearlySummaries : Dictionary~int, FinancialSummaryVM~
}

class WithdrawalHistoryVM {
    <<view model>>
    + WithdrawalId : int
    + ManagerName : string?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
}

%% ==================== BACKEND ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetWithdrawalHistory(year: int?, month: int?, page: int, pageSize: int) Task~IActionResult~
}

class IAdminFinanceService {
    <<service interface>>
    + GetWithdrawalHistoryAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~WithdrawalHistoryItem~~ *
}

class AdminFinanceService {
    <<service>>
    - _repo : IAdminFinanceRepository
    + GetWithdrawalHistoryAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~WithdrawalHistoryItem~~
}

class IAdminFinanceRepository {
    <<repository interface>>
    + GetWithdrawalsAsync(year: int?, month: int?, page: int, pageSize: int) Task~Tuple~List~PlatformWithdrawal~, int~~ *
}

class AdminFinanceRepository {
    <<repository>>
    - _context : AppDbContext
    + GetWithdrawalsAsync(year: int?, month: int?, page: int, pageSize: int) Task~Tuple~List~PlatformWithdrawal~, int~~
}

class AppDbContext {
    <<dbcontext>>
    + PlatformWithdrawals : DbSet~PlatformWithdrawal~
}

class WithdrawalHistoryItem {
    <<dto>>
    + WithdrawalId : int
    + ManagerName : string?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
}

%% ==================== DOMAIN ENTITIES ====================

class PlatformWithdrawal {
    <<entity>>
    + WithdrawalId : int
    + ManagerId : int?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
    + Manager : Manager?
}

class Manager {
    <<entity>>
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
    + Coupons : ICollection~Coupon~
    + ManagerNavigation : Account
    + SystemConfigs : ICollection~SystemConfig~
}

%% ==================== RELATIONSHIPS ====================

%% === ASSOCIATION ===
AdminFinanceControllerBE --> IAdminFinanceService
AdminFinanceService --> IAdminFinanceRepository
AdminFinanceRepository --> AppDbContext
PlatformWithdrawal -- Manager

%% === REALIZATION ===
AdminFinanceService ..|> IAdminFinanceService
AdminFinanceRepository ..|> IAdminFinanceRepository

%% === DEPENDENCY ===
AdminFinanceControllerFE ..> AdminFinanceControllerBE
AdminFinanceControllerFE ..> AdminFinanceUnifiedVM
AdminFinanceControllerFE ..> WithdrawalHistoryVM
AdminFinanceControllerBE ..> WithdrawalHistoryItem
AdminFinanceService ..> WithdrawalHistoryItem
AdminFinanceRepository ..> PlatformWithdrawal
AdminFinanceRepository ..> Manager

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
