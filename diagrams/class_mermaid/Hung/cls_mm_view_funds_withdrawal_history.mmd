classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    - _api : ApiClient
    + Index(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, year: int?, month: int?, payoutPage: int, withdrawPage: int) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + Dashboard : FinanceDashboardVM
    + Withdraw : WithdrawPageVM
    + Transactions : TransactionPagedVM
    + Payouts : PagedResult~PayoutDetailVM~
    + Withdrawals : PagedResult~WithdrawalHistoryVM~
    + PendingRefunds : PagedResult~RefundRequestVM~
    + PayoutDays : string
    + CourseRevenues : List~InstructorCourseRevenueResponse~
    + YearlySummaries : Dictionary~int, FinancialSummaryVM~
}

class PagedResultWithdrawalHistoryVM["PagedResult~WithdrawalHistoryVM~"] {
    + Items : List~WithdrawalHistoryVM~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
    + HasNextPage : bool
    + HasPreviousPage : bool
}

class WithdrawalHistoryVM {
    <<view model>>
    + WithdrawalId : int
    + ManagerName : string?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetWithdrawalHistory(year: int?, month: int?, page: int, pageSize: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class ApiResponseWithdrawal["ApiResponse~PagedResult~WithdrawalHistoryItem~~"] {
    <<dto>>
    + Success : bool
    + Message : string
    + Data : PagedResult~WithdrawalHistoryItem~
    + Errors : List~string~
}

class PagedResultWithdrawalHistoryItem["PagedResult~WithdrawalHistoryItem~"] {
    <<dto>>
    + Items : List~WithdrawalHistoryItem~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
    + HasNextPage : bool
    + HasPreviousPage : bool
}

class WithdrawalHistoryItem {
    <<dto>>
    + WithdrawalId : int
    + ManagerName : string?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminFinanceService {
    <<interface>>
    + GetWithdrawalHistoryAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~WithdrawalHistoryItem~~ *
}

class IAdminFinanceRepository {
    <<interface>>
    + GetWithdrawalsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PlatformWithdrawal~, int~~ *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AdminFinanceService {
    - _repo : IAdminFinanceRepository
    + GetWithdrawalHistoryAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~WithdrawalHistoryItem~~
    - SyncStripePayoutStatuses(withdrawals: List~PlatformWithdrawal~) Task~bool~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class AdminFinanceRepository {
    - _context : AppDbContext
    + GetWithdrawalsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PlatformWithdrawal~, int~~
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + PlatformWithdrawals : DbSet~PlatformWithdrawal~
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class PlatformWithdrawal {
    + WithdrawalId : int
    + ManagerId : int?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
    + Manager : Manager?
}

class Manager {
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
    + Coupons : ICollection~Coupon~
    + ManagerNavigation : Account
    + SystemConfigs : ICollection~SystemConfig~
}

