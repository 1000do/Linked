```mermaid
classDiagram
direction LR

%% ==================== FRONTEND ====================

class GiftControllerFE["GiftController"] {
    <<frontend controller>>
    + ClaimGiftAjax(token: string) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class GiftControllerBE["GiftController"] {
    <<backend controller>>
    - _giftService : IGiftService
    
    + ClaimGift(request: GiftClaimRequest) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class GiftClaimRequest {
    + RedemptionToken : string
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Gift {
    + GiftId : int
    + OrderItemId : int
    + SenderId : int?
    + RecipientEmail : string
    + RecipientName : string?
    + GiftMessage : string?
    + CardTheme : string?
    + RedemptionToken : string
    + IsClaimed : bool
    + ClaimedByUserId : int?
    + ClaimedAt : DateTime?
    + DeliveryStatus : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
}

class Course {
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + CourseAiIntegrations : ICollection~CourseAiIntegration~
    + CartItems : ICollection~CartItem~
    + Category : Category?
    + Coupon : Coupon?
    + Enrollments : ICollection~Enrollment~
    + Instructor : Instructor?
    + Lessons : ICollection~Lesson~
    + OrderItems : ICollection~OrderItem~
    + WishlistItems : ICollection~WishlistItem~
    + CourseExt : CourseExt?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

class Enrollment {
    + EnrollmentId : int
    + UserId : int?
    + CourseId : int?
    + Title : string?
    + Description : string?
    + CompletedDate : DateOnly?
    + IsCompleted : bool?
    + EnrollDate : DateOnly?
    + LastAccessedAt : DateTime?
    + EnrollmentStatus : string?
    + Course : Course?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IGiftService {
    <<interface>>
    + ClaimGiftAsync(userId: int, token: string) Task *
}

class IGiftRepository {
    <<interface>>
    + GetByTokenAsync(token: string) Task~Gift?~ *
    + Update(gift: Gift) void *
    + SaveChangesAsync() Task~int~ *
}

class ICourseRepository {
    <<interface>>
    + GetByIdAsync(courseId: int) Task~Course?~ *
}

class IEnrollmentRepository {
    <<interface>>
    + GetEnrollmentAsync(userId: int, courseId: int) Task~Enrollment?~ *
    + BeginTransactionAsync() Task~IDbContextTransaction~ *
    + AddEnrollmentAsync(enrollment: Enrollment) Task *
    + SaveChangesAsync() Task~int~ *
}

class ITransactionRepository {
    <<interface>>
    + RejectPendingRefundForGiftClaimedAsync(orderItemId: int) Task~bool~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class GiftService {
    - _giftRepo : IGiftRepository
    - _courseRepo : ICourseRepository
    - _enrollmentRepo : IEnrollmentRepository
    - _transactionRepo : ITransactionRepository
    
    + ClaimGiftAsync(userId: int, token: string) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class GiftRepository {
    - _context : AppDbContext
    
    + GetByTokenAsync(token: string) Task~Gift?~
    + Update(gift: Gift) void
    + SaveChangesAsync() Task~int~
}

class CourseRepository {
    - _context : AppDbContext
    
    + GetByIdAsync(courseId: int) Task~Course?~
}

class EnrollmentRepository {
    - _context : AppDbContext
    
    + GetEnrollmentAsync(userId: int, courseId: int) Task~Enrollment?~
    + BeginTransactionAsync() Task~IDbContextTransaction~
    + AddEnrollmentAsync(enrollment: Enrollment) Task
    + SaveChangesAsync() Task~int~
}

class TransactionRepository {
    - _context : AppDbContext
    
    + RejectPendingRefundForGiftClaimedAsync(orderItemId: int) Task~bool~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Gifts : DbSet~Gift~
    + Courses : DbSet~Course~
    + Enrollments : DbSet~Enrollment~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === ASSOCIATION ===
Course -- Enrollment

