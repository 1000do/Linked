classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    + Index(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, year: int?, month: int?, payoutPage: int, withdrawPage: int) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + Dashboard : FinanceDashboardVM
}

class FinanceDashboardVM {
    <<view model>>
    + Summary : FinancialSummaryVM
    + Payouts : List~PayoutDetailVM~
}

class FinancialSummaryVM {
    <<view model>>
    + GrossRevenue : decimal
    + TotalPaidOut : decimal
    + PendingEscrow : decimal
    + MaturedEscrow : decimal
    + PlatformNetProfit : decimal
}

class PayoutDetailVM {
    <<view model>>
    + PayoutId : int
    + TransactionId : int
    + InstructorName : string
    + CourseTitle : string
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + PayoutStatus : string
    + PayoutDate : DateTime
}

%% ==================== BACKEND - CONTROLLERS ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetFinancialSummary(year: int?, month: int?) Task~IActionResult~
    + GetPayouts(year: int?, month: int?, page: int, pageSize: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class FinancialSummaryResponse {
    <<dto>>
    + GrossRevenue : decimal
    + TotalPaidOut : decimal
    + PendingEscrow : decimal
    + MaturedEscrow : decimal
    + PlatformNetProfit : decimal
}

class PayoutDetailResponse {
    <<dto>>
    + PayoutId : int
    + InstructorName : string
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + PayoutStatus : string
    + PayoutDate : DateTime
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction {
    <<entity>>
    + TransactionId : int
    + Amount : decimal
    + TransactionsStatus : string?
    + TransactionCreatedAt : DateTime?
}

class InstructorPayout {
    <<entity>>
    + PayoutId : int
    + PayoutAmount : decimal
    + PayoutStatus : string?
    + PayoutDate : DateTime
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminFinanceService {
    <<service interface>>
    + GetFinancialSummaryAsync(year: int?, month: int?) Task~FinancialSummaryResponse~ *
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IAdminFinanceRepository {
    <<repository interface>>
    + GetGrossRevenueAsync(year: int?, month: int?) Task~decimal~ *
    + GetTotalPaidOutAsync(year: int?, month: int?) Task~decimal~ *
    + GetPendingEscrowAsync(year: int?, month: int?) Task~decimal~ *
    + GetMaturedEscrowAsync(year: int?, month: int?) Task~decimal~ *
    + GetPayoutDetailsAsync(year: int?, month: int?, page: int, pageSize: int) Task~(List~PayoutDetailProjection~, int)~ *
}

%% ==================== BACKEND - SERVICES ====================

class AdminFinanceService {
    <<service>>
    - _repo : IAdminFinanceRepository
    + GetFinancialSummaryAsync(year: int?, month: int?) Task~FinancialSummaryResponse~
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~
}

%% ==================== BACKEND - REPOSITORIES ====================

class AdminFinanceRepository {
    <<repository>>
    - _context : AppDbContext
    + GetGrossRevenueAsync(year: int?, month: int?) Task~decimal~
    + GetTotalPaidOutAsync(year: int?, month: int?) Task~decimal~
    + GetPendingEscrowAsync(year: int?, month: int?) Task~decimal~
    + GetMaturedEscrowAsync(year: int?, month: int?) Task~decimal~
    + GetPayoutDetailsAsync(year: int?, month: int?, page: int, pageSize: int) Task~(List~PayoutDetailProjection~, int)~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Transactions : DbSet~Transaction~
    + InstructorPayouts : DbSet~InstructorPayout~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
AdminFinanceUnifiedVM *-- FinanceDashboardVM
FinanceDashboardVM *-- FinancialSummaryVM
FinanceDashboardVM *-- PayoutDetailVM

AdminFinanceControllerBE --> IAdminFinanceService
AdminFinanceService --> IAdminFinanceRepository
AdminFinanceRepository --> AppDbContext

AppDbContext --> Transaction
AppDbContext --> InstructorPayout

%% === INTERFACE REALIZATION ===
AdminFinanceService ..|> IAdminFinanceService
AdminFinanceRepository ..|> IAdminFinanceRepository

%% === DEPENDENCY ===
AdminFinanceControllerFE ..> AdminFinanceUnifiedVM
AdminFinanceControllerFE ..> AdminFinanceControllerBE

AdminFinanceControllerBE ..> FinancialSummaryResponse
AdminFinanceControllerBE ..> PayoutDetailResponse

IAdminFinanceService ..> FinancialSummaryResponse
IAdminFinanceService ..> PayoutDetailResponse

AdminFinanceRepository ..> InstructorPayout
AdminFinanceRepository ..> Transaction

%% ==================== STYLES ====================
classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
