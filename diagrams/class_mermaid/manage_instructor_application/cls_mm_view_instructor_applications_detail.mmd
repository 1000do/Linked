classDiagram
direction LR

%% ==================== FRONTEND ====================

class AdminApprovalControllerFE["AdminApprovalController"] {
    <<frontend controller>>
    + Detail(id: int) Task~IActionResult~
}

class InstructorApprovalViewModel {
    + InstructorId : int
    + FullName : string
    + Email : string
    + AvatarUrl : string?
    + ProfessionalTitle : string?
    + LinkedInUrl : string?
    + YoutubeUrl : string?
    + FacebookUrl : string?
    + DocumentUrl : string?
    + ApprovalStatus : string?
    + ExpertiseCategories : string?
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminApprovalControllerBE["AdminApprovalController"] {
    <<backend controller>>
    - _service : IInstructorApprovalService
    + GetDetail(id: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class InstructorApprovalDto {
    + InstructorId : int
    + FullName : string
    + Email : string
    + AvatarUrl : string?
    + ProfessionalTitle : string?
    + DocumentUrl : string?
    + LinkedInUrl : string?
    + YoutubeUrl : string?
    + FacebookUrl : string?
    + ApprovalStatus : string?
    + ExpertiseCategories : string?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Instructor {
    + InstructorId : int
    + ProfessionalTitle : string?
    + ExpertiseCategories : string?
    + LinkedinUrl : string?
    + YoutubeUrl : string?
    + FacebookUrl : string?
    + DocumentUrl : string?
    + ApprovalStatus : string?
    + RejectionReason : string?
    + StripeAccountId : string?
    + StripeOnboardingStatus : string?
    + PayoutsEnabled : bool?
    + ChargesEnabled : bool?
    + StripeCountry : string?
}

class User {
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

class Account {
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IInstructorApprovalService {
    <<interface>>
    + GetDetailAsync(id: int) Task~InstructorApprovalDto?~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IInstructorRepository {
    <<interface>>
    + GetByIdAsync(id: int) Task~Instructor?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class InstructorApprovalService {
    - _repo : IInstructorRepository
    + GetDetailAsync(id: int) Task~InstructorApprovalDto?~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class InstructorRepository {
    - _context : AppDbContext
    + GetByIdAsync(id: int) Task~Instructor?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Instructors : DbSet~Instructor~
    + Users : DbSet~User~
    + Accounts : DbSet~Account~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION ===
Account *-- User
User *-- Instructor

%% === UNIDIRECTIONAL ASSOCIATION ===
AdminApprovalControllerBE --> IInstructorApprovalService
InstructorApprovalService --> IInstructorRepository
InstructorRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
InstructorApprovalService ..|> IInstructorApprovalService
InstructorRepository ..|> IInstructorRepository

%% === DEPENDENCY ===
AdminApprovalControllerFE ..> AdminApprovalControllerBE
AdminApprovalControllerFE ..> InstructorApprovalViewModel
AdminApprovalControllerBE ..> InstructorApprovalDto
InstructorApprovalService ..> InstructorApprovalDto
InstructorRepository ..> Instructor

