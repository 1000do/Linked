classDiagram
direction LR

%% ==================== FRONTEND ====================

class CourseControllerFE["CourseController"] {
    <<frontend controller>>
    + GetProgress(id: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class EnrollmentControllerBE["EnrollmentController"] {
    <<backend controller>>
    - _enrollmentService : IEnrollmentService
    
    + GetProgress(courseId: int) Task~IActionResult~
    - GetUserId() int?
}

%% ==================== BACKEND - DTOs ====================

class ProgressResponse {
    <<dto>>
    + EnrollmentId : int
    + LearnedMaterialCount : int
    + TotalMaterialCount : int
    + CompletedMaterialIds : List~int~
}

class CourseStats {
    <<dto>>
    + CourseId : int
    + TotalStudents : int
    + RatingAverage : decimal
    + TotalReviews : int
    + TotalLessons : int
    + TotalMaterials : int
    + TotalVideoDuration : int
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Enrollment {
    <<entity>>
    + EnrollmentId : int
    + UserId : int?
    + CourseId : int?
    + Title : string?
    + Description : string?
    + CompletedDate : DateOnly?
    + IsCompleted : bool?
    + EnrollDate : DateOnly?
    + LastAccessedAt : DateTime?
    + EnrollmentStatus : string?
    + Course : Course?
    + User : User?
    + MaterialCompletions : ICollection~MaterialCompletion~
}

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IEnrollmentService {
    <<service interface>>
    + GetProgressAsync(userId: int, courseId: int) Task~ProgressResponse?~ *
}

class IEnrollmentRepository {
    <<repository interface>>
    + GetEnrollmentAsync(userId: int, courseId: int) Task~Enrollment?~ *
    + GetCompletedMaterialCountAsync(enrollmentId: int) Task~int~ *
    + GetCompletedMaterialIdsAsync(enrollmentId: int) Task~List~int~~ *
}

class ICourseRepository {
    <<repository interface>>
    + GetCourseStatsAsync(courseId: int) Task~CourseStats?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class EnrollmentService {
    <<service>>
    - _repo : IEnrollmentRepository
    - _courseRepo : ICourseRepository
    
    + GetProgressAsync(userId: int, courseId: int) Task~ProgressResponse?~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class EnrollmentRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetEnrollmentAsync(userId: int, courseId: int) Task~Enrollment?~
    + GetCompletedMaterialCountAsync(enrollmentId: int) Task~int~
    + GetCompletedMaterialIdsAsync(enrollmentId: int) Task~List~int~~
}

class CourseRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetCourseStatsAsync(courseId: int) Task~CourseStats?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Enrollments : DbSet~Enrollment~
    + Courses : DbSet~Course~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
EnrollmentControllerBE --> IEnrollmentService
EnrollmentService --> IEnrollmentRepository
EnrollmentService --> ICourseRepository
EnrollmentRepository --> AppDbContext
CourseRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
EnrollmentService ..|> IEnrollmentService
EnrollmentRepository ..|> IEnrollmentRepository
CourseRepository ..|> ICourseRepository

%% === DEPENDENCY ===
CourseControllerFE ..> EnrollmentControllerBE
EnrollmentControllerBE ..> ProgressResponse
EnrollmentService ..> ProgressResponse
EnrollmentService ..> Enrollment
EnrollmentService ..> CourseStats
EnrollmentRepository ..> Enrollment
CourseRepository ..> CourseStats

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000