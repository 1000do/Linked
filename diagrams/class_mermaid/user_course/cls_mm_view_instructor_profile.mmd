classDiagram
direction LR

%% ==================== FRONTEND ====================

class InstructorControllerFE["InstructorController"] {
    <<frontend controller>>
    + Profile(id: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class InstructorControllerBE["InstructorController"] {
    <<backend controller>>
    - _instructorService : IInstructorService
    
    + GetPublicProfile(id: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class InstructorPublicProfileDto {
    <<dto>>
    + InstructorId : int
    + FirstName : string?
    + LastName : string?
    + Email : string?
    + AvatarUrl : string?
    + ProfessionalTitle : string?
    + Bio : string?
    + ExpertiseCategories : string?
    + LinkedinUrl : string?
    + YoutubeUrl : string?
    + FacebookUrl : string?
    + DocumentUrl : string?
    + TotalStudents : int
    + TotalReviews : int
    + AverageRating : decimal
    + ActiveCoursesCount : int
    + Courses : List~InstructorCourseDto~
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Instructor {
    <<entity>>
    + InstructorId : int
    + ProfessionalTitle : string?
    + ExpertiseCategories : string?
    + LinkedinUrl : string?
    + YoutubeUrl : string?
    + FacebookUrl : string?
    + DocumentUrl : string?
    + ApprovalStatus : string?
    + RejectionReason : string?
    + StripeAccountId : string?
    + StripeOnboardingStatus : string?
    + PayoutsEnabled : bool?
    + ChargesEnabled : bool?
    + StripeCountry : string?
    + Courses : ICollection~Course~
    + InstructorPayouts : ICollection~InstructorPayout~
    + Quizzes : ICollection~Quiz~
    + InstructorNavigation : User
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IInstructorService {
    <<service interface>>
    + GetPublicProfileAsync(instructorId: int) Task~InstructorPublicProfileDto?~ *
}

class IInstructorRepository {
    <<repository interface>>
    + GetByIdWithNavigationAsync(instructorId: int) Task~Instructor?~ *
    + GetStatsAsync(userId: int) Task~InstructorStats?~ *
    + CountActiveCoursesAsync(instructorId: int) Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class InstructorService {
    <<service>>
    - _repo : IInstructorRepository
    
    + GetPublicProfileAsync(instructorId: int) Task~InstructorPublicProfileDto?~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class InstructorRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByIdWithNavigationAsync(instructorId: int) Task~Instructor?~
    + GetStatsAsync(userId: int) Task~InstructorStats?~
    + CountActiveCoursesAsync(instructorId: int) Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Instructors : DbSet~Instructor~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
InstructorControllerBE --> IInstructorService
InstructorService --> IInstructorRepository
InstructorRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
InstructorService ..|> IInstructorService
InstructorRepository ..|> IInstructorRepository

%% === DEPENDENCY ===
InstructorControllerFE ..> InstructorControllerBE
InstructorControllerBE ..> InstructorPublicProfileDto
InstructorService ..> InstructorPublicProfileDto
InstructorService ..> Instructor
InstructorRepository ..> Instructor

