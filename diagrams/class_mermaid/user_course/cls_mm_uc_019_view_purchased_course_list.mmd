classDiagram
direction LR

%% ==================== FRONTEND ====================

class CourseControllerFE["CourseController"] {
    <<frontend controller>>
    + MyCourses() Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class EnrollmentControllerBE["EnrollmentController"] {
    <<backend controller>>
    - _enrollmentService : IEnrollmentService
    
    + GetMyCourses() Task~IActionResult~
    - GetUserId() int?
}

%% ==================== BACKEND - DTOs ====================

class EnrolledCourseDto {
    <<dto>>
    + CourseId : int
    + Title : string
    + ThumbnailUrl : string?
    + InstructorName : string?
    + EnrolledAt : DateTime?
    + TotalMaterials : int
    + LearnedMaterials : int
    + ProgressPercentage : decimal
    + IsArchived : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Enrollment {
    <<entity>>
    + EnrollmentId : int
    + UserId : int?
    + CourseId : int?
    + Title : string?
    + Description : string?
    + CompletedDate : DateOnly?
    + IsCompleted : bool?
    + EnrollDate : DateOnly?
    + LastAccessedAt : DateTime?
    + EnrollmentStatus : string?
    + Course : Course?
    + User : User?
    + MaterialCompletions : ICollection~MaterialCompletion~
}

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IEnrollmentService {
    <<service interface>>
    + GetMyEnrolledCoursesAsync(userId: int) Task~List~EnrolledCourseDto~~ *
}

class IEnrollmentRepository {
    <<repository interface>>
    + GetMyEnrolledCoursesAsync(userId: int) Task~List~Enrollment~~ *
    + GetCompletedMaterialCountAsync(enrollmentId: int) Task~int~ *
}

class ICourseRepository {
    <<repository interface>>
    + GetCourseStatsAsync(courseId: int) Task~CourseStats?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class EnrollmentService {
    <<service>>
    - _repo : IEnrollmentRepository
    - _courseRepo : ICourseRepository
    
    + GetMyEnrolledCoursesAsync(userId: int) Task~List~EnrolledCourseDto~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class EnrollmentRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetMyEnrolledCoursesAsync(userId: int) Task~List~Enrollment~~
    + GetCompletedMaterialCountAsync(enrollmentId: int) Task~int~
}

class CourseRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetCourseStatsAsync(courseId: int) Task~CourseStats?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Enrollments : DbSet~Enrollment~
    + Courses : DbSet~Course~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
EnrollmentControllerBE --> IEnrollmentService
EnrollmentService --> IEnrollmentRepository
EnrollmentService --> ICourseRepository
EnrollmentRepository --> AppDbContext
CourseRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
EnrollmentService ..|> IEnrollmentService
EnrollmentRepository ..|> IEnrollmentRepository
CourseRepository ..|> ICourseRepository

%% === DEPENDENCY ===
CourseControllerFE ..> EnrollmentControllerBE
EnrollmentControllerBE ..> EnrolledCourseDto
EnrollmentService ..> EnrolledCourseDto
EnrollmentService ..> Enrollment
EnrollmentRepository ..> Enrollment
EnrollmentRepository ..> Course
CourseRepository ..> Course

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000