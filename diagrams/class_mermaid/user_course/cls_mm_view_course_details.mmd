classDiagram
direction LR

%% ==================== FRONTEND ====================

class CourseControllerFE["CourseController"] {
    <<frontend controller>>
    + Details(id: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class CoursePublicController {
    <<backend controller>>
    - _courseQueryService : ICourseQueryService
    
    + GetCourseDetails(id: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class CourseDetailResponse {
    <<dto>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CourseStatus : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + InstructorName : string?
    + TotalStudents : int
    + RatingAverage : decimal
    + CategoryName : string?
    + InstructorAvatarUrl : string?
    + InstructorBio : string?
    + InstructorProfessionalTitle : string?
    + InstructorReviewCount : int
    + InstructorStudentsCount : int
    + InstructorCoursesCount : int
    + IsEnrolled : bool
    + IsOwner : bool
    + TotalReviews : int
    + LastApprovedAt : DateTime?
    + AppliedCouponCode : string?
    + AppliedCouponType : string?
    + AppliedCouponValue : decimal?
    + IsRemoved : bool
    + IsInAnyCart : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ICourseQueryService {
    <<interface>>
    + GetCourseWithDetailsAsync(courseId: int, userId: int?, userRole: string?) Task~CourseDetailResponse~ *
}

class ICourseRepository {
    <<interface>>
    + GetCourseWithDetailsAsync(courseId: int) Task~Course?~ *
    + GetCourseStatsAsync(courseId: int) Task~CourseStatsDto?~ *
    + IsEnrolledAsync(userId: int, courseId: int) Task~bool~ *
}

class IInstructorRepository {
    <<interface>>
    + GetStatsAsync(instructorId: int) Task~InstructorStatsDto?~ *
}

class ICartRepository {
    <<interface>>
    + IsCourseInAnyCartAsync(courseId: int) Task~bool~ *
}

class IRedisService {
    <<interface>>
    + GetCacheAsync~T~(key: string) Task~T?~ *
    + SetCacheAsync~T~(key: string, value: T, expiration: TimeSpan) Task *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CourseQueryService {
    - _courseRepository : ICourseRepository
    - _instructorRepository : IInstructorRepository
    - _cartRepository : ICartRepository
    - _redisService : IRedisService
    
    + GetCourseWithDetailsAsync(courseId: int, userId: int?, userRole: string?) Task~CourseDetailResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CourseRepository {
    - _context : AppDbContext
    
    + GetCourseWithDetailsAsync(courseId: int) Task~Course?~
    + GetCourseStatsAsync(courseId: int) Task~CourseStatsDto?~
    + IsEnrolledAsync(userId: int, courseId: int) Task~bool~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Courses : DbSet~Course~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
CoursePublicController --> ICourseQueryService
CourseQueryService --> ICourseRepository
CourseQueryService --> IInstructorRepository
CourseQueryService --> ICartRepository
CourseQueryService --> IRedisService
CourseRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
CourseQueryService ..|> ICourseQueryService
CourseRepository ..|> ICourseRepository

%% === DEPENDENCY ===
CourseControllerFE ..> CoursePublicController
CoursePublicController ..> CourseDetailResponse
CourseQueryService ..> CourseDetailResponse
CourseRepository ..> Course
CourseQueryService ..> Course

