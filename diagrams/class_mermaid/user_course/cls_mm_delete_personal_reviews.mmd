classDiagram
direction LR

%% ==================== FRONTEND ====================

class CourseControllerFE["CourseController"] {
    <<frontend controller>>
    + DeleteReview(reviewId: int, type: string) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class ReviewControllerBE["ReviewController"] {
    <<backend controller>>
    - _reviewService : IReviewService
    
    + DeleteReview(reviewId: int, type: string) Task~IActionResult~
    - GetUserId() int?
}

%% ==================== BACKEND - DTOs ====================

class DeleteReviewRequest {
    <<dto>>
    + ReviewId : int
    + Type : string?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class CourseReview {
    <<entity>>
    + CourseReviewId : int
    + EnrollmentId : int
    + Rating : int?
    + Comment : string?
    + CourseReviewStatus : string?
    + IsRemoved : bool?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + AiThreatLevel : AiThreatLevel
    + Enrollment : Enrollment?
    + Reports : ICollection~Report~
}

class LessonReview {
    <<entity>>
    + LessonReviewId : int
    + EnrollmentId : int
    + LessonId : int
    + Rating : int?
    + Comment : string?
    + LessonReviewStatus : string?
    + IsRemoved : bool?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + AiThreatLevel : AiThreatLevel
    + Enrollment : Enrollment?
    + Lesson : Lesson?
    + Reports : ICollection~Report~
}

class Enrollment {
    <<entity>>
    + EnrollmentId : int
    + UserId : int?
    + User : User?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IReviewService {
    <<service interface>>
    + DeleteReviewAsync(userId: int, request: DeleteReviewRequest) Task *
}

class IReviewRepository {
    <<repository interface>>
    + GetCourseReviewByIdAsync(reviewId: int) Task~CourseReview?~ *
    + GetLessonReviewByIdAsync(reviewId: int) Task~LessonReview?~ *
    + HasPendingCourseReviewReportsAsync(reviewId: int) Task~bool~ *
    + HasPendingLessonReviewReportsAsync(reviewId: int) Task~bool~ *
    + UpdateCourseReview(review: CourseReview) void *
    + UpdateLessonReview(review: LessonReview) void *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ReviewService {
    <<service>>
    - _reviewRepo : IReviewRepository
    
    + DeleteReviewAsync(userId: int, request: DeleteReviewRequest) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ReviewRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetCourseReviewByIdAsync(reviewId: int) Task~CourseReview?~
    + GetLessonReviewByIdAsync(reviewId: int) Task~LessonReview?~
    + HasPendingCourseReviewReportsAsync(reviewId: int) Task~bool~
    + HasPendingLessonReviewReportsAsync(reviewId: int) Task~bool~
    + UpdateCourseReview(review: CourseReview) void
    + UpdateLessonReview(review: LessonReview) void
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + CourseReviews : DbSet~CourseReview~
    + LessonReviews : DbSet~LessonReview~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
ReviewControllerBE --> IReviewService
ReviewService --> IReviewRepository
ReviewRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
ReviewService ..|> IReviewService
ReviewRepository ..|> IReviewRepository

%% === DEPENDENCY ===
CourseControllerFE ..> ReviewControllerBE
ReviewControllerBE ..> DeleteReviewRequest
ReviewService ..> DeleteReviewRequest
ReviewService ..> CourseReview
ReviewService ..> LessonReview
ReviewRepository ..> CourseReview
ReviewRepository ..> LessonReview

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000