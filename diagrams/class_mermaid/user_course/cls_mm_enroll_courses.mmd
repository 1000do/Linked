classDiagram
direction LR

%% ==================== FRONTEND ====================

class CourseControllerFE["CourseController"] {
    <<frontend controller>>
    + EnrollFree(id: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class EnrollmentControllerBE["EnrollmentController"] {
    <<backend controller>>
    - _enrollmentService : IEnrollmentService
    - _authService : IAuthService
    
    + FreeEnroll(courseId: int) Task~IActionResult~
    - GetUserId() int?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Enrollment {
    <<entity>>
    + EnrollmentId : int
    + UserId : int?
    + CourseId : int?
    + Title : string?
    + Description : string?
    + CompletedDate : DateOnly?
    + IsCompleted : bool?
    + EnrollDate : DateOnly?
    + LastAccessedAt : DateTime?
    + EnrollmentStatus : string?
    + Course : Course?
    + User : User?
    + MaterialCompletions : ICollection~MaterialCompletion~
}

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

class User {
    <<entity>>
    + UserId : int
    + FullName : string?
    + Email : string
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IEnrollmentService {
    <<service interface>>
    + EnrollFreeAsync(userId: int, courseId: int) Task *
}

class IAuthService {
    <<service interface>>
    + IsEmailVerifiedAsync(userId: int) Task~bool~ *
}

class INotificationService {
    <<service interface>>
    + SendNotificationAsync(userId: int, title: string, message: string, link: string?) Task *
}

class IEnrollmentRepository {
    <<repository interface>>
    + AddEnrollmentAsync(enrollment: Enrollment) Task *
    + BeginTransactionAsync() Task~IDbContextTransaction~ *
    + SaveChangesAsync() Task~int~ *
}

class ICourseRepository {
    <<repository interface>>
    + GetByIdAsync(id: int) Task~Course?~ *
    + IsEnrolledAsync(userId: int, courseId: int) Task~bool~ *
}

class IUserRepository {
    <<repository interface>>
    + GetUserByIdAsync(userId: int) Task~User?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class EnrollmentService {
    <<service>>
    - _repo : IEnrollmentRepository
    - _courseRepo : ICourseRepository
    - _notificationService : INotificationService
    - _userRepo : IUserRepository
    
    + EnrollFreeAsync(userId: int, courseId: int) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class EnrollmentRepository {
    <<repository>>
    - _context : AppDbContext
    
    + AddEnrollmentAsync(enrollment: Enrollment) Task
    + BeginTransactionAsync() Task~IDbContextTransaction~
    + SaveChangesAsync() Task~int~
}

class CourseRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByIdAsync(id: int) Task~Course?~
    + IsEnrolledAsync(userId: int, courseId: int) Task~bool~
}

class UserRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetUserByIdAsync(userId: int) Task~User?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Enrollments : DbSet~Enrollment~
    + Courses : DbSet~Course~
    + Users : DbSet~User~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
EnrollmentControllerBE --> IEnrollmentService
EnrollmentControllerBE --> IAuthService
EnrollmentService --> IEnrollmentRepository
EnrollmentService --> ICourseRepository
EnrollmentService --> INotificationService
EnrollmentService --> IUserRepository
EnrollmentRepository --> AppDbContext
CourseRepository --> AppDbContext
UserRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
EnrollmentService ..|> IEnrollmentService
EnrollmentRepository ..|> IEnrollmentRepository
CourseRepository ..|> ICourseRepository
UserRepository ..|> IUserRepository

%% === DEPENDENCY ===
CourseControllerFE ..> EnrollmentControllerBE
EnrollmentService ..> Enrollment
EnrollmentService ..> Course
EnrollmentService ..> User
EnrollmentRepository ..> Enrollment
CourseRepository ..> Course
UserRepository ..> User

