classDiagram
direction LR

%% ==================== FRONTEND ====================

class CartControllerFE["CartController"] {
    <<frontend controller>>
    + ApplyCoupon(model: ApplyCouponViewModel) Task~IActionResult~
    + Index() Task~IActionResult~
}

class ApplyCouponViewModel {
    + CouponCode : string
}

%% ==================== BACKEND - CONTROLLER ====================

class CartControllerBE["CartController"] {
    <<backend controller>>
    - _cartService : ICartService
    
    + GetCartSummary(couponCode: string?) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class CartSummaryResponse {
    + Subtotal : decimal
    + DiscountAmount : decimal
    + TotalAmount : decimal
    + AppliedCouponCode : string?
    + Items : List~CartItemDto~
    + AvailableCoupons : List~CouponDto~
}

class CartItemDto {
    + CourseId : int
    + Title : string
    + Price : decimal
}

class CouponDto {
    + CouponCode : string
    + DiscountValue : decimal
    + CouponType : string
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class CartItem {
    + CartItemId : int
    + UserId : int
    + CourseId : int
    + Price : decimal
    + Course : Course?
}

class Course {
    + CourseId : int
    + Title : string
    + Price : decimal
}

class Coupon {
    + CouponId : int
    + CouponCode : string
    + CouponType : string
    + DiscountValue : decimal
    + MinOrderValue : decimal?
    + UsageLimit : int?
    + UsedCount : int?
    + StartDate : DateTime?
    + EndDate : DateTime?
    + IsActive : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ICartService {
    <<interface>>
    + GetCartSummaryAsync(userId: int, couponCode: string?) Task~CartSummaryResponse~ *
}

class ICartRepository {
    <<interface>>
    + GetCartItemsWithDetailsAsync(userId: int) Task~List~CartItem~~ *
}

class ICouponRepository {
    <<interface>>
    + GetByCodeAsync(code: string) Task~Coupon?~ *
    + GetActiveAvailableCouponsAsync(now: DateTime) Task~List~Coupon~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CartService {
    - _cartRepository : ICartRepository
    - _couponRepository : ICouponRepository
    
    + GetCartSummaryAsync(userId: int, couponCode: string?) Task~CartSummaryResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CartRepository {
    - _context : AppDbContext
    
    + GetCartItemsWithDetailsAsync(userId: int) Task~List~CartItem~~
}

class CouponRepository {
    - _context : AppDbContext
    
    + GetByCodeAsync(code: string) Task~Coupon?~
    + GetActiveAvailableCouponsAsync(now: DateTime) Task~List~Coupon~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + CartItems : DbSet~CartItem~
    + Coupons : DbSet~Coupon~
    + Courses : DbSet~Course~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === BIDIRECTIONAL ASSOCIATION (solid line) ===
CartItem -- Course

%% === AGGREGATION (hollow diamond) ===
CartSummaryResponse o-- CartItemDto
CartSummaryResponse o-- CouponDto

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
CartControllerBE --> ICartService
CartService --> ICartRepository
CartService --> ICouponRepository
CartRepository --> AppDbContext
CouponRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
CartService ..|> ICartService
CartRepository ..|> ICartRepository
CouponRepository ..|> ICouponRepository

%% === DEPENDENCY (dashed arrows) ===
CartControllerFE ..> CartControllerBE
CartControllerFE ..> ApplyCouponViewModel
CartControllerBE ..> CartSummaryResponse
CartService ..> CartSummaryResponse
CartRepository ..> CartItem
CouponRepository ..> Coupon

