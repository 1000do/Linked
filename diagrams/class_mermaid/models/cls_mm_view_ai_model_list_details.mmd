classDiagram
direction LR

%% ==================== FRONTEND ====================

class AdminAiServiceControllerFE["AdminAiServiceController"] {
    <<frontend controller>>
    + Index(tab: string, subtab: string, modelPage: int, coursePage: int, cReviewPage: int, lReviewPage: int) Task~IActionResult~
}

class AdminAiServicePageViewModel {
    <<view model>>
    + AiModels : List~AiModelViewModel~
    + AllActiveModels : List~AiModelViewModel~
    + Config : AiConfigurationViewModel
    + CourseLogs : List~CourseModerationLogViewModel~
    + CourseReviewLogs : List~ReviewModerationLogViewModel~
    + LessonReviewLogs : List~ReviewModerationLogViewModel~
}

class AiModelViewModel {
    <<view model>>
    + ModelId : int
    + ModelName : string
    + ModelVersion : string
    + ModelPath : string
    + ModelProvider : string
    + ModelType : string
    + ProcessType : string
    + Description : string
    + ModelStatus : string
    + ModelUpdatedAt : DateTime?
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminAiServiceControllerBE["AdminAiServiceController"] {
    <<backend controller>>
    - _aiModelService : IAiModelManagementService
    
    + GetPagedModels(request: PagedRequestDto) Task~IActionResult~
    + GetAllModels() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class PagedRequestDto {
    <<dto>>
    + Page : int
    + PageSize : int
}

class AiModelAdminDto {
    <<dto>>
    + ModelId : int
    + ModelName : string
    + ModelVersion : string
    + ModelPath : string
    + ModelProvider : string
    + ModelType : string
    + ProcessType : string
    + Description : string
    + ModelStatus : string
    + ModelUpdatedAt : DateTime?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class AiModel {
    + ModelId : int
    + ModelName : string
    + ModelType : string?
    + ModelProvider : string?
    + ModelVersion : string?
    + ModelStatus : string?
    + Description : string?
    + ModelCreatedAt : DateTime?
    + ModelUpdatedAt : DateTime?
    + ModelPath : string?
    + ProcessType : string?
    + CourseAiIntegrations : ICollection~CourseAiIntegration~
    + CourseReviewModerationLogs : ICollection~CourseReviewModerationLog~
    + LessonReviewModerationLogs : ICollection~LessonReviewModerationLog~
    + MessageModerationLogs : ICollection~MessageModerationLog~
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAiModelManagementService {
    <<service interface>>
    + GetAllModelsAsync() Task~List~AiModelAdminDto~~ *
    + GetPagedModelsAsync(req: PagedRequestDto) Task~PagedResult~AiModelAdminDto~~ *
}

class IAiModelRepository {
    <<repository interface>>
    + GetAllAdminAsync() Task~List~AiModel~~ *
    + GetPagedAdminAsync(page: int, pageSize: int) Task~(List~AiModel~, int)~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AiModelManagementService {
    <<service>>
    - _aiModelRepo : IAiModelRepository
    
    + GetAllModelsAsync() Task~List~AiModelAdminDto~~
    + GetPagedModelsAsync(req: PagedRequestDto) Task~PagedResult~AiModelAdminDto~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class AiModelRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetAllAdminAsync() Task~List~AiModel~~
    + GetPagedAdminAsync(page: int, pageSize: int) Task~(List~AiModel~, int)~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + AiModels : DbSet~AiModel~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
AdminAiServiceControllerBE --> IAiModelManagementService
AiModelManagementService --> IAiModelRepository
AiModelRepository --> AppDbContext

%% === AGGREGATION ===
AdminAiServicePageViewModel o-- AiModelViewModel

%% === INTERFACE REALIZATION ===
AiModelManagementService ..|> IAiModelManagementService
AiModelRepository ..|> IAiModelRepository

%% === DEPENDENCY (dashed arrows) ===
AdminAiServiceControllerFE ..> AdminAiServiceControllerBE
AdminAiServiceControllerFE ..> AdminAiServicePageViewModel
AdminAiServiceControllerBE ..> PagedRequestDto
AdminAiServiceControllerBE ..> AiModelAdminDto
AiModelManagementService ..> PagedRequestDto
AiModelManagementService ..> AiModelAdminDto
AiModelRepository ..> AiModel

