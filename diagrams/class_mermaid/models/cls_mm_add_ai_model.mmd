%% ==================== FRONTEND ====================

class AdminAiServiceControllerFE["AdminAiServiceController"] {
    <<frontend controller>>
    + AddModel(req: CreateAiModelRequest) Task~IActionResult~
}


class CreateAiModelRequestVM["CreateAiModelRequest"] {
    <<view model>>
    + ModelName : string
    + ModelVersion : string
    + ModelPath : string
    + ModelProvider : string
    + ModelType : string
    + ProcessType : string
    + Description : string
    + ModelStatus : string
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminAiServiceControllerBE["AdminAiServiceController"] {
    <<backend controller>>
    - _aiModelService : IAiModelManagementService
    
    + AddModel(req: CreateAiModelRequest) Task~IActionResult~
}


%% ==================== BACKEND - DTOs ====================

class CreateAiModelRequestDTO["CreateAiModelRequest"] {
    <<dto>>
    + ModelName : string
    + ModelVersion : string
    + ModelPath : string
    + ModelProvider : string
    + ModelType : string
    + ProcessType : string
    + Description : string
    + ModelStatus : string
}

class AiModelAdminDto {
    + ModelId : int
    + ModelName : string
    + ModelVersion : string
    + ModelPath : string
    + ModelProvider : string
    + ModelType : string
    + ProcessType : string
    + Description : string
    + ModelStatus : string
    + ModelUpdatedAt : DateTime?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class AiModel {
    + ModelId : int
    + ModelName : string
    + ModelType : string?
    + ModelProvider : string?
    + ModelVersion : string?
    + ModelStatus : string?
    + Description : string?
    + ModelCreatedAt : DateTime?
    + ModelUpdatedAt : DateTime?
    + ModelPath : string?
    + ProcessType : string?
    + CourseAiIntegrations : ICollection~CourseAiIntegration~
    + CourseReviewModerationLogs : ICollection~CourseReviewModerationLog~
    + LessonReviewModerationLogs : ICollection~LessonReviewModerationLog~
    + MessageModerationLogs : ICollection~MessageModerationLog~
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAiModelManagementService {
    <<service interface>>
    + AddModelAsync(req: CreateAiModelRequest) Task~AiModelAdminDto~ *
}

class IAiModelRepository {
    <<repository interface>>
    + Add(model: AiModel) AiModel *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AiModelManagementService {
    <<service>>
    - _aiModelRepo : IAiModelRepository
    
    + AddModelAsync(req: CreateAiModelRequest) Task~AiModelAdminDto~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class AiModelRepository {
    <<repository>>
    - _context : AppDbContext
    
    + Add(model: AiModel) AiModel
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + AiModels : DbSet~AiModel~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

