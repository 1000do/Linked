classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class TransactionControllerFE["TransactionController"] {
    <<frontend controller>>
    + Instructor(page: int, pageSize: int, year: int?, month: int?) Task~IActionResult~
}

class InstructorFinancePageVM {
    <<view model>>
    + Transactions : TransactionPagedVM
    + Payouts : InstructorPayoutPagedViewModel
    + CourseRevenues : List~InstructorCourseRevenueResponse~
}

class TransactionPagedVM {
    <<view model>>
    + Items : List~TransactionListItemVM~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
}

class TransactionListItemVM {
    <<view model>>
    + TransactionId : int
    + StripeSessionId : string?
    + Date : DateTime?
    + Amount : decimal
    + Status : string?
    + BuyerName : string
    + CourseTitle : string
    + InstructorName : string
    + Currency : string?
    + PayoutCurrency : string?
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
    + IsGift : bool
    + RecipientEmail : string?
    + IsGiftClaimed : bool
}

class InstructorPayoutPagedViewModel {
    <<view model>>
    + Items : List~InstructorPayoutViewModel~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
}

class InstructorPayoutViewModel {
    <<view model>>
    + PayoutId : int
    + Amount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + CourseTitle : string
    + TotalAmount : decimal
    + PayoutStatus : string?
    + PaidToBankAt : DateTime?
    + StripeTransferId : string?
    + StripePayoutId : string?
}

class InstructorCourseRevenueResponse {
    <<dto>>
    + CourseId : int
    + CourseTitle : string
    + InstructorId : int
    + InstructorName : string
    + SalesCount : int
    + MonthlyRevenue : decimal
    + PreviousMonthRevenue : decimal
    + YearlyRevenue : decimal
    + LifetimeRevenue : decimal
}

%% ==================== BACKEND - CONTROLLERS ====================

class TransactionControllerBE["TransactionController"] {
    <<backend controller>>
    - _transactionService : ITransactionService
    + GetInstructorTransactions(page: int, pageSize: int, year: int?, month: int?) Task~IActionResult~
    + GetInstructorCourseRevenues(year: int, month: int) Task~IActionResult~
}

class InstructorControllerBE["InstructorController"] {
    <<backend controller>>
    - _instructorService : IInstructorService
    + GetPayouts(page: int, pageSize: int, year: int?, month: int?) Task~IActionResult~
    + GetPayoutDays() Task~IActionResult~
}

%% ==================== BACKEND - SERVICES ====================

class ITransactionService {
    <<interface>>
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~
    + GetInstructorCourseRevenuesAsync(userId: int, year: int, month: int) Task~List~InstructorCourseRevenueResponse~~
}

class IInstructorService {
    <<interface>>
    + GetPayoutsAsync(userId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~
    + GetPayoutDaysDelay() int
}

class TransactionService {
    - _repo : ITransactionRepository
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~
    + GetInstructorCourseRevenuesAsync(userId: int, year: int, month: int) Task~List~InstructorCourseRevenueResponse~~
}

class InstructorService {
    - _repo : IInstructorRepository
    + GetPayoutsAsync(userId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~
    + GetPayoutDaysDelay() int
}

%% ==================== BACKEND - REPOSITORIES ====================

class ITransactionRepository {
    <<interface>>
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~
    + GetInstructorCourseRevenuesAsync(year: int, month: int) Task~List~InstructorCourseRevenueResponse~~
}

class IInstructorRepository {
    <<interface>>
    + GetPayoutsAsync(userId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~
}

class TransactionRepository {
    - _context : AppDbContext
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~
    + GetInstructorCourseRevenuesAsync(year: int, month: int) Task~List~InstructorCourseRevenueResponse~~
}

class InstructorRepository {
    - _context : AppDbContext
    + GetPayoutsAsync(userId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~
}

%% ==================== BACKEND - DB CONTEXT ====================

class AppDbContext {
    + Transactions : DbSet~Transaction~
    + InstructorPayouts : DbSet~InstructorPayout~
}

%% ==================== BACKEND - ENTITIES ====================

class Transaction {
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + TransferRate : decimal
    + StripeSessionId : string?
    + StripePaymentintentId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionType : string?
    + TransactionCreatedAt : DateTime?
}

class InstructorPayout {
    + PayoutId : int
    + TransactionId : int?
    + InstructorId : int?
    + PayoutAmount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + PayoutStatus : string
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
}

%% ==================== RELATIONSHIPS ====================

TransactionControllerFE ..> InstructorFinancePageVM
InstructorFinancePageVM o-- TransactionPagedVM
InstructorFinancePageVM o-- InstructorPayoutPagedViewModel
InstructorFinancePageVM o-- InstructorCourseRevenueResponse

TransactionPagedVM *-- TransactionListItemVM
InstructorPayoutPagedViewModel *-- InstructorPayoutViewModel

TransactionControllerFE ..> TransactionControllerBE : API
TransactionControllerFE ..> InstructorControllerBE : API

TransactionControllerBE --> ITransactionService
InstructorControllerBE --> IInstructorService

TransactionService ..|> ITransactionService
TransactionService --> ITransactionRepository

InstructorService ..|> IInstructorService
InstructorService --> IInstructorRepository

TransactionRepository ..|> ITransactionRepository
TransactionRepository --> AppDbContext

InstructorRepository ..|> IInstructorRepository
InstructorRepository --> AppDbContext

AppDbContext --> Transaction
AppDbContext --> InstructorPayout

