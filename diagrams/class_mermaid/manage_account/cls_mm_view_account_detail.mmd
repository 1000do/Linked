classDiagram
direction LR

%% ==================== FRONTEND ====================

class AdminAccountControllerFE["AdminAccountController"] {
    <<frontend controller>>
    + Detail(id: int) Task~IActionResult~
}

class AccountDetailViewModel {
    <<view model>>
    + AccountDetail : AdminAccountDetail
    + Transactions : AccountTransactionSummary
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminAccountControllerBE["AdminAccountController"] {
    <<backend controller>>
    - _adminAccountService : IAdminAccountService
    
    + GetAccountDetail(id: int) Task~IActionResult~
    + GetAccountTransactions(id: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class AdminAccountDetail {
    <<dto>>
    + AccountId : int
    + Email : string
    + Role : string
}

class AccountTransactionSummary {
    <<dto>>
    + TotalSpent : decimal
    + TotalRevenue : decimal
    + TotalWithdrawn : decimal
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminAccountService {
    <<service interface>>
    + GetAccountDetailAsync(id: int) Task~AdminAccountDetail~ *
    + GetAccountTransactionsAsync(id: int) Task~AccountTransactionSummary~ *
}

class IUserRepository {
    <<repository interface>>
    + GetAccountByIdAsync(id: int) Task~Account?~ *
}

class ILockoutRepository {
    <<repository interface>>
    + GetActiveLockoutAsync(id: int, type: string) Task~Lockout?~ *
}

class IReportRepository {
    <<repository interface>>
    + GetResolvedReportsCountAsync(id: int) Task~int~ *
}

class INotificationRepository {
    <<repository interface>>
    + GetSentNotificationsCountAsync(id: int) Task~int~ *
}

class IChatRepository {
    <<repository interface>>
    + GetActiveChatsCountAsync(id: int) Task~int~ *
}

class ITransactionRepository {
    <<repository interface>>
    + GetTotalSpentAsync(id: int) Task~decimal~ *
    + GetInstructorTotalRevenueAsync(id: int) Task~decimal~ *
    + GetInstructorTotalWithdrawnAsync(id: int) Task~decimal~ *
    + GetAccountTransactionsSummaryAsync(id: int) Task~AccountTransactionSummary~ *
}

class IEnrollmentRepository {
    <<repository interface>>
    + GetMyEnrolledCoursesAsync(id: int) Task~List~Enrollment~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AdminAccountService {
    <<service>>
    - _userRepository : IUserRepository
    - _lockoutRepository : ILockoutRepository
    - _reportRepository : IReportRepository
    - _notificationRepository : INotificationRepository
    - _chatRepository : IChatRepository
    - _transactionRepository : ITransactionRepository
    - _enrollmentRepository : IEnrollmentRepository
    
    + GetAccountDetailAsync(id: int) Task~AdminAccountDetail~
    + GetAccountTransactionsAsync(id: int) Task~AccountTransactionSummary~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class UserRepository {
    <<repository>>
    + GetAccountByIdAsync(id: int) Task~Account?~
}

class LockoutRepository {
    <<repository>>
    + GetActiveLockoutAsync(id: int, type: string) Task~Lockout?~
}

class ReportRepository {
    <<repository>>
    + GetResolvedReportsCountAsync(id: int) Task~int~
}

class NotificationRepository {
    <<repository>>
    + GetSentNotificationsCountAsync(id: int) Task~int~
}

class ChatRepository {
    <<repository>>
    + GetActiveChatsCountAsync(id: int) Task~int~
}

class TransactionRepository {
    <<repository>>
    + GetTotalSpentAsync(id: int) Task~decimal~
    + GetInstructorTotalRevenueAsync(id: int) Task~decimal~
    + GetInstructorTotalWithdrawnAsync(id: int) Task~decimal~
    + GetAccountTransactionsSummaryAsync(id: int) Task~AccountTransactionSummary~
}

class EnrollmentRepository {
    <<repository>>
    + GetMyEnrolledCoursesAsync(id: int) Task~List~Enrollment~~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION (hollow diamond) ===
AccountDetailViewModel o-- AdminAccountDetail
AccountDetailViewModel o-- AccountTransactionSummary

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
AdminAccountControllerBE --> IAdminAccountService
AdminAccountService --> IUserRepository
AdminAccountService --> ILockoutRepository
AdminAccountService --> IReportRepository
AdminAccountService --> INotificationRepository
AdminAccountService --> IChatRepository
AdminAccountService --> ITransactionRepository
AdminAccountService --> IEnrollmentRepository

%% === INTERFACE REALIZATION ===
AdminAccountService ..|> IAdminAccountService
UserRepository ..|> IUserRepository
LockoutRepository ..|> ILockoutRepository
ReportRepository ..|> IReportRepository
NotificationRepository ..|> INotificationRepository
ChatRepository ..|> IChatRepository
TransactionRepository ..|> ITransactionRepository
EnrollmentRepository ..|> IEnrollmentRepository

%% === DEPENDENCY (dashed arrows) ===
AdminAccountControllerFE ..> AdminAccountControllerBE
AdminAccountControllerFE ..> AccountDetailViewModel
AdminAccountControllerBE ..> AdminAccountDetail
AdminAccountControllerBE ..> AccountTransactionSummary

AdminAccountService ..> AdminAccountDetail
AdminAccountService ..> AccountTransactionSummary

