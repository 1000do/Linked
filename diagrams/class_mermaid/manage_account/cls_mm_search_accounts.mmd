%% ==================== FRONTEND ====================

class AdminAccountControllerFE["AdminAccountController"] {
    <<frontend controller>>
    + Index(keyword: string?, role: string?, page: int) Task~IActionResult~
}

class AdminAccountListViewModel {
    <<view model>>
    + Keyword : string?
    + Role : string?
    + CurrentPage : int
    + TotalPages : int
    + Accounts : List~AdminAccountListDto~
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminAccountControllerBE["AdminAccountController"] {
    <<backend controller>>
    - _adminAccountService : IAdminAccountService
    
    + GetAccounts(keyword: string?, role: string?, page: int, pageSize: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================



class AdminAccountListDto {
    <<dto>>
    + AccountId : int
    + Email : string
    + Username : string
    + AccountStatus : string
    + Role : string
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Account {
    <<entity>>
    + AccountId : int
    + Email : string
    + Username : string
    + PasswordHash : string?
    + AccountStatus : string
    + IsVerified : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminAccountService {
    <<service interface>>
    + GetAccountsPagedAsync(keyword: string?, role: string?, page: int, pageSize: int) Task~PagedResult~AdminAccountListDto~~ *
}

class IUserRepository {
    <<repository interface>>
    + GetAccountsPagedAsync(keyword: string?, role: string?, page: int, pageSize: int) Task~PagedResult~Account~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AdminAccountService {
    <<service>>
    - _userRepository : IUserRepository
    
    + GetAccountsPagedAsync(keyword: string?, role: string?, page: int, pageSize: int) Task~PagedResult~AdminAccountListDto~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class UserRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetAccountsPagedAsync(keyword: string?, role: string?, page: int, pageSize: int) Task~PagedResult~Account~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Accounts : DbSet~Account~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

