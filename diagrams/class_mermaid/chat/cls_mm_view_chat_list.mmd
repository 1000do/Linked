classDiagram
direction LR

%% ==================== FRONTEND ====================

class ChatControllerFE["ChatController"] {
    <<frontend controller>>
    + Index() IActionResult
    + Learner() IActionResult
    + Instructor() IActionResult
    + Admin() IActionResult
    - GetActorFromCookie() string
}

%% ==================== BACKEND - CONTROLLER ====================

class ChatControllerBE["ChatController"] {
    <<backend controller>>
    - _chatService : IChatService
    + GetMyChats() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class ChatListDto {
    <<dto>>
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + LastMessage : string?
    + LastMessageAt : DateTime?
    + PartnerName : string?
    + PartnerAvatar : string?
    + ContextType : string?
    + ContextId : int?
    + UnreadCount : int
    + IsOnline : bool
    + PartnerId : int?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class ChatParticipant {
    <<entity>>
    + ChatId : int
    + AccountId : int
    + Role : string
    + JoinedAt : DateTime
    + ClearedAt : DateTime?
    + UnreadCount : int
    + LastReadAt : DateTime?
}

class Chat {
    <<entity>>
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + ContextType : string?
    + ContextId : int?
    + CreatedAt : DateTime?
    + LastMessageAt : DateTime?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IChatService {
    <<service interface>>
    + GetMyChatsAsync(accountId: int) Task~List~ChatListDto~~ *
}

class IRedisService {
    <<service interface>>
    + GetUnreadCountAsync(accountId: int, chatId: int) Task~int~ *
    + IsUserOnlineAsync(accountId: int) Task~bool~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IChatRepository {
    <<repository interface>>
    + GetParticipantsByAccountIdAsync(accountId: int) Task~List~ChatParticipant~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ChatService {
    <<service>>
    - _chatRepository : IChatRepository
    - _redisService : IRedisService
    + GetMyChatsAsync(accountId: int) Task~List~ChatListDto~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ChatRepository {
    <<repository>>
    - _context : AppDbContext
    + GetParticipantsByAccountIdAsync(accountId: int) Task~List~ChatParticipant~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + ChatParticipants : DbSet~ChatParticipant~
    + Chats : DbSet~Chat~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
ChatControllerBE --> IChatService
ChatService --> IChatRepository
ChatService --> IRedisService
ChatRepository --> AppDbContext
ChatParticipant --> Chat

%% === INTERFACE REALIZATION ===
ChatService ..|> IChatService
ChatRepository ..|> IChatRepository

%% === DEPENDENCY ===
ChatControllerFE ..> ChatControllerBE
ChatControllerBE ..> ChatListDto
ChatService ..> ChatListDto
ChatRepository ..> ChatParticipant

