classDiagram
direction LR

%% ==================== FRONTEND ====================

class FrontendChatController["ChatController"] {
    <<frontend controller>>
    + Index() IActionResult
    + Learner() IActionResult
    + Instructor() IActionResult
    + Admin() IActionResult
    - GetActorFromCookie() string
}

%% ==================== BACKEND - CONTROLLER ====================

class BackendChatController["ChatController"] {
    <<backend controller>>
    - _chatService : IChatService
    + SearchChats(q: string) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class ChatListDto {
    + ChatId : int
    + ChatName : string?
    + ChatType : string?
    + LastMessage : string?
    + LastMessageAt : DateTime?
    + ContextType : string?
    + ContextId : int?
    + UnreadCount : int
    + PartnerName : string?
    + PartnerAvatar : string?
    + PartnerId : int?
    + IsOnline : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Chat {
    + ChatId : int
    + ChatType : string?
    + ContextType : string?
    + ContextId : int?
    + CreatedAt : DateTime?
    + LastMessageAt : DateTime?
    + ChatName : string?
}

class ChatParticipant {
    + ChatId : int
    + AccountId : int
    + Role : string?
    + JoinedAt : DateTime?
    + ClearedAt : DateTime?
    + UnreadCount : int
    + LastReadAt : DateTime?
}

class Message {
    + MessageId : int
    + ChatId : int
    + SenderId : int
    + Content : string?
    + SentAt : DateTime?
    + IsSeen : bool?
    + MessageStatus : string?
}

class Account {
    + AccountId : int
    + Username : string?
    + Email : string
    + AvatarUrl : string?
}

class User {
    + UserId : int
    + AccountId : int?
    + FullName : string?
}

class Manager {
    + ManagerId : int
    + AccountId : int?
    + DisplayName : string?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IChatService {
    <<interface>>
    + SearchChatsAsync(accountId: int, query: string) Task~List~ChatListDto~~ *
}

class IRedisService {
    <<interface>>
    + GetUnreadCountAsync(accountId: int, chatId: int) Task~int~ *
    + IsUserOnlineAsync(accountId: int) Task~bool~ *
}

class IChatRepository {
    <<interface>>
    + SearchParticipantsByAccountIdAsync(accountId: int, query: string) Task~List~ChatParticipant~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ChatService {
    - _chatRepository : IChatRepository
    - _redisService : IRedisService
    + SearchChatsAsync(accountId: int, query: string) Task~List~ChatListDto~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ChatRepository {
    - _context : AppDbContext
    + SearchParticipantsByAccountIdAsync(accountId: int, query: string) Task~List~ChatParticipant~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Chats : DbSet~Chat~
    + ChatParticipants : DbSet~ChatParticipant~
    + Messages : DbSet~Message~
    + Accounts : DbSet~Account~
    + Users : DbSet~User~
    + Managers : DbSet~Manager~
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION ===
Chat *-- ChatParticipant
Chat *-- Message

%% === AGGREGATION ===
Account o-- User
Account o-- Manager

%% === UNIDIRECTIONAL ASSOCIATION ===
BackendChatController --> IChatService
ChatService --> IChatRepository
ChatService --> IRedisService
ChatRepository --> AppDbContext
ChatParticipant --> Account

%% === INTERFACE REALIZATION ===
ChatService ..|> IChatService
ChatRepository ..|> IChatRepository

%% === DEPENDENCY ===
FrontendChatController ..> BackendChatController
BackendChatController ..> ChatListDto
ChatService ..> ChatListDto
ChatRepository ..> ChatParticipant

