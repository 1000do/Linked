class IReportModerationService {
    <<interface>>
    + ResolveCourseReportAsync(reportId: int, resolverId: int, request: ResolveReportRequest) Task~bool~ *
    + ResolveCourseReviewReportAsync(reportId: int, resolverId: int, request: ResolveReportRequest) Task~bool~ *
    + ResolveLessonReviewReportAsync(reportId: int, resolverId: int, request: ResolveReportRequest) Task~bool~ *
}

class IReportRepository {
    <<interface>>
    + GetCourseReportByIdAsync(reportId: int) Task~CourseReport?~ *
    + GetCourseReviewReportByIdAsync(reportId: int) Task~CourseReviewReport?~ *
    + GetLessonReviewReportByIdAsync(reportId: int) Task~LessonReviewReport?~ *
    + UpdateCourseReport(report: CourseReport) void *
    + UpdateCourseReviewReport(report: CourseReviewReport) void *
    + UpdateLessonReviewReport(report: LessonReviewReport) void *
    + SaveChangesAsync() Task~int~ *
}

class IRedisService {
    <<interface>>
    + RemoveCacheAsync(key: string) Task *
}

class ReportModerationService {
    - _reportRepo : IReportRepository
    - _redisService : IRedisService
    + ResolveCourseReportAsync(reportId: int, resolverId: int, request: ResolveReportRequest) Task~bool~
    + ResolveCourseReviewReportAsync(reportId: int, resolverId: int, request: ResolveReportRequest) Task~bool~
    + ResolveLessonReviewReportAsync(reportId: int, resolverId: int, request: ResolveReportRequest) Task~bool~
    - GetCourseReportAndEntityAsync(reportId: int) Task~Tuple~CourseReport, Course~~
    - GetCourseReviewReportAndEntityAsync(reportId: int) Task~Tuple~CourseReviewReport, CourseReview~~
    - GetLessonReviewReportAndEntityAsync(reportId: int) Task~Tuple~LessonReviewReport, LessonReview~~
    - ValidateReportResolutionAccessAsync(currentStatus: string, resolverId: int) Task
    - ApplyCoursePenaltyAsync(course: Course, removeContent: bool, resolutionNote: string) Task
    - ApplyCourseReviewPenaltyAsync(review: CourseReview, removeContent: bool, resolutionNote: string) Task
    - ApplyLessonReviewPenaltyAsync(review: LessonReview, removeContent: bool, resolutionNote: string) Task
    - SaveReportChangesAsync() Task
    - NotifyAdminOnEscalationAsync(status: string, reportId: int, reportType: string) Task
    - ResolveLinkActionAsync(reportType: string, targetId: int?) Task~string~
    - NotifyReporterOfOutcomeAsync(reporterId: int?, linkAction: string, status: string, reportType: string) Task
    - SendResolutionNotificationsAsync(status: string, reportId: int, reporterId: int?, reportType: string, targetId: int?) Task
}

class ReportRepository {
    - _context : AppDbContext
    + GetCourseReportByIdAsync(reportId: int) Task~CourseReport?~
    + GetCourseReviewReportByIdAsync(reportId: int) Task~CourseReviewReport?~
    + GetLessonReviewReportByIdAsync(reportId: int) Task~LessonReviewReport?~
    + UpdateCourseReport(report: CourseReport) void
    + UpdateCourseReviewReport(report: CourseReviewReport) void
    + UpdateLessonReviewReport(report: LessonReviewReport) void
    + SaveChangesAsync() Task~int~
}

class AppDbContext {
    + CourseReports : DbSet~CourseReport~
    + CourseReviewReports : DbSet~CourseReviewReport~
    + LessonReviewReports : DbSet~LessonReviewReport~
}

