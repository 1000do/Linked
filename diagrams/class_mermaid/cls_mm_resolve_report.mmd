class AdminModerationControllerFE["AdminModerationController"] {
    <<frontend controller>>
    + ResolveCourseReport(reportId: int, model: ResolveReportViewModel) Task~IActionResult~
    + ResolveCourseReviewReport(reportId: int, model: ResolveReportViewModel) Task~IActionResult~
    + ResolveLessonReviewReport(reportId: int, model: ResolveReportViewModel) Task~IActionResult~
}

class ResolveReportViewModel {
    <<view model>>
    + Status : string
    + ResolutionNote : string?
    + RemoveContent : bool
}

class AdminModerationControllerBE["AdminModerationController"] {
    <<backend controller>>
    - _reportService : IReportModerationService
    + ResolveCourseReport(reportId: int, request: ResolveReportRequest) Task~IActionResult~
    + ResolveCourseReviewReport(reportId: int, request: ResolveReportRequest) Task~IActionResult~
    + ResolveLessonReviewReport(reportId: int, request: ResolveReportRequest) Task~IActionResult~
}

class ResolveReportRequest {
    <<dto>>
    + Status : string
