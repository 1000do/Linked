classDiagram
direction LR

%% ==================== FRONTEND ====================

class CourseControllerFE["CourseController"] {
    <<frontend controller>>
    + Index(query: string, category: string, sort: string, price: string, rating: string, page: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class CoursePublicController {
    <<backend controller>>
    - _courseQueryService : ICourseQueryService
    
    + GetAllCourses(query: string?, category: string?, sort: string?, price: string?, rating: string?, page: int?, pageSize: int?) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class PagedResultCourseResponse["PagedResult~CourseResponse~"] {
    <<dto>>
    + Items : List~CourseResponse~
    + TotalCount : int
}

class CourseResponse {
    <<dto>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CourseStatus : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + InstructorName : string?
    + TotalStudents : int
    + RatingAverage : decimal
    + CategoryName : string?
    + InstructorAvatarUrl : string?
    + InstructorBio : string?
    + InstructorProfessionalTitle : string?
    + InstructorReviewCount : int
    + InstructorStudentsCount : int
    + InstructorCoursesCount : int
    + IsEnrolled : bool
    + IsOwner : bool
    + TotalReviews : int
    + LastApprovedAt : DateTime?
    + AppliedCouponCode : string?
    + AppliedCouponType : string?
    + AppliedCouponValue : decimal?
    + IsRemoved : bool
    + IsInAnyCart : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ICourseQueryService {
    <<interface>>
    + GetPublishedCoursesAsync(query: string?, category: string?, sort: string?, price: string?, rating: string?, page: int, pageSize: int) Task~PagedResult~CourseResponse~~ *
}

class ICourseRepository {
    <<interface>>
    + GetPublishedCoursesAsync(query: string?, category: string?, sort: string?, price: string?, rating: string?, page: int, pageSize: int) Task~PagedResult~CourseResponse~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CourseQueryService {
    - _courseRepository : ICourseRepository
    
    + GetPublishedCoursesAsync(query: string?, category: string?, sort: string?, price: string?, rating: string?, page: int, pageSize: int) Task~PagedResult~CourseResponse~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CourseRepository {
    - _context : AppDbContext
    
    + GetPublishedCoursesAsync(query: string?, category: string?, sort: string?, price: string?, rating: string?, page: int, pageSize: int) Task~PagedResult~CourseResponse~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Courses : DbSet~Course~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION & COMPOSITION ===
PagedResultCourseResponse *-- CourseResponse

%% === UNIDIRECTIONAL ASSOCIATION ===
CoursePublicController --> ICourseQueryService
CourseQueryService --> ICourseRepository
CourseRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
CourseQueryService ..|> ICourseQueryService
CourseRepository ..|> ICourseRepository

%% === DEPENDENCY ===
CourseControllerFE ..> CoursePublicController
CoursePublicController ..> PagedResultCourseResponse
CourseQueryService ..> PagedResultCourseResponse
CourseRepository ..> PagedResultCourseResponse
CourseRepository ..> Course

