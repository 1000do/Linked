classDiagram
direction LR

%% ==================== BACKEND - CONTROLLER ====================

class CouponController {
    <<backend controller>>
    - _couponService : ICouponService
    
    + GetCoupons(isActive: bool?, type: string?, search: string?) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class CouponResponse {
    <<dto>>
    + CouponId : int
    + ManagerId : int?
    + CouponCode : string
    + CouponType : string?
    + DiscountValue : decimal
    + MinOrderValue : decimal
    + StartDate : DateTime?
    + EndDate : DateTime?
    + UsageLimit : int?
    + UsedCount : int?
    + IsActive : bool?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Coupon {
    <<entity>>
    + CouponId : int
    + ManagerId : int?
    + CouponCode : string
    + CouponType : string?
    + DiscountValue : decimal
    + MinOrderValue : decimal
    + StartDate : DateTime?
    + EndDate : DateTime?
    + UsageLimit : int?
    + UsedCount : int?
    + IsActive : bool?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ICouponService {
    <<service interface>>
    + GetAllAsync(managerId: int?, isActive: bool?, type: string?, search: string?, isAdmin: bool) Task~List~CouponResponse~~ *
}

class ICouponRepository {
    <<repository interface>>
    + GetAllAsync(filterId: int?, isActive: bool?, type: string?, search: string?) Task~List~Coupon~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CouponService {
    <<service>>
    - _couponRepository : ICouponRepository
    
    + GetAllAsync(managerId: int?, isActive: bool?, type: string?, search: string?, isAdmin: bool) Task~List~CouponResponse~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CouponRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetAllAsync(filterId: int?, isActive: bool?, type: string?, search: string?) Task~List~Coupon~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Coupons : DbSet~Coupon~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
CouponController --> ICouponService
CouponService --> ICouponRepository
CouponRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
CouponService ..|> ICouponService
CouponRepository ..|> ICouponRepository

%% === DEPENDENCY (dashed arrows) ===
CouponController ..> CouponResponse
CouponService ..> CouponResponse
CouponRepository ..> Coupon

