classDiagram
direction LR

%% ==================== FRONTEND ====================

class AccountControllerFE["AccountController"] {
    <<frontend controller>>
    + ChangePassword(request: ChangePasswordRequest) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class ProfileControllerBE["ProfileController"] {
    <<backend controller>>
    - _userProfileService : IUserProfileService
    
    + ChangePassword(request: ChangePasswordRequest) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class ChangePasswordRequest {
    + CurrentPassword : string
    + NewPassword : string
    + ConfirmNewPassword : string
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class User {
    + UserId : int
    + FullName : string?
    + Username : string
    + Email : string
    + PhoneNumber : string?
    + Bio : string?
    + DateOfBirth : DateTime?
    + IsVerified : bool
    + AvatarUrl : string?
    + Account : Account?
}

class Account {
    + AccountId : int
    + Email : string
    + Username : string
    + PasswordHash : string?
    + AccountStatus : string
    + IsVerified : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IUserProfileService {
    <<interface>>
    + ChangePasswordAsync(userId: int, currentPassword: string, newPassword: string) Task~bool~ *
}

class IUserRepository {
    <<interface>>
    + GetUserByIdAsync(userId: int) Task~User?~ *
    + UpdateAccountAsync(account: Account) void *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class UserProfileService {
    - _userRepository : IUserRepository
    
    + ChangePasswordAsync(userId: int, currentPassword: string, newPassword: string) Task~bool~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class UserRepository {
    - _context : AppDbContext
    
    + GetUserByIdAsync(userId: int) Task~User?~
    + UpdateAccountAsync(account: Account) void
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Users : DbSet~User~
    + Accounts : DbSet~Account~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
ProfileControllerBE --> IUserProfileService
UserProfileService --> IUserRepository
UserRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
UserProfileService ..|> IUserProfileService
UserRepository ..|> IUserRepository

%% === DEPENDENCY (dashed arrows) ===
AccountControllerFE ..> ChangePasswordRequest
ProfileControllerBE ..> ChangePasswordRequest

UserProfileService ..> User
UserProfileService ..> Account

UserRepository ..> User
UserRepository ..> Account

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
