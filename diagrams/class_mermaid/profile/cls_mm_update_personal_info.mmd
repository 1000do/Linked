classDiagram
direction LR

%% ==================== FRONTEND ====================

class AccountControllerFE["AccountController"] {
    <<frontend controller>>
    + EditProfile(request: UpdateProfileViewModel) Task~IActionResult~
}

%% ==================== FRONTEND - VIEW MODELS ====================

class UpdateProfileViewModel {
    <<view model>>
    + FullName : string
    + Email : string
    + PhoneNumber : string?
    + Bio : string?
    + DateOfBirth : DateTime?
    + AvatarFile : IFormFile?
}

%% ==================== BACKEND - CONTROLLER ====================

class ProfileControllerBE["ProfileController"] {
    <<backend controller>>
    - _userProfileService : IUserProfileService
    
    + UpdateProfile(request: UpdateProfileRequestDTO) Task~IActionResult~
    + GetProfile() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class UpdateProfileRequestDTO {
    <<dto>>
    + FullName : string
    + Email : string
    + PhoneNumber : string?
    + Bio : string?
    + DateOfBirth : DateTime?
    + AvatarFile : IFormFile?
}

class UserProfileResponse {
    <<dto>>
    + FullName : string?
    + Username : string
    + Email : string
    + PhoneNumber : string?
    + Bio : string?
    + DateOfBirth : DateTime?
    + IsVerified : bool
    + AvatarUrl : string?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class User {
    <<entity>>
    + UserId : int
    + FullName : string?
    + Username : string
    + Email : string
    + PhoneNumber : string?
    + Bio : string?
    + DateOfBirth : DateTime?
    + IsVerified : bool
    + AvatarUrl : string?
}

class Account {
    <<entity>>
    + AccountId : int
    + Email : string
}

class Instructor {
    + InstructorId : int
    + UserId : int
    + Bio : string?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IUserProfileService {
    <<service interface>>
    + UpdateProfileAsync(userId: int, request: UpdateProfileRequestDTO) Task~bool~ *
    + GetUserProfileAsync(userId: int) Task~UserProfileResponse?~ *
}

class IFileUploadService {
    <<service interface>>
    + UploadImageAsync(avatarFile: IFormFile) Task~string~ *
}

class IUserRepository {
    <<repository interface>>
    + GetUserByIdAsync(userId: int) Task~User?~ *
    + UpdateUserProfileAsync(userId: int, fullName: string, bio: string, dob: DateTime?, avatarUrl: string?, phoneNumber: string?, email: string) Task~bool~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class UserProfileService {
    <<service>>
    - _userRepository : IUserRepository
    - _fileUploadService : IFileUploadService
    
    + UpdateProfileAsync(userId: int, request: UpdateProfileRequestDTO) Task~bool~
    + GetUserProfileAsync(userId: int) Task~UserProfileResponse?~
}

class FileUploadService {
    <<service>>
    + UploadImageAsync(avatarFile: IFormFile) Task~string~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class UserRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetUserByIdAsync(userId: int) Task~User?~
    + UpdateUserProfileAsync(userId: int, fullName: string, bio: string, dob: DateTime?, avatarUrl: string?, phoneNumber: string?, email: string) Task~bool~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Users : DbSet~User~
    + Accounts : DbSet~Account~
    + Instructors : DbSet~Instructor~
    
    + SaveChangesAsync() Task~int~
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
ProfileControllerBE --> IUserProfileService
UserProfileService --> IUserRepository
UserProfileService --> IFileUploadService
UserRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
UserProfileService ..|> IUserProfileService
FileUploadService ..|> IFileUploadService
UserRepository ..|> IUserRepository

%% === DEPENDENCY (dashed arrows) ===
AccountControllerFE ..> UpdateProfileViewModel
ProfileControllerBE ..> UpdateProfileRequestDTO
UserProfileService ..> UpdateProfileRequestDTO

AccountControllerFE ..> UserProfileResponse
ProfileControllerBE ..> UserProfileResponse
UserProfileService ..> UserProfileResponse

UserRepository ..> User
UserRepository ..> Account
UserRepository ..> Instructor

