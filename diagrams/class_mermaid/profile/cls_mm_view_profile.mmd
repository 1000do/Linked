classDiagram
direction LR

%% ==================== FRONTEND ====================

class AccountController {
    <<frontend controller>>
    + Profile() Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class ProfileController {
    <<backend controller>>
    - _userProfileService : IUserProfileService
    
    + GetProfile() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class UserProfileResponseDTO {
    <<dto>>
    + FullName : string?
    + Username : string
    + Email : string
    + PhoneNumber : string?
    + Bio : string?
    + DateOfBirth : DateTime?
    + IsVerified : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class User {
    <<entity>>
    + UserId : int
    + FullName : string?
    + Username : string
    + Email : string
    + PhoneNumber : string?
    + Bio : string?
    + DateOfBirth : DateTime?
    + IsVerified : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IUserProfileService {
    <<service interface>>
    + GetUserProfileAsync(userId: int) Task~UserProfileResponseDTO?~ *
}

class IUserRepository {
    <<repository interface>>
    + GetUserByIdAsync(userId: int) Task~User?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class UserProfileService {
    <<service>>
    - _userRepository : IUserRepository
    
    + GetUserProfileAsync(userId: int) Task~UserProfileResponseDTO?~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class UserRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetUserByIdAsync(userId: int) Task~User?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Users : DbSet~User~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
ProfileController --> IUserProfileService
UserProfileService --> IUserRepository
UserRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
UserProfileService ..|> IUserProfileService
UserRepository ..|> IUserRepository

%% === DEPENDENCY (dashed arrows) ===
AccountController ..> UserProfileResponseDTO
ProfileController ..> UserProfileResponseDTO
UserProfileService ..> UserProfileResponseDTO
UserRepository ..> User

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
