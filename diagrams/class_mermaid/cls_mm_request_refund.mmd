classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class TransactionControllerFE["TransactionController"] {
    <<frontend controller>>
    + RequestRefund(transactionId: int, reason: string) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class TransactionControllerBE["TransactionController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    
    + RequestRefund(transactionId: int, request: StudentRefundRequest) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class StudentRefundRequest {
    <<dto>>
    + Reason : string
}

class RefundResultDto {
    <<dto>>
    + IsAutoRejected : bool
    + RejectReason : string?
}

class RefundEligibilityDto {
    <<dto>>
    + AccountFlagCount : int
    + PastRefundedCountForCourse : int
    + RefundRequestsLast14DaysCount : int
    + CourseTotalDurationHours : double
    + StudentProgressPercentage : double
    + CompletedVideoDurationHours : double
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction {
    + TransactionId : int
    + TransactionsStatus : string
    + TransactionExt : TransactionExt?
}

class TransactionExt {
    + TransactionId : int
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminFinanceService {
    <<interface>>
    + RequestRefundAsync(transactionId: int, studentId: int, reason: string) Task~RefundResultDto~~ *
}

class IAdminFinanceRepository {
    <<interface>>
    + GetTransactionWithFullGraphAsync(transactionId: int) Task~Transaction~~ *
    + GetRefundEligibilityMetricsAsync(transactionId: int, studentId: int, courseId: int) Task~RefundEligibilityDto~~ *
    + SaveChangesAsync() Task~int~~ *
}

class INotificationService {
    <<interface>>
    + SendNotificationAsync(userId: int, title: string, message: string, link: string) Task *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AdminFinanceService {
    - _repo : IAdminFinanceRepository
    - _notiService : INotificationService
    
    + RequestRefundAsync(transactionId: int, studentId: int, reason: string) Task~RefundResultDto~~
}

class NotificationService {
    + SendNotificationAsync(userId: int, title: string, message: string, link: string) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class AdminFinanceRepository {
    - _context : AppDbContext
    
    + GetTransactionWithFullGraphAsync(transactionId: int) Task~Transaction~~
    + GetRefundEligibilityMetricsAsync(transactionId: int, studentId: int, courseId: int) Task~RefundEligibilityDto~~
    + SaveChangesAsync() Task~int~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Transactions : DbSet~Transaction~
    + TransactionExts : DbSet~TransactionExt~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION / COMPOSITION ===
Transaction *-- TransactionExt

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
TransactionControllerBE --> IAdminFinanceService
AdminFinanceService --> IAdminFinanceRepository
AdminFinanceService --> INotificationService
AdminFinanceRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
AdminFinanceService ..|> IAdminFinanceService
AdminFinanceRepository ..|> IAdminFinanceRepository
NotificationService ..|> INotificationService

%% === DEPENDENCY (dashed arrows) ===
TransactionControllerFE ..> TransactionControllerBE
TransactionControllerBE ..> StudentRefundRequest
TransactionControllerBE ..> RefundResultDto
AdminFinanceService ..> RefundResultDto
AdminFinanceService ..> RefundEligibilityDto
AdminFinanceRepository ..> RefundEligibilityDto
AdminFinanceRepository ..> Transaction

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
