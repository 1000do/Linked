classDiagram
direction LR

%% ==================== FRONTEND ====================

class QuizAttemptControllerFE["QuizAttemptController"] {
    <<frontend controller>>
    + Details(attemptId: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class QuizAttemptControllerBE["QuizAttemptController"] {
    <<backend controller>>
    - _quizService : IQuizService
    
    + GetAttemptDetail(attemptId: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class QuizAttemptDetailResponse {
    <<dto>>
    + AttemptId : int
    + QuizId : int
    + QuizTitle : string
    + Score : int
    + IsPassed : bool
    + TotalQuestions : int
    + CorrectCount : int
    + SubmittedAt : DateTime?
    + Questions : List~QuizAttemptQuestionDetailResponse~
}

class QuizAttemptQuestionDetailResponse {
    <<dto>>
    + QuestionId : int
    + QuestionText : string
    + QuestionType : QuizQuestionType
    + Explanation : string?
    + SelectedOptionId : int?
    + IsCorrect : bool
    + Options : List~QuizOptionDetailResponse~
}

class QuizOptionDetailResponse {
    <<dto>>
    + OptionId : int
    + OptionText : string
    + IsCorrect : bool
    + OrderIndex : int
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class QuizAttempt {
    <<entity>>
    + AttemptId : int
    + QuizId : int
    + UserId : int
    + StartedAt : DateTime?
    + SubmittedAt : DateTime?
    + Score : int
    + IsPassed : bool
}

class QuizAttemptAnswer {
    <<entity>>
    + AnswerId : int
    + AttemptId : int
    + QuestionId : int
    + SelectedOptionId : int?
    + IsCorrect : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IQuizService {
    <<service interface>>
    + GetAttemptDetailAsync(attemptId: int, userId: int) Task~QuizAttemptDetailResponse~ *
}

class IQuizRepository {
    <<repository interface>>
    + GetAttemptByIdAsync(attemptId: int) Task~QuizAttempt?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class QuizService {
    <<service>>
    - _quizRepository : IQuizRepository
    
    + GetAttemptDetailAsync(attemptId: int, userId: int) Task~QuizAttemptDetailResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class QuizRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetAttemptByIdAsync(attemptId: int) Task~QuizAttempt?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + QuizAttempts : DbSet~QuizAttempt~
    + QuizAttemptAnswers : DbSet~QuizAttemptAnswer~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION & COMPOSITION ===
QuizAttemptDetailResponse *-- QuizAttemptQuestionDetailResponse
QuizAttemptQuestionDetailResponse *-- QuizOptionDetailResponse
QuizAttempt *-- QuizAttemptAnswer

%% === UNIDIRECTIONAL ASSOCIATION ===
QuizAttemptControllerBE --> IQuizService
QuizService --> IQuizRepository
QuizRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
QuizService ..|> IQuizService
QuizRepository ..|> IQuizRepository

%% === DEPENDENCY ===
QuizAttemptControllerFE ..> QuizAttemptControllerBE
QuizAttemptControllerBE ..> QuizAttemptDetailResponse
QuizService ..> QuizAttemptDetailResponse
QuizService ..> QuizAttempt
QuizRepository ..> QuizAttempt

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
