classDiagram
direction LR

%% ==================== FRONTEND ====================

class QuizAttemptControllerFE["QuizAttemptController"] {
    <<frontend controller>>
    + Detail(attemptId: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class QuizAttemptControllerBE["QuizAttemptController"] {
    <<backend controller>>
    - _quizService : IQuizService
    
    + GetAttemptDetail(attemptId: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class QuizAttemptDetailResponse {
    <<dto>>
    + AttemptId : int
    + Score : decimal
    + IsPassed : bool
    + Questions : List~QuestionDetailResponse~
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class QuizAttempt {
    <<entity>>
    + Id : int
    + UserId : int
    + QuizId : int
    + Score : decimal
    + IsPassed : bool
    + AttemptedAt : DateTime
    + Answers : List~QuizAttemptAnswer~
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IQuizService {
    <<interface>>
    + GetAttemptDetailAsync(attemptId: int, userId: int) Task~QuizAttemptDetailResponse~ *
}

class IQuizRepository {
    <<interface>>
    + GetAttemptByIdAsync(attemptId: int) Task~QuizAttempt~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class QuizService {
    - _quizRepository : IQuizRepository
    
    + GetAttemptDetailAsync(attemptId: int, userId: int) Task~QuizAttemptDetailResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class QuizRepository {
    - _context : AppDbContext
    
    + GetAttemptByIdAsync(attemptId: int) Task~QuizAttempt~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + QuizAttempts : DbSet~QuizAttempt~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
QuizAttemptControllerBE --> IQuizService
QuizService --> IQuizRepository
QuizRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
QuizService ..|> IQuizService
QuizRepository ..|> IQuizRepository

%% === DEPENDENCY (dashed arrows) ===
QuizAttemptControllerFE ..> QuizAttemptControllerBE
QuizAttemptControllerBE ..> QuizAttemptDetailResponse
QuizService ..> QuizAttemptDetailResponse
QuizService ..> QuizAttempt
QuizRepository ..> QuizAttempt

