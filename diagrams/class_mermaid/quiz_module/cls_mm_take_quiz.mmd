classDiagram
direction LR

%% ==================== FRONTEND ====================

class QuizAttemptControllerFE["QuizAttemptController"] {
    <<frontend controller>>
    + TakeQuiz(quizId: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class QuizAttemptControllerBE["QuizAttemptController"] {
    <<backend controller>>
    - _quizService : IQuizService
    
    + GetQuizForStudent(quizId: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class QuizStudentResponse {
    <<dto>>
    + QuizId : int
    + Title : string
    + Description : string?
    + TimeLimitMinutes : int?
    + PassingScore : int?
    + MaxAttempts : int?
    + Questions : List~QuizQuestionStudentResponse~
}

class QuizQuestionStudentResponse {
    <<dto>>
    + QuestionId : int
    + Content : string
    + QuestionType : string
    + Points : decimal
    + Options : List~QuizOptionStudentResponse~
}

class QuizOptionStudentResponse {
    <<dto>>
    + OptionId : int
    + Content : string
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Quiz {
    <<entity>>
    + QuizId : int
    + CourseId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + TimeLimitMinutes : int?
    + PassingScore : int?
    + MaxAttempts : int?
    + IsHidden : bool
    + IsRemoved : bool
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
}

class QuizQuestion {
    <<entity>>
    + QuestionId : int
    + QuizId : int
    + Content : string
    + QuestionType : string
    + Points : decimal
}

class QuizOption {
    <<entity>>
    + OptionId : int
    + QuestionId : int
    + Content : string
    + IsCorrect : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IQuizService {
    <<interface>>
    + GetQuizForStudentAsync(quizId: int, userId: int) Task~QuizStudentResponse~ *
}

class IQuizRepository {
    <<interface>>
    + GetQuizWithQuestionsAsync(quizId: int) Task~Quiz?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class QuizService {
    - _quizRepo : IQuizRepository
    
    + GetQuizForStudentAsync(quizId: int, userId: int) Task~QuizStudentResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class QuizRepository {
    - _context : AppDbContext
    
    + GetQuizWithQuestionsAsync(quizId: int) Task~Quiz?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Quizzes : DbSet~Quiz~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION & COMPOSITION ===
QuizStudentResponse *-- QuizQuestionStudentResponse
QuizQuestionStudentResponse *-- QuizOptionStudentResponse
Quiz *-- QuizQuestion
QuizQuestion *-- QuizOption

%% === UNIDIRECTIONAL ASSOCIATION ===
QuizAttemptControllerBE --> IQuizService
QuizService --> IQuizRepository
QuizRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
QuizService ..|> IQuizService
QuizRepository ..|> IQuizRepository

%% === DEPENDENCY ===
QuizAttemptControllerFE ..> QuizAttemptControllerBE
QuizAttemptControllerBE ..> QuizStudentResponse
QuizService ..> QuizStudentResponse
QuizService ..> Quiz
QuizRepository ..> Quiz

