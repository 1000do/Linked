classDiagram
direction LR

%% ==================== FRONTEND ====================

class QuizAttemptControllerFE["QuizAttemptController"] {
    <<frontend controller>>
    + History(quizId: int, page: int, pageSize: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class QuizAttemptControllerBE["QuizAttemptController"] {
    <<backend controller>>
    - _quizService : IQuizService
    
    + GetMyQuizHistory(quizId: int, request: PagedRequestDto) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class PagedRequestDto {
    <<dto>>
    + Page : int
    + PageSize : int
}

class QuizAttemptSummaryResponse {
    <<dto>>
    + AttemptId : int
    + QuizId : int
    + QuizTitle : string
    + UserId : int
    + UserFullName : string
    + Score : int
    + IsPassed : bool
    + StartedAt : DateTime?
    + SubmittedAt : DateTime?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class QuizAttempt {
    <<entity>>
    + AttemptId : int
    + QuizId : int
    + UserId : int
    + StartedAt : DateTime?
    + SubmittedAt : DateTime?
    + Score : int
    + IsPassed : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IQuizService {
    <<service interface>>
    + GetMyQuizAttemptsAsync(quizId: int, userId: int, request: PagedRequestDto) Task~List~QuizAttemptSummaryResponse~~ *
}

class IQuizRepository {
    <<repository interface>>
    + GetAttemptsByQuizAndUserAsync(quizId: int, userId: int, page: int, pageSize: int) Task~List~QuizAttempt~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class QuizService {
    <<service>>
    - _quizRepo : IQuizRepository
    
    + GetMyQuizAttemptsAsync(quizId: int, userId: int, request: PagedRequestDto) Task~List~QuizAttemptSummaryResponse~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class QuizRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetAttemptsByQuizAndUserAsync(quizId: int, userId: int, page: int, pageSize: int) Task~List~QuizAttempt~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + QuizAttempts : DbSet~QuizAttempt~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
QuizAttemptControllerBE --> IQuizService
QuizService --> IQuizRepository
QuizRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
QuizService ..|> IQuizService
QuizRepository ..|> IQuizRepository

%% === DEPENDENCY ===
QuizAttemptControllerFE ..> QuizAttemptControllerBE
QuizAttemptControllerBE ..> PagedRequestDto
QuizAttemptControllerBE ..> QuizAttemptSummaryResponse
QuizService ..> PagedRequestDto
QuizService ..> QuizAttemptSummaryResponse
QuizService ..> QuizAttempt
QuizRepository ..> QuizAttempt

