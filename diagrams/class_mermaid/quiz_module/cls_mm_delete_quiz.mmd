classDiagram
direction LR

%% ==================== FRONTEND ====================

class QuizControllerFE["QuizController"] {
    <<frontend controller>>
    + Delete(id: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class QuizControllerBE["QuizController"] {
    <<backend controller>>
    - _quizService : IQuizService
    
    + SoftDelete(id: int) Task~IActionResult~
    - GetInstructorId() int
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Quiz {
    <<entity>>
    + QuizId : int
    + InstructorId : int
    + Title : string
    + Description : string?
    + TimeLimitMinutes : int?
    + PassingScore : int
    + TotalQuestions : int
    + CourseId : int
    + IsHidden : bool
    + IsRemoved : bool
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IQuizService {
    <<service interface>>
    + SoftDeleteQuizAsync(quizId: int, instructorId: int) Task *
}

class IQuizRepository {
    <<repository interface>>
    + SoftDeleteAsync(quizId: int) Task *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class QuizService {
    <<service>>
    - _quizRepo : IQuizRepository
    
    + SoftDeleteQuizAsync(quizId: int, instructorId: int) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class QuizRepository {
    <<repository>>
    - _context : AppDbContext
    
    + SoftDeleteAsync(quizId: int) Task
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Quizzes : DbSet~Quiz~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
QuizControllerBE --> IQuizService
QuizService --> IQuizRepository
QuizRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
QuizService ..|> IQuizService
QuizRepository ..|> IQuizRepository

%% === DEPENDENCY ===
QuizControllerFE ..> QuizControllerBE
QuizService ..> Quiz
QuizRepository ..> Quiz

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000