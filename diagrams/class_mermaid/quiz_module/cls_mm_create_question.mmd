classDiagram
direction LR

%% ==================== FRONTEND ====================

class QuestionBankControllerFE["QuestionBankController"] {
    <<frontend controller>>
    + CreateQuestion(courseId: int, request: object) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class QuestionBankControllerBE["QuestionBankController"] {
    <<backend controller>>
    - _questionBankService : IQuestionBankService
    
    + AddQuestion(courseId: int, request: QuizAddQuestionRequest) Task~ActionResult~QuizQuestionResponse~~
    - GetCurrentUserId() int
}

%% ==================== BACKEND - DTOs ====================

class QuizAddQuestionRequest {
    <<dto>>
    + LessonId : int
    + QuestionText : string
    + Explanation : string?
    + QuestionType : QuizQuestionType
    + Options : List~QuizOptionRequest~
}

class QuizOptionRequest {
    <<dto>>
    + OptionText : string
    + IsCorrect : bool
}

class QuizQuestionResponse {
    <<dto>>
    + QuestionId : int
    + CourseId : int
    + LessonId : int?
    + QuestionText : string
    + Explanation : string?
    + QuestionType : QuizQuestionType
    + Options : List~QuizOptionResponse~
}

class QuizOptionResponse {
    <<dto>>
    + OptionId : int
    + OptionText : string
    + IsCorrect : bool
    + OrderIndex : int
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class QuizQuestion {
    + QuestionId : int
    + CourseId : int
    + LessonId : int
    + QuestionText : string
    + Explanation : string?
    + QuestionType : QuizQuestionType
    + CreatedAt : DateTime?
    + Course : Course?
    + Lesson : Lesson?
    + QuizOptions : ICollection~QuizOption~
    + QuizAttemptAnswers : ICollection~QuizAttemptAnswer~
}

class QuizOption {
    + OptionId : int
    + QuestionId : int
    + OptionText : string
    + IsCorrect : bool
    + OrderIndex : int
    + QuizQuestion : QuizQuestion?
    + QuizAttemptAnswers : ICollection~QuizAttemptAnswer~
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IQuestionBankService {
    <<interface>>
    + AddQuestionAsync(courseId: int, request: QuizAddQuestionRequest, instructorId: int) Task~QuizQuestionResponse~ *
}

class IQuestionBankRepository {
    <<interface>>
    + AddQuestionAsync(question: QuizQuestion) Task~QuizQuestion~ *
}

class ICourseRepository {
    <<interface>>
    + GetByIdAsync(id: int) Task~Course?~ *
}

class ILessonRepository {
    <<interface>>
    + GetByIdAsync(id: int) Task~Lesson?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class QuestionBankService {
    - _questionBankRepository : IQuestionBankRepository
    - _courseRepository : ICourseRepository
    - _lessonRepository : ILessonRepository
    
    + AddQuestionAsync(courseId: int, request: QuizAddQuestionRequest, instructorId: int) Task~QuizQuestionResponse~
    - ValidateQuizOptions(options: List~QuizOptionRequest~) void
    - EnsureInstructorOwnsCourseAsync(courseId: int, instructorId: int, errorMessage: string) Task~void~
    - MapToResponse(q: QuizQuestion) QuizQuestionResponse
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class QuestionBankRepository {
    - _context : AppDbContext
    
    + AddQuestionAsync(question: QuizQuestion) Task~QuizQuestion~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + QuizQuestions : DbSet~QuizQuestion~
    + QuizOptions : DbSet~QuizOption~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
QuizQuestion *-- QuizOption
QuizAddQuestionRequest *-- QuizOptionRequest
QuizQuestionResponse *-- QuizOptionResponse

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
QuestionBankControllerBE --> IQuestionBankService
QuestionBankService --> IQuestionBankRepository
QuestionBankService --> ICourseRepository
QuestionBankService --> ILessonRepository
QuestionBankRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
QuestionBankService ..|> IQuestionBankService
QuestionBankRepository ..|> IQuestionBankRepository

%% === DEPENDENCY (dashed arrows) ===
QuestionBankControllerFE ..> QuestionBankControllerBE
QuestionBankControllerBE ..> QuizAddQuestionRequest
QuestionBankService ..> QuizAddQuestionRequest
QuestionBankService ..> QuizQuestionResponse
QuestionBankService ..> QuizQuestion
QuestionBankRepository ..> QuizQuestion

