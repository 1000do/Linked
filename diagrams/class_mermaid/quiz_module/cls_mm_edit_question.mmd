classDiagram
direction LR

%% ==================== FRONTEND ====================

class QuestionBankControllerFE["QuestionBankController"] {
    <<frontend controller>>
    + UpdateQuestion(qId: int, request: object) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class QuestionBankControllerBE["QuestionBankController"] {
    <<backend controller>>
    - _questionBankService : IQuestionBankService
    
    + UpdateQuestion(questionId: int, request: QuizUpdateQuestionRequest) Task~ActionResult~QuizQuestionResponse~~
    - GetCurrentUserId() int
}

%% ==================== BACKEND - DTOs ====================

class QuizUpdateQuestionRequest {
    <<dto>>
    + LessonId : int
    + QuestionText : string
    + Explanation : string?
    + QuestionType : QuizQuestionType
    + Options : List~QuizUpdateOptionRequest~
}

class QuizUpdateOptionRequest {
    <<dto>>
    + OptionId : int?
    + OptionText : string
    + IsCorrect : bool
}

class QuizQuestionResponse {
    <<dto>>
    + QuestionId : int
    + CourseId : int
    + LessonId : int?
    + QuestionText : string
    + Explanation : string?
    + QuestionType : QuizQuestionType
    + Options : List~QuizOptionResponse~
}

class QuizOptionResponse {
    <<dto>>
    + OptionId : int
    + OptionText : string
    + IsCorrect : bool
    + OrderIndex : int
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class QuizQuestion {
    <<entity>>
    + QuestionId : int
    + CourseId : int
    + LessonId : int
    + QuestionText : string
    + Explanation : string?
    + QuestionType : QuizQuestionType
    + CreatedAt : DateTime?
}

class QuizOption {
    <<entity>>
    + OptionId : int
    + QuestionId : int
    + OptionText : string
    + IsCorrect : bool
    + OrderIndex : int
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IQuestionBankService {
    <<service interface>>
    + UpdateQuestionAsync(questionId: int, request: QuizUpdateQuestionRequest, instructorId: int) Task~QuizQuestionResponse~ *
}

class IQuestionBankRepository {
    <<repository interface>>
    + GetQuestionByIdAsync(questionId: int) Task~QuizQuestion?~ *
    + UpdateQuestionAsync(question: QuizQuestion) Task~QuizQuestion~ *
}

class ICourseRepository {
    <<repository interface>>
    + GetByIdAsync(id: int) Task~Course?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class QuestionBankService {
    <<service>>
    - _questionBankRepository : IQuestionBankRepository
    - _courseRepository : ICourseRepository
    
    + UpdateQuestionAsync(questionId: int, request: QuizUpdateQuestionRequest, instructorId: int) Task~QuizQuestionResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class QuestionBankRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetQuestionByIdAsync(questionId: int) Task~QuizQuestion?~
    + UpdateQuestionAsync(question: QuizQuestion) Task~QuizQuestion~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + QuizQuestions : DbSet~QuizQuestion~
    + QuizOptions : DbSet~QuizOption~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
QuizQuestion *-- QuizOption
QuizUpdateQuestionRequest *-- QuizUpdateOptionRequest
QuizQuestionResponse *-- QuizOptionResponse

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
QuestionBankControllerBE --> IQuestionBankService
QuestionBankService --> IQuestionBankRepository
QuestionBankService --> ICourseRepository
QuestionBankRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
QuestionBankService ..|> IQuestionBankService
QuestionBankRepository ..|> IQuestionBankRepository

%% === DEPENDENCY (dashed arrows) ===
QuestionBankControllerFE ..> QuestionBankControllerBE
QuestionBankControllerBE ..> QuizUpdateQuestionRequest
QuestionBankService ..> QuizUpdateQuestionRequest
QuestionBankService ..> QuizQuestionResponse
QuestionBankService ..> QuizQuestion
QuestionBankRepository ..> QuizQuestion

