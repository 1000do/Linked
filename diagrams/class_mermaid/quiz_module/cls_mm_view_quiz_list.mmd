classDiagram
direction LR

%% ==================== FRONTEND ====================

class QuizControllerFE["QuizController"] {
    <<frontend controller>>
    + Index(searchTerm: string?, page: int) Task~IActionResult~
}

class QuizListViewModel {
    <<view model>>
    + TotalCount : int
    + CurrentPage : int
    + TotalPages : int
    + FilterStatus : string?
    + SearchTerm : string?
    + Quizzes : List~QuizSummaryItem~
    + AvailableCourses : List~CourseListViewModel~
}

class QuizSummaryItem {
    <<view model>>
    + QuizId : int
    + Title : string
    + Description : string?
    + QuestionCount : int
    + TimeLimitMinutes : int?
    + PassingScore : int
    + CourseTitle : string
    + IsHidden : bool
    + IsRemoved : bool
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
}

%% ==================== BACKEND - CONTROLLER ====================

class QuizControllerBE["QuizController"] {
    <<backend controller>>
    - _quizService : IQuizService
    
    + GetMyQuizzes() Task~IActionResult~
    - GetInstructorId() int
}

%% ==================== BACKEND - DTOs ====================

class QuizSummaryResponse {
    <<dto>>
    + QuizId : int
    + Title : string
    + Description : string?
    + CourseId : int
    + CourseTitle : string
    + TotalQuestions : int
    + QuestionCount : int
    + TimeLimitMinutes : int?
    + PassingScore : int
    + IsHidden : bool
    + IsRemoved : bool
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Quiz {
    <<entity>>
    + QuizId : int
    + InstructorId : int
    + Title : string
    + Description : string?
    + TimeLimitMinutes : int?
    + PassingScore : int
    + TotalQuestions : int
    + CourseId : int
    + IsHidden : bool
    + IsRemoved : bool
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IQuizService {
    <<service interface>>
    + GetMyQuizzesAsync(instructorId: int) Task~List~QuizSummaryResponse~~ *
}

class IQuizRepository {
    <<repository interface>>
    + GetByInstructorAsync(instructorId: int) Task~List~Quiz~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class QuizService {
    <<service>>
    - _quizRepo : IQuizRepository
    
    + GetMyQuizzesAsync(instructorId: int) Task~List~QuizSummaryResponse~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class QuizRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByInstructorAsync(instructorId: int) Task~List~Quiz~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Quizzes : DbSet~Quiz~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
QuizControllerBE --> IQuizService
QuizService --> IQuizRepository
QuizRepository --> AppDbContext

%% === AGGREGATION & COMPOSITION ===
QuizListViewModel *-- QuizSummaryItem

%% === INTERFACE REALIZATION ===
QuizService ..|> IQuizService
QuizRepository ..|> IQuizRepository

%% === DEPENDENCY ===
QuizControllerFE ..> QuizControllerBE
QuizControllerFE ..> QuizListViewModel
QuizControllerBE ..> QuizSummaryResponse
QuizService ..> QuizSummaryResponse
QuizService ..> Quiz
QuizRepository ..> Quiz

