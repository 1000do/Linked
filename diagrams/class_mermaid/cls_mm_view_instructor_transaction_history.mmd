classDiagram
direction LR

%% ==================== FRONTEND - CONTROLLER ====================

class TransactionControllerFE["TransactionController"] {
    <<frontend controller>>
    + Instructor(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, payoutPage: int, payoutPageSize: int, payoutKeyword: string?, payoutSortBy: string?, payoutStatus: string?, year: int?, month: int?, courseSortBy: string?) Task~IActionResult~
}

%% ==================== FRONTEND - VIEW MODELS ====================

class InstructorFinancePageVM {
    <<view model>>
    + Transactions : TransactionPagedVM
    + Payouts : InstructorPayoutPagedViewModel
    + CourseRevenues : List~InstructorCourseRevenueResponse~
}

class TransactionPagedVM {
    <<view model>>
    + Items : List~TransactionListItemVM~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
}

class TransactionListItemVM {
    <<view model>>
    + TransactionId : int
    + PaymentMethod : string?
    + Amount : decimal
    + Currency : string?
    + Status : string?
    + CreatedAt : DateTime?
    + UserEmail : string?
    + UserName : string?
    + IsCourseOwner : bool
    + TransactionExt : TransactionExtVM?
}

class TransactionExtVM {
    <<view model>>
    + RefundReason : string?
    + RefundRequestedAt : DateTime?
}

%% ==================== BACKEND - CONTROLLER ====================

class TransactionControllerBE["TransactionController"] {
    <<backend controller>>
    - _transactionService : ITransactionService
    - _financeService : IAdminFinanceService
    + GetInstructorTransactions(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~IActionResult~
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ITransactionService {
    <<interface>>
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResultTransactionListDto~ *
}

class ITransactionRepository {
    <<interface>>
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~Tuple~List~TransactionListDto~, int~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class TransactionService {
    - _repo : ITransactionRepository
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResultTransactionListDto~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class TransactionRepository {
    - _context : AppDbContext
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~Tuple~List~TransactionListDto~, int~~
}

%% ==================== BACKEND - DB CONTEXT ====================

class AppDbContext {
    + Transactions : DbSet~Transaction~
}

%% ==================== BACKEND - DTOs ====================

class PagedResultTransactionListDto["PagedResult~TransactionListDto~"] {
    <<dto>>
    + Items : List~TransactionListDto~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
}

class TransactionListDto {
    <<dto>>
    + TransactionId : int
    + PaymentMethod : string?
    + Amount : decimal
    + Currency : string?
    + Status : string?
    + CreatedAt : DateTime?
    + UserEmail : string?
    + UserName : string?
    + IsCourseOwner : bool
    + TransactionExt : TransactionExtDto?
}

class TransactionExtDto {
    <<dto>>
    + RefundReason : string?
    + RefundRequestedAt : DateTime?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction {
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + TransferRate : decimal
    + StripeSessionId : string?
    + StripePaymentintentId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionType : string?
    + TransactionCreatedAt : DateTime?
    + TransactionExt : TransactionExt?
    + OrderItem : OrderItem?
    + AccountFromNavigation : Account?
    + AccountToNavigation : Account?
    + InstructorPayouts : ICollection~InstructorPayout~
}

class TransactionExt {
    + TransactionId : int
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
    + Transaction : Transaction
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
InstructorFinancePageVM *-- TransactionPagedVM
TransactionPagedVM *-- TransactionListItemVM
TransactionListItemVM *-- TransactionExtVM

PagedResultTransactionListDto *-- TransactionListDto
TransactionListDto *-- TransactionExtDto

Transaction *-- TransactionExt

%% === ASSOCIATION (solid arrow) ===
TransactionControllerBE --> ITransactionService
TransactionService --> ITransactionRepository
TransactionRepository --> AppDbContext

%% === REALIZATION (hollow arrow) ===
TransactionService ..|> ITransactionService
TransactionRepository ..|> ITransactionRepository

%% === DEPENDENCY (dashed arrow) ===
TransactionControllerFE ..> TransactionControllerBE
TransactionControllerFE ..> InstructorFinancePageVM
TransactionControllerBE ..> PagedResultTransactionListDto
TransactionService ..> PagedResultTransactionListDto
TransactionRepository ..> Transaction

