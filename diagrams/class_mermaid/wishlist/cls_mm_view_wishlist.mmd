classDiagram
direction LR

%% ==================== FRONTEND ====================

class WishlistControllerFE["WishlistController"] {
    <<frontend controller>>
    + Index() Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class WishlistControllerBE["WishlistController"] {
    <<backend controller>>
    - _wishlistService : IWishlistService
    
    + GetWishlist() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class WishlistResponseDTO {
    <<dto>>
    + CourseId : int
    + Title : string
    + ThumbnailUrl : string?
    + Price : decimal
    + InstructorName : string
    + AverageRating : double
    + EnrollmentCount : int
    + IsEnrolled : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class WishlistItem {
    + WishlistItemId : int
    + UserId : int
    + CourseId : int
    + CreatedAt : DateTime
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IWishlistService {
    <<service interface>>
    + GetWishlistAsync(userId: int) Task~List~WishlistResponseDTO~~ *
}

class IWishlistRepository {
    <<repository interface>>
    + GetByUserIdAsync(userId: int) Task~List~WishlistItem~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class WishlistService {
    <<service>>
    - _wishlistRepository : IWishlistRepository
    
    + GetWishlistAsync(userId: int) Task~List~WishlistResponseDTO~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class WishlistRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByUserIdAsync(userId: int) Task~List~WishlistItem~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + WishlistItems : DbSet~WishlistItem~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
WishlistControllerBE --> IWishlistService
WishlistService --> IWishlistRepository
WishlistRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
WishlistService ..|> IWishlistService
WishlistRepository ..|> IWishlistRepository

%% === DEPENDENCY (dashed arrows) ===
WishlistControllerFE ..> WishlistResponseDTO
WishlistControllerBE ..> WishlistResponseDTO
WishlistService ..> WishlistResponseDTO
WishlistService ..> WishlistItem
WishlistRepository ..> WishlistItem

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
