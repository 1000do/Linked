classDiagram
direction LR

%% ==================== FRONTEND ====================

class InstructorCourseControllerFE["InstructorCourseController"] {
    <<frontend controller>>
    + UpdateCourseStatus(courseId: int, status: string) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class CourseControllerBE["CourseController"] {
    <<backend controller>>
    - _courseCommandService : ICourseCommandService
    
    + UpdateCourseStatus(id: int, request: UpdateStatusRequest) Task~IActionResult~
    - GetInstructorId() int
}

%% ==================== BACKEND - DTOs ====================

class UpdateStatusRequest {
    <<dto>>
    + Status : string
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ICourseCommandService {
    <<service interface>>
    + UpdateCourseStatusAsync(courseId: int, status: string, instructorId: int) Task *
}

class ICourseRepository {
    <<repository interface>>
    + GetByIdAsync(id: int) Task~Course?~ *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CourseCommandService {
    <<service>>
    - _courseRepository : ICourseRepository
    
    + UpdateCourseStatusAsync(courseId: int, status: string, instructorId: int) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CourseRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByIdAsync(id: int) Task~Course?~
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Courses : DbSet~Course~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
CourseControllerBE --> ICourseCommandService
CourseCommandService --> ICourseRepository
CourseRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
CourseCommandService ..|> ICourseCommandService
CourseRepository ..|> ICourseRepository

%% === DEPENDENCY (dashed arrows) ===
InstructorCourseControllerFE ..> CourseControllerBE
CourseControllerBE ..> UpdateStatusRequest
CourseCommandService ..> Course
CourseRepository ..> Course

