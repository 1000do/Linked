classDiagram
direction LR

%% ==================== FRONTEND ====================

class InstructorCourseControllerFE["InstructorCourseController"] {
    <<frontend controller>>
    + Index(searchTerm: string?, status: string?, page: int) Task~IActionResult~
}

class InstructorStudioViewModel {
    <<viewmodel>>
    + Courses : List~CourseListViewModel~
    + TotalStudents : int
    + AverageRating : double
    + ActiveCoursesCount : int
    + PendingCoursesCount : int
    + DraftCoursesCount : int
    + TotalRevenue : decimal
    + EnrollmentGrowthPercentage : double
    + InstructorRankPercentage : int
    + CurrentPage : int
    + TotalPages : int
    + TotalItems : int
    + SearchTerm : string?
    + FilterStatus : string?
}

class CourseListViewModel {
    <<viewmodel>>
    + Id : int
    + Title : string
    + Students : int
    + Rating : double
    + Status : string
    + ThumbnailUrl : string
    + UpdatedAt : DateTime
    + IsRemoved : bool
    + FlagCount : int
}

%% ==================== BACKEND - CONTROLLER ====================

class CourseController {
    <<backend controller>>
    - _courseQueryService : ICourseQueryService
    + GetInstructorCourses(page: int, pageSize: int, query: string?, status: string?) Task~IActionResult~
}

class InstructorController {
    <<backend controller>>
    - _instructorService : IInstructorService
    + GetInstructorDashboardAsync() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class PagedResultCourseResponse["PagedResult~CourseResponse~"] {
    <<dto>>
    + Items : List~CourseResponse~
    + TotalCount : int
}

class CourseResponse {
    <<dto>>
    + CourseId : int
    + Title : string
    + Price : decimal
}

class InstructorDashboardDto {
    <<dto>>
    + TotalStudents : int
    + AverageRating : decimal
    + ActiveCoursesCount : int
    + PendingCoursesCount : int
    + DraftCoursesCount : int
    + TotalRevenue : decimal
    + EnrollmentGrowthPercentage : double
    + InstructorRankPercentage : int
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + CourseAiIntegrations : ICollection~CourseAiIntegration~
    + CartItems : ICollection~CartItem~
    + Category : Category?
    + Coupon : Coupon?
    + Enrollments : ICollection~Enrollment~
    + Instructor : Instructor?
    + Lessons : ICollection~Lesson~
    + OrderItems : ICollection~OrderItem~
    + WishlistItems : ICollection~WishlistItem~
    + CourseExt : CourseExt?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

class InstructorStats {
    <<entity>>
    + InstructorId : int
    + InstructorRating : double
    + TotalRevenue : decimal
    + TotalStudentsCount : int
}

class Enrollment {
    <<entity>>
    + EnrollmentId : int
    + UserId : int?
    + CourseId : int?
    + Title : string?
    + Description : string?
    + CompletedDate : DateOnly?
    + IsCompleted : bool?
    + EnrollDate : DateOnly?
    + LastAccessedAt : DateTime?
    + EnrollmentStatus : string?
    + Course : Course?
    + CourseReviews : ICollection~CourseReview~
    + LessonReviews : ICollection~LessonReview~
    + User : User?
    + MaterialCompletions : ICollection~MaterialCompletion~
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ICourseQueryService {
    <<interface>>
    + GetInstructorCoursesAsync(instructorId: int, page: int, pageSize: int, query: string, status: string) Task~PagedResult~CourseResponse~~ *
}

class IInstructorService {
    <<interface>>
    + GetInstructorDashboardAsync(userId: int) Task~InstructorDashboardDto?~ *
}

class ICourseRepository {
    <<interface>>
    + GetInstructorCoursesAsync(...) Task~PagedResult~CourseResponse~~ *
}

class IInstructorRepository {
    <<interface>>
    + GetDashboardDtoAsync(userId: int) Task~InstructorDashboardDto?~ *
    + GetEnrollmentGrowthAsync(instructorId: int) Task~double~ *
    + GetInstructorRankingPercentageAsync(instructorId: int) Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CourseQueryService {
    - _courseRepository : ICourseRepository
    + GetInstructorCoursesAsync(...) Task~PagedResult~CourseResponse~~
}

class InstructorService {
    - _repo : IInstructorRepository
    + GetInstructorDashboardAsync(userId: int) Task~InstructorDashboardDto?~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CourseRepository {
    - _context : AppDbContext
    + GetInstructorCoursesAsync(...) Task~PagedResult~CourseResponse~~
}

class InstructorRepository {
    - _context : AppDbContext
    + GetDashboardDtoAsync(userId: int) Task~InstructorDashboardDto?~
    + GetEnrollmentGrowthAsync(instructorId: int) Task~double~
    + GetInstructorRankingPercentageAsync(instructorId: int) Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Courses : DbSet~Course~
    + InstructorStats : DbSet~InstructorStats~
    + Enrollments : DbSet~Enrollment~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION & AGGREGATION ===
InstructorStudioViewModel o-- CourseListViewModel
PagedResultCourseResponse o-- CourseResponse
Course -- Enrollment

%% === UNIDIRECTIONAL ASSOCIATION ===
CourseController --> ICourseQueryService
InstructorController --> IInstructorService

CourseQueryService --> ICourseRepository
InstructorService --> IInstructorRepository

CourseRepository --> AppDbContext
InstructorRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
CourseQueryService ..|> ICourseQueryService
InstructorService ..|> IInstructorService
CourseRepository ..|> ICourseRepository
InstructorRepository ..|> IInstructorRepository

%% === DEPENDENCY (dashed arrows) ===
InstructorCourseControllerFE ..> CourseController
InstructorCourseControllerFE ..> InstructorController
InstructorCourseControllerFE ..> InstructorStudioViewModel

CourseQueryService ..> PagedResultCourseResponse
CourseRepository ..> Course
CourseRepository ..> PagedResultCourseResponse

InstructorService ..> InstructorDashboardDto
InstructorRepository ..> InstructorDashboardDto
InstructorRepository ..> InstructorStats
InstructorRepository ..> Enrollment

