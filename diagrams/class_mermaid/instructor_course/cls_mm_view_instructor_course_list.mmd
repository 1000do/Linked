classDiagram
direction LR

%% ==================== FRONTEND ====================

class InstructorCourseControllerFE["InstructorCourseController"] {
    <<frontend controller>>
    + Index(searchTerm: string?, status: string?, page: int) Task~IActionResult~
}

class InstructorStudioViewModel {
    <<viewmodel>>
    + Courses : List~CourseListViewModel~
    + TotalStudents : int
    + AverageRating : double
    + ActiveCoursesCount : int
    + PendingCoursesCount : int
    + DraftCoursesCount : int
    + TotalRevenue : decimal
    + EnrollmentGrowthPercentage : double
    + InstructorRankPercentage : int
    + CurrentPage : int
    + TotalPages : int
    + TotalItems : int
    + SearchTerm : string?
    + FilterStatus : string?
}

class CourseListViewModel {
    <<viewmodel>>
    + Id : int
    + Title : string
    + Students : int
    + Rating : double
    + Status : string
    + ThumbnailUrl : string
    + UpdatedAt : DateTime
    + IsRemoved : bool
    + FlagCount : int
}

%% ==================== BACKEND - CONTROLLER ====================

class CourseControllerBE["CourseController"] {
    <<backend controller>>
    - _courseQueryService : ICourseQueryService
    + GetMyCourses(search: string?, status: string?, page: int?, pageSize: int?) Task~IActionResult~
    - GetInstructorId() int
}

class InstructorControllerBE["InstructorController"] {
    <<backend controller>>
    - _instructorService : IInstructorService
    + GetDashboard() Task~IActionResult~
    - GetUserId() int?
}

%% ==================== BACKEND - DTOs ====================

class CourseResponse {
    <<dto>>
    + CourseId : int
    + Title : string
    + Price : decimal
}

class InstructorDashboardDto {
    <<dto>>
    + TotalStudents : int
    + AverageRating : decimal
    + ActiveCoursesCount : int
    + PendingCoursesCount : int
    + DraftCoursesCount : int
    + TotalRevenue : decimal
    + EnrollmentGrowthPercentage : double
    + InstructorRankPercentage : int
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

class InstructorStats {
    <<entity>>
    + InstructorId : int
    + InstructorRating : double
    + TotalRevenue : decimal
    + TotalStudentsCount : int
}

class Enrollment {
    <<entity>>
    + EnrollmentId : int
    + UserId : int?
    + CourseId : int?
    + Title : string?
    + Description : string?
    + CompletedDate : DateOnly?
    + IsCompleted : bool?
    + EnrollDate : DateOnly?
    + LastAccessedAt : DateTime?
    + EnrollmentStatus : string?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ICourseQueryService {
    <<service interface>>
    + GetInstructorCoursesPagedAsync(instructorId: int, search: string?, status: string?, page: int?, pageSize: int?) Task~PagedResult~CourseResponse~~ *
}

class IInstructorService {
    <<service interface>>
    + GetInstructorDashboardAsync(userId: int) Task~InstructorDashboardDto?~ *
}

class ICourseRepository {
    <<repository interface>>
    + GetInstructorCoursesPagedAsync(instructorId: int, search: string?, status: string?, page: int?, pageSize: int?) Task~(IEnumerable~Course~ Courses, int TotalCount)~ *
}

class IInstructorRepository {
    <<repository interface>>
    + GetDashboardDtoAsync(userId: int) Task~InstructorDashboardDto?~ *
    + GetEnrollmentGrowthAsync(instructorId: int) Task~double~ *
    + GetInstructorRankingPercentageAsync(instructorId: int) Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CourseQueryService {
    <<service>>
    - _courseRepository : ICourseRepository
    + GetInstructorCoursesPagedAsync(instructorId: int, search: string?, status: string?, page: int?, pageSize: int?) Task~PagedResult~CourseResponse~~
}

class InstructorService {
    <<service>>
    - _repo : IInstructorRepository
    + GetInstructorDashboardAsync(userId: int) Task~InstructorDashboardDto?~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CourseRepository {
    <<repository>>
    - _context : AppDbContext
    + GetInstructorCoursesPagedAsync(instructorId: int, search: string?, status: string?, page: int?, pageSize: int?) Task~(IEnumerable~Course~ Courses, int TotalCount)~
}

class InstructorRepository {
    <<repository>>
    - _context : AppDbContext
    + GetDashboardDtoAsync(userId: int) Task~InstructorDashboardDto?~
    + GetEnrollmentGrowthAsync(instructorId: int) Task~double~
    + GetInstructorRankingPercentageAsync(instructorId: int) Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Courses : DbSet~Course~
    + InstructorStats : DbSet~InstructorStats~
    + Enrollments : DbSet~Enrollment~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION & AGGREGATION ===
InstructorStudioViewModel *-- CourseListViewModel
Course *-- Enrollment

%% === UNIDIRECTIONAL ASSOCIATION ===
CourseControllerBE --> ICourseQueryService
InstructorControllerBE --> IInstructorService

CourseQueryService --> ICourseRepository
InstructorService --> IInstructorRepository

CourseRepository --> AppDbContext
InstructorRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
CourseQueryService ..|> ICourseQueryService
InstructorService ..|> IInstructorService
CourseRepository ..|> ICourseRepository
InstructorRepository ..|> IInstructorRepository

%% === DEPENDENCY ===
InstructorCourseControllerFE ..> CourseControllerBE
InstructorCourseControllerFE ..> InstructorControllerBE
InstructorCourseControllerFE ..> InstructorStudioViewModel

CourseQueryService ..> CourseResponse
CourseRepository ..> Course

InstructorService ..> InstructorDashboardDto
InstructorRepository ..> InstructorDashboardDto
InstructorRepository ..> InstructorStats
InstructorRepository ..> Enrollment

