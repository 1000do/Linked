classDiagram
direction LR

%% ==================== FRONTEND ====================

class InstructorCourseControllerFE["InstructorCourseController"] {
    <<frontend controller>>
    + AddLesson(courseId: int, title: string) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class LessonControllerBE["LessonController"] {
    <<backend controller>>
    - _lessonService : ILessonService
    
    + CreateLesson(request: LessonCreateRequest) Task~IActionResult~
    - GetInstructorId() int
}

%% ==================== BACKEND - DTOs ====================

class LessonCreateRequest {
    <<dto>>
    + CourseId : int
    + Title : string
    + Description : string?
    + ThumbnailUrl : string?
    + ThumbnailFile : IFormFile?
}

class LessonResponse {
    <<dto>>
    + LessonId : int
    + CourseId : int?
    + Title : string
    + Description : string?
    + ThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + LessonStatus : string?
    + CourseStatus : string?
    + ModerationFeedback : string?
    + LearningMaterials : List~MaterialResponse~
}

class MaterialResponse {
    <<dto>>
    + MaterialId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + MaterialMetadata : MaterialMetadata?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + LearningStatus : string?
    + ModerationFeedback : string?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Lesson {
    <<entity>>
    + LessonId : int
    + CourseId : int?
    + Title : string
    + Description : string?
    + ThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + LessonStatus : string?
    + ModerationFeedback : string?
    + IsRemoved : bool
}

class Course {
    <<entity>>
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

class LearningMaterial {
    <<entity>>
    + MaterialId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + MaterialMetadata : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + LearningStatus : string?
    + ModerationFeedback : string?
    + ThreatLevel : AiThreatLevel
    + IsRemoved : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ILessonService {
    <<service interface>>
    + CreateLessonAsync(request: LessonCreateRequest, instructorId: int) Task~LessonResponse~ *
}

class ILessonRepository {
    <<repository interface>>
    + AddAsync(lesson: Lesson) Task *
    + SaveChangesAsync() Task~int~ *
}

class ICourseRepository {
    <<repository interface>>
    + GetByIdAsync(id: int) Task~Course?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class LessonService {
    <<service>>
    - _lessonRepo : ILessonRepository
    - _courseRepo : ICourseRepository
    
    + CreateLessonAsync(request: LessonCreateRequest, instructorId: int) Task~LessonResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class LessonRepository {
    <<repository>>
    - _context : AppDbContext
    
    + AddAsync(lesson: Lesson) Task
    + SaveChangesAsync() Task~int~
}

class CourseRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByIdAsync(id: int) Task~Course?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Lessons : DbSet~Lesson~
    + Courses : DbSet~Course~
    + LearningMaterials : DbSet~LearningMaterial~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION & COMPOSITION ===
LessonResponse *-- MaterialResponse
Course *-- Lesson
Lesson *-- LearningMaterial

%% === UNIDIRECTIONAL ASSOCIATION ===
LessonControllerBE --> ILessonService
LessonService --> ILessonRepository
LessonService --> ICourseRepository
LessonRepository --> AppDbContext
CourseRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
LessonService ..|> ILessonService
LessonRepository ..|> ILessonRepository
CourseRepository ..|> ICourseRepository

%% === DEPENDENCY ===
InstructorCourseControllerFE ..> LessonControllerBE
LessonControllerBE ..> LessonCreateRequest
LessonService ..> LessonCreateRequest
LessonService ..> LessonResponse
LessonService ..> Lesson
LessonRepository ..> Lesson

