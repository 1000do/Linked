classDiagram
direction LR

%% ==================== FRONTEND ====================

class InstructorCourseControllerFE["InstructorCourseController"] {
    <<frontend controller>>
    + UpdateMaterialDetails(materialId: int, requestBody: object) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class LessonControllerBE["LessonController"] {
    <<backend controller>>
    - _lessonService : ILessonService
    
    + UpdateMaterialDetails(materialId: int, request: MaterialUpdateRequest) Task~IActionResult~
    - GetInstructorId() int
}

%% ==================== BACKEND - DTOs ====================

class MaterialUpdateRequest {
    <<dto>>
    + Title : string
    + Description : string?
}

class MaterialResponse {
    <<dto>>
    + MaterialId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + MaterialMetadata : MaterialMetadata?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + LearningStatus : string?
    + ModerationFeedback : string?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class LearningMaterial {
    <<entity>>
    + MaterialId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + MaterialMetadata : MaterialMetadata?
    + CloudPublicId : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + LearningStatus : string?
    + ModerationFeedback : string?
}

class MaterialMetadata {
    <<entity>>
    + FileSize : long?
    + FileType : string?
    + FileExtension : string?
    + Duration : int?
    + PageCount : int?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ILessonService {
    <<service interface>>
    + UpdateMaterialDetailsAsync(materialId: int, request: MaterialUpdateRequest, instructorId: int) Task~MaterialResponse~ *
}

class ILessonRepository {
    <<repository interface>>
    + GetByIdAsync(lessonId: int) Task~Lesson?~ *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class LessonService {
    <<service>>
    - _lessonRepo : ILessonRepository
    
    + UpdateMaterialDetailsAsync(materialId: int, request: MaterialUpdateRequest, instructorId: int) Task~MaterialResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class LessonRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByIdAsync(lessonId: int) Task~Lesson?~
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + LearningMaterials : DbSet~LearningMaterial~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION & COMPOSITION ===
LearningMaterial *-- MaterialMetadata
MaterialResponse *-- MaterialMetadata

%% === UNIDIRECTIONAL ASSOCIATION ===
LessonControllerBE --> ILessonService
LessonService --> ILessonRepository
LessonRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
LessonService ..|> ILessonService
LessonRepository ..|> ILessonRepository

%% === DEPENDENCY ===
InstructorCourseControllerFE ..> LessonControllerBE
LessonControllerBE ..> MaterialUpdateRequest
LessonService ..> MaterialUpdateRequest
LessonService ..> MaterialResponse
LessonService ..> LearningMaterial
LessonRepository ..> LearningMaterial

