classDiagram
direction LR

%% ==================== FRONTEND ====================

class InstructorCourseControllerFE["InstructorCourseController"] {
    <<frontend controller>>
    + PermanentDeleteMaterial(materialId: int) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class LessonControllerBE["LessonController"] {
    <<backend controller>>
    - _lessonService : ILessonService
    
    + PermanentDeleteMaterial(materialId: int) Task~IActionResult~
    - GetInstructorId() int
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class LearningMaterial {
    <<entity>>
    + MaterialId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + MaterialMetadata : MaterialMetadata?
    + CloudPublicId : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + LearningStatus : string?
    + ModerationFeedback : string?
    + IsRemoved : bool
}

class MaterialMetadata {
    <<entity>>
    + FileSize : long?
    + FileType : string?
    + FileExtension : string?
    + Duration : int?
    + PageCount : int?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ILessonService {
    <<service interface>>
    + PermanentDeleteMaterialAsync(materialId: int, instructorId: int) Task *
}

class IMaterialRepository {
    <<repository interface>>
    + GetByIdAsync(materialId: int) Task~LearningMaterial?~ *
    + Delete(material: LearningMaterial) void *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class LessonService {
    <<service>>
    - _materialRepository : IMaterialRepository
    
    + PermanentDeleteMaterialAsync(materialId: int, instructorId: int) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class MaterialRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByIdAsync(materialId: int) Task~LearningMaterial?~
    + Delete(material: LearningMaterial) void
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + LearningMaterials : DbSet~LearningMaterial~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION & COMPOSITION ===
LearningMaterial *-- MaterialMetadata

%% === UNIDIRECTIONAL ASSOCIATION ===
LessonControllerBE --> ILessonService
LessonService --> IMaterialRepository
MaterialRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
LessonService ..|> ILessonService
MaterialRepository ..|> IMaterialRepository

%% === DEPENDENCY ===
InstructorCourseControllerFE ..> LessonControllerBE
LessonService ..> LearningMaterial
MaterialRepository ..> LearningMaterial

