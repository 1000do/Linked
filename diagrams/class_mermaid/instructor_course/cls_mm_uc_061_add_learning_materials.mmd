classDiagram
direction LR

%% ==================== FRONTEND ====================

class InstructorCourseControllerFE["InstructorCourseController"] {
    <<frontend controller>>
    + AddMaterial(model: AddMaterialViewModel) Task~IActionResult~
}

class AddMaterialViewModel {
    <<view model>>
    + LessonId : int
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + Type : string
    + Duration : int?
    + FileSize : long?
    + FileExtension : string?
}

%% ==================== BACKEND - CONTROLLER ====================

class LessonControllerBE["LessonController"] {
    <<backend controller>>
    - _lessonService : ILessonService
    
    + AddMaterial(lessonId: int, request: MaterialCreateRequest) Task~IActionResult~
    - GetInstructorId() int
}

%% ==================== BACKEND - DTOs ====================

class MaterialCreateRequest {
    <<dto>>
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + MaterialMetadata : MaterialMetadata?
    + MaterialFile : IFormFile?
}

class MaterialResponse {
    <<dto>>
    + MaterialId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + MaterialMetadata : MaterialMetadata?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + LearningStatus : string?
    + ModerationFeedback : string?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class LearningMaterial {
    <<entity>>
    + MaterialId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + MaterialMetadata : MaterialMetadata?
    + CloudPublicId : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + LearningStatus : string?
    + ModerationFeedback : string?
}

class MaterialMetadata {
    <<entity>>
    + FileSize : long?
    + FileType : string?
    + FileExtension : string?
    + Duration : int?
    + PageCount : int?
}

class Lesson {
    <<entity>>
    + LessonId : int
    + CourseId : int?
    + Title : string
    + Description : string?
    + ThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + LessonStatus : string?
    + ModerationFeedback : string?
    + IsRemoved : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ILessonService {
    <<service interface>>
    + AddMaterialToLessonAsync(lessonId: int, request: MaterialCreateRequest, instructorId: int) Task~MaterialResponse~ *
}

class ILessonRepository {
    <<repository interface>>
    + GetByIdAsync(lessonId: int) Task~Lesson?~ *
    + SaveChangesAsync() Task~int~ *
}

class IFileUploadService {
    <<service interface>>
    + UploadVideoAsync(file: IFormFile) Task~string?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class LessonService {
    <<service>>
    - _lessonRepo : ILessonRepository
    - _uploadService : IFileUploadService
    
    + AddMaterialToLessonAsync(lessonId: int, request: MaterialCreateRequest, instructorId: int) Task~MaterialResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class LessonRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetByIdAsync(lessonId: int) Task~Lesson?~
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Lessons : DbSet~Lesson~
    + LearningMaterials : DbSet~LearningMaterial~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION & COMPOSITION ===
Lesson *-- LearningMaterial
LearningMaterial *-- MaterialMetadata
MaterialCreateRequest *-- MaterialMetadata
MaterialResponse *-- MaterialMetadata

%% === UNIDIRECTIONAL ASSOCIATION ===
LessonControllerBE --> ILessonService
LessonService --> ILessonRepository
LessonService --> IFileUploadService
LessonRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
LessonService ..|> ILessonService
LessonRepository ..|> ILessonRepository

%% === DEPENDENCY ===
InstructorCourseControllerFE ..> LessonControllerBE
InstructorCourseControllerFE ..> AddMaterialViewModel
LessonControllerBE ..> MaterialCreateRequest
LessonService ..> MaterialCreateRequest
LessonService ..> MaterialResponse
LessonService ..> LearningMaterial
LessonRepository ..> LearningMaterial

