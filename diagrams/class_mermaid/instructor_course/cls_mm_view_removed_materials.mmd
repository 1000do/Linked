classDiagram
direction LR

%% ==================== FRONTEND ====================

class InstructorCourseControllerFE["InstructorCourseController"] {
    <<frontend controller>>
    + Trash() Task~IActionResult~
}

class MaterialTrashViewModel {
    <<viewmodel>>
    + MaterialId : int
    + Title : string
    + LessonTitle : string?
    + CourseTitle : string?
    + DeletedAt : DateTime?
    + FileType : string?
    + CloudPublicId : string?
}

%% ==================== BACKEND - CONTROLLER ====================

class LessonControllerBE["LessonController"] {
    <<backend controller>>
    - _lessonService : ILessonService
    
    + GetTrashMaterials() Task~IActionResult~
    - GetInstructorId() int
}

%% ==================== BACKEND - DTOs ====================

class MaterialTrashResponse {
    <<dto>>
    + MaterialId : int
    + Title : string
    + LessonTitle : string?
    + CourseTitle : string?
    + DeletedAt : DateTime?
    + FileType : string?
    + CloudPublicId : string?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class LearningMaterial {
    <<entity>>
    + MaterialId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + MaterialUrl : string?
    + MaterialMetadata : MaterialMetadata?
    + CloudPublicId : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + LearningStatus : string?
    + ModerationFeedback : string?
    + IsRemoved : bool
}

class MaterialMetadata {
    <<entity>>
    + FileSize : long?
    + FileType : string?
    + FileExtension : string?
    + Duration : int?
    + PageCount : int?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ILessonService {
    <<service interface>>
    + GetTrashMaterialsAsync(instructorId: int) Task~IEnumerable~MaterialTrashResponse~~ *
}

class IMaterialRepository {
    <<repository interface>>
    + GetTrashMaterialsAsync(instructorId: int) Task~List~LearningMaterial~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class LessonService {
    <<service>>
    - _materialRepository : IMaterialRepository
    
    + GetTrashMaterialsAsync(instructorId: int) Task~IEnumerable~MaterialTrashResponse~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class MaterialRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetTrashMaterialsAsync(instructorId: int) Task~List~LearningMaterial~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + LearningMaterials : DbSet~LearningMaterial~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION & COMPOSITION ===
LearningMaterial *-- MaterialMetadata

%% === UNIDIRECTIONAL ASSOCIATION ===
LessonControllerBE --> ILessonService
LessonService --> IMaterialRepository
MaterialRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
LessonService ..|> ILessonService
MaterialRepository ..|> IMaterialRepository

%% === DEPENDENCY ===
InstructorCourseControllerFE ..> LessonControllerBE
InstructorCourseControllerFE ..> MaterialTrashViewModel
LessonControllerBE ..> MaterialTrashResponse
LessonService ..> MaterialTrashResponse
LessonService ..> LearningMaterial
MaterialRepository ..> LearningMaterial

