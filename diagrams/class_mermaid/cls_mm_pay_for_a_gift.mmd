%% ==================== FRONTEND ====================

class GiftController {
    <<frontend controller>>
    + Checkout(courseId: int, recipientEmail: string, recipientName: string?, giftMessage: string?, cardTheme: string) Task~IActionResult~
    + CreateGiftPaymentIntentAjax(courseId: int, recipientEmail: string, recipientName: string?, giftMessage: string?, cardTheme: string) Task~IActionResult~
    + CheckoutSuccess(sessionId: string?, paymentIntentId: string?) Task~IActionResult~
}

class CheckoutViewModel {
    <<view model>>
    + PublishableKey : string
    + ClientSecret : string
    + PaymentIntentId : string
    + Email : string
    + Cart : CartViewModel
}

class CartViewModel {
    <<view model>>
    + Items : List~CartItemViewModel~
    + SubTotal : decimal
    + Total : decimal
}

%% ==================== BACKEND - CONTROLLER ====================

class CheckoutController {
    <<backend controller>>
    - _giftCheckoutService : IGiftCheckoutService
    + GiftCreateIntent(request: GiftCheckoutRequest) Task~IActionResult~
    + GiftSuccessIntent(paymentIntentId: string) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class GiftCheckoutRequest {
    <<dto>>
    + CourseId : int
    + RecipientEmail : string
    + RecipientName : string?
    + GiftMessage : string?
    + CardTheme : string
    + SuccessUrl : string
    + CancelUrl : string
}

class CheckoutResponse {
    <<dto>>
    + SessionUrl : string
    + SessionId : string
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IGiftCheckoutService {
    <<interface>>
    + InitiateGiftPaymentIntentAsync(userId: int, request: GiftCheckoutRequest) Task~CheckoutResponse~ *
    + ProcessPaymentIntentSuccessAsync(paymentIntentId: string) Task *
}

class ICheckoutRepository {
    <<interface>>
    + BeginTransactionAsync() Task~IDbContextTransaction~ *
    + AddOrderAsync(order: OrderInfo) Task *
    + AddOrderItemAsync(orderItem: OrderItem) Task *
    + AddTransactionAsync(transaction: Transaction) Task *
    + AddInstructorPayoutAsync(payout: InstructorPayout) Task *
    + GetTransactionsBySessionIdAsync(stripeSessionId: string) Task~IEnumerable~Transaction~~ *
    + SaveChangesAsync() Task~int~ *
}

class IGiftRepository {
    <<interface>>
    + AddAsync(gift: Gift) Task *
    + SaveChangesAsync() Task~int~ *
}

class IPaymentGatewayService {
    <<interface>>
    + GetPaymentIntentMetadataAsync(paymentIntentId: string) Task~Dictionary~string,string~~ *
}

class IAdminFinanceService {
    <<interface>>
    + GetCurrentTransferRateAsync() Task~decimal~ *
    + GetPayoutDaysConfigAsync() Task~string~ *
}

class ICourseRepository {
    <<interface>>
    + GetCourseWithInstructorAsync(courseId: int) Task~Course?~ *
    + IsEnrolledAsync(accountId: int, courseId: int) Task~bool~ *
}

class IUserRepository {
    <<interface>>
    + GetInstructorStripeAccountIdAsync(instructorId: int) Task~string~ *
    + GetInstructorStripeCountryAsync(instructorId: int) Task~string~ *
    + GetUserEmailAsync(userId: int) Task~string~ *
    + GetAccountByEmailAsync(email: string) Task~Account?~ *
    + GetAccountByIdAsync(accountId: int) Task~Account?~ *
}

class IEmailService {
    <<interface>>
    + SendEmailAsync(to: string, subject: string, body: string) Task *
}

class INotificationService {
    <<interface>>
    + SendNotificationAsync(accountId: int, title: string, content: string, link: string) Task *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class GiftCheckoutService {
    - _repo : ICheckoutRepository
    - _paymentGateway : IPaymentGatewayService
    - _logger : ILogger~GiftCheckoutService~
    - _hubContext : IHubContext~FinanceHub~
    - _notificationService : INotificationService
    - _courseRepo : ICourseRepository
    - _userRepo : IUserRepository
    - _adminFinanceService : IAdminFinanceService
    - _giftRepo : IGiftRepository
    - _emailService : IEmailService
    - _configuration : IConfiguration
    
    + InitiateGiftPaymentIntentAsync(userId: int, request: GiftCheckoutRequest) Task~CheckoutResponse~
    + ProcessPaymentIntentSuccessAsync(paymentIntentId: string) Task
    - ProcessSuccessfulGiftPaymentCoreAsync(sessionId: string, paymentIntentId: string?, metadata: Dictionary~string,string~, userId: int) Task
    - CreateGiftOrderAsync(userId: int) Task~OrderInfo~
    - ProcessGiftCourseOrderItemAsync(orderId: int, courseId: int, userId: int, sessionId: string, paymentIntentId: string?, currentTransferRate: decimal, metadata: Dictionary~string,string~) Task
    - ValidateCourseForGiftAsync(course: Course?, recipientEmail: string, courseId: int) Task
    - BuildGiftMetadata(userId: int, request: GiftCheckoutRequest, courseId: int) Dictionary~string,string~
    - IsTransactionAlreadyProcessedAsync(stripeId: string) Task~bool~
    - ProcessGiftFulfillmentAsync(userId: int, orderItemId: int, course: Course, metadata: Dictionary~string,string~) Task
    - ProcessPayoutAndNotificationAsync(transaction: Transaction, instructorId: int?, courseTitle: string?, purchasePrice: decimal, currentTransferRate: decimal) Task
    - CalculatePayoutDateAsync(transactionDate: DateTime) Task~DateTime~
    - GetCurrencyFromCountry(countryCode: string?) string
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class OrderInfo {
    + OrderId : int
    + UserId : int
