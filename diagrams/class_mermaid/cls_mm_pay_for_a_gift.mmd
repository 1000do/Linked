    + OriginalPrice : decimal
    + DiscountAmount : decimal
}

class Transaction {
    + TransactionId : int
    + OrderItemId : int
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + TransferRate : decimal
    + StripeSessionId : string?
    + StripePaymentintentId : string?
    + Currency : string
    + TransactionsStatus : string
    + TransactionType : string
    + TransactionCreatedAt : DateTime
}

class Gift {
    + GiftId : int
    + OrderItemId : int
    + SenderId : int
    + RecipientEmail : string
    + RecipientName : string?
    + GiftMessage : string?
    + CardTheme : string
    + RedemptionToken : string
    + IsClaimed : bool
    + DeliveryStatus : string
    + CreatedAt : DateTime
    + UpdatedAt : DateTime
}

class InstructorPayout {
    + PayoutId : int
    + TransactionId : int
    + InstructorId : int
    + PayoutAmount : decimal
    + PayoutStatus : string
    + IsPaid : bool
    + CreatedAt : DateTime
    + PayoutDate : DateTime?
    + StripeTransferId : string?
}

class Course {
    + CourseId : int
    + InstructorId : int?
    + Title : string
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CourseStatus : string?
}

class Account {
    + AccountId : int
