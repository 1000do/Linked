classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    + Index(year: int?, month: int?) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + Withdrawals : PagedResult~WithdrawalHistoryVM~
}

class PagedResult_WithdrawalHistoryVM["PagedResult~WithdrawalHistoryVM~"] {
    <<view model>>
    + Items : List~WithdrawalHistoryVM~
    + TotalCount : int
    + PageCount : int
}

class WithdrawalHistoryVM {
    <<view model>>
    + WithdrawalId : int
    + ManagerName : string?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
}

%% ==================== BACKEND - CONTROLLERS ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetWithdrawalHistory(year: int?, month: int?, page: int, pageSize: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class PagedResult_WithdrawalHistoryItem["PagedResult~WithdrawalHistoryItem~"] {
    <<dto>>
    + Items : List~WithdrawalHistoryItem~
    + TotalCount : int
    + PageCount : int
}

class WithdrawalHistoryItem {
    <<dto>>
    + WithdrawalId : int
    + ManagerName : string?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
}

%% ==================== BACKEND - SERVICES ====================

class IAdminFinanceService {
    <<interface>>
    + GetWithdrawalHistoryAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~WithdrawalHistoryItem~~ *
}

class AdminFinanceService {
    - _financeRepo : IAdminFinanceRepository
    + GetWithdrawalHistoryAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~WithdrawalHistoryItem~~
}

%% ==================== BACKEND - REPOSITORIES ====================

class IAdminFinanceRepository {
    <<interface>>
    + GetWithdrawalsAsync(year: int?, month: int?, page: int, pageSize: int) Task~Tuple~List~PlatformWithdrawal~, int~~ *
}

class AdminFinanceRepository {
    - _context : AppDbContext
    + GetWithdrawalsAsync(year: int?, month: int?, page: int, pageSize: int) Task~Tuple~List~PlatformWithdrawal~, int~~
}

%% ==================== BACKEND - DB CONTEXT ====================

class AppDbContext {
    + PlatformWithdrawals : DbSet~PlatformWithdrawal~
}

%% ==================== BACKEND - ENTITIES ====================

class PlatformWithdrawal {
    + WithdrawalId : int
    + ManagerId : int?
    + Amount : decimal
    + StripePayoutId : string?
    + Status : string
    + CreatedAt : DateTime
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
AdminFinanceUnifiedVM --> PagedResult_WithdrawalHistoryVM
PagedResult_WithdrawalHistoryVM --> WithdrawalHistoryVM
PagedResult_WithdrawalHistoryItem --> WithdrawalHistoryItem

AdminFinanceControllerBE --> IAdminFinanceService
AdminFinanceService --> IAdminFinanceRepository
AdminFinanceRepository --> AppDbContext
AppDbContext --> PlatformWithdrawal

%% === REALIZATION ===
AdminFinanceService ..|> IAdminFinanceService
AdminFinanceRepository ..|> IAdminFinanceRepository

%% === DEPENDENCY ===
AdminFinanceControllerFE ..> AdminFinanceUnifiedVM
AdminFinanceControllerFE ..> AdminFinanceControllerBE : API calls
AdminFinanceControllerBE ..> PagedResult_WithdrawalHistoryItem
IAdminFinanceService ..> PagedResult_WithdrawalHistoryItem
IAdminFinanceRepository ..> PlatformWithdrawal
AdminFinanceRepository ..> PlatformWithdrawal

