classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    - _api : ApiClient
    + Index(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, year: int?, month: int?, payoutPage: int, withdrawPage: int) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + Dashboard : FinanceDashboardVM
    + Withdraw : WithdrawPageVM
    + Transactions : TransactionPagedVM
    + Payouts : PagedResult~PayoutDetailVM~
    + Withdrawals : PagedResult~WithdrawalHistoryVM~
    + PendingRefunds : PagedResult~RefundRequestVM~
    + PayoutDays : string
    + CourseRevenues : List~InstructorCourseRevenueResponse~
    + YearlySummaries : Dictionary~int, FinancialSummaryVM~
}

class PagedResultPayoutDetailVM["PagedResult~PayoutDetailVM~"] {
    + Items : List~PayoutDetailVM~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
    + HasNextPage : bool
    + HasPreviousPage : bool
}

class PayoutDetailVM {
    <<view model>>
    + PayoutId : int
    + TransactionId : int
    + InstructorName : string
    + InstructorEmail : string
    + CourseTitle : string
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + PlatformReceived : decimal
    + TransferRate : decimal
    + IsPaid : bool
    + TransactionDate : DateTime?
    + PayoutDate : DateTime
    + PayoutStatus : string?
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetPayouts(year: int?, month: int?, page: int, pageSize: int) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class ApiResponsePayout["ApiResponse~PagedResult~PayoutDetailResponse~~"] {
    <<dto>>
    + Success : bool
    + Message : string
    + Data : PagedResult~PayoutDetailResponse~
    + Errors : List~string~
}

class PagedResultPayoutDetailResponse["PagedResult~PayoutDetailResponse~"] {
    <<dto>>
    + Items : List~PayoutDetailResponse~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
    + HasNextPage : bool
    + HasPreviousPage : bool
}

class PayoutDetailResponse {
    <<dto>>
    + PayoutId : int
    + TransactionId : int
    + InstructorName : string
    + InstructorEmail : string
    + CourseTitle : string
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + PlatformReceived : decimal
    + TransferRate : decimal
    + IsPaid : bool
    + TransactionDate : DateTime?
    + PayoutDate : DateTime
    + PayoutStatus : string
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
}

class PayoutDetailProjection {
    <<dto>>
    + PayoutId : int
    + TransactionId : int
    + InstructorName : string
    + InstructorEmail : string
    + CourseTitle : string
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + TransferRate : decimal
    + IsPaid : bool
    + TransactionDate : DateTime?
    + PayoutDate : DateTime
