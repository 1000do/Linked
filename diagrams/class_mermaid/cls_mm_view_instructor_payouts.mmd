classDiagram
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    - _api : ApiClient
    - _jsonOpts : JsonSerializerOptions
    + Index(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, year: int?, month: int?, payoutPage: int, withdrawPage: int) Task~IActionResult~
    + SyncAllPayouts() Task~IActionResult~
    + PayViaStripe(payoutId: int) Task~IActionResult~
    + MarkAsPaid(payoutId: int) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    + Dashboard : FinanceDashboardVM
    + Withdraw : WithdrawPageVM
    + Transactions : TransactionPagedVM
    + Payouts : PagedResult~PayoutDetailVM~
    + Withdrawals : PagedResult~WithdrawalHistoryVM~
    + PendingRefunds : PagedResult~RefundRequestVM~
    + PayoutDays : string
    + CourseRevenues : List~InstructorCourseRevenueResponse~
    + YearlySummaries : Dictionary~int,FinancialSummaryVM~
}

class PayoutDetailVM {
    + PayoutId : int
    + TransactionId : int
    + InstructorName : string
    + InstructorEmail : string
    + CourseTitle : string
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + PlatformReceived : decimal
    + TransferRate : decimal
    + IsPaid : bool
    + TransactionDate : DateTime?
    + PayoutDate : DateTime
    + PayoutStatus : string?
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetPayouts(year: int?, month: int?, page: int, pageSize: int) Task~IActionResult~
    + SyncAllPayouts() Task~IActionResult~
    + TransferViaStripe(payoutId: int) Task~IActionResult~
    + MarkPayoutAsPaid(payoutId: int) Task~IActionResult~
}

