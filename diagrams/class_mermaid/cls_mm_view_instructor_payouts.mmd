%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminFinanceService {
    <<interface>>
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~ *
    + SyncAllPayoutsWithStripeAsync() Task *
    + PerformStripeTransferAsync(payoutId: int) Task~string~ *
    + MarkPayoutAsPaidAsync(payoutId: int) Task *
}

class IStripeConnectService {
    <<interface>>
    + ListPayoutsAsync(stripeAccountId: string) Task~List~StripePayoutDto~~ *
    + ListBalanceTransactionsAsync(stripeAccountId: string, stripePayoutId: string) Task~List~StripeBalanceTransactionDto~~ *
    + CreateConnectTransferAsync(amount: decimal, currency: string, destinationAccountId: string, description: string, payoutId: int) Task~StripeTransferResponseDto~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IAdminFinanceRepository {
    <<interface>>
    + GetPayoutDetailsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PayoutDetailProjection~,int~~ *
    + GetPayoutsByStripePayoutIdAsync(stripePayoutId: string) Task~List~InstructorPayout~~ *
    + GetPayoutByTransferIdAsync(transferId: string) Task~InstructorPayout?~ *
    + GetPayoutByIdAsync(payoutId: int) Task~InstructorPayout?~ *
    + SaveChangesAsync() Task~int~ *
}

class IInstructorRepository {
    <<interface>>
    + GetInstructorsWithStripeAsync() Task~List~Instructor~~ *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AdminFinanceService {
    - _repo : IAdminFinanceRepository
    - _instructorRepo : IInstructorRepository
    - _stripeConnect : IStripeConnectService
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~
    + SyncAllPayoutsWithStripeAsync() Task
    + PerformStripeTransferAsync(payoutId: int) Task~string~
    + MarkPayoutAsPaidAsync(payoutId: int) Task
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class AdminFinanceRepository {
    - _context : AppDbContext
    + GetPayoutDetailsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PayoutDetailProjection~,int~~
    + GetPayoutsByStripePayoutIdAsync(stripePayoutId: string) Task~List~InstructorPayout~~
    + GetPayoutByTransferIdAsync(transferId: string) Task~InstructorPayout?~
    + GetPayoutByIdAsync(payoutId: int) Task~InstructorPayout?~
    + SaveChangesAsync() Task~int~
}

class InstructorRepository {
    - _context : AppDbContext
    + GetInstructorsWithStripeAsync() Task~List~Instructor~~
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + InstructorPayouts : DbSet~InstructorPayout~
    + Transactions : DbSet~Transaction~
    + Instructors : DbSet~Instructor~
    + Users : DbSet~User~
}

