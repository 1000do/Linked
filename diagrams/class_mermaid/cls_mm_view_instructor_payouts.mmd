classDiagram-v2
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    + Index(year: int?, month: int?) Task~IActionResult~
    + SyncAllPayouts() Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + Payouts : PagedResult~PayoutDetailVM~
}

class PagedResult_PayoutDetailVM["PagedResult~PayoutDetailVM~"] {
    <<view model>>
    + Items : List~PayoutDetailVM~
    + TotalCount : int
    + PageCount : int
}

class PayoutDetailVM {
    <<view model>>
    + PayoutId : int
    + TransactionId : int
    + InstructorName : string
    + CourseTitle : string
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + TransferRate : decimal
    + IsPaid : bool
    + PayoutStatus : string?
    + StripeTransferId : string?
}

%% ==================== BACKEND - CONTROLLERS ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + GetPayouts(year: int?, month: int?, page: int, pageSize: int) Task~IActionResult~
    + SyncAllPayouts() Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class PagedResult_PayoutDetailResponse["PagedResult~PayoutDetailResponse~"] {
    <<dto>>
    + Items : List~PayoutDetailResponse~
    + TotalCount : int
    + PageCount : int
}

class PayoutDetailResponse {
    <<dto>>
    + PayoutId : int
    + TransactionId : int
    + InstructorName : string
    + CourseTitle : string
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + TransferRate : decimal
    + IsPaid : bool
    + PayoutStatus : string?
    + StripeTransferId : string?
}

%% ==================== BACKEND - SERVICES ====================

class IAdminFinanceService {
    <<interface>>
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~ *
    + SyncAllPayoutsWithStripeAsync() Task *
}

class AdminFinanceService {
    - _financeRepo : IAdminFinanceRepository
    - _stripeConnect : IStripeConnectService
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~
    + SyncAllPayoutsWithStripeAsync() Task
}

class IStripeConnectService {
    <<interface>>
    + SyncAllPayoutsWithStripeAsync() Task *
}

class StripeConnectService {
    + SyncAllPayoutsWithStripeAsync() Task
}


%% ==================== BACKEND - REPOSITORIES ====================

class IAdminFinanceRepository {
    <<interface>>
    + GetPayoutsAsync() Task~List~Payout~~ *
    + UpdatePayoutStatusAsync() Task *
}

class AdminFinanceRepository {
    - _context : AppDbContext
    + GetPayoutsAsync() Task~List~Payout~~
    + UpdatePayoutStatusAsync() Task
}

%% ==================== BACKEND - DB CONTEXT ====================

class AppDbContext {
    + Payouts : DbSet~Payout~
}

%% ==================== BACKEND - ENTITIES ====================

class Payout {
    + PayoutId : int
    + TransactionId : int
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + PayoutStatus : string
    + IsPaid : bool
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
AdminFinanceUnifiedVM --> PagedResult_PayoutDetailVM
PagedResult_PayoutDetailVM --> PayoutDetailVM
PagedResult_PayoutDetailResponse --> PayoutDetailResponse

AdminFinanceControllerBE --> IAdminFinanceService
AdminFinanceService --> IAdminFinanceRepository
AdminFinanceService --> IStripeConnectService
AdminFinanceRepository --> AppDbContext
AppDbContext --> Payout

%% === REALIZATION ===
AdminFinanceService ..|> IAdminFinanceService
AdminFinanceRepository ..|> IAdminFinanceRepository
StripeConnectService ..|> IStripeConnectService

%% === DEPENDENCY ===
AdminFinanceControllerFE ..> AdminFinanceUnifiedVM
AdminFinanceControllerFE ..> AdminFinanceControllerBE : API calls
AdminFinanceControllerBE ..> PagedResult_PayoutDetailResponse
IAdminFinanceService ..> PagedResult_PayoutDetailResponse
IAdminFinanceRepository ..> Payout
AdminFinanceRepository ..> Payout

%% ==================== STYLES ====================
classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
