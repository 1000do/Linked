    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminFinanceService {
    <<interface>>
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~ *
}

class IAdminFinanceRepository {
    <<interface>>
    + GetPayoutDetailsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PayoutDetailProjection~, int~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AdminFinanceService {
    - _repo : IAdminFinanceRepository
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class AdminFinanceRepository {
    - _context : AppDbContext
    + GetPayoutDetailsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PayoutDetailProjection~, int~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + InstructorPayouts : DbSet~InstructorPayout~
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class InstructorPayout {
    + PayoutId : int
    + TransactionId : int?
    + InstructorId : int?
    + PayoutAmount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + PayoutStatus : string
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
