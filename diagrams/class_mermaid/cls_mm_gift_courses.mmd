%% ==================== BACKEND - SERVICE INTERFACES ====================

class IGiftService {
    <<interface>>
    + IsRecipientEnrolledAsync(email: string, courseId: int) Task~bool~ *
}

class ICourseQueryService {
    <<interface>>
    + GetCourseWithDetailsAsync(courseId: int, userId: int?, userRole: string?) Task~CourseResponse~ *
}

class ICourseRepository {
    <<interface>>
    + IsEnrolledAsync(accountId: int, courseId: int) Task~bool~ *
    + GetCourseWithDetailsAsync(courseId: int) Task~Course?~ *
}

class IUserRepository {
    <<interface>>
    + GetAccountByEmailAsync(email: string) Task~Account?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class GiftService {
    - _giftRepo : IGiftRepository
    - _courseRepo : ICourseRepository
    - _userRepo : IUserRepository
    - _enrollmentRepo : IEnrollmentRepository
    - _transactionRepo : ITransactionRepository
    - _hubContext : IHubContext~FinanceHub~
    
    + IsRecipientEnrolledAsync(email: string, courseId: int) Task~bool~
    - GetGiftByTokenOrThrowAsync(token: string) Task~Gift~
    - ValidateGiftForViewing(gift: Gift) void
    - GetSenderNameAsync(senderId: int?) Task~string~
    - ValidateGiftForClaiming(gift: Gift) void
    - GetCourseForGiftOrThrowAsync(courseId: int?) Task~Course~
    - EnsureRecipientNotAlreadyEnrolledAsync(userId: int, courseId: int) Task
    - CreateEnrollmentWithinTransactionAsync(userId: int, course: Course) Task
    - MarkGiftAsClaimedWithinTransactionAsync(gift: Gift, userId: int) Task
    - NotifyAdminFinanceOfRefundRejectionAsync() Task
    - ValidateGiftCreationInputs(recipientEmail: string, token: string) void
    - EnsureNoExistingGiftAsync(orderItemId: int) Task
    - CreateNewGiftEntity(orderItemId: int, senderId: int, recipientEmail: string, recipientName: string?, message: string?, theme: string, token: string) Gift
}

class CourseQueryService {
    - _courseRepository : ICourseRepository
    - _instructorRepository : IInstructorRepository
    - _redisService : IRedisService
    - _cartRepository : ICartRepository
    
    + GetCourseWithDetailsAsync(courseId: int, userId: int?, userRole: string?) Task~CourseResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CourseRepository {
    - _context : AppDbContext
    
    + IsEnrolledAsync(accountId: int, courseId: int) Task~bool~
    + GetCourseWithDetailsAsync(courseId: int) Task~Course?~
}

class UserRepository {
    - _context : AppDbContext
    
    + GetAccountByEmailAsync(email: string) Task~Account?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Accounts : DbSet~Account~
    + Enrollments : DbSet~Enrollment~
    + Courses : DbSet~Course~
}

