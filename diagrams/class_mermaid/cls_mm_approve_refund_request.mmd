classDiagram
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    - _api : ApiClient
    - _jsonOpts : JsonSerializerOptions
    + ApproveRefundDecision(transactionId: int, adminNote: string?) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    + ApproveRefund(transactionId: int, request: RefundDecisionRequest) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class RefundDecisionRequest {
    + AdminNote : string?
}

class RefundResultResponse {
    + StripeRefundId : string
    + StripeReversalId : string?
    + RefundedAmount : decimal
    + EnrollmentRevoked : bool
    + TransactionStatus : string
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction {
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + TransferRate : decimal
    + StripeSessionId : string?
    + StripePaymentintentId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionType : string?
    + TransactionCreatedAt : DateTime?
    + TransactionExt : TransactionExt?
    + OrderItem : OrderItem?
    + AccountFromNavigation : Account?
    + AccountToNavigation : Account?
    + InstructorPayouts : ICollection~InstructorPayout~
}

class TransactionExt {
    + TransactionId : int
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
    + Transaction : Transaction
}

class OrderItem {
    + Id : int
    + OrderId : int?
    + CourseId : int?
    + PurchasePrice : decimal
    + CouponUsed : bool?
    + OriginalPrice : decimal?
    + CouponCode : string?
    + CouponType : string?
    + DiscountAmount : decimal
    + Course : Course?
    + Order : OrderInfo?
    + Transactions : ICollection~Transaction~
}

class Course {
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + IsRemoved : bool
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
}

class Account {
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
    + User : User?
    + TransactionFroms : ICollection~Transaction~
    + TransactionTos : ICollection~Transaction~
}

class User {
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
    + Instructor : Instructor?
    + UserNavigation : Account
}

class InstructorPayout {
    + PayoutId : int
    + TransactionId : int?
    + InstructorId : int?
    + PayoutAmount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + PayoutStatus : string
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
    + Transaction : Transaction?
    + Instructor : Instructor?
}

class Enrollment {
    + EnrollmentId : int
    + UserId : int?
    + CourseId : int?
    + Title : string?
    + Description : string?
    + CompletedDate : DateOnly?
    + IsCompleted : bool?
    + EnrollDate : DateOnly?
    + LastAccessedAt : DateTime?
    + EnrollmentStatus : string?
    + Course : Course?
    + User : User?
}

class Gift {
    + GiftId : int
    + OrderItemId : int
    + SenderId : int?
    + RecipientEmail : string
    + RecipientName : string?
    + GiftMessage : string?
    + CardTheme : string?
    + RedemptionToken : string
    + IsClaimed : bool
    + ClaimedByUserId : int?
    + ClaimedAt : DateTime?
    + DeliveryStatus : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + OrderItem : OrderItem
    + Sender : Account?
    + ClaimedByUser : User?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminFinanceService {
    <<interface>>
    + ApproveRefundAsync(transactionId: int, adminNote: string) Task *
    + RefundTransactionAsync(transactionId: int, reason: string?) Task~RefundResultResponse~ *
}

class IPaymentGatewayService {
    <<interface>>
    + ReverseTransferAsync(stripeTransferId: string) Task~string~ *
    + RefundAsync(paymentIntentId: string, amount: decimal, reason: string?) Task~string~ *
}

class INotificationService {
    <<interface>>
    + SendNotificationAsync(receiverId: int, title: string, content: string, actionUrl: string?) Task *
}

class ICourseRepository {
    <<interface>>
    + GetActiveEnrollmentAsync(userId: int, courseId: int) Task~Enrollment?~ *
}

class IGiftRepository {
    <<interface>>
    + GetByOrderItemIdAsync(orderItemId: int) Task~Gift?~ *
    + Update(gift: Gift) void *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IAdminFinanceRepository {
    <<interface>>
    + GetTransactionWithFullGraphAsync(transactionId: int) Task~Transaction?~ *
    + GetStripeTransferIdByDestinationPaymentAsync(destinationPaymentId: string) Task~string?~ *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AdminFinanceService {
    - _repo : IAdminFinanceRepository
    - _paymentGateway : IPaymentGatewayService
    - _notiService : INotificationService
    - _courseRepo : ICourseRepository
    - _giftRepo : IGiftRepository
    + ApproveRefundAsync(transactionId: int, adminNote: string) Task
    + RefundTransactionAsync(transactionId: int, reason: string?) Task~RefundResultResponse~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class AdminFinanceRepository {
    - _context : AppDbContext
    + GetTransactionWithFullGraphAsync(transactionId: int) Task~Transaction?~
    + GetStripeTransferIdByDestinationPaymentAsync(destinationPaymentId: string) Task~string?~
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Transactions : DbSet~Transaction~
    + TransactionExts : DbSet~TransactionExt~
    + OrderItems : DbSet~OrderItem~
    + Courses : DbSet~Course~
    + Accounts : DbSet~Account~
    + Users : DbSet~User~
    + InstructorPayouts : DbSet~InstructorPayout~
    + Enrollments : DbSet~Enrollment~
    + Gifts : DbSet~Gift~
}

%% ==================== RELATIONSHIPS ====================

%% === AGGREGATION (hollow diamond) ===
Transaction o-- TransactionExt
Transaction o-- OrderItem
OrderItem o-- Course
Transaction o-- Account
Account o-- User
Transaction o-- InstructorPayout
Enrollment o-- Course
Enrollment o-- User
Gift o-- OrderItem
Gift o-- User

%% === UNIDIRECTIONAL ASSOCIATION ===
AdminFinanceControllerFE ..> AdminFinanceControllerBE
AdminFinanceControllerBE --> IAdminFinanceService
AdminFinanceService --> IAdminFinanceRepository
AdminFinanceService --> IPaymentGatewayService
AdminFinanceService --> INotificationService
AdminFinanceService --> ICourseRepository
AdminFinanceService --> IGiftRepository
AdminFinanceRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
AdminFinanceService ..|> IAdminFinanceService
AdminFinanceRepository ..|> IAdminFinanceRepository

%% === DEPENDENCY ===
AdminFinanceControllerBE ..> RefundDecisionRequest
IAdminFinanceService ..> RefundResultResponse
AdminFinanceService ..> RefundResultResponse
AdminFinanceService ..> Transaction
AdminFinanceService ..> InstructorPayout
AdminFinanceService ..> Gift
AdminFinanceService ..> Enrollment
AdminFinanceRepository ..> Transaction

