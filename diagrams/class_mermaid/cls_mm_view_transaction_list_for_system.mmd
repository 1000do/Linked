classDiagram
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    + Index(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, year: int?, month: int?, payoutPage: int, withdrawPage: int) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + Transactions : TransactionPagedVM
}

class TransactionPagedVM {
    <<view model>>
    + Items : List~TransactionListItemVM~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
}

class TransactionListItemVM {
    <<view model>>
    + TransactionId : int
    + StripeSessionId : string?
    + Date : DateTime?
    + Amount : decimal
    + Status : string?
    + BuyerName : string
    + CourseTitle : string
    + InstructorName : string
    + Currency : string?
    + PayoutCurrency : string?
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
    + IsGift : bool
    + RecipientEmail : string?
    + IsGiftClaimed : bool
}

%% ==================== BACKEND - CONTROLLER ====================

class TransactionControllerBE["TransactionController"] {
    <<backend controller>>
    - _transactionService : ITransactionService
    + GetTransactions(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class PagedResultTransactionListDto["PagedResult~TransactionListDto~"] {
    <<dto>>
    + Items : IEnumerable~TransactionListDto~
    + TotalCount : int
    + Page : int
    + PageSize : int
    + TotalPages : int
}

class TransactionListDto {
    <<dto>>
    + TransactionId : int
    + StripeSessionId : string?
    + Date : DateTime?
    + Amount : decimal
    + Status : string?
    + BuyerName : string
    + CourseTitle : string
    + InstructorName : string
    + Currency : string?
    + PayoutCurrency : string?
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
    + IsGift : bool
    + RecipientEmail : string?
    + IsGiftClaimed : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction {
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + StripeSessionId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionCreatedAt : DateTime?
    + TransactionExt : TransactionExt?
    + OrderItem : OrderItem?
    + AccountFromNavigation : Account?
}

class TransactionExt {
    + TransactionId : int
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
}

class OrderItem {
    + Id : int
    + CourseId : int?
    + Course : Course?
}

class Course {
    + CourseId : int
    + Title : string
    + Instructor : Instructor?
}

class Instructor {
    + InstructorId : int
    + InstructorNavigation : User
}

class Account {
    + AccountId : int
    + User : User?
}

class User {
    + UserId : int
    + FullName : string
}

class Gift {
    + OrderItemId : int
    + RecipientEmail : string
    + IsClaimed : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class ITransactionService {
    <<interface>>
    + GetTransactionsAsync(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~TransactionListDto~~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class ITransactionRepository {
    <<interface>>
    + GetTransactionsAsync(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~ValueTuple~List~TransactionListDto~,int~~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class TransactionService {
    - _repo : ITransactionRepository
    + GetTransactionsAsync(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~TransactionListDto~~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class TransactionRepository {
    - _context : AppDbContext
    + GetTransactionsAsync(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~ValueTuple~List~TransactionListDto~,int~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Transactions : DbSet~Transaction~
    + TransactionExts : DbSet~TransactionExt~
    + OrderItems : DbSet~OrderItem~
    + Accounts : DbSet~Account~
    + Users : DbSet~User~
    + Courses : DbSet~Course~
    + Instructors : DbSet~Instructor~
    + Gifts : DbSet~Gift~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
AdminFinanceUnifiedVM *-- TransactionPagedVM
TransactionPagedVM *-- TransactionListItemVM
PagedResultTransactionListDto *-- TransactionListDto
Transaction *-- TransactionExt
OrderItem *-- Transaction
Account *-- User
User *-- Instructor
OrderItem *-- Gift

%% === AGGREGATION (hollow diamond) ===
Course o-- OrderItem

%% === UNIDIRECTIONAL ASSOCIATION ===
TransactionControllerBE --> ITransactionService
TransactionService --> ITransactionRepository
TransactionRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
TransactionService ..|> ITransactionService
TransactionRepository ..|> ITransactionRepository

%% === DEPENDENCY ===
AdminFinanceControllerFE ..> TransactionControllerBE
AdminFinanceControllerFE ..> AdminFinanceUnifiedVM
AdminFinanceControllerFE ..> TransactionPagedVM
TransactionControllerBE ..> PagedResultTransactionListDto
ITransactionService ..> PagedResultTransactionListDto
TransactionService ..> PagedResultTransactionListDto
ITransactionRepository ..> TransactionListDto
TransactionRepository ..> Transaction

%% === BIDIRECTIONAL ASSOCIATION ===
Transaction -- Account
Instructor -- Course
Gift -- Account
Gift -- User

