classDiagram
direction LR

%% ==================== FRONTEND ====================

class AccountController {
    <<frontend controller>>
    + Login() Task~IActionResult~
    + Login(model: LoginViewModel) Task~IActionResult~
}

class LoginViewModel {
    <<view model>>
    + UsernameOrEmail : string
    + Password : string
}

%% ==================== BACKEND - CONTROLLER ====================

class AuthController {
    <<backend controller>>
    - _authService : IAuthService
    
    + Login(request: LoginRequest) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class LoginRequest {
    <<dto>>
    + UsernameOrEmail : string
    + Password : string
}

class LoginResponse {
    <<dto>>
    + AccessToken : string
    + RefreshToken : string
    + UserName : string
    + AvatarUrl : string?
    + UserRole : string
    + UserId : int
    + IsVerified : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Account {
    <<entity>>
    + AccountId : int
    + Email : string
    + PasswordHash : string
    + AccountStatus : string
    + IsVerified : bool
    + LastLoginDate : DateTime?
    + RefreshToken : string?
    + User : User?
    + Lockouts : ICollection~Lockout~
}

class User {
    <<entity>>
    + UserId : int
    + AccountId : int
    + Username : string
    + FullName : string
    + AvatarUrl : string?
    + Account : Account?
}

class Lockout {
    <<entity>>
    + LockoutId : int
    + AccountId : int
    + LockoutType : string
    + LockoutEnd : DateTime
    + Reason : string?
    + IsActive : bool
    + Account : Account?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAuthService {
    <<service interface>>
    + LoginAsync(request: LoginRequest) Task~LoginResponse?~ *
}

class IUserRepository {
    <<repository interface>>
    + GetAccountByEmailOrUsernameAsync(usernameOrEmail: string) Task~Account?~ *
    + UpdateLastLoginAsync(accountId: int) Task~void~ *
    + GetRoleByAccountIdAsync(accountId: int) Task~string~ *
    + SaveRefreshTokenAsync(accountId: int, refreshToken: string) Task~void~ *
    + SaveChangesAsync() Task~int~ *
}

class ILockoutRepository {
    <<repository interface>>
    + GetActiveLockoutAsync(accountId: int, lockoutType: string) Task~Lockout?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AuthService {
    <<service>>
    - _userRepository : IUserRepository
    - _lockoutRepository : ILockoutRepository
    
    + LoginAsync(request: LoginRequest) Task~LoginResponse?~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class UserRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetAccountByEmailOrUsernameAsync(usernameOrEmail: string) Task~Account?~
    + UpdateLastLoginAsync(accountId: int) Task~void~
    + GetRoleByAccountIdAsync(accountId: int) Task~string~
    + SaveRefreshTokenAsync(accountId: int, refreshToken: string) Task~void~
    + SaveChangesAsync() Task~int~
}

class LockoutRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetActiveLockoutAsync(accountId: int, lockoutType: string) Task~Lockout?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Accounts : DbSet~Account~
    + Lockouts : DbSet~Lockout~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
Account *-- User
Account *-- Lockout

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
AuthController --> IAuthService
AuthService --> IUserRepository
AuthService --> ILockoutRepository
UserRepository --> AppDbContext
LockoutRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
AuthService ..|> IAuthService
UserRepository ..|> IUserRepository
LockoutRepository ..|> ILockoutRepository

%% === DEPENDENCY (dashed arrows) ===
AccountController ..> AuthController
AccountController ..> LoginViewModel
AuthController ..> LoginRequest
AuthController ..> LoginResponse
AuthService ..> LoginRequest
AuthService ..> LoginResponse
UserRepository ..> Account
LockoutRepository ..> Lockout

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
