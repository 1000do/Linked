classDiagram
direction LR

%% ==================== FRONTEND ====================

class AccountController {
    <<frontend controller>>
    + ForgotPassword(model: ForgotPasswordViewModel) Task~IActionResult~
    + VerifyOtp(model: VerifyOtpViewModel) Task~IActionResult~
    + ResetPassword(model: ResetPasswordViewModel) Task~IActionResult~
}

class ForgotPasswordViewModel {
    <<view model>>
    + Email : string
}

class VerifyOtpViewModel {
    <<view model>>
    + Email : string
    + OtpCode : string
}

class ResetPasswordViewModel {
    <<view model>>
    + Email : string
    + OtpCode : string
    + NewPassword : string
    + ConfirmPassword : string
}

%% ==================== BACKEND - CONTROLLER ====================

class AuthController {
    <<backend controller>>
    - _authService : IAuthService
    
    + ForgotPassword(request: ForgotPasswordRequest) Task~IActionResult~
    + VerifyOtp(request: VerifyOtpRequest) Task~IActionResult~
    + ResetPassword(request: ResetPasswordRequest) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class ForgotPasswordRequest {
    <<dto>>
    + Email : string
}

class VerifyOtpRequest {
    <<dto>>
    + Email : string
    + OtpCode : string
}

class ResetPasswordRequest {
    <<dto>>
    + Email : string
    + OtpCode : string
    + NewPassword : string
    + ConfirmPassword : string
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Account {
    <<entity>>
    + AccountId : int
    + Email : string
    + PasswordHash : string?
    + AccountStatus : string
    + IsVerified : bool
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAuthService {
    <<service interface>>
    + ForgotPasswordAsync(email: string) Task~string~ *
    + VerifyOtpForResetAsync(email: string, otp: string) Task~bool~ *
    + ResetPasswordAsync(email: string, otp: string, newPassword: string) Task~bool~ *
}

class IOtpService {
    <<service interface>>
    + GenerateOtp(email: string, context: string) Task~string~ *
    + ValidateOtp(email: string, otp: string, context: string) Task~bool~ *
    + ConsumeOtp(email: string, otp: string, context: string) Task~bool~ *
}

class IEmailService {
    <<service interface>>
    + SendEmailAsync(email: string, subject: string, body: string) Task~bool~ *
}

class IUserRepository {
    <<repository interface>>
    + GetAccountByEmailAsync(email: string) Task~Account?~ *
    + UpdateAccountAsync(account: Account) Task~void~ *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AuthService {
    <<service>>
    - _userRepository : IUserRepository
    - _otpService : IOtpService
    - _emailService : IEmailService
    
    + ForgotPasswordAsync(email: string) Task~string~
    + VerifyOtpForResetAsync(email: string, otp: string) Task~bool~
    + ResetPasswordAsync(email: string, otp: string, newPassword: string) Task~bool~
}

class OtpService {
    <<service>>
    + GenerateOtp(email: string, context: string) Task~string~
    + ValidateOtp(email: string, otp: string, context: string) Task~bool~
    + ConsumeOtp(email: string, otp: string, context: string) Task~bool~
}

class EmailService {
    <<service>>
    + SendEmailAsync(email: string, subject: string, body: string) Task~bool~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class UserRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetAccountByEmailAsync(email: string) Task~Account?~
    + UpdateAccountAsync(account: Account) Task~void~
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Accounts : DbSet~Account~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
AuthController --> IAuthService
AuthService --> IUserRepository
AuthService --> IOtpService
AuthService --> IEmailService
UserRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
AuthService ..|> IAuthService
OtpService ..|> IOtpService
EmailService ..|> IEmailService
UserRepository ..|> IUserRepository

%% === DEPENDENCY (dashed arrows) ===
AccountController ..> AuthController
AccountController ..> ForgotPasswordViewModel
AccountController ..> VerifyOtpViewModel
AccountController ..> ResetPasswordViewModel
AuthController ..> ForgotPasswordRequest
AuthController ..> VerifyOtpRequest
AuthController ..> ResetPasswordRequest
UserRepository ..> Account

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
