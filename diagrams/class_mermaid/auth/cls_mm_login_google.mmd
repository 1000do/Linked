classDiagram
direction LR

%% ==================== FRONTEND ====================

class AccountController {
    <<frontend controller>>
    + GoogleLogin(model: GoogleLoginViewModel) Task~IActionResult~
}

class GoogleLoginViewModel {
    <<view model>>
    + IdToken : string
}

%% ==================== BACKEND - CONTROLLER ====================

class AuthController {
    <<backend controller>>
    - _authService : IAuthService
    
    + GoogleLogin(request: GoogleLoginRequestDTO) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class GoogleLoginRequestDTO {
    <<dto>>
    + IdToken : string
}

class LoginResponseDTO {
    <<dto>>
    + AccessToken : string
    + RefreshToken : string
    + UserName : string
    + AvatarUrl : string?
    + UserRole : string
    + UserId : int
    + IsVerified : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Account {
    <<entity>>
    + AccountId : int
    + Email : string
    + PasswordHash : string?
    + AccountStatus : string
    + IsVerified : bool
    + LastLoginDate : DateTime?
    + RefreshToken : string?
    + User : User?
    + Lockouts : ICollection~Lockout~
}

class User {
    <<entity>>
    + UserId : int
    + AccountId : int
    + Username : string
    + FullName : string
    + AvatarUrl : string?
    + Account : Account?
}

class Lockout {
    <<entity>>
    + LockoutId : int
    + AccountId : int
    + LockoutType : string
    + LockoutEnd : DateTime
    + Reason : string?
    + IsActive : bool
    + Account : Account?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAuthService {
    <<service interface>>
    + GoogleLoginAsync(request: GoogleLoginRequestDTO) Task~LoginResponseDTO?~ *
}

class IUserRepository {
    <<repository interface>>
    + GetAccountByEmailAsync(email: string) Task~Account?~ *
    + RegisterUserAsync(account: Account, user: User) Task~bool~ *
    + UpdateLastLoginAsync(accountId: int) Task~int~ *
    + GetRoleByAccountIdAsync(accountId: int) Task~string~ *
    + SaveRefreshTokenAsync(accountId: int, refreshToken: string) Task~int~ *
}

class ILockoutRepository {
    <<repository interface>>
    + GetActiveLockoutAsync(accountId: int, lockoutType: string) Task~Lockout?~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AuthService {
    <<service>>
    - _userRepository : IUserRepository
    - _lockoutRepository : ILockoutRepository
    
    + GoogleLoginAsync(request: GoogleLoginRequestDTO) Task~LoginResponseDTO?~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class UserRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetAccountByEmailAsync(email: string) Task~Account?~
    + RegisterUserAsync(account: Account, user: User) Task~bool~
    + UpdateLastLoginAsync(accountId: int) Task~int~
    + GetRoleByAccountIdAsync(accountId: int) Task~string~
    + SaveRefreshTokenAsync(accountId: int, refreshToken: string) Task~int~
}

class LockoutRepository {
    <<repository>>
    - _context : AppDbContext
    
    + GetActiveLockoutAsync(accountId: int, lockoutType: string) Task~Lockout?~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    <<dbcontext>>
    + Accounts : DbSet~Account~
    + Lockouts : DbSet~Lockout~
    
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) void
    # OnModelCreating(modelBuilder: ModelBuilder) void
    + SaveChangesAsync() Task~int~
}

%% ==================== RELATIONSHIPS ====================

%% === COMPOSITION (filled diamond) ===
Account *-- User
Account *-- Lockout

%% === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
AuthController --> IAuthService
AuthService --> IUserRepository
AuthService --> ILockoutRepository
UserRepository --> AppDbContext
LockoutRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
AuthService ..|> IAuthService
UserRepository ..|> IUserRepository
LockoutRepository ..|> ILockoutRepository

%% === DEPENDENCY (dashed arrows) ===
AccountController ..> AuthController
AccountController ..> GoogleLoginViewModel
AuthController ..> GoogleLoginRequestDTO
AuthController ..> LoginResponseDTO
AuthService ..> GoogleLoginRequestDTO
AuthService ..> LoginResponseDTO
AuthService ..> Account
AuthService ..> User
UserRepository ..> Account
UserRepository ..> User
LockoutRepository ..> Lockout

%% ==================== STYLES ====================

classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
