classDiagram
direction LR

%% ==================== FRONTEND ====================

class AdminFinanceControllerFE["AdminFinanceController"] {
    <<frontend controller>>
    + Index(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, tab: string, year: int?, month: int?, payoutPage: int, withdrawPage: int) Task~IActionResult~
}

class AdminFinanceUnifiedVM {
    <<view model>>
    + Dashboard : FinanceDashboardVM
    + Withdraw : WithdrawPageVM
    + Transactions : TransactionPagedVM
    + Payouts : PagedResult~PayoutDetailVM~
    + Withdrawals : PagedResult~WithdrawalHistoryVM~
    + PendingRefunds : PagedResult~RefundRequestVM~
    + PayoutDays : string
    + CourseRevenues : List~InstructorCourseRevenueResponse~
    + YearlySummaries : Dictionary~int,FinancialSummaryVM~
}

%% ==================== BACKEND - CONTROLLERS ====================

class AdminFinanceControllerBE["AdminFinanceController"] {
    <<backend controller>>
    - _financeService : IAdminFinanceService
    - _instructorService : IInstructorService
    + GetFinancialSummary(year: int?, month: int?) Task~IActionResult~
    + GetPayouts(year: int?, month: int?, page: int, pageSize: int) Task~IActionResult~
    + GetWithdrawalHistory(year: int?, month: int?, page: int, pageSize: int) Task~IActionResult~
    + GetInstructorCourseRevenues(year: int, month: int) Task~IActionResult~
}

class TransactionControllerBE["TransactionController"] {
    <<backend controller>>
    - _transactionService : ITransactionService
    + GetTransactions(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~IActionResult~
}

%% ==================== BACKEND - DTOs ====================

class FinancialSummaryResponse {
    <<dto>>
    + GrossRevenue : decimal
    + TotalPaidOut : decimal
    + PendingEscrow : decimal
    + MaturedEscrow : decimal
    + PlatformNetProfit : decimal
    + CurrentTransferRate : decimal
    + TotalTransactions : int
    + TotalRefunded : decimal
}

class PayoutDetailResponse {
    <<dto>>
    + PayoutId : int
    + TransactionId : int
    + InstructorName : string
    + InstructorEmail : string
    + CourseTitle : string
    + TotalAmount : decimal
    + InstructorReceived : decimal
    + PlatformReceived : decimal
    + TransferRate : decimal
    + IsPaid : bool
    + PayoutStatus : string
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
    + TransactionDate : DateTime?
    + PayoutDate : DateTime
}

class WithdrawalHistoryItem {
    <<dto>>
    + WithdrawalId : int
    + ManagerName : string?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
}

class InstructorCourseRevenueResponse {
    <<dto>>
    + CourseId : int
    + CourseTitle : string
    + InstructorId : int
    + InstructorName : string
    + SalesCount : int
    + MonthlyRevenue : decimal
    + PreviousMonthRevenue : decimal
    + YearlyRevenue : decimal
    + LifetimeRevenue : decimal
}

class TransactionListDto {
    <<dto>>
    + TransactionId : int
    + StripeSessionId : string?
    + Date : DateTime?
    + Amount : decimal
    + Status : string?
    + BuyerName : string
    + CourseTitle : string
    + InstructorName : string
    + Currency : string?
    + PayoutCurrency : string?
    + RefundReason : string?
    + RefundAdminNote : string?
    + RefundRequestedAt : DateTime?
    + IsGift : bool
    + RecipientEmail : string?
    + IsGiftClaimed : bool
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction {
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + StripeSessionId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionCreatedAt : DateTime?
    + TransactionExt : TransactionExt?
    + OrderItem : OrderItem?
    + AccountFromNavigation : Account?
}

class PlatformWithdrawal {
    + WithdrawalId : int
    + ManagerId : int?
    + Amount : decimal
    + Currency : string
    + StripePayoutId : string?
    + Status : string
    + Description : string?
    + CreatedAt : DateTime
    + ArrivedAt : DateTime?
}

class InstructorPayout {
    + PayoutId : int
    + TransactionId : int?
    + InstructorId : int?
    + PayoutAmount : decimal
    + IsPaid : bool
    + PayoutStatus : string?
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
    + PayoutDate : DateTime
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IAdminFinanceService {
    <<interface>>
    + GetFinancialSummaryAsync(year: int?, month: int?) Task~FinancialSummaryResponse~ *
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~ *
    + GetWithdrawalHistoryAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~WithdrawalHistoryItem~~ *
    + GetInstructorCourseRevenuesAsync(year: int, month: int) Task~List~InstructorCourseRevenueResponse~~ *
}

class ITransactionService {
    <<interface>>
    + GetTransactionsAsync(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~TransactionListDto~~ *
}

%% ==================== BACKEND - REPOSITORY INTERFACES ====================

class IAdminFinanceRepository {
    <<interface>>
    + GetGrossRevenueAsync(year: int?, month: int?) Task~decimal~ *
    + GetTotalRefundedAsync(year: int?, month: int?) Task~decimal~ *
    + GetSucceededTransactionCountAsync(year: int?, month: int?) Task~int~ *
    + GetTotalPaidOutAsync(year: int?, month: int?) Task~decimal~ *
    + GetPendingEscrowAsync(year: int?, month: int?) Task~decimal~ *
    + GetMaturedEscrowAsync(year: int?, month: int?) Task~decimal~ *
    + GetPayoutDetailsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PayoutDetailProjection~,int~~ *
    + GetWithdrawalsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PlatformWithdrawal~,int~~ *
    + GetInstructorCourseRevenuesAsync(year: int, month: int) Task~List~InstructorCourseRevenueProjection~~ *
}

class ITransactionRepository {
    <<interface>>
    + GetTransactionsAsync(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~ValueTuple~List~TransactionListDto~,int~~ *
}

%% ==================== BACKEND - SERVICES ====================

class AdminFinanceService {
    - _repo : IAdminFinanceRepository
    + GetFinancialSummaryAsync(year: int?, month: int?) Task~FinancialSummaryResponse~
    + GetInstructorPayoutsAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~PayoutDetailResponse~~
    + GetWithdrawalHistoryAsync(year: int?, month: int?, page: int, pageSize: int) Task~PagedResult~WithdrawalHistoryItem~~
    + GetInstructorCourseRevenuesAsync(year: int, month: int) Task~List~InstructorCourseRevenueResponse~
}

class TransactionService {
    - _repo : ITransactionRepository
    + GetTransactionsAsync(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~PagedResult~TransactionListDto~~
}

%% ==================== BACKEND - REPOSITORIES ====================

class AdminFinanceRepository {
    - _context : AppDbContext
    + GetGrossRevenueAsync(year: int?, month: int?) Task~decimal~
    + GetTotalRefundedAsync(year: int?, month: int?) Task~decimal~
    + GetSucceededTransactionCountAsync(year: int?, month: int?) Task~int~
    + GetTotalPaidOutAsync(year: int?, month: int?) Task~decimal~
    + GetPendingEscrowAsync(year: int?, month: int?) Task~decimal~
    + GetMaturedEscrowAsync(year: int?, month: int?) Task~decimal~
    + GetPayoutDetailsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PayoutDetailProjection~,int~~
    + GetWithdrawalsAsync(year: int?, month: int?, page: int, pageSize: int) Task~ValueTuple~List~PlatformWithdrawal~,int~~
    + GetInstructorCourseRevenuesAsync(year: int, month: int) Task~List~InstructorCourseRevenueProjection~~
}

class TransactionRepository {
    - _context : AppDbContext
    + GetTransactionsAsync(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) Task~ValueTuple~List~TransactionListDto~,int~~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Transactions : DbSet~Transaction~
    + PlatformWithdrawals : DbSet~PlatformWithdrawal~
    + InstructorPayouts : DbSet~InstructorPayout~
}

