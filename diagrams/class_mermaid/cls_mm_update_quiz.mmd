direction LR

%% ==================== FRONTEND ====================

class QuizControllerFE["QuizController"] {
    <<frontend controller>>
    + EditQuiz(id: int, model: EditQuizViewModel) Task~IActionResult~
}

%% ==================== BACKEND - CONTROLLER ====================

class QuizControllerBE["QuizController"] {
    <<backend controller>>
    - _quizService : IQuizService
    
    + UpdateQuizSettings(id: int, request: QuizUpdateRequest) Task~IActionResult~
    - GetInstructorId() int
}

%% ==================== BACKEND - DTOs ====================

class QuizUpdateRequest {
    <<dto>>
    + Title : string
    + Description : string?
    + TimeLimitMinutes : int?
    + PassingScore : int?
    + MaxAttempts : int?
}

%% ==================== BACKEND - DOMAIN ENTITIES ====================

class Quiz {
    <<entity>>
    + QuizId : int
    + CourseId : int
    + LessonId : int?
    + Title : string
    + Description : string?
    + TimeLimitMinutes : int?
    + PassingScore : int?
    + MaxAttempts : int?
    + IsHidden : bool
    + IsRemoved : bool
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
}

%% ==================== BACKEND - SERVICE INTERFACES ====================

class IQuizService {
    <<interface>>
    + UpdateQuizSettingsAsync(quizId: int, request: QuizUpdateRequest, instructorId: int) Task~bool~ *
}

class IQuizRepository {
    <<interface>>
    + GetByIdAsync(id: int) Task~Quiz?~ *
    + Update(quiz: Quiz) void *
    + SaveChangesAsync() Task~int~ *
}

%% ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class QuizService {
    - _quizRepo : IQuizRepository
    
    + UpdateQuizSettingsAsync(quizId: int, request: QuizUpdateRequest, instructorId: int) Task~bool~
}

%% ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class QuizRepository {
    - _context : AppDbContext
    
    + GetByIdAsync(id: int) Task~Quiz?~
    + Update(quiz: Quiz) void
    + SaveChangesAsync() Task~int~
}

%% ==================== BACKEND - DbContext ====================

class AppDbContext {
    + Quizzes : DbSet~Quiz~
}

%% ==================== RELATIONSHIPS ====================

%% === UNIDIRECTIONAL ASSOCIATION ===
QuizControllerBE --> IQuizService
QuizService --> IQuizRepository
QuizRepository --> AppDbContext

%% === INTERFACE REALIZATION ===
QuizService ..|> IQuizService
QuizRepository ..|> IQuizRepository

%% === DEPENDENCY ===
QuizControllerFE ..> QuizControllerBE
QuizControllerBE ..> QuizUpdateRequest
QuizService ..> QuizUpdateRequest
QuizService ..> Quiz
QuizRepository ..> Quiz

