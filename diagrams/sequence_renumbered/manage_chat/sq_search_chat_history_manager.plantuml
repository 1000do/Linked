@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Search Conversations (Manager)

actor Staff as act
participant "ChatIndexPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_page
participant "ChatController" as fe_ctrl <<frontend controller>>
participant "ChatController" as be_ctrl <<backend controller>>
participant ":IChatService" as sv
participant ":ChatListDto" as chat_dto
participant ":IChatRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Type search query in "search-chats" input field
view->view++:2. EventListener: input event triggered

view->view++:3. handleSearchInput() (with debounce)
view--

view->fe_ctrl++:4. GET /Chat/Search?q={query}

fe_ctrl -> fe_ctrl++:5. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:5.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:5.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_page:5.2. Redirect to ErrorPage
    activate error_page
    error_page -->> act--:5.2.1. Display error message
else Valid actor's authentication and authorization
    fe_ctrl->be_ctrl++:5.3. GET /api/Chat/search?q={query}
    
    be_ctrl->sv++:5.3.1. Call SearchChatsAsync(accountId, query)

sv->repo++:5.3.2. Call SearchParticipantsByAccountIdAsync(accountId, query)
repo->ctx++:5.3.3. Call SearchParticipantsByAccountIdAsync(accountId, query)
ctx->db++:5.3.4. Execute SELECT query

db-->>ctx--:5.3.5. Return filtered ChatParticipants list
ctx-->>repo--:5.3.6. Return filtered ChatParticipants list
repo-->>sv--:5.3.7. Return filtered ChatParticipants list

sv->chat_dto++:5.3.8. Call ChatListDto()

chat_dto-->>sv--:5.3.9. Return ChatListDto items

sv-->>be_ctrl--:5.3.10. Return ChatListDto list
be_ctrl-->>fe_ctrl--:5.3.11. Return statusCode 200 (Ok)
fe_ctrl-->>view--:5.3.12. Return JSON search results

view->view++:5.3.13. applyChatFilters()
view--
view->view++:5.3.14. renderChatList(searchResults)
view--

view-->>act--:5.3.15. Display filtered conversations in sidebar list
end
@enduml
