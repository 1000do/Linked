@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Publish Course

actor Instructor as act
participant "InstructorCourseEditorPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "InstructorCourseController" as fe_ctrl <<frontend controller>>
participant "CourseController" as be_ctrl <<backend controller>>
participant ":ICourseAiModerationService" as sv
participant ":ICourseCommandService" as cmd_sv
participant ":ICourseRepository" as repo
participant ":IRedisService" as redis
participant ":IBackgroundTaskQueue" as queue
participant ":AppDbContext" as ctx
database Database as db

act ++

act -> view++:1. Click "Submit for Review"
view -> fe_ctrl++:2. POST /InstructorCourse/ModerateCourse

fe_ctrl -> fe_ctrl++:3. Validate Instructor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid Instructor's authentication and authorization
    fe_ctrl -> be_ctrl++:3.3. POST /api/courses/moderate
be_ctrl -> sv++:3.3.1. StartCourseModerationAsync(request, instructorId)
sv -> sv++:3.3.2. UpdateCourseStatusAndClearCacheAsync(courseId, "pending", instructorId)
sv -> cmd_sv++:3.3.3. UpdateCourseStatusAsync(courseId, "pending", instructorId)
cmd_sv -> cmd_sv++:3.3.4. Validate course update request
cmd_sv--

alt Course Not Found
    cmd_sv -->> sv:3.3.4.1. throw KeyNotFoundException
    sv -->> be_ctrl:3.3.4.1.1. throw KeyNotFoundException
    be_ctrl -->> fe_ctrl:3.3.4.1.2. Return statusCode 404
    fe_ctrl -->> view:3.3.4.1.3. Return NotFound()
    view -->> act:3.3.4.1.4. Display course not found error message
else Invalid Instructor Rights
    cmd_sv -->> sv:3.3.4.2. throw UnauthorizedAccessException
    sv -->> be_ctrl:3.3.4.2.1. throw UnauthorizedAccessException
    be_ctrl -->> fe_ctrl:3.3.4.2.2. Return statusCode 403
    fe_ctrl -->> view:3.3.4.2.3. Return Forbid()
    view -->> act:3.3.4.2.4. Display error message regarding invalid instructor rights
else Invalid course content
    cmd_sv -->> sv:3.3.4.3. throw BadRequestException
    sv -->> be_ctrl:3.3.4.3.1. throw BadRequestException
    be_ctrl -->> fe_ctrl:3.3.4.3.2. Return statusCode 400
    fe_ctrl -->> view:3.3.4.3.3. Return BadRequest()
    view -->> act:3.3.4.3.4. Display validation error message
else Valid course update request
    cmd_sv -> repo++:3.3.4.4. Update(course)
    repo -->> cmd_sv--:3.3.4.4.1. Return result
    cmd_sv -> repo++:3.3.4.4.2. SaveChangesAsync()
    repo -> ctx++:3.3.4.4.3. Call SaveChangesAsync()
    ctx -> db++:3.3.4.4.4. Save changes to database
alt Database Save Failure
        db -->> ctx:3.3.4.4.4.1. throw DbUpdateException
        ctx -->> repo:3.3.4.4.4.1.1. throw DbUpdateException
        repo -->> cmd_sv:3.3.4.4.4.1.2. throw DbUpdateException
        cmd_sv -->> sv:3.3.4.4.4.1.3. throw DbUpdateException
        sv -->> be_ctrl:3.3.4.4.4.1.4. throw DbUpdateException
        be_ctrl -->> fe_ctrl:3.3.4.4.4.1.5. Return statusCode 500
        fe_ctrl -->> view:3.3.4.4.4.1.6. Return StatusCode(500)
        view -->> act:3.3.4.4.4.1.7. Display database transaction failure message
else Database Save Success
        db -->> ctx--:3.3.4.4.4.2. Return numberOfRowsAffected
        ctx -->> repo--:3.3.4.4.4.2.1. Return numberOfRowsAffected
        repo -->> cmd_sv--:3.3.4.4.4.2.2. Return numberOfRowsAffected
        cmd_sv -->> sv--:3.3.4.4.4.2.3. Return result
        
        sv -> redis++:3.3.4.4.4.2.4. RemoveCacheAsync(key)
        redis -->> sv--:3.3.4.4.4.2.5. Return result
        sv --
        
        sv -> queue++:3.3.4.4.4.2.6. QueueBackgroundWorkItemAsync(workItem)

par Background Task
            ref over sv, db:3.3.4.4.4.2.6.1. Handle Course Moderation With AI
else Main Thread Return
            queue -->> sv--:3.3.4.4.4.2.6.2. Return result
            sv -->> be_ctrl--:3.3.4.4.4.2.6.2.1. Return result
        
            be_ctrl -->> fe_ctrl--:3.3.4.4.4.2.6.2.2. Return statusCode 200
            fe_ctrl -->> view--:3.3.4.4.4.2.6.2.3. Return Ok()
            view -->> act--:3.3.4.4.4.2.6.2.4. Display success message
end
end
end
end
@enduml
