@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Delete Cart Items

actor User as act
participant "CartPage" as view
participant "LoginPage" as login_view
participant "CartController" as fe_ctrl <<frontend controller>>
participant "CartController" as be_ctrl <<backend controller>>
participant ":ICartService" as sv
participant ":ICartRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Click "Remove" button on a course in cart
view->view++:2. Prompt confirmation dialog
view--

alt [User cancels]
    view-->>act:2.1. Do nothing
else [User confirms]
    view->fe_ctrl++:2.2. Send POST /Cart/RemoveFromCart (with courseId)
    
alt [AccessToken cookie is missing]
        fe_ctrl-->>login_view:2.2.1. Redirect to Login page
        activate login_view
        login_view-->>act--:2.2.1.1. Display Login page
else [AccessToken cookie exists]
        fe_ctrl->be_ctrl++:2.2.2. Send DELETE /api/cart/remove/{courseId} (with Bearer Token)
        
alt [Token is invalid or expired]
            be_ctrl-->>fe_ctrl:2.2.2.1. Return statusCode 401 (Unauthorized)
            fe_ctrl-->>login_view:2.2.2.1.1. Redirect to Login page
            activate login_view
            login_view-->>act--:2.2.2.1.2. Display Login page
else [Token is valid]
            be_ctrl->sv++:2.2.2.2. Call RemoveFromCartAsync(userId, courseId)
            
            sv->repo++:2.2.2.2.1. Call GetCartItemAsync(userId, courseId)
            repo->ctx++:2.2.2.2.2. Call GetCartItemAsync(userId, courseId)
            ctx->db++:2.2.2.2.3. Execute SELECT query
            
            db-->>ctx--:2.2.2.2.4. Return CartItem entity
            ctx-->>repo--:2.2.2.2.5. Return CartItem entity
            repo-->>sv--:2.2.2.2.6. Return CartItem entity
            
alt [item == null]
                sv-->>be_ctrl:2.2.2.2.6.1. throw InvalidOperationException("Course not found in the cart.")
                be_ctrl-->>fe_ctrl:2.2.2.2.6.1.1. Return statusCode 400 (BadRequest)
                fe_ctrl-->>view:2.2.2.2.6.1.2. Return statusCode 302 (Redirect)
                view-->>act:2.2.2.2.6.1.3. Display error message
else [item != null]
                sv->repo:2.2.2.2.6.2. Call RemoveCartItem(item)
                
                sv->repo++:2.2.2.2.6.2.1. Call SaveChangesAsync()
                repo->ctx++:2.2.2.2.6.2.2. Call SaveChangesAsync()
                ctx->db++:2.2.2.2.6.2.3. Save changes to database
                
alt [Database Save Fails (throws DbUpdateException)]
                    db-->>ctx--:2.2.2.2.6.2.3.1. Throw DbUpdateException
                    ctx-->>repo--:2.2.2.2.6.2.3.1.1. Throw DbUpdateException
                    repo-->>sv--:2.2.2.2.6.2.3.1.2. Throw DbUpdateException
                    sv-->>be_ctrl:2.2.2.2.6.2.3.1.3. Throw DbUpdateException
                    be_ctrl-->>fe_ctrl:2.2.2.2.6.2.3.1.4. Return statusCode 500 (InternalServerError)
                    fe_ctrl-->>view:2.2.2.2.6.2.3.1.5. Return statusCode 302 (Redirect)
                    view-->>act:2.2.2.2.6.2.3.1.6. Display database error message
else [Database Save Succeeds]
                    db-->>ctx--:2.2.2.2.6.2.3.2. Return result
                    ctx-->>repo--:2.2.2.2.6.2.3.2.1. Return result
                    repo-->>sv--:2.2.2.2.6.2.3.2.2. Return result
                    
                    sv-->>be_ctrl--:2.2.2.2.6.2.3.2.3. Return
                    be_ctrl-->>fe_ctrl--:2.2.2.2.6.2.3.2.4. Return statusCode 200 (Ok)
                    fe_ctrl-->>view--:2.2.2.2.6.2.3.2.5. Return statusCode 302 (Redirect)
                    view-->>act--:2.2.2.2.6.2.3.2.6. Display success message
end
end
end
end
end

@enduml
