@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Delete Cart Items

actor User as act
participant "CartPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_page
participant "CartController" as fe_ctrl <<frontend controller>>
participant "CartController" as be_ctrl <<backend controller>>
participant ":ICartService" as sv
participant ":ICartRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Click "Remove" button on a course in cart
view->view++:2. Prompt confirmation dialog
view--

alt [User cancels]
    view-->>act:2.1. Do nothing
else [User confirms]
    view->fe_ctrl++:2.2. POST /Cart/RemoveFromCart
    
    fe_ctrl -> fe_ctrl++:2.2.1. Validate actor's authentication and authorization
    fe_ctrl--
    
alt Session Invalid
        fe_ctrl -->> login_view:2.2.1.1. Redirect to LoginPage
        activate login_view
        login_view -->> act--:2.2.1.1.1. Display login form
else Unauthorized Access
        fe_ctrl -->> error_page:2.2.1.2. Redirect to ErrorPage
        activate error_page
        error_page -->> act--:2.2.1.2.1. Display error message
else Valid actor's authentication and authorization
        fe_ctrl->be_ctrl++:2.2.1.3. DELETE /api/cart/remove/{courseId}
        
        be_ctrl->sv++:2.2.1.3.1. Call RemoveFromCartAsync(userId, courseId)
            
            sv->repo++:2.2.1.3.2. Call GetCartItemAsync(userId, courseId)
            repo->ctx++:2.2.1.3.3. Call GetCartItemAsync(userId, courseId)
            ctx->db++:2.2.1.3.4. Execute SELECT query
            
            db-->>ctx--:2.2.1.3.5. Return CartItem entity
            ctx-->>repo--:2.2.1.3.6. Return CartItem entity
            repo-->>sv--:2.2.1.3.7. Return CartItem entity
            
alt [item == null]
                sv-->>be_ctrl:2.2.1.3.7.1. throw InvalidOperationException("Course not found in the cart.")
                be_ctrl-->>fe_ctrl:2.2.1.3.7.1.1. Return statusCode 400 (BadRequest)
                fe_ctrl-->>view:2.2.1.3.7.1.2. Return statusCode 302 (Redirect)
                view-->>act:2.2.1.3.7.1.3. Display error message
else [item != null]
                sv->repo++:2.2.1.3.7.2. Call RemoveCartItem(item)
                
                repo->ctx++:2.2.1.3.7.2.1. Call SaveChangesAsync()
                ctx->db++:2.2.1.3.7.2.2. Save changes to database
                
alt Database Save Failure
                    db-->>ctx--:2.2.1.3.7.2.2.1. Throw DbUpdateException
                    ctx-->>repo--:2.2.1.3.7.2.2.1.1. Throw DbUpdateException
                    repo-->>sv--:2.2.1.3.7.2.2.1.2. Throw DbUpdateException
                    sv-->>be_ctrl:2.2.1.3.7.2.2.1.3. Throw DbUpdateException
                    be_ctrl-->>fe_ctrl:2.2.1.3.7.2.2.1.4. Return statusCode 500 (InternalServerError)
                    fe_ctrl-->>view:2.2.1.3.7.2.2.1.5. Return statusCode 302 (Redirect)
                    view-->>act:2.2.1.3.7.2.2.1.6. Display database error message
else Database Save Success
                    db-->>ctx--:2.2.1.3.7.2.2.2. Return result
                    ctx-->>repo--:2.2.1.3.7.2.2.2.1. Return result
                    repo-->>sv--:2.2.1.3.7.2.2.2.2. Return result
                    
                    sv-->>be_ctrl--:2.2.1.3.7.2.2.2.3. Return
                    be_ctrl-->>fe_ctrl--:2.2.1.3.7.2.2.2.4. Return statusCode 200 (Ok)
                    fe_ctrl-->>view--:2.2.1.3.7.2.2.2.5. Return statusCode 302 (Redirect)
                    view-->>act--:2.2.1.3.7.2.2.2.6. Display success message
end
end
end
end

@enduml
