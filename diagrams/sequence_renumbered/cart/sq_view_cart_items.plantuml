@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Cart Items

actor User as act
participant "CartIndexPage" as view
participant "LoginPage" as login_view
participant "CartController" as fe_ctrl <<frontend controller>>
participant "CartController" as be_ctrl <<backend controller>>
participant ":ICartService" as sv
participant ":CartSummaryResponse" as cart_res
participant ":ICartRepository" as repo
participant ":ICouponRepository" as couponRepo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Access Shopping Cart page
view->fe_ctrl++:2. Send GET /Cart

alt [AccessToken cookie is missing]
    fe_ctrl-->>login_view:2.1. Redirect to Login page
    activate login_view
    login_view-->>act--:2.1.1. Display Login page
else [AccessToken cookie exists]
    fe_ctrl->fe_ctrl++:2.2. Get couponMap from cart_coupon cookie
    fe_ctrl--
    
    fe_ctrl->be_ctrl++:2.2.1. Send GET /api/cart/summary?couponCode={couponCode} (with Bearer Token)
    
alt [Token is invalid or expired]
        be_ctrl-->>fe_ctrl:2.2.1.1. Return statusCode 401 (Unauthorized)
        fe_ctrl-->>login_view:2.2.1.1.1. Redirect to Login page
        activate login_view
        login_view-->>act--:2.2.1.1.2. Display Login page
else [Token is valid]
        be_ctrl->sv++:2.2.1.2. Call GetCartSummaryAsync(userId, couponCode)
        
        sv->repo++:2.2.1.2.1. Call GetCartItemsWithDetailsAsync(userId)
        repo->ctx++:2.2.1.2.2. Call GetCartItemsWithDetailsAsync(userId)
        ctx->db++:2.2.1.2.3. Execute SELECT query
        
        db-->>ctx--:2.2.1.2.4. Return CartItems list with Course & Instructor navigation
        ctx-->>repo--:2.2.1.2.5. Return List<CartItem>
        repo-->>sv--:2.2.1.2.6. Return List<CartItem>
        
opt [couponCode is provided]
loop for each couponCode in list
                sv->couponRepo++:2.2.1.2.6.1. Call GetByCodeAsync(code)
                couponRepo->ctx++:2.2.1.2.6.1.1. Call GetByCodeAsync(code)
                ctx->db++:2.2.1.2.6.1.2. Execute SELECT query
                db-->>ctx--:2.2.1.2.6.1.3. Return Coupon
                ctx-->>couponRepo--:2.2.1.2.6.1.4. Return Coupon
                couponRepo-->>sv--:2.2.1.2.6.1.5. Return Coupon
                
alt [coupon is null OR inactive OR expired/limit reached]
                    sv-->>be_ctrl:2.2.1.2.6.1.5.1. throw InvalidOperationException
                    be_ctrl-->>fe_ctrl:2.2.1.2.6.1.5.1.1. Return statusCode 400 (BadRequest)
                    fe_ctrl-->>view:2.2.1.2.6.1.5.1.2. Return statusCode 400 (BadRequest)
                    view-->>act:2.2.1.2.6.1.5.1.3. Display coupon error message
else [coupon is valid]
                    sv->sv++:2.2.1.2.6.1.5.2. Calculate eligibleSubTotal & discountAmount
                    sv--
end
end
end
        
        sv->couponRepo++:2.2.1.2.7. Call GetActiveAvailableCouponsAsync(now)
        couponRepo->ctx++:2.2.1.2.8. Call GetActiveAvailableCouponsAsync(now)
        ctx->db++:2.2.1.2.9. Execute SELECT query
        db-->>ctx--:2.2.1.2.10. Return active coupons list
        ctx-->>couponRepo--:2.2.1.2.11. Return List<Coupon>
        couponRepo-->>sv--:2.2.1.2.12. Return List<Coupon>
        
        sv->cart_res++:2.2.1.2.13. Call CartSummaryResponse()
        cart_res-->>sv--:2.2.1.2.14. Return CartSummaryResponse object
        
        sv-->>be_ctrl--:2.2.1.2.15. Return CartSummaryResponse object
        be_ctrl-->>fe_ctrl--:2.2.1.2.16. Return statusCode 200 (Ok)
        
        fe_ctrl->fe_ctrl++:2.2.1.2.17. Map JSON response to CartViewModel
        fe_ctrl--
        
        fe_ctrl-->>view--:2.2.1.2.18. Return statusCode 200 (View)
        view-->>act--:2.2.1.2.19. Display cart items list, pricing summary, and available coupons
end
end

@enduml
