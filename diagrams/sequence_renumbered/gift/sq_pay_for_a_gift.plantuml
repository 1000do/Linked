@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Pay for a gift

actor User as act
participant "GiftCheckoutPage" as view
participant "MyCoursesPage" as my_courses_view
participant "GiftController" as fe_gift_ctrl <<frontend controller>>
participant "CheckoutController" as be_ctrl <<backend controller>>
participant ":ICheckoutService" as sv
participant ":CheckoutResponse" as res_dto
participant ":OrderInfo" as order_ett
participant ":OrderItem" as item_ett
participant ":Transaction" as tx_ett
participant ":IPaymentGatewayService" as stripe
participant ":IOrderRepository" as order_repo

participant ":AppDbContext" as ctx
database Database as db

act ++

' == Access Gift Checkout ==
act -> view++:1. Access Gift Checkout page
' view -> fe_gift_ctrl++:2. GET /Gift/Checkout
' fe_gift_ctrl -->> view--:3. Return View
' view -> view++:4. Mount Stripe Elements (Empty Card Form)
' view--
' view -->> act:5. Display checkout page and card entry form

' == Initiate Payment Intent ==
act -> view:6. Fill in Card details (Name, Card Number, Expiry, CVC)
act -> view:7. Click "Pay Securely" button

view -> view++:8. Validate form inputs
view--
opt Invalid form inputs
    view -->> act:8.1. Highlight invalid fields and display error message
end

' note right of view: Intent is created ON SUBMIT\nto prevent incomplete intents in Stripe
view -> fe_gift_ctrl++:9. POST /Gift/CreateGiftPaymentIntentAjax (AJAX)
fe_gift_ctrl -> be_ctrl++:10. POST /api/checkout/gift-intent
be_ctrl -> sv++:11. InitiateGiftPaymentIntentAsync(userId, request)

sv -> sv++:12. ValidateCourseForGiftAsync(course, recipientEmail, courseId)
sv--

alt Gift Details Missing or Invalid
    sv -->> be_ctrl:12.1. throw ArgumentException
    be_ctrl -->> fe_gift_ctrl:12.1.1. Return statusCode 400
    fe_gift_ctrl -->> view:12.1.2. Return JSON (success=false, message)
    view -->> act:12.1.3. Display error message
else Valid Gift Details
    sv -> stripe++:12.2. CreatePaymentIntentAsync(purchasePrice, "usd", metadata)
    stripe -->> sv--:12.2.1. Return ClientSecret and PaymentIntentId
    
    sv -> res_dto++:12.2.2. Call CheckoutResponse(ClientSecret, PaymentIntentId)
    res_dto -->> sv--:12.2.3. Return CheckoutResponse object
    
    sv -->> be_ctrl:12.2.4. Return CheckoutResponse object
    deactivate sv
    be_ctrl -->> fe_gift_ctrl:12.2.5. Return statusCode 200
    deactivate be_ctrl
    fe_gift_ctrl -->> view:12.2.6. Return JSON (ClientSecret)
    deactivate fe_gift_ctrl
end

' == Process Stripe Payment ==
view -> stripe++:13. stripe.confirmCardPayment(clientSecret, cardDetails)
stripe -->> view--:14. Return payment result

alt Payment declined
    view -->> act:14.1. Display payment error message
else Payment Successful
    view -> fe_gift_ctrl++:14.2. GET /Gift/CheckoutSuccess?payment_intent_id=...
    fe_gift_ctrl -> be_ctrl++:14.2.1. GET /api/checkout/success-intent
    be_ctrl -> sv++:14.2.2. ProcessPaymentIntentSuccessAsync(paymentIntentId)
    
    sv -> sv++:14.2.3. IsTransactionAlreadyProcessedAsync(paymentIntentId)
    sv--
    
    sv -> stripe++:14.2.4. GetPaymentIntentMetadataAsync(paymentIntentId)
    stripe -->> sv--:14.2.5. Return metadata
    
    sv -> sv++:14.2.6. ProcessSuccessfulPaymentCoreAsync
    
    sv -> order_repo++:14.2.7. BeginTransactionAsync()
    order_repo -> ctx++:14.2.8. Database.BeginTransactionAsync()
    ctx -> db++:14.2.9. Begin transaction
    db -->> ctx--:14.2.10. Transaction started
    ctx -->> order_repo--:14.2.11. Return IDbContextTransaction
    order_repo -->> sv--:14.2.12. Return transaction
    
    sv -> order_ett++:14.2.13. Call OrderInfo(...)
    order_ett -->> sv--:14.2.14. Return OrderInfo object
    
    sv -> order_repo++:14.2.15. AddOrderAsync(order)
    order_repo -->> sv--:14.2.16. Return result
    
    sv -> order_repo++:14.2.17. SaveChangesAsync()
    order_repo -> ctx++:14.2.18. SaveChangesAsync()
    ctx -> db++:14.2.19. Save changes to database
    db -->> ctx--:14.2.20. Return numberOfRowsAffected
    ctx -->> order_repo--:14.2.21. Return numberOfRowsAffected
    order_repo -->> sv--:14.2.22. Return numberOfRowsAffected
    
loop for each course in courseIds
        sv -> item_ett++:14.2.23. Call OrderItem(...)
        item_ett -->> sv--:14.2.24. Return OrderItem object
        
        sv -> order_repo++:14.2.25. AddOrderItemAsync(orderItem)
        order_repo -->> sv--:14.2.26. Return result
        
        sv -> order_repo++:14.2.27. SaveChangesAsync()
        order_repo -> ctx++:14.2.28. SaveChangesAsync()
        ctx -> db++:14.2.29. Save changes to database
        db -->> ctx--:14.2.30. Return numberOfRowsAffected
        ctx -->> order_repo--:14.2.31. Return numberOfRowsAffected
        order_repo -->> sv--:14.2.32. Return numberOfRowsAffected
        
        sv -> tx_ett++:14.2.33. Call Transaction(...)
        tx_ett -->> sv--:14.2.34. Return Transaction object
        
        sv -> order_repo++:14.2.35. AddTransactionAsync(transaction)
        order_repo -->> sv--:14.2.36. Return result
        
        sv -> order_repo++:14.2.37. SaveChangesAsync()
        order_repo -> ctx++:14.2.38. SaveChangesAsync()
        ctx -> db++:14.2.39. Save changes to database
        db -->> ctx--:14.2.40. Return numberOfRowsAffected
        ctx -->> order_repo--:14.2.41. Return numberOfRowsAffected
        order_repo -->> sv--:14.2.42. Return numberOfRowsAffected
        
        sv -> sv++:14.2.43. ProcessGiftFulfillmentAsync (Create gift record, send email & notification)
        sv--
        
        sv -> sv++:14.2.44. ProcessPayoutAndNotificationAsync (Create payout & notify instructor)
        sv--
end
    
    sv -> order_repo++:14.2.45. SaveChangesAsync()
    order_repo -> ctx++:14.2.46. SaveChangesAsync()
    ctx -> db++:14.2.47. Save changes to database
    db -->> ctx--:14.2.48. Return numberOfRowsAffected
    ctx -->> order_repo--:14.2.49. Return numberOfRowsAffected
    order_repo -->> sv--:14.2.50. Return numberOfRowsAffected
    
    sv -> sv++:14.2.51. Commit transaction
    sv -> ctx++:14.2.52. transaction.CommitAsync()
    ctx -> db++:14.2.53. Commit
    db -->> ctx--:14.2.54. Return result
    ctx -->> sv--:14.2.55. Return result
    sv--
    
    sv--
    sv -->> be_ctrl--:14.2.56. Return result
    be_ctrl -->> fe_gift_ctrl--:14.2.57. Return statusCode 200
    
    fe_gift_ctrl -->> my_courses_view--:14.2.58. Redirect to My Courses page
    activate my_courses_view
    my_courses_view -->> act:14.2.59. Display checkout success message
    deactivate my_courses_view
    deactivate view
end

@enduml
