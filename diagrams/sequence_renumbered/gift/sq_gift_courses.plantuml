@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Gift Courses

actor User as act
participant "GiftSetupPage" as view
participant "GiftCheckoutPage" as r_view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "GiftController" as fe_ctrl <<frontend controller>>
participant ":PublicCourseViewModel" as view_model
participant "GiftController" as be_ctrl <<backend controller>>
participant ":ICourseQueryService" as course_sv
participant ":IGiftService" as sv
participant ":CourseDetailResponse" as res
participant ":ICourseRepository" as repo
participant ":IUserRepository" as user_repo
participant ":AppDbContext" as ctx
database Database as db

act ++

act -> view++:1. Fill in Gift details (Recipient Email, Name, Theme, Message)
act -> view:2. Click "Proceed to Payment" button

view -> view++:3. Validate form inputs
view--
opt Invalid form inputs (A.5)
    view -->> act:3.1. Highlight invalid fields and display inline error messages
end

view -> fe_ctrl++:4. POST /Gift/Setup (FormData)
view--

fe_ctrl -> fe_ctrl++:5. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:5.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:5.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:5.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:5.2.1. Display error message
else Valid actor's authentication and authorization
    
    fe_ctrl -> fe_ctrl++:5.3. Validate ModelState
    fe_ctrl--
    
alt Invalid ModelState
        fe_ctrl -> be_ctrl++:5.3.1. GET /api/gift/course/{courseId}
        be_ctrl -> course_sv++:5.3.1.1. GetCourseWithDetailsAsync(courseId, userId, role)
        course_sv -> repo++:5.3.1.2. GetCourseWithDetailsAsync(courseId)
        repo -> ctx++:5.3.1.3. Query course details from database
        ctx -> db++:5.3.1.4. Execute query
        db -->> ctx--:5.3.1.5. Return data
        ctx -->> repo--:5.3.1.6. Return Course entity or null
        repo -->> course_sv--:5.3.1.7. Return Course entity or null
        course_sv -> res++:5.3.1.8. Call CourseDetailResponse(...)
        res -->> course_sv--:5.3.1.9. Return CourseDetailResponse object
        course_sv -->> be_ctrl--:5.3.1.10. Return CourseDetailResponse object
        be_ctrl -->> fe_ctrl--:5.3.1.11. Return statusCode 200
        
        fe_ctrl -> view_model++:5.3.1.12. Call PublicCourseViewModel()
        view_model -->> fe_ctrl--:5.3.1.13. Return PublicCourseViewModel object
        
        fe_ctrl -->> view:5.3.1.14. Return View(GiftSetupViewModel)
        activate view
        view -->> act--:5.3.1.15. Display error message
else Valid ModelState
        fe_ctrl -> be_ctrl++:5.3.2. GET /api/gift/check-recipient?email={recipientEmail}&courseId={courseId}
        be_ctrl -> sv++:5.3.2.1. IsRecipientEnrolledAsync(recipientEmail, courseId)
    
        sv -> user_repo++:5.3.2.2. GetAccountByEmailAsync(recipientEmail)
        user_repo -> ctx++:5.3.2.3. Query account by email from database
        ctx -> db++:5.3.2.4. Execute query
        db -->> ctx--:5.3.2.5. Return data
        ctx -->> user_repo--:5.3.2.6. Return Account entity or null
        user_repo -->> sv--:5.3.2.7. Return Account entity or null
    
opt Account found
            sv -> repo++:5.3.2.7.2. IsEnrolledAsync(accountId, courseId)
            repo -> ctx++:5.3.2.7.2.1. Check enrollment existence in database
            ctx -> db++:5.3.2.7.2.2. Execute query
            db -->> ctx--:5.3.2.7.2.3. Return data
            ctx -->> repo--:5.3.2.7.2.4. Return boolean
            repo -->> sv--:5.3.2.7.2.5. Return boolean
end
    
        sv -->> be_ctrl--:5.3.2.8. Return boolean
        be_ctrl -->> fe_ctrl--:5.3.2.9. Return statusCode 200
        
        fe_ctrl -> fe_ctrl++:5.3.2.10. Check recipient enrollment status
        fe_ctrl--
        
alt Recipient Already Enrolled (A.6 / EX-6)
            fe_ctrl -> be_ctrl++:5.3.2.10.1. GET /api/gift/course/{courseId}
            be_ctrl -> course_sv++:5.3.2.10.1.1. GetCourseWithDetailsAsync(courseId, userId, role)
            course_sv -> repo++:5.3.2.10.1.2. GetCourseWithDetailsAsync(courseId)
            repo -> ctx++:5.3.2.10.1.3. Query course details from database
            ctx -> db++:5.3.2.10.1.4. Execute query
            db -->> ctx--:5.3.2.10.1.5. Return data
            ctx -->> repo--:5.3.2.10.1.6. Return Course entity or null
            repo -->> course_sv--:5.3.2.10.1.7. Return Course entity or null
            course_sv -> res++:5.3.2.10.1.8. Call CourseDetailResponse(...)
            res -->> course_sv--:5.3.2.10.1.9. Return CourseDetailResponse object
            course_sv -->> be_ctrl--:5.3.2.10.1.10. Return CourseDetailResponse object
            be_ctrl -->> fe_ctrl--:5.3.2.10.1.11. Return statusCode 200
            
            fe_ctrl -> view_model++:5.3.2.10.1.12. Call PublicCourseViewModel()
            view_model -->> fe_ctrl--:5.3.2.10.1.13. Return PublicCourseViewModel object
            
            fe_ctrl -->> view:5.3.2.10.1.14. Return View(GiftSetupViewModel)
            activate view
            view -->> act--:5.3.2.10.1.15. Display error message
else Recipient Not Enrolled
            fe_ctrl -->> r_view--:5.3.2.10.2. Redirect to Gift Checkout page with gift details parameters
            activate r_view
            r_view -->> act--:5.3.2.10.2.1. Display Gift Checkout page
end
end
end

@enduml
