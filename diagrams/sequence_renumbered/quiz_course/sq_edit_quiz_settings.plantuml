@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Edit Quiz Settings

actor Instructor as act
participant "QuizEditorPage" as view
participant "QuizController" as fe_ctrl <<frontend controller>>
participant "QuizController" as be_ctrl <<backend controller>>
participant ":QuizService" as sv
participant ":IQuizRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Modify quiz settings and click Save
view -> fe_ctrl++:2. POST /Quiz/UpdateSettings/{id}
fe_ctrl -> be_ctrl++:3. PUT /api/quizzes/{id}/settings

be_ctrl -> sv++:4. Call UpdateQuizSettingsAsync(id, request, instructorId)

sv -> sv++:5. Validate quiz options and title uniqueness
sv--

alt Validation Failed
    sv -->> be_ctrl:5.1. throw ArgumentException
    be_ctrl -->> fe_ctrl:5.1.1. Return statusCode 400
    fe_ctrl -->> view:5.1.2. Return JSON (success=false)
    view -->> act:5.1.3. Display validation error message
else Validation Passed
    sv -> sv++:5.2. Validate quiz distributions
    sv--
    
alt Distributions Invalid
        sv -->> be_ctrl:5.2.1. throw ArgumentException
        be_ctrl -->> fe_ctrl:5.2.1.1. Return statusCode 400
        fe_ctrl -->> view:5.2.1.2. Return JSON (success=false)
        view -->> act:5.2.1.3. Display invalid distribution message
else Distributions Valid
        sv -> repo++:5.2.2. Call GetByIdAsync(id)
        repo -> ctx++:5.2.2.1. Execute query
        ctx -> db++:5.2.2.2. Fetch quiz and distributions
        db -->> ctx--:5.2.2.3. Return query results
        ctx -->> repo--:5.2.2.4. Return quiz entity
        repo -->> sv--:5.2.2.5. Return quiz entity
        
alt Quiz Not Found
            sv -->> be_ctrl:5.2.2.5.1. throw KeyNotFoundException
            be_ctrl -->> fe_ctrl:5.2.2.5.1.1. Return statusCode 404
            fe_ctrl -->> view:5.2.2.5.1.2. Return JSON (success=false)
            view -->> act:5.2.2.5.1.3. Display quiz not found message
else Quiz Found
            sv -> sv++:5.2.2.5.2. Validate Ownership
            sv--
            
alt Not Quiz Owner
                sv -->> be_ctrl:5.2.2.5.2.1. throw UnauthorizedAccessException
                be_ctrl -->> fe_ctrl:5.2.2.5.2.1.1. Return statusCode 403
                fe_ctrl -->> view:5.2.2.5.2.1.2. Return JSON (success=false)
                view -->> act:5.2.2.5.2.1.3. Display unauthorized message
else Is Quiz Owner
                sv -> sv++:5.2.2.5.2.2. Update quiz properties and distributions
                sv--
                
                sv -> repo++:5.2.2.5.2.2.1. Call UpdateAsync(quiz)
                repo -> ctx++:5.2.2.5.2.2.2. Save changes to database
                ctx -> db++:5.2.2.5.2.2.3. Update Quiz and Distributions
                
alt Database Save Failure
                    db -->> ctx:5.2.2.5.2.2.3.1. throw DbUpdateException
                    ctx -->> repo:5.2.2.5.2.2.3.1.1. throw DbUpdateException
                    repo -->> sv:5.2.2.5.2.2.3.1.2. throw DbUpdateException
                    sv -->> be_ctrl:5.2.2.5.2.2.3.1.3. throw DbUpdateException
                    be_ctrl -->> fe_ctrl:5.2.2.5.2.2.3.1.4. Return statusCode 500
                    fe_ctrl -->> view:5.2.2.5.2.2.3.1.5. Return JSON (success=false)
                    view -->> act:5.2.2.5.2.2.3.1.6. Display server error message
else Database Save Success
                    db -->> ctx--:5.2.2.5.2.2.3.2. Return returnCode
                    ctx -->> repo--:5.2.2.5.2.2.3.2.1. Return
                    repo -->> sv--:5.2.2.5.2.2.3.2.2. Return
                    
                    sv -> sv++:5.2.2.5.2.2.3.2.3. Map to QuizDetailResponse
                    sv--
                    
                    sv -->> be_ctrl--:5.2.2.5.2.2.3.2.4. Return QuizDetailResponse object
                    be_ctrl -->> fe_ctrl--:5.2.2.5.2.2.3.2.5. Return statusCode 200
                    fe_ctrl -->> view--:5.2.2.5.2.2.3.2.6. Return JSON (success=true)
                    view -->> act--:5.2.2.5.2.2.3.2.7. Display quiz updated successfully
end
end
end
end
end
