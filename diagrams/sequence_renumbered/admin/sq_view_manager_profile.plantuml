@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Profile (For Manager)

actor "Manager\n(Admin/Staff)" as act
participant "ProfilePage" as view
participant "LoginPage" as login_view
participant "AdminProfileController" as fe_ctrl <<frontend controller>>
participant "AdminProfileController" as be_ctrl <<backend controller>>
participant ":ManagerProfileService" as profile_sv
participant ":ManagerRepository" as manager_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
view ++

act -> view:1. Access the profile page
view -> fe_ctrl++:2. GET /AdminProfile/Index

fe_ctrl -> fe_ctrl:3. Validate active login session
alt Session Expired / Unauthorized Access
    fe_ctrl -->> login_view:3.1. Redirect to /Account/Login
    activate login_view
    login_view -->> act:3.1.1. Display Login page
    deactivate login_view
else Valid Session
    fe_ctrl -> be_ctrl++:3.2. GET /api/admin/profile
    
    be_ctrl -> be_ctrl:3.2.1. Validate ClaimTypes.NameIdentifier
    
alt Session Invalid
        be_ctrl -->> fe_ctrl:3.2.1.1. Return statusCode 401
        fe_ctrl -->> login_view:3.2.1.1.1. Redirect to /Account/Login
        activate login_view
        login_view -->> act:3.2.1.1.2. Display Login page
        deactivate login_view
else Valid Claim
        be_ctrl -> profile_sv++:3.2.1.2. GetProfileAsync(userId)
        profile_sv -> manager_repo++:3.2.1.2.1. GetManagerByIdAsync(userId)
        
        manager_repo -> ctx++:3.2.1.2.2. Query Manager\n(Include ManagerNavigation & Lockouts)
        ctx -> db++:3.2.1.2.3. Execute SELECT
        db -->> ctx--:3.2.1.2.4. Data
        
alt Manager Profile Not Found
            ctx -->> manager_repo:3.2.1.2.4.1. null
            manager_repo -->> profile_sv:3.2.1.2.4.1.1. null
            profile_sv -->> be_ctrl:3.2.1.2.4.1.2. null
            be_ctrl -->> fe_ctrl:3.2.1.2.4.1.3. Return statusCode 404
            fe_ctrl -->> login_view:3.2.1.2.4.1.4. Redirect to /Account/Login\nwith error message
            activate login_view
            login_view -->> act:3.2.1.2.4.1.5. Display error message regarding profile retrieval failure
            deactivate login_view
else Manager Profile Found
            ctx -->> manager_repo--:3.2.1.2.4.2. Manager Entity
            manager_repo -->> profile_sv--:3.2.1.2.4.2.1. Manager Entity
            
            profile_sv -> profile_sv:3.2.1.2.4.2.2. Retrieve account's active lockout history\n(From ManagerNavigation.Lockouts)
            
            profile_sv -> profile_sv:3.2.1.2.4.2.3. Map to ManagerProfileResponse
            profile_sv -->> be_ctrl--:3.2.1.2.4.2.4. Return ManagerProfileResponse
            
            be_ctrl -->> fe_ctrl--:3.2.1.2.4.2.5. Return statusCode 200 (ManagerProfileResponse)
            
            fe_ctrl -> fe_ctrl:3.2.1.2.4.2.6. Deserialize to AdminProfileViewModel
            fe_ctrl -->> view--:3.2.1.2.4.2.7. Return View(AdminProfileViewModel)
            
            view -->> act--:3.2.1.2.4.2.8. Display manager profile details,\naccount information, and lockout status
end
end
end

@enduml
