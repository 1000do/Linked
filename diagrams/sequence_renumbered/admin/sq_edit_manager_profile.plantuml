@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Edit Profile (For Manager)

actor "Manager\n(Admin/Staff)" as act
participant "ProfilePage" as view
participant "EditProfilePage" as edit_view
participant "LoginPage" as login_view
participant "AdminProfileController" as fe_ctrl <<frontend controller>>
participant "AdminProfileController" as be_ctrl <<backend controller>>
participant ":ManagerProfileService" as profile_sv
participant ":FileUploadService" as upload_sv
participant ":ManagerRepository" as manager_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
view ++

act -> view:1. Click the "Edit Profile" link
view -> fe_ctrl++:2. GET /AdminProfile/Edit

fe_ctrl -> fe_ctrl:3. Validate active login session
alt Session Invalid (Not Logged In)
    fe_ctrl -->> login_view:3.1. Redirect to /Account/Login
    activate login_view
    login_view -->> act:3.1.1. Display Login page
    deactivate login_view
else Valid Session
    fe_ctrl -> be_ctrl++:3.2. GET /api/admin/profile
    be_ctrl -->> fe_ctrl--:3.2.1. Return profile data
    
    fe_ctrl -> fe_ctrl:3.2.2. Map to UpdateAdminProfileViewModel
    fe_ctrl -->> edit_view:3.2.3. Return View(UpdateAdminProfileViewModel)
    activate edit_view
    edit_view -->> act:3.2.4. Display current profile details
end

alt A.1 Cancel editing
    act -> edit_view:4.1. Click "Cancel" or "Back to Profile"
    edit_view -->> act:4.1.1. Redirect back to Profile page
else Save Profile
    act -> edit_view:4.2. Update details and click "Save Profile"
    
    edit_view -> edit_view:4.2.1. Validate input fields and show confirmation prompt
    edit_view -->> act:4.2.2. Display confirmation prompt
    
    act -> edit_view:4.2.3. Click confirmation button
    
    edit_view -> fe_ctrl:4.2.4. POST /AdminProfile/Edit\n(multipart/form-data)
    
    fe_ctrl -> fe_ctrl:4.2.5. Validate active login session
alt Session Invalid (Not Logged In)
        fe_ctrl -->> edit_view:4.2.5.1. Return Json(success=false)
        edit_view -->> act:4.2.5.1.1. Display authentication error message\nRedirect to login page
else Valid Session
        fe_ctrl -> be_ctrl++:4.2.5.2. PUT /api/admin/profile/update
        
        be_ctrl -> be_ctrl:4.2.5.2.1. Validate ClaimTypes.NameIdentifier
        
        be_ctrl -> profile_sv++:4.2.5.2.2. UpdateProfileAsync(userId, request)
        
alt Has AvatarFile
            profile_sv -> upload_sv++:4.2.5.2.2.1. UploadImageAsync(request.AvatarFile)
            upload_sv -->> profile_sv--:4.2.5.2.2.1.1. return avatarUrl
alt File Upload Service offline
                profile_sv -->> be_ctrl:4.2.5.2.2.1.1.1. return false
                be_ctrl -->> fe_ctrl:4.2.5.2.2.1.1.1.1. Return statusCode 400
                fe_ctrl -->> edit_view:4.2.5.2.2.1.1.1.2. Return Json(success=false, message="Failed to update...")
                edit_view -->> act:4.2.5.2.2.1.1.1.3. Display error message regarding file upload failure
end
end
        
        profile_sv -> manager_repo++:4.2.5.2.3. UpdateManagerProfileAsync(...)
        manager_repo -> ctx++:4.2.5.2.4. Query Manager and Update Fields
        ctx -> db++:4.2.5.2.5. Execute UPDATE
        db -->> ctx--:4.2.5.2.6. row affected
        ctx -->> manager_repo--:4.2.5.2.7. return true
        manager_repo -->> profile_sv--:4.2.5.2.8. return true
        
        profile_sv -->> be_ctrl--:4.2.5.2.9. return true
        be_ctrl -->> fe_ctrl--:4.2.5.2.10. Return statusCode 200
        
        fe_ctrl -> be_ctrl++:4.2.5.2.11. GET /api/admin/profile (Sync Cookies)
        be_ctrl -->> fe_ctrl--:4.2.5.2.12. Return updated profile data
        
        fe_ctrl -> fe_ctrl:4.2.5.2.13. Update Cookies ("UserName", "AvatarUrl")
        
        fe_ctrl -->> edit_view--:4.2.5.2.14. Return Json(success=true, avatarUrl, userName)
        
        edit_view -> edit_view:4.2.5.2.15. Update layout dynamically
        edit_view -->> act--:4.2.5.2.16. Display success confirmation message
end
end
@enduml
