@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Sort Instructor Applications

actor Staff as act
participant "AdminApprovalIndexPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "AdminApprovalController" as fe_ctrl <<frontend controller>>
participant "AdminApprovalController" as be_ctrl <<backend controller>>
participant ":IInstructorApprovalService" as sv
participant ":IInstructorRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Access instructor applications queue page
view -> fe_ctrl++:2. GET /AdminApproval/Index (page, pageSize)

fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization
    fe_ctrl -> be_ctrl++:3.3. GET /api/AdminApproval/pending-instructors (with page/pageSize)
    
    be_ctrl -> sv++:3.3.1. Call GetPendingListAsync(page, pageSize)
    sv -> repo++:3.3.2. Call GetPendingInstructorsAsync(page, pageSize)
    repo -> ctx++:3.3.3. Call GetPendingInstructorsAsync(page, pageSize)
    ctx -> db++:3.3.4. Execute SELECT query
    
    db -->> ctx--:3.3.5. Return instructors list & totalCount
    ctx -->> repo--:3.3.6. Return instructors list & totalCount
    repo -->> sv--:3.3.7. Return instructors list & totalCount
    
    sv -> sv++:3.3.8. Call MapToInstructorApprovalDto for each item
    sv --
    
    sv -->> be_ctrl--:3.3.9. Return PagedResult<InstructorApprovalDto>
    be_ctrl -->> fe_ctrl--:3.3.10. Return statusCode 200
    fe_ctrl -->> view--:3.3.11. Return View with model
    
    view -> view++:3.3.12. Render pending applications table
    view --
    
    view -->> act:3.3.13. Display list of pending instructor applications

    act -> view:3.3.14. Select sorting option in sort dropdown
    view -> view++:3.3.15. EventListener: change event triggered
    view --
    
    view -> view++:3.3.16. applyFilters() (runs client-side sorting on cached applications)
    view --
    
    view -> view++:3.3.17. renderTable() (renders sorted results)
    view --
    
    view -->> act--:3.3.18. Display sorted pending instructor applications
end

@enduml
