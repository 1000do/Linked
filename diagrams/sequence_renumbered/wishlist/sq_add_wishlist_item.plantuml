@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Add Wishlist Item (Toggle)
actor User as act

participant "CourseDetailsView" as view
participant "WishlistController" as fe_ctrl <<frontend controller>>
participant "WishlistController" as be_ctrl <<backend controller>>
participant ":IWishlistService" as sv
participant ":ICourseRepository" as c_repo
participant ":IWishlistRepository" as w_repo
participant ":WishlistItem" as entity
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Click "Add to Wishlist" button
view->fe_ctrl++:2. POST /Wishlist/ToggleAjax

fe_ctrl->be_ctrl++:3. GET /api/wishlist/check/{courseId}

be_ctrl->be_ctrl++:4. Parse userId from token
be_ctrl--

be_ctrl->sv++:5. Call IsInWishlistAsync(userId, courseId)
sv->w_repo++:6. Call ExistsAsync(userId, courseId)
w_repo->ctx++:7. Query WishlistItem
ctx->db++:8. Execute query
db-->>ctx--:9. Return result
ctx-->>w_repo--:10. Return result
w_repo-->>sv--:11. Return result
sv-->>be_ctrl--:12. Return result
be_ctrl-->>fe_ctrl--:13. Return statusCode 200

fe_ctrl->fe_ctrl++:14. Check isInWishlist
fe_ctrl--

alt isInWishlist == true (Toggle to Remove)
    fe_ctrl->be_ctrl++:14.1. DELETE /api/wishlist/{courseId}
    be_ctrl-->>fe_ctrl--:14.1.1. Return statusCode 200
    fe_ctrl-->>view:14.1.2. Return JSON (success = true, isInWishlist = false)
    view-->>act:14.1.3. Update Wishlist icon (Removed)
else isInWishlist == false (Toggle to Add)
    fe_ctrl->be_ctrl++:14.2. POST /api/wishlist/{courseId}
    
    be_ctrl->be_ctrl++:14.2.1. Parse userId from token
    be_ctrl--
    
    be_ctrl->sv++:14.2.2. Call AddToWishlistAsync(userId, courseId)
    
    sv->c_repo++:14.2.3. Call GetByIdAsync(courseId)
    c_repo->ctx++:14.2.4. Query Course
    ctx->db++:14.2.5. Execute query
    db-->>ctx--:14.2.6. Return result
    ctx-->>c_repo--:14.2.7. Return result
    c_repo-->>sv--:14.2.8. Return result
    
    sv->w_repo++:14.2.9. Call ExistsAsync(userId, courseId)
    w_repo->ctx++:14.2.10. Query WishlistItem
    ctx->db++:14.2.11. Execute query
    db-->>ctx--:14.2.12. Return result
    ctx-->>w_repo--:14.2.13. Return result
    w_repo-->>sv--:14.2.14. Return result
    
    sv->sv++:14.2.15. Validate wishlist addition
    sv--
    
alt Pre-addition Validation Failed (Course not found/published or already in wishlist)
        sv-->>be_ctrl:14.2.15.1. throw InvalidOperationException
        be_ctrl-->>fe_ctrl:14.2.15.1.1. Return statusCode 400
        fe_ctrl-->>view:14.2.15.1.2. Return JSON (success = false)
        view-->>act:14.2.15.1.3. Display error message
else Pre-addition Validation Success
        sv->entity++:14.2.15.2. Call new WishlistItem()
        entity-->>sv--:14.2.15.2.1. Return WishlistItem object
        
        sv->w_repo++:14.2.15.2.2. Call AddAsync(newItem)
        w_repo->ctx++:14.2.15.2.3. Add WishlistItem entity
        ctx-->>w_repo--:14.2.15.2.4. Return result
        w_repo-->>sv--:14.2.15.2.5. Return result
        
        sv->w_repo++:14.2.15.2.6. Call SaveChangesAsync()
        w_repo->ctx++:14.2.15.2.7. Commit tracked changes
        ctx->db++:14.2.15.2.8. Execute query
        db-->>ctx--:14.2.15.2.9. Return result
        ctx-->>w_repo--:14.2.15.2.10. Return numberOfRowsAffected
        w_repo-->>sv--:14.2.15.2.11. Return numberOfRowsAffected
        
        sv->sv++:14.2.15.2.12. Check numberOfRowsAffected
        sv--
        
alt Database Save Failed (numberOfRowsAffected == 0)
            sv-->>be_ctrl:14.2.15.2.12.1. throw Exception
            be_ctrl-->>fe_ctrl:14.2.15.2.12.1.1. Return statusCode 400
            fe_ctrl-->>view:14.2.15.2.12.1.2. Return JSON (success = false)
            view-->>act:14.2.15.2.12.1.3. Display error message
else Database Save Success
            sv-->>be_ctrl--:14.2.15.2.12.2. Return success
            be_ctrl-->>fe_ctrl--:14.2.15.2.12.2.1. Return statusCode 200
            
            fe_ctrl-->>view--:14.2.15.2.12.2.2. Return JSON (success = true, isInWishlist = true)
            view-->>act--:14.2.15.2.12.2.3. Update Wishlist icon (Added)
end
end
end
@enduml
