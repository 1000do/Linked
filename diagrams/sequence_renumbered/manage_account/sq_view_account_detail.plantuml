@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Account Detail
actor Admin as act

participant "AdminAccountView" as view
participant "AdminAccountController" as fe_ctrl <<frontend controller>>
participant "AdminAccountController" as be_ctrl <<backend controller>>
participant ":AdminAccountDetailDto" as detail_dto
participant ":AccountTransactionSummaryDto" as summary_dto
participant ":AdminAccountDetailViewModel" as vm_acc
participant ":AccountTransactionSummaryViewModel" as vm_trans
participant ":AdminAccountDetailPageViewModel" as vm_page
participant ":IAdminAccountService" as sv
participant ":IUserRepository" as u_repo
participant ":ILockoutRepository" as lockout_repo
participant ":IReportRepository" as report_repo
participant ":INotificationRepository" as notif_repo
participant ":IChatRepository" as chat_repo
participant ":ITransactionRepository" as trans_repo
participant ":IEnrollmentRepository" as enroll_repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Click "View Detail" on an account
view->fe_ctrl++:2. GET /AdminAccount/Detail/{id}


fe_ctrl->be_ctrl++:3. GET /api/admin/accounts/{id}

be_ctrl->sv++:4. Call GetAccountDetailAsync(id)
sv->u_repo++:5. Call GetAccountByIdAsync(id)
u_repo->ctx++:6. Query Account
ctx->db++:7. Execute query
db-->>ctx--:8. Return result
ctx-->>u_repo--:9. Return Account
u_repo-->>sv--:10. Return Account

sv->lockout_repo++:11. Call GetActiveLockoutAsync(id, "account")
lockout_repo->ctx++:12. Query Lockout
ctx->db++:13. Execute query
db-->>ctx--:14. Return result
ctx-->>lockout_repo--:15. Return Lockout
lockout_repo-->>sv--:16. Return Lockout

opt Account is Staff or Admin
    sv->report_repo++:16.1. Call GetResolvedReportsCountAsync(id)
    report_repo->ctx++:16.1.1. Query Reports
    ctx->db++:16.1.2. Execute query
    db-->>ctx--:16.1.3. Return result
    ctx-->>report_repo--:16.1.4. Return count
    report_repo-->>sv--:16.1.5. Return count
    
    sv->notif_repo++:16.1.6. Call GetSentNotificationsCountAsync(id)
    notif_repo->ctx++:16.1.7. Query Notifications
    ctx->db++:16.1.8. Execute query
    db-->>ctx--:16.1.9. Return result
    ctx-->>notif_repo--:16.1.10. Return count
    notif_repo-->>sv--:16.1.11. Return count
    
    sv->chat_repo++:16.1.12. Call GetActiveChatsCountAsync(id)
    chat_repo->ctx++:16.1.13. Query Chats
    ctx->db++:16.1.14. Execute query
    db-->>ctx--:16.1.15. Return result
    ctx-->>chat_repo--:16.1.16. Return count
    chat_repo-->>sv--:16.1.17. Return count
end

opt Account is Student
    sv->trans_repo++:16.2. Call GetTotalSpentAsync(id)
    trans_repo->ctx++:16.2.1. Query Transactions
    ctx->db++:16.2.2. Execute query
    db-->>ctx--:16.2.3. Return result
    ctx-->>trans_repo--:16.2.4. Return total
    trans_repo-->>sv--:16.2.5. Return total
    
    sv->enroll_repo++:16.2.6. Call GetMyEnrolledCoursesAsync(id)
    enroll_repo->ctx++:16.2.7. Query Enrollments
    ctx->db++:16.2.8. Execute query
    db-->>ctx--:16.2.9. Return result
    ctx-->>enroll_repo--:16.2.10. Return enrollments
    enroll_repo-->>sv--:16.2.11. Return enrollments
    
opt Account is Instructor
        sv->trans_repo++:16.2.11.3. Call GetInstructorTotalRevenueAsync(id)
        trans_repo->ctx++:16.2.11.3.1. Query Transactions
        ctx->db++:16.2.11.3.2. Execute query
        db-->>ctx--:16.2.11.3.3. Return result
        ctx-->>trans_repo--:16.2.11.3.4. Return revenue
        trans_repo-->>sv--:16.2.11.3.5. Return revenue
        
        sv->trans_repo++:16.2.11.3.6. Call GetInstructorTotalWithdrawnAsync(id)
        trans_repo->ctx++:16.2.11.3.7. Query Transactions
        ctx->db++:16.2.11.3.8. Execute query
        db-->>ctx--:16.2.11.3.9. Return result
        ctx-->>trans_repo--:16.2.11.3.10. Return withdrawn
        trans_repo-->>sv--:16.2.11.3.11. Return withdrawn
end
end

sv->detail_dto++:17. Call AdminAccountDetailDto()
detail_dto-->>sv--:18. Return AdminAccountDetailDto object

sv-->>be_ctrl--:19. Return AdminAccountDetailDto object
be_ctrl-->>fe_ctrl--:20. Return statusCode 200


fe_ctrl->be_ctrl++:21. GET /api/admin/accounts/{id}/transactions

be_ctrl->sv++:22. Call GetAccountTransactionsAsync(id)
sv->u_repo++:23. Call GetAccountByIdAsync(id)
u_repo->ctx++:24. Query Account
ctx->db++:25. Execute query
db-->>ctx--:26. Return result
ctx-->>u_repo--:27. Return Account
u_repo-->>sv--:28. Return Account

sv->trans_repo++:29. Call GetAccountTransactionsSummaryAsync(id)
trans_repo->ctx++:30. Query Transactions
ctx->db++:31. Execute query
db-->>ctx--:32. Return result
ctx-->>trans_repo--:33. Return summary
trans_repo-->>sv--:34. Return summary

sv->summary_dto++:35. Call AccountTransactionSummaryDto()
summary_dto-->>sv--:36. Return AccountTransactionSummaryDto object

sv-->>be_ctrl--:37. Return AccountTransactionSummaryDto object
be_ctrl-->>fe_ctrl--:38. Return statusCode 200


alt Any request failed
    fe_ctrl-->>view:38.1. Return statusCode 302
    view-->>act:38.1.1. Display Index page with error message
else Both requests are successful
    fe_ctrl->vm_acc++:38.2. Call AdminAccountDetailViewModel()
    vm_acc-->>fe_ctrl--:38.2.1. Return AdminAccountDetailViewModel object

    fe_ctrl->vm_trans++:38.2.2. Call AccountTransactionSummaryViewModel()
    vm_trans-->>fe_ctrl--:38.2.3. Return AccountTransactionSummaryViewModel object

    fe_ctrl->vm_page++:38.2.4. Call AdminAccountDetailPageViewModel()
    vm_page-->>fe_ctrl--:38.2.5. Return AdminAccountDetailPageViewModel object

    fe_ctrl-->>view:38.2.6. Return statusCode 200
    deactivate fe_ctrl
    view-->>act:38.2.7. Display Account Detail page
    deactivate view
end
deactivate act
@enduml
