@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Delete Account
actor Admin as act

participant "AdminAccountView" as view
participant "AdminAccountController" as fe_ctrl <<frontend controller>>
participant "AdminAccountController" as be_ctrl <<backend controller>>
participant ":IAdminAccountService" as sv
participant ":Lockout" as lockout_ett
participant ":IUserRepository" as u_repo
participant ":ILockoutRepository" as lockout_repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Click "Delete/Ban" button
view->fe_ctrl++:2. POST /AdminAccount/ToggleBan/{id}

fe_ctrl->be_ctrl++:3. POST /api/admin/accounts/{id}/toggle-ban

be_ctrl->be_ctrl++:4. Extract adminId from User claims
be_ctrl--

be_ctrl->sv++:5. Call ToggleBanAsync(id, adminId)

sv->u_repo++:6. Call GetAccountByIdAsync(id)
u_repo->ctx++:7. Query Account with Manager details
ctx->db++:8. Execute query
db-->>ctx--:9. Return result
ctx-->>u_repo--:10. Return Account entity
u_repo-->>sv--:11. Return Account entity

alt Account not found
    sv-->>be_ctrl:11.1. Return null
    be_ctrl-->>fe_ctrl:11.1.1. Return statusCode 404
    fe_ctrl-->>view:11.1.2. Return JSON with success = false
    view-->>act:11.1.3. Display error toast message
else Account is Super Admin
    sv-->>be_ctrl:11.2. throw InvalidOperationException
    be_ctrl-->>fe_ctrl:11.2.1. Return statusCode 400
    fe_ctrl-->>view:11.2.2. Return JSON with success = false
    view-->>act:11.2.3. Display error toast message
else Account is valid
alt Account is currently Banned
        sv->sv++:11.3.1. Set AccountStatus = "Active"
        sv--
        sv->lockout_repo++:11.3.1.1. Call RemoveAccountLockoutsAsync(accountId)
        lockout_repo->ctx++:11.3.1.2. Remove Lockout entities
        ctx-->>lockout_repo--:11.3.1.3. Return tracking state
        lockout_repo-->>sv--:11.3.1.4. Return success
else Account is currently Active
        sv->sv++:11.3.2. Set AccountStatus = "Banned"
        sv--
        sv->lockout_ett++:11.3.2.1. Call Lockout()
        lockout_ett-->>sv--:11.3.2.2. Return Lockout entity
        sv->lockout_repo++:11.3.2.3. Call AddAsync(lockout)
        lockout_repo->ctx++:11.3.2.4. Add Lockout entity (100 years)
        ctx-->>lockout_repo--:11.3.2.5. Return tracking state
        lockout_repo-->>sv--:11.3.2.6. Return success
end
    
    sv->u_repo++:11.4. Call SaveChangesAsync()
    u_repo->ctx++:11.5. Commit tracked changes
    ctx->db++:11.6. Save changes to database
    db-->>ctx--:11.7. Return result
    ctx-->>u_repo--:11.8. Return numberOfRowsAffected
    u_repo-->>sv--:11.9. Return success
    
    sv-->>be_ctrl--:11.10. Return newStatus
    be_ctrl-->>fe_ctrl--:11.11. Return statusCode 200
    fe_ctrl-->>view--:11.12. Return JSON with success = true
    view-->>act--:11.13. Display success toast and update UI status
end
@enduml
