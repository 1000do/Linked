@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Receive Gift

actor User as act
participant "ClaimPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "GiftController" as fe_ctrl <<frontend controller>>
participant "GiftController" as be_ctrl <<backend controller>>
participant ":IGiftService" as sv
participant ":Enrollment" as enrollment
participant ":IGiftRepository" as gift_repo
participant ":ICourseRepository" as course_repo
participant ":IEnrollmentRepository" as enroll_repo
participant ":ITransactionRepository" as transaction_repo
database Database as db

act ++
act -> view++:1. Click "Claim Gift" button
view -> fe_ctrl++:2. POST /Gift/ClaimGiftAjax

fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization
    
    fe_ctrl -> be_ctrl++:3.3. POST /api/gift/claim
    
    be_ctrl -> be_ctrl++:3.3.1. Validate ModelState
    be_ctrl--
    
opt Invalid ModelState
        be_ctrl -->> fe_ctrl:3.3.1.1. Return statusCode 400
        fe_ctrl -->> view:3.3.1.1.1. Return Json(success=false)
        view -->> act:3.3.1.1.2. Display error message
end
    
    be_ctrl -> sv++:3.3.2. ClaimGiftAsync(userId, token)
            
            sv -> gift_repo++:3.3.3. GetByTokenAsync(token)
            gift_repo -> db++:3.3.4. Execute query
            db -->> gift_repo--:3.3.5. Return result
            gift_repo -->> sv--:3.3.6. Return Gift object
            
            sv -> sv++:3.3.7. Validate gift and token
            sv--
            
alt Gift not found or token invalid
                sv -->> be_ctrl:3.3.7.1. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:3.3.7.1.1. Return statusCode 400
                fe_ctrl -->> view:3.3.7.1.2. Return Json(success=false)
                view -->> act:3.3.7.1.3. Display error message
else Gift already claimed or refunded
                sv -->> be_ctrl:3.3.7.2. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:3.3.7.2.1. Return statusCode 400
                fe_ctrl -->> view:3.3.7.2.2. Return Json(success=false)
                view -->> act:3.3.7.2.3. Display error message
else Valid gift
                
                sv -> course_repo++:3.3.7.3. GetByIdAsync(courseId)
                course_repo -> db++:3.3.7.3.1. Execute query
                db -->> course_repo--:3.3.7.3.2. Return result
                course_repo -->> sv--:3.3.7.3.3. Return Course object
                
                sv -> sv++:3.3.7.3.4. Validate course
                sv--
                
alt Course not found
                    sv -->> be_ctrl:3.3.7.3.4.1. throw InvalidOperationException
                    be_ctrl -->> fe_ctrl:3.3.7.3.4.1.1. Return statusCode 400
                    fe_ctrl -->> view:3.3.7.3.4.1.2. Return Json(success=false)
                    view -->> act:3.3.7.3.4.1.3. Display error message
else Course found
                    
                    sv -> enroll_repo++:3.3.7.3.4.2. GetEnrollmentAsync(userId, courseId)
                    enroll_repo -> db++:3.3.7.3.4.2.1. Execute query
                    db -->> enroll_repo--:3.3.7.3.4.2.2. Return result
                    enroll_repo -->> sv--:3.3.7.3.4.2.3. Return Enrollment object
                    
                    sv -> sv++:3.3.7.3.4.2.4. Check enrollment status
                    sv--
                    
alt Recipient already enrolled
                        sv -->> be_ctrl:3.3.7.3.4.2.4.1. throw InvalidOperationException
                        be_ctrl -->> fe_ctrl:3.3.7.3.4.2.4.1.1. Return statusCode 400
                        fe_ctrl -->> view:3.3.7.3.4.2.4.1.2. Return Json(success=false)
                        view -->> act:3.3.7.3.4.2.4.1.3. Display error message
else Recipient not enrolled
                        
                        sv -> enroll_repo++:3.3.7.3.4.2.4.2. BeginTransactionAsync()
                        enroll_repo -> db++:3.3.7.3.4.2.4.2.1. Execute query
                        db -->> enroll_repo--:3.3.7.3.4.2.4.2.2. Return result
                        enroll_repo -->> sv--:3.3.7.3.4.2.4.2.3. Return result
                        
                        sv -> sv++:3.3.7.3.4.2.4.2.4. CreateEnrollmentWithinTransactionAsync(userId, course)
                        
                        sv -> enrollment++:3.3.7.3.4.2.4.2.5. Call Enrollment()
                        enrollment -->> sv--:3.3.7.3.4.2.4.2.6. Return Enrollment object
                        
                        sv -> enroll_repo++:3.3.7.3.4.2.4.2.7. AddEnrollmentAsync(enrollment)
                        enroll_repo -> db++:3.3.7.3.4.2.4.2.8. Execute query
                        db -->> enroll_repo--:3.3.7.3.4.2.4.2.9. Return result
                        enroll_repo -->> sv--:3.3.7.3.4.2.4.2.10. Return result
                        
                        sv -> enroll_repo++:3.3.7.3.4.2.4.2.11. SaveChangesAsync()
                        enroll_repo -> db++:3.3.7.3.4.2.4.2.12. Save changes to database
                        db -->> enroll_repo--:3.3.7.3.4.2.4.2.13. Return result
                        enroll_repo -->> sv--:3.3.7.3.4.2.4.2.14. Return result
                        sv--
                        
                        sv -> sv++:3.3.7.3.4.2.4.2.15. MarkGiftAsClaimedWithinTransactionAsync(gift, userId)
                        sv -> gift_repo++:3.3.7.3.4.2.4.2.16. Update(gift)
                        gift_repo -->> sv--:3.3.7.3.4.2.4.2.17. Return result
                        
                        sv -> gift_repo++:3.3.7.3.4.2.4.2.18. SaveChangesAsync()
                        gift_repo -> db++:3.3.7.3.4.2.4.2.19. Save changes to database
                        db -->> gift_repo--:3.3.7.3.4.2.4.2.20. Return result
                        gift_repo -->> sv--:3.3.7.3.4.2.4.2.21. Return result
                        sv--
                        
                        sv -> transaction_repo++:3.3.7.3.4.2.4.2.22. RejectPendingRefundForGiftClaimedAsync(orderItemId)
                        transaction_repo -> db++:3.3.7.3.4.2.4.2.23. Execute query
                        db -->> transaction_repo--:3.3.7.3.4.2.4.2.24. Return result
                        transaction_repo -->> sv--:3.3.7.3.4.2.4.2.25. Return result (rejected boolean)
                        
                        sv -> enroll_repo++:3.3.7.3.4.2.4.2.26. Commit transaction
                        enroll_repo -> db++:3.3.7.3.4.2.4.2.27. Execute query
                        db -->> enroll_repo--:3.3.7.3.4.2.4.2.28. Return result
                        enroll_repo -->> sv--:3.3.7.3.4.2.4.2.29. Return result
                        

                        
                        sv -->> be_ctrl--:3.3.7.3.4.2.4.2.30. Return result
                        be_ctrl -->> fe_ctrl--:3.3.7.3.4.2.4.2.31. Return statusCode 200
                        fe_ctrl -->> view--:3.3.7.3.4.2.4.2.32. Return Json(success=true)
                        view -->> act--:3.3.7.3.4.2.4.2.33. Display success message
end
end
end
end
@enduml
