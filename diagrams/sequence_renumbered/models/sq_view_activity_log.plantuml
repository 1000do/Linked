@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Activity Log

actor Admin as act
participant "AiServiceManagementPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "AdminAiServiceController" as fe_ctrl <<frontend controller>>
participant ":AdminAiServicePageViewModel" as view_model
participant "AdminAiServiceController" as be_ctrl <<backend controller>>
participant ":IAiModerationLogService" as sv
participant ":PagedResult<CourseModerationLogAdminDto>" as c_dto
participant ":PagedResult<ReviewModerationLogAdminDto>" as r_dto
participant ":ICourseAiUsageLogRepository" as course_repo
participant ":ICourseReviewModerationLogRepository" as course_rev_repo
participant ":ILessonReviewModerationLogRepository" as lesson_rev_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Access Ai Service Management page
view -> fe_ctrl++:2. Send GET request to /AdminAiService/Index
fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization
par Fetch Course Logs
        fe_ctrl -> be_ctrl++:3.3.1. Send GET request to /api/admin/ai-service/logs/course
        be_ctrl -> sv++:3.3.1.1. Call GetCourseModerationLogsAsync(req)
        sv -> course_repo++:3.3.1.2. Call GetPagedAdminAsync(page, pageSize)
        course_repo -> ctx++:3.3.1.3. Query CourseAiUsageLogs
        ctx -> db++:3.3.1.4. Execute query
alt Database Query Failure
            db -->> ctx:3.3.1.4.1. Return empty list, totalCount = 0
            ctx -->> course_repo:3.3.1.4.1.1. Return empty list, totalCount = 0
            course_repo -->> sv:3.3.1.4.1.2. Return empty list, totalCount = 0
            sv -->> be_ctrl:3.3.1.4.1.3. Throw KeyNotFoundException
            be_ctrl -->> fe_ctrl:3.3.1.4.1.4. Return statusCode 404
else Database Query Success
            db -->> ctx--:3.3.1.4.2. Return data
            ctx -->> course_repo--:3.3.1.4.2.1. Return data
            course_repo -->> sv--:3.3.1.4.2.2. Return (items, totalCount)
            sv -> c_dto++:3.3.1.4.2.3. Map to PagedResult<CourseModerationLogAdminDto>
            c_dto -->> sv--:3.3.1.4.2.4. Return PagedResult
            sv -->> be_ctrl--:3.3.1.4.2.5. Return PagedResult<CourseModerationLogAdminDto>
            be_ctrl -->> fe_ctrl--:3.3.1.4.2.6. Return statusCode 200
end
else Fetch Course Review Logs
        fe_ctrl -> be_ctrl++:3.3.2. Send GET request to /api/admin/ai-service/logs/course-review
        be_ctrl -> sv++:3.3.2.1. Call GetCourseReviewModerationLogsAsync(req)
        sv -> course_rev_repo++:3.3.2.2. Call GetPagedAdminAsync(page, pageSize)
        course_rev_repo -> ctx++:3.3.2.3. Query CourseReviewModerationLogs
        ctx -> db++:3.3.2.4. Execute query
alt Database Query Failure
            db -->> ctx:3.3.2.4.1. Return empty list, totalCount = 0
            ctx -->> course_rev_repo:3.3.2.4.1.1. Return empty list, totalCount = 0
            course_rev_repo -->> sv:3.3.2.4.1.2. Return empty list, totalCount = 0
            sv -->> be_ctrl:3.3.2.4.1.3. Throw KeyNotFoundException
            be_ctrl -->> fe_ctrl:3.3.2.4.1.4. Return statusCode 404
else Database Query Success
            db -->> ctx--:3.3.2.4.2. Return data
            ctx -->> course_rev_repo--:3.3.2.4.2.1. Return data
            course_rev_repo -->> sv--:3.3.2.4.2.2. Return (items, totalCount)
            sv -> r_dto++:3.3.2.4.2.3. Map to PagedResult<ReviewModerationLogAdminDto>
            r_dto -->> sv--:3.3.2.4.2.4. Return PagedResult
            sv -->> be_ctrl--:3.3.2.4.2.5. Return PagedResult<ReviewModerationLogAdminDto>
            be_ctrl -->> fe_ctrl--:3.3.2.4.2.6. Return statusCode 200
end
else Fetch Lesson Review Logs
        fe_ctrl -> be_ctrl++:3.3.3. Send GET request to /api/admin/ai-service/logs/lesson-review
        be_ctrl -> sv++:3.3.3.1. Call GetLessonReviewModerationLogsAsync(req)
        sv -> lesson_rev_repo++:3.3.3.2. Call GetPagedAdminAsync(page, pageSize)
        lesson_rev_repo -> ctx++:3.3.3.3. Query LessonReviewModerationLogs
        ctx -> db++:3.3.3.4. Execute query
alt Database Query Failure
            db -->> ctx:3.3.3.4.1. Return empty list, totalCount = 0
            ctx -->> lesson_rev_repo:3.3.3.4.1.1. Return empty list, totalCount = 0
            lesson_rev_repo -->> sv:3.3.3.4.1.2. Return empty list, totalCount = 0
            sv -->> be_ctrl:3.3.3.4.1.3. Throw KeyNotFoundException
            be_ctrl -->> fe_ctrl:3.3.3.4.1.4. Return statusCode 404
else Database Query Success
            db -->> ctx--:3.3.3.4.2. Return data
            ctx -->> lesson_rev_repo--:3.3.3.4.2.1. Return data
            lesson_rev_repo -->> sv--:3.3.3.4.2.2. Return (items, totalCount)
            sv -> r_dto++:3.3.3.4.2.3. Map to PagedResult<ReviewModerationLogAdminDto>
            r_dto -->> sv--:3.3.3.4.2.4. Return PagedResult
            sv -->> be_ctrl--:3.3.3.4.2.5. Return PagedResult<ReviewModerationLogAdminDto>
            be_ctrl -->> fe_ctrl--:3.3.3.4.2.6. Return statusCode 200
end
    
end
    fe_ctrl -> view_model++:3.4. Map responses to AdminAiServicePageViewModel
    view_model -->> fe_ctrl--:3.5. Return AdminAiServicePageViewModel object
    
    fe_ctrl -->> view--:3.6. Return View(model)
    
alt No Logs Exist For Category
        view -->> act:3.6.1. Display empty state message
else Logs Exist
        view -->> act:3.6.2. Display activity log list under course moderation subtab
        
opt Admin Switches Category Subtab
            act -> view:3.6.2.1. Click different category subtab
            view -> view++:3.6.2.1.1. Toggle subtab visibility
            view--
            view -->> act:3.6.2.1.2. Display activity log list for selected category
end
        
opt Admin Navigates to Another Page
            act -> view:3.6.2.2. Click pagination button
            view -> fe_ctrl++:3.6.2.2.1. Send GET request to GetCourseLogsPartial
            fe_ctrl -> fe_ctrl++:3.6.2.2.2. Fetch requested page of logs
            fe_ctrl--
            fe_ctrl -->> view--:3.6.2.2.3. Return PartialView
            view -->> act--:3.6.2.2.4. Display requested page of logs
end
end
end
@enduml
