@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Filter Payout History
actor Instructor as act

participant "Transaction/Instructor.cshtml" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "InstructorController" as be_ctrl <<backend controller>>
participant ":InstructorService" as sv
participant ":InstructorRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Enter payout keyword, select status, and click "Filter"
view->fe_ctrl++:2. Send GET /Transaction/Instructor?tab=po&payoutKeyword=Stripe&payoutStatus=succeeded&payoutPage=1

fe_ctrl->be_ctrl++:3. Send GET /api/instructor/payouts?page=1&pageSize=20&keyword=Stripe&status=succeeded&year=... (with Bearer Token)

be_ctrl->sv++:4. Call GetPayoutsAsync(..., keyword: "Stripe", status: "succeeded", ...)
sv->repo++:5. Call GetPayoutsAsync(..., keyword: "Stripe", status: "succeeded", ...)

repo->repo++:6. Construct EF Core IQueryable for InstructorPayouts
repo--

alt [keyword is not null or empty]
    repo->repo++:6.1. Apply .Where(p => p.CourseTitle.Contains(keyword) || p.StripeTransferId.Contains(keyword))
    repo--
end

alt [status is not null or empty]
    repo->repo++:7.1. Apply .Where(p => p.PayoutStatus == status)
    repo--
end

repo->ctx++:8. Query InstructorPayouts
ctx->db++:9. Execute filtered query with Skip() and Take()
db-->>ctx--:10. Return filtered payouts list and total count
ctx-->>repo--:11. Return payouts list and count

repo-->>sv--:12. Return PagedResult<InstructorPayoutDto>
sv-->>be_ctrl--:13. Return PagedResult<InstructorPayoutDto>
be_ctrl-->>fe_ctrl--:14. Return statusCode 200 (Ok) with filtered Payouts JSON

fe_ctrl-->>view--:15. Return View(vm)
view->view++:16. Re-render Payout History table
view--
view-->>act--:17. Display payout list matching criteria
@enduml
