@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Payout History
actor Instructor as act

participant "Transaction/Instructor.cshtml" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "InstructorController" as be_ctrl <<backend controller>>
participant ":InstructorService" as sv
participant ":InstructorRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Click "Payout History" tab
view->fe_ctrl++:2. Send GET /Transaction/Instructor?tab=po&payoutPage=1&payoutPageSize=20

fe_ctrl->be_ctrl++:3. Send GET /api/instructor/payouts?page=1&pageSize=20&year=... (with Bearer Token)

be_ctrl->be_ctrl++:4. Extract instructorId from claims
be_ctrl--

be_ctrl->sv++:5. Call GetPayoutsAsync(instructorId, page, pageSize, ...)
sv->repo++:6. Call GetPayoutsAsync(instructorId, page, pageSize, ...)

repo->ctx++:7. Query InstructorPayouts
ctx->db++:8. Execute SELECT query
db-->>ctx--:9. Return list of payout entries and total count
ctx-->>repo--:10. Return data

repo-->>sv--:11. Return PagedResult<InstructorPayoutDto>
sv-->>be_ctrl--:12. Return PagedResult<InstructorPayoutDto>
be_ctrl-->>fe_ctrl--:13. Return statusCode 200 (Ok) with Payouts JSON

fe_ctrl-->>view--:14. Return View(vm)
view->view++:15. Render table of Payout History
view--
view-->>act--:16. Display payout history list with pagination
@enduml
