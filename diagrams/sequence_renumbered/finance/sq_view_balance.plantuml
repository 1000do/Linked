@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Balance (Financial Overview)
actor Instructor as act

participant "Transaction/Instructor.cshtml" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "InstructorController" as inst_be_ctrl <<backend controller>>
participant "TransactionController" as tx_be_ctrl <<backend controller>>
participant ":InstructorService" as inst_sv
participant ":TransactionService" as tx_sv
participant ":AdminFinanceService" as finance_sv
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Access "Revenue & Payouts" page
view->fe_ctrl++:2. Send GET /Transaction/Instructor

note over fe_ctrl
    Calls are executed in parallel
    via Task.WhenAll()
end note

fe_ctrl->inst_be_ctrl++:3. Send GET /api/instructor/payouts?page=1&pageSize=100000 (with Year/Month)
inst_be_ctrl->inst_sv++:4. Call GetPayoutsAsync(userId, page, pageSize, ...)
inst_sv->ctx++:5. Query InstructorPayouts where InstructorId = userId
ctx->db++:6. Execute SELECT query
db-->>ctx--:7. Return payout entities
ctx-->>inst_sv--:8. Return payout entities
inst_sv-->>inst_be_ctrl--:9. Return PagedResult<InstructorPayoutDto>
inst_be_ctrl-->>fe_ctrl--:10. Return statusCode 200 (Ok) with Payouts JSON

fe_ctrl->inst_be_ctrl++:11. Send GET /api/instructor/payout-days
inst_be_ctrl->finance_sv++:12. Call GetPayoutDaysConfigAsync()
finance_sv->ctx++:13. Query PayoutDays system config
ctx->db++:14. Execute SELECT query
db-->>ctx--:15. Return payout days configuration
ctx-->>finance_sv--:16. Return config
finance_sv-->>inst_be_ctrl--:17. Return config value (e.g. "15")
inst_be_ctrl-->>fe_ctrl--:18. Return statusCode 200 (Ok) with string value

fe_ctrl->tx_be_ctrl++:19. Send GET /api/transactions/instructor/course-revenues (with Year/Month)
tx_be_ctrl->tx_sv++:20. Call GetCourseRevenuesAsync(userId, year, month)
tx_sv->ctx++:21. Query transactions and group by course
ctx->db++:22. Execute SELECT query
db-->>ctx--:23. Return course revenues list
ctx-->>tx_sv--:24. Return course revenues list
tx_sv-->>tx_be_ctrl--:25. Return List<InstructorCourseRevenueResponse>
tx_be_ctrl-->>fe_ctrl--:26. Return statusCode 200 (Ok) with Revenues JSON

fe_ctrl->fe_ctrl++:27. Calculate financial stats
fe_ctrl--

fe_ctrl->fe_ctrl++:28. Calculate Next automated transfer date
fe_ctrl--

fe_ctrl-->>view--:29. Return View(vm)
view->view++:30. Render Revenue Statistics cards
view--
view-->>act--:31. Display balances and next payout date information
@enduml
