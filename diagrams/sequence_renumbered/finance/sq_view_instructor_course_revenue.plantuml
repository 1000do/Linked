@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Instructor's Course Revenue
actor Instructor as act

participant "Transaction/Instructor.cshtml" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "TransactionController" as be_ctrl <<backend controller>>
participant ":AdminFinanceService" as sv
participant ":AdminFinanceRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Click "Course Revenues" tab
view->fe_ctrl++:2. Send GET /Transaction/Instructor?tab=cr&courseSortBy=sales_desc

fe_ctrl->be_ctrl++:3. Send GET /api/transactions/instructor/course-revenues?year=...&month=... (with Bearer Token)

be_ctrl->be_ctrl++:4. Extract instructorId from claims
be_ctrl--

be_ctrl->sv++:5. Call GetInstructorCourseRevenuesByInstructorAsync(instructorId, year, month)
sv->repo++:6. Call GetInstructorCourseRevenuesByInstructorAsync(instructorId, year, month)

repo->ctx++:7. Query Courses and aggregate Transactions
ctx->db++:8. Execute aggregation SELECT query
db-->>ctx--:9. Return aggregated course revenues list
ctx-->>repo--:10. Return data

repo-->>sv--:11. Return List<InstructorCourseRevenueResponse>
sv-->>be_ctrl--:12. Return List<InstructorCourseRevenueResponse>
be_ctrl-->>fe_ctrl--:13. Return statusCode 200 (Ok) with course revenues JSON

fe_ctrl->fe_ctrl++:14. Sort revenues list based on courseSortBy
fe_ctrl--

fe_ctrl-->>view--:15. Return View(vm)
view->view++:16. Render Course Revenues table
view--
view-->>act--:17. Display course-by-course revenue analytics
@enduml
