@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Filter Instructor's Transaction History
actor Instructor as act

participant "Transaction/Instructor.cshtml" as view
participant "TransactionController" as fe_ctrl <<frontend controller>>
participant "TransactionController" as be_ctrl <<backend controller>>
participant ":TransactionService" as sv
participant ":TransactionRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Enter search keyword, select status, and click "Filter"
view->fe_ctrl++:2. Send GET /Transaction/Instructor?tab=tx&keyword=John&status=succeeded&page=1

fe_ctrl->be_ctrl++:3. Send GET /api/transactions/instructor?page=1&pageSize=20&keyword=John&status=succeeded&year=... (with Bearer Token)

be_ctrl->sv++:4. Call GetInstructorTransactionsAsync(..., keyword: "John", status: "succeeded", ...)
sv->repo++:5. Call GetInstructorTransactionsAsync(..., keyword: "John", status: "succeeded", ...)

repo->repo++:6. Construct EF Core IQueryable for Transactions
repo--

alt [keyword is not null or empty]
    repo->repo++:6.1. Apply .Where(t => t.BuyerName.Contains(keyword) || t.CourseTitle.Contains(keyword))
    repo--
end

alt [status is not null or empty]
    repo->repo++:7.1. Apply .Where(t => t.Status == status)
    repo--
end

repo->ctx++:8. Query Transactions
ctx->db++:9. Execute filtered query with Skip() and Take()
db-->>ctx--:10. Return filtered transactions list and total count
ctx-->>repo--:11. Return transactions list and count

repo-->>sv--:12. Return (filteredList, totalCount)
sv-->>be_ctrl--:13. Return PagedResult<TransactionListDto>
be_ctrl-->>fe_ctrl--:14. Return statusCode 200 (Ok) with filtered Transactions JSON

fe_ctrl-->>view--:15. Return View(vm)
view->view++:16. Re-render purchases table
view--
view-->>act--:17. Display transaction list matching criteria
@enduml
