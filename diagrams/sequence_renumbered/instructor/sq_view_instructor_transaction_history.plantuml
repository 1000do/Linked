@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Instructor's Transaction History

actor "Instructor" as act
participant "EarningsDashboard" as view
participant "ApplicationStatusPage" as app_status_view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "TransactionController" as fe_tx_ctrl <<frontend controller>>
participant "TransactionController" as be_tx_ctrl <<backend controller>>
participant ":TransactionService" as tx_sv
participant ":PagedResult<TransactionListDto>" as dto
participant ":TransactionRepository" as tx_repo
participant ":AppDbContext" as ctx
database Database as db


act -> view++:1. Click "Revenue & Payouts" \n(or use Learner Purchases filters: keyword, status, sortBy)
view -> fe_tx_ctrl++:2. GET /Transaction/Instructor?page={p}&keyword={k}&status={s}&sortBy={sort}

fe_tx_ctrl -> fe_tx_ctrl++:3. Validate actor's authentication and authorization
fe_tx_ctrl--

alt Session Invalid
    fe_tx_ctrl -->> login_view++:3.1. Redirect to LoginPage
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_tx_ctrl -->> error_view++:3.2. Redirect to ErrorPage
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization
    fe_tx_ctrl -> fe_tx_ctrl++:3.3. Check Request.Cookies["InstructorApprovalStatus"]
    fe_tx_ctrl--
    
alt Not Approved Instructor
        fe_tx_ctrl -->> app_status_view++:3.3.1. Redirect to ApplicationStatus
        app_status_view -->> act--:3.3.1.1. Display status
else Approved Instructor
        fe_tx_ctrl -> be_tx_ctrl++:3.3.2. GET /api/transactions/instructor\n(paged for {y}, {m})
        
        be_tx_ctrl -> be_tx_ctrl++:3.3.2.1. Validate login session & Parse userId
        be_tx_ctrl--
        
alt Invalid login session
            be_tx_ctrl -->> fe_tx_ctrl:3.3.2.1.1. Return statusCode 401
            fe_tx_ctrl -->> login_view++:3.3.2.1.1.1. Redirect to LoginPage
            login_view -->> act--:3.3.2.1.1.2. Display login form
else Valid Request
            be_tx_ctrl -> tx_sv++:3.3.2.1.2. GetInstructorTransactionsAsync(...)
            tx_sv -> tx_repo++:3.3.2.1.2.1. GetInstructorTransactionsAsync(...)
            tx_repo -> ctx++:3.3.2.1.2.2. Query Transactions
            ctx -> db++:3.3.2.1.2.3. Execute SELECT
            db -->> ctx--:3.3.2.1.2.4. Return database record
            ctx -->> tx_repo--:3.3.2.1.2.5. Return list of Transaction entities
            tx_repo -->> tx_sv--:3.3.2.1.2.6. Return List
            
            tx_sv -> dto++:3.3.2.1.2.7. Map to PagedResult<TransactionListDto>
            dto -->> tx_sv--:3.3.2.1.2.8. Return PagedResult<TransactionListDto>
            
            tx_sv -->> be_tx_ctrl--:3.3.2.1.2.9. Return PagedResult<TransactionListDto>
            be_tx_ctrl -->> fe_tx_ctrl--:3.3.2.1.2.10. Return statusCode 200 (TransactionPagedVM)
            
alt Empty History (No Sales)
                fe_tx_ctrl -->> view--:3.3.2.1.2.10.1. Return View with InstructorFinancePageVM
                view -->> act--:3.3.2.1.2.10.1.1. Display empty state "No transactions yet..."
else Has Transactions
                fe_tx_ctrl -->> view--:3.3.2.1.2.10.2. Return View with InstructorFinancePageVM
                view -->> act--:3.3.2.1.2.10.2.1. Display "Learner Purchases" tab with Transaction Table\n(Date, Course/Purchaser, Net Earnings, Status, Actions)
end
end
end
end

@enduml
