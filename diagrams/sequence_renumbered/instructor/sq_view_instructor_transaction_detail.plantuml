@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Instructor's Transaction History Detail

actor Instructor as act
participant "EaringInstructorPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "InstructorTransactionDetailPage" as detail_view
participant "TransactionController" as fe_tx_ctrl <<frontend controller>>
participant ":TransactionDetailVM" as view_model
participant "TransactionController" as be_tx_ctrl <<backend controller>>
participant ":ITransactionService" as tx_sv
participant ":TransactionDetailDto" as res_dto
participant ":ITransactionRepository" as tx_repo
participant ":AppDbContext" as ctx
database Database as db

act ++

act -> view++:1. Click "View" button next to a transaction row
view -> fe_tx_ctrl++:2. GET /Transaction/InstructorDetail/{id}
view--

fe_tx_ctrl -> fe_tx_ctrl++:3. Validate actor's authentication and authorization
fe_tx_ctrl--

alt Session Invalid
    fe_tx_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act:3.1.1. Display login form
    deactivate login_view
else Unauthorized Access
    fe_tx_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act:3.2.1. Display error message
    deactivate error_view
else Valid actor's authentication and authorization
    fe_tx_ctrl -> be_tx_ctrl++:3.3. GET /api/transactions/{id}
    be_tx_ctrl -> tx_sv++:3.3.1. GetTransactionDetailAsync(id)

    tx_sv -> tx_sv++:3.3.2. Validate transaction ID
    tx_sv--

alt Invalid Transaction ID
        tx_sv -->> be_tx_ctrl:3.3.2.1. throw ArgumentException
        be_tx_ctrl -->> fe_tx_ctrl:3.3.2.1.1. Return statusCode 400
        
        fe_tx_ctrl -->> view:3.3.2.1.2. Redirect to InstructorFinancePage
        activate view
        view -->> act:3.3.2.1.3. Display error message
        deactivate view
else Valid Transaction ID
        tx_sv -> tx_repo++:3.3.2.2. GetTransactionDetailAsync(transactionId)
        tx_repo -> ctx++:3.3.2.2.1. Query Transaction by id
        ctx -> db++:3.3.2.2.2. Execute SELECT
        db -->> ctx--:3.3.2.2.3. Return data
        ctx -->> tx_repo--:3.3.2.2.4. Return mapped data
        
alt Transaction not found (Null)
            tx_repo -->> tx_sv:3.3.2.2.4.1. Return null
            tx_sv -->> be_tx_ctrl:3.3.2.2.4.1.1. Return null
            be_tx_ctrl -->> fe_tx_ctrl:3.3.2.2.4.1.2. Return statusCode 404
            
            fe_tx_ctrl -->> view:3.3.2.2.4.1.3. Redirect to InstructorFinancePage
            activate view
            view -->> act:3.3.2.2.4.1.4. Display error message
            deactivate view
else Transaction found
            tx_repo -> res_dto++:3.3.2.2.4.2. Call TransactionDetailDto()
            res_dto -->> tx_repo--:3.3.2.2.4.2.1. Return TransactionDetailDto object
            
            tx_repo -->> tx_sv--:3.3.2.2.4.2.2. Return TransactionDetailDto object
            tx_sv -->> be_tx_ctrl--:3.3.2.2.4.2.3. Return TransactionDetailDto object
            
            be_tx_ctrl -->> fe_tx_ctrl--:3.3.2.2.4.2.4. Return statusCode 200
            
            fe_tx_ctrl -> fe_tx_ctrl++:3.3.2.2.4.2.5. Deserialize JSON to TransactionDetailVM
            fe_tx_ctrl--
            
alt Invalid Transaction Data
                fe_tx_ctrl -->> view:3.3.2.2.4.2.5.1. Redirect to InstructorFinancePage
                activate view
                view -->> act:3.3.2.2.4.2.5.1.1. Display error message
                deactivate view
else Valid Transaction Data
                fe_tx_ctrl -> view_model++:3.3.2.2.4.2.5.2. Call TransactionDetailVM()
                view_model -->> fe_tx_ctrl--:3.3.2.2.4.2.5.2.1. Return TransactionDetailVM object
                
                fe_tx_ctrl -->> detail_view:3.3.2.2.4.2.5.2.2. Return View(parsed.Data)
                fe_tx_ctrl--
                activate detail_view
                detail_view -->> act--:3.3.2.2.4.2.5.2.3. Display Transaction details page
end
end
end
end

@enduml
