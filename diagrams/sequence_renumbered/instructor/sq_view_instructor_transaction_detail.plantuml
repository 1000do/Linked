@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white   
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Instructor's Transaction History Detail

actor "Instructor" as act
participant "EarningsDashboard" as view
participant "LoginPage" as login_view
participant "TransactionController" as fe_tx_ctrl <<frontend controller>>
participant "TransactionController" as be_tx_ctrl <<backend controller>>
participant ":TransactionService" as tx_sv
participant ":TransactionRepository" as tx_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
view ++

act -> view:1. Click "View" button \nnext to a transaction row
view -> fe_tx_ctrl++:2. GET /Transaction/InstructorDetail/{id}

fe_tx_ctrl -> be_tx_ctrl++:3. GET /api/transactions/{id}

alt Session Invalid / Unauthorized Access (EX-1)
    be_tx_ctrl -->> fe_tx_ctrl:3.1. Return statusCode 401
    fe_tx_ctrl -->> login_view:3.1.1. Redirect to /Account/Login
    activate login_view
    login_view -->> act:3.1.2. Display Login page
    deactivate login_view
else Authorized
    be_tx_ctrl -> tx_sv++:3.2. GetTransactionDetailAsync(id)
    tx_sv -> tx_repo++:3.2.1. GetTransactionDetailAsync(id)
    tx_repo -> ctx++:3.2.2. Query Transaction by id
    ctx -> db++:3.2.3. Execute SELECT
    db -->> ctx--:3.2.4. Transaction Data
    
alt Transaction Not Found (EX-5)
        ctx -->> tx_repo:3.2.4.1. null
        tx_repo -->> tx_sv:3.2.4.1.1. null
        tx_sv -->> be_tx_ctrl:3.2.4.1.2. null
        be_tx_ctrl -->> fe_tx_ctrl:3.2.4.1.3. Return statusCode 404
        fe_tx_ctrl -->> view:3.2.4.1.4. Redirect to Earnings Dashboard \nwith Error message
        view -->> act:3.2.4.1.5. Display warning message regarding transaction not found
else Transaction Found
        ctx -->> tx_repo--:3.2.4.2. Transaction Entity
        tx_repo -->> tx_sv--:3.2.4.2.1. Return TransactionDetailDto
        tx_sv -->> be_tx_ctrl--:3.2.4.2.2. Return TransactionDetailDto
        be_tx_ctrl -->> fe_tx_ctrl--:3.2.4.2.3. Return statusCode 200 (TransactionDetailVM)
        
        fe_tx_ctrl -> fe_tx_ctrl:3.2.4.2.4. Check Transaction Ownership (EX-5.2)
alt Unauthorized Transaction Access (EX-5.2)
            fe_tx_ctrl -->> view:3.2.4.2.4.1. Redirect to Earnings Dashboard \nwith Authorization error
            view -->> act:3.2.4.2.4.1.1. Display authorization error message
else Authorized Access
alt Refund Request Pending (A.7.1)
                fe_tx_ctrl -->> view:3.2.4.2.4.2.1. Return View with TransactionDetailVM (Pending)
                view -->> act:3.2.4.2.4.2.1.1. Display top warning banner (Refund Request Pending)
else Refund Approved (A.7.2)
                fe_tx_ctrl -->> view:3.2.4.2.4.2.2. Return View with TransactionDetailVM (Refunded)
                view -->> act:3.2.4.2.4.2.2.1. Display top alert banner (Refund Approved) & \nhighlight negative deductions in Split Summary Card
else Refund Request Rejected (A.7.3)
                fe_tx_ctrl -->> view:3.2.4.2.4.2.3. Return View with TransactionDetailVM (Completed + Note)
                view -->> act:3.2.4.2.4.2.3.1. Display top informational banner (Refund Rejected)
else Normal Transaction
                fe_tx_ctrl -->> view--:3.2.4.2.4.2.4. Return View with TransactionDetailVM
                view -->> act--:3.2.4.2.4.2.4.1. Display Transaction details page\n(Overview, Product, Purchaser, Stripe refs, Split Summary)
end
end
end
end

@enduml
