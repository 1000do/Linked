@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Mark As Read (User/Instructor)

actor User as act
participant "NotificationPage" as view
participant "NotificationController" as fe_ctrl <<frontend controller>>
participant "NotificationController" as be_ctrl <<backend controller>>
participant ":INotificationService" as sv
participant ":INotificationRepository" as repo
participant ":AppDbContext" as ctx
database Database as db
participant "NotificationHub" as hub

act++
act->view++:1. Click "Mark as read" button on notification
view->fe_ctrl++:2. Send PUT /Notification/MarkAsRead/{id}
fe_ctrl->be_ctrl++:3. Send PUT /api/Notification/mark-as-read/{id} (with Bearer Token)

be_ctrl->sv++:4. Call MarkAsReadAsync(id, userId)
sv->repo++:5. Call GetByIdAsync(id)
repo->ctx++:6. Call GetByIdAsync(id)
ctx->db++:7. Execute SELECT query
db-->>ctx--:8. Return notification entity
ctx-->>repo--:9. Return notification entity
repo-->>sv--:10. Return notification entity

alt [notification == null || notification.ReceiverId != userId]
    sv-->>be_ctrl:10.1. throw KeyNotFoundException
    be_ctrl-->>fe_ctrl:10.1.1. Return statusCode 404 (NotFound)
    fe_ctrl-->>view:10.1.2. Return JSON error response
    view-->>act:10.1.3. Display error message
else [notification exists and belongs to user]
    sv->repo++:10.2. Call Update(noti)
    repo->ctx++:10.2.1. Update notification entity state
    ctx-->>repo--:10.2.2. Return
    repo-->>sv--:10.2.3. Return
    
    sv->repo++:10.2.4. Call SaveChangesAsync()
    repo->ctx++:10.2.5. Call SaveChangesAsync()
    ctx->db++:10.2.6. Execute UPDATE statement
    
alt [Database Save Fails (throws DbUpdateException)]
        db-->>ctx:10.2.6.1. Throw DbUpdateException
        ctx-->>repo:10.2.6.1.1. Throw DbUpdateException
        repo-->>sv:10.2.6.1.2. Throw NotificationException
        sv-->>be_ctrl:10.2.6.1.3. Throw BadRequestException
        be_ctrl-->>fe_ctrl:10.2.6.1.4. Return statusCode 400 (BadRequest)
        fe_ctrl-->>view:10.2.6.1.5. Return JSON error response
        view-->>act:10.2.6.1.6. Display error message
else [Database Save Succeeds]
        db-->>ctx--:10.2.6.2. Return result
        ctx-->>repo--:10.2.6.2.1. Return result
        repo-->>sv--:10.2.6.2.2. Return result
        
        sv->hub++:10.2.6.2.3. Call Clients.All.SendAsync("ReceiveNotification")
        hub-->>sv:10.2.6.2.4. Broadcast notification via SignalR
        hub--
        
        sv-->>be_ctrl--:10.2.6.2.5. Return true
        be_ctrl-->>fe_ctrl--:10.2.6.2.6. Return statusCode 200 (Ok)
        fe_ctrl-->>view--:10.2.6.2.7. Return JSON success response
        view->view++:10.2.6.2.8. Update local notification state to read
        view--
        view-->>act--:10.2.6.2.9. Update notification UI to show as read
end
end

@enduml
