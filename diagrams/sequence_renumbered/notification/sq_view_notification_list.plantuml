@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Notification List (User/Instructor)

actor User as act
participant "NotificationPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "NotificationController" as fe_ctrl <<frontend controller>>
participant "NotificationController" as be_ctrl <<backend controller>>
participant ":INotificationService" as sv
participant ":INotificationRepository" as repo
participant ":NotificationResponseDto" as notif_dto
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Access "My Notifications" page
view->fe_ctrl++:2. GET /Notification/Index

fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization
    fe_ctrl->be_ctrl++:3.3. GET /api/Notification
    
    be_ctrl->sv++:3.3.1. Call GetNotificationsForUserAsync(userId, page, pageSize)
    sv->repo++:3.3.2. Call GetByReceiverIdAsync(userId, page, pageSize)
    repo->ctx++:3.3.3. Query notifications by receiverId
    ctx->db++:3.3.4. Execute SELECT query
    db-->>ctx--:3.3.5. Return notification list
    ctx-->>repo--:3.3.6. Return notification list & count
    repo-->>sv--:3.3.7. Return notification list & count
    
alt Notifications exist
        sv->notif_dto++:3.3.7.1. Call NotificationResponseDto()
        notif_dto-->>sv--:3.3.7.1.1. Return NotificationResponseDto list
        sv-->>be_ctrl:3.3.7.1.2. Return PagedResult<NotificationResponseDto>
        be_ctrl-->>fe_ctrl:3.3.7.1.3. Return statusCode 200
        fe_ctrl-->>view:3.3.7.1.4. Return View(viewModel)
        view-->>act:3.3.7.1.5. Display notification list
else No notifications found
        sv-->>be_ctrl--:3.3.7.2. throw KeyNotFoundException
        be_ctrl-->>fe_ctrl--:3.3.7.2.1. Return statusCode 200
        fe_ctrl-->>view--:3.3.7.2.2. Return View(emptyList)
        view-->>act--:3.3.7.2.3. Display empty list message
end
end

@enduml
