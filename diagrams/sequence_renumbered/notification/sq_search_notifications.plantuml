@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Search Notifications (Staff/Admin)

actor Admin as act
participant "NotificationManagementPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_page
participant "NotificationController" as fe_ctrl <<frontend controller>>
participant "NotificationHub" as hub
participant "NotificationController" as be_ctrl <<backend controller>>
participant ":INotificationService" as sv
participant ":INotificationRepository" as repo
participant ":NotificationAdminResponseDto" as notif_admin_dto
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Access System Notifications page
view->fe_ctrl++:2. GET /Notification/Admin
fe_ctrl-->>view--:3. Return Admin View

view->hub++:4. Start SignalR connection to /notificationHub
hub-->>view:5. Connection established successfully

view->fe_ctrl++:6. GET /Notification/GetAllAdmin

fe_ctrl -> fe_ctrl++:7. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:7.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:7.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_page:7.2. Redirect to ErrorPage
    activate error_page
    error_page -->> act--:7.2.1. Display error message
else Valid actor's authentication and authorization
    fe_ctrl->be_ctrl++:7.3. GET /api/Notification/all
    
    be_ctrl->sv++:7.3.1. Call GetAllNotificationsForAdminAsync()
    
    sv->repo++:7.3.2. Call AutoCleanupAdminNotificationsAsync()
    repo->ctx++:7.3.3. Query old read notifications (> 90 days)
    ctx->db++:7.3.4. Execute SELECT query
    db-->>ctx--:7.3.5. Return old notifications list
    ctx-->>repo--:7.3.6. Return old notifications list
    
opt Old notifications exist
        repo->ctx++:7.3.6.1. Mark IsRemoved = true for old notifications
        ctx-->>repo--:7.3.6.1.1. Return
        repo->ctx++:7.3.6.1.2. Call SaveChangesAsync()
        ctx->db++:7.3.6.1.3. Save changes to database (Execute UPDATE)
        db-->>ctx--:7.3.6.1.4. Return numberOfRowsAffected
        ctx-->>repo--:7.3.6.1.5. Return numberOfRowsAffected
end
    repo-->>sv--:7.3.7. Return result
    
    sv->repo++:7.3.8. Call GetAllAsync()
    repo->ctx++:7.3.9. Query active notifications
    ctx->db++:7.3.10. Execute SELECT query
    db-->>ctx--:7.3.11. Return active notifications list
    ctx-->>repo--:7.3.12. Return active notifications list
    repo-->>sv--:7.3.13. Return active notifications list
    
    sv->notif_admin_dto++:7.3.14. Call NotificationAdminResponseDto()
    notif_admin_dto-->>sv--:7.3.15. Return NotificationAdminResponseDto list
    
    sv-->>be_ctrl--:7.3.16. Return PagedResult<NotificationAdminResponseDto>
    be_ctrl-->>fe_ctrl--:7.3.17. Return statusCode 200 (Ok)
    fe_ctrl-->>view--:7.3.18. Return JSON notifications list
    
    view->view++:7.3.19. Apply default filters and sorting
    view--
    view->view++:7.3.20. Render notifications in table
    view--
    
    view-->>act:7.3.21. Display system notifications list

    act->view++:7.3.22. Enter keyword in search input field
    view->view++:7.3.23. EventListener: input event triggered
    view--
    
    view->view++:7.3.24. applyFilters() (runs client-side search on cached notifications)

    view--
    
    view->view++:7.3.25. renderTable() (paginates and renders matching results)
    view--
    
    view-->>act--:7.3.26. Display filtered notification list matching search criteria
end

@enduml
