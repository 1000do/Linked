@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Cancel Coupon
actor User as act

participant "CartView" as view
participant "CartController" as fe_ctrl <<frontend controller>>
participant "CartController" as be_ctrl <<backend controller>>
participant ":CartSummaryResponseDTO" as res
participant ":CartViewModel" as vm
participant ":ICartService" as sv
participant ":ICartRepository" as cart_repo
participant ":ICouponRepository" as coupon_repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Click "Cancel" / "Remove Coupon" button
view->fe_ctrl++:2. POST /Cart/RemoveCoupon

fe_ctrl->fe_ctrl++:3. Retrieve applied coupon map from cookies
fe_ctrl--
fe_ctrl->fe_ctrl++:4. Remove coupon entry from cookie map
fe_ctrl--
fe_ctrl->fe_ctrl++:5. Set success message
fe_ctrl--

fe_ctrl-->>view--:6. Return statusCode 302
view->fe_ctrl++:7. GET /Cart

fe_ctrl->be_ctrl++:8. GET /api/cart/summary

be_ctrl->sv++:9. Call GetCartSummaryAsync(userId, couponCode)

sv->cart_repo++:10. Call GetCartItemsWithDetailsAsync(userId)
cart_repo->ctx++:11. Query CartItems and Course details
ctx->db++:12. Execute query
db-->>ctx--:13. Return result
ctx-->>cart_repo--:14. Return list
cart_repo-->>sv--:15. Return list

sv->sv++:16. Re-calculate totals based on remaining coupons
sv--

sv->coupon_repo++:17. Call GetActiveAvailableCouponsAsync(now)
coupon_repo->ctx++:18. Query active coupons
ctx->db++:19. Execute query
db-->>ctx--:20. Return result
ctx-->>coupon_repo--:21. Return list
coupon_repo-->>sv--:22. Return list

sv->res++:23. Call CartSummaryResponseDTO()
res-->>sv--:24. Return CartSummaryResponseDTO object

sv-->>be_ctrl--:25. Return CartSummaryResponseDTO object
be_ctrl-->>fe_ctrl--:26. Return statusCode 200

fe_ctrl->vm++:27. Call CartViewModel()
vm-->>fe_ctrl--:28. Return CartViewModel object

fe_ctrl->fe_ctrl++:29. Map to CartViewModel
fe_ctrl--

fe_ctrl-->>view--:30. Return statusCode 200
view-->>act--:31. Display cart items with original prices and cleared coupon input
@enduml
