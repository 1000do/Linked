@startuml view_course_review_reports
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View List of Course Review Reports
actor Staff as act

participant "CourseReviewReportListView" as view
participant "AdminModerationController" as be_ctrl
participant ":ReportService" as sv
participant ":ReportRepository" as repo
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++:1. Access "Course Review Reports" page
view->be_ctrl++:2. GET /admin/moderation/reports/course-reviews?page={page}&pageSize={size}
be_ctrl->sv++:3. GetAllCourseReviewReportsAsync(status, page, pageSize)
sv->repo++:4. GetAllCourseReviewReportsAsync(status, page, pageSize)
repo->ctx++:5. Query CourseReviewReport entities
ctx->db++:6. Execute SQL query
db-->>ctx:7. Return result set
ctx-->>repo:8. (reports, totalCount)
repo-->>sv:9. (reports, totalCount)
sv-->>be_ctrl:10. PagedResult<CourseReviewReportDetailResponse>
be_ctrl-->>view:11. JSON payload
view-->>act:12. Render list UI
act--
@enduml
