@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Forget Password

actor "User/Instructor" as act
participant "ForgotPasswordView" as view
participant "VerifyOtpView" as otp_view
participant "ResetPasswordView" as reset_view
participant "LoginView" as login_view
participant "AccountController" as fe_ctrl <<frontend controller>>
participant "AuthController" as be_ctrl <<backend controller>>
participant ":VerifyOtpRequestDTO" as verify_req
participant ":ResetPasswordRequestDTO" as reset_req
participant ":IAuthService" as sv
participant ":IUserRepository" as u_repo
participant ":IOtpService" as otp_sv
participant ":IEmailService" as email_sv
participant ":AppDbContext" as ctx
database Database as db

act++


act->view++:1. Enter email and click "Submit"
view->fe_ctrl++:2. POST /Account/ForgotPassword

fe_ctrl->be_ctrl++:3. POST /api/auth/forgot-password

be_ctrl->sv++:4. Call ForgotPasswordAsync(email)
sv->u_repo++:5. Call GetAccountByEmailAsync(email)
u_repo->ctx++:6. Query Account
ctx->db++:7. Execute query
db-->>ctx--:8. Return result
ctx-->>u_repo--:9. Return account
u_repo-->>sv--:10. Return account

sv->sv++:11. Validate account
sv--

alt Account not found or invalid
    sv-->>be_ctrl:11.1. Return "Account not found"
    be_ctrl-->>fe_ctrl:11.1.1. Return statusCode 400
    fe_ctrl-->>view:11.1.2. Return statusCode 400
    view-->>act:11.1.3. Display error message
else Valid account
    sv->otp_sv++:11.2. Call GenerateOtp(email, "reset")
    otp_sv->otp_sv++:11.2.1. Store OTP in MemoryCache (2 mins)
    otp_sv--
    otp_sv-->>sv--:11.2.2. Return generated OTP
    
    sv->email_sv++:11.2.3. Call SendEmailAsync(email, subject, body)
    email_sv-->>sv--:11.2.4. Return success
    
    sv-->>be_ctrl--:11.2.5. Return "OTP sent"
    be_ctrl-->>fe_ctrl--:11.2.6. Return statusCode 200
    
    deactivate view
    fe_ctrl -->> otp_view--:11.2.7. Redirect to Verify OTP page
    activate otp_view
    otp_view -->> act--:11.2.8. Display OTP input form
end


act->otp_view++:12. Enter OTP and click "Verify"
otp_view->fe_ctrl++:13. POST /Account/VerifyOtp

fe_ctrl->be_ctrl++:14. POST /api/auth/verify-otp

be_ctrl->verify_req++:15. Call VerifyOtpRequestDTO()
verify_req-->>be_ctrl--:16. Return VerifyOtpRequestDTO object

be_ctrl->sv++:17. Call VerifyOtpForReset(verify_req.Email, verify_req.Otp)
sv->otp_sv++:18. Call ValidateOtp(email, otp, "reset")
otp_sv-->>sv--:19. Return isValid (true/false)

sv->sv++:20. Validate OTP
sv--

alt OTP invalid or expired
    sv-->>be_ctrl:20.1. Return false
    be_ctrl-->>fe_ctrl:20.1.1. Return statusCode 400
    fe_ctrl-->>otp_view:20.1.2. Return statusCode 400
    otp_view-->>act:20.1.3. Display error message
else OTP is valid
    sv-->>be_ctrl--:20.2. Return true
    be_ctrl-->>fe_ctrl--:20.2.1. Return statusCode 200
    
    deactivate otp_view
    fe_ctrl -->> reset_view--:20.2.2. Redirect to Reset Password page
    activate reset_view
    reset_view -->> act--:20.2.3. Display Reset Password form
end


act->reset_view++:21. Enter new password and click "Reset"
reset_view->fe_ctrl++:22. POST /Account/ResetPassword

fe_ctrl->be_ctrl++:23. POST /api/auth/reset-password

be_ctrl->reset_req++:24. Call ResetPasswordRequestDTO()
reset_req-->>be_ctrl--:25. Return ResetPasswordRequestDTO object

be_ctrl->sv++:26. Call ResetPasswordAsync(reset_req.Email, reset_req.Otp, reset_req.NewPassword)
sv->otp_sv++:27. Call ConsumeOtp(email, otp, "reset")
otp_sv->otp_sv++:28. Remove OTP from MemoryCache
otp_sv--
otp_sv-->>sv--:29. Return isValid (true/false)

sv->sv++:30. Validate OTP
sv--

alt OTP is invalid/expired
    sv-->>be_ctrl:30.1. Return false
    be_ctrl-->>fe_ctrl:30.1.1. Return statusCode 400
    fe_ctrl-->>reset_view:30.1.2. Return statusCode 400
    reset_view-->>act:30.1.3. Display error message
else OTP is valid
    sv->u_repo++:30.2. Call GetAccountByEmailAsync(email)
    u_repo->ctx++:30.2.1. Query Account
    ctx->db++:30.2.2. Execute query
    db-->>ctx--:30.2.3. Return result
    ctx-->>u_repo--:30.2.4. Return account
    u_repo-->>sv--:30.2.5. Return account
    
    sv->sv++:30.2.6. Hash new password
    sv--
    
    sv->u_repo++:30.2.7. Call UpdateAccountAsync(acc)
    u_repo->ctx++:30.2.8. Update PasswordHash
    ctx-->>u_repo--:30.2.9. Return result
    
    u_repo->ctx++:30.2.10. Call SaveChangesAsync()
    ctx->db++:30.2.11. Save changes to database
    
alt Database Save Failure
        db -->> ctx:30.2.11.1. throw DbUpdateException
        ctx -->> u_repo:30.2.11.1.1. throw DbUpdateException
        u_repo -->> sv:30.2.11.1.2. throw DatabaseException
        sv -->> be_ctrl:30.2.11.1.3. throw BadRequestException
        be_ctrl -->> fe_ctrl:30.2.11.1.4. Return statusCode 400
        fe_ctrl -->> reset_view:30.2.11.1.5. Return statusCode 400
        reset_view -->> act:30.2.11.1.6. Display error message
else Database Save Success
        db -->> ctx--:30.2.11.2. Return numberOfRowsAffected
        ctx -->> u_repo--:30.2.11.2.1. Return numberOfRowsAffected
        u_repo -->> sv--:30.2.11.2.2. Return numberOfRowsAffected
        
        sv -->> be_ctrl--:30.2.11.2.3. Return true
        be_ctrl -->> fe_ctrl--:30.2.11.2.4. Return statusCode 200
        
        deactivate reset_view
        fe_ctrl -->> login_view--:30.2.11.2.5. Redirect to Login page
        activate login_view
        login_view -->> act--:30.2.11.2.6. Display Login page with success message
end
end
@enduml
