@startuml 
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Login with Google
actor "User/Instructor" as act

participant "LoginView" as view
participant "AdminNotificationView" as admin_view
participant "HomeIndexView" as home_view
participant "Google Identity" as Google
participant "AccountController" as fe_ctrl <<frontend controller>>
participant "AuthController" as be_ctrl <<backend controller>>
participant ":GoogleLoginRequestDTO" as req
participant ":LoginResponseDTO" as res
participant ":IAuthService" as sv
participant ":Account" as acc_ett
participant ":User" as user_ett
participant ":IUserRepository" as u_repo
participant ":ILockoutRepository" as lock_repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Click "Sign in with Google" button
view->Google++:2. Request Google Authentication
Google-->>view--:3. Return Google IdToken

view->fe_ctrl++:4. POST /Account/GoogleLogin

fe_ctrl->be_ctrl++:5. POST /api/auth/google-login

be_ctrl->req++:6. Call GoogleLoginRequestDTO()
req-->>be_ctrl--:7. Return GoogleLoginRequestDTO object

be_ctrl->sv++:8. Call GoogleLoginAsync(req.IdToken)

sv->Google++:9. Validate IdToken signature
Google-->>sv--:10. Return payload

sv->u_repo++:11. Call GetAccountByEmailAsync(email)
u_repo->ctx++:12. Query Account
ctx->db++:13. Execute query
db-->>ctx--:14. Return result
ctx-->>u_repo--:15. Return account
u_repo-->>sv--:16. Return account

sv->sv++:17. Check account
sv--

opt account == null
    sv->acc_ett++:17.1. Call Account()
    acc_ett-->>sv--:17.1.1. Return Account entity
    
    sv->user_ett++:17.1.2. Call User()
    user_ett-->>sv--:17.1.3. Return User entity
    
    sv->u_repo++:17.1.4. Call RegisterUserAsync(acc, user)
    u_repo->ctx++:17.1.5. Add Account and User entities
    ctx-->>u_repo--:17.1.6. Return result
    
    u_repo->ctx++:17.1.7. Call SaveChangesAsync()
    ctx->db++:17.1.8. Save changes to database
    db-->>ctx--:17.1.9. Return numberOfRowsAffected
    ctx-->>u_repo--:17.1.10. Return numberOfRowsAffected
    u_repo-->>sv--:17.1.11. Return isCreated
    
    sv->u_repo++:17.1.12. Call GetAccountByEmailAsync(email)
    u_repo->ctx++:17.1.13. Query Account
    ctx->db++:17.1.14. Execute query
    db-->>ctx--:17.1.15. Return result
    ctx-->>u_repo--:17.1.16. Return account
    u_repo-->>sv--:17.1.17. Return account
end

sv->lock_repo++:18. Call GetActiveLockoutAsync(accountId, "account")
lock_repo->ctx++:19. Query active lockout
ctx->db++:20. Execute query
db-->>ctx--:21. Return result
ctx-->>lock_repo--:22. Return lockout
lock_repo-->>sv--:23. Return activeLockout

sv->sv++:24. Check activeLockout
sv--

alt Account is locked out
    sv-->>be_ctrl:24.1. throw UnauthorizedAccessException
    be_ctrl-->>fe_ctrl:24.1.1. Return statusCode 403
    fe_ctrl-->>view:24.1.2. Return statusCode 403
    view-->>act:24.1.3. Display error message
else Account is active
    sv->u_repo++:24.2. Call UpdateLastLoginAsync(accountId)
    u_repo->ctx++:24.2.1. Update LastLoginDate
    ctx-->>u_repo--:24.2.2. Return result
    
    u_repo->ctx++:24.2.3. Call SaveChangesAsync()
    ctx->db++:24.2.4. Save changes to database
    db-->>ctx--:24.2.5. Return numberOfRowsAffected
    ctx-->>u_repo--:24.2.6. Return numberOfRowsAffected
    u_repo-->>sv--:24.2.7. Return result
    
    sv->u_repo++:24.2.8. Call GetRoleByAccountIdAsync(accountId)
    u_repo->ctx++:24.2.9. Query Role
    ctx->db++:24.2.10. Execute query
    db-->>ctx--:24.2.11. Return result
    ctx-->>u_repo--:24.2.12. Return role
    u_repo-->>sv--:24.2.13. Return role
    
    sv->sv++:24.2.14. Generate JWT tokens
    sv--
    
    sv->u_repo++:24.2.15. Call SaveRefreshTokenAsync(accountId, refreshToken)
    u_repo->ctx++:24.2.16. Update RefreshToken
    ctx-->>u_repo--:24.2.17. Return result
    
    u_repo->ctx++:24.2.18. Call SaveChangesAsync()
    ctx->db++:24.2.19. Save changes to database
    db-->>ctx--:24.2.20. Return numberOfRowsAffected
    ctx-->>u_repo--:24.2.21. Return numberOfRowsAffected
    u_repo-->>sv--:24.2.22. Return result
    
    sv->res++:24.2.23. Call LoginResponseDTO()
    res-->>sv--:24.2.24. Return LoginResponseDTO object
    
    sv-->>be_ctrl--:24.2.25. Return LoginResponseDTO object
    
    be_ctrl-->>fe_ctrl--:24.2.26. Return statusCode 200
    
    fe_ctrl->fe_ctrl++:24.2.27. Append HttpOnly cookies and user info cookies
    fe_ctrl--
    
    fe_ctrl-->>view--:24.2.28. Return statusCode 200
    
    view->view++:24.2.29. Check user role from cookies
    view--
    
alt role == admin or staff
        view -->> admin_view--:24.2.29.1. Redirect to Admin Notification page
        activate admin_view
        admin_view -->> act--:24.2.29.1.1. Display Admin Notification page
else role == user or instructor
        view -->> home_view--:24.2.29.2. Redirect to Home Index page
        activate home_view
        home_view -->> act--:24.2.29.2.1. Display Homepage
end
end
@enduml
