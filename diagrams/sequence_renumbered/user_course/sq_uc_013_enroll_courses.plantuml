@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Enroll Free Course

actor User as act
participant "CourseDetailPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "EnrollmentController" as be_ctrl <<backend controller>>
participant ":EnrollmentService" as sv
participant ":IAuthService" as auth_sv
participant ":INotificationService" as notif_sv
participant ":Enrollment" as ett
participant ":IEnrollmentRepository" as repo
participant ":ICourseRepository" as course_repo
participant ":IUserRepository" as user_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click "Enroll for Free"
view -> fe_ctrl++:2. POST /Course/EnrollFree/{courseId}

fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization
    fe_ctrl -> be_ctrl++:3.3. POST /api/enrollment/free-enroll/{courseId}
    
    be_ctrl -> auth_sv++:3.3.1. Call IsEmailVerifiedAsync(userId)
    auth_sv -->> be_ctrl--:3.3.2. Return IsEmailVerified flag
    
alt Email Not Verified
        be_ctrl -->> fe_ctrl:3.3.2.1. Return statusCode 400
        fe_ctrl -->> view:3.3.2.1.1. Return JSON (success=false)
        view -->> act:3.3.2.1.2. Display email verification required message
else Email Verified
        be_ctrl -> sv++:3.3.2.2. Call EnrollFreeAsync(userId, courseId)
        
        sv -> course_repo++:3.3.2.2.1. Call GetByIdAsync(courseId)
        course_repo -->> sv--:3.3.2.2.2. Return course entity
        
alt Course Not Found, Not Published, Paid, or Owned By User
            sv -->> be_ctrl:3.3.2.2.2.1. throw InvalidOperationException
            be_ctrl -->> fe_ctrl:3.3.2.2.2.1.1. Return statusCode 400
            fe_ctrl -->> view:3.3.2.2.2.1.2. Return JSON (success=false)
            view -->> act:3.3.2.2.2.1.3. Display enrollment error message
else Valid Course
            sv -> course_repo++:3.3.2.2.2.2. Call IsEnrolledAsync(userId, courseId)
            course_repo -->> sv--:3.3.2.2.2.2.1. Return IsEnrolled flag
            
alt Already Enrolled
                sv -->> be_ctrl:3.3.2.2.2.2.1.1. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:3.3.2.2.2.2.1.1.1. Return statusCode 400
                fe_ctrl -->> view:3.3.2.2.2.2.1.1.2. Return JSON (success=false)
                view -->> act:3.3.2.2.2.2.1.1.3. Display already enrolled message
else Not Enrolled
                sv -> repo++:3.3.2.2.2.2.1.2. Call BeginTransactionAsync()
                repo -->> sv--:3.3.2.2.2.2.1.2.1. Return transaction
                
                sv -> ett++:3.3.2.2.2.2.1.2.2. Call Enrollment()
                ett -->> sv--:3.3.2.2.2.2.1.2.3. Return Enrollment entity
                
                sv -> repo++:3.3.2.2.2.2.1.2.4. Call AddEnrollmentAsync(enrollment)
                repo -->> sv--:3.3.2.2.2.2.1.2.5. Return result
                
                sv -> repo++:3.3.2.2.2.2.1.2.6. Call SaveChangesAsync()
                repo -> ctx++:3.3.2.2.2.2.1.2.7. Save changes to database
                ctx -> db++:3.3.2.2.2.2.1.2.8. Insert Enrollment
                
alt Database Save Failure
                    db -->> ctx:3.3.2.2.2.2.1.2.8.1. throw DbUpdateException
                    ctx -->> repo:3.3.2.2.2.2.1.2.8.1.1. throw DbUpdateException
                    repo -->> sv:3.3.2.2.2.2.1.2.8.1.2. throw DbUpdateException
                    sv -->> be_ctrl:3.3.2.2.2.2.1.2.8.1.3. throw DbUpdateException
                    be_ctrl -->> fe_ctrl:3.3.2.2.2.2.1.2.8.1.4. Return statusCode 500
                    fe_ctrl -->> view:3.3.2.2.2.2.1.2.8.1.5. Return JSON (success=false)
                    view -->> act:3.3.2.2.2.2.1.2.8.1.6. Display server error message
else Database Save Success
                    db -->> ctx--:3.3.2.2.2.2.1.2.8.2. Return returnCode
                    ctx -->> repo--:3.3.2.2.2.2.1.2.8.2.1. Return numberOfRowsAffected
                    repo -->> sv--:3.3.2.2.2.2.1.2.8.2.2. Return numberOfRowsAffected
                    
                    sv -> repo++:3.3.2.2.2.2.1.2.8.2.3. Call CommitAsync()
                    repo -->> sv--:3.3.2.2.2.2.1.2.8.2.4. Return result
                    
opt course has Instructor
                        sv -> user_repo++:3.3.2.2.2.2.1.2.8.2.4.1. Call GetUserByIdAsync(userId)
                        user_repo -->> sv--:3.3.2.2.2.2.1.2.8.2.4.1.1. Return student entity
                        sv -> notif_sv++:3.3.2.2.2.2.1.2.8.2.4.1.2. Call SendNotificationAsync(InstructorId, content)
                        notif_sv -->> sv--:3.3.2.2.2.2.1.2.8.2.4.1.3. Return result
end
                    
                    sv -->> be_ctrl--:3.3.2.2.2.2.1.2.8.2.5. Return result
                    be_ctrl -->> fe_ctrl--:3.3.2.2.2.2.1.2.8.2.6. Return statusCode 200
                    fe_ctrl -->> view--:3.3.2.2.2.2.1.2.8.2.7. Return JSON (success=true)
                    view -->> act--:3.3.2.2.2.2.1.2.8.2.8. Display enrollment success message
end
end
end
end
end
