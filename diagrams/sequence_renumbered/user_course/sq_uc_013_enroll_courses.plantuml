@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Enroll Free Course

actor User as act
participant "CourseDetailPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "EnrollmentController" as be_ctrl <<backend controller>>
participant ":EnrollmentService" as sv
participant ":IAuthService" as auth_sv
participant ":INotificationService" as notif_sv
participant ":Enrollment" as ett
participant ":IEnrollmentRepository" as repo
participant ":ICourseRepository" as course_repo
participant ":IUserRepository" as user_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click "Enroll for Free"
view -> fe_ctrl++:2. POST /Course/EnrollFree/{courseId}

fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization
    fe_ctrl -> be_ctrl++:3.3. POST /api/enrollment/free-enroll/{courseId}
    
    be_ctrl -> auth_sv++:3.3.1. Call IsEmailVerifiedAsync(userId)
    auth_sv -->> be_ctrl--:3.3.2. Return IsEmailVerified flag
    
alt Email Not Verified
        be_ctrl -->> fe_ctrl:3.3.2.1. Return statusCode 400
        fe_ctrl -->> view:3.3.2.1.1. Return JSON (success=false)
        view -->> act:3.3.2.1.2. Display email verification required message
else Email Verified
        be_ctrl -> sv++:3.3.2.2. Call EnrollFreeAsync(userId, courseId)
        
        sv -> course_repo++:3.3.2.2.1. Call GetByIdAsync(courseId)
        course_repo -> ctx++:3.3.2.2.2. Execute query
        ctx -> db++:3.3.2.2.3. Fetch course
        db -->> ctx--:3.3.2.2.4. Return query results
        ctx -->> course_repo--:3.3.2.2.5. Return course entity
        course_repo -->> sv--:3.3.2.2.6. Return course entity
        
alt Course == null OR CourseStatus != Published OR Price > 0 OR InstructorId == userId
            sv -->> be_ctrl:3.3.2.2.6.1. throw InvalidOperationException
            be_ctrl -->> fe_ctrl:3.3.2.2.6.1.1. Return statusCode 400
            fe_ctrl -->> view:3.3.2.2.6.1.2. Return JSON (success=false)
            view -->> act:3.3.2.2.6.1.3. Display enrollment error message
else Valid Course
            sv -> course_repo++:3.3.2.2.6.2. Call IsEnrolledAsync(userId, courseId)
            course_repo -> ctx++:3.3.2.2.6.2.1. Execute query
            ctx -> db++:3.3.2.2.6.2.2. Check enrollment
            db -->> ctx--:3.3.2.2.6.2.3. Return query results
            ctx -->> course_repo--:3.3.2.2.6.2.4. Return IsEnrolled flag
            course_repo -->> sv--:3.3.2.2.6.2.5. Return IsEnrolled flag
            
alt Already Enrolled
                sv -->> be_ctrl:3.3.2.2.6.2.5.1. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:3.3.2.2.6.2.5.1.1. Return statusCode 400
                fe_ctrl -->> view:3.3.2.2.6.2.5.1.2. Return JSON (success=false)
                view -->> act:3.3.2.2.6.2.5.1.3. Display already enrolled message
else Not Enrolled
                sv -> repo++:3.3.2.2.6.2.5.2. Call BeginTransactionAsync()
                repo -> ctx++:3.3.2.2.6.2.5.2.1. Begin transaction
                ctx -> db++:3.3.2.2.6.2.5.2.2. Begin db transaction
                db -->> ctx--:3.3.2.2.6.2.5.2.3. Return result
                ctx -->> repo--:3.3.2.2.6.2.5.2.4. Return transaction
                repo -->> sv--:3.3.2.2.6.2.5.2.5. Return transaction
                
                sv -> ett++:3.3.2.2.6.2.5.2.6. Call Enrollment()
                ett -->> sv--:3.3.2.2.6.2.5.2.7. Return Enrollment entity
                
                sv -> repo++:3.3.2.2.6.2.5.2.8. Call AddEnrollmentAsync(enrollment)
                repo -> ctx++:3.3.2.2.6.2.5.2.9. Add entity
                ctx -->> repo--:3.3.2.2.6.2.5.2.10. Return
                repo -->> sv--:3.3.2.2.6.2.5.2.11. Return result
                
                sv -> repo++:3.3.2.2.6.2.5.2.12. Call SaveChangesAsync()
                repo -> ctx++:3.3.2.2.6.2.5.2.13. Save changes to database
                ctx -> db++:3.3.2.2.6.2.5.2.14. Insert Enrollment
                
alt Database Save Failure
                    db -->> ctx:3.3.2.2.6.2.5.2.14.1. throw DbUpdateException
                    ctx -->> repo:3.3.2.2.6.2.5.2.14.1.1. throw DbUpdateException
                    repo -->> sv:3.3.2.2.6.2.5.2.14.1.2. throw DbUpdateException
                    sv -> sv++:3.3.2.2.6.2.5.2.14.1.3. Call transaction.RollbackAsync()
                    sv--
                    sv -->> be_ctrl:3.3.2.2.6.2.5.2.14.1.4. throw DbUpdateException
                    be_ctrl -->> fe_ctrl:3.3.2.2.6.2.5.2.14.1.5. Return statusCode 500
                    fe_ctrl -->> view:3.3.2.2.6.2.5.2.14.1.6. Return JSON (success=false)
                    view -->> act:3.3.2.2.6.2.5.2.14.1.7. Display server error message
else Database Save Success
                    db -->> ctx--:3.3.2.2.6.2.5.2.14.2. Return returnCode
                    ctx -->> repo--:3.3.2.2.6.2.5.2.14.2.1. Return numberOfRowsAffected
                    repo -->> sv--:3.3.2.2.6.2.5.2.14.2.2. Return numberOfRowsAffected
                    
                    sv -> sv++:3.3.2.2.6.2.5.2.14.2.3. Call transaction.CommitAsync()
                    sv--
                    
opt course.InstructorId HasValue
                        sv -> user_repo++:3.3.2.2.6.2.5.2.14.2.3.1. Call GetUserByIdAsync(userId)
                        user_repo -> ctx++:3.3.2.2.6.2.5.2.14.2.3.1.1. Execute query
                        ctx -> db++:3.3.2.2.6.2.5.2.14.2.3.1.2. Fetch user
                        db -->> ctx--:3.3.2.2.6.2.5.2.14.2.3.1.3. Return query results
                        ctx -->> user_repo--:3.3.2.2.6.2.5.2.14.2.3.1.4. Return user entity
                        user_repo -->> sv--:3.3.2.2.6.2.5.2.14.2.3.1.5. Return student entity
                        
                        sv -> notif_sv++:3.3.2.2.6.2.5.2.14.2.3.1.6. Call SendNotificationAsync(InstructorId, content)
                        notif_sv -->> sv--:3.3.2.2.6.2.5.2.14.2.3.1.7. Return result
end
                    
                    sv -->> be_ctrl--:3.3.2.2.6.2.5.2.14.2.4. Return result
                    be_ctrl -->> fe_ctrl--:3.3.2.2.6.2.5.2.14.2.5. Return statusCode 200
                    fe_ctrl -->> view--:3.3.2.2.6.2.5.2.14.2.6. Return JSON (success=true)
                    view -->> act--:3.3.2.2.6.2.5.2.14.2.7. Display enrollment success message
end
end
end
end
end
