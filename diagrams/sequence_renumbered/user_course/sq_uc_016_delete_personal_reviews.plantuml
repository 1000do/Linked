@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Delete Personal Reviews

actor User as act
participant "CourseDetailPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "ReviewController" as fe_ctrl <<frontend controller>>
participant "ReviewController" as be_ctrl <<backend controller>>
participant ":ReviewService" as sv
participant ":IReviewRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click Delete on own review
view -> fe_ctrl++:2. DELETE /Review/DeleteReview/{reviewId}

fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization
    fe_ctrl -> be_ctrl++:3.3. DELETE /api/reviews/{reviewId}
    be_ctrl -> sv++:3.3.1. Call DeleteReviewAsync(userId, reviewId)
    
    sv -> repo++:3.3.2. Call GetByIdAsync(reviewId)
    repo -> ctx++:3.3.3. Execute query
    ctx -> db++:3.3.4. Fetch review
    db -->> ctx--:3.3.5. Return query results
    ctx -->> repo--:3.3.6. Return review entity
    repo -->> sv--:3.3.7. Return review entity
    
alt Review Not Found
        sv -->> be_ctrl:3.3.7.1. throw KeyNotFoundException
        be_ctrl -->> fe_ctrl:3.3.7.1.1. Return statusCode 404
        fe_ctrl -->> view:3.3.7.1.2. Return JSON (success=false)
        view -->> act:3.3.7.1.3. Display review not found message
else Review Found
alt Not Owner of Review
            sv -->> be_ctrl:3.3.7.2.1. throw UnauthorizedAccessException
            be_ctrl -->> fe_ctrl:3.3.7.2.1.1. Return statusCode 403
            fe_ctrl -->> view:3.3.7.2.1.2. Return JSON (success=false)
            view -->> act:3.3.7.2.1.3. Display unauthorized message
else Owner of Review
            sv -> repo++:3.3.7.2.2. Call DeleteReviewAsync(review)
            repo -->> sv--:3.3.7.2.2.1. Return result
            
            sv -> repo++:3.3.7.2.2.2. Call SaveChangesAsync()
            repo -> ctx++:3.3.7.2.2.3. Save changes to database
            ctx -> db++:3.3.7.2.2.4. Delete Review
            
alt Database Save Failure
                db -->> ctx:3.3.7.2.2.4.1. throw DbUpdateException
                ctx -->> repo:3.3.7.2.2.4.1.1. throw DbUpdateException
                repo -->> sv:3.3.7.2.2.4.1.2. throw DbUpdateException
                sv -->> be_ctrl:3.3.7.2.2.4.1.3. throw DbUpdateException
                be_ctrl -->> fe_ctrl:3.3.7.2.2.4.1.4. Return statusCode 500
                fe_ctrl -->> view:3.3.7.2.2.4.1.5. Return JSON (success=false)
                view -->> act:3.3.7.2.2.4.1.6. Display server error message
else Database Save Success
                db -->> ctx--:3.3.7.2.2.4.2. Return returnCode
                ctx -->> repo--:3.3.7.2.2.4.2.1. Return numberOfRowsAffected
                repo -->> sv--:3.3.7.2.2.4.2.2. Return numberOfRowsAffected
                
                sv -->> be_ctrl--:3.3.7.2.2.4.2.3. Return success
                be_ctrl -->> fe_ctrl--:3.3.7.2.2.4.2.4. Return statusCode 200
                fe_ctrl -->> view--:3.3.7.2.2.4.2.5. Return JSON (success=true)
                view -->> act--:3.3.7.2.2.4.2.6. Display review deleted successfully
end
end
end
end
