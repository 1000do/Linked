@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Delete Personal Reviews

actor User as act
participant "CourseDetailPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "ReviewController" as be_ctrl <<backend controller>>
participant ":ReviewService" as sv
participant ":IReviewRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click Delete on own review
view -> fe_ctrl++:2. POST /Course/DeleteReview (DeleteReviewRequest)

fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization
    fe_ctrl -> be_ctrl++:3.3. DELETE /api/review/delete (request)
    be_ctrl -> sv++:3.3.1. Call DeleteReviewAsync(userId, request)
    
alt type == "lesson"
        sv -> repo++:3.3.1.1. Call GetLessonReviewByIdAsync(reviewId)
        repo -> ctx++:3.3.1.1.1. Execute query
        ctx -> db++:3.3.1.1.2. Fetch review
        db -->> ctx--:3.3.1.1.3. Return query results
        ctx -->> repo--:3.3.1.1.4. Return lesson review entity
        repo -->> sv--:3.3.1.1.5. Return lesson review entity
        
alt Review == null OR Not Owner
            sv -->> be_ctrl:3.3.1.1.5.1. throw InvalidOperationException / UnauthorizedAccessException
            be_ctrl -->> fe_ctrl:3.3.1.1.5.1.1. Return statusCode 400 / 403
            fe_ctrl -->> view:3.3.1.1.5.1.2. Return JSON (success=false)
            view -->> act:3.3.1.1.5.1.3. Display error message
else Valid Review
            sv -> repo++:3.3.1.1.5.2. Call HasPendingLessonReviewReportsAsync(reviewId)
            repo -> ctx++:3.3.1.1.5.2.1. Execute query
            ctx -> db++:3.3.1.1.5.2.2. Check reports
            db -->> ctx--:3.3.1.1.5.2.3. Return query results
            ctx -->> repo--:3.3.1.1.5.2.4. Return hasPending flag
            repo -->> sv--:3.3.1.1.5.2.5. Return hasPending flag
            
alt hasPending == true
                sv -->> be_ctrl:3.3.1.1.5.2.5.1. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:3.3.1.1.5.2.5.1.1. Return statusCode 400
                fe_ctrl -->> view:3.3.1.1.5.2.5.1.2. Return JSON (success=false)
                view -->> act:3.3.1.1.5.2.5.1.3. Display moderation error message
else No pending reports
                sv -> repo++:3.3.1.1.5.2.5.2. Call UpdateLessonReview(review)
                repo -> ctx++:3.3.1.1.5.2.5.2.1. Update entity state (IsRemoved=true)
                ctx -->> repo--:3.3.1.1.5.2.5.2.2. Return
                repo -->> sv--:3.3.1.1.5.2.5.2.3. Return
end
end
        
else type == "course" OR null
        sv -> repo++:3.3.1.2. Call GetCourseReviewByIdAsync(reviewId)
        repo -> ctx++:3.3.1.2.1. Execute query
        ctx -> db++:3.3.1.2.2. Fetch review
        db -->> ctx--:3.3.1.2.3. Return query results
        ctx -->> repo--:3.3.1.2.4. Return course review entity
        repo -->> sv--:3.3.1.2.5. Return course review entity
        
alt Review == null OR Not Owner
            sv -->> be_ctrl:3.3.1.2.5.1. throw InvalidOperationException / UnauthorizedAccessException
            be_ctrl -->> fe_ctrl:3.3.1.2.5.1.1. Return statusCode 400 / 403
            fe_ctrl -->> view:3.3.1.2.5.1.2. Return JSON (success=false)
            view -->> act:3.3.1.2.5.1.3. Display error message
else Valid Review
            sv -> repo++:3.3.1.2.5.2. Call HasPendingCourseReviewReportsAsync(reviewId)
            repo -> ctx++:3.3.1.2.5.2.1. Execute query
            ctx -> db++:3.3.1.2.5.2.2. Check reports
            db -->> ctx--:3.3.1.2.5.2.3. Return query results
            ctx -->> repo--:3.3.1.2.5.2.4. Return hasPending flag
            repo -->> sv--:3.3.1.2.5.2.5. Return hasPending flag
            
alt hasPending == true
                sv -->> be_ctrl:3.3.1.2.5.2.5.1. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:3.3.1.2.5.2.5.1.1. Return statusCode 400
                fe_ctrl -->> view:3.3.1.2.5.2.5.1.2. Return JSON (success=false)
                view -->> act:3.3.1.2.5.2.5.1.3. Display moderation error message
else No pending reports
                sv -> repo++:3.3.1.2.5.2.5.2. Call UpdateCourseReview(review)
                repo -> ctx++:3.3.1.2.5.2.5.2.1. Update entity state (IsRemoved=true)
                ctx -->> repo--:3.3.1.2.5.2.5.2.2. Return
                repo -->> sv--:3.3.1.2.5.2.5.2.3. Return
end
end
end
    
    sv -> repo++:3.3.2. Call SaveChangesAsync()
    repo -> ctx++:3.3.3. Save changes to database
    ctx -> db++:3.3.4. Update Review
    
alt Database Save Failure
        db -->> ctx:3.3.4.1. throw DbUpdateException
        ctx -->> repo:3.3.4.1.1. throw DbUpdateException
        repo -->> sv:3.3.4.1.2. throw DbUpdateException
        sv -->> be_ctrl:3.3.4.1.3. throw DbUpdateException
        be_ctrl -->> fe_ctrl:3.3.4.1.4. Return statusCode 500
        fe_ctrl -->> view:3.3.4.1.5. Return JSON (success=false)
        view -->> act:3.3.4.1.6. Display server error message
else Database Save Success
        db -->> ctx--:3.3.4.2. Return returnCode
        ctx -->> repo--:3.3.4.2.1. Return numberOfRowsAffected
        repo -->> sv--:3.3.4.2.2. Return numberOfRowsAffected
        
        sv -->> be_ctrl--:3.3.4.2.3. Return success
        be_ctrl -->> fe_ctrl--:3.3.4.2.4. Return statusCode 200
        fe_ctrl -->> view--:3.3.4.2.5. Return JSON (success=true)
        view -->> act--:3.3.4.2.6. Display review deleted successfully
end
end
