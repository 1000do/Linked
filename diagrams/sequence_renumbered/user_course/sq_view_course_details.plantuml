@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Course Details

actor Guest as act
participant "CourseDetailsPage" as view
participant "NotFoundPage" as not_found_view
participant "ErrorPage" as error_view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "CoursePublicController" as be_ctrl <<backend controller>>
participant ":CourseQueryService" as sv
participant ":CourseRepository" as repo
participant ":InstructorRepository" as inst_repo

participant ":RedisService" as redis
participant ":CourseDetailResponse" as res
participant ":AppDbContext" as ctx
database Database as db
act++
act -> view++:1. Access course details page
view -> fe_ctrl++:2. Send GET request to /Course/Details/{id}
fe_ctrl -> be_ctrl++:3. Send GET request to /api/public/courses/{id}

be_ctrl -> sv++:4. Call GetCourseWithDetailsAsync(id, 0, userId)

sv -> redis++:5. Call GetCacheAsync(cacheKey)
redis -->> sv--:6. Return cached response
opt Cache Miss
    sv -> repo++:6.1. Call GetCourseWithDetailsAsync(courseId)
    repo -> ctx++:6.1.1. Query course details
    ctx -> db++:6.1.2. Execute query
    db -->> ctx--:6.1.3. Return data
    ctx -->> repo--:6.1.4. Return data
    repo -->> sv--:6.1.5. Return Course object
    
    sv -> repo++:6.1.6. Call GetCourseStatsAsync(courseId)
    repo -> ctx++:6.1.7. Query course stats
    ctx -> db++:6.1.8. Execute query
    db -->> ctx--:6.1.9. Return data
    ctx -->> repo--:6.1.10. Return data
    repo -->> sv--:6.1.11. Return CourseStats
    
    sv -> inst_repo++:6.1.12. Call GetStatsAsync(instructorId)
    inst_repo -> ctx++:6.1.13. Query instructor stats
    ctx -> db++:6.1.14. Execute query
    db -->> ctx--:6.1.15. Return data
    ctx -->> inst_repo--:6.1.16. Return data
    inst_repo -->> sv--:6.1.17. Return InstructorStats

    sv -> res++:6.1.18. Call CourseDetailResponse()
    res -->> sv--:6.1.19. Return CourseDetailResponse object
    
    sv -> redis++:6.1.20. Call SetCacheAsync(cacheKey, response, TTL)
    redis -->> sv--:6.1.21. Return result
end
sv -> sv++:7. Check enrollment status
sv--

sv -->> be_ctrl--:8. Return CourseDetailResponse object

be_ctrl -> be_ctrl++:9. Validate actor permission to view
be_ctrl--

alt Course Not Found
    be_ctrl -->> fe_ctrl:9.1. Return statusCode 404
    fe_ctrl -> not_found_view++:9.1.1. Redirect to Not Found page
    not_found_view -->> act--:9.1.2. Display Not Found page
else Unauthorized Access
    be_ctrl -->> fe_ctrl:9.2. Return statusCode 403
    fe_ctrl -> error_view++:9.2.1. Redirect to Error page
    error_view -->> act--:9.2.2. Display Error page
else Valid Access
    be_ctrl -->> fe_ctrl--:9.3. Return statusCode 200
    fe_ctrl -->> view--:9.3.1. Return CourseDetailResponse object
    
opt View Unpublished Course
        view -> view++:9.3.1.2. Render unpublished warning banner
        view--
end
    
alt View Enrolled Course Actions
        view -->> act:9.3.1.1. Display course details with "Go to learning" button
else View Free Course Actions
        view -->> act:9.3.1.2. Display course details with "Enroll Now" button
else Paid Course Action
        view -->> act--:9.3.1.3. Display course details with "Add to cart" button
end
end
@enduml
