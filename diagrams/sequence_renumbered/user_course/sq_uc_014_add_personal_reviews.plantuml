@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Add Personal Reviews

actor User as act
participant "CourseDetailPage" as view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "ReviewController" as be_ctrl <<backend controller>>
participant ":ReviewService" as sv
participant ":IUserLockoutRepository" as lockout_repo
participant ":ICourseRepository" as course_repo
participant ":IEnrollmentRepository" as enroll_repo
participant ":IReviewRepository" as repo
participant ":INotificationService" as notif_sv
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click "Write a Review" and Submit
view -> fe_ctrl++:2. POST /Course/SubmitReview (ReviewRequest)

fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Valid actor's authentication and authorization
    fe_ctrl -> be_ctrl++:3.1. POST /api/review/submit
    be_ctrl -> sv++:3.1.1. Call SubmitReviewAsync(userId, request, requireCompletion)
    
    sv -> lockout_repo++:3.1.2. Call GetActiveLockoutAsync(userId, "review")
    lockout_repo -> ctx++:3.1.3. Execute query
    ctx -> db++:3.1.4. Fetch lockout
    db -->> ctx--:3.1.5. Return query results
    ctx -->> lockout_repo--:3.1.6. Return lockout entity
    lockout_repo -->> sv--:3.1.7. Return lockout entity
    
alt Active Lockout Exists
        sv -->> be_ctrl:3.1.7.1. throw BadRequestException
        be_ctrl -->> fe_ctrl:3.1.7.1.1. Return statusCode 400
        fe_ctrl -->> view:3.1.7.1.2. Return JSON (success=false)
        view -->> act:3.1.7.1.3. Display restriction message
else No Active Lockout
        sv -> course_repo++:3.1.7.2. Call IsOwnerAsync(userId, courseId)
        course_repo -> ctx++:3.1.7.2.1. Execute query
        ctx -> db++:3.1.7.2.2. Check owner
        db -->> ctx--:3.1.7.2.3. Return query results
        ctx -->> course_repo--:3.1.7.2.4. Return IsOwner flag
        course_repo -->> sv--:3.1.7.2.5. Return IsOwner flag
        
alt Is Owner
            sv -> enroll_repo++:3.1.7.2.5.1. Call GetEnrollmentWithProgressAsync(userId, courseId)
            enroll_repo -> ctx++:3.1.7.2.5.1.1. Execute query
            ctx -> db++:3.1.7.2.5.1.2. Fetch enrollment
            db -->> ctx--:3.1.7.2.5.1.3. Return query results
            ctx -->> enroll_repo--:3.1.7.2.5.1.4. Return enrollment entity
            enroll_repo -->> sv--:3.1.7.2.5.1.5. Return enrollment entity
            

else Not Owner
            sv -> enroll_repo++:3.1.7.2.5.2. Call GetEnrollmentWithProgressAsync(userId, courseId)
            enroll_repo -> ctx++:3.1.7.2.5.2.1. Execute query
            ctx -> db++:3.1.7.2.5.2.2. Fetch enrollment
            db -->> ctx--:3.1.7.2.5.2.3. Return query results
            ctx -->> enroll_repo--:3.1.7.2.5.2.4. Return enrollment entity
            enroll_repo -->> sv--:3.1.7.2.5.2.5. Return enrollment entity
            
alt Enrollment == null OR (requireCompletion == true AND Not Completed)
                sv -->> be_ctrl:3.1.7.2.5.2.5.1. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:3.1.7.2.5.2.5.1.1. Return statusCode 400
                fe_ctrl -->> view:3.1.7.2.5.2.5.1.2. Return JSON (success=false)
                view -->> act:3.1.7.2.5.2.5.1.3. Display requirement error message
else Enrollment Valid
opt requireCompletion == false
                    sv -> enroll_repo++:3.1.7.2.5.2.5.2.1. Call GetCompletedMaterialCountAsync(enrollmentId)
                    enroll_repo -->> sv--:3.1.7.2.5.2.5.2.1.1. Return learnedCount
end
end
end
        
alt LessonId HasValue
            sv -> repo++:3.1.7.2.5.1. Call AddLessonReviewAsync(newLessonReview)
            repo -> ctx++:3.1.7.2.5.1.1. Add entity
            ctx -->> repo--:3.1.7.2.5.1.2. Return
            repo -->> sv--:3.1.7.2.5.1.3. Return result
else CourseId Only
            sv -> repo++:3.1.7.2.5.2. Call AddCourseReviewAsync(newCourseReview)
            repo -> ctx++:3.1.7.2.5.2.1. Add entity
            ctx -->> repo--:3.1.7.2.5.2.2. Return
            repo -->> sv--:3.1.7.2.5.2.3. Return result
end
        
        sv -> repo++:3.1.7.2.6. Call SaveChangesAsync()
        repo -> ctx++:3.1.7.2.7. Save changes to database
        ctx -> db++:3.1.7.2.8. Insert Review
        
alt Database Save Failure
            db -->> ctx:3.1.7.2.8.1. throw DbUpdateException
            ctx -->> repo:3.1.7.2.8.1.1. throw DbUpdateException
            repo -->> sv:3.1.7.2.8.1.2. throw DbUpdateException
            sv -->> be_ctrl:3.1.7.2.8.1.3. throw DbUpdateException
            be_ctrl -->> fe_ctrl:3.1.7.2.8.1.4. Return statusCode 500
            fe_ctrl -->> view:3.1.7.2.8.1.5. Return JSON (success=false)
            view -->> act:3.1.7.2.8.1.6. Display server error message
else Database Save Success
            db -->> ctx--:3.1.7.2.8.2. Return returnCode
            ctx -->> repo--:3.1.7.2.8.2.1. Return numberOfRowsAffected
            repo -->> sv--:3.1.7.2.8.2.2. Return numberOfRowsAffected
            
            sv -->> be_ctrl--:3.1.7.2.8.2.3. Return result
            be_ctrl -->> fe_ctrl--:3.1.7.2.8.2.4. Return statusCode 200
            fe_ctrl -->> view--:3.1.7.2.8.2.5. Return JSON (success=true)
            view -->> act--:3.1.7.2.8.2.6. Display review success message
end
end
end
