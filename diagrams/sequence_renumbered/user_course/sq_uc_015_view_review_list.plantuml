@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Review List

actor Guest as act
participant "CourseDetailPage" as view
participant "ReviewController" as fe_ctrl <<frontend controller>>
participant "ReviewController" as be_ctrl <<backend controller>>
participant ":ReviewService" as sv
participant ":PagedResult<ReviewResponse>" as res
participant ":IReviewRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Scroll to Reviews section
view -> fe_ctrl++:2. GET /Review/CourseReviews?courseId={id}
fe_ctrl -> be_ctrl++:3. GET /api/reviews/course/{courseId}
be_ctrl -> sv++:4. Call GetCourseReviewsAsync(courseId, page, pageSize, starFilter)

sv -> repo++:5. Call GetCourseReviewsPagedAsync(courseId, page, pageSize, starFilter)
repo -> ctx++:6. Execute query
ctx -> db++:7. Fetch reviews
db -->> ctx--:8. Return query results
ctx -->> repo--:9. Return review entities and totalCount
repo -->> sv--:10. Return (reviews, totalCount)

sv -> sv++:11. Map reviews to ReviewResponse DTOs
sv--

sv -> res++:12. Call PagedResult(reviewResponses, totalCount)
res -->> sv--:13. Return PagedResult object

sv -->> be_ctrl--:14. Return PagedResult object
be_ctrl -->> fe_ctrl--:15. Return statusCode 200
fe_ctrl -->> view--:16. Return View(PagedResult)
view -->> act--:17. Display review list
