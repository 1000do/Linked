@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Review List

actor Guest as act
participant "CourseDetailPage" as view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "ReviewController" as be_ctrl <<backend controller>>
participant ":ReviewService" as sv
participant ":ReviewResponse" as res
participant ":IReviewRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Scroll to Reviews section
view -> fe_ctrl++:2. GET /Course/GetReviews?id={courseId}
fe_ctrl -> be_ctrl++:3. GET /api/reviews/course/{courseId}
be_ctrl -> sv++:4. Call GetCourseReviewsAsync(courseId, page, pageSize, starFilter)

sv -> repo++:5. Call GetCourseReviewsWithDetailsAsync(courseId, page, pageSize, starFilter)
repo -> ctx++:6. Execute query
ctx -> db++:7. Fetch reviews
db -->> ctx--:8. Return query results
ctx -->> repo--:9. Return review entities and totalCount
repo -->> sv--:10. Return (reviews, totalCount)

sv -> res++:11. Call ReviewResponse() (mapping)
res -->> sv--:12. Return List<ReviewResponse>

sv -->> be_ctrl--:13. Return PagedResult<ReviewResponse>
be_ctrl -->> fe_ctrl--:14. Return statusCode 200
fe_ctrl -->> view--:15. Return View(PagedResult<ReviewResponse>)
view -->> act--:16. Display review list
