@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Purchased Course List

actor User as act
participant "MyCoursesPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "EnrollmentController" as be_ctrl <<backend controller>>
participant ":EnrollmentService" as sv
participant ":EnrolledCourseResponse" as res
participant ":IEnrollmentRepository" as repo
participant ":ICourseRepository" as course_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click "My Courses"
view -> fe_ctrl++:2. GET /Course/MyCourses

fe_ctrl -> fe_ctrl++:3. Validate actor's authentication and authorization
fe_ctrl--

alt Session Invalid
    fe_ctrl -->> login_view:3.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:3.1.1. Display login form
else Unauthorized Access
    fe_ctrl -->> error_view:3.2. Redirect to ErrorPage
    activate error_view
    error_view -->> act--:3.2.1. Display error message
else Valid actor's authentication and authorization

    fe_ctrl -> be_ctrl++:3.3. GET /api/enrollment/my-courses
    be_ctrl -> sv++:3.3.1. Call GetMyEnrolledCoursesAsync(userId)
    
    sv -> repo++:3.3.2. Call GetMyEnrolledCoursesAsync(userId)
    repo -> ctx++:3.3.3. Execute query
    ctx -> db++:3.3.4. Fetch enrolled courses
    db -->> ctx--:3.3.5. Return query results
    ctx -->> repo--:3.3.6. Return enrollments
    repo -->> sv--:3.3.7. Return enrollments
    
    sv -> course_repo++:3.3.8. Call GetCourseStatsAsync(courseIds)
    course_repo -->> sv--:3.3.9. Return stats
    
    sv -> sv++:3.3.10. Calculate progress for each course
    sv--
    
    sv -> res++:3.3.11. Call EnrolledCourseResponse()
    res -->> sv--:3.3.12. Return EnrolledCourseResponse objects
    
    sv -->> be_ctrl--:3.3.13. Return EnrolledCourseResponse objects
    be_ctrl -->> fe_ctrl--:3.3.14. Return statusCode 200
    fe_ctrl -->> view:3.3.15. Return View(EnrolledCourseViewModel)
    view -->> act:3.3.16. Display enrolled courses list
end
