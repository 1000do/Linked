@startuml ViewCourseModerationList
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Course Moderation List
actor Staff as act

participant "AdminModerationCoursesView" as view
participant "AdminModerationController" as fe_ctrl
participant "ApiClient" as api_client
participant "CoursePublicController" as pub_ctrl
participant "AdminModerationController" as be_ctrl
participant ":CourseModerationService" as sv
participant ":CourseRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act -> fe_ctrl++:1. Access Course Moderation Page (/AdminModeration/Courses)

fe_ctrl -> api_client++:2. Send GET request to /api/public/categories
api_client -> pub_ctrl++:3. Send GET request to /api/public/categories
pub_ctrl -> ctx++:4. Call GetCategoriesAsync()
ctx -> db++:5. Query all Categories
db -->> ctx--:6. Return categories
ctx -->> pub_ctrl--:7. Return categories list
pub_ctrl -->> api_client--:8. Return HTTP 200 (Ok) with categories JSON data
api_client -->> fe_ctrl--:9. Return HTTP 200 (Ok) response

fe_ctrl -> api_client++:10. Send GET request to /api/admin/moderation/courses/pending?...
api_client -> be_ctrl++:11. Send GET request to /api/admin/moderation/courses/pending?...

be_ctrl -> sv++:12. Call GetPendingCoursesAsync(filter)
sv -> repo++:13. Call GetPendingCoursesModerationAsync(filter)
repo -> ctx++:14. Call GetPendingCoursesModerationAsync(filter)
ctx -> db++:15. Query pending/under-review courses
db -->> ctx--:16. Return courses list
ctx -->> repo--:17. Return courses list
repo -->> sv--:18. Return courses list

sv -> sv++:19. Calculate UrgencyLevel & UrgencyColor for each course
sv--

sv -->> be_ctrl--:20. Return PagedResult<CourseModerationDto>
be_ctrl -->> api_client--:21. Return HTTP 200 (Ok) with pending courses JSON

alt Pending Courses API Call Successful
    api_client -->> fe_ctrl:21.1. Return HTTP 200 (Ok) response
    deactivate api_client
    
    fe_ctrl -> api_client++:21.1.1. Send GET request to /api/admin/moderation/courses/stats
    api_client -> be_ctrl++:21.1.2. Send GET request to /api/admin/moderation/courses/stats
    be_ctrl -> sv++:21.1.3. Call GetCourseModerationStatsAsync()
    sv -> repo++:21.1.4. Call GetCourseModerationStatsAsync()
    repo -> ctx++:21.1.5. Call GetCourseModerationStatsAsync()
    ctx -> db++:21.1.6. Query counts (pending and resolved today)
    db -->> ctx--:21.1.7. Return counts
    ctx -->> repo--:21.1.8. Return counts
    repo -->> sv--:21.1.9. Return counts
    sv -->> be_ctrl--:21.1.10. Return CourseModerationStatsDto
    be_ctrl -->> api_client--:21.1.11. Return HTTP 200 (Ok) with stats JSON
    api_client -->> fe_ctrl:21.1.12. Return HTTP 200 (Ok) response
    deactivate api_client
    
    fe_ctrl -> view++:21.1.13. Render AdminModeration/Courses View with PagedResult and Stats
    deactivate fe_ctrl
    view -->> act:21.1.14. Display Course Moderation List and statistics
    deactivate view
else Pending Courses API Call Failed
    api_client -->> fe_ctrl:21.2. Return HTTP 400/500 Error response
    deactivate api_client
    
    fe_ctrl -> view++:21.2.1. Render AdminModeration/Courses View with empty PagedResult and 0 stats
    deactivate fe_ctrl
    view -->> act:21.2.2. Display empty moderation list
    deactivate view
end

@enduml
