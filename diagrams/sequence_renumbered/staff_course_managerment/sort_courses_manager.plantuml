@startuml SortCoursesManager
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Sort Courses (For Manager)
actor Staff as act

participant "AdminModerationCoursesView" as view
participant "AdminModerationController" as be_ctrl
participant ":CourseModerationService" as sv
participant ":CourseRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act -> view++:1. Select sorting option from "Sort By" dropdown (oldest / newest)

view -> view++:2. EventListener: change
view -> view++:3. triggerAjaxFetch() with 300ms debounce
view--

view -> view++:4. fetchCourses(search, category, status, sortBy)
view -> view++:5. Set moderation-table-container opacity to 0.5
view--

view -> be_ctrl++:6. Send GET request to /AdminModeration/Courses?search=...&category=...&status=...&sortBy=oldest|newest

be_ctrl -> sv++:7. Call GetPendingCoursesAsync(filter)
sv -> repo++:8. Call GetPendingCoursesModerationAsync(filter)
repo -> ctx++:9. Call GetPendingCoursesModerationAsync(filter)

ctx -> ctx++:10. Apply filter: Exclude status = "draft"
ctx--
ctx -> ctx++:11. Apply filter: status == filter.Status (if not "all")
ctx--
ctx -> ctx++:12. Apply search: Title or InstructorName contains keyword (if specified)
ctx--
ctx -> ctx++:13. Apply category filter (if specified)
ctx--
ctx -> ctx++:14. Apply sort: oldest-first (default) or newest-first based on sortBy
ctx--

ctx -> db++:15. Query sorted and filtered Courses
db -->> ctx--:16. Return sorted courses list
ctx -->> repo--:17. Return sorted courses list
repo -->> sv--:18. Return sorted courses list

sv -> sv++:19. Calculate UrgencyLevel & UrgencyColor for each course
sv--

sv -->> be_ctrl:20. Return PagedResult<CourseModerationDto>

be_ctrl -> be_ctrl++:21. Send GET request to /api/admin/moderation/courses/stats
be_ctrl -> sv++:22. Call GetCourseModerationStatsAsync()
sv -> repo++:23. Call GetCourseModerationStatsAsync()
repo -> ctx++:24. Call GetCourseModerationStatsAsync()
ctx -> db++:25. Query pending count and resolved-today count
db -->> ctx--:26. Return counts
ctx -->> repo--:27. Return counts
repo -->> sv--:28. Return counts
sv -->> be_ctrl--:29. Return CourseModerationStatsDto
be_ctrl--

be_ctrl -->> view:30. Return rendered HTML page with sorted results
deactivate be_ctrl

view -> view++:31. Parse HTML response with DOMParser
view -> view++:32. Replace moderation-table-container innerHTML with new content
view--
view -> view++:33. Replace stats-container innerHTML with new counts
view--
view -> view++:34. Restore moderation-table-container opacity to 1.0
view--
deactivate view

view -->> act--:35. Display course list in selected sorted order
deactivate view

@enduml
