@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Remove Lessons

actor Instructor as act
participant "CourseEditorPage" as view
participant "InstructorCourseController" as fe_ctrl <<frontend controller>>
participant "LessonController" as be_ctrl <<backend controller>>
participant ":LessonService" as sv
participant ":ILessonRepository" as repo
participant ":ICourseRepository" as course_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click Delete Lesson
view -> fe_ctrl++:2. DELETE /InstructorCourse/RemoveLesson/{lessonId}
fe_ctrl -> be_ctrl++:3. DELETE /api/lessons/{id}

be_ctrl -> sv++:4. Call DeleteLessonAsync(id, instructorId)

sv -> repo++:5. Call GetByIdAsync(id)
repo -> ctx++:6. Execute query
ctx -> db++:7. Fetch lesson
db -->> ctx--:8. Return query results
ctx -->> repo--:9. Return lesson entity
repo -->> sv--:10. Return lesson entity

alt Lesson Not Found
    sv -->> be_ctrl:10.1. throw Exception
    be_ctrl -->> fe_ctrl:10.1.1. Return statusCode 404
    fe_ctrl -->> view:10.1.2. Return JSON (success=false)
    view -->> act:10.1.3. Display lesson not found message
else Lesson Found
    sv -> sv++:10.2. Validate Instructor and Course State
    sv--
    
alt Validation Failed
        sv -->> be_ctrl:10.2.1. throw BadRequestException
        be_ctrl -->> fe_ctrl:10.2.1.1. Return statusCode 400
        fe_ctrl -->> view:10.2.1.2. Return JSON (success=false)
        view -->> act:10.2.1.3. Display error message
else Valid to Delete
        sv -> sv++:10.2.2. Soft delete materials and move to trash
        sv--
        
        sv -> repo++:10.2.2.1. Call Update(lesson) (Set IsRemoved=true)
        repo -> ctx++:10.2.2.2. Update entity state
        ctx -->> repo--:10.2.2.3. Return
        repo -->> sv--:10.2.2.4. Return
        
opt Course is Published
            sv -> sv++:10.2.2.4.1. Set course.CourseStatus = "draft"
            sv--
end
        
        sv -> repo++:10.2.2.5. Call SaveChangesAsync()
        repo -> ctx++:10.2.2.6. Save changes to database
        ctx -> db++:10.2.2.7. Update Lesson (Soft Delete)
        db -->> ctx--:10.2.2.8. Return returnCode
        ctx -->> repo--:10.2.2.9. Return numberOfRowsAffected
        repo -->> sv--:10.2.2.10. Return numberOfRowsAffected
        
        sv -> sv++:10.2.2.11. Check numberOfRowsAffected
        sv--
        
alt numberOfRowsAffected > 0
            sv -> sv++:10.2.2.11.1. Call Cache Invalidation Logic
            sv--
            
            sv -->> be_ctrl--:10.2.2.11.1.1. Return success
            be_ctrl -->> fe_ctrl--:10.2.2.11.1.2. Return statusCode 200
            fe_ctrl -->> view--:10.2.2.11.1.3. Return JSON (success=true)
            view -->> act--:10.2.2.11.1.4. Display lesson removed successfully
else numberOfRowsAffected = 0
            sv -->> be_ctrl--:10.2.2.11.2. throw InvalidOperationException
            be_ctrl -->> fe_ctrl--:10.2.2.11.2.1. Return statusCode 400
            fe_ctrl -->> view--:10.2.2.11.2.2. Return JSON (success=false)
            view -->> act--:10.2.2.11.2.3. Display error message
end
end
end
