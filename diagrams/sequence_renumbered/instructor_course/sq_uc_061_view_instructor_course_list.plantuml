@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View Instructor Dashboard & Course List

actor Instructor as act
participant "InstructorDashboardPage" as view
participant "InstructorCourseController" as fe_ctrl <<frontend controller>>
participant "InstructorController" as be_inst_ctrl <<backend controller>>
participant "CourseController" as be_crs_ctrl <<backend controller>>
participant ":InstructorService" as inst_sv
participant ":CourseQueryService" as crs_sv
participant ":IInstructorRepository" as inst_repo
participant ":ICourseRepository" as crs_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. View Dashboard/Course tab
view -> fe_ctrl++:2. GET /InstructorCourse/Index

== Fetch Dashboard Stats ==
fe_ctrl -> be_inst_ctrl++:3. GET /api/instructor/dashboard
be_inst_ctrl -> inst_sv++:4. Call GetInstructorDashboardAsync(instructorId)
inst_sv -> inst_repo++:5. Call GetDashboardDtoAsync(instructorId)
inst_repo -->> inst_sv--:6. Return basic stats
inst_sv -> inst_repo++:7. Call GetEnrollmentGrowthAsync(instructorId)
inst_repo -->> inst_sv--:8. Return growth %
inst_sv -> inst_repo++:9. Call GetInstructorRankingPercentageAsync(instructorId)
inst_repo -->> inst_sv--:10. Return rank %
inst_sv -->> be_inst_ctrl--:11. Return InstructorDashboardDto
be_inst_ctrl -->> fe_ctrl--:12. Return InstructorDashboardDto

== Fetch Course List ==
fe_ctrl -> be_crs_ctrl++:13. GET /api/courses/my-courses
be_crs_ctrl -> crs_sv++:14. Call GetInstructorCoursesPagedAsync(instructorId, page, pageSize, search, status)
crs_sv -> crs_repo++:15. Call GetInstructorCoursesPagedAsync(...)
crs_repo -> ctx++:16. Execute query
ctx -> db++:17. Fetch instructor courses
db -->> ctx--:18. Return query results
ctx -->> crs_repo--:19. Return entities and totalCount
crs_repo -->> crs_sv--:20. Return (courses, totalCount)
crs_sv -->> be_crs_ctrl--:21. Return PagedResult<CourseResponse>
be_crs_ctrl -->> fe_ctrl--:22. Return statusCode 200

fe_ctrl -> fe_ctrl:23. Map to InstructorStudioViewModel
fe_ctrl -->> view:24. Return View(InstructorStudioViewModel)
view -->> act:25. Display Dashboard & Course list
@enduml
