@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Hide courses

actor Instructor as act
participant "InstructorDashboardPage" as view
participant "InstructorCourseController" as fe_ctrl <<frontend controller>>
participant "CourseController" as be_ctrl <<backend controller>>
participant ":CourseCommandService" as sv
participant ":IRedisCacheService" as redis
participant ":IReviewLockoutRepository" as lockout_repo
participant ":ICourseRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click Hide Course
view -> fe_ctrl++:2. PATCH /InstructorCourse/UpdateStatus/{id}
fe_ctrl -> be_ctrl++:3. PATCH /api/courses/{id}/status

be_ctrl -> sv++:4. Call UpdateCourseStatusAsync(id, "hidden", instructorId)

sv -> sv++:5. Call ValidateCourseStatusUpdateAsync(id, "hidden", instructorId)
sv -> repo++:6. Call GetByIdAsync(id)
repo -> ctx++:7. Execute query
ctx -> db++:8. Fetch course
db -->> ctx--:9. Return query results
ctx -->> repo--:10. Return course entity
repo -->> sv--:11. Return course entity

alt Course Not Found
    sv -->> be_ctrl:11.1. throw KeyNotFoundException
    be_ctrl -->> fe_ctrl:11.1.1. Return statusCode 404
    fe_ctrl -->> view:11.1.2. Return JSON (success=false)
    view -->> act:11.1.3. Display course not found message
else Course Found
alt Not Course Owner
        sv -->> be_ctrl:11.2.1. throw UnauthorizedAccessException
        be_ctrl -->> fe_ctrl:11.2.1.1. Return statusCode 403
        fe_ctrl -->> view:11.2.1.2. Return JSON (success=false)
        view -->> act:11.2.1.3. Display unauthorized message
else Is Course Owner
        sv -> lockout_repo++:11.2.2. Call GetActiveLockoutAsync(instructorId, "instructor")
        lockout_repo -->> sv--:11.2.2.1. Return activeLockout
        
alt Account is locked out
            sv -->> be_ctrl:11.2.2.1.1. throw BadRequestException
            be_ctrl -->> fe_ctrl:11.2.2.1.1.1. Return statusCode 400
            fe_ctrl -->> view:11.2.2.1.1.2. Return JSON (success=false)
            view -->> act:11.2.2.1.1.3. Display lockout restriction message
else Account is active
            sv -->> sv--:11.2.2.1.2. Return valid course entity
            
            sv -> sv++:11.2.2.1.2.1. Set course.CourseStatus = "hidden"
            sv--
            
            sv -> repo++:11.2.2.1.2.2. Call Update(course)
            repo -->> sv--:11.2.2.1.2.3. Return tracking state
            
            sv -> repo++:11.2.2.1.2.4. Call SaveChangesAsync()
            repo -> ctx++:11.2.2.1.2.5. Save changes to database
            ctx -> db++:11.2.2.1.2.6. Update Course Status
            
alt Database Save Failure
                db -->> ctx:11.2.2.1.2.6.1. throw DbUpdateException
                ctx -->> repo:11.2.2.1.2.6.1.1. throw DbUpdateException
                repo -->> sv:11.2.2.1.2.6.1.2. throw DbUpdateException
                sv -->> be_ctrl:11.2.2.1.2.6.1.3. throw DbUpdateException
                be_ctrl -->> fe_ctrl:11.2.2.1.2.6.1.4. Return statusCode 500
                fe_ctrl -->> view:11.2.2.1.2.6.1.5. Return JSON (success=false)
                view -->> act:11.2.2.1.2.6.1.6. Display server error message
else Database Save Success
                db -->> ctx--:11.2.2.1.2.6.2. Return returnCode
                ctx -->> repo--:11.2.2.1.2.6.2.1. Return numberOfRowsAffected
                repo -->> sv--:11.2.2.1.2.6.2.2. Return numberOfRowsAffected
                
                sv -> redis++:11.2.2.1.2.6.2.3. Call RemoveCacheAsync(cacheKey)
                redis -->> sv--:11.2.2.1.2.6.2.4. Return
                
                sv -->> be_ctrl--:11.2.2.1.2.6.2.5. Return success
                be_ctrl -->> fe_ctrl--:11.2.2.1.2.6.2.6. Return statusCode 200
                fe_ctrl -->> view--:11.2.2.1.2.6.2.7. Return JSON (success=true)
                view -->> act--:11.2.2.1.2.6.2.8. Display course hidden successfully
end
end
end
end
