@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Restore learning materials

actor Instructor as act
participant "TrashBinPage" as view
participant "LessonController" as fe_ctrl <<frontend controller>>
participant "LessonController" as be_ctrl <<backend controller>>
participant ":LessonService" as sv
participant ":IFileStorageService" as storage_sv
participant ":IMaterialRepository" as repo
participant ":ILessonRepository" as lesson_repo
participant ":ICourseRepository" as course_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click Restore
view -> fe_ctrl++:2. POST /Lesson/RestoreMaterial/{materialId}
fe_ctrl -> be_ctrl++:3. POST /api/lessons/materials/{materialId}/restore

be_ctrl -> sv++:4. Call RestoreMaterialAsync(materialId, instructorId)

sv -> repo++:5. Call GetByIdAsync(materialId)
repo -> ctx++:6. Execute query
ctx -> db++:7. Fetch material
db -->> ctx--:8. Return query results
ctx -->> repo--:9. Return material entity
repo -->> sv--:10. Return material entity

alt Material Not Found
    sv -->> be_ctrl:10.1. throw Exception
    be_ctrl -->> fe_ctrl:10.1.1. Return statusCode 404
    fe_ctrl -->> view:10.1.2. Return JSON (success=false)
    view -->> act:10.1.3. Display material not found message
else Material Found
    sv -> lesson_repo++:10.2. Call GetByIdAsync(lessonId)
    lesson_repo -->> sv--:10.2.1. Return lesson entity
    
    sv -> sv++:10.2.2. Call ValidateInstructorAndCourseStateAsync()
    sv--
    
opt Course is Published
        sv -> sv++:10.2.2.1. Set course.CourseStatus = "draft"
        sv--
        sv -> course_repo++:10.2.2.1.1. Call Update(course)
        course_repo -->> sv--:10.2.2.1.2. Return
end
    
opt Restoring a Video
        sv -> repo++:10.2.2.2. Call GetMaterialsByLessonIdAsync(lessonId)
        repo -->> sv--:10.2.2.2.1. Return existing materials
        
opt Active Video Exists
            sv -> sv++:10.2.2.2.1.3. Call MoveMaterialToTrashAsync(activeVideo)
            sv--
            sv -> repo++:10.2.2.2.1.3.1. Call Update(activeVideo)
            repo -->> sv--:10.2.2.2.1.3.2. Return
end
end
    
opt Has CloudPublicId
        sv -> storage_sv++:10.2.2.4. Call RestoreFileAsync(publicId, fileType)
        storage_sv -->> sv--:10.2.2.4.1. Return result
end
    
    sv -> sv++:10.2.3. Set material.IsRemoved = false and LearningStatus = "active"
    sv--
    
    sv -> repo++:10.2.4. Call Update(material)
    repo -->> sv--:10.2.5. Return tracking state
    
    sv -> repo++:10.2.6. Call SaveChangesAsync()
    repo -> ctx++:10.2.7. Save changes to database
    ctx -> db++:10.2.8. Update Entities
    
alt Database Save Failure
        db -->> ctx:10.2.8.1. throw DbUpdateException
        ctx -->> repo:10.2.8.1.1. throw DbUpdateException
        repo -->> sv:10.2.8.1.2. throw DbUpdateException
        sv -->> be_ctrl:10.2.8.1.3. throw DbUpdateException
        be_ctrl -->> fe_ctrl:10.2.8.1.4. Return statusCode 500
        fe_ctrl -->> view:10.2.8.1.5. Return JSON (success=false)
        view -->> act:10.2.8.1.6. Display server error message
else Database Save Success
        db -->> ctx--:10.2.8.2. Return returnCode
        ctx -->> repo--:10.2.8.2.1. Return numberOfRowsAffected
        repo -->> sv--:10.2.8.2.2. Return numberOfRowsAffected
        
        sv -> sv++:10.2.8.2.3. Call InvalidateCourseCacheAsync(courseId)
        sv--
        
        sv -->> be_ctrl--:10.2.8.2.4. Return success
        be_ctrl -->> fe_ctrl--:10.2.8.2.5. Return statusCode 200
        fe_ctrl -->> view--:10.2.8.2.6. Return JSON (success=true)
        view -->> act--:10.2.8.2.7. Display material restored successfully
end
end
