@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Edit Courses

actor Instructor as act
participant "CourseEditPage" as view
participant "CourseController" as fe_ctrl <<frontend controller>>
participant "CourseController" as be_ctrl <<backend controller>>
participant ":CourseCommandService" as sv
participant ":IRedisCacheService" as redis
participant ":IReviewLockoutRepository" as lockout_repo
participant ":IFileStorageService" as storage_sv
participant ":ICourseRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Modify course info and click Save
view -> fe_ctrl++:2. POST /InstructorCourse/Update/{id}
fe_ctrl -> be_ctrl++:3. PUT /api/courses/{id}

be_ctrl -> sv++:4. Call UpdateCourseAsync(id, request, instructorId)

sv -> repo++:5. Call GetByIdAsync(id)
repo -> ctx++:6. Execute query
ctx -> db++:7. Fetch course
db -->> ctx--:8. Return query results
ctx -->> repo--:9. Return course entity
repo -->> sv--:10. Return course entity

alt Course Not Found
    sv -->> be_ctrl:10.1. throw Exception
    be_ctrl -->> fe_ctrl:10.1.1. Return statusCode 404
    fe_ctrl -->> view:10.1.2. Return JSON (success=false)
    view -->> act:10.1.3. Display course not found message
else Course Found
alt Not Course Owner
        sv -->> be_ctrl:10.2.1. throw UnauthorizedAccessException
        be_ctrl -->> fe_ctrl:10.2.1.1. Return statusCode 403
        fe_ctrl -->> view:10.2.1.2. Return JSON (success=false)
        view -->> act:10.2.1.3. Display unauthorized message
else Is Course Owner
        sv -> lockout_repo++:10.2.2. Call GetActiveLockoutAsync(instructorId, "instructor")
        lockout_repo -->> sv--:10.2.2.1. Return activeLockout
        
alt Account is locked out
            sv -->> be_ctrl:10.2.2.1.1. throw BadRequestException
            be_ctrl -->> fe_ctrl:10.2.2.1.1.1. Return statusCode 400
            fe_ctrl -->> view:10.2.2.1.1.2. Return JSON (success=false)
            view -->> act:10.2.2.1.1.3. Display lockout restriction message
else Account is active
alt Archived and Flagged >= 3
                sv -->> be_ctrl:10.2.2.1.2.1. throw BadRequestException
                be_ctrl -->> fe_ctrl:10.2.2.1.2.1.1. Return statusCode 400
                fe_ctrl -->> view:10.2.2.1.2.1.2. Return JSON (success=false)
                view -->> act:10.2.2.1.2.1.3. Display permanently discontinued message
else Pending Review
                sv -->> be_ctrl:10.2.2.1.2.2. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:10.2.2.1.2.2.1. Return statusCode 400
                fe_ctrl -->> view:10.2.2.1.2.2.2. Return JSON (success=false)
                view -->> act:10.2.2.1.2.2.3. Display pending review message
else Can Edit
opt Has New Thumbnail File
                    sv -> storage_sv++:10.2.2.1.2.3.1. Call UploadFileAsync(ThumbnailFile)
                    storage_sv -->> sv--:10.2.2.1.2.3.1.1. Return thumbnailUrl
end
                
                sv -> sv++:10.2.2.1.2.4. Call SanitizeHtml(description)
                sv--
                
                sv -> sv++:10.2.2.1.2.5. Update course properties and set Status=Pending
                sv--
                
                sv -> sv++:10.2.2.1.2.6. Call AddCourseFingerprintAsync(course)
                sv--
                
                sv -> repo++:10.2.2.1.2.7. Call Update(course)
                repo -->> sv--:10.2.2.1.2.8. Return tracking state
                
                sv -> repo++:10.2.2.1.2.9. Call SaveChangesAsync()
                repo -> ctx++:10.2.2.1.2.10. Save changes to database
                ctx -> db++:10.2.2.1.2.11. Update Course
                
alt Database Save Failure
                    db -->> ctx:10.2.2.1.2.11.1. throw DbUpdateException
                    ctx -->> repo:10.2.2.1.2.11.1.1. throw DbUpdateException
                    repo -->> sv:10.2.2.1.2.11.1.2. throw DbUpdateException
                    sv -->> be_ctrl:10.2.2.1.2.11.1.3. throw DbUpdateException
                    be_ctrl -->> fe_ctrl:10.2.2.1.2.11.1.4. Return statusCode 500
                    fe_ctrl -->> view:10.2.2.1.2.11.1.5. Return JSON (success=false)
                    view -->> act:10.2.2.1.2.11.1.6. Display server error message
else Database Save Success
                    db -->> ctx--:10.2.2.1.2.11.2. Return returnCode
                    ctx -->> repo--:10.2.2.1.2.11.2.1. Return numberOfRowsAffected
                    repo -->> sv--:10.2.2.1.2.11.2.2. Return numberOfRowsAffected
                    
                    sv -> redis++:10.2.2.1.2.11.2.3. Call RemoveCacheAsync(cacheKey)
                    redis -->> sv--:10.2.2.1.2.11.2.4. Return
                    
                    sv -->> be_ctrl--:10.2.2.1.2.11.2.5. Return CourseResponse object
                    be_ctrl -->> fe_ctrl--:10.2.2.1.2.11.2.6. Return statusCode 200
                    fe_ctrl -->> view--:10.2.2.1.2.11.2.7. Return JSON (success=true)
                    view -->> act--:10.2.2.1.2.11.2.8. Display course updated successfully and redirect
end
end
end
end
end
