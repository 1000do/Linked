@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Remove Courses

actor Instructor as act
participant "InstructorDashboardPage" as view
participant "InstructorCourseController" as fe_ctrl <<frontend controller>>
participant "CourseController" as be_ctrl <<backend controller>>
participant ":CourseCommandService" as sv
participant ":IReviewLockoutRepository" as lockout_repo
participant ":ICourseRepository" as repo
participant ":ILessonRepository" as lesson_repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click Delete Course
view -> fe_ctrl++:2. POST /InstructorCourse/Delete/{id}
fe_ctrl -> be_ctrl++:3. DELETE /api/courses/{id}

be_ctrl -> sv++:4. Call DeleteCourseAsync(id, instructorId)

sv -> repo++:5. Call GetByIdAsync(id)
repo -> ctx++:6. Execute query
ctx -> db++:7. Fetch course
db -->> ctx--:8. Return query results
ctx -->> repo--:9. Return course entity
repo -->> sv--:10. Return course entity

alt Course Not Found
    sv -->> be_ctrl:10.1. throw Exception
    be_ctrl -->> fe_ctrl:10.1.1. Return statusCode 404
    fe_ctrl -->> view:10.1.2. Return JSON (success=false)
    view -->> act:10.1.3. Display course not found message
else Course Found
alt Not Course Owner
        sv -->> be_ctrl:10.2.1. throw UnauthorizedAccessException
        be_ctrl -->> fe_ctrl:10.2.1.1. Return statusCode 403
        fe_ctrl -->> view:10.2.1.2. Return JSON (success=false)
        view -->> act:10.2.1.3. Display unauthorized message
else Is Course Owner
        sv -> lockout_repo++:10.2.2. Call GetActiveLockoutAsync(instructorId, "instructor")
        lockout_repo -->> sv--:10.2.2.1. Return activeLockout
        
alt Account is locked out
            sv -->> be_ctrl:10.2.2.1.1. throw BadRequestException
            be_ctrl -->> fe_ctrl:10.2.2.1.1.1. Return statusCode 400
            fe_ctrl -->> view:10.2.2.1.1.2. Return JSON (success=false)
            view -->> act:10.2.2.1.1.3. Display lockout restriction message
else Account is active
alt Archived and Flagged >= 3
                sv -->> be_ctrl:10.2.2.1.2.1. throw BadRequestException
                be_ctrl -->> fe_ctrl:10.2.2.1.2.1.1. Return statusCode 400
                fe_ctrl -->> view:10.2.2.1.2.1.2. Return JSON (success=false)
                view -->> act:10.2.2.1.2.1.3. Display permanently discontinued message
else Pending Review
                sv -->> be_ctrl:10.2.2.1.2.2. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:10.2.2.1.2.2.1. Return statusCode 400
                fe_ctrl -->> view:10.2.2.1.2.2.2. Return JSON (success=false)
                view -->> act:10.2.2.1.2.2.3. Display pending review message
else Can Delete
                sv -> repo++:10.2.2.1.2.3. Call HasEnrollmentsAsync(id)
                repo -->> sv--:10.2.2.1.2.3.1. Return hasEnrollments flag
                
alt hasEnrollments == true
                    sv -->> be_ctrl:10.2.2.1.2.3.1.1. throw BadRequestException
                    be_ctrl -->> fe_ctrl:10.2.2.1.2.3.1.1.1. Return statusCode 400
                    fe_ctrl -->> view:10.2.2.1.2.3.1.1.2. Return JSON (success=false)
                    view -->> act:10.2.2.1.2.3.1.1.3. Display active students error message
else hasEnrollments == false
                    sv -> sv++:10.2.2.1.2.3.1.2. Set course.IsRemoved = true
                    sv--
                    
                    sv -> lesson_repo++:10.2.2.1.2.3.1.2.1. Call GetByCourseIdAsync(id)
                    lesson_repo -->> sv--:10.2.2.1.2.3.1.2.2. Return lessons
                    
                    sv -> sv++:10.2.2.1.2.3.1.2.3. Soft delete course and cascade to lessons
                    sv--
                    
                    sv -> repo++:10.2.2.1.2.3.1.2.4. Call SaveChangesAsync()
                    repo -> ctx++:10.2.2.1.2.3.1.2.5. Save changes to database
                    ctx -> db++:10.2.2.1.2.3.1.2.6. Update entities (Soft Delete)
                    
alt Database Save Failure
                        db -->> ctx:10.2.2.1.2.3.1.2.6.1. throw DbUpdateException
                        ctx -->> repo:10.2.2.1.2.3.1.2.6.1.1. throw DbUpdateException
                        repo -->> sv:10.2.2.1.2.3.1.2.6.1.2. throw DbUpdateException
                        sv -->> be_ctrl:10.2.2.1.2.3.1.2.6.1.3. throw DbUpdateException
                        be_ctrl -->> fe_ctrl:10.2.2.1.2.3.1.2.6.1.4. Return statusCode 500
                        fe_ctrl -->> view:10.2.2.1.2.3.1.2.6.1.5. Return JSON (success=false)
                        view -->> act:10.2.2.1.2.3.1.2.6.1.6. Display server error message
else Database Save Success
                        db -->> ctx--:10.2.2.1.2.3.1.2.6.2. Return returnCode
                        ctx -->> repo--:10.2.2.1.2.3.1.2.6.2.1. Return numberOfRowsAffected
                        repo -->> sv--:10.2.2.1.2.3.1.2.6.2.2. Return numberOfRowsAffected
                        
                        sv -->> be_ctrl--:10.2.2.1.2.3.1.2.6.2.3. Return success
                        be_ctrl -->> fe_ctrl--:10.2.2.1.2.3.1.2.6.2.4. Return statusCode 200
                        fe_ctrl -->> view--:10.2.2.1.2.3.1.2.6.2.5. Return JSON (success=true)
                        view -->> act--:10.2.2.1.2.3.1.2.6.2.6. Display course deleted successfully
end
end
end
end
end
end
