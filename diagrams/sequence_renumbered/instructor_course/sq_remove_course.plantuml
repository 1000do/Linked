@startuml RemoveCourse
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Remove Course
actor Instructor as act

participant "InstructorCourseListView" as view
participant "InstructorCourseController" as fe_ctrl <<frontend controller>>
participant "CourseController" as be_ctrl <<backend controller>>

participant ":CourseCommandService" as sv
participant ":LockoutRepository" as lock_repo
participant ":CourseRepository" as repo
participant ":LessonRepository" as lesson_repo
participant ":RedisService" as redis
participant ":AppDbContext" as ctx

database Database as db

act++
act->view++:1. Click "Delete" button of a course
view->view++:2. Show deletion confirmation dialog
view--
group opt [Instructor cancels deletion]
    view-->>act:2.1. Close confirmation dialog
end

act->view:3. Confirm course deletion
view->fe_ctrl++:4. Send AJAX POST request to InstructorCourse/Delete/{id}

fe_ctrl->be_ctrl++:5. Send DELETE request to /api/courses/{id}
be_ctrl->be_ctrl++:6. Call GetInstructorId()
be_ctrl--
be_ctrl->sv++:7. Call DeleteCourseAsync(id, instructorId)

sv->repo++:8. Call GetByIdAsync(courseId)
repo->ctx++:9. Call FindAsync(courseId)
ctx->db++:10. Query Course by courseId
db-->>ctx--:11. Return course or null
ctx-->>repo--:12. Return course or null
repo-->>sv--:13. Return course or null

sv->lock_repo++:14. Call GetActiveLockoutAsync(instructorId, "instructor")
lock_repo->ctx++:15. Call GetActiveLockoutAsync()
ctx->db++:16. Query active lockout
db-->>ctx--:17. Return activeLockout or null
ctx-->>lock_repo--:18. Return activeLockout or null
lock_repo-->>sv--:19. Return activeLockout or null

sv->repo++:20. Call HasEnrollmentsAsync(courseId)
repo->ctx++:21. Call AnyAsync()
ctx->db++:22. Query course enrollments
db-->>ctx--:23. Return hasEnrollments (true/false)
ctx-->>repo--:24. Return hasEnrollments
repo-->>sv--:25. Return hasEnrollments

sv->sv++:26. Validate course removal request
sv--

alt Course Not Found
    sv-->>be_ctrl:26.1. throw Exception
    be_ctrl-->>fe_ctrl:26.1.1. Return statusCode 404
    fe_ctrl-->>view:26.1.2. Return statusCode 404
    view-->>act:26.1.3. Display error message
else Invalid Instructor Rights
    sv-->>be_ctrl:26.2. throw BadRequestException
    be_ctrl-->>fe_ctrl:26.2.1. Return statusCode 400
    fe_ctrl-->>view:26.2.2. Return statusCode 400
    view-->>act:26.2.3. Display error message
else Invalid Course Status
    sv-->>be_ctrl:26.3. throw InvalidOperationException
    be_ctrl-->>fe_ctrl:26.3.1. Return statusCode 400
    fe_ctrl-->>view:26.3.2. Return statusCode 400
    view-->>act:26.3.3. Display error message
else Course Has Active Enrollments
    sv-->>be_ctrl:26.4. throw BadRequestException
    be_ctrl-->>fe_ctrl:26.4.1. Return statusCode 400
    fe_ctrl-->>view:26.4.2. Return statusCode 400
    view-->>act:26.4.3. Display error message
else Valid course removal request
    sv->sv++:26.5. Mark course as removed (IsRemoved = true)
    sv--
    
    sv->sv++:26.5.1. RemoveLessonsInCourse()
    sv--
    
    
    sv->repo++:26.5.2. Call Update(course)
    repo-->>sv--:26.5.3. Return result
    
    sv->repo++:26.5.4. Call SaveChangesAsync()
    repo->ctx++:26.5.5. Call SaveChangesAsync()
    ctx->db++:26.5.6. Save changes to Database
    db-->>ctx--:26.5.7. Return numberOfRowsAffected
    ctx-->>repo--:26.5.8. Return numberOfRowsAffected
    repo-->>sv--:26.5.9. Return numberOfRowsAffected
    
    sv->sv++:26.5.10. Check numberOfRowsAffected
    sv--
    
alt numberOfRowsAffected > 0
        sv->redis++:26.5.10.1. Call RemoveCacheAsync(courseKey)
        redis-->>sv--:26.5.10.1.1. Return result
        
        sv-->>be_ctrl:26.5.10.1.2. Return result
        be_ctrl-->>fe_ctrl:26.5.10.1.3. Return statusCode 200
        fe_ctrl-->>view:26.5.10.1.4. Return statusCode 200
        view-->>act:26.5.10.1.5. Display success message
else numberOfRowsAffected = 0
        sv-->>be_ctrl--:26.5.10.2. throw InvalidOperationException
        be_ctrl-->>fe_ctrl--:26.5.10.2.1. Return statusCode 400
        fe_ctrl-->>view--:26.5.10.2.2. Return statusCode 400
        view-->>act--:26.5.10.2.3. Display error message
end
end

@enduml
