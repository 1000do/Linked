@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Delete Quiz

actor Instructor as act
participant "QuizListPage" as view
participant "QuizController" as fe_ctrl <<frontend controller>>
participant "QuizController" as be_ctrl <<backend controller>>
participant ":QuizService" as sv
participant ":IQuizRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click Delete Quiz
view -> fe_ctrl++:2. POST /Quiz/SoftDelete/{id}
fe_ctrl -> be_ctrl++:3. DELETE /api/quizzes/{id}

be_ctrl -> sv++:4. Call SoftDeleteQuizAsync(id, instructorId)

sv -> repo++:5. Call GetByIdAsync(id)
repo -> ctx++:6. Execute query
ctx -> db++:7. Fetch quiz
db -->> ctx--:8. Return query results
ctx -->> repo--:9. Return quiz entity
repo -->> sv--:10. Return quiz entity

alt Quiz Not Found
    sv -->> be_ctrl:10.1. throw KeyNotFoundException
    be_ctrl -->> fe_ctrl:10.1.1. Return statusCode 404
    fe_ctrl -->> view:10.1.2. Return JSON (success=false)
    view -->> act:10.1.3. Display quiz not found message
else Quiz Found
    sv -> sv++:10.2. Call EnsureOwnership(quiz, instructorId)
    sv--
    
alt Not Quiz Owner
        sv -->> be_ctrl:10.2.1. throw UnauthorizedAccessException
        be_ctrl -->> fe_ctrl:10.2.1.1. Return statusCode 403
        fe_ctrl -->> view:10.2.1.2. Return JSON (success=false)
        view -->> act:10.2.1.3. Display unauthorized message
else Is Quiz Owner
        sv -> repo++:10.2.2. Call HasActiveAttemptsAsync(id)
        repo -->> sv--:10.2.2.1. Return hasActiveAttempts
        
alt hasActiveAttempts == true
            sv -->> be_ctrl:10.2.2.1.1. throw InvalidOperationException
            be_ctrl -->> fe_ctrl:10.2.2.1.1.1. Return statusCode 400
            fe_ctrl -->> view:10.2.2.1.1.2. Return JSON (success=false)
            view -->> act:10.2.2.1.1.3. Display active students error message
else No Active Attempts
            sv -> repo++:10.2.2.1.2. Call IsQuizInEnrolledCourseAsync(id)
            repo -->> sv--:10.2.2.1.2.1. Return isEnrolled
            
alt isEnrolled == true
                sv -->> be_ctrl:10.2.2.1.2.1.1. throw InvalidOperationException
                be_ctrl -->> fe_ctrl:10.2.2.1.2.1.1.1. Return statusCode 400
                fe_ctrl -->> view:10.2.2.1.2.1.1.2. Return JSON (success=false)
                view -->> act:10.2.2.1.2.1.1.3. Display enrolled course error message
else Can Delete
                sv -> repo++:10.2.2.1.2.1.2. Call SoftDeleteAsync(id)
                repo -> ctx++:10.2.2.1.2.1.2.1. Update IsRemoved = true
                ctx -> db++:10.2.2.1.2.1.2.2. Update Quiz Record
                
alt Database Save Failure
                    db -->> ctx:10.2.2.1.2.1.2.2.1. throw DbUpdateException
                    ctx -->> repo:10.2.2.1.2.1.2.2.1.1. throw DbUpdateException
                    repo -->> sv:10.2.2.1.2.1.2.2.1.2. throw DbUpdateException
                    sv -->> be_ctrl:10.2.2.1.2.1.2.2.1.3. throw DbUpdateException
                    be_ctrl -->> fe_ctrl:10.2.2.1.2.1.2.2.1.4. Return statusCode 500
                    fe_ctrl -->> view:10.2.2.1.2.1.2.2.1.5. Return JSON (success=false)
                    view -->> act:10.2.2.1.2.1.2.2.1.6. Display server error message
else Database Save Success
                    db -->> ctx--:10.2.2.1.2.1.2.2.2. Return returnCode
                    ctx -->> repo--:10.2.2.1.2.1.2.2.2.1. Return numberOfRowsAffected
                    repo -->> sv--:10.2.2.1.2.1.2.2.2.2. Return numberOfRowsAffected
                    
                    sv -->> be_ctrl--:10.2.2.1.2.1.2.2.2.3. Return success
                    be_ctrl -->> fe_ctrl--:10.2.2.1.2.1.2.2.2.4. Return statusCode 200
                    fe_ctrl -->> view--:10.2.2.1.2.1.2.2.2.5. Return JSON (success=true)
                    view -->> act--:10.2.2.1.2.1.2.2.2.6. Display quiz deleted successfully
end
end
end
end
end
