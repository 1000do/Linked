@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe View list of removed learning materials

actor Instructor as act
participant "TrashBinPage" as view
participant "LessonController" as fe_ctrl <<frontend controller>>
participant "LessonController" as be_ctrl <<backend controller>>
participant ":LessonService" as sv
participant ":MaterialTrashResponse" as res
participant ":IMaterialRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. View Trash Bin
view -> fe_ctrl++:2. GET /Lesson/TrashMaterials
fe_ctrl -> be_ctrl++:3. GET /api/lessons/materials/trash

be_ctrl -> sv++:4. Call GetTrashMaterialsAsync(instructorId)

sv -> repo++:5. Call GetTrashMaterialsAsync(instructorId)
repo -> ctx++:6. Execute query
ctx -> db++:7. Fetch removed materials
db -->> ctx--:8. Return query results
ctx -->> repo--:9. Return material entities
repo -->> sv--:10. Return material entities

sv -> sv++:11. Map materials to MaterialTrashResponse DTOs
sv--

sv -> res++:12. Call MaterialTrashResponse()
res -->> sv--:13. Return List<MaterialTrashResponse>

sv -->> be_ctrl--:14. Return List<MaterialTrashResponse>
be_ctrl -->> fe_ctrl--:15. Return statusCode 200
fe_ctrl -->> view--:16. Return View(MaterialTrashViewModel)
view -->> act--:17. Display list of removed materials
