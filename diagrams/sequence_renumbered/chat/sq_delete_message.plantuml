@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox
mainframe Delete Message

actor User as act
participant "ChatRoom" as view
participant "ErrorPage" as error_page
participant "ChatController" as fe_ctrl <<frontend controller>>
participant "ChatController" as be_ctrl <<backend controller>>
participant ":IChatService" as sv
participant ":IChatRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act ++
act -> view++:1. Click "Delete for me"
view -> view++:2. deleteMsg(messageId)
view--
view -> fe_ctrl++:3. DELETE /Chat/DeleteMessage?messageId={id}
fe_ctrl -> be_ctrl++:4. DELETE /api/chat/message/{id}
be_ctrl -> sv++:5. Call DeleteMessageAsync(messageId, accountId)

sv -> repo++:6. Call GetMessageByIdAsync(messageId)
repo -> ctx++:7. FindAsync(messageId)
ctx -> db++:8. Execute query
db -->> ctx--:9. Return data
ctx -->> repo--:10. Return Entity object
repo -->> sv--:11. Return Message object

alt Message found and is Sender
    sv -> sv++:11.1. Update message.MessageStatus = "deleted_by_sender"
    sv--
    sv -> repo++:11.1.1. Call SaveChangesAsync()
    repo -> ctx++:11.1.2. SaveChangesAsync()
    ctx -> db++:11.1.3. Save changes to database
    db -->> ctx--:11.1.4. Return numberOfRowsAffected
    ctx -->> repo--:11.1.5. Return numberOfRowsAffected
    repo -->> sv--:11.1.6. Return numberOfRowsAffected
    
    sv -> sv++:11.1.7. Check numberOfRowsAffected
    sv--
    
alt numberOfRowsAffected > 0
        sv -->> be_ctrl:11.1.7.1. Return chatId
        
        be_ctrl -> be_ctrl++:11.1.7.1.1. Broadcast "MessageDeleted" to User_{accountId} via SignalR
        be_ctrl--
        
        be_ctrl -->> fe_ctrl:11.1.7.1.2. Return statusCode 200
        fe_ctrl -->> view:11.1.7.1.3. Return statusCode 200
        view -> view++:11.1.7.1.4. Remove message element from DOM
        view--
        view -->> act:11.1.7.1.5. Message is hidden from view
else numberOfRowsAffected = 0
        sv -->> be_ctrl--:11.1.7.2. throw InvalidOperationException
        be_ctrl -->> fe_ctrl--:11.1.7.2.1. Return statusCode 500
        fe_ctrl -->> view--:11.1.7.2.2. Return statusCode 500
        view -->> act--:11.1.7.2.3. Display error message
end
else Message not found
    sv -->> be_ctrl:11.2. throw KeyNotFoundException
    be_ctrl -->> fe_ctrl:11.2.1. Return statusCode 404
    fe_ctrl -->> view:11.2.2. Return statusCode 404
    view -->> act:11.2.3. Display error message
else Unauthorized (Not sender)
    sv -->> be_ctrl:11.3. throw UnauthorizedAccessException
    be_ctrl -->> fe_ctrl:11.3.1. Return statusCode 403
    fe_ctrl-->>error_page++:11.3.2. Redirect to ErrorPage
    error_page-->>act--:11.3.3. Display error message
end
@enduml
