@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe View Chat List

actor User as act
participant "ChatIndexPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_page
participant "ChatController" as fe_ctrl <<frontend controller>>
participant "ChatController" as be_ctrl <<backend controller>>
participant ":IChatService" as sv
participant ":ChatListDto" as chat_dto
participant ":IRedisService" as redis
participant ":IChatRepository" as repo
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Access Chat page
view->fe_ctrl++:2. GET /Chat/Index

alt AccessToken cookie is missing
    fe_ctrl -->> login_view:2.1. Redirect to LoginPage
    activate login_view
    login_view -->> act--:2.1.1. Display Login page
else AccessToken cookie exists
    fe_ctrl-->>view:2.2. Return View
    view->view++:2.2.1. loadChats()
    view--
    
    view->fe_ctrl:2.2.2. GET /Chat/GetList
    
    fe_ctrl -> fe_ctrl++:2.2.3. Validate actor's authentication and authorization
    fe_ctrl--
    
alt Session Invalid
        fe_ctrl -->> login_view:2.2.3.1. Redirect to LoginPage
        activate login_view
        login_view -->> act--:2.2.3.1.1. Display login form
else Unauthorized Access
        fe_ctrl -->> error_page:2.2.3.2. Redirect to ErrorPage
        activate error_page
        error_page -->> act--:2.2.3.2.1. Display error message
else Valid actor's authentication and authorization
        fe_ctrl->be_ctrl++:2.2.3.3. GET /api/chat/list
        
        be_ctrl->sv++:2.2.3.3.1. Call GetMyChatsAsync(accountId)
        
        sv->repo++:2.2.3.3.2. Call GetParticipantsByAccountIdAsync(accountId)
        repo->ctx++:2.2.3.3.3. Call GetParticipantsByAccountIdAsync(accountId)
        ctx->db++:2.2.3.3.4. Execute SELECT query
        
        db-->>ctx--:2.2.3.3.5. Return participants list
        ctx-->>repo--:2.2.3.3.6. Return List<ChatParticipant>
        repo-->>sv--:2.2.3.3.7. Return List<ChatParticipant>
        
loop for each ChatParticipant in participants
            sv->redis++:2.2.3.3.8. Call GetUnreadCountAsync(accountId, chatId)
            redis-->>sv--:2.2.3.3.9. Return unreadCount
            
            sv->redis++:2.2.3.3.10. Call IsUserOnlineAsync(partnerId)
            redis-->>sv--:2.2.3.3.11. Return isOnline
end
        
        sv->chat_dto++:2.2.3.3.12. Call ChatListDto()
        
        chat_dto-->>sv--:2.2.3.3.13. Return ChatListDto items
        
        sv-->>be_ctrl--:2.2.3.3.14. Return List<ChatListDto>
        be_ctrl-->>fe_ctrl--:2.2.3.3.15. Return statusCode 200 (Ok)
        fe_ctrl-->>view--:2.2.3.3.16. Return JSON Chat List
        
        view->view++:2.2.3.3.17. renderChatList(chats)
        view--
        
        view-->>act--:2.2.3.3.18. Display conversation list with online statuses and unread counts
end
end


@enduml
