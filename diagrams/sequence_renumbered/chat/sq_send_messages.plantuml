@startuml
<style>
    sequenceDiagram{
        FontSize 16

        arrow {
            ' Set the maximum width of the text on arrows
            MaximumWidth 300

        }
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Send Messages

actor User as act
participant "ChatIndexPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_page
participant "ChatController" as fe_ctrl <<frontend controller>>
participant "ChatController" as be_ctrl <<backend controller>>
participant "ChatAttachmentController" as be_att_ctrl <<backend controller>>
participant ":ICloudinaryUploadService" as upload_sv
participant "ChatHub" as hub
participant ":IChatService" as sv
participant ":Message" as msg_ett
participant ":MessageAttachment" as msg_att_ett
participant ":MessageDto" as msg_dto
participant ":IChatRepository" as repo
participant ":IUserRepository" as user_repo
participant ":IRedisService" as redis
participant ":AppDbContext" as ctx
database Database as db

act++

alt Send Message in Existing Chat
    act->view++:0.1. Enter message text
    act->view:0.1.1. Select files (Optional)
    act->view:0.1.2. Click "Send" button (or press Enter)
    
opt With Attachments
loop for each selected file f
        view->fe_ctrl++:0.1.2.1. POST /Chat/UploadAttachment
        
        fe_ctrl -> fe_ctrl++:0.1.2.1.1. Validate attachment upload
        fe_ctrl--
        
alt Session Invalid
            fe_ctrl -->> login_view:0.1.2.1.1.1. Redirect to LoginPage
            activate login_view
            login_view -->> act--:0.1.2.1.1.1.1. Display login form
else Unauthorized Access
            fe_ctrl -->> error_page:0.1.2.1.1.2. Redirect to ErrorPage
            activate error_page
            error_page -->> act--:0.1.2.1.1.2.1. Display error message
else File size > 10MB
            fe_ctrl->be_att_ctrl++:0.1.2.1.1.3. POST /api/ChatAttachment/upload
            be_att_ctrl-->>fe_ctrl--:0.1.2.1.1.3.1. Return statusCode 400 (BadRequest)
            fe_ctrl-->>view:0.1.2.1.1.3.2. Return BadRequest
            view-->>act:0.1.2.1.1.3.3. Display file size validation error
else File size <= 10MB
            fe_ctrl->be_att_ctrl++:0.1.2.1.1.4. POST /api/ChatAttachment/upload
            
            be_att_ctrl->upload_sv++:0.1.2.1.1.4.1. Call UploadImageAsync() / UploadVideoAsync() / UploadFileAsync()
            upload_sv->upload_sv++:0.1.2.1.1.4.2. Upload to Cloudinary
            upload_sv--
            upload_sv-->>be_att_ctrl--:0.1.2.1.1.4.3. Return SecureUrl
            
            be_att_ctrl-->>fe_ctrl--:0.1.2.1.1.4.4. Return statusCode 200 (Ok) with metadata
            fe_ctrl-->>view--:0.1.2.1.1.4.5. Return JSON with attachment metadata
            view-->>act:0.1.2.1.1.4.6. Display uploaded file in UI
end
end
end

view->view++:0.1.3. sendMsg()
view--

view->hub++:0.1.4. Invoke SendMessage(dto) via SignalR
hub->hub++:0.1.5. GetAccountId()
hub--

hub->sv++:0.1.6. Call SaveMessageAsync(senderId, dto)
    sv->sv++:0.1.7. Call ValidateMessageSendingAccessAsync(senderId, dto.ChatId)
    sv--

alt isParticipant == false
    sv-->>hub:0.1.7.1. Throw UnauthorizedAccessException
    hub->hub++:0.1.7.1.1. Send error message to Caller
    hub--
    hub-->>view:0.1.7.1.2. Send error event via SignalR
    view-->>act:0.1.7.1.3. Display permission error message
else Valid Permissions
    sv->msg_ett++:0.1.7.2. Call Message(dto)
    msg_ett-->>sv--:0.1.7.2.1. Return Message object
    
opt EnableAttachments == true && dto.Attachments is not empty
        sv->msg_att_ett++:0.1.7.2.1.2. Call MessageAttachment()
        msg_att_ett-->>sv--:0.1.7.2.1.2.1. Return MessageAttachments list
end
    
    sv->repo++:0.1.7.2.2. Call AddMessageAsync(message)
    repo->ctx++:0.1.7.2.3. Call AddAsync(message)
    ctx-->>repo--:0.1.7.2.4. Return success
    repo-->>sv--:0.1.7.2.5. Return success
    
    sv->sv++:0.1.7.2.6. Call UpdateChatAndNotifyRecipientsAsync(senderId, dto.ChatId, message.SentAt)
    sv->redis++:0.1.7.2.7. Call IncrementUnreadCountAsync(accountId, chatId)
    redis-->>sv--:0.1.7.2.8. Return
    sv--
    
    sv->repo++:0.1.7.2.9. Call SaveChangesAsync()
    repo->ctx++:0.1.7.2.10. Call SaveChangesAsync()
    ctx->db++:0.1.7.2.11. Save changes (Execute INSERT & UPDATE statements)
    
alt Database Save Failure
        db-->>ctx:0.1.7.2.11.1. Throw DbUpdateException
        ctx-->>repo:0.1.7.2.11.1.1. Throw DbUpdateException
        repo-->>sv:0.1.7.2.11.1.2. Throw DbUpdateException
        sv-->>hub:0.1.7.2.11.1.3. Throw DbUpdateException
        hub->hub++:0.1.7.2.11.1.4. Send error message to Caller
        hub--
        hub-->>view:0.1.7.2.11.1.5. Send error event via SignalR
        view-->>act:0.1.7.2.11.1.6. Display database error message
else Database Save Success
        db-->>ctx--:0.1.7.2.11.2. Return result
        ctx-->>repo--:0.1.7.2.11.2.1. Return result
        repo-->>sv--:0.1.7.2.11.2.2. Return result
        
        sv->user_repo++:0.1.7.2.11.2.3. Call GetByIdAsync(senderId)
        user_repo->ctx++:0.1.7.2.11.2.4. Call GetByIdAsync(senderId)
        ctx->db++:0.1.7.2.11.2.5. Execute SELECT query
        db-->>ctx--:0.1.7.2.11.2.6. Return User
        ctx-->>user_repo--:0.1.7.2.11.2.7. Return User
        user_repo-->>sv--:0.1.7.2.11.2.8. Return User
        
        sv->msg_dto++:0.1.7.2.11.2.9. Call MessageDto()
        msg_dto-->>sv--:0.1.7.2.11.2.10. Return MessageDto object
        
        sv-->>hub--:0.1.7.2.11.2.11. Return MessageDto
        
        hub->hub++:0.1.7.2.11.2.12. Broadcast ReceiveMessage to Group Chat ("Chat_{chatId}")
        hub--
        hub-->>view--:0.1.7.2.11.2.13. Broadcast message via SignalR Group
        
        view->view++:0.1.7.2.11.2.14. appendMessage(msg)
        view--
        view->view++:0.1.7.2.11.2.15. scrollToBottom()
        view--
        view-->>act--:0.1.7.2.11.2.16. Display sent message on UI
end

@enduml
