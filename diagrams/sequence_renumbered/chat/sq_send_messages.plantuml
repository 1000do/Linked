@startuml
<style>
    sequenceDiagram{
        actor{
            BackgroundColor white
            LineThickness 1.0
        }
        participant{
            BackgroundColor white
            RoundCorner 0
        }
        database{
            BackgroundColor white
        }
        groupHeader{
            BackgroundColor white
        }
        referenceHeader{
            BackgroundColor white
        }
        reference{
            BackgroundColor white
        }
    }
</style>

hide footbox

mainframe Send Messages

actor User as act
participant "ChatIndexPage" as view
participant "LoginPage" as login_view
participant "ErrorPage" as error_page
participant "ChatController" as fe_ctrl <<frontend controller>>
participant "ChatAttachmentController" as be_att_ctrl <<backend controller>>
participant ":ICloudinaryUploadService" as upload_sv
participant "ChatHub" as hub
participant ":IChatService" as sv
participant ":Message" as msg_ett
participant ":MessageAttachment" as msg_att_ett
participant ":MessageDto" as msg_dto
participant ":IChatRepository" as repo
participant ":IUserRepository" as user_repo
participant ":IRedisService" as redis
participant ":AppDbContext" as ctx
database Database as db

act++
act->view++:1. Enter message text
act->view:2. Select files (Optional)
act->view:3. Click "Send" button (or press Enter)

opt With Attachments
loop for each selected file f
        view->fe_ctrl++:3.1. POST /Chat/UploadAttachment
        
        fe_ctrl -> fe_ctrl++:3.1.1. Validate actor's authentication and authorization
        fe_ctrl--
        
alt Session Invalid
            fe_ctrl -->> login_view:3.1.1.1. Redirect to LoginPage
            activate login_view
            login_view -->> act--:3.1.1.1.1. Display login form
else Unauthorized Access
            fe_ctrl -->> error_page:3.1.1.2. Redirect to ErrorPage
            activate error_page
            error_page -->> act--:3.1.1.2.1. Display error message
else Valid actor's authentication and authorization
            fe_ctrl->be_att_ctrl++:3.1.1.3. POST /api/ChatAttachment/upload
            
            be_att_ctrl->be_att_ctrl++:3.1.1.3.1. Check ChatSettings:EnableAttachments
            be_att_ctrl--
        
alt EnableAttachments = false
            be_att_ctrl-->>fe_ctrl:3.1.1.3.1.1. Return statusCode 400 (BadRequest)
            fe_ctrl-->>view:3.1.1.3.1.1.1. Return BadRequest
            view-->>act:3.1.1.3.1.1.2. Display feature disabled warning
else EnableAttachments = true
alt file size > 10MB
                be_att_ctrl-->>fe_ctrl:3.1.1.3.1.2.1. Return statusCode 400 (BadRequest)
                fe_ctrl-->>view:3.1.1.3.1.2.1.1. Return BadRequest
                view-->>act:3.1.1.3.1.2.1.2. Display file size validation error
else file size <= 10MB
                be_att_ctrl->upload_sv++:3.1.1.3.1.2.2. Call UploadImageAsync() / UploadVideoAsync() / UploadFileAsync()
                upload_sv->upload_sv++:3.1.1.3.1.2.2.1. Upload to Cloudinary
                upload_sv--
                upload_sv-->>be_att_ctrl--:3.1.1.3.1.2.2.2. Return SecureUrl
                
                be_att_ctrl-->>fe_ctrl--:3.1.1.3.1.2.2.3. Return statusCode 200 (Ok) with metadata
                fe_ctrl-->>view--:3.1.1.3.1.2.2.4. Return JSON with attachment metadata
                view-->>act:3.1.1.3.1.2.2.5. Display uploaded file in UI
end
end
end
end
end

view->view++:4. sendMsg()
view--

view->hub++:5. Invoke SendMessage(dto) via SignalR
hub->hub++:6. GetAccountId()
hub--

hub->sv++:7. Call SaveMessageAsync(senderId, dto)
sv->repo++:8. Call IsParticipantAsync(dto.ChatId, senderId)
repo->ctx++:9. Call IsParticipantAsync(chatId, senderId)
ctx->db++:10. Execute SELECT query

db-->>ctx--:11. Return isParticipant
ctx-->>repo--:12. Return isParticipant
repo-->>sv--:13. Return isParticipant

alt isParticipant == false
    sv->repo++:13.1. Call HasActiveReportForChatAsync(dto.ChatId)
    repo->ctx++:13.1.1. Call HasActiveReportForChatAsync(chatId)
    ctx->db++:13.1.2. Execute SELECT query
    db-->>ctx--:13.1.3. Return hasActiveReport
    ctx-->>repo--:13.1.4. Return hasActiveReport
    repo-->>sv--:13.1.5. Return hasActiveReport
end

alt isParticipant == false && hasActiveReport == false
    sv-->>hub:14.1. Throw UnauthorizedAccessException
    hub->hub++:14.1.1. Send error message to Caller
    hub--
    hub-->>view:14.1.2. Send error event via SignalR
    view-->>act:14.1.3. Display permission error message
else Valid Permissions
    sv->msg_ett++:14.2. Call Message(dto)
    msg_ett-->>sv--:14.2.1. Return Message object
    
opt EnableAttachments == true && dto.Attachments is not empty
        sv->msg_att_ett++:14.2.1.2. Call MessageAttachment()
        msg_att_ett-->>sv--:14.2.1.2.1. Return MessageAttachments list
end
    
    sv->repo++:14.2.2. Call AddMessageAsync(message)
    repo->ctx++:14.2.3. Call AddAsync(message)
    ctx-->>repo--:14.2.4. Return success
    repo-->>sv--:14.2.5. Return success
    
    sv->sv++:14.2.6. Update chat.LastMessageAt
    sv--
    
    sv->sv++:14.2.7. Increment unread counts for participants in Redis
    sv--
    
    sv->repo++:14.2.8. Call SaveChangesAsync()
    repo->ctx++:14.2.9. Call SaveChangesAsync()
    ctx->db++:14.2.10. Save changes (Execute INSERT & UPDATE statements)
    
alt Database Save Failure
        db-->>ctx:14.2.10.1. Throw DbUpdateException
        ctx-->>repo:14.2.10.1.1. Throw DbUpdateException
        repo-->>sv:14.2.10.1.2. Throw DbUpdateException
        sv-->>hub:14.2.10.1.3. Throw DbUpdateException
        hub->hub++:14.2.10.1.4. Send error message to Caller
        hub--
        hub-->>view:14.2.10.1.5. Send error event via SignalR
        view-->>act:14.2.10.1.6. Display database error message
else Database Save Success
        db-->>ctx--:14.2.10.2. Return result
        ctx-->>repo--:14.2.10.2.1. Return result
        repo-->>sv--:14.2.10.2.2. Return result
        
        sv->sv++:14.2.10.2.3. Fetch sender details
        sv--
        
        sv->msg_dto++:14.2.10.2.4. Call MessageDto()
        msg_dto-->>sv--:14.2.10.2.5. Return MessageDto object
        
        sv-->>hub--:14.2.10.2.6. Return MessageDto
        
        hub->hub++:14.2.10.2.7. Broadcast ReceiveMessage to Group Chat ("Chat_{chatId}")
        hub--
        hub-->>view--:14.2.10.2.8. Broadcast message via SignalR Group
        
        view->view++:14.2.10.2.9. appendMessage(msg)
        view--
        view->view++:14.2.10.2.10. scrollToBottom()
        view--
        view-->>act--:14.2.10.2.11. Display sent message on UI
end
end

@enduml
