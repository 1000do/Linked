@startuml ViewTransactionDetail_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor #333333
    ArrowColor #333333
}

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class TransactionControllerFE #FFFFFF {
    + Detail(id: int) : Task<IActionResult>
    + InstructorDetail(id: int) : Task<IActionResult>
    + HistoryDetail(id: int) : Task<IActionResult>
}

class TransactionDetailVM #FFFFFF {
    - TransactionId : int
    - StripeSessionId : string?
    - StripePaymentIntentId : string?
    - Date : DateTime?
    - Status : string?
    - Currency : string?
    - BuyerName : string
    - BuyerEmail : string
    - CourseTitle : string
    - CourseThumbnail : string?
    - InstructorName : string
    - InstructorEmail : string
    - GrossAmount : decimal
    - OriginalPrice : decimal
    - DiscountAmount : decimal
    - CouponUsed : bool
    - CouponCode : string?
    - CouponType : string?
    - CouponDiscountValue : decimal?
    - TransferRate : decimal
    - InstructorPayout : decimal
    - PlatformProfit : decimal
    - IsPaid : bool
    - RefundReason : string?
    - RefundAdminNote : string?
    - RefundRequestedAt : DateTime?
}

' ==================== BACKEND - CONTROLLER ====================

class TransactionControllerBE #FFFFFF {
    - _transactionService : ITransactionService
    + GetTransactionDetail(id: int) : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class TransactionDetailDto #FFFFFF {
    - TransactionId : int
    - StripeSessionId : string?
    - StripePaymentIntentId : string?
    - Date : DateTime?
    - Status : string?
    - Currency : string?
    - BuyerName : string
    - BuyerEmail : string
    - CourseTitle : string
    - CourseThumbnail : string?
    - InstructorName : string
    - InstructorEmail : string
    - GrossAmount : decimal
    - OriginalPrice : decimal
    - DiscountAmount : decimal
    - CouponUsed : bool
    - CouponCode : string?
    - CouponType : string?
    - CouponDiscountValue : decimal?
    - TransferRate : decimal
    - InstructorPayout : decimal
    - PlatformProfit : decimal
    - IsPaid : bool
    - RefundReason : string?
    - RefundAdminNote : string?
    - RefundRequestedAt : DateTime?
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction #FFFFFF {
    - TransactionId : int
    - OrderItemId : int?
    - AccountFrom : int?
    - AccountTo : int?
    - Amount : decimal
    - TransferRate : decimal
    - StripeSessionId : string?
    - StripePaymentintentId : string?
    - Currency : string?
    - TransactionsStatus : string?
    - TransactionType : string?
    - TransactionCreatedAt : DateTime?
    - TransactionExt : TransactionExt?
    - OrderItem : OrderItem?
    - AccountFromNavigation : Account?
    - AccountToNavigation : Account?
}

class TransactionExt #FFFFFF {
    - TransactionId : int
    - RefundReason : string?
    - RefundAdminNote : string?
    - RefundRequestedAt : DateTime?
    - Transaction : Transaction
}

class OrderItem #FFFFFF {
    - Id : int
    - OrderId : int?
    - CourseId : int?
    - PurchasePrice : decimal
    - CouponUsed : bool?
    - OriginalPrice : decimal?
    - CouponCode : string?
    - CouponType : string?
    - DiscountAmount : decimal
    - Course : Course?
    - Order : OrderInfo?
}

class InstructorPayout #FFFFFF {
    - PayoutId : int
    - TransactionId : int?
    - PayoutAmount : decimal
    - IsPaid : bool
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface ITransactionService #FFFFFF {
    //+ GetTransactionDetailAsync(transactionId: int) : Task<TransactionDetailDto?>//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface ITransactionRepository #FFFFFF {
    //+ GetTransactionDetailAsync(transactionId: int) : Task<TransactionDetailDto?>//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class TransactionService #FFFFFF {
    - _repo : ITransactionRepository
    + GetTransactionDetailAsync(transactionId: int) : Task<TransactionDetailDto?>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class TransactionRepository #FFFFFF {
    - _context : AppDbContext
    + GetTransactionDetailAsync(transactionId: int) : Task<TransactionDetailDto?>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #FFFFFF {
    + Transactions : DbSet<Transaction>
    + TransactionExts : DbSet<TransactionExt>
    + OrderItems : DbSet<OrderItem>
    + InstructorPayouts : DbSet<InstructorPayout>
}

' ==================== RELATIONSHIPS ====================

' === COMPOSITION (filled diamond) ===
OrderItem -down*-- Transaction
Transaction -down*-- TransactionExt
Transaction -down*-- InstructorPayout

' === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
TransactionControllerFE -down..> TransactionControllerBE
TransactionControllerBE -down--> ITransactionService
TransactionService -down--> ITransactionRepository
TransactionRepository -right--> AppDbContext

' === INTERFACE REALIZATION ===
TransactionService -up..|> ITransactionService
TransactionRepository -up..|> ITransactionRepository

' === DEPENDENCY (dashed arrows) ===
TransactionControllerFE -left..> TransactionDetailVM
TransactionControllerBE -down..> TransactionDetailDto
TransactionService -down..> TransactionDetailDto
TransactionRepository -down..> TransactionDetailDto
TransactionRepository -down..> Transaction

@enduml
