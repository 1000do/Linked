@startuml SearchChatHistory_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor #1A73E8
    ArrowColor #5F6368
}

!define ABSTRACT_COLOR #FFE6CC
!define SERVICE_COLOR #CCE5FF
!define DTO_COLOR #E6CCFF
!define ENTITY_COLOR #CCFFE6
!define REPOSITORY_COLOR #FFFFCC
!define CONTROLLER_COLOR #FFE6E6

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F9F9F9
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class "ChatController" as FrontendChatController <<frontend controller>> #FFE6E6 {
    + Index() : IActionResult
    + Learner() : IActionResult
    + Instructor() : IActionResult
    + Admin() : IActionResult
    - GetActorFromCookie() : string
}

' ==================== BACKEND - CONTROLLER ====================

class "ChatController" as BackendChatController <<backend controller>> #FFE6E6 {
    - _chatService : IChatService
    
    + SearchChats(q: string) : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class ChatListDto #E6CCFF {
    + ChatId : int
    + ChatName : string?
    + ChatType : string?
    + LastMessage : string?
    + LastMessageAt : DateTime?
    + ContextType : string?
    + ContextId : int?
    + UnreadCount : int
    + PartnerName : string?
    + PartnerAvatar : string?
    + PartnerId : int?
    + IsOnline : bool
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class Chat #CCFFE6 {
    + ChatId : int
    + ChatType : string?
    + ContextType : string?
    + ContextId : int?
    + CreatedAt : DateTime?
    + LastMessageAt : DateTime?
    + ChatName : string?
}

class ChatParticipant #CCFFE6 {
    + ChatId : int
    + AccountId : int
    + Role : string?
    + JoinedAt : DateTime?
    + ClearedAt : DateTime?
    + UnreadCount : int
    + LastReadAt : DateTime?
}

class Message #CCFFE6 {
    + MessageId : int
    + ChatId : int
    + SenderId : int
    + Content : string?
    + SentAt : DateTime?
    + IsSeen : bool?
    + MessageStatus : string?
}

class Account #CCFFE6 {
    + AccountId : int
    + Username : string?
    + Email : string
    + AvatarUrl : string?
}

class User #CCFFE6 {
    + UserId : int
    + AccountId : int?
    + FullName : string?
}

class Manager #CCFFE6 {
    + ManagerId : int
    + AccountId : int?
    + DisplayName : string?
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface IChatService #FFE6CC {
    //+ SearchChatsAsync(accountId: int, query: string) : Task<List<ChatListDto>>//
}

interface IRedisService #FFE6CC {
    //+ GetUnreadCountAsync(accountId: int, chatId: int) : Task<int>//
    //+ IsUserOnlineAsync(accountId: int) : Task<bool>//
}

interface IChatRepository #FFE6CC {
    //+ SearchParticipantsByAccountIdAsync(accountId: int, query: string) : Task<List<ChatParticipant>>//
}

interface IUserRepository #FFE6CC {
}

interface ICourseRepository #FFE6CC {
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ChatService #CCE5FF {
    - _chatRepository : IChatRepository
    - _redisService : IRedisService
    - _userRepository : IUserRepository
    - _courseRepository : ICourseRepository
    - _configuration : IConfiguration
    
    + SearchChatsAsync(accountId: int, query: string) : Task<List<ChatListDto>>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ChatRepository #FFFFCC {
    - _context : AppDbContext
    
    + SearchParticipantsByAccountIdAsync(accountId: int, query: string) : Task<List<ChatParticipant>>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #E6F3FF {
    + Chats : DbSet<Chat>
    + ChatParticipants : DbSet<ChatParticipant>
    + Messages : DbSet<Message>
    + Accounts : DbSet<Account>
    + Users : DbSet<User>
    + Managers : DbSet<Manager>
    ---
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) : void
    # OnModelCreating(modelBuilder: ModelBuilder) : void
}

' ==================== RELATIONSHIPS ====================

' === COMPOSITION (filled diamond) ===
Chat *-- ChatParticipant
Chat *-- Message

' === AGGREGATION (hollow diamond) ===
Account o-- User
Account o-- Manager

' === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
BackendChatController --> IChatService
ChatService --> IChatRepository
ChatService --> IRedisService
ChatService --> IUserRepository
ChatService --> ICourseRepository
ChatRepository --> AppDbContext

ChatParticipant --> Account

' === INTERFACE REALIZATION ===
ChatService ..|> IChatService
ChatRepository ..|> IChatRepository

' === DEPENDENCY (dashed arrows) ===
FrontendChatController ..> BackendChatController
BackendChatController ..> ChatListDto
ChatService ..> ChatListDto
ChatService ..> ChatParticipant
ChatRepository ..> ChatParticipant

@enduml
