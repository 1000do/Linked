@startuml ViewChatList_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor #1A73E8
    ArrowColor #5F6368
}

!define ABSTRACT_COLOR #FFE6CC
!define SERVICE_COLOR #CCE5FF
!define DTO_COLOR #E6CCFF
!define ENTITY_COLOR #CCFFE6
!define REPOSITORY_COLOR #FFFFCC
!define CONTROLLER_COLOR #FFE6E6
!define DbContext #E6F3FF

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F9F9F9
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class "ChatController" as ChatControllerFE #FFE6E6 {
    + Index() : IActionResult
    + Learner() : IActionResult
    + Instructor() : IActionResult
    + Admin() : IActionResult
    - GetActorFromCookie() : string
}

' ==================== BACKEND - CONTROLLER ====================

class "ChatController" as ChatControllerBE #FFE6E6 {
    - _chatService : IChatService
    + GetMyChats() : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class ChatListDto #E6CCFF {
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + LastMessage : string?
    + LastMessageAt : DateTime?
    + PartnerName : string?
    + PartnerAvatar : string?
    + ContextType : string?
    + ContextId : int?
    + UnreadCount : int
    + IsOnline : bool
    + PartnerId : int?
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class ChatParticipant #CCFFE6 {
    + ChatId : int <<PK, FK>>
    + AccountId : int <<PK, FK>>
    + Role : string
    + JoinedAt : DateTime
    + ClearedAt : DateTime?
    + UnreadCount : int
    + LastReadAt : DateTime?
}

class Chat #CCFFE6 {
    + ChatId : int <<PK>>
    + ChatName : string?
    + ChatType : string
    + ContextType : string?
    + ContextId : int?
    + CreatedAt : DateTime?
    + LastMessageAt : DateTime?
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface IChatService #FFE6CC {
    //+ GetMyChatsAsync(accountId: int) : Task<List<ChatListDto>>//
}

interface IRedisService #FFE6CC {
    //+ GetUnreadCountAsync(accountId: int, chatId: int) : Task<int>//
    //+ IsUserOnlineAsync(accountId: int) : Task<bool>//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface IChatRepository #FFE6CC {
    //+ GetParticipantsByAccountIdAsync(accountId: int) : Task<List<ChatParticipant>>//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ChatService #CCE5FF {
    - _chatRepository : IChatRepository
    - _redisService : IRedisService
    + GetMyChatsAsync(accountId: int) : Task<List<ChatListDto>>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ChatRepository #FFFFCC {
    - _context : AppDbContext
    + GetParticipantsByAccountIdAsync(accountId: int) : Task<List<ChatParticipant>>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #E6F3FF {
    + ChatParticipants : DbSet<ChatParticipant>
    + Chats : DbSet<Chat>
}

' ==================== RELATIONSHIPS ====================

' === UNIDIRECTIONAL ASSOCIATION ===
ChatControllerBE --> IChatService
ChatService --> IChatRepository
ChatService --> IRedisService
ChatRepository --> AppDbContext
ChatParticipant --> Chat

' === INTERFACE REALIZATION ===
ChatService ..|> IChatService
ChatRepository ..|> IChatRepository

' === DEPENDENCY ===
ChatControllerFE ..> ChatControllerBE : calls via HTTP
ChatControllerBE ..> ChatListDto : uses
ChatService ..> ChatListDto : uses
ChatRepository ..> ChatParticipant : uses

@enduml
