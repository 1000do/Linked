@startuml ViewInstructorCourseList
' Styling & Settings - Simplified for compatibility
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor #333333
    ArrowColor #333333
}
hide empty members

' === PARTICIPANTS ===

' --- Frontend ---
class InstructorCourseController {
    + Index(): IActionResult
}

class InstructorCourseIndexViewModel {
    + Courses: List<InstructorCourseDto>
}

' --- Backend Controller ---
class CourseController {
    + GetMyCourses(): Task<IActionResult>
}

' --- DTO ---
class InstructorCourseDto {
    + CourseId: int
    + Title: string
    + Status: string
    + TotalStudents: int
    + AverageRating: decimal
}

' --- Services ---
interface ICourseQueryService {
    + GetCoursesByInstructorAsync(instructorId: int): Task<IEnumerable<InstructorCourseDto>>
}

class CourseQueryService {
    + GetCoursesByInstructorAsync(instructorId: int): Task<IEnumerable<InstructorCourseDto>>
}

' --- Repositories ---
interface ICourseRepository {
    + GetInstructorCoursesAsync(instructorId: int): Task<IEnumerable<Course>>
    + GetCourseStatsAsync(courseIds: IEnumerable<int>): Task<IEnumerable<CourseStats>>
}

class CourseRepository {
    + GetInstructorCoursesAsync(instructorId: int): Task<IEnumerable<Course>>
    + GetCourseStatsAsync(courseIds: IEnumerable<int>): Task<IEnumerable<CourseStats>>
}

' --- Entities & DbContext ---
class Course {
    + CourseId: int
    + InstructorId: int?
    + Title: string
}

class CourseStats {
    + CourseId: int
    + EnrollmentCount: int
    + AverageRating: decimal
}

class Instructor {
    + InstructorId: int
}

' --- DbContext represented as a class for compatibility ---
class ApplicationDbContext


' === RELATIONSHIPS ===

' Frontend to Backend Dependency
InstructorCourseController ..> CourseController

' ViewModel/DTO Dependencies
InstructorCourseController ..> InstructorCourseIndexViewModel
CourseController ..> InstructorCourseDto
CourseQueryService ..> InstructorCourseDto
CourseQueryService ..> Course

' Dependency Injection (Unidirectional Association)
CourseController --> ICourseQueryService
CourseQueryService --> ICourseRepository
CourseRepository --> ApplicationDbContext

' Repository to Entity Dependency
CourseRepository ..> Course
CourseRepository ..> CourseStats

' Entity Relationships
Instructor *-- Course
Course *-- CourseStats

' Interface Realization
CourseQueryService ..|> ICourseQueryService
CourseRepository ..|> ICourseRepository

@enduml
