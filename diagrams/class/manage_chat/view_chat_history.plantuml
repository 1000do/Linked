@startuml ViewChatHistory_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor #1A73E8
    ArrowColor #5F6368
}

!define ABSTRACT_COLOR #FFE6CC
!define SERVICE_COLOR #CCE5FF
!define DTO_COLOR #E6CCFF
!define ENTITY_COLOR #CCFFE6
!define REPOSITORY_COLOR #FFFFCC
!define CONTROLLER_COLOR #FFE6E6
!define DbContext #E6F3FF

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F9F9F9
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class "ChatController" as FrontendController <<frontend controller>> #FFE6E6 {
    + GetHistory(roomId: int) : Task<IActionResult>
}

' ==================== BACKEND - CONTROLLER ====================

class "ChatController" as BackendController <<backend controller>> #FFE6E6 {
    - _chatService : IChatService
    + GetChatHistory(roomId: int) : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class MessageDto #E6CCFF {
    + MessageId : int
    + ChatId : int
    + SenderId : int?
    + SenderName : string
    + SenderAvatar : string?
    + Content : string
    + IsSeen : bool
    + MessageStatus : string
    + SentAt : DateTime?
    + Attachments : List<AttachmentDto>
}

class AttachmentDto #E6CCFF {
    + AttachmentId : int
    + FileUrl : string
    + FileName : string?
    + FileType : string?
    + FileSize : long?
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class Chat #CCFFE6 {
    + ChatId : int
    + ChatName : string?
    + ChatType : string
    + ContextType : string?
    + ContextId : int?
    + CreatedAt : DateTime?
    + LastMessageAt : DateTime?
}

class Message #CCFFE6 {
    + MessageId : int
    + ChatId : int
    + SenderId : int?
    + Content : string
    + IsSeen : bool
    + MessageStatus : string
    + SentAt : DateTime?
    + ReceivedAt : DateTime?
}

class MessageAttachment #CCFFE6 {
    + AttachmentId : int
    + MessageId : int
    + FileUrl : string
    + FileName : string?
    + FileType : string?
    + FileSize : long?
    + CreatedAt : DateTime?
}

class Account #CCFFE6 {
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
}

class User #CCFFE6 {
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

class Manager #CCFFE6 {
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface IChatService #FFE6CC {
    //+ GetChatHistoryAsync(chatId: int, accountId: int) : Task<List<MessageDto>>//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface IChatRepository #FFE6CC {
    //+ GetMessagesByChatIdAsync(chatId: int) : Task<List<Message>>//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class ChatService #CCE5FF {
    - _repo : IChatRepository
    + GetChatHistoryAsync(chatId: int, accountId: int) : Task<List<MessageDto>>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class ChatRepository #FFFFCC {
    - _context : AppDbContext
    + GetMessagesByChatIdAsync(chatId: int) : Task<List<Message>>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #E6F3FF {
    + Accounts : DbSet<Account>
    + Users : DbSet<User>
    + Managers : DbSet<Manager>
    + Chats : DbSet<Chat>
    + Messages : DbSet<Message>
    + MessageAttachments : DbSet<MessageAttachment>
}

' ==================== RELATIONSHIPS ====================

' === COMPOSITION (filled diamond) ===
Account *-- User
Account *-- Manager
Chat *-- Message
Message *-- MessageAttachment
MessageDto *-- AttachmentDto

' === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
Message --> Account
BackendController --> IChatService
ChatService --> IChatRepository
ChatRepository --> AppDbContext

' === INTERFACE REALIZATION ===
ChatService ..|> IChatService
ChatRepository ..|> IChatRepository

' === DEPENDENCY (dashed arrows) ===
FrontendController ..> BackendController
BackendController ..> MessageDto
ChatService ..> MessageDto
ChatRepository ..> Message

@enduml
