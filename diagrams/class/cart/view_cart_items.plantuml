@startuml ViewCartItems_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor #1A73E8
    ArrowColor #5F6368
}

!define ABSTRACT_COLOR #FFE6CC
!define SERVICE_COLOR #CCE5FF
!define DTO_COLOR #E6CCFF
!define ENTITY_COLOR #CCFFE6
!define REPOSITORY_COLOR #FFFFCC
!define CONTROLLER_COLOR #FFE6E6
!define DbContext #E6F3FF

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F9F9F9
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class "CartController" as CartControllerFE <<frontend controller>> #FFE6E6 {
    + Index() : Task<IActionResult>
    - GetCouponMapFromCookie() : Dictionary<int, string>
    - SaveCouponMapToCookie(map: Dictionary<int, string>) : void
}

class CartViewModel #E6CCFF {
    + Items : List<CartItemViewModel>
    + SubTotal : decimal
    + DiscountAmount : decimal
    + Total : decimal
    + AppliedCouponCode : string?
    + CouponMessage : string?
    + HasDiscount : bool
    + AvailableCoupons : List<AvailableCouponViewModel>
}

class CartItemViewModel #E6CCFF {
    + CourseId : int
    + Title : string
    + ThumbnailUrl : string?
    + InstructorName : string?
    + Price : decimal
    + OriginalPrice : decimal
    + DiscountedPrice : decimal
    + AppliedCouponCode : string?
    + DiscountAmount : decimal
}

class AvailableCouponViewModel #E6CCFF {
    + CouponCode : string
    + CouponType : string
    + DiscountValue : decimal
    + MinOrderValue : decimal
    + EndDate : DateTime?
    + IsEligible : bool
    + ConditionMessage : string
    + CourseId : int?
}

' ==================== BACKEND - CONTROLLER ====================

class "CartController" as CartControllerBE <<backend controller>> #FFE6E6 {
    - _cartService : ICartService
    + GetSummary(couponCode: string?) : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class CartSummaryResponse #E6CCFF {
    + Items : List<CartItemDto>
    + SubTotal : decimal
    + DiscountAmount : decimal
    + Total : decimal
    + AppliedCouponCode : string?
    + CouponMessage : string?
    + AvailableCoupons : List<AvailableCouponDto>
}

class CartItemDto #E6CCFF {
    + CourseId : int
    + Title : string
    + ThumbnailUrl : string?
    + InstructorName : string?
    + Price : decimal
    + OriginalPrice : decimal
    + DiscountedPrice : decimal
    + AppliedCouponCode : string?
    + DiscountAmount : decimal
}

class AvailableCouponDto #E6CCFF {
    + CouponCode : string
    + CouponType : string
    + DiscountValue : decimal
    + MinOrderValue : decimal
    + EndDate : DateTime?
    + IsEligible : bool
    + ConditionMessage : string
    + CourseId : int?
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class CartItem #CCFFE6 {
    + Id : int
    + UserId : int?
    + CourseId : int?
    + AddedDate : DateTime?
    + Price : decimal?
    + Course : Course?
    + User : User?
}

class Course #CCFFE6 {
    + CourseId : int
    + InstructorId : int?
    + CategoryId : int?
    + CouponId : int?
    + Title : string
    + Description : string?
    + Price : decimal
    + CourseThumbnailUrl : string?
    + CreatedAt : DateTime?
    + UpdatedAt : DateTime?
    + CourseStatus : string?
    + CourseFlagCount : int?
    + CourseAiIntegrations : ICollection<CourseAiIntegration>
    + CartItems : ICollection<CartItem>
    + Category : Category?
    + Coupon : Coupon?
    + Enrollments : ICollection<Enrollment>
    + Instructor : Instructor?
    + Lessons : ICollection<Lesson>
    + OrderItems : ICollection<OrderItem>
    + WishlistItems : ICollection<WishlistItem>
    + CourseExt : CourseExt?
    + WhatYouWillLearn : string?
    + Requirements : string?
    + ModerationFeedback : string?
    + LastApprovedAt : DateTime?
    + IsRemoved : bool
    + ThreatLevel : AiThreatLevel
}

class Coupon #CCFFE6 {
    + CouponId : int
    + ManagerId : int?
    + CouponCode : string
    + CouponType : string?
    + DiscountValue : decimal
    + MinOrderValue : decimal
    + StartDate : DateTime?
    + EndDate : DateTime?
    + UsageLimit : int?
    + UsedCount : int?
    + IsActive : bool?
    + Courses : ICollection<Course>
    + Manager : Manager?
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface ICartService #FFE6CC {
    //+ GetCartSummaryAsync(userId: int, couponCode: string?) : Task<CartSummaryResponse>//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface ICartRepository #FFE6CC {
    //+ GetCartItemsWithDetailsAsync(userId: int) : Task<List<CartItem>>//
}

interface ICourseRepository #FFE6CC {
    //+ IsEnrolledAsync(userId: int, courseId: int) : Task<bool>//
}

interface ICouponRepository #FFE6CC {
    //+ GetByCodeAsync(code: string) : Task<Coupon?>//
    //+ GetActiveAvailableCouponsAsync(now: DateTime) : Task<List<Coupon>>//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CartService #CCE5FF {
    - _repo : ICartRepository
    - _courseRepo : ICourseRepository
    - _couponRepo : ICouponRepository
    + GetCartSummaryAsync(userId: int, couponCode: string?) : Task<CartSummaryResponse>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CartRepository #FFFFCC {
    - _context : AppDbContext
    + GetCartItemsWithDetailsAsync(userId: int) : Task<List<CartItem>>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #E6F3FF {
    + CartItems : DbSet<CartItem>
    + Courses : DbSet<Course>
    + Coupons : DbSet<Coupon>
}

' ==================== RELATIONSHIPS ====================

' === UNIDIRECTIONAL ASSOCIATION ===
CartControllerBE --> ICartService
CartService --> ICartRepository
CartService --> ICourseRepository
CartService --> ICouponRepository
CartRepository --> AppDbContext
' === COMPOSITION / BIDIRECTIONAL ASSOCIATION ===
Coupon -- Course
Course -- CartItem
CartViewModel *-- CartItemViewModel
CartViewModel *-- AvailableCouponViewModel
CartSummaryResponse *-- CartItemDto
CartSummaryResponse *-- AvailableCouponDto

' === INTERFACE REALIZATION ===
CartService ..|> ICartService
CartRepository ..|> ICartRepository

' === DEPENDENCY ===
CartControllerFE ..> CartControllerBE
CartControllerFE ..> CartViewModel
CartControllerBE ..> CartSummaryResponse
CartService ..> CartSummaryResponse
CartService ..> CartItemDto
CartService ..> AvailableCouponDto
CartRepository ..> CartItem

@enduml
