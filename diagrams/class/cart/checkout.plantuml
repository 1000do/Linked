@startuml Checkout_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor #1A73E8
    ArrowColor #5F6368
}

!define ABSTRACT_COLOR #FFFFFF
!define SERVICE_COLOR #FFFFFF
!define DTO_COLOR #FFFFFF
!define ENTITY_COLOR #FFFFFF
!define REPOSITORY_COLOR #FFFFFF
!define CONTROLLER_COLOR #FFFFFF
!define DB_COLOR #FFFFFF

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class CartControllerFE #FFFFFF {
    + Checkout() : Task<IActionResult>
    + DirectCheckout(id: int) : Task<IActionResult>
    + CheckoutSuccess(sessionId: string?, paymentIntent: string?, paymentIntentId: string?) : Task<IActionResult>
    + CheckoutCancel(orderId: int) : Task<IActionResult>
}

class CheckoutViewModel #FFFFFF {
    + PublishableKey : string
    + ClientSecret : string
    + PaymentIntentId : string
    + Email : string
    + Cart : CartViewModel
}

' ==================== BACKEND - CONTROLLER ====================

class CheckoutControllerBE #FFFFFF {
    - _checkoutService : ICheckoutService
    - _authService : IAuthService
    + Process(request: CheckoutRequest) : Task<IActionResult>
    + CreateIntent(request: CheckoutRequest) : Task<IActionResult>
    + DirectProcess(request: DirectCheckoutRequest) : Task<IActionResult>
    + Success(sessionId: string) : Task<IActionResult>
    + SuccessIntent(paymentIntentId: string) : Task<IActionResult>
    + Cancel(orderId: int) : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class CheckoutRequest #FFFFFF {
    + CouponCode : string?
    + SuccessUrl : string
    + CancelUrl : string
}

class DirectCheckoutRequest #FFFFFF {
    + CourseId : int
}

class CheckoutResponse #FFFFFF {
    + SessionUrl : string
    + SessionId : string
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class OrderInfo #FFFFFF {
    + OrderId : int
    + UserId : int?
    + OrderDate : DateTime?
    + OrderStatus : string?
    + PaymentMethod : string?
    + OrderItems : ICollection<OrderItem>
    + User : User?
}

class OrderItem #FFFFFF {
    + Id : int
    + OrderId : int?
    + CourseId : int?
    + PurchasePrice : decimal
    + CouponUsed : bool?
    + OriginalPrice : decimal?
    + CouponCode : string?
    + CouponType : string?
    + DiscountAmount : decimal
    + Course : Course?
    + Order : OrderInfo?
    + Transactions : ICollection<Transaction>
}

class Transaction #FFFFFF {
    + TransactionId : int
    + OrderItemId : int?
    + AccountFrom : int?
    + AccountTo : int?
    + Amount : decimal
    + TransferRate : decimal
    + StripeSessionId : string?
    + StripePaymentintentId : string?
    + Currency : string?
    + TransactionsStatus : string?
    + TransactionType : string?
    + TransactionCreatedAt : DateTime?
    + TransactionExt : TransactionExt?
    + OrderItem : OrderItem?
    + AccountFromNavigation : Account?
    + AccountToNavigation : Account?
    + InstructorPayouts : ICollection<InstructorPayout>
}

class InstructorPayout #FFFFFF {
    + PayoutId : int
    + TransactionId : int?
    + InstructorId : int?
    + PayoutAmount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + PayoutStatus : string
    + StripeTransferId : string?
    + StripePayoutId : string?
    + PaidToBankAt : DateTime?
    + Transaction : Transaction?
    + Instructor : Instructor?
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface ICheckoutService #FFFFFF {
    //+ InitiateCheckoutAsync(userId: int, couponCode: string?, successUrl: string, cancelUrl: string) : Task<CheckoutResponse>//
    //+ InitiateDirectCheckoutAsync(userId: int, courseId: int, couponCode: string?, successUrl: string, cancelUrl: string) : Task<CheckoutResponse>//
    //+ InitiatePaymentIntentAsync(userId: int, couponCode: string?) : Task<CheckoutResponse>//
    //+ ProcessPaymentSuccessAsync(sessionId: string, failOnTransferFailure: bool) : Task//
    //+ ProcessPaymentIntentSuccessAsync(paymentIntentId: string) : Task//
    //+ ProcessPaymentCancelAsync(orderId: int) : Task//
}

interface IAuthService #FFFFFF {
    //+ IsEmailVerifiedAsync(userId: int) : Task<bool>//
}

interface IPaymentGatewayService #FFFFFF {
    //+ CreateCheckoutSessionAsync(lineItems: List<PaymentLineItem>, successUrl: string, cancelUrl: string, customerEmail: string?, clientReferenceId: string?, currency: string?, paymentIntentId: string?, stripeAccountId: string?, metadata: Dictionary<string, string>?) : Task<PaymentSessionResult>//
    //+ CreatePaymentIntentAsync(amount: decimal, currency: string, metadata: Dictionary<string, string>?) : Task<(string ClientSecret, string PaymentIntentId)>//
    //+ GetPaymentReferenceAsync(sessionId: string) : Task<string?>//
    //+ GetSessionMetadataAsync(sessionId: string) : Task<Dictionary<string, string>?>//
    //+ GetPaymentIntentMetadataAsync(paymentIntentId: string) : Task<Dictionary<string, string>?>//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface ICheckoutRepository #FFFFFF {
    //+ GetCartItemsWithCourseAndInstructorAsync(userId: int) : Task<List<CartItem>>//
    //+ GetTransactionsBySessionIdAsync(stripeSessionId: string) : Task<List<Transaction>>//
    //+ AddOrderAsync(order: OrderInfo) : Task//
    //+ AddOrderItemAsync(item: OrderItem) : Task//
    //+ AddTransactionAsync(transaction: Transaction) : Task//
    //+ AddInstructorPayoutAsync(payout: InstructorPayout) : Task//
    //+ ClearCartAsync(userId: int) : Task//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class CheckoutService #FFFFFF {
    - _repo : ICheckoutRepository
    - _enrollmentRepo : IEnrollmentRepository
    - _paymentGateway : IPaymentGatewayService
    - _courseRepo : ICourseRepository
    - _couponRepo : ICouponRepository
    - _userRepo : IUserRepository
    + InitiateCheckoutAsync(userId: int, couponCode: string?, successUrl: string, cancelUrl: string) : Task<CheckoutResponse>
    + InitiateDirectCheckoutAsync(userId: int, courseId: int, couponCode: string?, successUrl: string, cancelUrl: string) : Task<CheckoutResponse>
    + InitiatePaymentIntentAsync(userId: int, couponCode: string?) : Task<CheckoutResponse>
    + ProcessPaymentSuccessAsync(sessionId: string, failOnTransferFailure: bool) : Task
    + ProcessPaymentIntentSuccessAsync(paymentIntentId: string) : Task
    + ProcessPaymentCancelAsync(orderId: int) : Task
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class CheckoutRepository #FFFFFF {
    - _context : AppDbContext
    + GetCartItemsWithCourseAndInstructorAsync(userId: int) : Task<List<CartItem>>
    + GetTransactionsBySessionIdAsync(stripeSessionId: string) : Task<List<Transaction>>
    + AddOrderAsync(order: OrderInfo) : Task
    + AddOrderItemAsync(item: OrderItem) : Task
    + AddTransactionAsync(transaction: Transaction) : Task
    + AddInstructorPayoutAsync(payout: InstructorPayout) : Task
    + ClearCartAsync(userId: int) : Task
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #FFFFFF {
    + OrderInfos : DbSet<OrderInfo>
    + OrderItems : DbSet<OrderItem>
    + Transactions : DbSet<Transaction>
    + InstructorPayouts : DbSet<InstructorPayout>
}

' ==================== RELATIONSHIPS ====================

' === COMPOSITION (filled diamond) ===
OrderInfo *-- OrderItem

' === UNIDIRECTIONAL ASSOCIATION ===
CheckoutControllerBE --> ICheckoutService
CheckoutControllerBE --> IAuthService
CheckoutService --> ICheckoutRepository
CheckoutService --> IPaymentGatewayService
CheckoutRepository --> AppDbContext

' === BIDIRECTIONAL ASSOCIATION ===
OrderItem -- Transaction
Transaction -- InstructorPayout

' === INTERFACE REALIZATION ===
CheckoutService ..|> ICheckoutService
CheckoutRepository ..|> ICheckoutRepository

' === DEPENDENCY ===
CartControllerFE ..> CheckoutControllerBE
CartControllerFE ..> CheckoutViewModel
CheckoutControllerBE ..> CheckoutRequest
CheckoutControllerBE ..> DirectCheckoutRequest
CheckoutControllerBE ..> CheckoutResponse
CheckoutService ..> CheckoutRequest
CheckoutService ..> DirectCheckoutRequest
CheckoutService ..> CheckoutResponse
CheckoutService ..> OrderInfo
CheckoutService ..> OrderItem
CheckoutService ..> Transaction
CheckoutService ..> InstructorPayout
CheckoutRepository ..> OrderInfo
CheckoutRepository ..> OrderItem
CheckoutRepository ..> Transaction
CheckoutRepository ..> InstructorPayout

@enduml
