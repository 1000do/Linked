@startuml ForgetPassword_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor #1A73E8
    ArrowColor #5F6368
}

!define ABSTRACT_COLOR #FFE6CC
!define SERVICE_COLOR #CCE5FF
!define DTO_COLOR #E6CCFF
!define ENTITY_COLOR #CCFFE6
!define REPOSITORY_COLOR #FFFFCC
!define CONTROLLER_COLOR #FFE6E6
!define DbContext #E6F3FF

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F9F9F9
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class AccountControllerFE #FFE6E6 {
    - _httpClientFactory : IHttpClientFactory
    + ForgotPassword() : IActionResult
    + ForgotPassword(email: string) : Task<IActionResult>
    + VerifyOtp() : IActionResult
    + VerifyOtp(otp: string) : Task<IActionResult>
    + ResetPassword() : IActionResult
    + ResetPassword(email: string, otp: string, newPassword: string) : Task<IActionResult>
}

' ==================== BACKEND - CONTROLLER ====================

class AuthControllerBE #FFE6E6 {
    - _authService : IAuthService
    + ForgotPassword(email: string) : Task<IActionResult>
    + VerifyOtpForReset(request: VerifyOtpRequest) : IActionResult
    + ResetPassword(request: ResetPasswordRequest) : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class VerifyOtpRequest #E6CCFF {
    + Email : string
    + Otp : string
}

class ResetPasswordRequest #E6CCFF {
    + Email : string
    + Otp : string
    + NewPassword : string
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class Account #CCFFE6 {
    + AccountId : int <<PK>>
    + Email : string
    + PasswordHash : string?
    + AuthProvider : string
    + IsVerified : bool
    + AccountUpdatedAt : DateTime
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface IAuthService #FFE6CC {
    //+ ForgotPasswordAsync(email: string) : Task<string>//
    //+ VerifyOtpForReset(email: string, otp: string) : bool//
    //+ ResetPasswordAsync(email: string, otp: string, newPassword: string) : Task<bool>//
}

interface IOtpService #FFE6CC {
    //+ GenerateOtp(email: string, type: string) : string//
    //+ ValidateOtp(email: string, otp: string, type: string) : bool//
    //+ ConsumeOtp(email: string, otp: string, type: string) : bool//
}

interface IEmailService #FFE6CC {
    //+ SendEmailAsync(to: string, subject: string, body: string) : Task//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface IUserRepository #FFE6CC {
    //+ GetAccountByEmailAsync(email: string) : Task<Account?>//
    //+ UpdateAccountAsync(acc: Account) : Task//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class AuthService #CCE5FF {
    - _userRepo : IUserRepository
    - _otpService : IOtpService
    - _emailService : IEmailService
    + ForgotPasswordAsync(email: string) : Task<string>
    + VerifyOtpForReset(email: string, otp: string) : bool
    + ResetPasswordAsync(email: string, otp: string, newPassword: string) : Task<bool>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class UserRepository #FFFFCC {
    - _context : AppDbContext
    + GetAccountByEmailAsync(email: string) : Task<Account?>
    + UpdateAccountAsync(acc: Account) : Task
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #E6F3FF {
    + Accounts : DbSet<Account>
}

' ==================== RELATIONSHIPS ====================

' === UNIDIRECTIONAL ASSOCIATION ===
AccountControllerFE --> AuthControllerBE : calls via HTTP
AuthControllerBE --> IAuthService
AuthService --> IUserRepository
AuthService --> IOtpService
AuthService --> IEmailService
UserRepository --> AppDbContext

' === INTERFACE REALIZATION ===
AuthService ..|> IAuthService
UserRepository ..|> IUserRepository

' === DEPENDENCY ===
AuthControllerBE ..> VerifyOtpRequest : uses
AuthControllerBE ..> ResetPasswordRequest : uses
IAuthService ..> ResetPasswordRequest : uses
AuthService ..> Account : updates
UserRepository ..> Account : queries/updates

@enduml
