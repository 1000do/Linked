' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class NotificationService #CCE5FF {
    - _repo : INotificationRepository
    - _userRepo : IUserRepository
    - _hubContext : IHubContext<NotificationHub>
    + GetNotificationsForUserAsync(userId: int, page: int, pageSize: int) : Task<PagedResult<NotificationResponseDto>>
    + GetAllNotificationsAsync(page: int, pageSize: int) : Task<PagedResult<NotificationResponseDto>>
    + SendNotificationAsync(receiverId: int, title: string, content: string, linkAction: string?) : Task<bool>
    + DeleteNotificationAsync(notiId: int, userId: int) : Task<bool>
    + MarkAsReadAsync(notificationId: int, userId: int) : Task<bool>
    + MarkAllAsReadAsync(userId: int) : Task<bool>
    + GetAllNotificationsForAdminAsync(page: int, pageSize: int) : Task<PagedResult<NotificationAdminResponseDto>>
    + SearchEmailsAsync(query: string, senderId: int, senderRole: string) : Task<List<string>>
    + GetUnreadCountAsync(userId: int) : Task<int>
    + SendAdvancedAsync(dto: NotificationAdvancedDto, senderId: int, senderRole: string) : Task<int>
    + SendBulkNotificationsAsync(dtos: IEnumerable<NotificationBulkDto>) : Task<bool>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class NotificationRepository #FFFFCC {
    - _context : AppDbContext
    + GetByReceiverIdAsync(userId: int, page: int, pageSize: int) : Task<(List<Notification> Items, int TotalCount)>
    + GetAllAsync(page: int, pageSize: int) : Task<(List<Notification> Items, int TotalCount)>
    + GetByIdAsync(id: int) : Task<Notification?>
    + Delete(notification: Notification) : void
    + AddAsync(notification: Notification) : Task<void>
    + AddRangeAsync(notifications: IEnumerable<Notification>) : Task<void>
    + Update(notification: Notification) : void
    + UpdateRange(notifications: IEnumerable<Notification>) : void
    + SaveChangesAsync() : Task<int>
    + GetUnreadByReceiverIdAsync(userId: int) : Task<List<Notification>>
    + GetUnreadCountAsync(userId: int) : Task<int>
    + AutoCleanupAdminNotificationsAsync() : Task<int>
    + GetSentNotificationsCountAsync(senderId: int) : Task<int>
}

class UserRepository #FFFFCC {
    - _context : AppDbContext
    + GetAccountByEmailAsync(email: string) : Task<Account?>
    + GetRoleByAccountIdAsync(accountId: int) : Task<string>
    + GetAllUserIdsAsync() : Task<List<int>>
    + GetUserIdsForStaffSenderAsync() : Task<List<int>>
    + GetUserIdsForAdminSenderAsync() : Task<List<int>>
    + SearchEmailsByQueryAsync(query: string, senderId: int, senderRole: string, take: int) : Task<List<string>>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #E6F3FF {
    + Accounts : DbSet<Account>
    + Users : DbSet<User>
    + Managers : DbSet<Manager>
    + Notifications : DbSet<Notification>
    ---
    # OnConfiguring(optionsBuilder: DbContextOptionsBuilder) : void
    # OnModelCreating(modelBuilder: ModelBuilder) : void
}

' ==================== RELATIONSHIPS ====================

' === COMPOSITION (filled diamond) ===
Account *-- User
Account *-- Manager
Account *-- Notification

' === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
BackendController --> INotificationService
BackendController --> IChatService
NotificationService --> INotificationRepository
NotificationService --> IUserRepository
NotificationRepository --> AppDbContext
UserRepository --> AppDbContext

' === INTERFACE REALIZATION ===
NotificationService ..|> INotificationService
NotificationRepository ..|> INotificationRepository
UserRepository ..|> IUserRepository

' === DEPENDENCY (dashed arrows) ===
FrontendController ..> BackendController
FrontendController ..> NotificationViewModel
BackendController ..> NotificationSendDto
BackendController ..> NotificationAdvancedDto
BackendController ..> NotificationAdminResponseDto
NotificationService ..> NotificationAdvancedDto
NotificationService ..> NotificationAdminResponseDto
NotificationService ..> Notification
NotificationRepository ..> Notification
UserRepository ..> Account

@enduml
