}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface INotificationRepository #FFE6CC {
    //+ GetByReceiverIdAsync(userId: int, page: int, pageSize: int) : Task<(List<Notification> Items, int TotalCount)>//
    //+ GetByIdAsync(id: int) : Task<Notification?>//
    //+ AddAsync(notification: Notification) : Task<void>//
    //+ AddRangeAsync(notifications: IEnumerable<Notification>) : Task<void>//
    //+ Delete(notification: Notification) : void//
    //+ Update(notification: Notification) : void//
    //+ UpdateRange(notifications: IEnumerable<Notification>) : void//
    //+ SaveChangesAsync() : Task<int>//
    //+ GetAllAsync(page: int, pageSize: int) : Task<(List<Notification> Items, int TotalCount)>//
