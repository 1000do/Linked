interface IUserRepository #FFE6CC {
    //+ GetAccountByEmailAsync(email: string) : Task<Account?>//
    //+ GetRoleByAccountIdAsync(accountId: int) : Task<string>//
    //+ GetAllUserIdsAsync() : Task<List<int>>//
    //+ GetUserIdsForStaffSenderAsync() : Task<List<int>>//
    //+ GetUserIdsForAdminSenderAsync() : Task<List<int>>//
    //+ SearchEmailsByQueryAsync(query: string, senderId: int, senderRole: string, take: int) : Task<List<string>>//
