@startuml ManageNotification_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor #1A73E8
    ArrowColor #5F6368
}

!define ABSTRACT_COLOR #FFE6CC
!define SERVICE_COLOR #CCE5FF
!define DTO_COLOR #E6CCFF
!define ENTITY_COLOR #CCFFE6
!define REPOSITORY_COLOR #FFFFCC
!define CONTROLLER_COLOR #FFE6E6
!define DbContext #E6F3FF

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F9F9F9
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class "NotificationController" as FrontendController <<frontend controller>> #FFE6E6 {
    - _api : ApiClient
    + Index() : Task<IActionResult>
    + GetListTiny() : Task<IActionResult>
    + Admin() : IActionResult
    + GetAllAdmin() : Task<IActionResult>
    + GetMyNotifications() : Task<IActionResult>
    + MarkAllAsRead() : Task<IActionResult>
    + MarkAsRead(id: int) : Task<IActionResult>
    + Delete(id: int) : Task<IActionResult>
    + SendAdvanced(payload: object) : Task<IActionResult>
    + GetUnreadSummary() : Task<IActionResult>
    + SearchEmails(query: string) : Task<IActionResult>
}

class NotificationViewModel #E6CCFF {
    + NotificationId : int
    + ReceiverId : int
    + ReceiverFullName : string?
    + ReceiverEmail : string?
    + Title : string
    + Content : string
    + LinkAction : string?
    + IsRead : bool
    + CreatedAt : DateTime?
    + ReceiverRole : string?
    + SenderId : int?
    + SenderRole : string?
}

' ==================== BACKEND - CONTROLLER ====================

class "NotificationController" as BackendController <<backend controller>> #FFE6E6 {
    - _notiService : INotificationService
    - _chatService : IChatService
    + GetMyNotifications(page: int, pageSize: int) : Task<IActionResult>
    + GetAllNotifications(page: int, pageSize: int) : Task<IActionResult>
    + MarkAllAsRead() : Task<IActionResult>
    + MarkAsRead(id: int) : Task<IActionResult>
    + Delete(id: int) : Task<IActionResult>
    + SearchEmails(query: string) : Task<IActionResult>
    + SendTest(dto: NotificationSendDto) : Task<IActionResult>
    + SendAdvanced(dto: NotificationAdvancedDto) : Task<IActionResult>
    + GetUnreadSummary() : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class NotificationSendDto #E6CCFF {
    + ReceiverId : int
    + Title : string
    + Content : string
}

class NotificationAdvancedDto #E6CCFF {
    + TargetType : string
    + Emails : List<string>?
    + Title : string
    + Content : string
    + LinkAction : string?
}

class NotificationAdminResponseDto #E6CCFF {
    + NotificationId : int
    + Title : string?
    + Content : string?
    + IsRead : bool?
    + CreatedAt : DateTime?
    + ReceiverEmail : string?
    + ReceiverFullName : string?
    + ReceiverRole : string?
    + ReceiverId : int?
    + SenderId : int?
    + SenderRole : string?
    + LinkAction : string?
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class Notification #CCFFE6 {
    + NotificationId : int
    + SenderId : int?
    + ReceiverId : int?
    + Title : string?
    + Content : string?
    + LinkAction : string?
    + IsRead : bool?
    + IsRemoved : bool?
    + CreatedAt : DateTime?
    + Receiver : Account?
    + Sender : Account?
}

class Account #CCFFE6 {
    + AccountId : int
    + Email : string
    + Username : string?
    + PasswordHash : string?
    + PhoneNumber : string?
    + AccountStatus : string?
    + AccountFlagCount : int?
    + AccountLastLoginAt : DateTime?
    + AuthProvider : string?
    + AvatarUrl : string?
    + RefreshToken : string?
    + RefreshTokenExpiryTime : DateTime?
    + IsVerified : bool
    + AccountCreatedAt : DateTime?
    + AccountUpdatedAt : DateTime?
    + User : User?
    + Manager : Manager?
    + NotificationReceivers : ICollection<Notification>
    + NotificationSenders : ICollection<Notification>
}

class User #CCFFE6 {
    + UserId : int
    + FullName : string
    + Bio : string?
    + DateOfBirth : DateOnly?
}

class Manager #CCFFE6 {
    + ManagerId : int
    + Role : string?
    + DisplayName : string
    + FullName : string?
    + PhoneNumber : string?
    + AvatarUrl : string?
    + Bio : string?
}

' ==================== BACKEND - SERVICE INTERFACES ====================

