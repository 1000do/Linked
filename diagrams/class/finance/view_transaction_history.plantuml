@startuml ViewTransactionHistory_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor #333333
    ArrowColor #333333
}

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class TransactionControllerFE #FFFFFF {
    + Instructor(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?) : Task<IActionResult>
}

class TransactionPagedVM #FFFFFF {
    - Items : List<TransactionListItemVM>
    - TotalCount : int
    - Page : int
    - PageSize : int
    - TotalPages : int
}

class TransactionListItemVM #FFFFFF {
    - TransactionId : int
    - StripeSessionId : string?
    - Date : DateTime?
    - Amount : decimal
    - Status : string?
    - BuyerName : string
    - CourseTitle : string
    - InstructorName : string
}

' ==================== BACKEND - CONTROLLER ====================

class TransactionControllerBE #FFFFFF {
    - _transactionService : ITransactionService
    + GetInstructorTransactions(page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class TransactionListDto #FFFFFF {
    - TransactionId : int
    - StripeSessionId : string?
    - Date : DateTime?
    - Amount : decimal
    - Status : string?
    - BuyerName : string
    - CourseTitle : string
    - InstructorName : string
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class Transaction #FFFFFF {
    - TransactionId : int
    - OrderItemId : int?
    - AccountFrom : int?
    - AccountTo : int?
    - Amount : decimal
    - TransferRate : decimal
    - StripeSessionId : string?
    - StripePaymentintentId : string?
    - Currency : string?
    - TransactionsStatus : string?
    - TransactionType : string?
    - TransactionCreatedAt : DateTime?
    - TransactionExt : TransactionExt?
    - OrderItem : OrderItem?
    - AccountFromNavigation : Account?
    - AccountToNavigation : Account?
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface ITransactionService #FFFFFF {
    //+ GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<TransactionListDto>>//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface ITransactionRepository #FFFFFF {
    //+ GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<(List<TransactionListDto> Items, int TotalCount)>//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class TransactionService #FFFFFF {
    - _repo : ITransactionRepository
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<TransactionListDto>>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class TransactionRepository #FFFFFF {
    - _context : AppDbContext
    + GetInstructorTransactionsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<(List<TransactionListDto> Items, int TotalCount)>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #FFFFFF {
    + Transactions : DbSet<Transaction>
}

' ==================== RELATIONSHIPS ====================

' === COMPOSITION / AGGREGATION ===
TransactionPagedVM -down-* TransactionListItemVM

' === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
TransactionControllerFE -down..> TransactionControllerBE
TransactionControllerBE -down--> ITransactionService
TransactionService -down--> ITransactionRepository
TransactionRepository -down--> AppDbContext

' === INTERFACE REALIZATION ===
TransactionService -up..|> ITransactionService
TransactionRepository -up..|> ITransactionRepository

' === DEPENDENCY (dashed arrows) ===
TransactionControllerFE -left..> TransactionPagedVM
TransactionControllerBE -down..> TransactionListDto
TransactionService -down..> TransactionListDto
TransactionRepository -down..> TransactionListDto
TransactionRepository -down..> Transaction

@enduml
