@startuml ViewBalance_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor #333333
    ArrowColor #333333
}

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class TransactionControllerFE #FFFFFF {
    + Instructor(page: int, pageSize: int, year: int?, month: int?) : Task<IActionResult>
}

class InstructorFinancePageVM #FFFFFF {
    - Transactions : TransactionPagedVM
    - Payouts : InstructorPayoutPagedViewModel
    - CourseRevenues : List<InstructorCourseRevenueResponse>
}

class InstructorPayoutPagedViewModel #FFFFFF {
    - Items : List<InstructorPayoutViewModel>
    - TotalCount : int
    - Page : int
    - PageSize : int
    - TotalPages : int
}

class InstructorPayoutViewModel #FFFFFF {
    - PayoutId : int
    - TransactionId : int?
    - PayoutAmount : decimal
    - PayoutDate : DateTime
    - IsPaid : bool
    - PayoutStatus : string?
}

' ==================== BACKEND - CONTROLLER ====================

class InstructorControllerBE #FFFFFF {
    - _instructorService : IInstructorService
    + GetDashboard() : Task<IActionResult>
    + GetPayoutDays() : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class InstructorDashboardDto #FFFFFF {
    - InstructorId : int
    - TotalStudents : int
    - AverageRating : decimal
    - ActiveCoursesCount : int
    - TotalRevenue : decimal
    - StripeAccountId : string?
    - StripeOnboardingStatus : string?
    - PayoutsEnabled : bool
    - ChargesEnabled : bool
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class Instructor #FFFFFF {
    - InstructorId : int
    - ProfessionalTitle : string?
    - ExpertiseCategories : string?
    - LinkedinUrl : string?
    - YoutubeUrl : string?
    - FacebookUrl : string?
    - DocumentUrl : string?
    - ApprovalStatus : string?
    - RejectionReason : string?
    - StripeAccountId : string?
    - StripeOnboardingStatus : string?
    - PayoutsEnabled : bool
    - ChargesEnabled : bool
}

class InstructorPayout #FFFFFF {
    - PayoutId : int
    - TransactionId : int?
    - InstructorId : int?
    - PayoutAmount : decimal
    - PayoutDate : DateTime
    - IsPaid : bool
    - PayoutStatus : string
    - StripeTransferId : string?
    - StripePayoutId : string?
    - PaidToBankAt : DateTime?
    - Transaction : Transaction?
    - Instructor : Instructor?
}

class Transaction #FFFFFF {
    - TransactionId : int
    - OrderItemId : int?
    - AccountFrom : int?
    - AccountTo : int?
    - Amount : decimal
    - TransferRate : decimal
    - StripeSessionId : string?
    - StripePaymentintentId : string?
    - Currency : string?
    - TransactionsStatus : string?
    - TransactionType : string?
    - TransactionCreatedAt : DateTime?
    - TransactionExt : TransactionExt?
    - OrderItem : OrderItem?
    - AccountFromNavigation : Account?
    - AccountToNavigation : Account?
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface IInstructorService #FFFFFF {
    //+ GetInstructorDashboardAsync(userId: int) : Task<InstructorDashboardDto?>//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface IInstructorRepository #FFFFFF {
    //+ GetDashboardDtoAsync(userId: int) : Task<InstructorDashboardDto?>//
    //+ GetStatsAsync(userId: int) : Task<InstructorStats?>//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class InstructorService #FFFFFF {
    - _repo : IInstructorRepository
    + GetInstructorDashboardAsync(userId: int) : Task<InstructorDashboardDto?>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class InstructorRepository #FFFFFF {
    - _context : AppDbContext
    + GetDashboardDtoAsync(userId: int) : Task<InstructorDashboardDto?>
    + GetStatsAsync(userId: int) : Task<InstructorStats?>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #FFFFFF {
    + Instructors : DbSet<Instructor>
    + InstructorPayouts : DbSet<InstructorPayout>
    + Transactions : DbSet<Transaction>
}

' ==================== RELATIONSHIPS ====================

' === COMPOSITION / AGGREGATION ===
InstructorFinancePageVM -down-o InstructorPayoutPagedViewModel
InstructorPayoutPagedViewModel -down-* InstructorPayoutViewModel
Instructor -down-* InstructorPayout
Transaction -down* InstructorPayout

' === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
TransactionControllerFE -down..> InstructorControllerBE
InstructorControllerBE -down--> IInstructorService
InstructorService -down--> IInstructorRepository
InstructorRepository -down--> AppDbContext

' === INTERFACE REALIZATION ===
InstructorService -up..|> IInstructorService
InstructorRepository -up..|> IInstructorRepository

' === DEPENDENCY (dashed arrows) ===
TransactionControllerFE -left..> InstructorFinancePageVM
InstructorControllerBE -down..> InstructorDashboardDto
IInstructorService -down..> InstructorDashboardDto
InstructorService -down..> InstructorDashboardDto
InstructorRepository -down..> Instructor

@enduml
