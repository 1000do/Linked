@startuml FilterPayoutHistory_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor #333333
    ArrowColor #333333
}

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class TransactionControllerFE #FFFFFF {
    + Instructor(payoutKeyword: string?, payoutStatus: string?, year: int?, month: int?) : Task<IActionResult>
}

' ==================== BACKEND - CONTROLLER ====================

class InstructorControllerBE #FFFFFF {
    - _instructorService : IInstructorService
    + GetPayouts(keyword: string?, status: string?, year: int?, month: int?) : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class InstructorPayoutDto #FFFFFF {
    - PayoutId : int
    - Amount : decimal
    - PayoutDate : DateTime
    - IsPaid : bool
    - CourseTitle : string
    - TotalAmount : decimal
    - PayoutStatus : string?
    - PaidToBankAt : DateTime?
    - StripeTransferId : string?
    - StripePayoutId : string?
}

' ==================== BACKEND - DOMAIN ENTITIES ====================

class InstructorPayout #FFFFFF {
    - PayoutId : int
    - TransactionId : int?
    - InstructorId : int?
    - PayoutAmount : decimal
    - PayoutDate : DateTime
    - IsPaid : bool
    - PayoutStatus : string
    - StripeTransferId : string?
    - StripePayoutId : string?
    - PaidToBankAt : DateTime?
    - Transaction : Transaction?
    - Instructor : Instructor?
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface IInstructorService #FFFFFF {
    //+ GetPayoutsAsync(userId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<InstructorPayoutDto>>//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface IInstructorRepository #FFFFFF {
    //+ GetPayoutsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<InstructorPayoutDto>>//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class InstructorService #FFFFFF {
    - _repo : IInstructorRepository
    + GetPayoutsAsync(userId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<InstructorPayoutDto>>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class InstructorRepository #FFFFFF {
    - _context : AppDbContext
    + GetPayoutsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<InstructorPayoutDto>>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #FFFFFF {
    + InstructorPayouts : DbSet<InstructorPayout>
}

' ==================== RELATIONSHIPS ====================

' === UNIDIRECTIONAL ASSOCIATION (solid arrow) ===
TransactionControllerFE -down..> InstructorControllerBE
InstructorControllerBE -down--> IInstructorService
InstructorService -down--> IInstructorRepository
InstructorRepository -down--> AppDbContext

' === INTERFACE REALIZATION ===
InstructorService -up..|> IInstructorService
InstructorRepository -up..|> IInstructorRepository

' === DEPENDENCY (dashed arrows) ===
InstructorControllerBE -down..> InstructorPayoutDto
InstructorService -down..> InstructorPayoutDto
InstructorRepository -down..> InstructorPayoutDto
InstructorRepository -down..> InstructorPayout

@enduml
