@startuml FilterPayoutHistory_ClassDiagram

' Styling & Settings
skinparam style strictuml
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor #1A73E8
    ArrowColor #5F6368
}

!define ABSTRACT_COLOR #FFE6CC
!define SERVICE_COLOR #CCE5FF
!define DTO_COLOR #E6CCFF
!define REPOSITORY_COLOR #FFFFCC
!define CONTROLLER_COLOR #FFE6E6
!define DbContext #E6F3FF

skinparam backgroundColor #FFFFFF
skinparam classBackgroundColor #F9F9F9
skinparam classBorderColor #333333
skinparam arrowColor #333333

' ==================== FRONTEND ====================

class TransactionControllerFE #FFE6E6 {
    - _api : ApiClient
    + Instructor(payoutKeyword: string?, payoutStatus: string?, year: int?, month: int?) : Task<IActionResult>
}

' ==================== BACKEND - CONTROLLER ====================

class InstructorControllerBE #FFE6E6 {
    - _instructorService : IInstructorService
    + GetPayouts(keyword: string?, status: string?, year: int?, month: int?) : Task<IActionResult>
}

' ==================== BACKEND - DTOs ====================

class InstructorPayoutDto #E6CCFF {
    + PayoutId : int
    + Amount : decimal
    + PayoutDate : DateTime
    + IsPaid : bool
    + CourseTitle : string
    + PayoutStatus : string?
}

class PagedResult #E6CCFF {
    + Items : List<T>
    + TotalCount : int
}

' ==================== BACKEND - SERVICE INTERFACES ====================

interface IInstructorService #FFE6CC {
    //+ GetPayoutsAsync(userId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<InstructorPayoutDto>>//
}

' ==================== BACKEND - REPOSITORY INTERFACES ====================

interface IInstructorRepository #FFE6CC {
    //+ GetPayoutsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<InstructorPayoutDto>>//
}

' ==================== BACKEND - SERVICE IMPLEMENTATION ====================

class InstructorService #CCE5FF {
    - _repo : IInstructorRepository
    + GetPayoutsAsync(userId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<InstructorPayoutDto>>
}

' ==================== BACKEND - REPOSITORY IMPLEMENTATION ====================

class InstructorRepository #FFFFCC {
    - _context : AppDbContext
    + GetPayoutsAsync(instructorId: int, page: int, pageSize: int, keyword: string?, sortBy: string?, status: string?, year: int?, month: int?) : Task<PagedResult<InstructorPayoutDto>>
}

' ==================== BACKEND - DbContext ====================

class AppDbContext #E6F3FF {
}

' ==================== RELATIONSHIPS ====================

' === UNIDIRECTIONAL ASSOCIATION ===
TransactionControllerFE --> InstructorControllerBE : calls via HTTP with filter parameters
InstructorControllerBE --> IInstructorService
InstructorService --> IInstructorRepository
InstructorRepository --> AppDbContext

' === INTERFACE REALIZATION ===
InstructorService ..|> IInstructorService
InstructorRepository ..|> IInstructorRepository

' === DEPENDENCY ===
InstructorControllerBE ..> PagedResult : uses
IInstructorService ..> PagedResult : returns
IInstructorService ..> InstructorPayoutDto : uses
InstructorService ..> InstructorPayoutDto : creates
InstructorRepository ..> InstructorPayoutDto : filters and projects

@enduml
